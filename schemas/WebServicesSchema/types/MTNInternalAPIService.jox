    <JadeMethod name="getReserveDetailMatchingCargo" id="d470e802-2319-4376-9deb-ae7a9ad2dc9f">
        <updating/>
        <source>getReserveDetailMatchingCargo(cargoOid : String; releaseOid : String) : WS_GetBRReserveDetailResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2024	jlier1	Initial creation MTN-33003

*/

vars
	response : WS_GetBRReserveDetailResponse;
	term : CM_Terminal;
	 bulkRelease : CM_BulkRelease;
	 cargo  : CM_TrackedItem;
	 reserveDetail : CM_ReserveDetail;
	 matchedReserveSelection : CM_ReserveSelection;
	 reason : String;
		wsReserveDetail : WS_ReserveDetail;	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	term := app.myPassport.myTerminal;
	
	if term = null then
		self.httpStatusCode := HttpResponseSystemError;
		return response;
	endif;
	bulkRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
			
	if bulkRelease = null  then
		app.raiseCMException(Bulk_Release_Not_Found,null,null);
		return response;
	endif;
	
	cargo:=app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	if cargo = null or not cargo.isOnSite then 
		 app.raiseCMException1( Cargo_item_not_found_site,cargoOid,null,null );
	endif;
	
	if bulkRelease.allTrackedItemsReleased.includes(cargo) then
		app.raiseCMException2(NOT_VALID_PACK_PARENT,cargo.id,bulkRelease.code,null,null);
		return response;
	endif;
	
	foreach reserveDetail in bulkRelease.allReserveDetails where reserveDetail.isKindOf(CM_ReserveSelection) do
			
		if reserveDetail.includeTrackedItem(cargo, false) then //23/06/2023	navkc1	CR 58406 Task 58408
			matchedReserveSelection :=reserveDetail.CM_ReserveSelection;
				break;
		endif;	
		
		if cargo.isPackingComplete then
			 continue;
		endif;
		
		if not cargo.allBulkReleasesAssigned.isEmpty then
			//can't be a parent on multiple releases
			continue;
		endif;
			
		if cargo.testAgainstReserveSelection(reserveDetail.CM_ReserveSelection, reason, false, null ) then 
			matchedReserveSelection :=reserveDetail.CM_ReserveSelection;
			break;
		endif;
	endforeach;
	
	if matchedReserveSelection &lt;&gt; null then
		create wsReserveDetail transient;
		wsReserveDetail.setProxyFromObject(matchedReserveSelection);
		response.reserveDetail:=wsReserveDetail;
	else
		//app.raiseCMWarning1(Cargo_item_release_issue , reason, null,null,null);
		app.raiseCMWarning2(NOT_VALID_PACK_PARENT,cargo.id,bulkRelease.code &amp;  ". "  &amp; reason,null,null,null);
	endif;
	
	return response;
	
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="cargoOid" type="String"/>
        <Parameter name="releaseOid" type="String"/>
        <ReturnType type="WS_GetBRReserveDetailResponse"/>
    </JadeMethod>
    <JadeMethod name="getResourceTypeGroups" id="f58ef5e8-7549-4c4b-bbe8-504dea20ee55">
        <updating/>
        <source>getResourceTypeGroups() : WS_RestIntResTypeGroupResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	response				: WS_RestIntResTypeGroupResponse;
	resourceTypeGroup		: CM_ResourceTypeGroup;
	wsResourceTypeGroup		: WS_RestIntResourceTypeGroup;
	allResourceTypeGroups	: CM_ResourceTypeGroupByCode;
	term					: CM_Terminal;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	term := app.myPassport.myTerminal;
	
	if term = null then
		self.httpStatusCode := HttpResponseSystemError;
		return response;
	endif;
	
	allResourceTypeGroups := app.myRoot.allResourceTypeGroups;
	
	foreach resourceTypeGroup in allResourceTypeGroups do
		if resourceTypeGroup.isNotAvailableForEntry then
			continue;
		endif;
		create wsResourceTypeGroup transient;
		wsResourceTypeGroup.setProxyFromObject(resourceTypeGroup);
		response.allResourceTypeGroups.add(wsResourceTypeGroup);
		
	endforeach;
	
	return response;
	
epilog
	self.finaliseResponse(response);
	
end;</source>
        <ReturnType type="WS_RestIntResTypeGroupResponse"/>
    </JadeMethod>
    <JadeMethod name="getResourceTypes" id="44d34ad1-370a-415a-a94e-349d44835f24">
        <updating/>
        <source>getResourceTypes(_taskCode : String) : WS_RestIntResTypeResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2023	navma1	ChangeRequest 58761: EUP | VAS Mobile App - [53813.060] VAS Resource Groups
*/

vars
	response			: WS_RestIntResTypeResponse;
	resourceType		: CM_ResourceType;
	wsResourceType		: WS_RestIntResourceType;
	toDoTask			: CM_ToDoTaskDesc;
	obj					: CM_Object;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	toDoTask := app.myRoot.allToDoTaskDescriptions[_taskCode.Integer];
	
	if toDoTask = null then
		self.httpStatusCode := HttpResponseSystemError;
		return response;
	endif;
	
	foreach obj in toDoTask.allResourceTypes do
		resourceType := obj.CM_ResourceType;
		if not resourceType.isAvailable then
			continue;
		endif;
		
		create wsResourceType transient;
		wsResourceType.setProxyFromObject(resourceType);
		response.allResourceTypes.add(wsResourceType);

	endforeach;
	

	return response;
	
epilog
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="_taskCode" type="String"/>
        <ReturnType type="WS_RestIntResTypeResponse"/>
    </JadeMethod>
    <JadeMethod name="getRoadJobForTruck" id="3d64d485-8a6f-4a28-ae38-e6d69304a099">
        <updating/>
        <source>getRoadJobForTruck(truckId : String) : WS_RoadJobResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
14 September 2023		jlizm1	Initial creation TFS 59985 Truck Seals design changes

*/

vars
	response 		: WS_RoadJobResponse;
	roadJob 		: CM_RoadJob;
	wsRoadJob		: WS_RoadJob;
	truck			: CM_Vehicle;
	terminal		: CM_Terminal;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	truck := app.myPassport.getObjectOfTypeFromOid(truckId, CM_Vehicle).CM_Vehicle;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if truck = null then
		truck := terminal.vehicles[truckId.toUpper, ""];
		
		if truck = null then
			app.raiseCMException(Truck_not_found, null, null);
			return response;
		endif;
	endif;
	
	roadJob := truck.getCurrentRoadJob();
	
	if roadJob = null then
		app.raiseCMException1(Truck_does_not_have_road, truck.regNumber, null, null);
		return response;
	endif;
	
	create wsRoadJob transient;
	wsRoadJob.setProxyFromObject(roadJob);
	response.myRoadJob := wsRoadJob;
	
	return response;
	
epilog
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="truckId" type="String"/>
        <ReturnType type="WS_RoadJobResponse"/>
    </JadeMethod>
    <JadeMethod name="getRoadReleaseSummary" id="10c3dede-0145-4b70-860e-b6e0edccb540">
        <updating/>
        <source>getRoadReleaseSummary(releaseID : String): WS_ReleaseSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
14 June 2019	jlger1	Initial creation
17 July 2019	jlgrr1	
06 Aug 2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
07 Apr 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
10 Apr 2025		navma1	MTN-34595 	DPH - Release Staging – Improve Performance of getRoadReleaseSummary() API
*/

vars
	response 		: WS_ReleaseSummaryResponse;
	releaseSummary 	: WS_ReleaseRequestSummary;
	bulkRelease		: CM_BulkRelease;
	failedDAC		: CM_DataAccessController ;
	releaseNumber   : String;
	user			: CM_User;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
		
	create response transient;
	
	if releaseID.trimBlanks = null then
		app.raiseCMException(Input_required_field_relNum,null,null);
		return response;
	endif;
	
	//epr TFS 46632 23/9/19 
	releaseNumber := releaseID.trimBlanks.toUpper.asStringRESTFUL;
	bulkRelease   := app.myPassport.myTerminal.allBulkReleaseByTypeByStByCd.getAtKeyGeq(BR_TYPE_ROAD,BR_ACTIVE,releaseNumber, null );

	if bulkRelease = null or bulkRelease.type &lt;&gt; BR_TYPE_ROAD or bulkRelease.status &lt;&gt; BR_ACTIVE or bulkRelease.code &lt;&gt; releaseNumber then
		app.raiseCMException1(Bulk_Release_Not_Found,releaseNumber ,null,null);
		return response;
	endif;
	
	user := app.getMyUser;		 //14.04.2025 navma1 #MTN-34595
	
	if not bulkRelease.canUserAccessSelf(user,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,user.userName,bulkRelease.code,null, null,null);
		return response;
	endif;		
	
	create releaseSummary transient;
	releaseSummary.setProxyFromObject(bulkRelease);
	
	//releaseSummary.setProxyReserveDetails(bulkRelease); // jlier1 26/7/21 TFS 51626  //14.04.2025 navma1 #MTN-34595
	releaseSummary.setProxyRoadRelSummary(bulkRelease);   //14.04.2025 navma1 #MTN-34595
	response.releaseRequestSummary := releaseSummary;
	
	return response;
epilog	
	self.finaliseResponse(response);
end;</source>
        <Parameter name="releaseID" type="String"/>
        <ReturnType type="WS_ReleaseSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getSSOPublicInfo" id="a5f3f7e2-e9e4-411c-9e1c-d10691ac51f2">
        <updating/>
        <source>getSSOPublicInfo() : WS_SSOConfigResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2025	navnk30	JIRA 34701: SSO Implementation for Vehicle App - Jade Portion

*/

vars
	response	: WS_SSOConfigResponse;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportPartial();
	
	app.writeLog(method.qualifiedName, LogTRACE);
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;
	
	create response transient;
	response.tenantId := app.myRoot.getConfig(SsoAzureTenantId).StringUtf8;
	response.clientId := app.myRoot.getConfig(SsoAzureClientId).StringUtf8;
	
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_SSOConfigResponse"/>
    </JadeMethod>
    <JadeMethod name="getScanCargoGroups" id="9c6bab9d-91a6-42c8-8c96-a3caa6b37dcd">
        <updating/>
        <source>getScanCargoGroups(_mode : String) : WS_CargoGroupsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2023	jlier1	Initial creation 59948
22 Feb 2024 navhl20 ChangeRequest 62406:[62534] EUP | Scanning App Cargo Group Overview Changes
27 Feb 2024 navhl20 Bug 62645: EUP - Cargo Scanning - Internal Server error on the Unpack Mode
27 Feb 2024 navhl20 Bug 62644: EUP - Cargo Scanning - On the Sort Out mode when selecting the Booking or BOL and clicking on the Overview button throws an error 
28 Mar 2024 navbk1  Bug 63193: EUP | Scanning App Cargo Group Overview Changes
24 Apr 2024 navbk1  Bug 63811: EUP | Scanning App Cargo Group Overview Changes - Part 2
25 Jun 2024 navbk1  Bug 64807: FR | 53856 - New Scanning App - Cargo Group Overview - part 3
12 Aug 2024 navbk1  Bug 65344: FR | 53856 - New Scanning App - Cargo Group Overview - Cargo groups not found
*/
constants
	Ship 	:	String = "ship";
	Road 	:	String = "road";
	Rail 	:	String = "rail";
	Unpack 	:	String = "unpack";
	Sortout	:	String = "sortout";
vars
	response : WS_CargoGroupsResponse;
	terminal : CM_Terminal;
	entityId,
	bookingId,
	bolId,
	voyageId			: String;
	wagon				: CM_Wagon;
	voyage				: CM_Voyage;
	truck				: CM_Vehicle;
	workorder			: CM_WorkOrderTI;	
	booking				: CM_BookingRef;
	bol					: CM_BOL;
	foundCargo 			: CM_TIByCargoGroupIdDict;
	roadJob				: CM_Job;
	ti					: CM_TrackedItem;
	cargoGroups 		: CM_TISet;
	wsCargoGroup 		: WS_CargoGroup;
	cargoGroup			:  CM_CargoGroup;  
	trans				: CM_Transaction;															

	includeTI			: Boolean;																	
	entity			    : Object;
	childTi				: CM_TrackedItem;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
	self.initialisePassport();
	
	create response transient;
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	create foundCargo transient;
	if _mode = Ship then
		entityId:=self.qsData.getValue(QueryParam_VoyageId).asStringJMT();
		if entityId = null then
			return response;
		endif;	
		entity := app.myPassport.getObjectOfTypeFromOid(entityId, CM_Voyage);																//03.05.2024 navbk1 #63811			
		voyage := entity.CM_Voyage;																											//03.05.2024 navbk1 #63811
		if voyage &lt;&gt; null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; voyage.String, LogINFO);
			terminal.findAllCargoWithId(null,CM_QueryOperator.Operator_Equal,null,TI_STATE_ONSHIP,voyage,null,null,false,foundCargo);	
			terminal.findAllCargoWithId(null,CM_QueryOperator.Operator_Equal,null,TI_STATE_NORMAL,voyage,null,null,false,foundCargo);		//28.03.2024 navbk1 #63193
		endif;
		// START 01.07.2024 navbk1 #64807
		foreach ti in foundCargo do
			includeTI := true;
			foreach trans in ti.allTransactions do
				if trans.isKindOf(CM_ReleaseShip) and trans.getMyVoyageObject().code = voyage.code then
					includeTI := false;
				endif;
				// START 25.06.2024 navbk1 #64807
				if trans.isKindOf(CM_ReceiveRail) or trans.isKindOf(CM_ReceiveRoad) then
					includeTI := false;
				endif;
				//END 25.06.2024 navbk1 #64807
				// if trans.isKindOf(CM_ReceiveShip) or trans.isKindOf(CM_ReceiveRail) or trans.isKindOf(CM_ReceiveRoad) then           //25.06.2024 navbk1 #64807
				if trans.isKindOf(CM_ReceiveShip) then																					//25.06.2024 navbk1 #64807
					if trans.getMyVoyageObject() &lt;&gt; null and trans.getMyVoyageObject().code &lt;&gt; voyage.code then
						includeTI := false;
					endif;
				endif;
			endforeach;
			if not includeTI then
				foundCargo.remove(ti);
			endif;
		endforeach;
		//END 01.07.2024 navbk1 #64807
	elseif _mode = Road then
		entityId:=self.qsData.getValue(QueryParam_TruckId).asStringJMT;
		if entityId = null then
			return response;
		endif;
		entity := app.myPassport.getObjectOfTypeFromOid(entityId, CM_Vehicle);								//03.05.2024 navbk1 #63811
		truck := entity.CM_Vehicle;																			//03.05.2024 navbk1 #63811
		if truck &lt;&gt; null then
			foreach roadJob in truck.allRoadJobs  do
				foreach ti in roadJob.CM_RoadJob.allReceiveTrackedItems where ti.isOnTruck do
					foundCargo.addNoDuplicates(ti,false);
				endforeach;
			endforeach;
		endif;
	elseif _mode = Rail then
		entityId:=self.qsData.getValue(QueryParam_WagonId).asStringJMT;
		if entityId = null then
			return response;
		endif;
		entity := app.myPassport.getObjectOfTypeFromOid(entityId, CM_Wagon);								//03.05.2024 navbk1 #63811
		wagon := entity.CM_Wagon;																			//03.05.2024 navbk1 #63811									
		if wagon &lt;&gt; null then
			wagon.getAllTrackedItems(true,foundCargo,false);
		endif;
	elseif _mode = Unpack then
		entityId:=self.qsData.getValue(QueryParam_WorkOrderId).asStringJMT;
		if entityId = null then
			return response;
		endif;
		entity := app.myPassport.getObjectOfTypeFromOid(entityId, CM_WorkOrderTI);							//03.05.2024 navbk1 #63811
		workorder := entity.CM_WorkOrderTI;																	//03.05.2024 navbk1 #63811
		if workorder &lt;&gt; null then								//27.02.2024 navhl20 #62645
			foreach ti in workorder.allTIs do 
				//START 12.08.2024 navbk1 #65344
				//foundCargo.addNoDuplicates(ti,false);			//22.02.2024 navhl20 #62406[62534]
				foreach childTi in ti.allChildren do
					foundCargo.addNoDuplicates(childTi, false);
				endforeach;
				//END 12.08.2024 navbk1 #65344
			endforeach;
		endif;
	elseif _mode = Sortout then
		voyageId 	:= 	self.qsData.getValue(QueryParam_VoyageId);
		bookingId	:= 	self.qsData.getValue(QueryParam_BookingId);
		bolId 		:=	self.qsData.getValue(QueryParam_BOLId);
		
		voyage	 := app.myPassport.getObjectOfTypeFromOid(voyageId, CM_Voyage).CM_Voyage;
		booking	 := app.myPassport.getObjectOfTypeFromOid(bookingId, CM_BookingRef).CM_BookingRef;
		bol	 	 := app.myPassport.getObjectOfTypeFromOid(bolId, CM_BOL).CM_BOL;			//27.02.2024 navhl20 #62644
		if voyage = null and booking = null and bol = null then
			//don't do an open ended search 
			return response;
		endif;
		terminal.findAllCargoWithId(null,CM_QueryOperator.Operator_Equal,null,TI_STATE_NORMAL,voyage,booking,bol,false,foundCargo);	
	endif;
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; foundCargo.size.String, LogINFO);
		 
	create cargoGroups transient;
	foundCargo.getCargoGroups(cargoGroups, terminal);							//01.07.2024 navbk1 #64807
	
	foreach cargoGroup in cargoGroups  as CM_CargoGroup  do
		create wsCargoGroup transient;
		wsCargoGroup.setPxyFromObject(cargoGroup,_mode,entity);					//03.05.2024 navbk1 #63811
		response.allCargoGroups.add(wsCargoGroup);
	endforeach;
	
	return response;
epilog	
	self.finaliseResponse(response);
	delete foundCargo;
	delete cargoGroups;
end;</source>
        <Parameter name="_mode" type="String"/>
        <ReturnType type="WS_CargoGroupsResponse"/>
    </JadeMethod>
    <JadeMethod name="getScanCargoItem" id="6a9c3928-1829-498c-92b4-4735e82f35af">
        <updating/>
        <source>getScanCargoItem(_mode: String; _itemid: String) : WS_ScannedCargoResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2023	navmj1	Initial creation
18 Apr 2023	navcs2	ChangeRequest 57557: [57396]: EUP - INB/MOB - New Scanning App - JADE
17 Aug 2023	jlier1  TFS 59748 - fixed range of issues 
01 Sep 2023	jlier1  TFS  60152 
07 Dec 2023 navhl20 ChangeRequest 58400:[61619] EUP | Ship Operations in DD - [54176.050] Mobile App changes
19 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
01 Apr 2024 navbk1  ChangeRequest 63249: FR | 53856 - New Scanning App - Remedial
*/
constants
	Ship 	:	String = "ship";
	Road 	:	String = "road";
	Rail 	:	String = "rail";
	Unpack 	:	String = "unpack";
	Sortout	:	String = "sortout";
vars
	ti,
	trackedItem,
	childTI				: CM_TrackedItem;
	entity,
	trackedItemId,
	entityId1,
	bookingId,
	bolId,
	voyageId			: String;
	response			: WS_ScannedCargoResponse;
	wagon				: CM_Wagon;
	voyage				: CM_Voyage;
	truck				: CM_Vehicle;
	workorder			: CM_WorkOrderTI;	
	roadJob				: CM_Job;
	included			: Boolean;
	terminal			: CM_Terminal;
	details				: WS_ScannedCargoDetails;
	booking				: CM_BookingRef;
	bol					: CM_BOL;
	foundCargo 			: CM_TIArray;
	wsScannedCargo		: WS_ScannedCargoScanned;
	entityObj			: CM_Object;
	voyJobOid			: String;
	voyJob				: CM_VoyageWorkPointJob;
	jobWOReceive		: CM_WOReceiveCargoJob;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
	self.initialisePassport();
	
	create response transient;
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal 	  := app.myPassport.myTerminal;
	trackedItemId := _itemid.asStringRESTFUL;
	trackedItem   := app.myPassport.getObjectOfTypeFromOid(trackedItemId, CM_TrackedItem).CM_TrackedItem;
	
	if trackedItem &lt;&gt; null then
		trackedItemId := trackedItem.id;
	endif;
	
	if app.myPassport.hasErrors then
		return response;
	endif;

	create foundCargo transient;
	
	// Build the response
	if _mode = Ship then
		entityId1  := self.qsData.getValue(QueryParam_VoyageId).asStringJMT();
		voyage     := app.myPassport.getObjectOfTypeFromOid(entityId1, CM_Voyage).CM_Voyage;
		voyJobOid  := self.qsData.getValue(QueryParam_JobOId).asStringJMT();													//07.12.2023 navhl20 #58400[61619]
		voyJob     := app.myPassport.getObjectOfTypeFromOid(voyJobOid, CM_VoyageWorkPointJob).CM_VoyageWorkPointJob;			//07.12.2023 navhl20 #58400[61619]
		entityObj  := voyage;
		
		if voyage &lt;&gt; null then
			entity := voyage.code;
			if trackedItem = null then
				terminal.findAllCargoWithId(trackedItemId,CM_QueryOperator.Operator_Equal,null,TI_STATE_ONSHIP,voyage,null,null,true,foundCargo);	
				trackedItem := foundCargo.first;
				if trackedItem = null then
					terminal.findAllCargoWithId(trackedItemId,CM_QueryOperator.Operator_Equal,null,TI_STATE_NORMAL,voyage,null,null,true,foundCargo);	//02.04.2024 navbk1 #63249
					trackedItem := foundCargo.first;																									//02.04.2024 navbk1 #63249
					if trackedItem = null then																											//02.04.2024 navbk1 #63249
						app.raiseCMException2(No_Cargo_Id_Match,trackedItemId,entity ,null,null);														//02.04.2024 navbk1 #63249
					else
						app.raiseCMException1(Item_Already_Discharged,trackedItemId,null,null);
					endif;
					return response;
				endif;
			else
				if not voyage.allOnshipTIsByIdCargoType.includes(trackedItem) then
					app.raiseCMException2(No_Cargo_Id_Match,trackedItemId,entity ,null,null);
					return response;
				endif;		
			endif;
			if voyJob &lt;&gt; null then																							//07.12.2023 navhl20 #58400[61619]
				jobWOReceive := voyJob.myWorkOrderReceiveJob;
				if jobWOReceive &lt;&gt; null then
					if  not jobWOReceive.allTrackedItems.includes(trackedItem) then
						app.raiseCMException2(No_Cargo_Id_Match_Job,trackedItemId,voyJob.id ,null,null);
						return response;
					endif;
				endif;
			else																											//19.01.2024 navhl20 #62066
				app.raiseCMException(No_Jobs_Selected,null,null);
				return response;
			endif;
		else		
			app.raiseCMException1(Voyage_not_found ,entityId1,null,null);
			return response;	
		endif;
	elseif _mode = Road then
		included := false;
		entityId1 := self.qsData.getValue(QueryParam_TruckId).asStringJMT();
		truck := app.myPassport.getObjectOfTypeFromOid(entityId1, CM_Vehicle).CM_Vehicle;
		entityObj:=truck;
		if truck &lt;&gt; null then
			entity := truck.regNumber;
			foreach roadJob in truck.allRoadJobs  do : outerLoop
				if trackedItem  &lt;&gt; null then
					if roadJob.CM_RoadJob.allReceiveTrackedItems.includes(trackedItem) and trackedItem.isOnTruck then
						included := true;
						break;
					endif;
				else
					foreach ti in roadJob.CM_RoadJob.allReceiveTrackedItems do													//02.04.2024 navbk1 #63249
						if ti.id = trackedItemId or ti.alternativeId = trackedItemId then										//02.04.2024 navbk1 #63249
							if ti.isOnTruck() then																				//02.04.2024 navbk1 #63249					
								included := true;
								trackedItem:=ti;
								break outerLoop;
							else
								app.raiseCMException1(Item_Already_Discharged,trackedItemId,null,null);							//02.04.2024 navbk1 #63249
								return response;																				//02.04.2024 navbk1 #63249
							endif;
						endif;
					endforeach;
				endif;
			endforeach;
			if not included then
				app.raiseCMException2(No_Cargo_Id_Match,trackedItemId,entity ,null,null);
				return response;
			endif;
		else
			app.raiseCMException(Truck_not_found,null,null);
			return response;	
		endif;
	elseif _mode = Rail then
		entityId1 := self.qsData.getValue(QueryParam_WagonId).asStringJMT();
		wagon := app.myPassport.getObjectOfTypeFromOid(entityId1, CM_Wagon).CM_Wagon;												
		entityObj:=wagon;
		if wagon &lt;&gt; null then
			entity := wagon.id;
			wagon.getAllTrackedItems(true,foundCargo,true);																				//02.04.2024 navbk1 #63249
			if trackedItem  &lt;&gt; null then
				if foundCargo.includes(trackedItem) then
					included := true;
				endif;
			else
				foreach ti in foundCargo do
					if ti.id = trackedItemId or ti.alternativeId = trackedItemId then
						if ti.isOnWagon() then																							//02.04.2024 navbk1 #63249
							included := true;
							trackedItem:=ti;
							break;	
						else 
							app.raiseCMException1(Item_Already_Discharged,trackedItemId,null,null);										//02.04.2024 navbk1 #63249
							return response;																							//02.04.2024 navbk1 #63249
						endif;
					endif;
				endforeach;
			endif;
		
			if not included then
				app.raiseCMException2(No_Cargo_Id_Match,trackedItemId,entity ,null,null);
				return response;
			endif;
		else
			app.raiseCMException1(Wagon_not_found_expect_wagons,entityId1,null,null);
			return response;	
		endif;
	elseif _mode = Unpack then
		entityId1 := self.qsData.getValue(QueryParam_WorkOrderId).asStringJMT();
		workorder := app.myPassport.getObjectOfTypeFromOid(entityId1, CM_WorkOrderTI).CM_WorkOrderTI;
		entityObj:=workorder;
		if workorder &lt;&gt; null then
			entity := workorder.id;
			foreach ti in workorder.allTIs do : outerLoop
				foreach childTI in ti.allChildren do
					if trackedItem &lt;&gt; null then
						if childTI = trackedItem then
							included := true;
							break;
						endif;
					else
						if childTI.id = trackedItemId or childTI.alternativeId = trackedItemId then
							included := true;
							trackedItem:=childTI;
							break outerLoop;
						endif;
					endif;
				endforeach;
			endforeach;
			if not included then
				terminal.findAllCargoWithId(trackedItemId,CM_QueryOperator.Operator_Equal,null,null,null,null,null,true,foundCargo);		//02.04.2024 navbk1 #63249
				ti := foundCargo.first();																									//02.04.2024 navbk1 #63249
				if ti &lt;&gt; null and ti.getLastTransOfClass(CM_Unpack) &lt;&gt; null then															//02.04.2024 navbk1 #63249
					app.raiseCMException1(Item_Already_Discharged,trackedItemId,null,null);													//02.04.2024 navbk1 #63249
				else 
					app.raiseCMException2(No_Cargo_Id_Match,trackedItemId,entity ,null,null);
				endif;
				return response;
			endif;
		else
			app.raiseCMException(No_Work_order_selected,null,null);
			return response;	
		endif;
	elseif _mode = Sortout then	
		
		
		voyageId 	:= 	self.qsData.getValue(QueryParam_VoyageId);
		bookingId	:= 	self.qsData.getValue(QueryParam_BookingId);
		bolId 		:=	self.qsData.getValue(QueryParam_BOLId);
		
		voyage	 := app.myPassport.getObjectOfTypeFromOid(voyageId, CM_Voyage).CM_Voyage;
		booking	 := app.myPassport.getObjectOfTypeFromOid(bookingId, CM_BookingRef).CM_BookingRef;
		bol	 	 := app.myPassport.getObjectOfTypeFromOid(bookingId, CM_BOL).CM_BOL;
		if voyage &lt;&gt; null then
			entity:=voyage.code;
		endif;
		if booking &lt;&gt; null then
			if entity = null then
				entity:=booking.bookingReference;
			else
				entity:=entity &amp; " " &amp; booking.bookingReference;
			endif;
		endif;
		if bol &lt;&gt; null then
			if entity = null then
				entity:=bol.number;
			else
				entity:=entity &amp; " " &amp; bol.number;
			endif;
		endif;
		
		terminal.findAllCargoWithId(trackedItemId,CM_QueryOperator.Operator_Equal,null,TI_STATE_NORMAL,voyage,booking,bol,true,foundCargo);	
		trackedItem:=foundCargo.first;
		if trackedItem = null then
			app.raiseCMException2(No_Cargo_Id_Match,trackedItemId,entity ,null,null);
			return response;
		endif;
	else
		app.raiseCMException(Unrecognis_mode_entered ,null,null);
		return response;
	endif;
	
	create details transient;
	details.setProxyFromObject(trackedItem);
	details.summary.setEntity(entity);
	
	create wsScannedCargo transient;
	if trackedItem &lt;&gt; null then
		wsScannedCargo.setEntityTotals(entityObj,trackedItem.myCargoGroup);
	endif;
	details.scanned:=wsScannedCargo;
	response.details := details;
	
	return response;
	
epilog	
	delete foundCargo;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_itemid" type="String"/>
        <ReturnType type="WS_ScannedCargoResponse"/>
    </JadeMethod>
    <JadeMethod name="getScanWorkPointDetails" id="373733c9-6ec9-4424-be3d-7325e6f0283a">
        <updating/>
        <source>getScanWorkPointDetails(_mode: String; _otherParams: ParamListType) : String updating;
/*

Purpose:			

A method to return different entities based on the the mode passed in (Rail, Road etc) 		

Return Value:		

Date			Who		Reason
29 March 2023	navmj1	Initial creation
18 April 2023	navcs2	ChangeRequest 57557: [57396]: EUP - INB/MOB - New Scanning App - JADE
17 Aug 	 2023	jlier1 TFS 59748 - fixed range of issues 
21 Aug 	2023	jlier1 TFS 59876 -leaking transients
01 Sep 	2023	jlier1 TFS  60152 
11 Dec 2023 	navhl20 ChangeRequest 58400:[61619] EUP | Ship Operations in DD - [54176.050] Mobile App changes
19 Dec 2023		navmj1	TFS 61826: EUP | added vessel name (description) to the response for all voyages
25 Feb 2025 	navma1 MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/
constants
	Ship 		:	String = "ship";
	Road 		:	String = "road";
	Rail 		:	String = "rail";
	Unpack 		:	String = "unpack";
	Sortout		:	String = "sortout";
	Voyages		: 	String = "voyages";
	VoyageName	: 	String = "voyageName";
	VesselName	: 	String = "vesselName"; 			//19.12.2023 navmj1 #53586[61838]
	BOLNumber	:	String = "bolNumber";
	BOL			:	String = "bol";
	TruckReg	: 	String = "truckRegistration";
	Workorderid	: 	String = "workorderId";
	WagonNumber	:	String = "wagonNumber";
	Uid			: 	String = "uid";
	VoyageUid 	:   String = "voyageUid";
	Trucks		:	String = "trucks";
	Wagons		: 	String = "wagons";
	WorkOrders	:	String = "workOrders";
	BOLs		:	String = "bols";
	Bookings	:	String = "bookings";
	Booking		:	String = "bookingCode";
	Parameter   :   String = "parameter";
vars
	_id1				: String;
	jobSheet			: CM_JobSheet;
	job					: CM_Job;
	jobJdo,
	returnJdo			: JadeDynamicObject;
	allJDOEntity		: JadeDynamicObjectArray;
	response			: String;
	terminal			: CM_Terminal;
	voyage				: CM_Voyage;
	truck				: CM_Vehicle;
	wagon				: CM_Wagon;
	workorder			: CM_WorkOrder;
	receivalDate		: TimeStamp;
	bol					: CM_BOL;
	booking				: CM_BookingRef;
	allVoyages			: CM_VoyageSet;
	allBookings			: CM_BookingRefSet;
	allBOLs				: CM_BOLSet;
	trackedItem			: CM_TrackedItem;
	jobSet				: CM_JobSet;
	vehicle				: CM_Vehicle;
	vehicleSet			: CM_VehicleSet;
	wagonDict			: CM_WagonByIDByDateDict;
	wod					: CM_WorkOrderTIDtl;
	woDict				: CM_WorkOrderByIdDict;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassport();

	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	_id1 := self.qsData.getValue(Parameter).asStringJMT;
	
	if _id1 &lt;&gt; null and _mode &lt;&gt; Sortout  then
		jobSheet := app.myPassport.getObjectOfTypeFromOid(_id1, CM_JobSheet).CM_JobSheet;	
	endif;
	
	
	create returnJdo transient;
	self.objectsToBeDeleted.add(returnJdo);
	create allJDOEntity transient;
	self.objectsToBeDeleted.add(allJDOEntity);
	terminal := app.myPassport.myTerminal;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if _mode = Ship then	
		if jobSheet &lt;&gt; null then
			if jobSheet.isMatchingWorkPointType(WORK_POINT_TYPE_SHIP) then									//11.12.2023 navhl20 #58400[61619]
				
				create jobSet transient;
				jobSheet.allJobsByPriorityRequiredDT.copy(jobSet);											//25.02.2025 navma1 #MTN-34075
				
				foreach job in jobSet discreteLock where job.isKindOf(CM_VoyageJob) do						//25.02.2025 navma1 #MTN-34075
					
					voyage := job.CM_VoyageJob.myVoyage;													//25.02.2025 navma1 #MTN-34075
					
					if voyage &lt;&gt; null then
						create jobJdo transient;
						jobJdo.addProperty(VoyageName,		 String);
						jobJdo.setPropertyValue(VoyageName, voyage.code);
						jobJdo.addProperty(VesselName, 		String); 										//19.12.2023 navmj1 #53586[61838]
						jobJdo.setPropertyValue(VesselName, voyage.vesselName);								//19.12.2023 navmj1 #53586[61838]
						jobJdo.addProperty(Uid,			    String);
						jobJdo.setPropertyValue(Uid,        voyage.getOidString);
						allJDOEntity.add(jobJdo);
						self.objectsToBeDeleted.add(jobJdo);
					endif;
				endforeach;
			endif;
		else 
			create allVoyages transient;
			terminal.getAllCurrentVoyages(allVoyages,true,false,false);
		
			foreach voyage in allVoyages discreteLock do
				create jobJdo transient;
				jobJdo.addProperty(VoyageName, String);
				jobJdo.setPropertyValue(VoyageName, voyage.code);
				jobJdo.addProperty(VesselName, String);														//19.12.2023 navmj1 #53586[61838]
				jobJdo.setPropertyValue(VesselName, voyage.vesselName);										//19.12.2023 navmj1 #53586[61838]
				jobJdo.addProperty(Uid, String);
				jobJdo.setPropertyValue(Uid, voyage.getOidString);
				allJDOEntity.add(jobJdo);
				self.objectsToBeDeleted.add(jobJdo);
			endforeach;
		endif;
		returnJdo.addProperty(Voyages, JadeDynamicObjectArray);
		returnJdo.setPropertyValue(Voyages,allJDOEntity );
	
	elseif _mode = Road then
		if jobSheet &lt;&gt; null then
	
			if jobSheet.isMatchingWorkPointType(WORK_POINT_TYPE_ROAD) then										//11.12.2023 navhl20 #58400[61619]
				
				create jobSet transient;
				jobSheet.allJobsByPriorityRequiredDT.copy(jobSet);												//25.02.2025 navma1 #MTN-34075
				foreach job in jobSet discreteLock where job.isRoadJob do										//25.02.2025 navma1 #MTN-34075
					
					vehicle := job.CM_RoadJob.myVehicle;														//25.02.2025 navma1 #MTN-34075
					
					if vehicle &lt;&gt; null then
						create jobJdo transient;
						jobJdo.addProperty(TruckReg, String);
						jobJdo.setPropertyValue(TruckReg, vehicle.regNumber);
						jobJdo.addProperty(Uid, String);
						jobJdo.setPropertyValue(Uid, vehicle.getOidString);
						allJDOEntity.add(jobJdo);
						self.objectsToBeDeleted.add(jobJdo);
					endif;
				endforeach;
			endif;
		else 
			create vehicleSet transient;
			terminal.myRoadJobSheet.allInTerminalVehicles.copy(vehicleSet);
			
			foreach truck in vehicleSet discreteLock do
				create jobJdo transient;
				jobJdo.addProperty(TruckReg, String);
				jobJdo.setPropertyValue(TruckReg, truck.regNumber);
				jobJdo.addProperty(Uid, String);
				jobJdo.setPropertyValue(Uid, truck.getOidString);
				allJDOEntity.add(jobJdo);
				self.objectsToBeDeleted.add(jobJdo);
			endforeach;
		endif;
		returnJdo.addProperty(Trucks, JadeDynamicObjectArray);
		returnJdo.setPropertyValue(Trucks,allJDOEntity );
	
	elseif _mode = Rail then
		if jobSheet &lt;&gt; null then
			if jobSheet.isMatchingWorkPointType(WORK_POINT_TYPE_RAIL) then											//11.12.2023 navhl20 #58400[61619]
				
				create jobSet transient;
				jobSheet.allJobsByPriorityRequiredDT.copy(jobSet);													//25.02.2025 navma1 #MTN-34075
				
				foreach job in jobSet discreteLock where job.isRail do												//25.02.2025 navma1 #MTN-34075							
					
					wagon := job.CM_RailJob.getMyWagon;
					
					if wagon &lt;&gt; null and wagon.confirmed and not wagon.confirmedOutwards  then
						create jobJdo transient;
						jobJdo.addProperty(WagonNumber, String);
						jobJdo.setPropertyValue(WagonNumber, wagon.id);												 //25.02.2025 navma1 #MTN-34075
						jobJdo.addProperty(Uid, String);
						jobJdo.setPropertyValue(Uid, wagon.getOidString);											 //25.02.2025 navma1 #MTN-34075
						allJDOEntity.add(jobJdo);
						self.objectsToBeDeleted.add(jobJdo);
					endif;
				endforeach;
			endif;
		else 
			//jlier1 TFS 60152 30/8/23 - wagon is confirmed
			
			create wagonDict transient;
			terminal.allWagons.copy(wagonDict);																		//25.02.2025 navma1 #MTN-34075
			
			foreach wagon in wagonDict discreteLock where wagon.confirmed and not wagon.confirmedOutwards do		//25.02.2025 navma1 #MTN-34075
				create jobJdo transient;
				jobJdo.addProperty(WagonNumber, String);
				jobJdo.setPropertyValue(WagonNumber, wagon.id);
				jobJdo.addProperty(Uid, String);
				jobJdo.setPropertyValue(Uid, wagon.getOidString);
				allJDOEntity.add(jobJdo);
				self.objectsToBeDeleted.add(jobJdo);
			endforeach;
		endif;
		returnJdo.addProperty(Wagons, JadeDynamicObjectArray);
		returnJdo.setPropertyValue(Wagons,allJDOEntity );
	
	elseif _mode = Unpack then
		if jobSheet &lt;&gt; null then
			if jobSheet.isMatchingWorkPointType(WORK_POINT_TYPE_PACKUNPACK) then									//11.12.2023 navhl20 #58400[61619]
				
				create jobSet transient;
				jobSheet.allJobsByPriorityRequiredDT.copy(jobSet);													//25.02.2025 navma1 #MTN-34075
				
				foreach job in jobSet discreteLock where job.isWOUnpackJob do										//25.02.2025 navma1 #MTN-34075
					
					wod := job.CM_WOUnpackJob.myWODtl;
					if wod &lt;&gt; null then
						create jobJdo transient;
						jobJdo.addProperty(Workorderid, String);
						jobJdo.setPropertyValue(Workorderid, wod.myParent.id);
						jobJdo.addProperty(Uid, String);
						jobJdo.setPropertyValue(Uid, wod.myParent.getOidString);
						allJDOEntity.add(jobJdo);
						self.objectsToBeDeleted.add(jobJdo);
					endif;
				endforeach;	
			endif;
		else 
			
			create woDict transient;								//25.02.2025 navma1 #MTN-34075
			terminal.allWorkOrders.copy(woDict);					//25.02.2025 navma1 #MTN-34075
			
			foreach workorder in woDict discreteLock where workorder.hasUnpackTask and (not workorder.isComplete and not workorder.isCancelled) do
				create jobJdo transient;
				jobJdo.addProperty(Workorderid, String);
				jobJdo.setPropertyValue(Workorderid, workorder.id);
				jobJdo.addProperty(Uid, String);
				jobJdo.setPropertyValue(Uid, workorder.getOidString);
				allJDOEntity.add(jobJdo);
				self.objectsToBeDeleted.add(jobJdo);
			endforeach;
		endif;
		returnJdo.addProperty(WorkOrders, JadeDynamicObjectArray);
		returnJdo.setPropertyValue(WorkOrders,allJDOEntity );
	
	elseif _mode = Sortout then
		_id1			:= self.qsData.getValue(Parameter).asStringJMT;
		receivalDate 	:= _id1.asTimeStampFromWebInterface;
		
		if receivalDate &lt;&gt; null and receivalDate.isValid then

			create allBOLs transient;
			create allBookings transient;
			create allVoyages transient;
			
			//jlier1 TFS 60152 30/8/23 - all active voyages
			foreach voyage in terminal.allVoyagesByArrivalDTCode discreteLock where (receivalDate.date &lt; voyage.arrivedDT.date or receivalDate.date &lt; voyage.departedDT.date) do
				if voyage.isCancelled or voyage.status = Voyage_Status_Closed then 
					continue;
				endif;					
				allVoyages.add(voyage);
			endforeach;
			
			foreach bol in terminal.allBOLsReceivedByDTType  discreteLock do									//25.02.2025 navma1 #MTN-34075
				if allVoyages.includes(bol.getMyVoyage) or  receivalDate.date &lt; bol.dateTime.date then
					allBOLs.add(bol);
				endif;
			endforeach;
			
			foreach booking in terminal.allBookingRefsByRef discreteLock do										//25.02.2025 navma1 #MTN-34075
				if allVoyages.includes(booking.myVoyage) then
					allBookings.addNoDuplicates(booking, false);
				endif;
				
				foreach trackedItem in booking.allTIs discreteLock do 											//25.02.2025 navma1 #MTN-34075
					if receivalDate.date &lt; trackedItem.receivedDT.date then
						allBookings.addNoDuplicates(booking, false);
					endif;
				endforeach;
			endforeach;
		
			create allJDOEntity transient;
			foreach voyage in allVoyages discreteLock do													   //25.02.2025 navma1 #MTN-34075
				create jobJdo transient;
				jobJdo.addProperty(VoyageName, String);
				jobJdo.setPropertyValue(VoyageName, voyage.code);
				jobJdo.addProperty(VesselName, String);														    //19.12.2023 navmj1 #53586[61838]
				jobJdo.setPropertyValue(VesselName, voyage.vesselName);											//19.12.2023 navmj1 #53586[61838]
				jobJdo.addProperty(Uid, String);
				jobJdo.setPropertyValue(Uid, voyage.getOidString);
				allJDOEntity.add(jobJdo);
				self.objectsToBeDeleted.add(jobJdo);
			endforeach;	
			returnJdo.addProperty(Voyages, JadeDynamicObjectArray);
			returnJdo.setPropertyValue(Voyages,allJDOEntity );
		
			create allJDOEntity transient;
			foreach bol in allBOLs discreteLock do																//25.02.2025 navma1 #MTN-34075
				create jobJdo transient;
				jobJdo.addProperty(BOLNumber, String);
				jobJdo.setPropertyValue(BOLNumber, bol.number);
				jobJdo.addProperty(Uid, String);
				jobJdo.setPropertyValue(Uid, bol.getOidString);
				if bol.getMyVoyage &lt;&gt; null then
					jobJdo.addProperty(VoyageUid, String);
					jobJdo.setPropertyValue(VoyageUid, bol.getMyVoyage.getOidString);
				endif;
				allJDOEntity.add(jobJdo);
				self.objectsToBeDeleted.add(jobJdo);
			endforeach;	
			returnJdo.addProperty(BOLs, JadeDynamicObjectArray);
			returnJdo.setPropertyValue(BOLs,allJDOEntity );
			
			create allJDOEntity transient;
			foreach booking in allBookings discreteLock do													    //25.02.2025 navma1 #MTN-34075
				create jobJdo transient;
				jobJdo.addProperty(Booking, String);
				jobJdo.setPropertyValue(Booking, booking.bookingReference);
				jobJdo.addProperty(Uid, String);
				jobJdo.setPropertyValue(Uid, booking.getOidString);
				if booking.myVoyage &lt;&gt; null then
					jobJdo.addProperty(VoyageUid, String);
					jobJdo.setPropertyValue(VoyageUid, booking.myVoyage.getOidString);
				endif;
				allJDOEntity.add(jobJdo);
				self.objectsToBeDeleted.add(jobJdo);
			endforeach;	
			returnJdo.addProperty(Bookings, JadeDynamicObjectArray);
			returnJdo.setPropertyValue(Bookings,allJDOEntity );
			
		else
			app.raiseCMException(DATE_INVALID ,null,null);
			return response;
		endif;
	else
		app.raiseCMException(Unrecognis_mode_entered ,null,null);
		return response;
	endif;
	
	returnJdo.deserializeJSON(response);
	
	return response;
epilog

	delete allBOLs;
	delete allBookings;
	delete allVoyages;
	delete jobSet;
	delete wagonDict;
	delete woDict;
	delete vehicleSet;
	self.finaliseJSONResponse(response);
	
	return response;
end;</source>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_otherParams" type="ParamListType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getScanWorkPoints" id="fffa761a-947b-453d-9135-c9075ec9a546">
        <updating/>
        <source>getScanWorkPoints(_mode: String): String updating;
/*

Purpose:			

TO DO

Parameters:			

Return Value:		

Date			Who		Reason
29 March 2023	navmj1	Initial creation
18 April 2023	navcs2	ChangeRequest 57557: [57396]: EUP - INB/MOB - New Scanning App - JADE
21 Aug 	2023	jlier1 TFS 59876 - leaking transients
07 Dec 2023 	navhl20 ChangeRequest 58400:[61619] EUP | Ship Operations in DD - [54176.050] Mobile App changes
13 Mar 2024 	navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
18 Apr 2025		navhl20 Bug MTN-34624: EUP | 53856 - Scanning App - further issues
*/
constants
	Ship 			:	String = "ship";
	Road 			:	String = "road";
	Rail 			:	String = "rail";
	Unpack 			:	String = "unpack";
	Sortout			:	String = "sortout";
	WorkPoints		: 	String = "workPoints";
	JobSheetName	:	String = "jobSheet";
	Uid				: 	String = "uid";
	
vars
	terminal			: CM_Terminal;
	response			: String;
	jobSheetJdo,
	returnJdo			: JadeDynamicObject;
	allJDOEntity		: JadeDynamicObjectArray;
	jobSheet			: CM_JobSheet;
	voyageCode			: String;
	voyage				: CM_Voyage;
	jobSheetSet			: CM_JobSheetArray;
	jobSheetDict 		: CM_WPJobSheetByDate;
	todayDT				: Date;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	// Some initial setup to help later on
	terminal := app.myPassport.myTerminal;	
	
	create returnJdo transient;
	self.objectsToBeDeleted.add(returnJdo);
	create allJDOEntity transient;
	self.objectsToBeDeleted.add(allJDOEntity);
	// Get the correct workpoints that have the correct jobsheets
	
	create jobSheetSet transient;																//11.12.2023 navma1 #58400[61619]
	
	create jobSheetDict transient;
	terminal.allJobSheetsForWorkPoints.copy(jobSheetDict);
	
	if _mode = Ship then
		voyageCode := self.qsData.getValue(self.QueryParam_VoyageId).asStringJMT();				//07.12.2023 navhl20 #58400[61619]
		voyage     := terminal.lookupVoyage(voyageCode,null,false);								//07.12.2023 navhl20 #58400[61619]
		todayDT    := app.actualTimeServer().date;
		
		foreach jobSheet in jobSheetDict discreteLock  do										//25.02.2025 navma1 #MTN-34075
			if voyage = null then																//18.04.2025 navhl20 #34624
				continue;
			endif;
			
			if not jobSheet.isMatchingWorkPointType(WORK_POINT_TYPE_SHIP) then					//11.12.2023 navma1 #58400[61619]
				continue;
			endif;
			
			if voyage &lt;&gt; null then																//07.12.2023 navhl20 #58400[61619]
				if not jobSheet.CM_WorkPointJobSheet.isMatchingForVoyage(voyage) then
					continue;
				endif;
			endif;
			
			if jobSheet.CM_WorkPointJobSheet.myShift.startDateTime.date &lt;&gt; todayDT then			//18.04.2025 navhl20 #34624
				continue;
			endif;
			jobSheetSet.add(jobSheet);
		endforeach;
		
	elseif _mode = Road then
		foreach jobSheet in jobSheetDict discreteLock  do										//25.02.2025 navma1 #MTN-34075
			if jobSheet.isMatchingWorkPointType(WORK_POINT_TYPE_ROAD) then
				jobSheetSet.add(jobSheet);
			endif;
		endforeach;
		
	elseif _mode = Rail then
		foreach jobSheet in jobSheetDict discreteLock  do										//25.02.2025 navma1 #MTN-34075
			if jobSheet.isMatchingWorkPointType(WORK_POINT_TYPE_RAIL) then
				jobSheetSet.add(jobSheet);
			endif;
		endforeach;
		
	elseif _mode = Unpack then
		foreach jobSheet in jobSheetDict discreteLock  do										//25.02.2025 navma1 #MTN-34075
			if jobSheet.isMatchingWorkPointType(WORK_POINT_TYPE_PACKUNPACK) then
				jobSheetSet.add(jobSheet);
			endif;
		endforeach;
		
	elseif _mode = Sortout then
		foreach jobSheet in jobSheetDict discreteLock  do										//25.02.2025 navma1 #MTN-34075
			if jobSheet.myWorkPoint.myWorkPointType &lt;&gt; null then
				jobSheetSet.add(jobSheet);
			endif;
		endforeach;
	else
		app.raiseCMException(Unrecognis_mode_entered ,null,null);
		return response;
	endif;
	
	if jobSheetSet.isNotEmpty() then
		foreach jobSheet in jobSheetSet discreteLock do												//11.12.2023 navhl20 #58400[61619]
			create jobSheetJdo transient;
			jobSheetJdo.addProperty(JobSheetName, String);
			jobSheetJdo.setPropertyValue(JobSheetName, jobSheet.externalName);
			jobSheetJdo.addProperty(Uid, String);
			jobSheetJdo.setPropertyValue(Uid, jobSheet.getOidString);
			allJDOEntity.add(jobSheetJdo);
			self.objectsToBeDeleted.add(jobSheetJdo);
		endforeach;
		returnJdo.addProperty(WorkPoints, JadeDynamicObjectArray);
		returnJdo.setPropertyValue(WorkPoints, allJDOEntity );
	endif;
	
	returnJdo.deserializeJSON(response);
	
	// return the response
	return response;
epilog
	delete jobSheetDict;
	self.finaliseJSONResponse(response);
	delete jobSheetSet;
	return response;
end;</source>
        <Parameter name="_mode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSealCheckForTruck" id="94bcca8e-ac0a-4b9b-a5c1-4087b7763aa3">
        <updating/>
        <source>getSealCheckForTruck(truckOid : String): WS_SealCheckTruckResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 May 2023			jlizm1	Initial creation TFS 56558 EUP Seal Numbers on Trucks

*/

vars
	response	: WS_SealCheckTruckResponse;
	roadJob 	: CM_RoadJob;
	terminal	: CM_Terminal;
	context		: Integer;
	checkType	: Integer;
	sealType	: CM_SealType;
	sealTypeAvailable : Boolean;
	truck		: CM_Vehicle;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	truck := app.myPassport.getObjectOfTypeFromOid(truckOid, CM_Vehicle).CM_Vehicle;
	
	if truck = null then
		truck := terminal.vehicles[truckOid.toUpper, ""];
		
		if truck = null then
			app.raiseCMException(Truck_not_found, null, null);
			return response;
		endif;
	endif;
	
	roadJob := truck.getCurrentRoadJob();
	if roadJob = null then
		app.raiseCMException(Cannot_find_roadJob, null, null);
		return response;
	endif;	
	
	if roadJob.isRelease then
		context := CARGO_CHECK_CONTEXT_ROAD_REL;
	else
		context := CARGO_CHECK_CONTEXT_ROAD_REC;
	endif;
	
	checkType := terminal.getSealCheckTypeForContext(context);
	if checkType = SEAL_CHECK_DEFAULT then
		checkType := SEAL_CHECK_NONE;
	endif;
	
	if not checkType = SEAL_CHECK_NONE then
		sealTypeAvailable := false;
		foreach sealType in app.myRoot.allTruckSealTypes do
			if not sealType.notAvailableForEntry then
				sealTypeAvailable := true;
				break;
			endif;
		endforeach;
		
		if not sealTypeAvailable then
			checkType := SEAL_CHECK_NONE;
		endif;
	endif;
	
	response.context := context;
	response.sealCheckType := checkType;
	
	return response;
	
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="truckOid" type="String"/>
        <ReturnType type="WS_SealCheckTruckResponse"/>
    </JadeMethod>
    <JadeMethod name="getSealsForTruck" id="8ef89b7f-c2f4-4cf3-b637-2b95a0d1f7a5">
        <updating/>
        <source>getSealsForTruck(truckOid : String): WS_SealsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 May 2023			jlizm1	Initial creation TFS 56558 EUP Seal Numbers on Trucks

*/

vars
	response 	: WS_SealsResponse;
	roadJob		: CM_RoadJob;
	vvr 		: CM_VehicleVisitRecord;
	sealType	: CM_SealType;
	truckSeal	: CM_TruckSeal;
	wsSeal 		: WS_Seal;
	truck		: CM_Vehicle;
	terminal	: CM_Terminal;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	truck := app.myPassport.getObjectOfTypeFromOid(truckOid, CM_Vehicle).CM_Vehicle;
	
	if truck = null then
		truck := terminal.vehicles[truckOid.toUpper, ""];
		
		if truck = null then
			app.raiseCMException(Truck_not_found, null, null);
			return response;
		endif;
	endif;
	
	roadJob := truck.getCurrentRoadJob();
	if roadJob = null then
		app.raiseCMException(Cannot_find_roadJob, null, null);
		return response;
	endif;

	vvr := roadJob.myVehicleVisit;
	if vvr = null then
		app.raiseCMException(Err_No_Vehicle_visit_found, null, null);
		return response;
	endif;
	
	foreach sealType in app.myRoot.allTruckSealTypes discreteLock do
		truckSeal := vvr.allTruckSeals.getTruckSeal(sealType);
		create wsSeal transient;
		if truckSeal &lt;&gt; null then		
			wsSeal.setProxyFromObject(truckSeal);	
		else
			wsSeal.sealType:=sealType.sealType;
			wsSeal.description:=sealType.description;
		endif;
		response.allSeals.add(wsSeal);
	endforeach;
	
	return response;
	
epilog
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="truckOid" type="String"/>
        <ReturnType type="WS_SealsResponse"/>
    </JadeMethod>
    <JadeMethod name="getSealsForWagon" id="392ab694-5775-4ced-8ba4-6cb9a22e7308">
        <updating/>
        <source>getSealsForWagon(wagonOid : String ) : WS_SealsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	jlier1	Initial creation 53971

*/

vars
	response : WS_SealsResponse;
	wagon : CM_Wagon;
	wagonSeal : CM_WagonSeal;
	wsSeal : WS_Seal;
	sealType  : CM_SealType;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	wagon:=app.myPassport.getObjectOfTypeFromOid(wagonOid,CM_Wagon).CM_Wagon;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if wagon = null then
		//raise exception 
		app.raiseCMException1(Wagon_not_found_expect_wagons,wagonOid,null,null);
		return response;
	endif;
	
	foreach sealType in wagon.myWagonClass.allSelectedSealTypes discreteLock do
		wagonSeal:=wagon.allWagonSeals[sealType.sealType];
		create wsSeal transient;
		if wagonSeal &lt;&gt; null then		
			wsSeal.setProxyFromObject(wagonSeal);	
		else
			wsSeal.sealType:=sealType.sealType;
			wsSeal.description:=sealType.description;
		endif;
		response.allSeals.add(wsSeal);
	endforeach;
	
	return response;
	
epilog
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="wagonOid" type="String"/>
        <ReturnType type="WS_SealsResponse"/>
    </JadeMethod>
    <JadeMethod name="getSites" id="0ef9f5b8-f7bd-4443-9204-e858c9b4a473">
        <updating/>
        <source>getSites() : WS_SiteStateResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	jlier1	Initial creation 53022

*/

vars
	response		: WS_SiteStateResponse;
	siteState		: WS_SiteState;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	//TFS 48024 --&gt;
	create siteState transient;
	siteState.setDetails(TI_STATE_NORMAL);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetails(TI_STATE_OFFSITE);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetails(TI_STATE_ONSHIP);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetails(TI_STATE_OFFLOADED);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetails(TI_STATE_NOTIFIED);
	response.allSiteStates.add(siteState);
	
	create siteState transient;
	siteState.setDetails(TI_STATE_DELETED);
	response.allSiteStates.add(siteState);
	
	if app.isInterTerminalTransferEnabled() then 
		create siteState transient;
		siteState.setDetails(TI_STATE_TRANSFER_TO);
		response.allSiteStates.add(siteState);
		
		create siteState transient;
		siteState.setDetails(TI_STATE_TRANSFER_FROM);
		response.allSiteStates.add(siteState);
	endif;
	
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <ReturnType type="WS_SiteStateResponse"/>
    </JadeMethod>
    <JadeMethod name="getStatus" id="2bbe1941-653e-491a-b379-545aea5b2887">
        <updating/>
        <source>getStatus() : WS_Response updating;
/*
Purpose:			
Simple end point that can be call to exercise a Jade REST end point to make sure the service is up and running.
This is not a secure end point so can be called by a monitoring service without credentials.

Return Value:		
The WS_Reponse object with the results of the call.

Date		Who		Reason
10 Apr 2024	navmj1	Initial creation
*/

vars
	response : WS_Response;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	// start a JSM trackable transaction
	self.startCnTrx:= cnStartTransaction(method.qualifiedName[1:CN_TRANSACTION_ID_MAXLENGTH]);
	
		
	response.result := HttpResponseNoContent; // return a 204 code as there is not content
		
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="getTandemCargo" id="99984711-72b8-49cb-92d2-ea7f7e66126a">
        <updating/>
        <source>getTandemCargo(cargoId: String): WS_TandemContainerResponse updating;
/*

Purpose: This is the REST version of machineGetTandemContainer

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	machine 	: CM_Machine;	
	response	: WS_TandemContainerResponse;			
	tiSet		: CM_TISet;
	terminal	: CM_Terminal;
	trackedItem,
	overstow	: CM_TrackedItem;
	task1,
	task2		: CM_RTQueueTask;
	request		: CM_Request;
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	// Create the response
	create response transient;
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	create tiSet transient;
		
	//Look for the overstow container
	if terminal &lt;&gt; null then
		terminal.lookupAllOnsiteTrackedItems(TI_CargoType_Container, cargoId, tiSet, false, null);
		if tiSet.size() = 1 then
			trackedItem := tiSet.first();
			if trackedItem.myPrimaryActualLocation.isGridLocation() 
			and trackedItem.myPrimaryActualLocation.CM_GridController.getMyGridArea().isKindOf(CM_ForkLiftStack) then
				overstow := trackedItem.getTandemLiftBox();
				if overstow &lt;&gt; null and overstow.isContainer() then
					response.idOverstowing := overstow.id;
				endif;
			endif;
		endif;
	endif;
	
	//check director tasks	
	if machine &lt;&gt; null and machine.allCurrentWorkingQueueTasks.size() = 2 and overstow &lt;&gt; null then
		task1 := machine.allCurrentWorkingQueueTasks.first();
		task2 := machine.allCurrentWorkingQueueTasks.last();
		if task1.taskType = TASK_DIRECTOR and task2.taskType = TASK_DIRECTOR then
			request := task2.myEntry.getMyRequest();
			overstow.testAgainstRequest(request);
			if app.myPassport.hasErrorsOrWarnings then
				response.idOverstowing := null;				
				return response;
			endif;
		endif;
	endif;

	return response;
	
epilog
	delete tiSet;	
	
	finaliseResponse(response);	
end;
	
</source>
        <Parameter name="cargoId" type="String"/>
        <ReturnType type="WS_TandemContainerResponse"/>
    </JadeMethod>
    <JadeMethod name="getTaskByOid" id="e008ee15-d133-4a15-8a42-c4e6d29b5671">
        <updating/>
        <source>getTaskByOid(taskOid: String) : String updating;
/*

Purpose: This is the REST version of the getQueueTask		

Parameters:			

Return Value:		

Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================
*/

vars	
	response	: String;
	machine 	: CM_Machine;
	rtTasks 	: CM_RTQueueTask;
	allTasks	: CM_RTQueueTaskArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassportMachine();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	machine:=app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;
	
	rtTasks := app.myPassport.getObjectOfTypeFromOid(taskOid, CM_RTQueueTask).CM_RTQueueTask;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if rtTasks = null then
		app.raiseCMException(Input_required_field_RTQue,null,null);	
		return response;
	endif;
	
	create allTasks transient;
	
	allTasks.add(rtTasks);
	
	response := machine.getTasksAsJSON(allTasks);
		
epilog
	delete allTasks;
	
	finaliseJSONResponse(response);
	
	return response;
end;</source>
        <Parameter name="taskOid" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTasks" id="4dbabb28-d68a-4bc0-a4ae-4cde641730a0">
        <updating/>
        <source>getTasks() : String updating;
/*

Purpose: This is the REST version of the machineGetTaskList, machineGetCurrentTasks 

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation TFS 52595

*/


vars
	response	: String;
	machine 	: CM_Machine;
	allTasks 	: CM_RTQueueTaskArray; 
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassportMachine();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	machine:=app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then
		if app.myPassport.allErrors.first.errorCode = ERR_MACH_FAULTS_OUT then
			app.myPassport.clearErrorsWarnings;
		else
			self.httpStatusCode := HttpResponseForbidden;	
			return response;
		endif;
	endif;
	create allTasks transient;
	
	response:=machine.getTasksAsJSON(allTasks);
	
	app.myTrxUA.trxMachineSetTaskStates(machine,allTasks,app.myPassport);

epilog
	delete allTasks;
	
	finaliseJSONResponse(response);
	return response;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminalAreaTypes" id="e2323094-5586-4db5-a2c8-4732f647bfce">
        <updating/>
        <source>getTerminalAreaTypes() : WS_TATypeResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	jlier1	Initial creation 53022

*/

vars
	response	: WS_TATypeResponse;	
	terminal	: CM_Terminal;
	iter 		: Iterator;	
	taMaster 	: CM_TerminalAreaMaster;
	cmTAType			: CM_TerminalAreaType;
	tAType				: WS_TerminalAreaType;
	allTATypes : CM_TATypeByTypeDict;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	self.initMachineOptional();
	
	terminal := app.myPassport.myTerminal;
	//if for a machine only show ta area types a machine has access to
	if app.myPassport.myMachine &lt;&gt; null then
		create allTATypes transient;
		app.myPassport.myMachine.getAllowedTATypes(allTATypes);
		iter:=allTATypes.createIterator;
	else
		iter:=app.myRoot.allTerminalAreaTypes.createIterator;
	endif;
	
	while iter.next(cmTAType) do
		if cmTAType.getIsNotAvailableForEntry then
			continue;
		endif;
			
		if cmTAType.isGantryLaneAreaType then
			continue;
		endif;
		
		if  cmTAType.type = TA_TYPE_BUILDING then
			continue;
		endif;
		
		create tAType transient;
		tAType.setProxyFromObject(cmTAType);
		response.allTATypes.add(tAType);	
	endwhile;
	
	return response;
epilog
	delete allTATypes;
	delete iter;
	self.finaliseResponse(response);

end;</source>
        <ReturnType type="WS_TATypeResponse"/>
    </JadeMethod>
    <JadeMethod name="getTerminalAreasForType" id="38f70ee6-17b1-415f-a3af-36c7d543037a">
        <updating/>
        <source>getTerminalAreasForType(optionalParam : ParamListType) : WS_TerminalAreaMasterResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	jlier1	Initial creation 53022

*/

vars
	terminal : CM_Terminal;
	response			: WS_TerminalAreaMasterResponse;
	cmTAType			: CM_TerminalAreaType;
	cmTA				: CM_TerminalArea;
	cmTAMaster			: CM_TerminalAreaMaster;
	taTypeId		: String;
	taMaster			: WS_TerminalAreaMaster;
	iter				: Iterator;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	self.initMachineOptional();
	
	taTypeId:=parseParameterList(optionalParam, 1, String).String;
	if taTypeId &lt;&gt; null then
		//epr TFS 5535 10/8/17 
		cmTAType := app.myPassport.getObjectOfTypeFromOid(taTypeId,CM_TerminalAreaType).CM_TerminalAreaType;
		if app.myPassport.hasErrors then
			return response;
		endif;
		if cmTAType = null then		
			cmTAType :=  app.myRoot.allTerminalAreaTypes.getAtKey(taTypeId.Integer);	
		endif;
	endif;
	
	
	terminal := app.myPassport.myTerminal;
	//if for a machine only show ta area types a machine has access to
	if app.myPassport.myMachine &lt;&gt; null then
		foreach cmTAMaster in app.myPassport.myMachine.allowedTAMasters discreteLock do
			if not cmTAMaster.isKindOf(CM_TerminalArea) then
				continue;
			endif;
			if cmTAMaster.CM_TerminalArea.isSwapStack then
				continue;
			endif;
			if cmTAMaster.CM_TerminalArea.isInterchangeArea then
				continue;
			endif;
			if cmTAMaster.CM_TerminalArea.type = TA_TYPE_LOGAREA or
				cmTAMaster.CM_TerminalArea.type = TA_TYPE_DELETE then
				continue;
			endif;
			if cmTAType &lt;&gt; null and cmTAMaster.CM_TerminalArea.myType &lt;&gt; cmTAType then
				continue;
			endif;
			create taMaster transient;
			taMaster.setProxyFromObject(cmTAMaster);
			response.allTAMasters.add(taMaster);	
		endforeach;
	else
		iter:=terminal.allTerminalAreasByTypeId.createIterator;
		if cmTAType &lt;&gt; null then
			terminal.allTerminalAreasByTypeId.startKeyGeq(cmTAType.type, null, iter);
		endif;
		while iter.next(cmTA) do	
			if cmTA.isSwapStack then
				continue;
			endif;
			if cmTA.isInterchangeArea then
				continue;
			endif;
			if cmTA.type = TA_TYPE_LOGAREA or
				cmTA.type = TA_TYPE_DELETE then
				continue;
			endif;
			if cmTAType &lt;&gt; null and cmTA.myType &lt;&gt; cmTAType then
				break;
			endif;
			create taMaster transient;
			taMaster.setProxyFromObject(cmTA);  //jlier1 TFS 54101 8/7/22
			response.allTAMasters.add(taMaster);	
		endwhile;
		
	endif;
	
	return response;
epilog
	delete iter;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_TerminalAreaMasterResponse"/>
    </JadeMethod>
    <JadeMethod name="getTerminals" id="cfc2ce4c-3cf7-418d-98b7-51f8e1a4ac92">
        <updating/>
        <source>getTerminals(): WS_TerminalsResponse updating;
/*

Purpose: This is the REST version of getTerminals

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
03 Apr 2024 navmd1	Add additional logging/errors for Initial setups
04 Apr 2024	jlizm1	TFS 54886 Error when no terminals or machines returned
============================================================================*/

vars	
	response		: WS_TerminalsResponse;
	terminal		: WS_Terminal;
	completedOK		: Boolean;
	user			: CM_User;
	userTerminal	: CM_UserTerminal;
	localTerminal	: CM_Terminal;
begin

	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportPartial();
	
	create response transient;
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	// Populate list of Terminals
	user := app.getMyUser();
	
	foreach userTerminal in user.allUserTerminals do
		localTerminal := userTerminal.myTerminal;
		
		if (localTerminal.machines.size &gt; 0 and localTerminal.myRTVehicleConfig &lt;&gt; null) then
			create terminal transient;
			terminal.setProxyFromObject(localTerminal);
			
			response.allTerminals.add(terminal);
		else
			// Sick of PS saying 'the web services aren't working' when, actually, they just haven't configured the Terminal correctly yet!
			app.writeLog(localTerminal.code &amp; " has no machines or no Terminal Level RTConfig. Excluding from list", LogDEBUG);		// Technically a warning, but we don't want this logged all the time
		endif;
	endforeach;
	
	if response.allTerminals.size = 0 then
		app.writeLog(app.getErrorString(No_valid_rt_terminals), LogERROR);
		app.raiseCMException(No_valid_rt_terminals, null, null);
	endif;
		
	return response;
	
epilog
		
	self.finaliseResponse(response);
	
end;</source>
        <ReturnType type="WS_TerminalsResponse"/>
    </JadeMethod>
    <JadeMethod name="getToDoTasksDescs" id="ea80ac44-cfe0-4bdc-9f23-30e4b49cd37e">
        <updating/>
        <source>getToDoTasksDescs() : WS_RestIntToDoTaskResResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	response		: WS_RestIntToDoTaskResResponse;
	terminal		: CM_Terminal;
	user			: CM_User;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	wsToDoTaskDesc	: WS_RestIntToDoTaskDesc;
	toDoTaskUid		: String;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal	:= app.myPassport.myTerminal;
	user		:= app.myPassport.myUser;
	
	toDoTaskUid := self.qsData[self.QueryParam_ToDoTaskUid].value;
	
	toDoTaskDesc := app.myPassport.getObjectOfTypeFromOid(toDoTaskUid, CM_ToDoTaskDesc).CM_ToDoTaskDesc;
	
	if toDoTaskDesc = null then
		app.raiseCMException(Input_required_field_taskUid, null, null);
		return response;
	endif;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmTodotableMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	// STUFF
	// Load the descriptions 
	if not user.canAddRemoveTodoTask(terminal, toDoTaskDesc) then
		//Should we raise an exception?
		//Should we even do this?
		return response;
	endif;
	
	create wsToDoTaskDesc transient;
	wsToDoTaskDesc.setProxyFromObject(toDoTaskDesc);
	
	response.allToDoTasksDescs.add(wsToDoTaskDesc);
	
	return response;
	
epilog
	self.finaliseResponse(response);
	
end;</source>
        <ReturnType type="WS_RestIntToDoTaskResResponse"/>
    </JadeMethod>
    <JadeMethod name="getTrailerTypes" id="17c832da-c6c8-4781-81ca-d03a9d548dfc">
        <updating/>
        <source>getTrailerTypes(cargoTypeId : String) : WS_TrailerTypeResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2022	jlier1	Initial creation

*/

vars
	response		: WS_TrailerTypeResponse;
	cargoType : CM_CargoType;
	trailerType		: CM_TILCType;
	wsTrailerType	: WS_TrailerType;
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	cargoType := app.myPassport.getObjectOfTypeFromOid( cargoTypeId,CM_CargoType).CM_CargoType;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargoType = null then
		//lets try the id
		cargoType := app.myRoot.allCargoTypesById[cargoTypeId.Integer];
	endif;
	
	if cargoType = null then
		app.raiseCMException1(Cargot_not_valid_cargot_system, cargoTypeId, null, null);
		return response;
	endif;
	

	foreach trailerType in cargoType.allTILCTypes do
		if trailerType.isNotAvailableForEntry then
			continue;
		endif;
		
		create wsTrailerType transient;
		wsTrailerType.setProxyFromObject(trailerType);
		response.allTrailerTypes.add(wsTrailerType);
	endforeach;
	
	return response;
epilog
	
	self.finaliseResponse(response);
end;</source>
        <Parameter name="cargoTypeId" type="String"/>
        <ReturnType type="WS_TrailerTypeResponse"/>
    </JadeMethod>
    <JadeMethod name="getTrailersForRelease" id="4580dc7c-6e9f-4702-bdf9-849b1757ee3a">
        <updating/>
        <source>getTrailersForRelease(releaseOid  : String) : WS_TrailersResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 August 2021	jlier1	Initial creation 51879
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_TrailersResponse;
	release 	: CM_BulkRelease;
	trailerArray : CM_TIArray ;
	ti : CM_TrackedItem;
	wsTrailer : WS_Trailer;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	
	release:=app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if release = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
	
	create trailerArray transient;
	release.getAssociatedTrailers(trailerArray);
	
	foreach ti in trailerArray discreteLock do 
	
		create wsTrailer transient;
		wsTrailer.setProxyFromObject(  ti.CM_TILC );
		response.allTrailers.add( wsTrailer );
	endforeach;
	
	return response;
epilog
	delete trailerArray;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="releaseOid" type="String"/>
        <ReturnType type="WS_TrailersResponse"/>
    </JadeMethod>
    <JadeMethod name="getTrains" id="e61b08a4-9c8a-4f55-9637-5ab921e4e3db">
        <updating/>
        <source>getTrains(): WS_TrainsResponse  updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description
20 Feb 2023     navmp20     Bug 56522:  EUP Testing | Arrived Train not visible in Rail Confirm App
****************************************************/

vars
	response		: WS_TrainsResponse;
	train			: CM_Train;
	trainProxy	    : WS_Train;
	terminal		: CM_Terminal;
	checkDT         : Date;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	terminal:= app.myPassport.myTerminal;
	checkDT := app.actualTimeServer().Date;  
	//checkDT := checkDT.addDays(2);	  		//TFS 56522
	checkDT := checkDT.addDays(6);         		// 09.03.2023 navmp20 TFS 56522
	
	foreach train in terminal.allTrainsOnTerminal discreteLock do
		// Populate response
		if train.isNullTrain() then
			continue;
		endif;
		
		if train.scheduledArrivalDT.Date &gt;= checkDT then
			continue;
		endif;
		
		create trainProxy transient;
		trainProxy.setProxyFromObject(train);
		
		response.allTrains.add(trainProxy);
	endforeach;
	
	return response;
epilog	
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_TrainsResponse"/>
    </JadeMethod>
    <JadeMethod name="getTruckChecks" id="37a021fd-f3b4-4851-8e95-d1af7e63e939">
        <updating/>
        <source>getTruckChecks(truckOid : String; context : Integer) : WS_CargoChecksResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
13 September 2023		jlizm1	Initial creation TFS 59985 Truck Seals design changes

*/

vars
	response 		: WS_CargoChecksResponse;
	cargoCheck 		: CM_CargoCheck;
	cargoCheckItem	: CM_CargoCheckItem;
	cargoCheckProxy : WS_CargoCheck;
	truck			: CM_Vehicle;
	terminal		: CM_Terminal;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	truck := app.myPassport.getObjectOfTypeFromOid(truckOid, CM_Vehicle).CM_Vehicle;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if truck = null then
		truck := terminal.vehicles[truckOid.toUpper, ""];
		
		if truck = null then
			app.raiseCMException(Truck_not_found, null, null);
			return response;
		endif;
	endif;
	
	if context &lt;&gt; TRUCK_CHECK_LOAD_COMPLETE then
		return response;
	endif;
	
	cargoCheck:=app.myPassport.myTerminal.allCargoChecks[context];
	if cargoCheck = null then	
		return response;
	endif;
	
	foreach cargoCheckItem in cargoCheck.allCargoCheckItems do
		
		if cargoCheckItem.requiredExtraInfo = EXTRA_INFO_SEALS then
			//check if there are any truck seals defined
			if app.myRoot.allTruckSealTypes.first = null then
				continue;
			endif;			
		endif;
		
		create cargoCheckProxy transient;
		
		cargoCheckProxy.setProxyFromObjectAndSeals(app.myPassport.myTerminal, null, cargoCheckItem);
		
		response.allCargoChecks.add(cargoCheckProxy);
	
	endforeach;	
	
	return response;
epilog
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="truckOid" type="String"/>
        <Parameter name="context" type="Integer"/>
        <ReturnType type="WS_CargoChecksResponse"/>
    </JadeMethod>
    <JadeMethod name="getTrucksForRelease" id="d5919947-19f9-4f00-bc48-7253c942cd05">
        <updating/>
        <source>getTrucksForRelease(releaseOid : String) : WS_VehiclesResponse updating;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 August 2021	jlier1	Initial creation 51879
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
response : WS_VehiclesResponse;
	terminal : CM_Terminal;
	release 	: CM_BulkRelease;
	vehicleArray : CM_VehicleArray ;
	vehicle : CM_Vehicle;
	wsVehicle		: WS_Vehicle;
	selectedStageArea : CM_LocationsController;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal:=app.myPassport.myTerminal;
	
	release:=app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if release = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
	
	create vehicleArray transient;
	release.getAssociatedTrucks(vehicleArray);
	
	foreach vehicle in vehicleArray discreteLock do 
	
		create wsVehicle transient;
		wsVehicle.setProxyFromObject( vehicle );
		response.allVehicles.add( wsVehicle );
	endforeach;
	//have to check if need to pre select the vehicle
	if vehicleArray.size = 1 then
		selectedStageArea:=null;
		release.getAllPreStagedLocations(selectedStageArea);
		if selectedStageArea &lt;&gt; null then
			response.selectedVehicleOid:=vehicleArray.first.getOidAsString;
		endif;
	endif;
	
	
	return response;
epilog
	delete vehicleArray;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="releaseOid" type="String"/>
        <ReturnType type="WS_VehiclesResponse"/>
    </JadeMethod>
    <JadeMethod name="getTrucksInGateLane" id="07b32ca2-e767-4397-b5c8-374152ef25e1">
        <updating/>
        <source>getTrucksInGateLane(laneOid : String) : WS_VehiclesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 August 2024		jlizm1	Initial creation TFS 65856 MTN - Gate Checker Not validating when there is a truck in the lane

*/

vars
	response 			: WS_VehiclesResponse;
	terminal 			: CM_Terminal;
	gateLane			: CM_GateAreaLaneController;
	vehicleArray 		: CM_VehicleArray ;
	vehicle 			: CM_Vehicle;
	wsVehicle			: WS_Vehicle;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	gateLane := app.myPassport.getObjectOfTypeFromOid(laneOid, CM_GateAreaLaneController).CM_GateAreaLaneController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if gateLane = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Gate_lane), null, null);
		return response;
	endif;
	
	create vehicleArray transient;
	if gateLane.hasVehicles then
		gateLane.allVehicleMachines.copy(vehicleArray);
	endif;
	
	foreach vehicle in vehicleArray discreteLock do 
		create wsVehicle transient;
		wsVehicle.setProxyFromObject( vehicle );
		response.allVehicles.add( wsVehicle );
	endforeach;
	
	return response;
	
epilog
	delete vehicleArray;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="laneOid" type="String"/>
        <ReturnType type="WS_VehiclesResponse"/>
    </JadeMethod>
    <JadeMethod name="getVASJob" id="a2931907-4584-4094-8981-bb150532173c">
        <updating/>
        <source>getVASJob(jobid: String)  : String updating;
/*

Purpose:
Returns the details of a VAS Job.  			

Parameters:			

Return Value:		

Date		Who		Reason
2023/06/15	navmj1 	Initial creation 58526

*/

vars
begin
	if jobid = '16349.1531' then
		return '{"oid": "16349.1531","workorder_reference": "CWO0365","job_type": "Voyage To Do Task","remarks": "","required_date": "2023-06-14T19:19","operator": "Navis NZ Ltd","no_packages":"1","total_weight": "","voyage_details":{"code": "AMA_31523-01,EUP-A-01","name": "DUB-A01"}}';
	elseif jobid = '16347.99' then
		return '{"oid": "16239.4192","workorder_reference": "CWO0372","job_type": "Truck To Do Task","remarks": "","required_date": "2023-06-15T16:16","operator": "Navis NZ Ltd","no_packages": "1", "total_weight": "","truck_plate": "HM77"}';
	elseif jobid = '16346.1387' then
		return '{"oid": "16346.1387","workorder_reference": "CWO0360","job_type": "Wagon To Do Task","remarks": "","required_date": "2023-06-13T00:00","operator": "Navis NZ Ltd","no_packages": "1","total_weight": "","train_code": "FLAT5423-02"}';
	else		
		self.httpStatusCode := HttpResponseNotFound;
		return null;
	endif;

epilog

end;</source>
        <Parameter name="jobid" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVASJobs" id="6f1159d6-54f1-489b-9df5-733ab42633b3">
        <updating/>
        <source>getVASJobs()  : String updating;
/*

Purpose:
Returns a list of VAS Jobs that need to be actioned.  			

Parameters:			

Return Value:		

Date		Who		Reason
2023/06/15	navmj1 	Initial creation 58526

*/

vars
	gangid: String;
begin
	gangid := self.qsData.getValue("gangid").asStringJMT();
	/*
	If the gangid is null then return unallocated jobs, if it has a value return allocated filtered by the gangid
	*/
	if gangid = '' then
		return '{"Type": "unallocated","Jobs": [{"VasType": "Voyage","oid": "16349.1531","JobType": "Voyage To Do Task","RequiredDate": "2023-06-14T19:19","Priority": "3","Operator": "Navis NZ Ltd"},{"Type": "Voyage","oid": "16349.1503","JobType": "Voyage To Do Task","RequiredDate": "2023-06-6T00:00","Priority": "2","Operator": "Navis NZ Ltd"},{"Type": "Vehicle","oid": "16347.99","JobType": "Truck To Do Task","RequiredDate": "2023-06-15T16:16","Priority": "3","Operator": "Navis NZ Ltd"},{"Type": "Wagon","oid": "16346.1387","JobType": "Wagon To Do Task","RequiredDate": "2023-06-15T16:16","Priority": "3","Operator": "Navis NZ Ltd"},{"Type": "Tracked Item","oid": "16239.4192","JobType": "Cargo To Do Task","RequiredDate": "2023-06-15T19:19","Priority": "3","Operator": "Navis NZ Ltd","Commodity": "Empty","Location": "BS02"}]}';
	else
		return '{"Type": "allocated","Jobs": [{"Type": "Train","oid": "16345.1368","JobType": "Train To Do Task","RequiredDate": "2023-05-31T16:16","Priority": "3","Operator": "Navis NZ Ltd"},{"Type": "Tracked Item","oid": "16239.4192","JobType": "Cargo To Do Task","RequiredDate": "2023-06-15T19:19","Priority": "3","Operator": "Navis NZ Ltd","Commodity": "ROLLS","Location": "RAIL01 0201 1"}]}';
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageJobByUid" id="2c3c0411-2cca-4dcb-b69c-dc8245c256b6">
        <updating/>
        <source>getVoyageJobByUid(_jobUid : String):WS_JobResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Nov 2023 navhl20 ChangeRequest 61361:[61424] MTN - Work Hold Jobs on Job Lander [React Version]
*/

vars
	response 		: WS_JobResponse;
	term			: CM_Terminal;
	job,
	woJob			: CM_Job;
	wsJob			: WS_Job;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;	
	
	// Create the response
	create response transient;
	
	term := app.myPassport.myTerminal;
	
	if term = null then
		self.httpStatusCode := HttpResponseSystemError;
		return response;
	endif;
	
	if _jobUid = "" then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	job := app.myPassport.getObjectOfTypeFromOid(_jobUid, CM_VoyageJob).CM_VoyageJob;
	if app.myPassport.hasErrors then
		return response;
	endif;	
	
	create wsJob transient;
	wsJob.setProxyFromObject(job);
	response.allJobs.add(wsJob);
	
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_jobUid" type="String"/>
        <ReturnType type="WS_JobResponse"/>
    </JadeMethod>
    <JadeMethod name="getVoyageLocations" id="44aecdb0-00e4-45ce-9cfe-538b7de5d3c2">
        <updating/>
        <source>getVoyageLocations(_releaseId : String):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
04 Jan 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
19 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
*/

constants
	LcId		:	String = "id";
	Uid			: 	String = "uid";
	Locations 	:   String = "locations";
	SelLoc		:	String = "SelectedLocation";
vars
	lcSet				: CM_LCSet;
	lc					: CM_LocationsController;
	response			: String;
	lcJdo,
	returnJdo			: JadeDynamicObject;
	allJDOEntity		: JadeDynamicObjectArray;
	terminal			: CM_Terminal;
	bulkRelease			: CM_BulkRelease;
	voyage				: CM_Voyage;
	wod					: CM_WodRelease;
	job					: CM_WOReleaseCargoJob;
	voyJob				: CM_VoyageWorkPointJob;
	hold				: String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	// Some initial setup to help later on
	terminal := app.myPassport.myTerminal;
	create lcSet transient;
	create returnJdo transient;
	self.objectsToBeDeleted.add(returnJdo);
	create allJDOEntity transient;
	self.objectsToBeDeleted.add(allJDOEntity);
	
	bulkRelease := app.myPassport.getObjectOfTypeFromOid(_releaseId, CM_BulkRelease).CM_BulkRelease;
	
	if bulkRelease &lt;&gt; null then
		voyage := bulkRelease.myVoyage;
	endif;
	
	if voyage &lt;&gt; null then						//04.01.2023 navhl20 #61092[61621]
		voyage.getHolds(lcSet);
	endif;
	
	if bulkRelease.allWOReleases.isNotEmpty() then				//19.01.2024 navhl20 #62066
		wod := bulkRelease.allWOReleases.first.CM_WodRelease;
		if wod &lt;&gt; null and wod.allJobs.isNotEmpty() then
			job := wod.allJobs.first.CM_WOReleaseCargoJob;
		endif;
		if job &lt;&gt; null and job.allVoyageJobs.isNotEmpty() then
			voyJob := job.allVoyageJobs.first.CM_VoyageWorkPointJob;
		endif;
		if voyJob &lt;&gt; null then
			hold := voyJob.getVoyageHold();
		endif;
	endif;
	
	if lcSet.isNotEmpty() then
		foreach lc in lcSet do
			create lcJdo transient;
			lcJdo.addProperty(LcId, String);
			lcJdo.setPropertyValue(LcId, lc.getFullId());
			lcJdo.addProperty(Uid, String);
			lcJdo.setPropertyValue(Uid, lc.getOidString);
			allJDOEntity.add(lcJdo);
			self.objectsToBeDeleted.add(lcJdo);
		endforeach;
		returnJdo.addProperty(Locations, JadeDynamicObjectArray);
		returnJdo.setPropertyValue(Locations, allJDOEntity );
		returnJdo.addProperty(SelLoc, String);							//19.01.2024 navhl20 #62066
		returnJdo.setPropertyValue(SelLoc, hold);						//19.01.2024 navhl20 #62066
	endif;
	returnJdo.deserializeJSON(response);
	
	// return the response
	return response;
epilog
	self.finaliseJSONResponse(response);
	delete lcSet;	
	return response;
end;</source>
        <Parameter name="_releaseId" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWagonChecks" id="8f474ba3-a318-4188-bfec-7872e99c2f0a">
        <updating/>
        <source>getWagonChecks(wagonOid : String; context : Integer) : WS_CargoChecksResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 July 2022		jlier1	Initial creation 53971
04 November 2022	jlizm1	TFS 54118 Assigning Releases to Wagons

*/

vars
	response : WS_CargoChecksResponse;
	cargoCheck 		: CM_CargoCheck;
	cargoCheckItem : CM_CargoCheckItem;
	cargoCheckProxy : WS_CargoCheck;
	wagon : CM_Wagon;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	
	wagon:=app.myPassport.getObjectOfTypeFromOid(wagonOid,CM_Wagon).CM_Wagon;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if wagon = null then
		app.raiseCMException1(Wagon_not_found_expect_wagons,wagonOid,null,null);
		return response;
	endif;	
	
	//should be either WAGON_CHECK_CONTEXT_PLACE_IN or WAGON_CHECK_CONTEXT_PLACE_OUT
	if context &lt;&gt; WAGON_CHECK_CONTEXT_PLACE_IN and context &lt;&gt; WAGON_CHECK_CONTEXT_PLACE_OUT and context &lt;&gt; WAGON_CHECK_LOAD_COMPLETE then
		//return error
		return response;
	endif;
	cargoCheck:=app.myPassport.myTerminal.allCargoChecks[context];
	if cargoCheck = null then
		
		return response;
	endif;
	foreach cargoCheckItem in cargoCheck.allCargoCheckItems do
		
		if cargoCheckItem.requiredExtraInfo = EXTRA_INFO_SEALS then
			//check if the wagon class has any seals defined
			if wagon.myWagonClass.allSelectedSealTypes.first = null then
				continue;
			endif;			
		endif;
		
		create cargoCheckProxy transient;
		
		cargoCheckProxy.setProxyFromObjectAndSeals(app.myPassport.myTerminal,null,cargoCheckItem);
		
		response.allCargoChecks.add(cargoCheckProxy);
	
	endforeach;	
	
	return response;
epilog
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="wagonOid" type="String"/>
        <Parameter name="context" type="Integer"/>
        <ReturnType type="WS_CargoChecksResponse"/>
    </JadeMethod>
    <JadeMethod name="getWagonDamageConfigData" id="ce3ad226-4a8d-40c5-b87a-265dbf84a715">
        <updating/>
        <source>getWagonDamageConfigData() : WS_DamageConfigResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
29 Aug 2023		navcs2	ChangeRequest 58142: EUP | Add advanced damage to rail wagons - From FR &lt;&lt;53489&gt;&gt; JADE
19 Mar 2024		jlizm1	MTN 34270 Default damage severity on web apps
*/

vars
	response 		: WS_DamageConfigResponse;
	damageCode 		: CM_DamageDefinitionCode;
	damagePos 		: CM_DamagePosition;
	wsDamCode 		: WS_DamageCode;
	wsDamPos 		: WS_DamagePosition;
	wsDamSev 		: WS_DamageSeverity;
	severity  		: CM_DamageSeverity;
	damPlace		: CM_DamagePlace;
	wsDamPlace		: WS_DamagePlace;
	wsDamReason 	: WS_DamageReason;
	damReason 		: CM_DamageReason;
	wsDamParty 		: WS_ResponsibleParty;
	damParty		: CM_DamageParty;
	advanceDamPerm,
	advancedRepPerm	: Boolean;
	repairReason 	: CM_RepairReason;
	wsRepairReason	: WS_RepairReason;
	terminal		: CM_Terminal;
	myRoot 			: CM_Root;
	machType 		: CM_MachineType;

begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportPartial();
	
	create response transient;
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	machType := app.myRoot.allMachineTypes[MACHINETYPE_WAGONRAIL];

	terminal := app.myPassport.myTerminal;
	myRoot := app.myRoot;
	
	advanceDamPerm := app.myCurrentUserCan(terminal,PmAdmDamageCodeAdvancedMaint);
	advancedRepPerm := 	app.myCurrentUserCan(terminal,PmAdmTIRepairMaint);

	
	// Populate Validate response 
	foreach damageCode in machType.CM_MachineType.allDamageDefinitionCodes discreteLock do
		create wsDamCode transient;
		wsDamCode.setProxyFromObject(damageCode);
		response.allDamageCodes.add(wsDamCode);
	endforeach;
	
	foreach damagePos in machType.CM_MachineType.allDamagePositions discreteLock do
		create wsDamPos transient;
		wsDamPos.setProxyFromObject(damagePos);
		response.allDamagePositions.add(wsDamPos);
	endforeach;
	
	foreach severity in terminal.allDamageSeverities do		
		create wsDamSev transient;
		wsDamSev.setProxyFromObject(severity);
		response.allDamageSeverities.add( wsDamSev );
	endforeach;
	
	severity := terminal.getConfig(DamageSeverityDefault).CM_DamageSeverity;
	if severity &lt;&gt; null then
		create wsDamSev transient;
		wsDamSev.setProxyFromObject(severity);
		response.defaultDamageSeverity := wsDamSev;
	endif;
	
	// advanced details only if we have the advanced permission
	if advanceDamPerm then
		foreach damPlace in terminal.allDamagePlaces do
			create wsDamPlace transient;
			wsDamPlace.setProxyFromObject(damPlace);
			response.allDamagePlaces.add(wsDamPlace);
		endforeach;
		
		foreach damReason in terminal.allDamageReasons do
			create wsDamReason transient;
			wsDamReason.setProxyFromObject(damReason);
			response.allDamageReasons.add(wsDamReason);
		endforeach;
		
		foreach damParty in terminal.allDamageParties do
			create wsDamParty transient;
			wsDamParty.setProxyFromObject(damParty);
			response.allDamageParties.add(wsDamParty);
		endforeach;
	endif;
	
	if advancedRepPerm then
		foreach repairReason in terminal.allRepairReasons do
			if repairReason.isNotAvalableForEntry then
				continue;
			endif;
			create wsRepairReason transient;
			wsRepairReason.setProxyFromObject(repairReason);
			response.allRepairReasons.add(wsRepairReason);
		endforeach;
	endif;
	
	return response;
epilog
	finaliseResponse(response);
end;</source>
        <ReturnType type="WS_DamageConfigResponse"/>
    </JadeMethod>
    <JadeMethod name="getWagonLoadedCargoAmount" id="7d439fa8-e3f5-4e64-b6aa-2909b49b2dc6">
        <updating/>
        <source>getWagonLoadedCargoAmount(wagonOid : String; isInward : Boolean) : WS_CargoAmountResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 May 2025			jlizm1	Initial creation MTN 34761 Rail lander totals only include first 50 search results

*/

vars
	response 		: WS_CargoAmountResponse;
	wagon 			: CM_Wagon;
	tiArray			: CM_TIArray;
	weight			: Decimal[12,4];
	quantity		: Integer;
	totalQuantity	: Integer;
	ti 				: CM_TrackedItem;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;		
	
	wagon := app.myPassport.getObjectOfTypeFromOid(wagonOid,CM_Wagon).CM_Wagon;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if wagon = null then
		app.raiseCMException1(Wagon_not_found_expect_wagons, wagonOid, null, null);
		return response;
	endif;	
	
	create tiArray transient;
	wagon.getAllTrackedItems(isInward, tiArray, false);
	
	foreach ti in tiArray do
		quantity := quantity + 1;
		totalQuantity := totalQuantity + ti.totalQuantity;
		weight := weight + ti.totalWeight;
	endforeach;

	response.quantity := quantity;
	response.totalQuantity := totalQuantity;
	response.totalWeight := weight.asStringJMT();
	
	return response;
	
epilog
	delete tiArray;
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="wagonOid" type="String"/>
        <Parameter name="isInward" type="Boolean"/>
        <ReturnType type="WS_CargoAmountResponse"/>
    </JadeMethod>
    <JadeMethod name="getWagonWeights" id="a9132b64-4afb-42d7-8322-9ee39547f32d">
        <updating/>
        <source>getWagonWeights(wagonOid : String) : WS_WagonWeightsResponse updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 July 2022
TFS#		: 53741
Function	:

*** Changes ***
Date			Name		TFS#		Description
18/08/2022		jlika1		TFS 54549  	EUP - Max Wagon Payload
****************************************************/

vars
	response 	: WS_WagonWeightsResponse;
	wagon 		: CM_Wagon;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;		
	
	wagon := app.myPassport.getObjectOfTypeFromOid(wagonOid,CM_Wagon).CM_Wagon;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if wagon = null then
		app.raiseCMException1(Wagon_not_found_expect_wagons,wagonOid,null,null);
		return response;
	endif;	
	
	response.maxCargoWeight := wagon.getMaxCargoWeight().asStringJMT();
	response.tareWeight := wagon.getWagonTareWeight().asStringJMT();
	
	return response;
epilog
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="wagonOid" type="String"/>
        <ReturnType type="WS_WagonWeightsResponse"/>
    </JadeMethod>
    <JadeMethod name="getWagonsForTrain" id="3de2e261-df0d-43ea-adcb-ea188a37d0e3">
        <updating/>
        <source>getWagonsForTrain(trainOid : String; optionalParam : ParamListType) : WS_WagonsResponse updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	response		: WS_WagonsResponse;
	wagon			: CM_Wagon;
	wagons			: CM_WagonSet;
	wagonProxy	    : WS_Wagon;
	train			: CM_Train;
	allTis 			: CM_TIArray;
	inwardOnly,
	outwardOnly, 
	canLoad, 
	canDischarge 	: Boolean;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	train := app.myPassport.getObjectOfTypeFromOid(trainOid,CM_Train).CM_Train;
	if train = null then
		return response;
	endif;
	
	inwardOnly 			:= parseParameterList(optionalParam, 1, Boolean).Boolean;
	outwardOnly			:= parseParameterList(optionalParam, 2, Boolean).Boolean;
	if inwardOnly or outwardOnly then
		wagons := train.getWagons(outwardOnly, inwardOnly);
	else
		wagons := train.getWagons(true, true);
	endif;
	create allTis transient;
	foreach wagon in wagons do
		canLoad:=false;
		canDischarge:=false;
		if train.allWagonsByIdInward[wagon.id] &lt;&gt; null then
			canLoad:=true;
		endif;
		
		allTis.clear();
		wagon.getAllTrackedItems(true, allTis, false);
		if allTis.first() &lt;&gt; null then
			canDischarge:=true;
		endif;
		
		if inwardOnly and not canLoad then
			continue;
		endif;
		if outwardOnly and not canDischarge then
			continue;
		endif;
		
		create wagonProxy transient;
		wagonProxy.setProxyFromObject(wagon);
		wagonProxy.canLoad:=canLoad;
		wagonProxy.canDischarge:=canDischarge;
		
		response.allWagons.add(wagonProxy);
	endforeach;
	
	return response;
epilog
	delete allTis;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="trainOid" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_WagonsResponse"/>
    </JadeMethod>
    <JadeMethod name="getWorkPointJobSheet" id="d5ceb44c-b492-4eed-be6b-e6395ac10557">
        <updating/>
        <source>getWorkPointJobSheet(_workPointType : String):WS_RestIntWPJobSheetResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Sep 2023	navma1  ChangeRequest 60014: EUP | Mobile DD - Work Point Selection - [BackEnd]
20 Sep 2023 namva1	Defect 60580: MTN - Internal server error when an invalid _workPointType is entered 
06 Nov 2023 navhl20 ChangeRequest 58756:[60740] EUP | VAS Mobile App - [53813.010] VAS Mobile App
*/

vars
	response 	    : WS_RestIntWPJobSheetResponse;
	term	 	    : CM_Terminal;
	jobSheet  		: CM_JobSheet;
	wsJobSheet		: WS_RestIntJobSheet;
	workPointType   : CM_WorkPointType;
	workPointcode   : String;
	jobSheetDict 	: CM_WPJobSheetByDate;
begin
	
	// Arm exception handler for CM Exceptions
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	term := app.myPassport.myTerminal;
	
	if term = null then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	if not app.myPassport.isVASEnabled  then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	workPointcode 			:= self.qsData.getValue(self.QueryParam_WPCode).asStringJMT();
	if workPointcode &lt;&gt; null  then
		
		workPointType := term.allWorkPointTypes[_workPointType.Integer,workPointcode];			//20.09.2023 navma1 #60580
		if workPointType = null then
			app.raiseCMException1(ERR_WorkPointType_NotExist,workPointcode,null,null);
			self.httpStatusCode := HttpResponseNotFound;
			return response;
		else
			if workPointType.code &lt;&gt; workPointcode then
				app.raiseCMException1(ERR_WorkPointType_NotExist,workPointcode,null,null);
				self.httpStatusCode := HttpResponseNotFound;
				return response;
			endif;
		endif;
	endif;

	create jobSheetDict transient;
	term.allJobSheetsForWorkPoints.copy(jobSheetDict);											//25.02.2025 navma1 #MTN-34075
	
	foreach jobSheet in jobSheetDict discreteLock do 											//25.02.2025 navma1 #MTN-34075
		
		if workPointType &lt;&gt; null then															//10.11.2023 navhl20 #58756[60740]
			if jobSheet.getWorkPointType() &lt;&gt; workPointType then
				continue;
			endif;
		else
			if jobSheet.getWorkPointType().type &lt;&gt; _workPointType.Integer then
				continue;
			endif;
		endif;
		
		/*
		Extra Condition will be added later to filter current Shift only
		*/
		create wsJobSheet transient;
		wsJobSheet.setProxyFromObject(jobSheet);
		response.allJobSheets.add(wsJobSheet);
	endforeach;
	
	return response;
epilog
	delete jobSheetDict;
	finaliseResponse(response);
end;</source>
        <Parameter name="_workPointType" type="String"/>
        <ReturnType type="WS_RestIntWPJobSheetResponse"/>
    </JadeMethod>
    <JadeMethod name="getWorkPointTypes" id="a58ee49c-592b-4b8b-8e26-28c3b31dcd95">
        <updating/>
        <source>getWorkPointTypes():WS_RestIntWPTypeResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Sep 2023	navma1 ChangeRequest 60014: EUP | Mobile DD - Work Point Selection - [BackEnd]
*/

vars
	response 	    : WS_RestIntWPTypeResponse;
	terminal 	    : CM_Terminal;
	workPointType   : CM_WorkPointType;
	wsWorkPointType : WS_RestIntWorkPointType;
	iter		    : Iterator;
begin
	// Arm exception handler for CM Exceptions
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	terminal := app.myPassport.myTerminal;
	
	if terminal = null then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	if not app.myPassport.isVASEnabled  then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	iter := terminal.allWorkPointTypes.createIterator;
	
	while iter.next(workPointType) do
		if workPointType.notAvailableForEntry  then
			continue;
		endif;
		
		create wsWorkPointType transient;
		wsWorkPointType.setProxyFromObject(workPointType);
		response.allWorkPointTypes.add(wsWorkPointType);
	endwhile;
	
	return response;
epilog
	delete iter;
	finaliseResponse(response);
end;</source>
        <ReturnType type="WS_RestIntWPTypeResponse"/>
    </JadeMethod>
    <JadeMethod name="getYardLocationById" id="586c7a21-d5c6-4c92-ae03-e712c5f1f05a">
        <updating/>
        <source>getYardLocationById(locationId : String) : WS_LocationResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 August 2021	jlier1	Initial creation 51684
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	terminal : CM_Terminal;
	response : WS_LocationResponse;
	foundLC : CM_LocationsController;
	foundHeight : Integer;
	wsLC : 	WS_LocationsController;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	create response transient;

	if locationId = null then
		app.raiseCMException(Input_Required_For_Location,null,null);
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	terminal.findLocationFromString(locationId.asStringRESTFUL ,true,foundLC,foundHeight);
	
	if foundLC &lt;&gt; null and foundLC.isKindOf(CM_YardController) then
		create wsLC transient;
		wsLC.setProxyFromObject(foundLC);
		response.myLocation:=wsLC;
	
	else
		app.raiseCMException1(Location_NotFound,locationId.asStringRESTFUL.toUpper,null,null);	
	endif;
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="locationId" type="String"/>
        <ReturnType type="WS_LocationResponse"/>
    </JadeMethod>
    <JadeMethod name="getYardLocationsForArea" id="e173d63e-3d98-4744-adf3-a3fa5c99a8ac">
        <updating/>
        <source>getYardLocationsForArea(areaID : String)  : WS_LocationsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2022	jlier1	Initial creation 53766

*/

vars
	terminal : CM_Terminal;
	response : WS_LocationsResponse;
	location : CM_LocationsController;
	foundHeight : Integer;
	wsLC : 	WS_LocationsController;
	terminalArea : CM_TerminalAreaMaster;
	iter : Iterator;
	failedDAC : CM_DataAccessController;
	allLCsSet : CM_LCSet;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	create response transient;

	if areaID = null then
		app.raiseCMException(Input_Required_For_Location,null,null);
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	terminalArea := terminal.allTerminalAreaMastersById[areaID];
		
	
	// Code cloned from CMUI_Assistant::comboBoxLocationControllers and CMUI_Assistant::displayEntryLocationController
	if terminalArea &lt;&gt; null then
	
		if terminalArea.isKindOf(CM_IrregularBlockArea) then
			create allLCsSet transient; 
			terminalArea.CM_IrregularBlockArea.getValidLCsCollectionForMove(allLCsSet);
			iter:=allLCsSet.createIterator;
		else
			iter := terminalArea.getLCsCollectionForDisplay.createIterator();
		endif;
		while iter.next(location) do
		
			if not location.canUserAccessSelf(null, failedDAC, app.myPassport) then
				continue;
			endif;
			
			create wsLC transient;
			wsLC.setProxyFromObject(location);
			response.allLocationsControllers.add(wsLC);
		endwhile;	
	endif;
	
	// Got to here, everything is ok
	
	return response;
	

epilog
	delete allLCsSet;
	delete iter;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="areaID" type="String"/>
        <ReturnType type="WS_LocationsResponse"/>
    </JadeMethod>
    <JadeMethod name="initMachineOptional" id="e3025637-1f01-40ff-81f1-89cf6bb69552">
        <source>initMachineOptional() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2022	jlier1	Initial creation

*/

constants
    MachineID = "MachineID";
vars
	machineCookie : CM_StringWithString; 
	machineCookieID : String ;
	machine : CM_Machine ; 
	cookies : CM_StringDict;

begin
	create cookies transient;
	self.parseCookies(cookies);
	machineCookie:=cookies[MachineID].CM_StringWithString;
	if machineCookie &lt;&gt; null and machineCookie.strString &lt;&gt; null then
		machineCookieID:=machineCookie.strString;
	endif;
	if machineCookieID &lt;&gt; null then
		app.myPassport.setMyMachine(app.myPassport.myTerminal.machines[machineCookieID]);
	endif;
epilog
	if cookies &lt;&gt; null then
		cookies.purge;
	endif;
	delete cookies;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialisePassportMachineSSO" id="7af03ab5-b0cd-42d6-8f1a-72410ea3c6cd">
        <updating/>
        <source>initialisePassportMachineSSO(_accessToken, _terminalId, _machineId : String; upn, uid: String output) : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2022 navam1  TFS 53986: EUP - Azure Active Directory Single Sign On - Web
05 Apr 2024 navmj1	TFS 63510: MTN - Change the name of the method for the JSM transaction
08 May 2025 navnk30	JIRA 34701: SSO Implementation for Vehicle App - Jade Portion
*/

vars
	locale 		 : CM_Locale;
	terminal 	 : CM_Terminal;
	user 		 : CM_User;
	result		 : Integer;
    callStack    : ProcessStackArray;
    methCallDesc : MethodCallDesc;
begin	
	// Get the calling method, not the current one, so the correct name is 
	// used in the JSM trx. 04 Apr 2024. 
	create callStack;
    process.currentStack(callStack);
	methCallDesc := callStack[3];  
	
	self.startCnTrx:= cnStartTransaction(methCallDesc.method.qualifiedName[1:CN_TRANSACTION_ID_MAXLENGTH]);
	app.writeLog(methCallDesc.method.qualifiedName, LogTRACE);

	app.createPassport();
	
	//validate accessToken in the request and retrieve upn and uid
	WS_WebServiceAgent@validateSSOJWT(_accessToken, upn, uid);
	
	if app.myPassport.hasErrors() then
		app.writeLog(method.qualifiedName &amp; " Returning Early: Azure SSO Token invalid", LogTRACE);
		return null;
	endif;
	
	result := app.validateUserSSO(upn, uid);
	if result &lt;&gt; 0 then
		app.writeLog(method.qualifiedName &amp; " Invalid Username/Password", LogERROR);
		return false;
	endif;
	
	if result = 0 then

		user := app.getMyUser();
		
		if _terminalId &lt;&gt; null then
			terminal := app.myRoot.allTerminals[_terminalId];
		endif;
		if terminal = null then
			if self.httpStatusCode = null then
				self.httpStatusCode := HttpResponseForbidden;
			endif;
			return false;
		endif;

	endif;
	
	// Set Locale and Special based on user
	app.isRTApp := false;
	app.myPassport.setMyUser(user);
	app.myPassport.setMyTerminal(terminal);
	
	locale := user.getLocale();
	app.setLocale(locale);

	if user.code = "SUPERUSER" then
		app.setSpecial('31/12/3000'.TimeStamp);
	else
		app.setSpecial(app.actualTimeServer);
	endif;
	
	//self.initMachine();						//08.05.2025 navnk30 JIRA 34701
	self.initMachineByMachineId(_machineId);	//08.05.2025 navnk30 JIRA 34701
	if self.httpStatusCode = HttpResponseForbidden then
		return false;
	endif;

	self.saveUserState(user, terminal);
	return true;
epilog
	if callStack &lt;&gt; null then
		callStack.purge;
		delete callStack;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_accessToken" type="String"/>
        <Parameter name="_terminalId" type="String"/>
        <Parameter name="_machineId" type="String"/>
        <Parameter name="upn" type="String" usage="output"/>
        <Parameter name="uid" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="postCargoDamage" id="5b4ccaff-6327-46da-a3bb-425f3222f635">
        <updating/>
        <source>postCargoDamage(_cargoDamageRequest : WS_CargoDamageRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 Sept 2022	navlw1	Initial creation tfs 53880 Web extra damage details task 54812
19 May	2023	navcs2	Defect 57970: MTN - Mobile Apps cargo lander check cargo was not saving new cargo damage
30/06/2023		navcs2 	Bug 58965: EUP - When deleting damage in Mobile apps it does not remove the DamagedDT
14/08/2023		navkc1	Bug 59111: MTN - Get Method raiseUnexpectedProgramError() Issue
19/12/2023      navbk1  Defect 61444: MTN - Damage Time is incorrect in the getCargoDamage Response
*/

vars
	response 		: WS_Response;
	terminal 		: CM_Terminal;
	wsDamageObject 	: WS_RestDamageObject;
	cargoId,
	cargoOid		: String;
	ti,	
	pxyTI			: CM_TrackedItem;
	damPos 			: CM_DamagePosition;
	damType 		: CM_DamageDefinitionCode;
	damSev 			: CM_DamageSeverity;
	damParty 		: CM_DamageParty;
	damReason		: CM_DamageReason;
	damPlace		: CM_DamagePlace;
	status 			: Integer;
	damSize			: String;
	isLoadState,
	advanceDamPerm	: Boolean;
	damDate			: TimeStamp;

begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);

	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	self.setIgnoreWarnings(_cargoDamageRequest.warningsAcknowledged);
		
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHDamageReport);
	if app.myPassport.hasErrors then
		return response;
	endif;	
	
	wsDamageObject := _cargoDamageRequest.damage;
	cargoId := _cargoDamageRequest.cargoId;
	cargoOid := _cargoDamageRequest.cargoUid;												// 18/05/2023 navcs2 Defect 57970
	
	//jlier1 TFS 58968 12/9/23 if no damage object then just create quick damage
	if cargoId = null and cargoOid = null  then
		app.raiseCMException1(Cargo_item_not_found, cargoId , null, null);
		return response;
	endif;
	
	ti := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;	// 18/05/2023 navcs2 Defect 57970
	
	if ti = null then																		// 18/05/2023 navcs2 Defect 57970
		ti := terminal.lookupTrackedItem(cargoId, null, null, null, false);					// 18/05/2023 navcs2 Defect 57970
	endif;																					// 18/05/2023 navcs2 Defect 57970
	
	if ti = null then
		app.raiseCMException1(Cargo_item_not_found, cargoId , null, null);
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	if wsDamageObject = null and ti.damaged then
			app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String  &amp; " already damamged" , LogINFO);
		return response; //nothing to do already damaged
	endif;
	
	
	if wsDamageObject &lt;&gt; null then
		advanceDamPerm := app.myCurrentUserCan(terminal,PmAdmDamageCodeAdvancedMaint);
		
		// advanced permission check
		if advanceDamPerm then
			if wsDamageObject.responsibleParty &lt;&gt; null then
				damParty := terminal.allDamageParties[wsDamageObject.responsibleParty].CM_DamageParty;
			endif;
			status := wsDamageObject.damageStatus.Integer;
			if wsDamageObject.damagePlace &lt;&gt; null then
				damPlace := terminal.allDamagePlaces[wsDamageObject.damagePlace].CM_DamagePlace;
			endif;
			damDate := wsDamageObject.damageDateTime.TimeStamp;                                        // 19/12/23 navbk1 Defect 61444
			if wsDamageObject.damageReason &lt;&gt; null then
				damReason := terminal.allDamageReasons[wsDamageObject.damageReason].CM_DamageReason;
			endif;
		endif;
		// 30/06/2023 navcs2 Defect 58120  //jlier1 TFS 58968 12/9/2
		if (wsDamageObject.damagePosition = null or wsDamageObject.damageDefinition = null) and damParty = null then
			//14/08/2023	navkc1	Bug 59111 - Display info message
			response.addInfo(app.getErrorString(CargoDamagedNoInstance));
			
			if ti.damaged then
				return response;
			else
				app.cmsBeginLoad(isLoadState);
				pxyTI := ti.pxyCreateUpdateProxy();
				app.cmsEndLoad(isLoadState);
				pxyTI.setDamaged(true);
				app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
				return response;
			endif;
		endif;
		// 30/06/2023 navcs2 Defect 58120
		
		if wsDamageObject.damagePosition &lt;&gt; null then
			damPos := app.myRoot.allDamagePositionsByCode[wsDamageObject.damagePosition].CM_DamagePosition;
		endif;
		if wsDamageObject.damageDefinition &lt;&gt; null then
			damType := app.myRoot.allDamageDefinitionCodes[wsDamageObject.damageDefinition].CM_DamageDefinitionCode;
		endif;
		if wsDamageObject.damageSeverity.String &lt;&gt; null then
			damSev := terminal.allDamageSeverities[wsDamageObject.damageSeverity.String];
		endif;
		if wsDamageObject.damageSize &lt;&gt; null then
			damSize := wsDamageObject.damageSize.value.String;
		endif;
		status := null;
		
		
		
		
	endif;
	
	app.cmsBeginLoad(isLoadState);
	pxyTI := ti.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoadState);
	
	pxyTI.setDamaged(true);
	pxyTI.setDamagedDT(true);	
	
	// 30/06/2023	navcs2 	Bug 58965
	if wsDamageObject &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String  &amp; "creating damage " &amp; damParty.String , LogINFO);
		pxyTI.createPxyDamageInstance(damType, 
								  damPos,
								  wsDamageObject.remarks, 
								  true, 
								  wsDamageObject.quantity, 
								  damSev, 
								  null,
								  damPlace, 
								  damParty, 
								  damReason, 
								  null, 
								  damSize.Decimal, 
								  damDate,
								  status, 
								  null, 
								  null);
	endif;
								  
	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	
	return response;
epilog
	app.cmsEndLoad(isLoadState);
	delete pxyTI;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_cargoDamageRequest" type="WS_CargoDamageRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postCargoOnWagon" id="ddb453b2-e29c-48f4-b301-7ccf66120ce7">
        <updating/>
        <source>postCargoOnWagon(request : WS_CargoOnWagonRequest; wagonOid : String) : WS_TrackedItemUpdateResponse updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	response : WS_TrackedItemUpdateResponse;
	terminal	   : CM_Terminal;
	error		   : CM_Error;
	ti 			   : CM_TrackedItem;
	mess 		   : String;
	wagon 		   : CM_Wagon;
	locnController : CM_WagonController;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
		
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if request.id = "" then
		app.raiseCMException(ERR_TIID_MISSING,null,null);
		return response;
	endif;

	if wagonOid = "" then
		app.raiseCMException(ERR_NO_WAGON_ID,null,null);
		return response;
	endif;
	
	if request.isoType = "" then
		app.raiseCMException(ERR_INVALID_ISOTYPE,null,null);
		return response;
	endif;

	//epr TFS 5535 4/8/17 
	wagon := app.myPassport.getObjectOfTypeFromOid(wagonOid,CM_Wagon).CM_Wagon;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if wagon = null then
		app.raiseCMException(ERR_INVALID_WAGONNO,null,null);

		return response;
	endif;	
	
	if wagon.isBoxcar or wagon.isSkeletonCar then
		locnController := wagon.allLocationsControllers.first();
	elseif wagon.isFlatcar or wagon.isWellcarVisit then
		if request.wagonPosition &lt; 1 or request.wagonPosition &gt; wagon.allLocationsControllersArray.size then
			app.raiseCMException(Please_select_positionPOP,null,null);
			return response;
		endif;
		locnController := wagon.allLocationsControllersArray[request.wagonPosition];
	endif;
	if locnController = null then
		app.raiseCMException(Please_select_positionPOP,null,null);
		return response;		
	endif;
	
	ti := wagon.createNewTIFromHandHeld(request.id, locnController, request.isoType.toUpper, self.class, mess);
	
	if ti = null and mess &lt;&gt; "" then
		create error transient;
		error.setErrorText(mess,false);        
		error.addToPassport(app.myPassport);
	endif;
	
	if ti &lt;&gt; null then
		response.cargoUidUpdated := ti.getOidAsString;
	endif;
	
	if not app.myPassport.trxCompletedOK then
		app.myPassport.removeDuplicateWarnings();
	endif;	
	
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoOnWagonRequest"/>
        <Parameter name="wagonOid" type="String"/>
        <ReturnType type="WS_TrackedItemUpdateResponse"/>
    </JadeMethod>
    <JadeMethod name="postFrontEndException" id="1bf24604-fa17-4f8e-b636-d5684691eac9">
        <updating/>
        <source>postFrontEndException(request: WS_FrontEndExceptionRequest) : WS_Response updating;
/*

Purpose:			
Capture statistics in JSM on when and how often front end exceptions are occuring

Parameters:			
The request should contain the a details parameter with the content of the front end exception. 
At the moment nothing will be done with this log, other than statistics (JSM) will be captured by
the .NET layer. Because this is secure end point the initialisePassport creates the transaction 
that is monitored by JSM.

Return Value:		

Date		Who		Reason
10 April 2024	navmj1	Initial creation

*/

vars
	response : WS_Response;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
			
	response.result := HttpResponseNoContent; // return a 204 code as there is not content
		
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_FrontEndExceptionRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postImportData" id="22234f12-6e2b-417b-af6e-51bc3a99cc8b">
        <updating/>
        <source>postImportData(_request: WS_ImportDataRequest): WS_ImportDataResponse updating;
/**
 * Imports JADE class instances from Base64-encoded XML
 * 
 * REST Endpoint: POST /importData?internalAPI=true
 * Security: Requires valid JWT access token + appropriate import permission
 * 
 * Request Body:
 * - dataEntity: Display name of class to import
 * - dataBase64: Base64-encoded XML from export
 * 
 * Import Mode: ADD_NEW_ONLY
 * - All records must be new (not existing in database)
 * - Updates to existing records not supported
 * - Validates all records before committing any
 * 
 * Permissions:
 * - System classes: PmAdmSystemImport
 * - Terminal classes: PmAdmTerminalImport
 * 
 * Response Codes:
 * - 200: All records imported successfully
 * - 207: Partial success (some records failed)
 * - 400: Bad request (invalid structure)
 * - 403: Forbidden (missing permission)
 * - 422: Unprocessable Entity (XML invalid)
 * - 500: Internal server error
 * 
 * Date        Who                      Reason
 * 6 Jan 2026 naviv1     Initial creation - MTN-36584 - Create Import API
 */
vars
    response: WS_ImportDataResponse;
    passport: CM_Passport;
    term: CM_Terminal;
    exportClass: CM_ExportImportClass;
    wsAgent: CM_DataImportAgent;
    xmlData: String;
    requiredPermission: Integer;
    importResult: CM_ImportResult;
    failedRecord: WS_FailedRecord;
    brokenLinkRecord: WS_BrokenLinkRecord;
    cmFailedRec : CM_FailedRecord;
	cmBrokenLink : CM_BrokenLink;
	dataEntity : String;
begin
    // Arm exception handlers
    on CM_Exception do self.handleCMException(exception);
    on LockException do self.handleLockExceptions(exception);
    
    create response transient;
    
    // Initialize passport and validate session
    self.initialisePassport();
    passport := app.myPassport;
    
    if self.httpStatusCode &lt;&gt; HttpResponseOK then
        app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
        return response;
    endif;
    
    if passport.hasErrors then
        self.httpStatusCode := HttpResponseUnauthorized;
        return response;
    endif;
    
    term := passport.myTerminal;
    if term = null then
        self.httpStatusCode := HttpResponseSystemError;
        return response;
    endif;
    
    // Validate request
	dataEntity := _request.dataEntity.replace(Space,'');
    if _request = null or _request.dataEntity = null or _request.dataBase64 = null then
        self.httpStatusCode := HttpResponseClientError;
        return response;
    endif;
    
    // Validate data entity
    exportClass := app.myRoot.allExportImportClasses.getByDisplayName(dataEntity);
    if exportClass = null then
        self.httpStatusCode := HttpResponseClientError;
        return response;
    endif;
    
    if not exportClass.isExportable then
        self.httpStatusCode := HttpResponseClientError;
        return response;
    endif;
    
    // Check permissions
    requiredPermission := self.getRequiredImportPermission(exportClass.category);
    if not passport.myUser.canDo(term,requiredPermission) then
        self.httpStatusCode := HttpResponseForbidden;

        return response;
    endif;
    
    // Decode Base64 to XML
    xmlData := _request.dataBase64.base64DecodeToString;
	
    
    // Perform import
    create wsAgent transient;
    create importResult transient;
	wsAgent.myExportImportClass := exportClass;
    
   importResult := wsAgent.importFromXmlString(xmlData);
    
    // Build response from import result
    response.recordsProcessed := importResult.recordsProcessed;
    response.successCount := importResult.successCount;
    
    // Add failed records
	create failedRecord transient;
    foreach cmFailedRec in importResult.allFailedRecords do
        failedRecord.objectKey := cmFailedRec.objectKey;
        failedRecord.rowNumber := cmFailedRec.rowNumber;
        failedRecord.errorMessage := cmFailedRec.errorMessage;
        response.failedRecords.add(failedRecord);
    endforeach;
    
    // Add broken link records
	create brokenLinkRecord transient;
    foreach cmBrokenLink in importResult.allBrokenLinks do
        brokenLinkRecord.objectKey := cmBrokenLink.objectKey;
        brokenLinkRecord.errorMessage := cmBrokenLink.errorMessage;
        brokenLinkRecord.missingLink := cmBrokenLink.referencedKey;
        response.brokenLinkRecords.add(brokenLinkRecord);
    endforeach;
    
    // Set HTTP status code
    if response.failedRecords.size &gt; 0 or response.brokenLinkRecords.size &gt; 0 then
        self.httpStatusCode := HttpResponseClientError;  
    elseif response.successCount &gt; 0 then
        self.httpStatusCode := HttpResponseOK;  // 200
    endif;
    
    return response;
    
epilog
    self.finaliseResponse(response);
    delete wsAgent;
    delete importResult;
end;</source>
        <Parameter name="_request" type="WS_ImportDataRequest"/>
        <ReturnType type="WS_ImportDataResponse"/>
    </JadeMethod>
    <JadeMethod name="postLogoffMachineForPicking" id="86db9b40-557e-4a80-b113-3b9b767c4a0b">
        <updating/>
        <source>postLogoffMachineForPicking(machineOid : String): WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626
07 April 2022	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_Response;
	machine : CM_Machine;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	app.checkCurrentUserHasAccess(PmHHOrderPicking);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;		
		
	machine:= app.myPassport.getObjectOfTypeFromOid(machineOid,CM_Machine).CM_Machine;
	if machine = null then
		app.raiseCMException2(ERR_MACH_NOTFOUND,machineOid,app.myPassport.myTerminal.code,null,null);
		return response;
	endif;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if machine.loggedOn and machine.user = app.myPassport.myUser then
		app.myTrxUA.trxUpdateLogoff( machine, app.myPassport );
	endif;
		
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="machineOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postLogonMachine" id="7748d6c1-2b1d-47dd-8fa7-024f8fbe966f">
        <updating/>
        <source>postLogonMachine(): WS_LogonResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation TFS 52595
15 Nov 2022	jlier1 TFS 55160
28 May 2023 jlier1 TFS 56468
*/

vars
	response : WS_LogonResponse;
	username,
	password,resultStr  : String;
	result : Integer;
	passport : CM_Passport;
	machine  : CM_Machine;
	errorMsg : WS_ErrorMessage;
	user : CM_User;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassportMachine();
	
	if app.myPassport.hasErrors then	
		self.httpStatusCode:=HttpResponseForbidden;
		return response;
	endif;
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
	
		if self.httpStatusCode = HttpResponseUnauthorized then
			app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String &amp; " Passwword error", LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
			create errorMsg transient;
			errorMsg.errorCode := ERR_PASSWORD;
			errorMsg.text := app.getErrorString(ERR_PASSWORD );
			response.allErrors.add(errorMsg);
		endif;
	
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String &amp; " user not validated", LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	//app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String &amp; " restSessionID = " &amp;request.sessionID , LogERROR);
	machine:=app.myPassport.myMachine;

	
	self.parseBasicAuth(username,password);
	
	machine:=app.myPassport.myMachine;
	result :=app.myTrxUA.trxUpdateLogonWithMachine(	username, password,machine, passport);
	user :=app.myPassport.myUser;	
	
	if result &lt;&gt; 0  then	
		// Advise the requester that they can force off their old *web* session, if the user has permission to do so
		//jlier1 TFS 56468 16/5/23
		if user &lt;&gt; null then
			response.allowForceLogin := user.getUserSingleSignAllowOverride();
		endif;
		resultStr := app.getErrorString(result);
		app.myRoot.resolveMessagesWithExtraInfo(result, resultStr);
		app.myPassport.addErrorFull(result, resultStr, null, null, null);
	endif;
	
	if user &lt;&gt; null and not user.canDo(null, Mod_WebApps) then
		app.raiseCMException1(NotLicensedToPerformAction, app.getLicenseName(Mod_WebApps),null,null);
	endif;
	if app.myPassport.noErrors then
		//don't stop the login but warn there are fault questions 
		if machine.isFaultQuestionOutstanding then
			app.raiseCMWarning1(ERR_MACH_FAULTS_OUT, machine.id, null, null,null);
		endif;
	endif;
	
	
	return response;
epilog

	self.finaliseResponse(response);
	
end;</source>
        <ReturnType type="WS_LogonResponse"/>
    </JadeMethod>
    <JadeMethod name="postLogonMachineChangePassword" id="6717832b-705f-4647-a2a1-646e5cbd521a">
        <updating/>
        <source>postLogonMachineChangePassword(request : WS_LogonRestRequest): WS_Response updating;	// 02.02.2023 navak20 TFS 55856
/*

Purpose: This is the REST version of the logonWithMachineChangePassword 

Parameters: REST JSON Body parameters as sample below
				{    
					"confirmNewPassword" : "confirmNewPassword",
					"newPassword" : "newPassword"
				}

Return Value:		

Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
15 Nov 2022	jlier1 TFS 55160
02 Feb 2023	navak20 Bug 55856: PNL - Vehicle App - Users unable to update passwords when they expire, or for New Users
============================================================================*/

vars
	passport 	: CM_Passport;
	response 	: WS_Response;	
	user	 	: CM_User;
	machine  	: CM_Machine;
	result 	 	: Integer;	
	username 	: String;
	password,
	resultStr	: String;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Create the response
	create response transient;
	
	self.initialisePassportMachine();
	
	if app.myPassport.hasErrors then
		self.httpStatusCode:=HttpResponseForbidden;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String &amp; " passport has errors", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String &amp; " passport has errors", LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;		
	
	self.parseBasicAuth(username,password);
	
	if not app.myPassport.myUser.canDo(null, Mod_WebApps) then
		app.raiseCMException1(NotLicensedToPerformAction, app.getLicenseName(Mod_WebApps),null,null);		
		return response;
	endif;
	
	machine := app.myPassport.myMachine;
			
	result := app.validateUserPassword(username, password);

	if result = Err_Password_Expired then
		result := 0;
	endif;	
	
	if result = 0 then
		user := app.myRoot.allUsers[username];
	
		app.myTrxUA.trxUpdatePassword(true, username, password, request.newPassword, request.confirmNewPassword, app.myPassport);
	
		// Check for errors in change password
		if not app.myPassport.trxCompletedOK then			
			return response;
		endif;	
		
	endif;
	
	passport := app.myPassport;
	
	result:=app.myTrxUA.trxUpdateLogonWithMachine(	username, request.newPassword,machine, passport);
	
	if result &lt;&gt; 0  then
		resultStr := app.getErrorString(result);
		app.myRoot.resolveMessagesWithExtraInfo(result, resultStr);
		app.myPassport.addErrorFull(result, resultStr, null, null, null);
	endif;
	
	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	
	if app.myPassport.noErrors then
		//don't stop the login but warn there are fault questions 
		if machine.isFaultQuestionOutstanding then
			app.raiseCMWarning1(ERR_MACH_FAULTS_OUT, machine.id, null, null,null);
		endif;
	endif;
		
	return response;
	
epilog
	finaliseResponse(response);	
end;</source>
        <Parameter name="request" type="WS_LogonRestRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postLogonMachineForPicking" id="7e230a71-4022-4b03-80b9-49697ebb6fd7">
        <updating/>
        <source>postLogonMachineForPicking(machineOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_Response;
	machine : CM_Machine;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHOrderPicking);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;		
		
	machine:= app.myPassport.getObjectOfTypeFromOid(machineOid,CM_Machine).CM_Machine;
	if machine = null then
		app.raiseCMException2(ERR_MACH_NOTFOUND,machineOid,app.myPassport.myTerminal.code,null,null);
		return null;
	endif;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.myTrxUA.trxHHAgentDirectMachineLogON( machine, app.myPassport.myUser, app.myPassport );
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="machineOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postLogonSSOMachine" id="f16c2611-7e0e-4319-a8a9-fa14a4b32425">
        <updating/>
        <source>postLogonSSOMachine(request: WS_LogonSSORequest) : WS_LogonSSOResponse updating ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Aug 2022 navam1	ChangeRequest 53986: EUP - Azure Active Directory Single Sign On - Web
08 May 2025 navnk30	JIRA 34701: SSO Implementation for Vehicle App - Jade Portion
	
*/
constants
	AppName : String = "InternalAPIService";
vars
	response 		: WS_LogonSSOResponse;
	user			: CM_User;
	terminal		: CM_Terminal;
	result			: Integer;
	currentTerminal : String;
	upn, uid		: String;
	passport 		: CM_Passport;
	machine  		: CM_Machine;
	resultStr,
	appId			: String;
	jwtClaims		: CMIF_WSClaimsObj;
	accessToken		: String;
	expiry			: Integer;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);

	create response transient;
	
	//self.initialisePassportMachineSSO(request.accessToken, request.terminalId, upn, uid);						//08.05.2025 navnk30 JIRA 34701
	self.initialisePassportMachineSSO(request.accessToken, request.terminalId, request.machineId, upn, uid);	//08.05.2025 navnk30 JIRA 34701
	
	if app.myPassport.hasErrors then	
		self.httpStatusCode:=HttpResponseForbidden;
		return response;
	endif;
	
	if request.forceOffOldSessions then				//12.05.2025 navnk30 JIRA 34701
		self.forceOffOldSessions(app.myPassport);
	endif;

	machine:=app.myPassport.myMachine;
	result :=app.myTrxUA.trxUpdateLogonSSOWithMachine(upn,uid,machine,passport);
	
	/*						15.05.2025 navnk30 JIRA 34701
	if result &lt;&gt; 0  then
		app.myPassport.addErrorFull(result, app.getErrorString(result), null, null, null);
	endif;
	*/
	
	user := app.getMyUser();										//15.05.2025 navnk30 JIRA 34701
	if user &lt;&gt; null and not user.canDo(null, Mod_WebApps) then		//15.05.2025 navnk30 JIRA 34701
	//if not app.myPassport.myUser.canDo(null, Mod_WebApps) then	//15.05.2025 navnk30 JIRA 34701
		app.raiseCMException1(NotLicensedToPerformAction, app.getLicenseName(Mod_WebApps),null,null);
	endif;
	if app.myPassport.noErrors then
		//don't stop the login but warn there are fault questions 
		if machine &lt;&gt; null and machine.isFaultQuestionOutstanding then
			app.raiseCMWarning1(ERR_MACH_FAULTS_OUT, machine.id, null, null,null);
		endif;
	endif;

	response.userCode := app.getMyUserCode;
	
	if result = 0 then
		currentTerminal :=user.getStateData(ConfigGrp_Web, UserCurrentTerminal).String;
		if currentTerminal &lt;&gt; null then	
			terminal:=app.myRoot.allTerminals[currentTerminal];
			if user.allUserTerminals[terminal] = null then
				terminal := null;
			endif;
		endif;

		if terminal = null and not user.allUserTerminals.isEmpty then
			terminal := user.allUserTerminals.first.myTerminal;
		endif;
			
		if terminal = null then
			result := Err_InsufficientPermission;
		endif;
		
		//add jwt tokens to response
		create jwtClaims transient;
		jwtClaims.setScopeClaims("Master Terminal", terminal.code,"Navis","MTN");
		accessToken	:= request.accessToken;			//09.05.2025 navec1 JIRA 34701
		appId := JadeJWTParser@getClaimValue(accessToken, CMIF_WSClaimsObj.JWT_CLAIMS_AZURE_APPID);
		response.accessToken := WS_WebServiceAgent@createJWT(user, terminal, appId, AppName, expiry, false, jwtClaims);
		response.expiresIn := expiry;
		expiry := 0;
		response.refreshToken := WS_WebServiceAgent@createJWT(user, terminal, appId, AppName, expiry, true, jwtClaims);
	else
		response.allowForceLogin := user &lt;&gt; null and user.getUserSingleSignAllowOverride();
		resultStr := app.getErrorString(result);
		app.myRoot.resolveMessagesWithExtraInfo(result, resultStr);
		app.myPassport.addErrorFull(result, resultStr, null, null, null);
	endif;
		
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_LogonSSORequest"/>
        <ReturnType type="WS_LogonSSOResponse"/>
    </JadeMethod>
    <JadeMethod name="postScanConfirmCargo" id="062da682-f203-44b3-9652-45bef49c3553">
        <updating/>
        <source>postScanConfirmCargo(request : WS_CargoLocationMatchRequest):  WS_Response  updating;
/*

Purpose:			

Return Value:		

Date			Who		Reason
29 March 2023	navmj1	Initial creation
18 April 2023	navcs2	ChangeRequest 57557: [57396]: EUP - INB/MOB - New Scanning App - JADE
21 Aug 	2023	jlier1  TFS 59876 - actually move the cargo
01 Sep 2023		jlier1  TFS 60152
21 Sep 2023		navsck1 ChangeRequest 60536: EUP | Mobile DD - [FrontEnd] Truck Jobs - Receive Jobs
20 Nov 2023     navam1	Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
07 Dec 2023 	navhl20 ChangeRequest 58400:[61619] EUP | Ship Operations in DD - [54176.050] Mobile App changes
09 Jan 2023 	navhl20 Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
14 Mar 2024 	navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
10 Jul 2024 	navsck1 Defect 65010: MTN - Mobile Apps - Truck Loader / Unloader is no longer return the warning message 79688 (Unavailable for Release)
23 Jul 2024 	navsck1 ChangeRequest 65258: EUP | 53856 - New Scanning App - Unpack mode issue
06 Mar 2025		navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/
vars
	response 		: WS_Response;
	trackedItem,
	parent			: CM_TrackedItem;
	targetLocation 	: CM_LocationsController;
	dummyHeight 	: Integer;
	failedDAC		: CM_DataAccessController;
	moveAgent 		: CMIF_MobileGenericAgent;	
	entityId1 		: String;
	wagon			: CM_Wagon;
	truck			: CM_Vehicle;
	job  			: CM_Job;
	wle,
	myWle			: CM_WorkListEntry;
	voyage 			: CM_Voyage;
	wsinfo 			: WS_InfoMessage; 
	pxyTI		    : CM_TrackedItem;
	voyJob,
	pxyJob			: CM_VoyageWorkPointJob;
	retroDT			: TimeStamp;
	wo				: CM_WorkOrder;
	unpackWLE 		: CM_WorkListEntry;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
		
	create response transient;	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	app.checkCurrentUserHasAccess(PmMobScanningApp);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	trackedItem := app.myPassport.getObjectOfTypeFromOid(request.cargoId, CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if trackedItem = null then
		app.raiseCMException1(Cargo_item_not_found,request.cargoId ,null,null);
		return response;	
	endif;
	
	app.myPassport.myTerminal.findLocationFromString( request.locationId,true,targetLocation,dummyHeight);
	
	if targetLocation = null then
		app.raiseCMException1(Location_invalid,request.locationId, null,null);
		return response;
	endif;	
	
	if not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),request.locationId, null,null);
		return response;
	endif;
	
	
	if trackedItem.myPrimaryActualLocation = targetLocation then
		app.raiseCMException2(Cargo_already_located, trackedItem.id, targetLocation.getID,null,null );
		return response;
	endif;
	 
	create moveAgent transient;
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);	
	 
	 entityId1 := self.qsData.getValue(QueryParam_WagonId).asStringJMT();
	 if entityId1 &lt;&gt; null then
		wagon := app.myPassport.getObjectOfTypeFromOid(entityId1, CM_Wagon).CM_Wagon;
		if wagon &lt;&gt; null then
			job:= wagon.getReceiveJob;
		endif;
	 endif;
	 
	 if entityId1 = null then
		entityId1 := self.qsData.getValue(QueryParam_TruckId).asStringJMT();
		if entityId1 &lt;&gt; null then
			truck:=app.myPassport.getObjectOfTypeFromOid(entityId1, CM_Vehicle).CM_Vehicle;
			if truck &lt;&gt; null then
				job:=truck.getCurrentRoadJob;
			endif;
		endif;
	 endif;
	 
	 if entityId1 = null then																				//07.12.2023 navhl20 #58400[61619]
		entityId1 := self.qsData.getValue(QueryParam_JobOId).asStringJMT();
		if entityId1 &lt;&gt; null then
			voyJob := app.myPassport.getObjectOfTypeFromOid(entityId1, CM_VoyageWorkPointJob).CM_VoyageWorkPointJob;
			if voyJob &lt;&gt; null and voyJob.myWorkOrderReceiveJob &lt;&gt; null then
				job := voyJob.myWorkOrderReceiveJob;
				foreach myWle in job.workListEntries discreteLock do  //06.03.2025 navma1 #MTN-34179
					if myWle.myTrackedItem = trackedItem then
						wle := myWle;
					endif;
				endforeach;
			endif;
		endif;
	 endif;
	 
	 if entityId1 = null then
		entityId1 := self.qsData.getValue(QueryParam_VoyageId).asStringJMT();
		if entityId1 &lt;&gt; null then
			voyage := app.myPassport.getObjectOfTypeFromOid(entityId1, CM_Voyage).CM_Voyage;
			if voyage &lt;&gt; null then
				moveAgent.doImportGetJobWLE(trackedItem,job,wle,true,false,0,0,targetLocation);
			endif;
		endif;
	 endif;
	 
	 app.writeLog(method.qualifiedName &amp; Tab &amp; " entityID=" &amp;  entityId1.String, LogINFO);
	 
	 if job &lt;&gt; null and wle = null then
		wle:=job.getWLEforTIwithStatus(trackedItem,null,false,true,null);
	 endif;
	 
	 if trackedItem.isChild then
		//parent := trackedItem.myParent;		//20.11.2023 navma1 #60947										//09.01.2023 navhl20 #60947
		//app.myTrxUA.trxUpdateUnpackCargo(trackedItem, targetLocation,null,null, true,app.myPassport);			//09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
		parent := trackedItem.myParent;																			//18.03.2024 navhl20 #62861
		if parent &lt;&gt; null then																					//18.03.2024 navhl20 #62861
			retroDT := parent.getRetrospectiveDT(CM_WOUnpackJob);
		endif;
		
		if job = null then
			entityId1 := self.qsData.getValue(QueryParam_WorkOrderId).asStringJMT;
			wo := app.myPassport.getObjectOfTypeFromOid(entityId1, CM_WorkOrder).CM_WorkOrder;
			foreach myWle in parent.allWorklistEntries discreteLock where myWle.isKindOf(CM_WOUnpackWLE) do		//06.03.2025 navma1 #MTN-34179
				if myWle.job.getWorkOrder() = wo then
					job := myWle.job;
					unpackWLE := myWle;
					break;
				endif;
			endforeach;
		endif;
		 
		// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1 Silent Dead Lock Retry
		app.myPassport.setupForDeadlockReplay(300, 2000);
		while true do
			app.myTrxUA.trxUpdateUnpackCargo(trackedItem, targetLocation,null,null, true,retroDT,app.myPassport);		//14.03.2024 navhl20 #62861
			if app.myPassport.noTrxReplayAllowed() then
				break;
			endif;
		endwhile;
	 else
		// ### TFS CR 64297 TASK 64299 06JUNE024 NAVAB1 Silent Dead Lock Retry
		app.myPassport.setupForDeadlockReplay(300, 2000);
		while true do
			moveAgent.moveTI(trackedItem, null, targetLocation, wle, true, null, null, voyJob);				//18.12.2023 navhl20 #58400[61617]	
			if app.myPassport.noTrxReplayAllowed() then
				break;
			endif;
		endwhile;
	 endif;
	 
	 if job &lt;&gt; null then 					// 21.09.2023 navsck1 #60536
		create wsinfo transient;			// 21.09.2023 navsck1 #60536
		if unpackWLE &lt;&gt; null then
			wsinfo.text := unpackWLE.statusString;	// 23.07.2024 navsck1 #65258
		else
			wsinfo.text := job.statusString;	// 21.09.2023 navsck1 #60536
		endif;
		response.allInfo.add(wsinfo);		// 21.09.2023 navsck1 #60536
	endif;									// 21.09.2023 navsck1 #60536

	return response;
epilog
	delete moveAgent;
	delete pxyTI;
	delete pxyJob;
	
	// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;

	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLocationMatchRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postUserStateData" id="b5dcbada-0090-40d5-a293-157ab01bf3d5">
        <updating/>
        <source>postUserStateData(key: String; value: String): WS_StateDataResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2022	jlier1	Initial creation 54477

*/
constants
	IsDriverMode = "isDriverMode";
vars
	response 		: WS_StateDataResponse;	
	
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Create the response
	create response transient;
		
	self.initialisePassport();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;		
	
	if key = null or value = null then
		return response;
	endif;
	
	app.myTrxUA.trxUpdateUserStateData(app.getMyUser(), ConfigGrp_Web, key, value, app.myPassport);
		
	if key  = IsDriverMode and value.Boolean then
		self.initMachineOptional;
		
		if app.myPassport.myMachine &lt;&gt; null then
			app.myTrxUA.trxMachineSetTaskStates(app.myPassport.myMachine , null, app.myPassport);	
		endif;
	endif;
		
	return response;
	
epilog
	finaliseResponse(response);	

end;</source>
        <Parameter name="key" type="String"/>
        <Parameter name="value" type="String"/>
        <ReturnType type="WS_StateDataResponse"/>
    </JadeMethod>
    <JadeMethod name="postVisitPhotos" id="be00aef3-967e-44fe-8d3a-292918f53b1e">
        <updating/>
        <source>postVisitPhotos(_vistPhotos : WS_VisitPhotoRequest; _truckOid : String ) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Aug 2025	navhl20 Story MTN-35651: TPT | Uploading of Photos into MTN Production | 3 | Web Changes
21 Nov 2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/

vars
	response		: WS_Response;
	wsVistPhoto		: WS_Photo;
	attachment		: CM_Attachment;
	proxyPhoto, 
	photo			: CM_Photo;
	terminal		: CM_Terminal;
	visit			: CM_VehicleVisitRecord;
	iter			: Iterator;
	photosToDelete	: ObjectArray;
	obj				: Object;
	truck			: CM_Vehicle;
	roadJob			: CM_RoadJob;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;	
	
	// Create the response
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	
	if terminal = null then
		self.httpStatusCode := HttpResponseSystemError;
		return response;
	endif;

	// Validate the response
	truck := app.myPassport.getObjectOfTypeFromOid(_truckOid, CM_Vehicle).CM_Vehicle;
	
	if truck = null then
		truck := terminal.vehicles[_truckOid.toUpper, ""];
		
		if truck = null then
			app.raiseCMException(Truck_not_found, null, null);
			return response;
		endif;
	endif;
	
	roadJob := truck.getCurrentRoadJob();
	if roadJob = null then
		app.raiseCMException(Cannot_find_roadJob, null, null);
		return response;
	endif;
	
	visit := roadJob.myVehicleVisit;
	if visit = null then
		app.raiseCMException(Err_No_Vehicle_visit_found, null, null);
		return response;
	endif;

	// Check and remove any duplicates
	create photosToDelete transient;
	foreach wsVistPhoto in _vistPhotos.allPhotos do
		if visit &lt;&gt; null then
			iter := visit.allAttachments.createIterator();
			visit.allAttachments.startKeyGeq(CM_Attachment.Type_Photo,iter);
			while iter.next(attachment) do
				if attachment.type &lt;&gt; CM_Attachment.Type_Photo then
					break;
				endif;	
				photo := attachment.CM_Photo;	
				if wsVistPhoto.description &lt;&gt; null and wsVistPhoto.description = photo.description then
					photosToDelete.add(photo);
				endif;
			endwhile;
			delete iter;
		endif;
	endforeach;
	
	foreach obj in photosToDelete do
		app.myTrxDA.trxDeleteVisitPhoto(obj.CM_Photo, app.myPassport);
		if app.myPassport.hasErrors then
			return response;
		endif;
	endforeach;

	// Add the photos
	foreach wsVistPhoto in _vistPhotos.allPhotos do
		create proxyPhoto transient;
		proxyPhoto.setDescription(wsVistPhoto.description);
		proxyPhoto.setMyParent(visit);
		proxyPhoto.setPhotoContent(wsVistPhoto.photoBytes);
		//proxyPhoto.setThumbnailContent(wsVistPhoto.photoBytes);           //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
		
		app.myTrxCA.trxCreateVisitPhoto(proxyPhoto, photo, app.myPassport);
		if app.myPassport.hasErrors then		
			return response;
		endif;
	endforeach;	

	return response;
epilog
	delete iter;
	delete photosToDelete;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_vistPhotos" type="WS_VisitPhotoRequest"/>
        <Parameter name="_truckOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postWagonOnTrain" id="e8dc24a8-d9e5-4e5a-ae71-4207742cc7d9">
        <updating/>
        <source>postWagonOnTrain(request : WS_WagonAddOrUpdRequest) : WS_WagonAddOrUpdResponse updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	response 		: WS_WagonAddOrUpdResponse;
	train			: CM_Train;
	terminal 		: CM_Terminal;
	railLine		: CM_RailLine;
	wagon,
	currentWagon,
	pxyWagon		: CM_Wagon;
	wagonProxy		: WS_Wagon;
	errorMess		: String;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	loadState 		: Boolean;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;		
	
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if request.trainUid = "" then
		return response;
	endif;
	
	if request.rakeUid = "" then
		return response;
	endif;

	if request.newWagonId = "" then
		return response;
	endif;

	if request.rakePosition &lt; 1 then
		return response;
	endif;

	terminal := app.myPassport.myTerminal;
	
	train := app.myPassport.getObjectOfTypeFromOid(request.trainUid,CM_Train).CM_Train;
	if train = null then
		return response;
	endif;
	
	railLine :=app.myPassport.getObjectOfTypeFromOid( request.rakeUid,CM_RailLine).CM_RailLine;
	if railLine = null then
		return response;
	endif;
	
	currentWagon:=railLine.getWagonAtPosition(request.rakePosition);
	wagon:=train.allWagonsByIdInward[request.newWagonId];
	if currentWagon &lt;&gt; null and currentWagon &lt;&gt; wagon then
		if currentWagon.myTrainInwards &lt;&gt; null and  currentWagon.myTrainInwards &lt;&gt; train and not currentWagon.myTrainInwards.isNullTrain then
			app.raiseCMException2(INWARD_WAG_ALREADY_EXISTS,currentWagon.id, currentWagon.myTrainInwards.code,null,null);
			return response;
		endif;
	endif;	
	//epr already a wagon put it in the position
	if wagon &lt;&gt; null then
		//set Wagon position if currentWagon &lt;&gt; null then swap that
		if wagon.confirmed then
			app.raiseCMException2(Already_confirmed, wagon.id, wagon.getPositionDescr,null,null);
			return response;
		endif;
		if currentWagon &lt;&gt; null and currentWagon.confirmed then
			app.raiseCMException2(Already_confirmed, currentWagon.id, currentWagon.getPositionDescr,null,null);
			return response;
		endif;
		
		if currentWagon = null then
			app.cmsBeginLoad(loadState);
			pxyWagon :=	wagon.pxyCreateUpdateProxy();
			app.cmsEndLoad(loadState);
		
			create wagonUpdateCtrl transient;
			wagonUpdateCtrl.setBasicDetails(CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
											railLine,// rake
											train,	//_train : CM_Train;
											request.rakePosition, //_wagonPosition : Integer;
											false	// isTrainMode
											);										
			wagonUpdateCtrl.myProxyWagon := pxyWagon;
			wagonUpdateCtrl.expectedEditionWagon := wagon.edition;
			wagonUpdateCtrl.populateFromExistingWagonAddTi( wagon, null, 0 );
			
			app.myPassport.clearErrorsWarnings();
			app.myPassport.setWarningsIgnored(true);
			app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);
		else
			app.myTrxUA.trxUpdateWagonRakePositionSwap(currentWagon, wagon, app.myPassport);
		endif;
	else
		
		wagon := train.createOrUpdateWagon(request.newWagonId, request.rakePosition, railLine, errorMess);
	endif;

	if wagon &lt;&gt; null then
		create wagonProxy transient;
		wagonProxy.setProxyFromObject(wagon);
		wagonProxy.setProxyLocationCargo();
		response.wagon := wagonProxy;	
	endif;
	
	if errorMess &lt;&gt; "" then
		app.myPassport.addErrorFull(Wagon_null, errorMess, null, null, null);
	endif;
	
	return response;
	
epilog
	app.cmsEndLoad(loadState);
	delete pxyWagon;
	delete wagonUpdateCtrl;

	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_WagonAddOrUpdRequest"/>
        <ReturnType type="WS_WagonAddOrUpdResponse"/>
    </JadeMethod>
    <JadeMethod name="putAcceptCargoForDischarge" id="5d52b8ff-3a17-48a1-b6e8-089fab7d4b68">
        <updating/>
        <source>putAcceptCargoForDischarge(cargoOid: String; twinCargoOid: String): String updating;
/*

Purpose: This is the REST version of machineDoAcceptDischarge

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	machine 			: CM_Machine;
	response			: String;	
	task,
	tandemTask 			: CM_RTQueueTask;
	sideAccessDirection : Integer;	
	allTasks 			: CM_RTQueueTaskArray;
	cargo,
	twinCargo  			: CM_TrackedItem;
	
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;	
		return response;
	endif;	
	
	cargo :=app.myPassport.getObjectOfTypeFromOid( cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then		
		return response;
	endif;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);		
		return response;
	endif;
	
	twinCargo := app.myPassport.getObjectOfTypeFromOid(twinCargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then		
		return response;
	endif;	
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	
	while true do
		self.setIgnoreWarnings(true);
		
		app.myTrxUA.trxMachineCranePickup(machine, cargo, twinCargo, true, false, app.myPassport);
	
		if app.myPassport.noTrxReplayAllowed() then	
			break;
		endif;

	endwhile;
	
	
	if app.myPassport.hasErrors then		
		return response;
	endif;	
	
	create allTasks transient;
	
	response := machine.getTasksAsJSON(allTasks);
	
	return response;
epilog
	delete allTasks;	
	
	finaliseJSONResponse(response);	
	return response;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
	
end;
	
</source>
        <Parameter name="cargoOid" type="String"/>
        <Parameter name="twinCargoOid" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putAcceptCargoForDriverMove" id="21b61e4d-6d37-476a-ab38-8b278c6fa87f">
        <updating/>
        <source>putAcceptCargoForDriverMove(request : WS_Request;cargoOid: String; twinCargoOid: String): String updating;
/*

Purpose: This is the REST version of machineDoAcceptDriverMove

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	machine 			: CM_Machine;
	response			: String;	
	allTasks 			: CM_RTQueueTaskArray;
	cargo,
	twinCargo  			: CM_TrackedItem;
	quantity			: Integer;
	weight 				: Decimal[16,4];	
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;	
		return response;
	endif;	
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then		
		return response;
	endif;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);		
		return response;
	endif;
	
	twinCargo := app.myPassport.getObjectOfTypeFromOid(twinCargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	self.doDisconnectCargo(cargo,request);
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	
	while true do
		self.setIgnoreWarnings(true);
		
		app.myTrxUA.trxMachineDriverInitiatedMove(machine, cargo, twinCargo, quantity, weight,  app.myPassport);
	
		if app.myPassport.noTrxReplayAllowed() then	
			break;
		endif;

	endwhile;
	
	app.writeLog(method.qualifiedName &amp; " - " &amp; app.myPassport.allErrors.listString(",","errorCode"), LogDEBUG);
	if app.myPassport.allErrors.size = 1 and  app.myPassport.allErrors.first.errorCode = MACH_LIFT_POWER then 
		app.myPassport.clearErrorsWarnings;
		app.raiseCMException1(Machine_disconnect_power,cargo.id,null,null);
	endif;
	
	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	
	create allTasks transient;
	
	response := machine.getTasksAsJSON(allTasks);
	
	return response;
epilog
	delete allTasks;
	
	finaliseJSONResponse(response);	
	return response;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
	
end;
	
</source>
        <Parameter name="request" type="WS_Request"/>
        <Parameter name="cargoOid" type="String"/>
        <Parameter name="twinCargoOid" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putAcceptCargoForMultiMove" id="b063fb77-5f49-4b69-b8c9-82470d0e1c5d">
        <updating/>
        <source>putAcceptCargoForMultiMove(cargoOid: String): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2022	jlier1	Initial creation 53023

*/

vars
	machine 			: CM_Machine;
	response			: String;	
	cargo	: CM_TrackedItem;
	machConfig 			: CM_RTVehicleConfig;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;	
		return response;
	endif;	
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then		
		return response;
	endif;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);		
		return response;
	endif;
	
	machConfig := machine.myTerminal.getRTVehicleConfigForObject(machine);
	if machConfig = null then
		app.raiseCMException1(Machine_require_vehicle_config,machine.code,null,null);
		return response;
	endif;
	
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	while true do
		self.setIgnoreWarnings(true);
		
		app.myTrxUA.trxMachineDriverInitiatedMove(machine, cargo, null, null, null,  app.myPassport);
	
		if app.myPassport.noTrxReplayAllowed() then	
			break;
		endif;

	endwhile;
	
	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	response := machine.getMultiMoveCargoAsJSON();
	
	return response;
	
epilog	
	

	finaliseJSONResponse(response);	
	return response;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putAcceptTask" id="f3737c39-c8b7-41be-bd21-c30c4977b343">
        <updating/>
        <source>putAcceptTask(request : WS_Request; taskOid: String; optionalParam: ParamListType): String updating;
/*

Purpose: This is the REST version of machineDoAccept			

Parameters:	taskOid Id is a mandatory parameter with an optional parameter of twinTaskOid
			so in postman should be put to
			https://web1.jlidmast.jli.cnw.co.nz/bin_public/jadehttp.dll/acceptTask/2345.234/?JMTAppVehicle 			
			and if you had twin task it would be 			
			https://web1.jlidmast.jli.cnw.co.nz/bin_public/jadehttp.dll/acceptTask/2345.234/2345.89?JMTAppVehicle
			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	allTasks 			: CM_RTQueueTaskArray; 	
	machine 			: CM_Machine;
	response			: String;
	sideAccessDirection : Integer;	
	task 				: CM_RTQueueTask;
	twinTask 			: CM_RTQueueTask;
	twinTaskOid			: String;
	ti                  : CM_TrackedItem;
	id                  : String;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then		
		self.httpStatusCode := HttpResponseForbidden;	
		return response;
	endif;
	
	task := app.myPassport.getObjectOfTypeFromOid(taskOid,CM_RTQueueTask).CM_RTQueueTask;
	if app.myPassport.hasErrors then		
		return response;
	endif;
	if task = null then
		app.raiseCMException(Input_required_field_RTQue,null,null);		
		return response;
	endif;
	
	twinTaskOid := parseParameterList(optionalParam, 1, String).String;
	
	twinTask :=app.myPassport.getObjectOfTypeFromOid( twinTaskOid,CM_RTQueueTask).CM_RTQueueTask;
	if app.myPassport.hasErrors then		
		return response;
	endif;
	sideAccessDirection:=null;
	ti  := task.ti;
	id:=task.tiId;
	
	self.doDisconnectCargo(ti,request);
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);	
	while true do
		self.setIgnoreWarnings(true);
	
		app.myTrxUA.trxMachineAcceptTask(machine, task, twinTask, sideAccessDirection, app.myPassport);
	
		if app.myPassport.noTrxReplayAllowed() then	
			break;
		endif;
	endwhile;
	
	
	if app.myPassport.allErrors.size = 1 and  app.myPassport.allErrors.first.errorCode = MACH_LIFT_POWER then 
		app.myPassport.clearErrorsWarnings;
		app.raiseCMException1(Machine_disconnect_power,id,null,null);
	endif;
	
	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	create allTasks transient;
	
	response := machine.getTasksAsJSON(allTasks);
	
	
epilog
	delete allTasks;
	finaliseJSONResponse(response);	
	return response;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;
	
</source>
        <Parameter name="request" type="WS_Request"/>
        <Parameter name="taskOid" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putAllCargoPackToRelease" id="feddb4ef-906d-4e7d-ac87-7386aa32a5b3">
        <updating/>
        <source>putAllCargoPackToRelease(request : WS_CargoPackToReleaseRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
01 October 2021	jlier1	Initial creation 51879
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
19 Jun 2024 navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
*/

vars
	response : WS_Response;
	reserveDetail  : CM_ReserveDetail;
	release : CM_BulkRelease;
	cargoOid : String;
	parentCargo,cargo : CM_TrackedItem;
	cmifLoader : CMIF_MobileGenericAgent;
	setParentFromChild  : Boolean;
	quantity			: Integer;
	weight 				: Decimal [14,4];
	reason :String;
	permissionsToCheck : IntegerArray;
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	//app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//19.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//19.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHPackLoadRequest);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	release:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release = null then
		app.raiseCMException1(Bulk_Release_Not_Found,request.releaseOid, null,null);
		return response;
	endif;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release = null then
		app.raiseCMException1(Cargo_item_not_found,request.releaseOid, null,null);
		return response;
	endif;
		
	//epr TFS 5535 8/8/17
	parentCargo:=app.myPassport.getObjectOfTypeFromOid(request.parentCargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if parentCargo = null then
		app.raiseCMException(No_Pack_Container,null,null);
		return response;
	endif;
	setParentFromChild :=  parentCargo.allChildren.isEmptyOrContainsOnlyEquipment
							and parentCargo.isStorage;
	
	create cmifLoader transient;
	cmifLoader.setMyTerminal(app.myPassport.myTerminal);
	cmifLoader.setMyBulkRelease(release);
	
	
	
	foreach cargoOid in request.allCargoOids discreteLock do
		cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			return response;
		endif;
		if cargo = null then
			app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
			return response;
		endif;
		
		//already packed maybe from previous call before a warning
		if cargo.myParent = parentCargo then
			continue;
		endif;
		
		if not setParentFromChild then
			parentCargo.validateCargoToPack(cargo);
			if app.myPassport.hasErrors then
				return response;
			endif;
		endif;			
		quantity := cargo.totalQuantity;
		weight := cargo.totalWeight;
		reserveDetail:=cmifLoader.getReserveDetailCargoMatches(cargo,quantity, weight,reason);
		if reserveDetail = null then
			app.raiseCMException(Cargo_item_release_issue,null,null);
			return response;
		endif;
		reserveDetail.validateForPack(reserveDetail, cargo, quantity, weight);
		if app.myPassport.hasErrors then
			return response;
		endif;
		app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
		app.myTrxUA.trxUpdatePackCargo(parentCargo, cargo, quantity, weight, setParentFromChild,release, reserveDetail,true,null, app.myPassport);	//19.03.2024 navhl20 #62863
		if not app.myPassport.trxCompletedOK then
			return response;
		endif;
		
	endforeach;
	
	return response;
epilog
	delete cmifLoader;
	delete permissionsToCheck;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoPackToReleaseRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putAllCargoToLoadToRelease" id="8d0542fc-f9df-4bb7-a2ce-b8289b765c10">
        <updating/>
        <source>putAllCargoToLoadToRelease(request : WS_CargoLoadToReleaseRequest): WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 September 2021	jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
19 Jun 2024 navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps 

*/

vars
	response : WS_Response;
	reserveDetail  : CM_ReserveDetail;
	release : CM_BulkRelease;
	vehicle  : CM_Vehicle;
	chassis	  : CM_TILC;
	wagon  : CM_Wagon;
	cmifLoader : CMIF_MobileGenericAgent;
	cargo : CM_TrackedItem;
	roadJob : CM_RoadJob;
	targetLocation 	: CM_LocationsController;
	reason : String;
	wle: CM_WorkListEntry;
	cargoOid : String;
	getReserveFromCargo : Boolean;
	moveController : CMIF_MoveController;
	permissionsToCheck : IntegerArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	//app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//19.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//19.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHPackLoadRequest);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
		release:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release = null then
		app.raiseCMException1(Bulk_Release_Not_Found,request.releaseOid, null,null);
		return response;
	endif;
	
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	getReserveFromCargo:=reserveDetail = null;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	vehicle:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_Vehicle).CM_Vehicle;
	if app.myPassport.hasErrors then
		app.myPassport.clearErrorsWarnings;
	endif;
	if vehicle = null then
		//lets see if it is a chassis
		chassis:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_TILC).CM_TILC;
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
		endif;	
		if chassis = null then
			wagon:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_Wagon).CM_Wagon;
			if app.myPassport.hasErrors then
				app.myPassport.clearErrorsWarnings;
			endif;	
		endif;
	endif;	
	
	if vehicle = null and  chassis = null and wagon = null  then
		app.raiseCMException1(No_Target_location_found,request.targetLocationOid, null,null);
		return response;
	endif;
	
	create cmifLoader transient;
	cmifLoader.setMyTerminal(app.myPassport.myTerminal);
	cmifLoader.setMyBulkRelease(release);

	if vehicle &lt;&gt; null then
		roadJob:=vehicle.getCurrentRoadJob();
		targetLocation:=vehicle.locationsController;
	elseif chassis &lt;&gt; null then
		roadJob:=chassis.jobRoadRelease;
		targetLocation:=chassis.allLCs.first;
	endif;
	
	foreach cargoOid in request.allCargoOids do
		cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			return response;
		endif;
		if cargo = null then
			app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
			return response;
		endif;
		//already loaded maybe from the first call before any cargo had warnings
		if cargo.myPrimaryActualLocation = targetLocation then
			continue;
		endif;
		
		
		if getReserveFromCargo then
			reserveDetail:=cmifLoader.getReserveDetailCargoMatches(cargo,cargo.totalQuantity.max(1), cargo.totalWeight,reason);
		endif;
		wle:=cmifLoader.getWleForLoadTarget(wagon,roadJob,cargo,reserveDetail);
		cmifLoader.setMyWle(wle);
	
		if wagon &lt;&gt; null then
			targetLocation:=wagon.getNextFreeWagonContForWLE(cargo,wle);
		endif;
		cmifLoader.setMyLocationsController(targetLocation);
		
		cmifLoader.validateReleaseLoad(reserveDetail, roadJob,cargo.quantity.max(1),cargo.totalWeight);
	
		if app.myPassport.hasErrors then
			return response;
		endif;
		if app.myPassport.hasWarnings and not request.warningsAcknowledged then
			return response;
		endif;
		//we have cargo, reserve and target location
		if wle &lt;&gt; null and (wle.myTrackedItem = null or wle.myTrackedItem.isRRP ) then
			delete moveController;
			create moveController transient;
			moveController.setMyWorkListEntry(wle);
			moveController.setMyToPrimaryLocation(targetLocation);
			moveController.setMyTrackedItem(cargo);
			app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
			if not app.myPassport.trxCompletedOK then
				return response;
			endif;
		else
			if not cmifLoader.moveTI(cargo, null, targetLocation, wle, true, null, null, reserveDetail) then
				return response;
			endif;
		endif;
		
	endforeach;
	
		
	return response;
epilog
	delete cmifLoader;
	delete moveController;
	delete permissionsToCheck;
	
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLoadToReleaseRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putAllCargoToLocation" id="050b19d7-7a25-4e90-a1cf-9949092f4812">
        <updating/>
        <source>putAllCargoToLocation(request : WS_CargoPickingRequest) : WS_Response updating;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2022	jlier1	Initial creation 55404

*/

vars
	response : WS_Response;
	cargo : CM_TrackedItem;
	targetLocation : CM_LocationsController;
	tis : CM_TISet;
	cargoOid : String;
	moveController		: CMIF_MoveController;
	permissionsToCheck : IntegerArray;
	ti : CM_TrackedItem;
	weight 			: Decimal [16,4];
	quantity 			: Integer;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	create permissionsToCheck transient;
	permissionsToCheck.add(PmWebCargoInstantMove);
	permissionsToCheck.add(PmHHWarehouseMultiMove);  //jlier1 TFS 55404
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);	
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
		
	targetLocation:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if targetLocation = null then
		app.raiseCMException1(No_Target_location_found,request.targetLocationOid, null,null);
		return response;
	endif;
	
	
	create tis transient;
	
	foreach cargoOid in request.allCargoOids do
		cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			return response;
		endif;
		if cargo = null then
			app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
			return response;
		endif;
		tis.addNoDuplicates(cargo,false);
	endforeach;
	//jlier1 56271 27/1/22
	if tis.size = 1 then
		ti:=tis.first;
		if ti.myCargoType.allowDuplicates then
			if request.amount = null then
				app.raiseCMException(Must_enter_move_amount_move ,null,null );
				return response;
			endif;
			
			if ti.isBulkByQuantity then
				quantity:=request.amount.asIntegerJMT;
			else
				weight := request.amount.asDecimalJMT;								
				if  ti.myCargoType.isTrackByVolume then		
					weight := weight * ti.getDensity;		
				endif;
			endif;		
		endif;
	endif;
	
	create moveController transient;
	moveController.setMyTrackedItem(tis.first);	
	moveController.setAllOtherTrackedItems(tis);
	moveController.allOtherTrackedItems.remove(moveController.myTrackedItem);
	moveController.setMyToPrimaryLocation(targetLocation);
	moveController.setMoveMode(REAL_MODE);
	//jlier1 56271 27/1/22
	if quantity &lt;&gt; 0 then
		moveController.setQuantity(quantity);
	endif;
	if weight &lt;&gt; 0 then
		moveController.setWeight(weight);
	endif;

	app.myPassport.setWarningsIgnored(true); //jlier1 13/12/22 after post demo discussion with Mohammed decided to ignore all warnings
	
	app.myTrxUA.trxMoveTrackedItem(moveController,app.myPassport);
	
	return response;
	
epilog
	delete moveController;
	delete permissionsToCheck;
	delete tis;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoPickingRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putAllCargoToPickingLocation" id="89abad7d-0c97-49a5-b6dd-a6cd9bff8537">
        <updating/>
        <source>putAllCargoToPickingLocation(request : WS_CargoPickingRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_Response;
	cargo : CM_TrackedItem;
	reserveDetail : CM_ReserveDetail;
	release	: CM_BulkRelease;
	targetLocation : CM_LocationsController;
	quantity 			: Integer;
	weight 			: Decimal [16,4];
	stagedAreas : CM_LCSet;
	tis : CM_TISet;
	cargoOid : String;
	allWarningsToIgnore : StringArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHOrderPicking);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if reserveDetail = null then
		app.raiseCMException1(No_release_item_selected,request.reserveDetailOid, null,null);
		return response;
	endif;
	
	release:=reserveDetail.myReserveHeader;
	
	targetLocation:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if targetLocation = null then
		app.raiseCMException1(No_Target_location_found,request.targetLocationOid, null,null);
		return response;
	endif;
	
	
	create tis transient;
	
	foreach cargoOid in request.allCargoOids do
		cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			return response;
		endif;
		if cargo = null then
			app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
			return response;
		endif;
		tis.addNoDuplicates(cargo,false);
		
		if ( cargo.myCargoType.isBulkByVolume or cargo.myCargoType.isBulkByWeight) then
			weight :=weight + cargo.totalWeight;		
		else
			
			quantity:=quantity +	cargo.totalQuantity;
		endif;		
		
	endforeach;
	
	if not request.warningsAcknowledged then
		create allWarningsToIgnore transient;
		request.ignoreErrorCodes.getTokensForDelimiter(",", allWarningsToIgnore);
		
		if not allWarningsToIgnore.includes(Stagi_area_alrea_conta_cargo_a.String) then	//05 May 2016	NDL	TFS 1936 (reset if target area changes)
			if targetLocation &lt;&gt; null then
				if targetLocation.containsCargoForAnotherRelease(release) then
					app.raiseCMWarning(Stagi_area_alrea_conta_cargo_a,null,null,null);		
				endif;
			endif;
		endif;
		
		if  not allWarningsToIgnore.includes(Relea_item_alrea_fully_stage_w.String)   then
			if reserveDetail.isFullyStaged then
				app.raiseCMWarning(Relea_item_alrea_fully_stage_w,null,null,null);		
			endif;
		endif;
		
		create stagedAreas transient;
		if not release.validateStagedToOneArea( stagedAreas ) and not allWarningsToIgnore.includes(Releas_staged_multip_areas_con.String)  then
			app.raiseCMWarning(Releas_staged_multip_areas_con,null,null,null);
		endif;
		
		if not allWarningsToIgnore.includes(This_relea_curre_stage_into_su.String)  then
			if stagedAreas.size = 1 and stagedAreas.first &lt;&gt; targetLocation then
				app.raiseCMWarning2(This_relea_curre_stage_into_su, stagedAreas.first.getFullId, targetLocation.getFullId,null,null,null);
			endif;
		endif;
			
		if  not allWarningsToIgnore.includes(Will_OverStage.String)   then
			if reserveDetail.wouldBeOverStaged( null, quantity, weight ) then
				app.raiseCMWarning1(Will_OverStage, reserveDetail.getDescription,null,null,null);
			endif;
		endif;
	endif;
	
	if app.myPassport.hasWarnings then
		return response;
	endif;
	
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	app.myTrxUA.trxStageMultiCargoForRelease(tis, reserveDetail,targetLocation, app.myPassport);
	
	return response;
epilog
	delete allWarningsToIgnore;
	delete stagedAreas;
	delete tis;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoPickingRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putAllCargosToStage" id="56e4c535-1daf-4aaa-bd97-266c5ebe4c94">
        <updating/>
        <source>putAllCargosToStage(request : WS_CargoLoadToReleaseRequest): WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jan 2023 navhl20 ChangeRequest 58760:[61583] EUP | VAS Mobile App - [53813.050] VAS Tasks for Release Cargo Work Order
19 Jun 2024 navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps 
*/

vars
	response 		: WS_Response;
	reserveDetail  	: CM_ReserveDetail;
	release 		: CM_BulkRelease;
	cmifLoader 		: CMIF_MobileGenericAgent;
	cargo 			: CM_TrackedItem;
	cargoOid 		: String;
	moveController 	: CMIF_MoveController;
	tiSet 			: CM_TISet;
	term			: CM_Terminal;
	targetLocation 	: CM_LocationsController;
	permissionsToCheck : IntegerArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	//app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//19.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//19.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHPackLoadRequest);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	targetLocation := app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	term := app.myPassport.myTerminal;
	reserveDetail := app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	create cmifLoader transient;
	create tiSet transient;
	cmifLoader.setMyTerminal(app.myPassport.myTerminal);
	cmifLoader.setMyBulkRelease(release);
	
	foreach cargoOid in request.allCargoOids do
		cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			return response;
		endif;
		
		if cargo = null then
			app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
			return response;
		endif;
		
		tiSet.addNoDuplicates(cargo,false);
	endforeach;
	
	if tiSet.isNotEmpty then
		app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
		app.myTrxUA.trxUpdateStagedTis(reserveDetail.CM_ReserveSelection,targetLocation,tiSet,term,app.myPassport);
	endif;
		
	return response;
epilog
	delete cmifLoader;
	delete moveController;
	delete permissionsToCheck;
	
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLoadToReleaseRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putBBRepairDetails" id="6e838476-d17a-4b86-9b9a-7eb0ec92a068">
        <updating/>
        <source>putBBRepairDetails(_request : WS_BBRepairDetailsRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15 March 2023	navlw1	Initial creation tfs 53880 extra repair details for Breaking Bulk/Bulk
22/08/2023 		navcs2	Bug 59247: MTN | Adding repair discrepancies doesnt work for "ON SHIP" cargo
*/

vars
	ti,	
	pxyTI				: CM_TrackedItem;
	response 			: WS_Response;
	terminal 			: CM_Terminal;
	cargoId,
	voyageId			: String;
	wsBBRepairObject 	: WS_BBRepairDetailsRequest;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	self.setIgnoreWarnings(_request.warningsAcknowledged);
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHDamageReport);
	if app.myPassport.hasErrors then
		return response;
	endif;	
	
	wsBBRepairObject := _request;
	
	// tracked item
	cargoId 	:= wsBBRepairObject.cargoId;
	voyageId	:= wsBBRepairObject.voyageId;								// 22/08/2023 navcs2	Bug 59247
	ti := terminal.lookupTrackedItem(cargoId,null,null,voyageId,false);		// 22/08/2023 navcs2	Bug 59247
	if ti = null then
		app.raiseCMException1(Cargo_item_not_found, cargoId , null, null);
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
	app.myTrxUA.trxUpdateRepairedDimensions(
							pxyTI, 
							wsBBRepairObject.quantity, 
							wsBBRepairObject.tareWeight.asDecimalJMT, 
							wsBBRepairObject.cargoWeight.asDecimalJMT, 
							wsBBRepairObject.totalWeight.asDecimalJMT,
							wsBBRepairObject.reason, 
							wsBBRepairObject.diameter.asDecimalJMT, 
							wsBBRepairObject.height.asDecimalJMT, 
							wsBBRepairObject.volume.asDecimalJMT, 
							wsBBRepairObject.rollingLength.asDecimalJMT, 
							wsBBRepairObject.length.asDecimalJMT, 
							wsBBRepairObject.grammage, 
							wsBBRepairObject.width.asDecimalJMT,
							app.myPassport);
	return response;
epilog
	delete pxyTI;
	finaliseResponse(response);
end;</source>
        <Parameter name="_request" type="WS_BBRepairDetailsRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoAssignToCargoGroup" id="bed2d42d-324b-4159-9d7e-c48e2ff2eadf">
        <updating/>
        <source>putCargoAssignToCargoGroup(request : WS_AssignCargoToGroupRequest;cargoOid : String ) :WS_AssignCargoToGroupResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 August 2021	jlier1	Initial creation 51683
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_AssignCargoToGroupResponse;
	cga, completeAssignment, nextAssignment  : CM_CargoGroupAssignment;
	cg 	: CM_CargoGroup;
	cargo : CM_TrackedItem;
	terminal : CM_Terminal;
	location,newLocation : CM_LocationsController;
	foundHeight : Integer;
	info , moreInfo: String;
	onlyCompleteGroup,completeGroup, clearCargoGroup , clearLocation : Boolean;
	nextCargoGroup : CM_CargoGroup ; 
	cgsToComplete : CM_TISet;
	strArray : StringArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	app.checkCurrentUserHasAccess(PmHHCargoGroupMove);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cga:=app.myPassport.getObjectOfTypeFromOid(request.groupAssignOid,CM_CargoGroupAssignment).CM_CargoGroupAssignment;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cga = null then
		//need to change to appriopriate error
		app.raiseCMException(Input_requir_cargo_group_assig, null, null);
		return response;
	endif;
	
	
	cg:=app.myPassport.getObjectOfTypeFromOid(request.cargoGroupOid,CM_CargoGroup).CM_CargoGroup;
	if cg = null then
		//need to change to appriopriate error
		app.raiseCMException(Cargo_group_found, null, null);
		return response;
	endif;
	
	cargo:=app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	if cargo = null then
		//need to change to appriopriate error
		app.raiseCMException(Input_required_field_cargoId, null, null);
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	terminal.findLocationFromString(request.locationId.asStringRESTFUL ,true,location,foundHeight);
	
	if location = null  then
		app.raiseCMException1(Location_NotFound,request.locationId.asStringRESTFUL,null,null);	
		return response;
	endif;
	
	info :=cg.validateForAssignMove(cga,cargo,nextCargoGroup,newLocation, onlyCompleteGroup,completeGroup,clearCargoGroup, clearLocation);
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if onlyCompleteGroup then
		app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
		app.myTrxUA.trxCargoGroupComplete(cg,app.myPassport);
		
		if not app.myPassport.hasErrors then
			if nextCargoGroup &lt;&gt; null then
				response.nextCargoGroupOid:=nextCargoGroup.getOidAsString;
				response.clearLocation:=clearLocation;
				response.clearCargoGroup:=clearCargoGroup;
			endif;
		endif;
		
		return response;
	endif;
	
	create cgsToComplete transient;
	if  completeGroup then
		cgsToComplete.add(cg);
	endif;
	
	if nextCargoGroup &lt;&gt; null then
		cg:=nextCargoGroup;
	endif;
	if newLocation &lt;&gt; null then	
		location:=newLocation;
	endif;
	
	create strArray transient;
	if cga.getNotYetScanned( strArray, true ) = 1 then
		// this is the last ti, we must be all complete
		completeAssignment :=  cga;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxUA.trxAddToCargoGroup(cg, cargo, location, cgsToComplete, completeAssignment, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		return response;
	endif;
	
	if newLocation &lt;&gt; null then
		response.newLocationId:=newLocation.getFullId;
	endif;
	if nextCargoGroup &lt;&gt; null then
		response.nextCargoGroupOid:=nextCargoGroup.getOidAsString;
	endif;
	
	if completeAssignment &lt;&gt; null then
		nextAssignment := completeAssignment.getNextAvailAssignment();
		if nextAssignment &lt;&gt;  null then	
			create response.myCargoGroupAssign transient;
			response.myCargoGroupAssign.setProxyFromObject(nextAssignment);
			moreInfo:= app.getErrorString1(Last_avail_item_been_com_b, completeAssignment.id);
		else
			response.clearCargoGroupAssign:=true;
			moreInfo:= app.getErrorString1(Last_avail_item_been_com_a, completeAssignment.id);
		endif;
	endif;
	
	if response.myCargoGroupAssign = null and not response.clearCargoGroupAssign then
		create response.myCargoGroupAssign transient;
		response.myCargoGroupAssign.setProxyFromObject(cga);
		response.myCargoGroupAssign.selectedCargoGroupOid:=cg.getOidAsString;
	endif;
	
	return response;
epilog
	if not request.warningsAcknowledged then
		response.addInfo(info);
		response.addInfo(moreInfo);
	endif;
	
	delete cgsToComplete;
	delete strArray;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_AssignCargoToGroupRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_AssignCargoToGroupResponse"/>
    </JadeMethod>
    <JadeMethod name="putCargoDamage" id="f79c28d0-3edd-4152-afb9-710fae80e58b">
        <updating/>
        <source>putCargoDamage(_cargoDamageRequest : WS_CargoDamageRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
03 Oct 2022		navlw1		Initial creation tfs 53880 to update existing damage for a cargo item
14/08/2023		navkc1		Bug 59764: MTN - 404 response for Delete and PUT requests for Cargo Damage
27/09/2023		navcs2		ChangeRequest 60695: EUP | FR 54536 - Damage and Repair - Transaction Changes
31/10/2023		navcs2		Defect 60960: Rail confirm App - Advance damage Form -Wagon Damage Date/Time is not stamped in the Damage details section
19/12/2023      navbk1      Defect 61444: MTN - Damage Time is incorrect in the getCargoDamage Response
*/

vars
	response 		: WS_Response;
	terminal 		: CM_Terminal;
	wsDamageObject 	: WS_RestDamageObject;
	cargoId 		: String;
	ti,	
	pxyTI			: CM_TrackedItem;
	damPos 			: CM_DamagePosition;
	damType 		: CM_DamageDefinitionCode;
	damSev 			: CM_DamageSeverity;
	damParty 		: CM_DamageParty;
	damReason		: CM_DamageReason;
	damPlace		: CM_DamagePlace;
	status 			: Integer;
	damSize			: String;
	advancedPerm	: Boolean;
	isLoadState		: Boolean;
	damage			: CM_DamageInstance;
	damageToUpdate	: CM_DamageInstance;
	pxyDamage		: CM_DamageInstance;
	completedOK 	: Boolean;
	damDate			: TimeStamp;

begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	self.setIgnoreWarnings(_cargoDamageRequest.warningsAcknowledged);
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHDamageReport);
	if app.myPassport.hasErrors then
		return response;
	endif;	
	
	wsDamageObject := _cargoDamageRequest.damage;
	if wsDamageObject.damageUid &lt;&gt; null then
		damageToUpdate := app.myPassport.getObjectOfTypeFromOid(wsDamageObject.damageUid,CM_DamageInstance).CM_DamageInstance;
	else
		//14/08/2023	navkc1	Bug 59764
		app.raiseCMException(InvalidDamageUid, null, null);
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	if damageToUpdate = null then
		app.raiseCMException1(Damage_not_found, wsDamageObject.damageUid, null, null);
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	// tracked item
	cargoId := _cargoDamageRequest.cargoId;
	ti := terminal.lookupTrackedItem(cargoId,null,null,"",false);
	if ti = null then
		app.raiseCMException1(Cargo_item_not_found, cargoId , null, null);
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	if wsDamageObject.damagePosition &lt;&gt; null then
		damPos := app.myRoot.allDamagePositionsByCode[wsDamageObject.damagePosition].CM_DamagePosition;
	endif;
	
	if wsDamageObject.damageDefinition &lt;&gt; null then
		damType := app.myRoot.allDamageDefinitionCodes[wsDamageObject.damageDefinition].CM_DamageDefinitionCode;
	endif;
	
	if wsDamageObject.damageSeverity.String &lt;&gt; null then
		damSev := terminal.allDamageSeverities[wsDamageObject.damageSeverity.String];
	endif;
	
	if wsDamageObject.damageReason &lt;&gt; null then
		damReason := terminal.allDamageReasons[wsDamageObject.damageReason].CM_DamageReason;
	endif;
	
	damSize := wsDamageObject.damageSize.value.String;
	status := null;
	
	// advanced permission check
	advancedPerm := app.myCurrentUserCan(terminal,PmAdmDamageCodeAdvancedMaint);
	if advancedPerm then
		if wsDamageObject.responsibleParty &lt;&gt; null then
			damParty := terminal.allDamageParties[wsDamageObject.responsibleParty].CM_DamageParty;
		endif;
		if wsDamageObject.damagePlace &lt;&gt; null then
			damPlace := terminal.allDamagePlaces[wsDamageObject.damagePlace].CM_DamagePlace;
		endif;
		status := wsDamageObject.damageStatus.Integer; // this will be changing to a string at some point
		damDate := wsDamageObject.damageDateTime.TimeStamp;		// 31/10/2023 navcs2 Defect 60960   19/12/23 navbk1 Defect 61444
	endif;
	
	app.cmsBeginLoad(isLoadState);
	pxyTI		:=	ti.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoadState);
	
	/*
	
	***** Pending changes from ChangeRequest 60695 *****
	
	pxyTI.purgeAllDamageInstance();
	foreach damage in ti.allDamageInstances do
		if damage = damageToUpdate then
			continue;
		endif;
		pxyDamage := app.createUpdateProxy(damage).CM_DamageInstance;
		pxyDamage.setMyTrackedItem(pxyTI);
		self.objectsToBeDeleted.add(pxyDamage);
	endforeach;
	
	pxyTI.createPxyDamageInstance(	damType, 
									damPos, 
									wsDamageObject.remarks, 
									true, 
									wsDamageObject.quantity, 
									damSev, 
									null,
									damPlace,
									damParty,
									damReason,
									damageToUpdate.myRepairReason,
									damSize.Decimal,					
									damDate,
									status,
									damageToUpdate.repairRemarks,
									damageToUpdate.repairedDateTime
									);
	*/
	
	pxyDamage := damageToUpdate.pxyGetProxyObject();	// 27/09/2023 navcs2 ChangeRequest 60695
	
	pxyDamage.setProxy(pxyTI, null, damType, damPos, wsDamageObject.remarks, false, wsDamageObject.quantity, 	// 27/09/2023 navcs2 ChangeRequest 60695
									damSev, 
									null,
									damPlace,
									damParty,
									damReason,
									damageToUpdate.myRepairReason,
									damSize.Decimal,					
									damDate,
									status,
									damageToUpdate.repairRemarks,
									damageToUpdate.repairedDateTime);
	
	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	
	return response;
epilog
	app.cmsEndLoad(isLoadState);
	delete pxyTI;
	finaliseResponse(response);
end;</source>
        <Parameter name="_cargoDamageRequest" type="WS_CargoDamageRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoGroupComplete" id="82acc5f6-b163-40a2-bb5b-6416a373c81b">
        <updating/>
        <source>putCargoGroupComplete(request : WS_Request; groupOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 August 2021	jlier1	Initial creation 51683
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_Response;
	cargoGroup : CM_CargoGroup;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHCargoGroupMove);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cargoGroup	:= app.myPassport.getObjectOfTypeFromOid(groupOid,CM_CargoGroup).CM_CargoGroup;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargoGroup = null then
		app.raiseCMException(Cargo_group_found,null,null);
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxUA.trxCargoGroupComplete(cargoGroup,app.myPassport);
	
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_Request"/>
        <Parameter name="groupOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoLoadToMAFI" id="f829b989-c83f-4c92-afbe-a2503fbba00c">
        <updating/>
        <source>putCargoLoadToMAFI(request : WS_CargoLoadUnloadMAFIRequest; cargoID : String) : WS_CargoLoadUnloadMAFIResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2022	jlier1	Initial creation 54703

*/

vars
	response : WS_CargoLoadUnloadMAFIResponse;
	cargo 	: CM_TrackedItem;
	quantity : Integer;
	weight , newLoadedWeight : Decimal [23,4];
	moveAgent : CMIF_MobileGenericAgent;
	mafi 	: CM_TILC;
	terminalArea : CM_TerminalArea;
	terminal : CM_Terminal;
	ti  : CM_TrackedItem;
	tis : CM_TISet;
	iter : Iterator;
	cargoSummary : WS_CargoSummary;
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHMAFILoadUnload);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	terminal:=app.myPassport.myTerminal;
	
	if request.locationOid &lt;&gt; null then
		terminalArea:=app.myPassport.getObjectOfTypeFromOid(request.locationOid,CM_TerminalArea).CM_TerminalArea;
		if app.myPassport.hasErrors then
			return response;
		endif;
	endif;
	
	create tis transient;
	terminal.lookupAllOnsiteTrackedItems(null,cargoID,tis,false,null);
	iter := tis.createIterator;
	while iter.next(ti) do
		if ti.id &lt;&gt; cargoID then
			continue;
		endif;
		if terminalArea &lt;&gt; null and ti.myTerminalArea &lt;&gt; terminalArea then
			continue;
		endif;
		cargo:=ti;
		break;
	endwhile;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoID, null,null);
		return response;
	endif;
	
	if cargo.myCargoType.allowDuplicates then
		//	app.raiseCMException(Must_enter_move_amount_move ,null,null );
		if cargo.isBulkByQuantity then
			if cargo.totalQuantity = 1 then
				quantity:=1;
			else
				if request.amount = null then
					response.needAmount:=true;
					return response;
				endif;
				quantity:=request.amount.asIntegerJMT;
			endif;
		else
			if request.amount = null then
				response.needAmount:=true;
				return response;
			endif;
			weight := request.amount.asDecimalJMT;								
			if  cargo.myCargoType.isTrackByVolume then		
				weight := weight * cargo.getDensity;		
			endif;
		endif;		
	endif;
	
	
	mafi :=app.myPassport.getObjectOfTypeFromOid(request.mafiOid,CM_TILC).CM_TILC;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if mafi = null then
		app.raiseCMException1(Cargo_item_not_found,request.mafiOid, null,null);
		return response;
	endif;
			
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	if request.ignoreErrorCodes &lt;&gt; null then
		app.myPassport.errorsToIgnore.add(request.ignoreErrorCodes.Integer);
	endif;

	create moveAgent transient;
		
	moveAgent.moveTI(cargo, null, mafi.getNextFreeLC, null, true, quantity, weight, null);			
	
	if not app.myPassport.trxCompletedOK then
		return response;
	endif;
	
	response.setDetailsFromMAFI(mafi); //jlier1 TFS 61160 21/11/23
	create cargoSummary transient;
	if moveAgent.myNewTI = null then
		cargoSummary.setProxyFromObject(cargo);
	else
		cargoSummary.setProxyFromObject(moveAgent.myNewTI);
	endif;
	response.myCargo:=cargoSummary;

	return response;
epilog
	delete tis;
	delete moveAgent;
	delete iter;
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="request" type="WS_CargoLoadUnloadMAFIRequest"/>
        <Parameter name="cargoID" type="String"/>
        <ReturnType type="WS_CargoLoadUnloadMAFIResponse"/>
    </JadeMethod>
    <JadeMethod name="putCargoLoadToRelease" id="bb877515-42d5-4412-88e4-0d1b49ce7c6c">
        <updating/>
        <source>putCargoLoadToRelease(request : WS_CargoLoadToReleaseRequest; cargoOid : String) : WS_CargoLoadToReleaseResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 September 2021	jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
19 Dec 2023 		navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
05 Jan 2023 		navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
19 Jun 2024 		navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
10 Jul 2024 		navsck1 Defect 65010: MTN - Mobile Apps - Truck Loader / Unloader is no longer return the warning message 79688 (Unavailable for Release)
16 Aug 2024			navpw1	TFS: 65623 (65624)- Added support for Any ID Any Amount loading
24 Oct 2024			navpw1	JIRA MTN-12518 - We now set the weight variable for a release by type by weight so we can validate whether the cargo item can be loaded
31 Jan 2025 		navlc30 JIRA 33649 EUP - When loading partial weight to truck showing an error.

*/

vars
	response			: WS_CargoLoadToReleaseResponse;
	cargo				: CM_TrackedItem;
	reserveDetail		: CM_ReserveDetail;
	release				: CM_BulkRelease;
	vehicle				: CM_Vehicle;
	chassis				: CM_TILC;
	wagon				: CM_Wagon;
	wle,
	myWle				: CM_WorkListEntry;
	roadJob				: CM_RoadJob;
	cmifLoader			: CMIF_MobileGenericAgent;
	quantity			: Integer;
	weight				: Decimal [16,4];
	targetLocation		: CM_LocationsController;
	moveController		: CMIF_MoveController;
	tiToAdd				: CM_TrackedItem;
	cmifAutoPlan		: CMIF_YAAutoPlanNormal;
	cargoCheck			: CM_CargoCheck;
	check				: CM_CargoCheckItem;
	cargoLoaded			: WS_CargoSummary;
	reason				: String;
	cargoSplitable,
	cargoWillSplit		: Boolean;
	context				: Object;
	terminal			: CM_Terminal;
	forEUP				: Boolean;
	voyageProcess		: CM_VoyageProcess;
	wodRelease			: CM_WodRelease;
	job					: CM_Job;
	permissionsToCheck	: IntegerArray;
	wleToProcess		: CM_WorkListEntry;
	delRequest			: CM_DeliveryRequest;				// ### JIRA: MTN-14770 30Oct2024 NAVPW1
	vbsti				: CM_VehicleBookingTimeSlotItem;	// ### JIRA: MTN-14770 30Oct2024 NAVPW1
	
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	//app.checkCurrentUserHasAccess(PmHHPackLoadRequest);	
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//19.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//19.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHPackLoadRequest);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	

	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
		
	release:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release = null then
		app.raiseCMException1(Bulk_Release_Not_Found,request.releaseOid, null,null);
		return response;
	endif;
	
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;												//20.12.2023 navhl20 #61092[61621]
	voyageProcess := terminal.getDefaultVoyageProcess();								//18.12.2023 navhl20 #61092[61621]
	forEUP := voyageProcess.isEUPDefaultProcess;										//20.12.2023 navhl20 #61092[61621]
	create cmifLoader transient;
	
	cmifLoader.setMyTerminal(app.myPassport.myTerminal);
	cmifLoader.setMyBulkRelease(release);
	
	if forEUP and release.type = BR_TYPE_SHIP then										//20.12.2023 navhl20 #61092[61621]
		targetLocation := app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_LocationsController).CM_LocationsController;
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
		endif;
		
		if targetLocation = null then
			app.raiseCMException(No_Target_location_found,null,null);
			return response;
		endif;
	else
		vehicle:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_Vehicle).CM_Vehicle;
		if app.myPassport.hasErrors then
			app.myPassport.clearErrorsWarnings;
		endif;
		if vehicle = null then
			//lets see if it is a chassis
			chassis:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_TILC).CM_TILC;
			if app.myPassport.hasErrors then
				app.myPassport.clearErrorsWarnings;
			endif;	
			if chassis = null then
				wagon:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_Wagon).CM_Wagon;
				if app.myPassport.hasErrors then
					app.myPassport.clearErrorsWarnings;
				endif;	
			endif;
		endif;	
		
		if vehicle = null and  chassis = null and wagon = null  then
			app.raiseCMException(No_Target_location_found,null,null);
			return response;
		endif;
		
		if vehicle &lt;&gt; null then
			roadJob:=vehicle.getCurrentRoadJob();
			targetLocation:=vehicle.locationsController;
		elseif chassis &lt;&gt; null then
			roadJob:=chassis.jobRoadRelease;
			targetLocation:=chassis.allLCs.first;
		endif;
		wle:=cmifLoader.getWleForLoadTarget(wagon,roadJob,cargo,reserveDetail);
		cmifLoader.setMyWle(wle);	
	
		if wagon &lt;&gt; null then
			targetLocation:=wagon.getNextFreeWagonContForWLE(cargo,wle);
			if targetLocation = null then
				targetLocation:=wagon.allLocationsControllers.first;
			endif;
		endif;
	endif;
	
	cargoSplitable:=cargo.myCargoType.allowDuplicates;
	if cargo.isBulkByQuantity then
		quantity:=request.amount.asIntegerJMT;	
		cargoWillSplit := quantity &lt; cargo.totalQuantity;
	elseif cargo.isBulkByWeight or cargo.isBulkByVolume then
		weight := request.amount.asDecimalJMT;								
		if  cargo.myCargoType.isTrackByVolume then		
			weight := weight * cargo.getDensity;		
		endif;	
		cargoWillSplit := weight &lt; cargo.totalWeight;
	endif;

	if reserveDetail = null then
		reserveDetail:=cmifLoader.getReserveDetailCargoMatches(cargo,cargo.totalQuantity.max(1), cargo.totalWeight,reason);
	endif;
	
	if wle &lt;&gt; null and wle.myRequest &lt;&gt; null then
		delRequest := wle.getDeliveryRequest();
		vbsti := wle.getVbsti();
		
	endif;
	
	// ### JIRA: MTN-12518 18Oct2024 NAVPW1
	//if reserveDetail &lt;&gt; null and reserveDetail.byTypeByWeight then																													//31.01.2025 navlc30 #33649
	if cargo.isBreakBulkGeneric and reserveDetail &lt;&gt; null and reserveDetail.byTypeByWeight then																							//31.01.2025 navlc30 #33649	
		weight := cargo.totalWeight;
	// ### JIRA: MTN-14770 30Oct2024 NAVPW1
	//elseif wle &lt;&gt; null and delRequest &lt;&gt; null and delRequest.isAnyId and delRequest.isAnyAmount and vbsti &lt;&gt; null and vbsti.maxWeight &lt;&gt; null then									//31.01.2025 navlc30 #33649
	elseif cargo.isBreakBulkGeneric and wle &lt;&gt; null and delRequest &lt;&gt; null and delRequest.isAnyId and delRequest.isAnyAmount and vbsti &lt;&gt; null and vbsti.maxWeight &lt;&gt; null then			//31.01.2025 navlc30 #33649	
		weight := cargo.totalWeight;
	// ### JIRA: MTN-14770 30Oct2024 NAVPW1
	endif;
	// ### JIRA: MTN-12518 18Oct2024 NAVPW1
	
	if request.completedChecks = false then
		//check if the cargo needs checks
		
		if cargo.canSplitTotalQuantity and request.amount = "" then
			//return response
			response.showDetails := true;
			return response;
		endif;
		if roadJob &lt;&gt; null then
			cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_TRUKLOAD];
		elseif wagon &lt;&gt; null then
			cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_RAIL_REL];
		else																						//20.12.2023 navhl20 #61092[61621]
			cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_SHIP_LOAD];
		endif;
		if cargoCheck &lt;&gt; null and cargoCheck.allCargoCheckItems.first &lt;&gt; null then
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(cargo);		
			foreach check in cargoCheck.allCargoCheckItems discreteLock do
				if  check.doesTIMatchMe(cmifAutoPlan) then	
					response.showDetails := true;
					return response;
				endif;
			endforeach;
		endif;
	endif;
	
	cmifLoader.setMyLocationsController(targetLocation);
	
	cmifLoader.validateReleaseLoad(reserveDetail, roadJob,quantity,weight);
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if app.myPassport.hasWarnings and not request.warningsAcknowledged then
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	
	// ### TFS CR 64297 TASK 64299 06JUNE024 NAVAB1 Silent Dead Lock Retry
	app.myPassport.setupForDeadlockReplay(300, 2000);
	app.myPassport.silentDeadlockLimit := 5;	// ### JIRA 33872 31JAN2025 NAVAB1
	
	while true do
		if wle &lt;&gt; null and ( wle.myTrackedItem = null or wle.myTrackedItem.isRRP ) then
			// ### TFS 65623 (65624) 16Aug2024 NAVPW1
			//if (wle.isAnyId or wle.isAnyAmount) and cargo.myCargoType.allowDuplicates then
			//if wle.isAnyId or wle.isAnyAmount then //No Cargo Types Duplicates check needed
			if wle.isAnyId or wle.isAnyAmount and app.myPassport.isVASEnabled then //Added is vas enabled to lock down this change
				wleToProcess := cmifLoader.doPackLoadByReqAnyIdAmt(cargo, wle, quantity, weight, context);
				//If we don't have a new wle or if the passport had errors then just return the response as it should have errors
				if wleToProcess = null or app.myPassport.hasErrors then
					return response;
					
				endif;
			// ### TFS 65623 (65624) 16Aug2024 NAVPW1
			else
				create moveController transient;
				moveController.setMyWorkListEntry(wle);
				moveController.setMyToPrimaryLocation(targetLocation);
				moveController.setMyTrackedItem(cargo);
				moveController.setQuantity( quantity);
				moveController.setWeight( weight);
				app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
				
			endif;
			
		else
			if cargoWillSplit then
				context :=reserveDetail;
			endif;
			if forEUP and release.type = BR_TYPE_SHIP then										//20.12.2023 navhl20 #61092[61621]
				wodRelease := reserveDetail.allWodReleases.first.CM_WodRelease;
				if wodRelease &lt;&gt; null then														//05.01.2023 navhl20 #61092[61621]
					job	:= wodRelease.allJobs.first.CM_Job;
					context := job.CM_WOReleaseCargoJob.allVoyageJobs.first;
					wle := job.workListEntries.first;
					cmifLoader.setMyWle(wle);
				endif;
			endif;
			cmifLoader.moveTI(cargo, null, targetLocation, wle, true, quantity, weight, context);
			
		endif;
		
		if app.myPassport.noTrxReplayAllowed() then
			break;
		endif;
		
	endwhile;
	
	if not app.myPassport.trxCompletedOK then
		return response;
	endif;
	
	if cargoSplitable then
		if moveController &lt;&gt; null then	//03 Nov 2015	NDL	Par 37005
			// used a wleToProcess
			tiToAdd := moveController.myTrackedItem;
		else
			// came thru the direct move code
			if wagon &lt;&gt; null then
				tiToAdd := wagon.findTi( cargo.id );
			else
				tiToAdd := targetLocation.allTrackedItemsById.getAtKey( cargo.id, cargo.cargoType ); // Might have been split off.. 
			endif;
		endif;
	endif;
	
	if cargoSplitable and cargo &lt;&gt; tiToAdd and tiToAdd &lt;&gt; null then
		//has been a split
		create cargoLoaded transient;
		cargoLoaded.setProxyFromObject(tiToAdd);
		response.myCargo:=cargoLoaded;
	endif;
	
	response.setWeightAndCounts(release,targetLocation);
	
	return response;
	
epilog
	// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
	
	delete cmifLoader;
	delete moveController;
	delete cmifAutoPlan;
	delete permissionsToCheck;
	
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="request" type="WS_CargoLoadToReleaseRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_CargoLoadToReleaseResponse"/>
    </JadeMethod>
    <JadeMethod name="putCargoLoadToReleaseUndo" id="d04247a3-6ed8-441a-ae56-a90a5654f83a">
        <updating/>
        <source>putCargoLoadToReleaseUndo(request : WS_CargoLoadToReleaseRequest; cargoOid : String) : WS_CargoLoadToReleaseResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 September 2021	jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
19 Jun 2024 navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps 
*/

vars
	response : WS_CargoLoadToReleaseResponse;
	cargo : CM_TrackedItem;
	release : CM_BulkRelease;
	cmifLoader : CMIF_MobileGenericAgent;
	quantity 			: Integer;
	weight 			: Decimal [16,4];
	targetLocation,
 	currentLocation	: CM_LocationsController;
	moveController : CMIF_MoveController;
	tiToAdd : CM_TrackedItem;
	cmifAutoPlan	: CMIF_YAAutoPlanNormal;
	cargoCheck	  : CM_CargoCheck;
	check 			: CM_CargoCheckItem;
	wsCargo 	: WS_CargoSummary;
	cargoSplitable, cargoWillSplit : Boolean;
	context : Object;
	vehicle  : CM_Vehicle;
	wagon  : CM_Wagon;
	wle : CM_WorkListEntry;
	permissionsToCheck : IntegerArray;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	//app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//19.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//19.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHPackLoadRequest);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	

	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
	currentLocation:=cargo.myPrimaryActualLocation;
	if currentLocation = null or not cargo.isOnSite then
		app.raiseCMException1( ERR_TI_NOT_ONSITE,cargo.id,null,null);
		return response;
	endif;
	release:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release = null then
		app.raiseCMException1(Bulk_Release_Not_Found,request.releaseOid, null,null);
		return response;
	endif;
		
	targetLocation:=cargo.getPriorLocationLC;
	if targetLocation = null then
		app.raiseCMException(No_Target_location_found, null,null);
		return response;
	endif;
	
	
	
	cargoSplitable:=cargo.myCargoType.allowDuplicates;
	if cargo.isBulkByQuantity then
		quantity:=request.amount.asIntegerJMT;
		cargoWillSplit := quantity &lt; cargo.totalQuantity;
	elseif cargo.isBulkByWeight or cargo.isBulkByVolume then
		weight := request.amount.asDecimalJMT;								
		if  cargo.myCargoType.isTrackByVolume then		
			weight := weight * cargo.getDensity;		
		endif;
		cargoWillSplit := weight &lt; cargo.totalWeight;
	endif;	
		
	if currentLocation.isKindOf(CM_VehicleController) then
		vehicle:=currentLocation.CM_VehicleController.vehicle;
	elseif currentLocation.isKindOf(CM_TILCController) then
		vehicle:=currentLocation.CM_TILCController.getVehicle;
	elseif currentLocation.isKindOf(CM_WagonController)  &lt;&gt; null then
		wagon:=currentLocation.CM_WagonController.myWagon;
	endif;
	
	
	if request.completedChecks = false then
		//check if the cargo needs checks
		if cargo.canSplitTotalQuantity and request.amount = "" then
			//return response
			response.showDetails := true;
			return response;
		endif;
		if vehicle &lt;&gt; null then
			cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_TRUKUNLOAD];
		elseif wagon  &lt;&gt; null then
			cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_RAIL_REC];
		endif;
		if cargoCheck &lt;&gt; null and cargoCheck.allCargoCheckItems.first &lt;&gt; null then
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(cargo);		
			foreach check in cargoCheck.allCargoCheckItems discreteLock do
				if  check.doesTIMatchMe(cmifAutoPlan) then	
					response.showDetails := true;
					return response;
				endif;
			endforeach;
		endif;
	endif;
	
	create cmifLoader transient;
	cmifLoader.setMyTerminal(app.myPassport.myTerminal);
	cmifLoader.setMyBulkRelease(release);
	cmifLoader.setMyLocationsController(targetLocation);
	
	if cargo.jobRoadRelease &lt;&gt; null then
		wle:=cargo.jobRoadRelease.getWLEForTI(cargo);
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	

	if cargoWillSplit then
		context :=release;
	endif;	
	cmifLoader.moveTI(cargo, null, targetLocation, wle, true, quantity, weight, context);
	
	if not app.myPassport.trxCompletedOK then
		return response;
	endif;
	
	if cargoSplitable then
	
		tiToAdd := targetLocation.allTrackedItemsById.getAtKey( cargo.id, cargo.cargoType ); // Might have been split off.. 	
	endif;

	if cargoSplitable and cargo &lt;&gt; tiToAdd and tiToAdd &lt;&gt; null then
		//has been a split
		create wsCargo transient;
		wsCargo.setProxyFromObject(tiToAdd);
		response.myCargo:=wsCargo;
	endif;
	
	response.setWeightAndCounts(release,currentLocation);
	
	return response;
epilog
	delete cmifLoader;
	delete moveController;
	delete cmifAutoPlan;
	delete permissionsToCheck;
	
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoLoadToReleaseRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_CargoLoadToReleaseResponse"/>
    </JadeMethod>
    <JadeMethod name="putCargoOnMachineForPicking" id="f7ed5b0b-c504-4b39-97a9-af52d245f49e">
        <updating/>
        <source>putCargoOnMachineForPicking(request : WS_CargoToMachineRequest; cargoOid : String)  : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 July 2021	jlier1	Initial creation TFS 52626
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_Response;
	cargo : CM_TrackedItem;
	reserveDetail  : CM_ReserveDetail;
	release : CM_BulkRelease;
	machine  : CM_Machine;
	moveController : CMIF_MoveController;
	quantity 		: Integer;
	weight 			: Decimal [16,4];
	targetLocation 	: CM_LocationsController;
	allWarningsToIgnore : StringArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHOrderPicking);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
		
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if reserveDetail = null then
		app.raiseCMException1(Cargo_item_not_found,request.reserveDetailOid, null,null);
		return response;
	endif;
	
	release:=reserveDetail.myReserveHeader;
	
	machine:=app.myPassport.getObjectOfTypeFromOid(request.machineOid, CM_Machine).CM_Machine;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if machine = null then
		app.raiseCMException1(Cargo_item_not_found,request.machineOid, null,null);
		return response;
	endif;
	

	targetLocation:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_LocationsController).CM_LocationsController;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if not request.warningsAcknowledged then
		create allWarningsToIgnore transient;
		request.ignoreErrorCodes.getTokensForDelimiter(",", allWarningsToIgnore);
		
		if  not allWarningsToIgnore.includes(Stagi_area_alrea_conta_cargo_a.String)  then	//05 May 2016	NDL	TFS 1936 (reset if target area changes)
			if targetLocation &lt;&gt; null then
				if targetLocation.containsCargoForAnotherRelease(release)  then
					app.raiseCMWarning(Stagi_area_alrea_conta_cargo_a,null,null,null);			
				endif;
			endif;
		endif;
		
		if not allWarningsToIgnore.includes(Relea_item_alrea_fully_stage_w.String) then
			if reserveDetail.isFullyStaged then
				app.raiseCMWarning(Relea_item_alrea_fully_stage_w,null,null,null);		
			endif;
		endif;
	endif;
	
	
	create moveController transient;
	moveController.setMyTrackedItem( cargo );
	moveController.setMoveMode( REAL_MODE );
	moveController.setMyToPrimaryLocation( machine.myMachineController );
	
	if cargo.isBulkByQuantity then	
		quantity:=request.amount.asIntegerJMT;
		moveController.setQuantity(quantity);
	else
		weight := request.amount.asDecimalJMT;								
		if  cargo.myCargoType.isTrackByVolume then		
			weight := weight * cargo.getDensity;		
		endif;
		if weight &gt; 0 then
			moveController.setWeight(weight);
		endif;
	endif;	
	
		
	if not request.warningsAcknowledged and   not allWarningsToIgnore.includes(Will_OverStage.String)   then
		if reserveDetail.wouldBeOverSelected( cargo, quantity, weight ) then
			app.raiseCMWarning1(Will_OverStage, reserveDetail.getDescription,null,null,null);
		endif;
	endif;
	
	// from functional review - was not including overstage if got any of the other warnings
	if app.myPassport.hasWarnings then
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	app.myTrxUA.trxStageCargoForRelease(moveController,reserveDetail,false, app.myPassport);
	
	return response;
epilog
	delete allWarningsToIgnore; 
	delete moveController;
	
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoToMachineRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoPackToRelease" id="331b8ea4-a23f-41dd-9c9d-c69f3acf11b3">
        <updating/>
        <source>putCargoPackToRelease(request : WS_CargoPackToReleaseRequest;cargoOid : String) : WS_CargoPackToReleaseResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 September 2021	jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
16 Aug 2022 		navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system
19 Mar 2024 		navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
19 Jun 2024 		navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps 
*/

vars
	response : WS_CargoPackToReleaseResponse;
	beforePackCargo,
	packCargo,
	parentCargo,
	child	: CM_TrackedItem;
	quantity			: Integer;
	weight 				: Decimal [14,4];
	bulkRelease			: CM_BulkRelease;
	reserveDetail		: CM_ReserveDetail;
	setParentFromChild,cargoSplitable 	: Boolean;
	cmifLoader : CMIF_MobileGenericAgent;
	reason :String;
	cmifAutoPlan	: CMIF_YAAutoPlanNormal;
	cargoCheck	  : CM_CargoCheck;
	check 			: CM_CargoCheckItem;
	wsCargo 	: WS_CargoSummary;
	permissionsToCheck : IntegerArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	//app.checkCurrentUserHasAccess(PmHHPackLoadRequest);	
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//19.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//19.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHPackLoadRequest);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	packCargo	:= app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if packCargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//16.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,cargoOid,null,null);	//16.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	//epr TFS 5535 8/8/17
	parentCargo:=app.myPassport.getObjectOfTypeFromOid(request.parentCargoOid,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if parentCargo = null then
		app.raiseCMException(No_Pack_Container,null,null);
		return response;
	endif;
	cargoSplitable:=packCargo.myCargoType.allowDuplicates;
	if packCargo.isBulkByQuantity then
		quantity:=request.amount.asIntegerJMT;
	elseif packCargo.isBulkByWeight or packCargo.isBulkByVolume then
		weight := request.amount.asDecimalJMT;								
		if  packCargo.myCargoType.isTrackByVolume then		
			weight := weight * packCargo.getDensity;		
		endif;
	endif;	
		
	if request.completedChecks = false then
		//check if the cargo needs checks
		if packCargo.canSplitTotalQuantity and request.amount = "" then
			//return response
			response.showDetails := true;
			return response;
		endif;
		cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_PACK];
			if cargoCheck &lt;&gt; null and cargoCheck.allCargoCheckItems.first &lt;&gt; null then
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(packCargo);		
			foreach check in cargoCheck.allCargoCheckItems discreteLock do
				if  check.doesTIMatchMe(cmifAutoPlan) then	
					response.showDetails := true;
					return response;
				endif;
			endforeach;
		endif;
	endif;
		
	bulkRelease:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if bulkRelease = null then
		app.raiseCMException1(Bulk_Release_Not_Found,request.releaseOid, null,null);
		return response;
	endif;
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	setParentFromChild :=  parentCargo.allChildren.isEmptyOrContainsOnlyEquipment
							and parentCargo.isStorage;
							
	if not setParentFromChild then
		parentCargo.validateCargoToPack(packCargo);
		if app.myPassport.hasErrors then
			return response;
		endif;
	endif;			

	if reserveDetail = null then
		create cmifLoader transient;
		cmifLoader.setMyTerminal(app.myPassport.myTerminal);
		cmifLoader.setMyBulkRelease(bulkRelease);
		reserveDetail:=cmifLoader.getReserveDetailCargoMatches(packCargo,quantity, weight,reason);
	endif;
	
	if reserveDetail = null then
		app.raiseCMException(Cargo_item_release_issue,null,null);
		return response;
	endif;
	reserveDetail.validateForPack(reserveDetail, packCargo, quantity, weight);
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	beforePackCargo:=packCargo;
	app.myTrxUA.trxUpdatePackCargo(parentCargo, packCargo, quantity, weight, setParentFromChild,bulkRelease, reserveDetail,true,null, app.myPassport);	//19.03.2024 navhl20 #62863
	
	//need to figure out appropriate way of updating commodity on parent to not empty
	
	if not app.myPassport.trxCompletedOK then
		return response;
	endif;
	if beforePackCargo &lt;&gt; packCargo then
		create wsCargo transient;
		wsCargo.setProxyFromObject(packCargo);
		response.myCargo:=wsCargo;
	endif;
	
	response.setWeightAndCounts(bulkRelease,parentCargo);
	return response;
epilog
	delete cmifAutoPlan;
	delete cmifLoader;
	delete permissionsToCheck;
	
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoPackToReleaseRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_CargoPackToReleaseResponse"/>
    </JadeMethod>
    <JadeMethod name="putCargoPackToReleaseUndo" id="4250acb9-38da-4d91-a5b4-d6233c3e93d6">
        <updating/>
        <source>putCargoPackToReleaseUndo(request : WS_CargoPackToReleaseRequest;cargoOid : String) : WS_CargoPackToReleaseResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 Sept 2021	jlier1	Initial creation
07 Apr 2022		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
16 Aug 2022		navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system
09 Jan 2024		navma1  Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
14 Mar 2024 	navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
24 Jun 2024 	navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
*/

vars
	response 			: WS_CargoPackToReleaseResponse;
	unpackCargo,
	unpackedCargo, 
	parentCargo			: CM_TrackedItem;
	bulkRelease			: CM_BulkRelease;
	priorLocation 		: CM_LocationsController;
	quantity			: Integer;
	weight 				: Decimal [14,4];
	cargoSplitable 		: Boolean;
	wsCargo 			: WS_CargoSummary;
	cargoCheck	  		: CM_CargoCheck;
	check 				: CM_CargoCheckItem;
	cmifAutoPlan		: CMIF_YAAutoPlanNormal;
	permissionsToCheck 	: IntegerArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//24.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//24.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHPackContainer);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	

	//if not app.getMyUser.canDo( app.myPassport.myTerminal, PmHHPackContainer) then
	//	app.raiseCMException(Err_InsufficientPermission, null, null);//79610
	//	return response;
	//endif;		

	unpackCargo	:= app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if unpackCargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//16.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,cargoOid,null,null);	//16.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	if not unpackCargo.isChild then
		app.raiseCMException(Not_unpack_cargo_not_packed,null,null);
		return response;
	endif;
	
	parentCargo:=unpackCargo.myParent;
	bulkRelease:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid, CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	priorLocation:=unpackCargo.getPriorLocationLC();
	if priorLocation = null then
		app.raiseCMException(ERR_UNPACK_NULL_LOCATION,null,null);
		return response;
	endif;
	
	cargoSplitable:=unpackCargo.myCargoType.allowDuplicates;
	if unpackCargo.isBulkByQuantity then
		quantity:=request.amount.asIntegerJMT;
	elseif unpackCargo.isBulkByWeight or unpackCargo.isBulkByVolume then
		weight := request.amount.asDecimalJMT;								
		if  unpackCargo.myCargoType.isTrackByVolume then		
			weight := weight * unpackCargo.getDensity;		
		endif;
	endif;	
	
	if request.completedChecks = false then
		//check if the cargo needs checks
		if unpackCargo.canSplitTotalQuantity and request.amount = "" then
			//return response
			response.showDetails := true;
			return response;
		endif;
		cargoCheck:=app.myPassport.myTerminal.allCargoChecks[ CARGO_CHECK_CONTEXT_UNPACK];
			if cargoCheck &lt;&gt; null and cargoCheck.allCargoCheckItems.first &lt;&gt; null then
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(unpackCargo);		
			foreach check in cargoCheck.allCargoCheckItems discreteLock do
				if  check.doesTIMatchMe(cmifAutoPlan) then	
					response.showDetails := true;
					return response;
				endif;
			endforeach;
		endif;
	endif;
	
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	//app.myTrxUA.trxUpdateUnpackCargo(unpackCargo, priorLocation,quantity,weight,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
	app.myTrxUA.trxUpdateUnpackCargo(unpackCargo, priorLocation,quantity,weight,false,null, app.myPassport); 	//14.03.2024 navhl20 #62861

	if app.myPassport.trxCompletedOK() then
		if cargoSplitable then
			unpackedCargo := priorLocation.allTrackedItemsById.getAtKey( unpackCargo.id, unpackCargo.cargoType );
			if unpackedCargo &lt;&gt; unpackCargo then
				create wsCargo transient;
				wsCargo.setProxyFromObject(unpackedCargo);
				response.myCargo:=wsCargo;
			endif;
		endif;
	endif;
	
	response.setWeightAndCounts(bulkRelease,parentCargo);
	return response;
	
epilog
	delete permissionsToCheck;
	
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoPackToReleaseRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_CargoPackToReleaseResponse"/>
    </JadeMethod>
    <JadeMethod name="putCargoQueueToLocation" id="b83b4f16-fc54-4647-a5bc-355c26aeedd2">
        <updating/>
        <source>putCargoQueueToLocation(request : WS_CargoLocationRequest; cargoOid : String )  : WS_Response updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
31 July 2019	jlgns1	Initial creation
06 August 2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
*/

vars
	cargo 			: CM_TrackedItem;
	targetLocation 	: CM_LocationsController;
	response 		: WS_Response;
	weight 			: Decimal [16,4];
	moveAgent 		: CMIF_MobileGenericAgent;
	location 		: String;
	quantity 			: Integer;
	dummyHeight		: Integer;
	failedDAC		: CM_DataAccessController ;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	app.checkCurrentUserHasAccess(PmWebCargoQueuedMove);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	// Get the parameters
	location := request.location;
	
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;	

	app.writeLog(location, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		
	if cargoOid.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null,null);
		return response;
	endif;	
		
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	if location.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_TA, null,null);
		return response;
	endif;	
	app.myPassport.myTerminal.findLocationFromString(location,true,targetLocation,dummyHeight);

	
	if targetLocation = null then
		app.raiseCMException1(Location_invalid,location, null,null);
		return response;
	endif;	
	
	if not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),location, null,null);
		return response;
	endif;
	
	if cargo.myCargoType.allowDuplicates then
		if request.amount = null then
			app.raiseCMException(Must_enter_move_amount_move ,null,null );
			return response;
		endif;
		
		if cargo.isBulkByQuantity then
			quantity:=request.amount.asIntegerJMT;
		else
			weight := request.amount.asDecimalJMT;								
			if  cargo.myCargoType.isTrackByVolume then		
				weight := weight * cargo.getDensity;		
			endif;
		endif;		
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	create moveAgent transient;
	
	moveAgent.doQueueTI(cargo, targetLocation , quantity, weight);
	
	return response;
epilog
	delete moveAgent;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLocationRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoRemoveFromWagon" id="f6e92d22-9e96-488b-97e3-a692ee3d7bb6">
        <updating/>
        <source>putCargoRemoveFromWagon(request : WS_Request; cargoOid : String ): WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2022	jlier1	Initial creation

*/

vars
	response : WS_Response;
	cargo : CM_TrackedItem;
	moveController 	: CMIF_MoveController;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
		
	if cargoOid.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null,null);
		return response;
	endif;	
		
		
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	if cargo.myPrimaryActualLocation = null or not cargo.myPrimaryActualLocation.isKindOf(CM_WagonController) then
		//raise exception
		
		return response;
	endif;

	create moveController transient;
	moveController.isForcedMove		:= true;
	moveController.isSystemMove 	:= true;
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyTrackedItem(cargo);
	moveController.setMyToPrimaryLocation(null);
	
	app.myTrxUA.trxMoveTrackedItem(moveController,app.myPassport);
	
	return response;
epilog
	delete moveController;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_Request"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoToLocation" id="c7dc3c8d-718f-4570-9075-c5802332b8ad">
        <updating/>
        <source>putCargoToLocation(request : WS_CargoLocationRequest; cargoOid : String )  : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 June 2019	jlger1	Initial creation
06 August 2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
*/

vars
	cargo 			: CM_TrackedItem;
	targetLocation 	: CM_LocationsController;
	response 		: WS_Response;
	weight 			: Decimal [16,4];
	moveAgent 		: CMIF_MobileGenericAgent;	
	location 		: String;
	quantity 			: Integer;
	dummyHeight		: Integer;
	failedDAC		: CM_DataAccessController ;
	permissionsToCheck : IntegerArray;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	create permissionsToCheck transient;
	permissionsToCheck.add(PmWebCargoInstantMove);
	permissionsToCheck.add(PmHHWarehouseMultiMove);  //jlier1 TFS 55404
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);			
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	

	
	// Get the parameters
	location := request.location;
	
		
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;	

	app.writeLog(location, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		
	if cargoOid.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null,null);
		return response;
	endif;	
		
		
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	if location.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_TA, null,null);
		return response;
	endif;	
		
	
	app.myPassport.myTerminal.findLocationFromString(location,true,targetLocation,dummyHeight);
	
	if targetLocation = null then
		app.raiseCMException1(Location_invalid,location, null,null);
		return response;
	endif;	
	
	if not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),location, null,null);
		return response;
	endif;
	
	
	if cargo.myPrimaryActualLocation = targetLocation then
		app.raiseCMException2(Cargo_already_located, cargo.id, targetLocation.getID,null,null );
		return response;
	endif;
	
	if cargo.myCargoType.allowDuplicates then
		if request.amount = null then
			app.raiseCMException(Must_enter_move_amount_move ,null,null );
			return response;
		endif;
		
		if cargo.isBulkByQuantity then
			quantity:=request.amount.asIntegerJMT;
		else
			weight := request.amount.asDecimalJMT;								
			if  cargo.myCargoType.isTrackByVolume then		
				weight := weight * cargo.getDensity;		
			endif;
		endif;		
	endif;
	
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	create moveAgent transient;
		
	moveAgent.moveTI(cargo, location, targetLocation, null, true, quantity, weight, null);			
	
	return response;
epilog
	delete moveAgent;
	delete permissionsToCheck;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLocationRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoToPickingLocation" id="350ebf5b-964e-4595-9da9-78d73dfe2cc3">
        <updating/>
        <source>putCargoToPickingLocation(request : WS_CargoPickingRequest;cargoOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_Response;
	cargo : CM_TrackedItem;
	reserveDetail : CM_ReserveDetail;
	release	: CM_BulkRelease;
	targetLocation : CM_LocationsController;
	moveController : CMIF_MoveController;
	quantity 			: Integer;
	weight 			: Decimal [16,4];
	stagedAreas : CM_LCSet;
	allWarningsToIgnore : StringArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHOrderPicking);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
	
	
	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if reserveDetail = null then
		app.raiseCMException1(No_release_item_selected,request.reserveDetailOid, null,null);
		return response;
	endif;
	
	release:=reserveDetail.myReserveHeader;
	
	targetLocation:=app.myPassport.getObjectOfTypeFromOid(request.targetLocationOid, CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if targetLocation = null then
		app.raiseCMException1(No_Target_location_found,request.targetLocationOid, null,null);
		return response;
	endif;
	create allWarningsToIgnore transient;
	if not request.warningsAcknowledged then
		
		request.ignoreErrorCodes.getTokensForDelimiter(",", allWarningsToIgnore);
		
		if not allWarningsToIgnore.includes(Stagi_area_alrea_conta_cargo_a.String) then	//05 May 2016	NDL	TFS 1936 (reset if target area changes)
			if targetLocation &lt;&gt; null then
				if targetLocation.containsCargoForAnotherRelease(release) then
					app.raiseCMWarning(Stagi_area_alrea_conta_cargo_a,null,null,null);		
				endif;
			endif;
		endif;
		
		if  not allWarningsToIgnore.includes(Relea_item_alrea_fully_stage_w.String)   then
			if reserveDetail.isFullyStaged then
				app.raiseCMWarning(Relea_item_alrea_fully_stage_w,null,null,null);		
			endif;
		endif;
		
		create stagedAreas transient;
		if not release.validateStagedToOneArea( stagedAreas ) and not allWarningsToIgnore.includes(Releas_staged_multip_areas_con.String)  then
			app.raiseCMWarning(Releas_staged_multip_areas_con,null,null,null);
		endif;
		
		if not allWarningsToIgnore.includes(This_relea_curre_stage_into_su.String)  then
			if stagedAreas.size = 1 and stagedAreas.first &lt;&gt; targetLocation then
				app.raiseCMWarning2(This_relea_curre_stage_into_su, stagedAreas.first.getFullId, targetLocation.getFullId,null,null,null);	
			endif;
		endif;
	endif;
	
	
	create moveController transient;
	moveController.setMyTrackedItem( cargo );
	moveController.setMoveMode( REAL_MODE );
	moveController.setMyToPrimaryLocation( targetLocation);
	
	if cargo.isBulkByQuantity then
		quantity:=	request.amount.asIntegerJMT;
		moveController.setQuantity(quantity);
	else
		weight := request.amount.asDecimalJMT;								
		if  cargo.myCargoType.isTrackByVolume then		
			weight := weight * cargo.getDensity;		
		endif;
		if weight &gt; 0 then
			moveController.setWeight(weight);
		endif;
	endif;	
	
	if not request.warningsAcknowledged and   not allWarningsToIgnore.includes(Will_OverStage.String)   then
		if reserveDetail.wouldBeOverStaged( cargo, quantity, weight ) then
			app.raiseCMWarning1(Will_OverStage, reserveDetail.getDescription,null,null,null);
		endif;
	endif;
	
	// from functional review - was not including overstage if got any of the other warnings
	if app.myPassport.hasWarnings then
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxUA.trxStageCargoForRelease(moveController,reserveDetail, false,app.myPassport);
	
	
	return response;
epilog
	delete allWarningsToIgnore;
	delete moveController;
	delete stagedAreas;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoPickingRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoToPreviousLocation" id="e2972bbb-0029-488d-819e-86e2d2d744e7">
        <updating/>
        <source>putCargoToPreviousLocation(request : WS_CargoLocationRequest; cargoOid : String )  : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
13/06/2019	jlger1	 Initial creation
6/08/2019 	JLGNS1	 ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
20/09/2021	jlier1 	 TFS 51626 - wanted to also unasssign the release if moving to prior release
07/04/2022	navmd1	 TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
22/7/2022	jlier1   TFS 53363 
12/08/2022  navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
26/09/2023  navma1	 Bug 54704: EUP - cannot load cargo from Rail Release in Mobile App
*/

vars
	cargo 			 : CM_TrackedItem;
	targetLocation 	 : CM_LocationsController;
	response 		 : WS_Response;
	weight 			 : Decimal [16,4];
	moveAgent 		 : CMIF_MobileGenericAgent;
	location 		 : String;
	quantity 		 : Integer;
	dummyHeight 	 : Integer;
	failedDAC		 : CM_DataAccessController ;
	permissions 	 : IntegerArray;
	lastMoveTrx		 : CM_TITransaction;
	reserveDetailOid : String;
	reserveDetail 	 : CM_ReserveDetail;
	moveController   : CMIF_MoveController;
	bulkRelease 	 : CM_BulkRelease;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	//jler1 TFS 51626 3/9/21 - 
	create permissions transient;
	permissions.add(PmWebCargoInstantMove);
	permissions.add(PmHHOrderPicking);
	app.myPassport.validateUserHasOnePermission(permissions);
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	

	app.writeLog(location, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	
	if cargoOid.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null,null);
		return response;
	endif;	
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	location := cargo.priorLocation;
	
	if location.trimBlanks = "" then
		app.raiseCMException1(Cargo_previous_location,cargo.id, null,null);
		return response;
	endif;	
	
		
	app.myPassport.myTerminal.findLocationFromString(location,true,targetLocation,dummyHeight);
		
	if targetLocation = null then
		app.raiseCMException1(Location_invalid,location, null,null);
		return response;
	endif;	
	
	if cargo.myPrimaryActualLocation.isKindOf(CM_WagonController) then
		if targetLocation.isKindOf(CM_WagonController) then
			targetLocation:=cargo.getLastTALocation;
		endif;
	endif;
	
	if targetLocation = null then
		app.raiseCMException1(Location_invalid,location, null,null);
		return response;
	endif;	
	app.writeLog(targetLocation.String, LogINFO);
	
	if not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),location, null,null);
		return response;
	endif;
	
	if cargo.myCargoType.allowDuplicates then
		if request.amount = null then
			app.raiseCMException(Must_enter_move_amount_move ,null,null );
			return response;
		endif;
		
		if cargo.isBulkByQuantity then
			quantity:=request.amount.asIntegerJMT;
		else
			weight := request.amount.asDecimalJMT;								
			if  cargo.myCargoType.isTrackByVolume then		
				weight := weight * cargo.getDensity;		
			endif;
		endif;		
	endif;
	

	if cargo.myPrimaryActualLocation &lt;&gt; null then
	
		if cargo.myPrimaryActualLocation.isKindOf(CM_MachineController) then
			//if this is for staging then unstage
			lastMoveTrx :=cargo.allTransactions.getLastTransOfType(TRANS_TYPE_MOVE_PICKUP,null);
			if lastMoveTrx &lt;&gt; null and lastMoveTrx.CM_Move.targetLocn = cargo.locationId then
				//check if it was assigned to a release here
				reserveDetailOid:=lastMoveTrx.getExtraData(TrnsExtraDataAssignedRel).String;
				if reserveDetailOid &lt;&gt; null then
					//reserveDetail:=reserveDetailOid.asOid.CM_ReserveDetail;	//navtnr20 12-08-2022 52451
					reserveDetail := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid,CM_ReserveDetail).CM_ReserveDetail;	//navtnr20 12-08-2022 52451
				endif;
			endif;
		endif;
		//jlier1 TFS 53363 25/7/22
		if cargo.myPrimaryActualLocation.isKindOf(CM_WagonController) then
			lastMoveTrx := cargo.allTransactions.getLastTransOfType(TRANS_TYPE_REL_REQ_ASSIGN,null);
				if lastMoveTrx &lt;&gt; null then																						//26.09.2023 navma1 #54704
					if lastMoveTrx.CM_RelRequestAssign.myBulkReleaseCode &lt;&gt; null and lastMoveTrx.isFromMobileApp then
						foreach bulkRelease in cargo.allBulkReleasesAssigned discreteLock  where bulkRelease.code = lastMoveTrx.CM_RelRequestAssign.myBulkReleaseCode do
							if bulkRelease.isRailType then
								reserveDetail:=bulkRelease.getReserveDetailFor(cargo);
								if reserveDetail &lt;&gt; null then
									break;
								endif;
							endif;
						endforeach;
					endif;
				endif;

		endif;
		app.writeLog(method.name &amp; " lastMoveTrx = "  &amp; lastMoveTrx.String, LogDEBUG);
	
		if reserveDetail &lt;&gt; null then
			//un stage it 
				create moveController transient;
				moveController.setMyTrackedItem( cargo );
				moveController.setMoveMode( REAL_MODE );
				moveController.setMyToPrimaryLocation( targetLocation);
				if quantity &lt;&gt; 0 then
					moveController.setQuantity(quantity);
				endif;
				if weight &lt;&gt; 0 then
					moveController.setWeight(weight);
				endif;
				app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
				//this trx just moves and will unassign from release if is undo
				app.myTrxUA.trxStageCargoForRelease(moveController,reserveDetail, true,app.myPassport);
				
				return response;
		endif;
		
	endif;
	
		
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	create moveAgent transient;
	
	moveAgent.moveTI(cargo, location, targetLocation, null, true, quantity, weight, null);			
	
	return response;
epilog
	delete moveAgent;
	delete moveController;
	delete permissions;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLocationRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoToWagon" id="805e1dd8-177f-4633-a68b-b79fba253aa1">
        <updating/>
        <source>putCargoToWagon(request :  WS_CargoToWagonRequest; cargoOid : String )  : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 Aug 2019		jlger1	Initial creation TFS 45291
07 Apr 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
26 Apr 2023		jlier1	TFS 56773 
18 May 2023		jlizm1	TFS 57945 loading incorrect wle to wagon
27 Jul 2023		jlizm1	TFS 58752 Overloading wagon when wles complete
03 Apr 2024		navpw1	TFS 62859 (62860) - Added job as context object for rail release retrospective ops
10 Jul 2024 	navsck1 Defect 65010: MTN - Mobile Apps - Truck Loader / Unloader is no longer return the warning message 79688 (Unavailable for Release)
*/

vars
	cargo					: CM_TrackedItem;
	targetLocation			: CM_LocationsController;
	response				: WS_Response;
	weight					: Decimal [16,4];
	moveAgent				: CMIF_MobileGenericAgent;	
	quantity				: Integer;
	failedDAC				: CM_DataAccessController ;
	wagon					: CM_Wagon;
	reserveDetail			: CM_ReserveDetail;
	wle						: CM_WorkListEntry;
	moveController			: CMIF_MoveController;
	allRequests				: CM_DeliveryRequestSet;
	desc					: String;
	release					: CM_BulkRelease;
	hasSubRetroWorkOrder 	: Boolean;
	job						: CM_Job;
	
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmWebCargoInstantMove);
	hasSubRetroWorkOrder := app.myRoot.canDo(Sub_RetroWorkOrder);
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
	
	//app.raiseCMWarning1(Wagon_not_found_expect_wagons,request.wagonOid, null,null,null);
	//return response;
	
	wagon:=app.myPassport.getObjectOfTypeFromOid(request.wagonOid, CM_Wagon).CM_Wagon;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if wagon = null then
		app.raiseCMException1(Wagon_not_found_expect_wagons,request.wagonOid, null,null);
		return response;
	endif;

	reserveDetail:=app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	//jlier1 TFS 56773 27/4/23
	release:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid,CM_BulkRelease).CM_BulkRelease;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	wle := wagon.getWLEforCargo(cargo,reserveDetail);
	
	targetLocation:=wagon.getNextFreeWagonContForWLE(cargo,wle);
	
	if targetLocation = null then
		app.raiseCMException2(ERR_NO_SPACE,cargo.id,wagon.id ,null,null);
		return response;
	endif;	
	
	if cargo.myPrimaryActualLocation = targetLocation then
		app.raiseCMException2(Cargo_already_located, cargo.id, targetLocation.getID,null,null );
		return response;
	endif;
	
	if not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.userName,targetLocation.auditId,null, null,null);
		return response;
	endif;
	
	//jlier1 TFS 56773 24/3/23
	if wle = null and release &lt;&gt; null then
		create allRequests transient;
		wagon.getAllAssignedDelRequests(allRequests);
		
		if allRequests.first &lt;&gt; null then
			app.raiseCMException(Work_list_entry_found, null, self );
			return response;
		endif;
	endif;

	if cargo.myCargoType.allowDuplicates then
		if request.amount = null then
			app.raiseCMException(Must_enter_move_amount_move ,null,null );
			return response;
		endif;
		
		if cargo.isBulkByQuantity then
			quantity:=request.amount.asIntegerJMT;
		else
			weight := request.amount.asDecimalJMT;								
			if  cargo.myCargoType.isTrackByVolume then		
				weight := weight * cargo.getDensity;		
			endif;
		endif;		
	endif;
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	if hasSubRetroWorkOrder then
		if wle = null then
			app.raiseCMException(Work_list_entry_found, null, self );
			return response;
		endif;
		
		job := wle.job;
		
		if job = null then
			app.raiseCMException1(Not_found_worklis_entry, wle.id, null, self );
			return response;
		endif;
	endif;
	
	if wle &lt;&gt; null and ( wle.myTrackedItem = null or wle.myTrackedItem.isTBAorIsRRP ) then
		create moveController transient;
		moveController.setMyWorkListEntry(wle);
		moveController.setMyToPrimaryLocation(targetLocation);
		moveController.setMyTrackedItem(cargo);
		moveController.setQuantity( quantity);
		moveController.setWeight( weight);
		
		
		
		// ### TFS CR 64297 TASK 64299 06JUNE024 NAVAB1 Silent Dead Lock Retry
		app.myPassport.setupForDeadlockReplay(234, 1500); // ### JIRA 33872 31JAN2025 NAVAB1 was -100 and 2000
		app.myPassport.silentDeadlockLimit := 5;	// ### JIRA 33872 31JAN2025 NAVAB1
		
		while true do		
			app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
			if app.myPassport.noTrxReplayAllowed() then
				break;
			endif;
		endwhile;	
	else
		create moveAgent transient;
		// ### TFS CR 64297 TASK 64299 06JUNE024 NAVAB1 Silent Dead Lock Retry
		app.myPassport.setupForDeadlockReplay(155, 1500); // ### JIRA 33872 31JAN2025 NAVAB1 was 2000
		app.myPassport.silentDeadlockLimit := 5;	// ### JIRA 33872 31JAN2025 NAVAB1
		
		while true do
			if hasSubRetroWorkOrder and job &lt;&gt; null then
				moveAgent.moveTI(cargo, null, targetLocation, wle, true, quantity, weight, job);
			else
				//jlier1 TFS 51372 10/8/22
				moveAgent.moveTI(cargo, null, targetLocation, wle, true, quantity, weight, reserveDetail);
			endif;
		
			if app.myPassport.noTrxReplayAllowed() then
				break;
			endif;
		endwhile;
	endif;
	
	return response;
	
epilog
	
	// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;

	delete moveAgent;
	delete moveController;
	delete allRequests;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoToWagonRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCargoUnloadFromMAFI" id="f69f2ff2-25f1-4c1e-bd7b-23230fa270a6">
        <updating/>
        <source>putCargoUnloadFromMAFI(request : WS_CargoLoadUnloadMAFIRequest; cargoID : String) : WS_CargoLoadUnloadMAFIResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	jlier1	Initial creation 54703

*/

vars
	response : WS_CargoLoadUnloadMAFIResponse;
	terminal : CM_Terminal;
	location : CM_LocationsController;
	cargo  : CM_TrackedItem;
	quantity : Integer;
	weight : Decimal [23,4];
	mafi : CM_TILC;
	moveAgent : CMIF_MobileGenericAgent;
	cargoSummary : WS_CargoSummary;
	tis : CM_TISet;
	ti : CM_TrackedItem;
	isPreviousLC : Boolean;
	obj : Object;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHMAFILoadUnload);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	terminal:=app.myPassport.myTerminal;
	
	mafi :=app.myPassport.getObjectOfTypeFromOid(request.mafiOid,CM_TILC).CM_TILC;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if mafi = null then
		app.raiseCMException1(Cargo_item_not_found,request.mafiOid, null,null);
		return response;
	endif;
	
	//find cargo on the mafi with the id
	create tis transient;
	mafi.getAllOnboardTIs(tis);
	foreach ti in tis discreteLock do
		if ti.id = cargoID then
			cargo:=ti;
			break;
		endif;	
	endforeach;
	
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoID, null,null);
		return response;
	endif;
	
	if request.locationOid &lt;&gt; null then
		//jlier1 TFS 54703 after demo - if unload and has location sent which is ta then use that
		obj:=request.locationOid.asOid.Object;
		if obj.isKindOf(CM_LocationsController) then
			location:=  obj.CM_LocationsController;
		elseif obj.isKindOf(CM_BlockStack) then
			location := obj.CM_BlockStack.myLocationsController;
		else
			location:=cargo.getPriorLocationLC;
			isPreviousLC:=true;
		endif;
		if app.myPassport.hasErrors then
			return response;
		endif;
	else
		location :=cargo.getPriorLocationLC;
		isPreviousLC:=true;
	endif;
	
	if location = null then
		if isPreviousLC then
			app.raiseCMException1(Cargo_previous_location,cargo.id,null,null);
		else
			app.raiseCMException1(Location_NotFound,request.locationOid,null,null);
		endif;
		return response;
	endif;
	
	
	if cargo.myCargoType.allowDuplicates then
			
		if cargo.isBulkByQuantity then
			if cargo.totalQuantity = 1 then
				quantity:=1;
			else
				if request.amount = null then
					response.needAmount:=true;
					return response;
				endif;
				quantity:=request.amount.asIntegerJMT;
			endif;
		else
			if request.amount = null then	
				//app.raiseCMException(Must_enter_move_amount_move ,null,null );	
				response.needAmount:=true;
				return response;
			endif;
			weight := request.amount.asDecimalJMT;								
			if  cargo.myCargoType.isTrackByVolume then		
				weight := weight * cargo.getDensity;		
			endif;
		endif;		
	endif;
	
		
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	if request.ignoreErrorCodes &lt;&gt; null then
		app.myPassport.errorsToIgnore.add(request.ignoreErrorCodes.Integer);
	endif;
	
	//app.myPassport
	create moveAgent transient;
		
	moveAgent.moveTI(cargo, null, location, null, true, quantity, weight, null);			
	
	if not app.myPassport.trxCompletedOK then
		return response;
	endif;
	
	response.setDetailsFromMAFI(mafi); //jlier1 TFS 61160 21/11/23
			
	create cargoSummary transient;
	if moveAgent.myNewTI = null then
		cargoSummary.setProxyFromObject(cargo);
	else
		cargoSummary.setProxyFromObject(moveAgent.myNewTI);
	endif;
	response.myCargo:=cargoSummary;
	
	
	return response;
epilog
	delete tis;
	delete moveAgent;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_CargoLoadUnloadMAFIRequest"/>
        <Parameter name="cargoID" type="String"/>
        <ReturnType type="WS_CargoLoadUnloadMAFIResponse"/>
    </JadeMethod>
    <JadeMethod name="putCompleteIMVTask" id="c4e13786-867d-4cd8-96bd-ea98c7afe2ae">
        <updating/>
        <source>putCompleteIMVTask(taskOid : String) : String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2022	jlier1	Initial creation

*/

vars
	response		: String;	
	machine 		: CM_Machine;	
	task 		: CM_RTQueueTask;	
	wle : CM_WorkListEntry;
	cargo : CM_TrackedItem;
	targetLocation : CM_LocationsController;
	voyage : CM_Voyage;
	mobileAgent 		: CMIF_MobileGenericAgent;
	newTasks 		: CM_RTQueueTaskArray;	
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;	
		return response;
	endif;
	
	//epr TFS 5535 4/8/17 
	task := app.myPassport.getObjectOfTypeFromOid(taskOid,CM_RTQueueTask).CM_RTQueueTask;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if task = null then
		app.raiseCMException(Input_required_field_RTQue,null,null);
		return response;
	endif;

	cargo:=task.ti;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		return response;
	endif;
	
	targetLocation:=task.targetLocation;
	if targetLocation = null then
		app.raiseCMException1(Location_NotFound,null,null,null);
		return response;
	endif;
	
	if not targetLocation.isKindOf(CM_VoyageController) then
		app.raiseCMException(Cannot_load_voyage_locatio,null,null);
		return response;
	endif;
	
	voyage :=targetLocation.CM_VoyageController.myVoyage;
	
	wle:=task.myEntry.myWorkListEntry;
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(app.myPassport.myTerminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShipLoadCargo);
	self.setIgnoreWarnings(true);
	mobileAgent.doLanderLoad(cargo,targetLocation,wle,0,0);
	
	create newTasks transient;
	response := machine.getTasksAsJSON(newTasks);
	
epilog
	delete newTasks;	
	delete mobileAgent;

	finaliseJSONResponse(response);	
	return response;
end;</source>
        <Parameter name="taskOid" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putCompleteMAFI" id="4f2a7181-7a25-4042-b505-06fd3800d2fb">
        <updating/>
        <source>putCompleteMAFI(request : WS_CompleteMAFIRequest; mafiOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2022	jlier1	Initial creation 54703
14 Mar 2023			jlika1	TFS 57042 Enter Highest Cargo Height from MAFI load/unload app
09 Feb 2024			jlika1	TFS 62215 CUX | Transactions when loading/unloading a MAFI
*/

vars
	response : WS_Response;
	mafi, pxyMafi: CM_TILC;
	wsResourceUsage			: WS_ResourceTypeUsage;
	resourceUsage			: CM_ResourceTypeUsage;
	resource				: CM_ResourceType;
	resourceUsageProxys		: CM_ResourceTypeUsageSet;
	fromDT,
	toDT					: TimeStamp;
	lashingToDoDesc : CM_ToDoTaskDesc;
	extraParams : CMIF_TIUpdateExtraParams;
	txnControllerDict : CMIF_TITxnContrlrByTypeDTDict;
	txnParams			: CMIF_TITransactionController;
begin	
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHMAFILoadUnload);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	mafi:=app.myPassport.getObjectOfTypeFromOid(mafiOid,CM_TILC).CM_TILC;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if mafi = null then
		app.raiseCMException1(Cargo_item_not_found,mafiOid, null,null);
		return response;
	endif;
	
	
	create extraParams transient;
	
	if request.contentsStatus = TI_CONTENTS_STATUS_FULLLASHED or request.contentsStatus = TI_CONTENTS_STATUS_PRTLOADLASH  then
		lashingToDoDesc:=app.myPassport.myTerminal.getConfig(ToDoTaskMAFILashing).CM_ToDoTaskDesc;
		if lashingToDoDesc &lt;&gt;  null then
		
			//check if already completed this task??
			
			//has not already been completed 
			//check if it is added 
			if mafi.getToDoTaskToDoWithCode(lashingToDoDesc.code) = null then
				//add the to do task
				if not extraParams.allTasksToAdd.includes(lashingToDoDesc.code) then
					extraParams.allTasksToAdd.add(lashingToDoDesc.code);
					extraParams.hasEditedToDoTasks:=true;
				endif;
			endif;
			
			extraParams.allTasksToComplete.add(lashingToDoDesc.code);
			extraParams.hasEditedToDoTasks:=true;
			
		
			if lashingToDoDesc.allResourceTypes.first &lt;&gt; null then
				create resourceUsageProxys transient;
				foreach wsResourceUsage in request.allResourceTypeUsages do
					resource := app.myRoot.allTaskResourceTypes[wsResourceUsage.myResourceType.code];
					//epr TFS 38523 1/6/18
					fromDT:=null;
					toDT  := null;
					if resource.isFromToDateTimeRequired then
						fromDT :=wsResourceUsage.fromDateTime.asTimeStampFromWebInterface;
						toDT:= wsResourceUsage.toDateTime.asTimeStampFromWebInterface;
					endif;
					
					create resourceUsage transient;
					resourceUsage.setProxy(resource,
											null,							//_transaction : CM_TITransaction;
											wsResourceUsage.noCharge,
											wsResourceUsage.quantity,
											wsResourceUsage.remarks,
											CM_InvoiceLine.STATUS_NORMAL,
											fromDT,							//_fromDateTime : TimeStamp
											toDT,							//_toDateTime : TimeStamp
											null,
											null,
											null
											);
					extraParams.allPxyResourceUsages.add(resourceUsage);
					
				endforeach;
			endif;
		endif;	
	endif;
	
	beginLoad;
	pxyMafi:=mafi.pxyCreateUpdateProxy();
	endLoad;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	if request.contentsStatus &lt;&gt; 0 then
		pxyMafi.setContentsStatus(request.contentsStatus);
	endif;
	
	if request.overHeight &lt;&gt; 0  then
		pxyMafi.setMeasurementValue(ETRow_OverHeight,request.overHeight);
	endif;
	if request.overWidth &lt;&gt; 0  then
		pxyMafi.setMeasurementValue(ETRow_OverWidth,request.overWidth);
	endif;
	if request.overLength &lt;&gt; 0  then
		pxyMafi.setMeasurementValue(ETRow_OverLength,request.overLength);
	endif;
	if request.height &lt;&gt; 0  then
		pxyMafi.setHeight(request.height);
	endif;
	
	create txnControllerDict transient;
	
	// set contents status and over dimensions
	app.myTrxUA.trxUpdateTIandExtraInfo(pxyMafi,
										TI_UPDMODE_NORMAL, 
										extraParams,
										txnControllerDict, 
										null,
										app.myPassport);		
	
	return response;
epilog
	endLoad;
	if txnControllerDict &lt;&gt; null then
		txnControllerDict.purge;
		delete txnControllerDict;
	endif;
	delete extraParams;
	delete pxyMafi;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CompleteMAFIRequest"/>
        <Parameter name="mafiOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCompleteTruck" id="c418eb21-659a-422a-bf23-009c10941f28">
        <updating/>
        <source>putCompleteTruck(request : WS_Request; truckOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 September 2021	jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
19 Jun 2024 navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps

*/

vars
	response : WS_Response;
	truckUnLoaderController: CMIF_MobileTruckLoaderUnloader;
	truck : CM_Vehicle;
	permissionsToCheck : IntegerArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	//app.checkCurrentUserHasAccess(PmHHPackLoadRequest);	
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//19.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//19.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHPackLoadRequest);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	truck:=app.myPassport.getObjectOfTypeFromOid(truckOid, CM_Vehicle).CM_Vehicle;
	if app.myPassport.hasErrors then
		app.myPassport.clearErrorsWarnings;
		return response;
	endif;
	if truck = null then
		app.raiseCMException1(Truck_not_found,truckOid, null,null);
		return response;
	endif;
	
	
	create truckUnLoaderController transient;
	truckUnLoaderController.setMyTerminal(truck.myTerminal);
	truckUnLoaderController.setTruck(truck);
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	truckUnLoaderController.doTruckComplete(false,false,true);
	return response;
epilog
	delete truckUnLoaderController;
	delete permissionsToCheck;
	
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_Request"/>
        <Parameter name="truckOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putCompleteWagon" id="5c3be0fb-e26b-41f2-a3c0-29efb5e1cfaf">
        <updating/>
        <source>putCompleteWagon(request : WS_Request; wagonOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
04 November 2022		jlizm1	Initial creation TFS 54118 Assigning Releases to Wagons
24 Jun 2024 			navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
14 Feb 2025        		navbk1  CR 33829: EUP | Completing Any Amount Rail jobs with "Done" button

*/

vars
	response : WS_Response;
	wagon : CM_Wagon;
	realEventTrans	: CM_EventTransaction;
	permissionsToCheck : IntegerArray;
	completeWagonLoad: Boolean;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	//app.checkCurrentUserHasAccess(PmMobRailLoadByRequest);	
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//24.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//24.06.2024 navsck1 #63668
	permissionsToCheck.add(PmMobRailLoadByRequest);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	wagon := app.myPassport.getObjectOfTypeFromOid(wagonOid, CM_Wagon).CM_Wagon;
	if app.myPassport.hasErrors then
		app.myPassport.clearErrorsWarnings;
		return response;
	endif;
	
	if wagon = null then
		app.raiseCMException1(Wagon_not_found_expect_wagons, wagonOid, null, null);
		return response;
	endif;
	
	completeWagonLoad := self.qsData.getValue(self.QueryParam_CompleteWagonLoad).asBooleanJMT();    		//14.02.25 navbk1 #33829
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxUA.trxUpdateWagonLoadComplete(wagon, completeWagonLoad, app.myPassport);						//14.02.25 navbk1  #33829
	
	return response;
	
epilog
	delete permissionsToCheck;
	
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_Request"/>
        <Parameter name="wagonOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putDamageOnWagon" id="16b23387-0117-4dc1-a957-b7725fd9fb3e">
        <updating/>
        <source>putDamageOnWagon(request : WS_DamageUpdateRequest; wagonOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	jlier1	Initial creation 53971
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
03 Aug  2022	jlier1	TFS 54400 - MTN - Rail Confirm React - Issues with iso type for cargo on wagons
31/10/2023		navcs2	Defect 60960: Rail confirm App - Advance damage Form -Wagon Damage Date/Time is not stamped in the Damage details section
*/

vars
	response : WS_Response;
	wsDamage : WS_RestDamageObject;
	wagon 	: CM_Wagon;
	damage,
	pxyDamage : CM_DamageInstance;
	damageCode : CM_DamageDefinitionCode;
	damagePos : CM_DamagePosition;
	damageDateTime : TimeStamp;
	damageLocation : CM_DamagePlace;
	damageReason : CM_DamageReason;
	damageSeverity : CM_DamageSeverity;
	damageSize : Decimal[12];
	damageStatus : Integer;
	damageUid	: String;
	isNewDamage,
	isRepaired : Boolean;
	quantity : Integer;
	remarks : String;
	responsibleParty : CM_DamageParty;
	createDamage : Boolean;
	terminal : CM_Terminal;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);		
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	
	wagon:=app.myPassport.getObjectOfTypeFromOid(wagonOid,CM_Wagon).CM_Wagon;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if wagon = null then
		app.raiseCMException1(Wagon_not_found_expect_wagons,wagonOid,null,null);
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	wsDamage := request.damage;
	
	if wsDamage = null then
		return response;
	endif;
	
	
	damageCode := app.myRoot.allDamageDefinitionCodes[wsDamage.damageDefinition];
	damagePos := app.myRoot.allDamagePositionsByCode[wsDamage.damagePosition]; 
	damageReason := terminal.allDamageReasons[wsDamage.damageReason];
	damageSeverity := terminal.allDamageSeverities[wsDamage.damageSeverity];
	damageLocation := terminal.allDamagePlaces[wsDamage.damagePlace];
	if wsDamage.damageSize &lt;&gt; null then
		damageSize := wsDamage.damageSize.value;
	endif;
	damageStatus := app.damageStatusStringToEnum(wsDamage.damageStatus);
	responsibleParty := terminal.allDamageParties[wsDamage.responsibleParty];
	remarks := wsDamage.remarks;
	quantity:=wsDamage.quantity;
	
	damageDateTime := wsDamage.damageDateTime.TimeStampOffset.asUTCTimeStamp.utcToLocalTime();		// 31/10/2023 navcs2 Defect 60960


	app.writeLog(method.qualifiedName &amp; Tab &amp; " damage uid" &amp; wsDamage.damageUid, LogTRACE);	
	if wsDamage.damageUid &lt;&gt; null then
		//get object 
		damage:=app.myPassport.getObjectOfTypeFromOid(wsDamage.damageUid,CM_DamageInstance).CM_DamageInstance;
		if app.myPassport.hasErrors then
			return response;
		endif;
		if damage &lt;&gt; null then
			app.writeLog( method.qualifiedName &amp; Tab &amp;" damage exist", LogTRACE);
			beginLoad;
			pxyDamage:=damage.pxyCreateUpdateProxy();
			endLoad;
			if app.myPassport.hasErrors then
				return response;
			endif;
		endif;
	endif;
		
	if pxyDamage = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " pxydamage null", LogTRACE);
		create pxyDamage transient;
		createDamage:=true;
	endif;
	
	pxyDamage.setMySubject(wagon);
	pxyDamage.setProxy(	null, 
						null,
						damageCode, 
						damagePos,
						remarks,
						pxyDamage.isNewDamage,
						quantity,
						damageSeverity,
						null,
						damageLocation,
						responsibleParty,
						damageReason,
						pxyDamage.myRepairReason,
						damageSize,
						damageDateTime,
						damageStatus,
						pxyDamage.repairRemarks,
						pxyDamage.repairedDateTime);
	
	
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);

	if createDamage then
		app.myTrxCA.trxCreateWagonDamageInstance(wagon,pxyDamage,app.myPassport);
	else
		app.myTrxUA.trxUpdateWagonDamageInstance(wagon,pxyDamage,app.myPassport);
	endif;

	
	return response;
epilog
	delete pxyDamage;
	finaliseResponse(response);	
end;</source>
        <Parameter name="request" type="WS_DamageUpdateRequest"/>
        <Parameter name="wagonOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putFaultQuestions" id="b0951019-b11b-4be8-87c9-f50c61dc1b05">
        <updating/>
        <source>putFaultQuestions(request: WS_MultiFaultResponseRequest): WS_Response updating;
/*

Purpose: This is the REST version of machineDoUpdateMultiFaults

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	machine 		: CM_Machine;
	response		: WS_Response;			
	faultQuestion 	: WS_MultiFaultResponse;
	
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	// Create the response
	create response transient;
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(false);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;	
		return response;
	endif;	
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);
			
	foreach faultQuestion in request.allQuestionsResponse do
		self.setIgnoreWarnings(true);
		
		app.myTrxUA.trxMachineUpdateFaultResponse(machine, faultQuestion.faultQuestionIndex, faultQuestion.faultQuestionResponse, app.myPassport);
	endforeach;
		
	return response;
epilog
	
	finaliseResponse(response);	
end;
	
</source>
        <Parameter name="request" type="WS_MultiFaultResponseRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putISOType" id="73f1f516-3222-46c3-9091-dac54da88e63">
        <updating/>
        <source>putISOType(request : WS_ISOTypeRequest; cargoOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2022	jlier1	Initial creation
16 Aug 2022 	navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system

*/

vars
	response    : WS_Response;
	cargo,
	pxyTi		: CM_TrackedItem;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);		
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	cargo	:= app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//16.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,cargoOid,null,null);	//16.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	
	// Check Marks
	if request.isoType = "" then
		app.raiseCMException(Input_required_field_IsoType, null,null);
		return response;
	endif;	
	
	//Update Cargo Marks
	pxyTi := app.createUpdateProxy(cargo).CM_TrackedItem;
	pxyTi.setISOType(request.isoType);
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxUA.trxUpdateTrackedItem(pxyTi,null,TI_UPDMODE_NORMAL,null,app.myPassport);
	

	return response;
epilog
	delete pxyTi;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_ISOTypeRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putJobTimingUpdate" id="6ac8b5eb-5d29-4918-8448-3862b3cbfc4a">
        <updating/>
        <source>putJobTimingUpdate(request: WS_JobTimingUpdateRequest) : WS_Response updating;
/*

Purpose:			
Updates the job timing context for the start/stop operations. The status can be start, stopped or resumed.

Parameters:			
The WS_JobStateUpdateRequest contains two values. The first is the joib id of the job to change.
The second is the timing context as an integer value that represents whether the operation has 
start, stopped, completed. This will need to be added as a global const.
1=started
2=stopped
3=resumed
4=completed

Return Value:		
The WS_Reponse object with the results of the call.

Date			Who		Reason
12 March 2024	navmj1	Initial creation
28/03/2024		navkc1 	CR63258  Task 63259: Jade - Start Stop API call TRX
10 Jul 2024 	navsck1 Defect 65010: MTN - Mobile Apps - Truck Loader / Unloader is no longer return the warning message 79688 (Unavailable for Release)
24 Sep 2024		navbs1  Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
21 Oct 2024		navbs1  Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue
30 Oct 2024		navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs
*/

vars
	response : WS_Response;
	job		 : CM_Job;
	action 	 : Integer;
	actionTS : TimeStamp;
	obj		 : CM_Object;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		response.result := HttpResponseUnauthorized;
		return response;
	endif;	
	
	//28/03/2024	navkc1 CR63258  Task 63259
	job := request.jobOid.asOid().CM_Job;
	if request.entityOid &lt;&gt; null then				//24.09.2024  navbs1  #12445						//30.10.2024 navhl20 #33232
		obj := app.myPassport.getObjectOfTypeFromOid(request.entityOid,CM_Object).CM_Object;			//30.10.2024 navhl20 #33232
	endif;
	
	
	//28/03/2024	navkc1 CR63258  Task 63259
	if job = null then
		response.result := HttpResponseSystemError;
		return response;
	endif;
	
	if request.isFromScanApp then 																		//21.10.2024  navbs1  #14791
		app.myPassport.setContext(Context_Pass_MOB_Scan);
	endif;
	
	// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1 Silent Dead Lock Retry
	app.myPassport.setupForDeadlockReplay(310, 2000);
	while true do
		//28/03/2024	navkc1 CR63258  Task 63259
		app.myTrxUA.trxUpdateJobAction(job, request.timingContext, actionTS, obj, app.myPassport);		//23.09.2024  navbs1  #12445	//30.10.2024 navhl20 #33232
		if app.myPassport.noTrxReplayAllowed() then
			break;
		endif;
	endwhile;
	
	if app.myPassport.hasErrors then
		response.result := HttpResponseSystemError;
		return response;
	endif;
		
	response.result := HttpResponseNoContent; // return a 204 code as there is not content
		
	return response;
epilog
	
	// ### TFS CR 64297 TASK 64299 04JUNE024 NAVAB1
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
	app.myPassport.setContext(Context_Pass_Null);														//21.10.2024  navbs1  #14791
	
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_JobTimingUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putLocationChecks" id="ea9da8f5-a27a-4686-827a-850fc3644f85">
        <updating/>
        <source>putLocationChecks(request : WS_LocationChecksRequest; locationOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Aug 2021	jlier1	Initial creation TFS 51684
07 Apr 2022 navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
09 May 2025	navhl20 Bug MTN-34743: MSL -- On confirming a cargo item in the location check app on requerying it still shows as not confirmed
03 Jun 2025	navhl20 CR MTN-35026: MTN - Optimize Performance of getCargoInLocation Web Service in Location Check Mobile App
08 Jan 2026 navma1 MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	location 		: CM_LocationsController;
	response 		: WS_Response;
	iter 			: Iterator;
	allTIs  		: CM_TIArray;
	ti 				: CM_TrackedItem;
	trxCmifSet		: CMIF_TITxnControllerSet;
	trxDict 		: CM_TITransactionSet;
	confirmedTIOids : StringArray;
	cmif 			: CMIF_LocationCheckController;
	locationID,
	cargoOid 		: String;
	size 			: Integer;
	cargoGroup 		: CM_CargoGroup;
	now				: TimeStamp;
	oidStr			: String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	location:=app.myPassport.getObjectOfTypeFromOid(locationOid,CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if location = null then
		app.raiseCMException(Input_Required_For_Location,null,null);
		return response;
	endif;
	locationID := location.getFullId();
	
	if request.cargoGroupOid &lt;&gt; null then
		cargoGroup := app.myPassport.getObjectOfTypeFromOid(request.cargoGroupOid,CM_CargoGroup).CM_CargoGroup;
		if app.myPassport.hasErrors then
			return response;
		endif;
	endif;
	
	create confirmedTIOids transient;
	request.allCargoOids.copy(confirmedTIOids);
	create trxCmifSet transient;
	create trxDict transient;
	
	create allTIs transient;
	location.getTIs(allTIs,REAL_MODE,true);
	iter := allTIs.createIterator;
	
	now := app.actualTimeAppServer;										//03.06.2025 navhl20 #35026
	while iter.next(ti) do
		if cargoGroup &lt;&gt; null then
			if ti.myCargoGroup &lt;&gt; cargoGroup then
				continue;
			endif;
		endif;
	
		create cmif transient;
		cmif.type := TRANS_TYPE_LocationCheck;
		cmif.userId := app.myPassport.userCode;
		cmif.dateTime := now;											//03.06.2025 navhl20 #35026
		cmif.myTrackedItem := ti;
		cmif.expectedLocation:=locationID;
		cmif.actualLocation := null;
		oidStr := ti.getOidAsString();									//03.06.2025 navhl20 #35026
		if confirmedTIOids.includes(oidStr) then						//03.06.2025 navhl20 #35026
			cmif.actualLocation := locationID;	
			trxCmifSet.add( cmif );										//09.05.2025 navhl20 #34743
			confirmedTIOids.remove(oidStr);								//03.06.2025 navhl20 #35026
		endif;	
	endwhile;
	
	//any left must be in a this actual location but not expected in differnt location 
	foreach cargoOid in confirmedTIOids discreteLock do
	
		ti:=app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			//ti is invalid or not found
			app.myPassport.clearErrorsWarnings;
			continue;
		endif;
		// shouldn't happen but just incase
		if ti = null then
			continue;
		endif;
		create cmif transient;
		cmif.type := TRANS_TYPE_LocationCheck;
		cmif.userId := app.myPassport.userCode;
		cmif.dateTime := now;											//03.06.2025 navhl20 #35026
		cmif.myTrackedItem := ti;
		cmif.expectedLocation:=ti.myPrimaryActualLocation.getFullId();
		cmif.actualLocation := locationID;
		trxCmifSet.add( cmif );
	endforeach;
	
	size := trxCmifSet.size;
	if size =  0 then
		app.raiseCMException(Locatio_check_transac_create,null,null);
		return response;
	endif;
	
	if not request.warningsAcknowledged then
		app.raiseCMWarning1(Sure_want_creat_locat_check_tr,size.String,null,null,null);
		return response;
	endif;
		
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxCA.trxCreateLocationCheckTrans( trxCmifSet, trxDict, app.myPassport	);

	return response;
epilog
	if trxCmifSet &lt;&gt; null then
		trxCmifSet.purge();
	endif;
	delete iter;				//08.01.2026 navma1 #MTN-36897
	delete allTIs;
	delete trxCmifSet;
	delete trxDict;		
	delete confirmedTIOids;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_LocationChecksRequest"/>
        <Parameter name="locationOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putMachineInQueue" id="ffd3d2ca-fe6a-4570-8025-e84ad0784e72">
        <updating/>
        <source>putMachineInQueue(queueID : String): WS_Response updating;
/*

Purpose: This is the REST version of machineDoUpdateQueue

Parameters:

			
Return Value: 


Date		Name	TFS#	Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	newQueue : CM_RadioTelemetryQueue;
	pxyMachine : CM_Machine;
	loadStateSet : Boolean;
	machine : CM_Machine;
	response : WS_Response;			
	faultQuestion  : WS_MultiFaultResponse;
	decodedQueueId : String;
	
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	// Create the response
	create response transient;
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.myTerminal.radioTelemetry = null then		
		return response;
	endif;
	
	decodedQueueId := queueID.asStringRESTFUL();
	newQueue := app.myPassport.myTerminal.findQueue(decodedQueueId);
	
	if newQueue = null then
		app.raiseCMException1(Err_InvalidQueue, decodedQueueId, null, null);		
		return response;
	endif;
	
	machine := app.myPassport.myMachine;
	//nothing to do if already in queue
	if newQueue = machine.myPrimaryQueue then		
		return response;
	endif;
	
	if machine.currentQueueTask &lt;&gt; null then
		app.raiseCMException(Change_queue_working_task, null, null);		
		return response;
	endif;
	
	self.setIgnoreWarnings(true);
	app.cmsBeginLoad(loadStateSet);
	pxyMachine := machine.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadStateSet);
	app.myTrxUA.trxUpdateMachineQueue(pxyMachine, newQueue, app.myPassport);
		
	return response;
epilog
	app.cmsEndLoad(loadStateSet); 

	delete pxyMachine;
	
	finaliseResponse(response);	
end;
	
</source>
        <Parameter name="queueID" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putMultiTIReeferConnect" id="20a03ada-b14b-4888-b1b8-d2dd8baaccf0">
        <updating/>
        <source>putMultiTIReeferConnect(request : WS_MultiTIReeferConnectRequest) : WS_RestResponse updating;
/*

Date		 Who		Reason
22 May 2025	 navtr3		MTN-34806 Create an endpoint to support connecting and disconnecting multiple refers to be used with MTN-34794
16 June 2025 navsck1	MTN-35071 Unable to connect or disconnect the reefer cargo using multi select option 
*/

vars
	response			: WS_RestResponse;
	power 				: CM_GapController;
	ti 					: CM_TrackedItem;
	agent 				: CMIF_MobileGenericAgent;
	connectParams		: CMIF_ConnectParams;
	connectTimeStamp	: TimeStamp;
	action				: Integer;
	cargoOid            : String;
    totalCount          : Integer;
	
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;	
	create agent transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(Mod_BaseSystem);	//Mod_BaseSystem // 12.06.2025 NAVSCK1 MTN-35071
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	 // Validate request
    if request = null or request.cargoOids = null or request.cargoOids.isEmpty then		
        app.raiseCMException(NO_Data, null, null);
        return response;
    endif;
	
	 // Set warnings to be ignored if requested
    app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
    
    // Track number of cargo items processed
    totalCount := request.cargoOids.size;
	
	// Set action based on connection request
	if request.connected then
		action := ACTION_CONNECT;
	else
		action := ACTION_DISCONNECT;
	endif;	
		
	connectTimeStamp := app.actualTimeServer;
	
	create connectParams transient;	
	connectParams.dateTime := connectTimeStamp;
	connectParams.noCharge := request.noCharge;
	connectParams.userId := app.getMyUserCode();
	connectParams.action := action;
	connectParams.gapController := power; 
	connectParams.urNumber := null;
	connectParams.radioTelemetryIgnoreWarnings := true;
	connectParams.radioTelemetryUser := false;
	
	// Process each cargo item
   foreach cargoOid in request.cargoOids do   
		connectParams.allTrackedItems.clear();		
		connectParams.myTerminal := null;
		connectParams.myTrackedItem := null;
		 
		if cargoOid &lt;&gt; null then
			ti := app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
		endif;
		
		if ti = null then			
			app.raiseCMException1(Cargo_item_not_found, cargoOid, null, null);
			if app.myPassport.hasErrors and response &lt;&gt; null then
					response.setErrorsFromPassport();						
			endif;	
			continue;
		endif;
		// Check to see if this container has been connected/disconnected already elsewhere
		if ti.isConnected = request.connected then
			continue;
		endif;	
		
		// Power cannot be null if the terminal area is a Gridded Block stack
		if ti.myTerminalArea.isKindOf(CM_ForkLiftStack) and not ti.myPrimaryActualLocation.hasPower then
			power := agent.findClosestPowerPoint(ti);
			if power = null then
				app.raiseCMException1(No_power_avail, cargoOid, null, null);
				if app.myPassport.hasErrors and response &lt;&gt; null then
						response.setErrorsFromPassport();
				endif;	
				continue;
			endif;
		endif;	
		
		connectParams.allTrackedItems.add(ti);		
		connectParams.myTerminal := ti.myTerminal;
		connectParams.myTrackedItem := ti;
		
		if connectParams.myTrackedItem &lt;&gt; null then
			connectParams.locationsController := connectParams.myTrackedItem.myPrimaryActualLocation;
		endif;		
			
		app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
			
		if request.connected then
			app.myTrxUA.trxUpdateConnect(connectParams, app.myPassport);
		else
			app.myTrxUA.trxUpdateDisconnect(connectParams, app.myPassport);
		endif;
		// Check for errors
		if app.myPassport.hasErrors and response &lt;&gt; null then
				response.setErrorsFromPassport();
		endif;	
		
	endforeach;	
    return response;

epilog
	delete agent;
	delete connectParams;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_MultiTIReeferConnectRequest"/>
        <ReturnType type="WS_RestResponse"/>
    </JadeMethod>
    <JadeMethod name="putPackComplete" id="b98f2148-f7dd-4640-aafc-225d2f6ce004">
        <updating/>
        <source>putPackComplete(request : WS_PackCompleteRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 September 2021	jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
16 Aug 2022 		navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system
12 Sep 2023 		navhl20 Bug 52191: MTN - Pack by Request not changing the status of the Release Request to Complete after packing
19 Mar 2024 		navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
19 Jun 2024 		navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
16 Aug 2024 		navbs1	Bug 65544: TPT | Pack Container via Pack Load Release - Error 75764
20 Aug 2024 		navbs1	Defect 65687: 75764 exception when clicking on the Pack Complete button on the Complete Job form
08 Oct 2024 		navhl20 Bug 12500: EUP | No warning message on the work order operations app after packing part of one child line
*/

vars
	response    : WS_Response;
	parentCargo,
	pxyTI		: CM_TrackedItem;
	release		: CM_BulkRelease;
	subTerminal : CM_SubTerminal;
	operator 	: CM_Operator;
	terminal	: CM_Terminal;
	permissionsToCheck : IntegerArray;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	//app.checkCurrentUserHasAccess(PmHHPackLoadRequest);		
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//19.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//19.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHPackLoadRequest);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	parentCargo	:= app.myPassport.getObjectOfTypeFromOid(request.parentCargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if parentCargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//16.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,request.parentCargoOid,null,null);	//16.8.2022 navhl20 TFS 52943
		return response;
	endif;
	
	release:=app.myPassport.getObjectOfTypeFromOid(request.releaseOid,CM_BulkRelease).CM_BulkRelease;	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if release &lt;&gt; null and not release.isPackingType then
		release := null;
	endif;

	pxyTI :=  app.createUpdateProxy(parentCargo).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	operator:=app.myRoot.allOperators[request.operatorCode];
	if operator &lt;&gt; null and  operator &lt;&gt; pxyTI.myOperator then
		pxyTI.zSetPxyOperator(operator);
	endif;
	
	if app.isSubTerminalsOn(terminal) then
		subTerminal := app.myRoot.allSubTerminals[request.subTerminalCode];
		if subTerminal &lt;&gt; pxyTI.mySubTerminal then
			pxyTI.zSetPxySubTerminal(subTerminal);
		endif;
	endif;
	
	if app.myPassport.isVASEnabled then
		/*
			Euro Ports asked for flow to raise warning and error message 
			if there are more items needs to be packed
			Before the user confirm pack complete
			
		*/
		self.setIgnoreWarnings(request.warningsAcknowledged);				//12.9.2023 navhl20 #52191	//08.10.2024 navhl20 #12500
	else
		//warnings were always Acknowledged for all of our customers
		self.setIgnoreWarnings(true);
	endif;

	app.myTrxUA.trxUpdateTIPackComplete(pxyTI, release, null, app.myPassport);	//19.03.2024 navhl20 #62863
	
	return response;
epilog
	delete pxyTI;
	delete permissionsToCheck;
	
	self.finaliseResponse(response);

end;</source>
        <Parameter name="request" type="WS_PackCompleteRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putPickupCargoForMoveByType" id="40cf051a-8055-45ca-ae87-6fbfa6f70696">
        <updating/>
        <source>putPickupCargoForMoveByType(request : WS_Request;cargoOid: String; twinCargoOid: String; amount: String): String updating;
/*

Purpose: This is the REST version of machineDoDirectorPickup

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	machine 			: CM_Machine;
	response			: String;	
	allTasks 			: CM_RTQueueTaskArray;
	cargo,
	twinCargo  			: CM_TrackedItem;
	quantity			: Integer;
	weight 				: Decimal[16,4];	
	id                  : String;
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);		
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;	
		return response;
	endif;	
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid.asStringRESTFUL.trimBlanks, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then		
		return response;
	endif;
	app.writeLog("cargo:" &amp; cargo.id, LogINFO);
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);		
		return response;
	endif;
	
	id:=cargo.id;
	self.doDisconnectCargo(cargo,request);
	
	twinCargo := app.myPassport.getObjectOfTypeFromOid(twinCargoOid.asStringRESTFUL.trimBlanks, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then		
		return response;
	endif;	
	
	if machine.currentQueueTask &lt;&gt; null then				
		if cargo.myCargoType.allowDuplicates then
			if amount = null then
				app.raiseCMException(Must_enter_move_amount_move ,null,null );
				return response;
			endif;								
				
			if cargo.isBulkByQuantity then
				quantity := amount.asIntegerJMT;
			else
				weight := amount.asDecimalJMT;								
				if  cargo.myCargoType.isTrackByVolume then		
					weight := weight * cargo.getDensity;		
				endif;
			endif;		
		endif;			
	
	endif;
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	
	while true do
		self.setIgnoreWarnings(true);
		
		app.myTrxUA.trxMachineDirectorTask(machine, cargo, twinCargo, true, quantity, weight,  app.myPassport);
	
		if app.myPassport.noTrxReplayAllowed() then	
			break;
		endif;

	endwhile;
	
	if app.myPassport.allErrors.size = 1 and  app.myPassport.allErrors.first.errorCode = MACH_LIFT_POWER then 
		app.myPassport.clearErrorsWarnings;
		app.raiseCMException1(Machine_disconnect_power,id,null,null);
	endif;
	
	if app.myPassport.hasErrors then		
		return response;
	endif;	
	
	create allTasks transient;	
	response := machine.getTasksAsJSON(allTasks);

	return response;
epilog
	delete allTasks;
		
	finaliseJSONResponse(response);	
	return response;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
	
end;
	
</source>
        <Parameter name="request" type="WS_Request"/>
        <Parameter name="cargoOid" type="String"/>
        <Parameter name="twinCargoOid" type="String"/>
        <Parameter name="amount" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putPickupCargoForMultiMove" id="aa2cfaf7-552c-4260-a756-cfecb77b6310">
        <updating/>
        <source>putPickupCargoForMultiMove(_request : WS_MultiMoveRequest) : String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2022	jlier1	Initial creation

*/

vars
	machine 			: CM_Machine;
	response			: String;	
	cargo	: CM_TrackedItem;
	machConfig 			: CM_RTVehicleConfig;
	allCmifItems    : CMIF_Array;
	cmifMultiItem   : CMIF_MultiMoveItem;
	moveRequestItem : WS_MoveItem;
	rtqTask         : CM_RTQueueTask;
	targetLoc		: String;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;	
		return response;
	endif;	
	
	machConfig := machine.myTerminal.getRTVehicleConfigForObject(machine);
	if machConfig = null then
		app.raiseCMException1(Machine_require_vehicle_config,machine.code,null,null);
		return response;
	endif;
	
	
	if _request.allMoveItems.first = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);	
		return response;
	endif;
	
	//[1] Prepare Items
	create allCmifItems transient;
	foreach moveRequestItem in _request.allMoveItems do
		
		targetLoc:=null;
		rtqTask:=null;
		cargo   := app.myPassport.getObjectOfTypeFromOid(moveRequestItem.cargoOid,CM_TrackedItem).CM_TrackedItem;
		if cargo &lt;&gt; null then
			rtqTask:=cargo.getQueueTask;
			targetLoc:=cargo.plannedLocnId;
			if rtqTask = null then
				app.raiseCMException(Input_required_field_RTQue,null,null);	
				return response;
			endif;
		else
			app.raiseCMException(Input_required_field_cargoId,null,null);	
			return response;
		endif;
		
		if  targetLoc &lt;&gt; null and rtqTask &lt;&gt; null then
			create cmifMultiItem transient;
			cmifMultiItem.setCmifDetails(rtqTask,targetLoc);
			allCmifItems.add(cmifMultiItem);
		endif;
	endforeach;
	
	//[2] Call pickup Trx
	if allCmifItems.isNotEmpty() then
			
		app.myPassport.setupForDeadlockReplay(-100, 2000);
		while true do
			self.setIgnoreWarnings(true);
			
			app.myTrxUA.trxMachinePickupMultiTask(machine,allCmifItems, app.myPassport);
		
			if app.myPassport.noTrxReplayAllowed() then	
				break;
			endif;
	
		endwhile;
	endif;
	
	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	response := machine.getMultiMoveCargoAsJSON();
	
	return response;
	
epilog	
	if allCmifItems &lt;&gt; null then
		allCmifItems.purge;
	endif;
	delete allCmifItems;

	finaliseJSONResponse(response);	
	return response;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_request" type="WS_MultiMoveRequest"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putPickupTask" id="32c3febc-6ae9-431f-99c4-6f45c1b01837">
        <updating/>
        <source>putPickupTask( request : WS_Request; amount: String) : String updating;
/*

Purpose: This is the REST version of machineDoPickup		

Parameters:			

Return Value:

Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
03 May 2022 navma1	Bug 57849: MSL - Slowness Issues
============================================================================*/

vars
	allTasks 		: CM_RTQueueTaskArray; 	
	machine 		: CM_Machine;	
	quantity		: Integer;
	response		: String;		
	weight 			: Decimal[16,4];	
	ti 				: CM_TrackedItem;	
	id				: String;
	passport		: CM_Passport;
	currentTask		: CM_RTQueueTask;
	rtqEntry		: CM_RTQueueEntry;
begin
	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	passport	:= app.myPassport;
	machine 	:= passport.myMachine;
	
	machine.validateForVehicleApp(true);
	
	if passport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;	
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	
	currentTask := machine.currentQueueTask;							   					    //03.05.2023 navma1 #57849
	if currentTask &lt;&gt; null then
		ti := currentTask.ti;
		if ti &lt;&gt; null then			
			if ti.myCargoType.allowDuplicates then
				if amount = null then
					app.raiseCMException(Must_enter_move_amount_move ,null,null );
					return response;
				endif;								
					
				if ti.isBulkByQuantity then
					quantity := amount.asIntegerJMT;
				else
					weight := amount.asDecimalJMT;								
					if  ti.myCargoType.isTrackByVolume then		
						weight := weight * ti.getDensity;		
					endif;
				endif;		
			endif;			
		endif;
		
		id 			:= currentTask.tiId;														//03.05.2023 navma1 #57849
		rtqEntry	:= currentTask.myEntry;
		if rtqEntry &lt;&gt; null and rtqEntry.isMachineInitiatedMove then							//03.05.2023 navma1 #57849
			passport.errorsToIgnore.add(MACH_LIFT_POWER);
		else
			self.doDisconnectCargo(ti,request);
		endif;
	endif;

	passport.setupForDeadlockReplay(-100, 2000);
	
	while true do		
		self.setIgnoreWarnings(true);
		
		app.myTrxUA.trxMachinePickupTask( machine, quantity, weight, passport);
		
		if passport.noTrxReplayAllowed() then	
			break;
		endif;
	endwhile;
	
	if passport.allErrors.size = 1 and  passport.allErrors.first.errorCode = MACH_LIFT_POWER then 
		passport.clearErrorsWarnings;
		app.raiseCMException1(Machine_disconnect_power,id,null,null);
	endif;
	
	
	if passport.hasErrors then		
		return response;
	endif;
	
	create allTasks transient;
	
	response := machine.getTasksAsJSON(allTasks);

	return response;
epilog
	delete allTasks;
	
	finaliseJSONResponse(response);	
	return response;
	
	process.setPersistentDeadlockPriority(0);
	passport.replayingDeadlocks := false;
	
end;</source>
        <Parameter name="request" type="WS_Request"/>
        <Parameter name="amount" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putRejectCargoForMultiMove" id="2a0806d3-0324-4c66-984e-4184507d2590">
        <updating/>
        <source>putRejectCargoForMultiMove(cargoOid: String): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2022	jlier1	Initial creation 53023

*/

vars
	machine 			: CM_Machine;
	response			: String;	
	cargo	: CM_TrackedItem;
	task : CM_RTQueueTask;
	allTasks : CM_RTQueueTaskArray;
	machConfig 			: CM_RTVehicleConfig;
	
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;	
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then		
		return response;
	endif;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);		
		return response;
	endif;
	
	machConfig := machine.myTerminal.getRTVehicleConfigForObject(machine);
	if machConfig = null then
		app.raiseCMException1(Machine_require_vehicle_config,machine.code,null,null);
		return response;
	endif;
	
	task:=cargo.getQueueTask();
	if task = null then
		app.raiseCMException(Input_required_field_RTQue,null,null);			
		return response;
	endif;
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	
	create allTasks transient;
	allTasks.add(task);
	
	while true do
		self.setIgnoreWarnings(true);
		
		app.myTrxUA.trxMachineRejectTasks(machine, allTasks, false,app.myPassport);
		
		if app.myPassport.noTrxReplayAllowed() then	
			break;
		endif;

	endwhile;

	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	response := machine.getMultiMoveCargoAsJSON();
	
	return response;
	
epilog
	delete allTasks;
	
	finaliseJSONResponse(response);	
	return response;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putRejectTask" id="7352618e-ab25-42da-b1b3-975945f7bd70">
        <updating/>
        <source>putRejectTask(request : WS_MachineRejectTasksRequest) : String updating;
/*

Purpose: This is the REST version of machineDoReject	

Parameters:			

Return Value:

Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/

vars
	allTasks 		: CM_RTQueueTaskArray;
	newTasks 		: CM_RTQueueTaskArray;	
	machine 		: CM_Machine;		
	response		: String;	
	task,
	twinTask 		: CM_RTQueueTask;	
	addToRejectList : Boolean;
	isDriverMove	: Boolean;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;	
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
		
	if not request.rejectAll then
		create allTasks transient;
		
		task := app.myPassport.getObjectOfTypeFromOid( request.taskOid,CM_RTQueueTask).CM_RTQueueTask;
		if app.myPassport.hasErrors then			
			return response;
		endif;
		if task = null then
			app.raiseCMException(Input_required_field_RTQue,null,null);			
			return response;
		endif;
		isDriverMove := not task.isOverstowTask and task.myEntry.isMachineInitiatedMove;
		allTasks.add(task);
		twinTask := app.myPassport.getObjectOfTypeFromOid(request.twinTaskOid,CM_RTQueueTask).CM_RTQueueTask;
		if app.myPassport.hasErrors then			
			return response;
		endif;
		if twinTask &lt;&gt; null then
			allTasks.add(twinTask);
		endif;
	endif;
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	
	while true do
		self.setIgnoreWarnings(true);
		
		app.myTrxUA.trxMachineRejectTasks(machine, allTasks, addToRejectList,app.myPassport);
		
		if app.myPassport.noTrxReplayAllowed() then	
			break;
		endif;

	endwhile;
	
	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	create newTasks transient;
	
	response := machine.getTasksAsJSON(newTasks);
	
	//jlier1 TFS 57910 11/5/23
	if isDriverMove then
		newTasks:=null;
	endif;
	app.myTrxUA.trxMachineSetTaskStates(machine,newTasks,app.myPassport);
	
	return response;
epilog
	delete allTasks;
	delete newTasks;
	
	finaliseJSONResponse(response);	
	return response;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
	
end;</source>
        <Parameter name="request" type="WS_MachineRejectTasksRequest"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putRepairDamage" id="de6af500-d1d2-4bf5-b0fe-b740d4b7c2b1">
        <updating/>
        <source>putRepairDamage(_request : WS_RepairDamageRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jan 2023	navlw1	Initial creation TFS 55162 EUP - WMS-Advanced Repair Details

*/

vars
	response 			: WS_Response;
	completedOK 		: Boolean;
	damageInstanceOid 	: String;
	damageInstance 		: CM_DamageInstance;
	allDamageToRepair 	: CM_DamageInstanceSet;
	damageUid 			: String;
	wsRepairObject 		: WS_RestRepairObject;
	pxyDamage 			: CM_DamageInstance;
	repairReason 		: CM_RepairReason;
	terminal 			: CM_Terminal;
	repairedDate		: TimeStamp;
	status 				: Integer;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	self.setIgnoreWarnings(_request.warningsAcknowledged);
	
	app.checkCurrentUserHasAccess(PmHHCargoRepair);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	create allDamageToRepair transient;
	
	// loop through the collection 
	foreach wsRepairObject in _request.allDamagesToRepair do
		if wsRepairObject.damageUid &lt;&gt; null then
			damageInstance := app.myPassport.getObjectOfTypeFromOid(wsRepairObject.damageUid,CM_DamageInstance).CM_DamageInstance;
		endif;
		if app.myPassport.hasErrors then
			completedOK := true;
			return response;
		endif;
		if wsRepairObject.repairReason &lt;&gt; null then
			repairReason := terminal.allRepairReasons[wsRepairObject.repairReason].CM_RepairReason;
		endif;
		if wsRepairObject.repairDateTime &lt;&gt; null then
			repairedDate := wsRepairObject.repairDateTime.TimeStamp;
		endif;
		if wsRepairObject.status = null then
			status := 3;
		else
			status := wsRepairObject.status;
		endif;
		if damageInstance &lt;&gt; null then
			pxyDamage := app.createUpdateProxy(damageInstance).CM_DamageInstance;
			pxyDamage.setProxy(damageInstance.myTrackedItem, 
								damageInstance.myTIMaster,
								damageInstance.myDamageDefinition, 
								damageInstance.myDamagePosition,
								damageInstance.remarks,
								damageInstance.isNewDamage,
								damageInstance.quantity,
								damageInstance.myDamageSeverity,
								damageInstance.locationString,
								damageInstance.myDamagePlace,
								damageInstance.myDamageParty,
								damageInstance.myDamageReason,
								repairReason,
								damageInstance.damageSize,
								damageInstance.damageDateTime,
								status,
								wsRepairObject.repairRemarks,
								repairedDate);
								
			self.objectsToBeDeleted.add(pxyDamage);
		
			if not allDamageToRepair.includes(pxyDamage) then
				allDamageToRepair.add(pxyDamage);
			endif;
		endif;
	endforeach;
	
	if allDamageToRepair.first = null then
		completedOK := true;
		return response;	
	endif;
	
	app.myTrxUA.trxUpdateDamageRepair(allDamageToRepair,app.myPassport);
	
	completedOK := true;
	return response;

epilog
	delete allDamageToRepair;
	finaliseResponse(response);
end;</source>
        <Parameter name="_request" type="WS_RepairDamageRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putSaveCargoDamage" id="6deeac51-40c9-4393-a7c8-1c5f03f5adce">
        <updating/>
        <source>putSaveCargoDamage(_cargoDamageRequest : WS_CargoDamageNxgRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2024	navsck1	Initial creation for MTN-33610 Create a new webservice to handle multiple damages and images
27 Dec 2024	navnk30	JIRA 63610: Create a new webservice to handle multiple damages and images
30 Jan 2025	navsck1	MTN-33869 photo preview is not displayed in the thin-client from the web
21 Nov 2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/

vars
	response 		: WS_Response;
	terminal 		: CM_Terminal;
	wsDamageObject 	: WS_RestDamageNxgObject;
	damageUid,
	damSize,
	cargoId,
	cargoOid		: String;
	ti,	
	pxyTI			: CM_TrackedItem;
	damPos 			: CM_DamagePosition;
	damType 		: CM_DamageDefinitionCode;
	damSev 			: CM_DamageSeverity;
	damParty 		: CM_DamageParty;
	damReason		: CM_DamageReason;
	damPlace		: CM_DamagePlace;
	status 			: Integer;
	isLoadState,
	advanceDamPerm	: Boolean;
	damDate			: TimeStamp;
	damages			: WS_DamageNxgArray;
	damage,
	damageToUpdate,
	pxyDamage,
	damageToDelete	: CM_DamageInstance;
	damageDeleteSet	: CM_DamageInstanceSet;
	wsCargoPhoto	: WS_Photo;
	proxyPhoto	 	: CM_Photo;	
	picture         : Binary;
	cargoPhotos 	: ObjectArray;
	
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);

	create response transient;
	create damageDeleteSet transient;					//27.12.2024 navnk30 JIRA #33610
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	self.setIgnoreWarnings(_cargoDamageRequest.warningsAcknowledged);
		
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHDamageReport);
	if app.myPassport.hasErrors then
		return response;
	endif;	
	
	damages := _cargoDamageRequest.damages;	
	cargoId := _cargoDamageRequest.cargoId;
	cargoOid := _cargoDamageRequest.cargoUid;													

	if cargoId = null and cargoOid = null  then
		app.raiseCMException1(Cargo_item_not_found, cargoId , null, null);
		return response;
	endif;
	
	ti := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;		
	if ti = null then																		
		ti := terminal.lookupTrackedItem(cargoId, null, null, null, false);					
	endif;																					
	
	if ti = null then
		app.raiseCMException1(Cargo_item_not_found, cargoId , null, null);
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	
	//now remove the damage from the exisitng all instance of the ti
	app.cmsBeginLoad(isLoadState);
	pxyTI :=	ti.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoadState);
	
	/* If any damages are to be deleted, purge all the pxy damages,	
		create new pxy damages only for damage instances that are not present in damagesToDelete
	*/
	if _cargoDamageRequest.damagesToDelete.isNotEmpty then
		pxyTI.purgeAllDamageInstance();
	endif;
	
	foreach damageUid in _cargoDamageRequest.damagesToDelete do 				//27.12.2024 navnk30 JIRA #33610 START
		damageToDelete := app.myPassport.getObjectOfTypeFromOid(damageUid,CM_DamageInstance).CM_DamageInstance;
		if app.myPassport.hasErrors then
			return response;
		endif;
		if damageToDelete = null then
			app.raiseCMException1(Damage_not_found, damageUid, null, null);
			return response;
		endif;
		
		damageDeleteSet.tryAdd(damageToDelete);
	endforeach;
	
	foreach damage in ti.allDamageInstances where not damageDeleteSet.includes(damage) do
		app.cmsBeginLoad(isLoadState);
		if damage.pxyGetProxyObject() = null then
			pxyDamage := damage.pxyCreateUpdateProxy();
		else
			pxyDamage := damage.pxyGetProxyObject();
		endif;
		app.cmsEndLoad(isLoadState);
		pxyDamage.setMyTrackedItem(pxyTI);
	endforeach;																	//27.12.2024 navnk30 JIRA #33610 END
	

	//here check for update damage and create damages
	// have to iterate the damages add or update
	foreach wsDamageObject in damages where wsDamageObject &lt;&gt; null do			//27.12.2024 navnk30 JIRA #33610
		damageUid := wsDamageObject.damageUid;
		advanceDamPerm := app.myCurrentUserCan(terminal,PmAdmDamageCodeAdvancedMaint);
			
		// advanced permission check
		if advanceDamPerm then
			if wsDamageObject.responsibleParty &lt;&gt; null then
				damParty := terminal.allDamageParties[wsDamageObject.responsibleParty];
			endif;
			status := wsDamageObject.damageStatus.Integer;
			if wsDamageObject.damagePlace &lt;&gt; null then
				damPlace := terminal.allDamagePlaces[wsDamageObject.damagePlace];
			endif;
			damDate := wsDamageObject.damageDateTime.TimeStamp;                                        
			if wsDamageObject.damageReason &lt;&gt; null then
				damReason := terminal.allDamageReasons[wsDamageObject.damageReason];
			endif;
			if wsDamageObject.damageSize &lt;&gt; null then
				damSize := wsDamageObject.damageSize;
			endif;
		endif;

		if (wsDamageObject.damagePosition = null or wsDamageObject.damageDefinition = null) and damParty = null then
			//Display info message
			response.addInfo(app.getErrorString(CargoDamagedNoInstance));
			
			if ti.damaged then
				continue;
			else
				pxyTI.setDamaged(true);
				continue;
			endif;
		endif;
		
		if wsDamageObject.damagePosition &lt;&gt; null then
			damPos := app.myRoot.allDamagePositionsByCode[wsDamageObject.damagePosition];
		endif;
		if wsDamageObject.damageDefinition &lt;&gt; null then
			damType := app.myRoot.allDamageDefinitionCodes[wsDamageObject.damageDefinition];
		endif;
		if wsDamageObject.damageSeverity &lt;&gt; null then
			damSev := terminal.allDamageSeverities[wsDamageObject.damageSeverity];
		endif;
		
		if not advanceDamPerm then
			status := null;		
		endif;
	
		if damageUid = null then
			pxyTI.setDamaged(true);
			pxyTI.setDamagedDT(true);	
		
			if wsDamageObject &lt;&gt; null then
				app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String  &amp; "creating damage " &amp; damParty.String , LogINFO);
				pxyTI.createPxyDamageInstance(damType, 
										  damPos,
										  wsDamageObject.remarks, 
										  true, 
										  wsDamageObject.quantity.Integer, 
										  damSev, 
										  null,
										  damPlace, 
										  damParty, 
										  damReason, 
										  null, 
										  damSize.Decimal, 
										  damDate,
										  status, 
										  null, 
										  null);
			endif;
			
		else
			//update existing damage
			damageToUpdate := app.myPassport.getObjectOfTypeFromOid(wsDamageObject.damageUid,CM_DamageInstance).CM_DamageInstance;
			
			if damageToUpdate = null then
				app.raiseCMException1(Damage_not_found, wsDamageObject.damageUid, null, null);	
				return response;
			endif;
			
			pxyDamage := damageToUpdate.pxyGetProxyObject();	
	
			pxyDamage.setProxy(pxyTI, null, damType, damPos, wsDamageObject.remarks, false, wsDamageObject.quantity.Integer,
											damSev, 
											null,
											damPlace,
											damParty,
											damReason,
											damageToUpdate.myRepairReason,
											damSize.Decimal,					
											damDate,
											status,
											damageToUpdate.repairRemarks,
											damageToUpdate.repairedDateTime);
		endif;
	endforeach;
	
	if pxyTI.allDamageInstances.isEmpty then		
		pxyTI.setDamaged(false);					
		pxyTI.setDamagedDT(false);					
	endif;											
	
	create cargoPhotos transient;
	foreach wsCargoPhoto in _cargoDamageRequest.allPhotos do
		create proxyPhoto transient;
		proxyPhoto.setDescription(wsCargoPhoto.description);
		proxyPhoto.setMyParent(ti);
		proxyPhoto.setPhotoContent(wsCargoPhoto.photoBytes);
		//proxyPhoto.setThumbnailContent(wsCargoPhoto.photoBytes);    // 30.01.2025 navsck1 #MTN-33869      //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
		
		picture := proxyPhoto.photoBytes.getContent();    
		if not picture.isPictureValid then
			app.raiseCMException(File_type_not_support, null, null);
			return response;
		endif;
		cargoPhotos.add(proxyPhoto);
	endforeach;	
	
	// final trx call 
	app.myTrxUA.trxUpdateTIDamagesAndPhotos(pxyTI, app.myPassport, cargoPhotos);
	return response;
epilog
	app.cmsEndLoad(isLoadState);
	delete pxyTI;
	delete proxyPhoto;
	delete cargoPhotos;
	delete damageDeleteSet;
	self.finaliseResponse(response);	
end;</source>
        <Parameter name="_cargoDamageRequest" type="WS_CargoDamageNxgRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putSealsOnTruck" id="b486a941-b9a4-47e6-85a3-9fb422c06be5">
        <updating/>
        <source>putSealsOnTruck(request : WS_SealsRequest; truckOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 May 2023			jlizm1	Initial creation TFS 56558 EUP Seal Numbers on Trucks - Web
19 Jun 2024 		navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps 

*/

vars
	response 			: WS_Response;
	roadJob 			: CM_RoadJob;
	vvr 				: CM_VehicleVisitRecord;
	sealCheckType 		: Integer;
	beforeValue			: String;
	afterValue 			: String;
	viewed 				: Integer;
	sealedDT 			: TimeStamp;
	seal 				: WS_Seal;
	pxyTruckSeal 		: CM_TruckSeal;
	truckSeal 			: CM_TruckSeal;
	truck				: CM_Vehicle;
	terminal			: CM_Terminal;
	permissionsToCheck 	: IntegerArray;
	pxySealCheckDetail 	: CM_WagonSealCheckDetail;
	pxyUpdateSealsArray : CM_SealObjectBySealTypeDict;
	pxySealsCheckDetailArray	: CM_SealCheckDetailSet;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;
	
	if app.myPassport.hasErrors then
		app.writeLog(method.qualifiedName &amp; " passport has errors", LogERROR);
		return response;
	endif;
	
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//19.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//19.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHCargoSeals);
	permissionsToCheck.add(PmHandHeldTruckLoader);
	permissionsToCheck.add(PmHandHeldTruckUnloader);
	permissionsToCheck.add(PmHHPackLoadRequest);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	truck := app.myPassport.getObjectOfTypeFromOid(truckOid, CM_Vehicle).CM_Vehicle;
	
	if truck = null then
		truck := terminal.vehicles[truckOid.toUpper, ""];
		
		if truck = null then
			app.raiseCMException(Truck_not_found, null, null);
			return response;
		endif;
	endif;
	
	roadJob := truck.getCurrentRoadJob();
	if roadJob = null then
		app.raiseCMException(Cannot_find_roadJob, null, null);
		return response;
	endif;
	
	vvr := roadJob.myVehicleVisit;
	if vvr = null then
		app.raiseCMException(Err_No_Vehicle_visit_found, null, null);
		return response;
	endif;
	
	create pxySealsCheckDetailArray transient;
	create pxyUpdateSealsArray transient;
	sealCheckType := app.myPassport.myTerminal.getSealCheckTypeForContext(request.sealCheckContext);
	
	foreach seal in request.allSeals discreteLock do
		beforeValue := null;
		afterValue := null;
		viewed := 0;
		
		if sealCheckType = SEAL_CHECK_VIEW then
			if  seal.value = "" then
				app.raiseCMException2(Pleas_indic_wheth_seal_item_be, seal.sealType, vvr.regNumber ,null,null);
				return response;
			endif;
			
			if seal.value = "Y" then
				viewed := CM_WagonSealCheckDetail.Seal_Viewed;
			elseif seal.value = "N" then
				viewed := CM_WagonSealCheckDetail.Seal_Not_Viewed;
			endif;
			
		else
			afterValue := seal.value;
			truckSeal := vvr.allTruckSeals.getTruckSeal(seal.getSealTypeObj());
			beforeValue := null;
			if truckSeal &lt;&gt; null then
				beforeValue := truckSeal.getSealValueAsString;
			endif;
			
			if  sealCheckType = SEAL_CHECK_STRICT then		
				//check the values match
				if beforeValue &lt;&gt; afterValue then
					app.raiseCMException2(Value_entered_does_not_match, afterValue, app.myRoot.allSealTypes[seal.sealType].description, null, null);
					return response;
				endif;
				
			else
				if beforeValue &lt;&gt; afterValue then
					if truckSeal &lt;&gt; null then
						sealedDT := truckSeal.sealedDT;
					else
						sealedDT := app.actualTimeServer;
					endif;
				
					create pxyTruckSeal transient;
					pxyTruckSeal.setProxy(	afterValue,		//_sealNum : String;
											beforeValue,	//_prevSeal : String;
											seal.sealType,	//_sealType : String;
											sealedDT,		//_sealedDT : TimeStamp;
											vvr				//_vvr : CM_VehcileVisitRecord
											);
										
					pxyUpdateSealsArray.add(pxyTruckSeal);
				endif;
			endif;	
		endif;		

		create pxySealCheckDetail transient;
		pxySealCheckDetail.setProxy(null,			//_sealCheck : CM_SealCheck;
									afterValue,		//_sealAfter : String;
									beforeValue,	//_sealBefore : String;
									sealCheckType,	//_sealCheckType : Integer;
									seal.sealType,	//_sealType : String;
									viewed			//_viewed : Integer;
									);
	
		pxySealsCheckDetailArray.add( pxySealCheckDetail );
	endforeach;

		
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);	
	app.myTrxCA.trxCreateTruckSealCheckTrans(pxySealsCheckDetailArray, vvr, pxyUpdateSealsArray, app.myPassport);
		
	return response;
	
epilog
	if pxySealsCheckDetailArray &lt;&gt; null then
		pxySealsCheckDetailArray.purge();
	endif;
	delete pxySealsCheckDetailArray;
	
	if pxyUpdateSealsArray &lt;&gt; null then
		pxyUpdateSealsArray.purge();
	endif;
	delete pxyUpdateSealsArray;
	
	delete permissionsToCheck;

	finaliseResponse(response);	

end;</source>
        <Parameter name="request" type="WS_SealsRequest"/>
        <Parameter name="truckOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putSealsOnWagon" id="9b13b336-067b-47c7-9ea1-507a9b2669f4">
        <updating/>
        <source>putSealsOnWagon(request : WS_WagonSealsRequest; wagonOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	jlier1	Initial creation 53971

*/

vars
	response : WS_Response;
	wagon 	: CM_Wagon;
	seal 	: WS_Seal;
	pxyWagonSeal : CM_WagonSeal;
	wagonSeal : CM_WagonSeal;
	beforeValue,
	afterValue : String;
	pxySealCheckDetail : CM_WagonSealCheckDetail;
	pxySealsCheckDetailArray,
	pxyUpdateSealsArray : CM_ObjectArray;
	wagonTrx : CMEVT_WagonTransaction;
	viewed :Integer;
	sealedDT : TimeStamp;
	sealCheckType : Integer;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		app.writeLog(method.qualifiedName &amp; " passport has errors", LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);		
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	
	wagon:=app.myPassport.getObjectOfTypeFromOid(wagonOid,CM_Wagon).CM_Wagon;
	
	if app.myPassport.hasErrors then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " passport has errors", LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	
	if wagon = null then
		app.raiseCMException1(Wagon_not_found_expect_wagons,wagonOid,null,null);
		return response;
	endif;	

	create pxySealsCheckDetailArray transient;
	create pxyUpdateSealsArray transient;
		// ### If VIEW mode then check that all the seals have been touched
	sealCheckType:=app.myPassport.myTerminal.getSealCheckTypeForContext(request.sealCheckContext);
	app.writeLog("I got up to this point in the REST API", LogINFO);			
	app.writeLog(request.allSeals.size.String, LogINFO);			
	foreach seal in request.allSeals discreteLock do
			app.writeLog("Seal Value from REST API" &amp; seal.value.String, LogINFO);	
			app.writeLog("Seal Type from REST API" &amp; seal.sealType.String, LogINFO);	
			beforeValue:=null;
			afterValue:=null;
			viewed:=0;
			if sealCheckType = SEAL_CHECK_VIEW then
				if  seal.value = "" then
					app.raiseCMException2(Pleas_indic_wheth_seal_item_be,wagon.id, seal.sealType,null,null);
					return response;
				endif;
				if seal.value ="Y" then
					viewed:=CM_WagonSealCheckDetail.Seal_Viewed;
				elseif seal.value = "N" then
					viewed:=CM_WagonSealCheckDetail.Seal_Not_Viewed;
				endif;
			else
				afterValue:=seal.value;
				wagonSeal:=wagon.allWagonSeals[seal.sealType];
				beforeValue:=null;
				if wagonSeal &lt;&gt; null then
					beforeValue:=wagonSeal.getSealValueAsString;
				endif;
				if  sealCheckType = SEAL_CHECK_STRICT then		
				//check the values match
				
					if beforeValue &lt;&gt; afterValue then
						app.raiseCMException2(Value_entered_does_not_match,afterValue,app.myRoot.allSealTypes[seal.sealType].description,null,null);
						
						return response;
					endif;
				else
					if beforeValue &lt;&gt; afterValue then
						if wagonSeal &lt;&gt; null then
							sealedDT:=wagonSeal.sealedDT;
						else
							sealedDT:=app.actualTimeServer;
						endif;
					
						create pxyWagonSeal transient;
						pxyWagonSeal.setProxy(	afterValue,	//_sealNum : String;
												beforeValue,	//_prevSeal : String;
												seal.sealType,	//_sealType : String;
												sealedDT,	//_sealedDT : TimeStamp;
												wagon	//_myWagonVisit : CM_Wagon
												);
											
						pxyUpdateSealsArray.add( pxyWagonSeal );
					
					endif;
				endif;	
			endif;		

			create pxySealCheckDetail transient;
			
			pxySealCheckDetail.setProxy(	null,	//_sealCheck : CM_SealCheck;
										afterValue,	//_sealAfter : String;
										beforeValue,	//_sealBefore : String;
										sealCheckType,	//_sealCheckType : Integer;
										seal.sealType,	//_sealType : String;
										viewed	//_viewed : Integer;
										);
	
			pxySealsCheckDetailArray.add( pxySealCheckDetail );
			
	endforeach;

		
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);	
	app.myTrxCA.trxCreateWagonSealsCheckTrans( null, wagon, wagonTrx,pxySealsCheckDetailArray, pxyUpdateSealsArray,  request.sealCheckContext, app.myPassport);
		
	
	return response;
epilog
	
	if pxySealsCheckDetailArray &lt;&gt; null then
		pxySealsCheckDetailArray.purge;
	endif;
	delete pxySealsCheckDetailArray;
	if pxyUpdateSealsArray &lt;&gt; null then
		pxyUpdateSealsArray.purge;
	endif;
	delete pxyUpdateSealsArray;
	
	finaliseResponse(response);	
	
end;</source>
        <Parameter name="request" type="WS_WagonSealsRequest"/>
        <Parameter name="wagonOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putSetDownCargoForMultiMove" id="01af9ad9-9515-4aca-bceb-064a114679ba">
        <updating/>
        <source>putSetDownCargoForMultiMove(_request : WS_MultiMoveRequest) : String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 April 2022	jlier1	Initial creation
10 Jul 2024 	navsck1 Defect 65010: MTN - Mobile Apps - Truck Loader / Unloader is no longer return the warning message 79688 (Unavailable for Release)
*/

vars
	machine 			: CM_Machine;
	response			: String;	
	cargo	: CM_TrackedItem;
	machConfig 			: CM_RTVehicleConfig;
	allCmifItems    : CMIF_Array;
	cmifMultiItem   : CMIF_MultiMoveItem;
	moveRequestItem : WS_MoveItem;
	rtqTask         : CM_RTQueueTask;
	targetLoc		: String;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;	
		return response;
	endif;	
	
	machConfig := machine.myTerminal.getRTVehicleConfigForObject(machine);
	if machConfig = null then
		app.raiseCMException1(Machine_require_vehicle_config,machine.code,null,null);
		return response;
	endif;
	
	
	if _request.allMoveItems.first = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);	
		return response;
	endif;
	
	//[1] Prepare Items
	create allCmifItems transient;
	foreach moveRequestItem in _request.allMoveItems do
		
		targetLoc:=null;
		rtqTask:=null;
		cargo   := app.myPassport.getObjectOfTypeFromOid(moveRequestItem.cargoOid,CM_TrackedItem).CM_TrackedItem;
		if cargo &lt;&gt; null then
			rtqTask:=cargo.getQueueTask;
			targetLoc:=cargo.plannedLocnId;
			if rtqTask = null then
				app.raiseCMException(Input_required_field_RTQue,null,null);	
				return response;
			endif;
		else
			app.raiseCMException(Input_required_field_cargoId,null,null);	
			return response;
		endif;
		
		if  targetLoc &lt;&gt; null and rtqTask &lt;&gt; null then
			create cmifMultiItem transient;
			cmifMultiItem.setCmifDetails(rtqTask,targetLoc);
			allCmifItems.add(cmifMultiItem);
		endif;
	endforeach;
	
	//[2] Call pickup Trx
	if allCmifItems.isNotEmpty() then
		app.myPassport.setupForDeadlockReplay(-100, 2000);
		while true do
			app.myTrxUA.trxMachineSetdownMultiTask(machine,allCmifItems, app.myPassport);
			if app.myPassport.noTrxReplayAllowed() then	
				break;
			endif;
		endwhile;
	endif;
	
	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	response := machine.getMultiMoveCargoAsJSON();
	
	return response;
	
epilog	
	if allCmifItems &lt;&gt; null then
		allCmifItems.purge;
	endif;
	delete allCmifItems;

	finaliseJSONResponse(response);	
	return response;
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_request" type="WS_MultiMoveRequest"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putSetDownTask" id="14b25da4-86f6-44cd-b749-0729e584d8e1">
        <updating/>
        <source>putSetDownTask(request : WS_MachineSetdownTaskRequest) : String updating;
/*

Purpose: This is the REST version of machineDoSetdown	

Parameters:			

Return Value:

Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
22 Jun 2022 jlika1	53830	PNL - Vehicle App - Swap Button Broken when Tandem Lifting to two trucks
16 Aug 2022	jlier1	54410 	Moved updating the weights to the trx layer 
============================================================================*/

vars
	response		: String;	
	task,
	twinTask 		: CM_RTQueueTask;	
	machineConfig 	: CM_RTVehicleConfig;
	machine 		: CM_Machine;
	showList		: Boolean;
	canChange		: Boolean;
	isDriverMove	: Boolean;
	isDischargeMove	: Boolean;
	taskTi			: CM_TrackedItem;
	newTasks 		: CM_RTQueueTaskArray;
	sourceLocation : CM_LocationsController;
	terminal : CM_Terminal;
	job	: CM_Job;
	wle : CM_WorkListEntry;
	moveController : CMIF_MoveController;
	params 	: CMIF_AutoplanParams;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;	
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	task := app.myPassport.getObjectOfTypeFromOid(request.taskOid,CM_RTQueueTask).CM_RTQueueTask;	
	if task = null then
		app.raiseCMException(Input_required_field_RTQue,null,null);		
		return response;
	endif;
	
	taskTi := task.ti; 
	twinTask := app.myPassport.getObjectOfTypeFromOid(request.twinTaskOid,CM_RTQueueTask).CM_RTQueueTask;
	if app.myPassport.hasErrors then		
		return response;
	endif;	
	isDriverMove := not task.isOverstowTask and task.myEntry.isMachineInitiatedMove;
	//epr TFS 49687 6/7/21
	sourceLocation:= task.myEntry.getUltimateSourceLocation;
	if sourceLocation &lt;&gt; null and sourceLocation.isKindOf(CM_VoyageController) and task.myEntry.myQueue.canMachineDischarge then
		isDischargeMove :=true;
	endif;
	
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	while true do
		if machine.ignoresWarnings then									
			self.setIgnoreWarnings(true);
		else															
			self.setIgnoreWarnings(request.warningsAcknowledged);		
		endif;			
		
		app.myTrxUA.trxMachineSetdownTask(machine, task, twinTask, request.setdownLocation, request.twinSetdownLocation, request.overrideToInterchange, request.isSwap,request.weightTotal.Integer, request.weightCertified,app.myPassport);
		
		if app.myPassport.hasWarningsToAcknowledge and not app.myPassport.warningsIgnored then						
			return response;																			
		endif;																							
				
		if app.myPassport.noTrxReplayAllowed() then	
			break;
		endif;		
		
	endwhile;
	
	if app.myPassport.hasErrors then		
		return response;
	endif;
	
	terminal:=machine.getMyTerminal;
	machineConfig := terminal.getRTVehicleConfigForObject(machine);	

	//epr TFS 49687 6/7/21
	if  not isDriverMove and  not isDischargeMove and machineConfig &lt;&gt; null then
		showList:=machineConfig.isShowingList(canChange);
		if not showList and  machineConfig.automaticGetNextTask then
			app.myPassport.replayingDeadlocks := false;
			app.myPassport.setupForDeadlockReplay(-100, 2000);
			
			while true do				
				app.myTrxUA.trxMachineGetNext(machine, app.myPassport);
				if app.myPassport.noTrxReplayAllowed() then
					break;
				endif;
	
			endwhile;
		endif;
		//I don't care about errors after automatic get next
		app.myPassport.clearErrorsWarnings;
	endif;
	
	//jlier TFS 54676 1/11/22
	if isDriverMove then
		//was on a MAFI
		app.writeLog(method.qualifiedName &amp; Tab &amp; sourceLocation.String, LogTRACE);	
		if taskTi.isImport and taskTi.isContainer and (sourceLocation.isKindOf(CM_TILCController) and sourceLocation.CM_TILCController.myTILC.isMAFI)   then
			if terminal.getConfig(QueueImpStagedRORODriver).Boolean then
				job:=taskTi.getRoadReleaseJob(null);		
				if  job &lt;&gt; null and job.status = JOB_COMPLETE then
					job:=null;
				endif;
				job:=taskTi.jobRoadRelease;
				if  job &lt;&gt; null and job.status = JOB_COMPLETE then
					job:=null;
				endif;
				if job &lt;&gt; null then
					wle:=job.getWLEForTI(taskTi);
				endif;
				app.myPassport.replayingDeadlocks := false;
				app.myPassport.setupForDeadlockReplay(-100, 2000);
				if wle &lt;&gt; null then
					create moveController transient;
					moveController.setMyTrackedItem(taskTi);
					moveController.setMoveMode(QUEUE_MODE);
					moveController.setMyToPrimaryLocation(wle.getTargetLocation);
					moveController.setMyWorkListEntry(wle);
					moveController.setJobForMove(wle.job);
					while true do				
						app.myPassport.setWarningsIgnored(true);
						app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
						if app.myPassport.noTrxReplayAllowed() then
							break;
						endif;	
					endwhile;
				
				else
					//auto plan 
					create params transient;					
					params.moveMode := QUEUE_MODE;
					params.allTrackedItems.add(taskTi);
					
					while true do
						app.myPassport.setWarningsIgnored(true);
						app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
						if app.myPassport.noTrxReplayAllowed() then
							break;
						endif;	
					endwhile;
					
				endif;
				app.myPassport.clearErrorsWarnings;
			endif;
		endif;
	endif;
	
	create newTasks transient;
	
	response := machine.getTasksAsJSON(newTasks);
	
	//jlier1 TFS 57910 11/5/23
	if isDriverMove then
		newTasks:=null;
	endif;
	app.myTrxUA.trxMachineSetTaskStates(machine,newTasks,app.myPassport);
	
	return response;
	
epilog	
	delete newTasks;
	delete moveController;
	
	finaliseJSONResponse(response);	
	return response;	
	
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="request" type="WS_MachineSetdownTaskRequest"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="putWOJobTaskComplete" id="badd7b82-6a4f-4ea4-9cb0-7fc46e3e9c4c">
        <updating/>
        <source>putWOJobTaskComplete(_request : WS_RestIntWoJobTaskCompRequest) : WS_Response updating;
/*

Purpose:			Completes a ToDo Task work order job and completes the to do task associated with each cargo item on the work order

Parameters:			_request	WS_RestIntWoJobTaskComplRequest	The request to process and action

Return Value:		WS_Response	The response containing any errors messages &amp; warnings

Date				Who		Reason
05 December 2023	navpw1	Initial creation TFS: 58758 (60742)
07 May 2024			navpw1	TFS: 63920 (63924) - Added new wle to handle transactions of type WO TI Transaction
31 May 2024 		navhl20 Bug 64261: EUP | VAS - Not able to complete TODO jobs
03 Dec 2024 		navbs1 Bug MTN-33436: EUP - Internal server error -Non cargo Todo work Orders
06 Mar 2025			navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
05 Mar 2025			navhl20 Bug MTN-34107: EUP - ToDo Tasks getting completed for Partial Receive Work Orders
*/

vars
	response					: WS_Response;
	terminal					: CM_Terminal;
	user						: CM_User;
	woToDoTaskJob				: CM_WOToDoTaskJob;
	tiSet						: CM_TISet;
	ti							: CM_TrackedItem;
	toDoTaskDesc				: CM_ToDoTaskDesc;
	resourceUsageProxys			: CM_ResourceTypeUsageSet;
	wsResourceCategory			: WS_RestIntResourceCategory;
	wsResourceUsage				: WS_RestIntResourceUsage;
	resourceType				: CM_ResourceType;
	resourceUsage				: CM_ResourceTypeUsage;
	taskCriteria				: CM_TaskCriteria;
	resourceTypeGroup			: CM_ResourceTypeGroup;
	resourceCategory			: WS_RestIntResourceCategory;
	mandatoryGroupsArr			: ObjectArray;
	fromDT,
	toDT						: TimeStamp;
	hasToDoTask					: Boolean;
	strResourceTypeGroupsError	: String;
	wle							: CM_WorkListEntry;				// ### TFS 63920 (63924) 07May2024 NAVPW1
	task						: CM_ToDoTask;
	object						: CM_Object;
	wodl						: CM_WorkOrderToDoDtl;
	operJob						: CM_Job;
	operJobStr					: String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal	:= app.myPassport.myTerminal;
	user		:= app.myPassport.myUser;
	
	woToDoTaskJob := app.myPassport.getObjectOfTypeFromOid(_request.jobUid, CM_WOToDoTaskJob).CM_WOToDoTaskJob;
	
	if woToDoTaskJob = null then
		app.raiseCMException(Input_required_field_jobUid, null, null);
		return response;
	endif;
	
	// Check security access to this message, if required
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(_request.warningsAcknowledged);
	
	operJobStr := self.qsData.getValue(self.QueryParam_operationalJobOid).asStringJMT();			//05.03.2025 navhl20 #34107
	if operJobStr &lt;&gt; null then																//05.03.2025 navhl20 #34107
		operJob := app.myPassport.getObjectOfTypeFromOid(operJobStr, CM_Job).CM_Job;
	endif;
	
	toDoTaskDesc := woToDoTaskJob.myToDoTaskDesc;
	
	//Validate Resources on ToDo task and ensure mandatory ones are provided
	create mandatoryGroupsArr transient;
	taskCriteria := toDoTaskDesc.allTaskCriteria[terminal, toDoTaskDesc.code];	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
	if taskCriteria &lt;&gt; null then
		taskCriteria.allMandatoryResourceGroups.copy(mandatoryGroupsArr);
	endif;
	
	foreach resourceCategory in _request.resourceCategories do
		resourceTypeGroup := app.myPassport.getObjectOfTypeFromOid(resourceCategory.uid, CM_ResourceTypeGroup).CM_ResourceTypeGroup;
		
		if resourceTypeGroup = null then
			app.raiseCMException1(Resource_type_grp_not_found, resourceCategory.uid, null, null);
			return response;
			
		endif;
		
		if not mandatoryGroupsArr.includes(resourceTypeGroup) then
			continue;
			
		endif;
		
		mandatoryGroupsArr.remove(resourceTypeGroup);
		
	endforeach;
	
	if mandatoryGroupsArr.isNotEmpty then
		foreach resourceTypeGroup in mandatoryGroupsArr as CM_ResourceTypeGroup do
			strResourceTypeGroupsError &amp;= resourceTypeGroup.code &amp; Comma &amp; Space;
			
		endforeach;
		
		app.raiseCMException2(Mandatory_res_type_grps_miss, toDoTaskDesc.description, strResourceTypeGroupsError.stripTrailingChar(Comma), null, null);
		return response;
		
	endif;
	
	// ### TFS 63920 (63924) 07May2024 NAVPW1
	//Grab the wle
	wle := woToDoTaskJob.workListEntries.first;
	
	if not wle.isForToDoWOTransaction then //If this wle is not for ToDo WO Transaction type then add the tis to the set
		create tiSet transient;
		foreach wle in woToDoTaskJob.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
			ti := wle.CM_WOToDoWLE.myTrackedItem;
			
			if ti  = null then
				continue;
			endif;
			
			hasToDoTask := ti.allToDoTasksToDo.includesToDoDesc(toDoTaskDesc.code);
			
			if not hasToDoTask then
				continue;
			endif;
			
			if operJob &lt;&gt; null and not operJob.isRelease then			//05.03.2025 navhl20 #34107
				if operJob.isRail then
					if not operJob.CM_RailJob.allReceiveTrackedItems.includes(ti) then
						continue;
					endif;
				else
					if not operJob.CM_RoadJob.allReceiveTrackedItems.includes(ti) then
						continue;
					endif;
				endif;
			endif;
			
			tiSet.addNoDuplicates(ti,false);
		endforeach;
	endif;
	// ### TFS 63920 (63924) 07May2024 NAVPW1
	
	//Create resource type usage proxies for job/task.
	create resourceUsageProxys transient;
	foreach wsResourceCategory in _request.resourceCategories do
		foreach wsResourceUsage in wsResourceCategory.resources do
			resourceType := app.myPassport.getObjectOfTypeFromOid(wsResourceUsage.uid, CM_ResourceType).CM_ResourceType;
			
			if resourceType = null then
				app.raiseCMException1(Resource_type_not_found, wsResourceUsage.uid, null, null);
				return response;
				
			endif;
			
			fromDT	:= null;
			toDT	:= null;
			
			if resourceType.isFromToDateTimeRequired then
				fromDT := wsResourceUsage.fromDateTime.asUTCTimeStamp.utcToLocalTime;
				toDT:= wsResourceUsage.toDateTime.asUTCTimeStamp.utcToLocalTime;
			endif;
			
			create resourceUsage transient;
			resourceUsage.setProxy(resourceType,
									null,							//_transaction : CM_TITransaction;
									null,
									wsResourceUsage.quantity,
									wsResourceUsage.remarks,
									CM_InvoiceLine.STATUS_NORMAL,
									fromDT,							//_fromDateTime : TimeStamp
									toDT,							//_toDateTime : TimeStamp
									null,
									null,
									null
									);
			resourceUsageProxys.add(resourceUsage);
			
		endforeach;
		
	endforeach;
	
	//03.12.2024  navbs1  #33436 START
	/*//If this is a CM_WOTransaction transaction type of To Do Task.
	// ### TFS 63920 (63924) 07May2024 NAVPW1
	if wle &lt;&gt; null and wle.isForToDoWOTransaction() then
		app.myTrxUA.trxUpdateWODTIToDoNoTIComplete(wle.CM_WOToDoWLE, wle.CM_WOToDoWLE.getToDoTask().CM_TiToDoTask, resourceUsageProxys, app.myPassport);
		return response;
		
	endif;
	// ### TFS 63920 (63924) 07May2024 NAVPW1
	
	if tiSet.isNotEmpty then																	//31.05.2024 navhl20 #64261
		//If this is a CM_TITransaction transaction type of To Do Task
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, tiSet, resourceUsageProxys, app.myPassport);
	else																						//31.05.2024 navhl20 #64261
		if wle &lt;&gt; null and wle.isKindOf(CM_WOToDoWLE) then
			task := wle.CM_WOToDoWLE.myToDoTask;
			wodl := wle.job.myWorkOrderDtlToDo;
		endif;
		if task &lt;&gt; null then
			object := task.getToDoObject();
		endif;
		app.myTrxUA.trxUpdateVasToDoTaskComplete(object, toDoTaskDesc.code, app.myPassport, resourceUsageProxys, wodl);
	endif;*/
	
	if wle.job.CM_WOToDoTaskJob.isToDoForCargoWorkOrder then 
		if wle.isForToDoWOTransaction() then 
			app.myTrxUA.trxUpdateWODTIToDoNoTIComplete(wle.CM_WOToDoWLE, wle.CM_WOToDoWLE.getToDoTask().CM_TiToDoTask, resourceUsageProxys, app.myPassport);
		else
			app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, tiSet, resourceUsageProxys, app.myPassport);
		endif;
	else
		task := wle.CM_WOToDoWLE.myToDoTask;
		wodl := wle.job.myWorkOrderDtlToDo;
		if task &lt;&gt; null then
			object := task.getToDoObject();
		endif;
		app.myTrxUA.trxUpdateVasToDoTaskComplete(object, toDoTaskDesc.code, app.myPassport, resourceUsageProxys, wodl);
	endif;
	//03.12.2024  navbs1  #33436 END
	
	return response;
	
epilog
	delete mandatoryGroupsArr;
	if resourceUsageProxys &lt;&gt; null then
		resourceUsageProxys.purge;
	endif;
	delete resourceUsageProxys;
	
	delete tiSet;
	
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="_request" type="WS_RestIntWoJobTaskCompRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putWagonConfirmation" id="902519a2-4fc6-405c-b866-00359a80f8e7">
        <updating/>
        <source>putWagonConfirmation(request : WS_WagonConfirmRequest): WS_Response updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description
19 July 2024 	navsck1 ChangeRequest 65186: MTN - SetIgnore Warning in mobile apps
****************************************************/

vars
	response 	: WS_Response;
	control		: CMIF_WagonMoveController;
	wagon		: CM_Wagon;
	wagonArray	: CM_WagonArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " passport has errors", LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	//self.setIgnoreWarnings(true); 			//19.7.2024 navsck1 #65186

	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);		
		
	if app.myPassport.hasErrors then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " passport has errors", LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	
	wagon:= app.myPassport.getObjectOfTypeFromOid(request.wagonUid,CM_Wagon).CM_Wagon;	
	if app.myPassport.hasErrors then
		app.writeLog(method.qualifiedName &amp; Tab &amp; " passport has errors", LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	if wagon = null then
		app.raiseCMException2(ERR_IsNotValid, app.getErrorString(Wagon),'', null,null) ;
		return response;
	endif;
	
	create wagonArray transient;
	wagonArray.add( wagon );
	create control transient;
	control.doAutoPlanOfCargo := request.autoPlanCargo;
	app.myPassport.clearErrorsWarnings();
	
	if request.isInwards then
		// ### TFS CR 64297 TASK 64391 31MAY2024 NAVAB1 - incase of dead locks, wait and retry
		app.myPassport.setupForDeadlockReplay(320, 2000);
		app.myPassport.silentDeadlockLimit := 4;	
		
		while true do
			self.setIgnoreWarnings(true);  						
			app.myTrxUA.trxUpdateWagonConfirm(wagonArray, true, control, app.myPassport);
			if app.myPassport.noTrxReplayAllowed() then
				break;
			endif;
		endwhile;
		 
	else
		app.myTrxUA.trxUpdateWagonsConfirmOut(null, wagonArray, true, app.myPassport);
	endif;
	
	return response;
epilog
	delete wagonArray;
	delete control;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_WagonConfirmRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="putWagonToRailLinePosition" id="2b24d58e-af0c-441c-b29d-68c1e2d222e7">
        <updating/>
        <source>putWagonToRailLinePosition(request : WS_WagonPosUpdRequest): WS_WagonPosUpdResponse updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	response 			: WS_WagonPosUpdResponse;
	terminal 			: CM_Terminal;
	railLine			: CM_RailLine;
	wagon				: CM_Wagon;
	wagonProxy			: WS_Wagon;
	wagonMoveController : CMIF_WagonMoveController;
	wagonOrginalPos 	: Integer;
	wagonAtSamePos  	: CM_Wagon;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	self.setIgnoreWarnings(true);

	
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if request.rakeUid = "" then
		app.raiseCMException(Rake_not_found,null,null);		
		return response;
	endif;

	if request.wagonUid = "" then
		app.raiseCMException(Wagon_null,null,null);	
		return response;
	endif;

	if request.rakePosition &lt; 1 then
		app.raiseCMException(Rake_posi_not_found,null,null);			
		return response;
	endif;

	terminal := app.myPassport.myTerminal;
	
	railLine := app.myPassport.getObjectOfTypeFromOid(request.rakeUid,CM_RailLine).CM_RailLine;
	
	if railLine = null then
		app.raiseCMException(Rake_posi_not_found,null,null);				
		return response;
	endif;
	
	wagon :=  app.myPassport.getObjectOfTypeFromOid(request.wagonUid,CM_Wagon).CM_Wagon;
	if wagon = null then
		app.raiseCMException(Wagon_null,null,null);		
		return response;
	endif;
	
	create wagonMoveController transient;
	wagonMoveController.myTargetRailLine := railLine;
	wagonMoveController.isInwardTarget := request.inwards;
	wagonMoveController.targetPosition := request.rakePosition;
	wagonMoveController.allWagons.add(wagon);
	wagonMoveController.swapWagons:=true;
	app.myTrxUA.trxMoveWagons(wagonMoveController, app.myPassport);
	
	if app.myPassport.noErrors then
		create wagonProxy transient;
		wagonProxy.setProxyFromObject(wagon);
		wagonProxy.setProxyLocationCargo();
		response.wagon := wagonProxy;	
	endif;
	
	return response;
epilog

	delete wagonMoveController;

	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_WagonPosUpdRequest"/>
        <ReturnType type="WS_WagonPosUpdResponse"/>
    </JadeMethod>
    <JadeMethod name="putWagonWeights" id="71193445-3a0b-4e1e-a8ce-393d87f1b8b9">
        <updating/>
        <source>putWagonWeights(request : WS_WagonWeightsRequest; wagonOid : String): WS_Response updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 July 2022
TFS#		: 53741
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	response 		: WS_Response;
	wagon			: CM_Wagon;
	pxyWagon		: CM_Wagon;
	loadState 		: Boolean;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	wagonMaster		: CM_WagonMaster;
	pxyWagonMaster	: CM_WagonMaster;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		app.writeLog(method.qualifiedName &amp; " passport has errors", LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	self.setIgnoreWarnings(true);
	
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);	
			
	if app.myPassport.hasErrors then

		return response;
	endif;
	
	wagon:= app.myPassport.getObjectOfTypeFromOid(wagonOid,CM_Wagon).CM_Wagon;	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if wagon = null then
		app.raiseCMException2(ERR_IsNotValid, app.getErrorString(Wagon),'', null,null) ;
		return response;
	endif;
	
	app.cmsBeginLoad(loadState);
	pxyWagon :=	wagon.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	pxyWagon.setMaxCargoWeight(request.maxCargoWeight.Decimal);
	pxyWagon.setTareWeight(request.tareWeight.Decimal);
	
	app.myTrxUA.trxUpdateTrainWagon(pxyWagon,app.myPassport);
	
	return response;
epilog
	app.cmsEndLoad(loadState);
	delete pxyWagon;
	delete pxyWagonMaster;
	
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_WagonWeightsRequest"/>
        <Parameter name="wagonOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="reply" id="323b1ad2-9faf-4dee-a6c2-f5996d5e91a3">
        <source>reply(msg: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2021	jlier1	Initial creation 49429

*/

vars
	result, newResult : String;
	resultSize , i,j: Integer;
begin
	app.writeLog(msg, LogTRACE);
	result:=msg;
	
	i:=result.pos('"',1);
	j:=result.pos("{",1);
	//this is a fudge for when I return a string formated as JSON remove the "" jade puts in to format the string
	if (i &gt; 0 and j &gt;0) and i = j-1 then
		//result:=msg.cnRemoveChars("\");
		result:=JadeRegex@replaceAll(result, "", '\\(?=")', true);
		result:=JadeRegex@replaceAll(result, "\", '\\\\', true);
		resultSize:=result.length;
		i:=result.pos('"',1);
		j:=result.pos("{",1);
		newResult:=result[1:i-1] &amp; result[i+1:end];
		newResult:=newResult[1:newResult.length-1];
		result:=newResult;
	endif;
	
	
	
	inheritMethod(result);

epilog

end;</source>
        <Parameter name="msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupCargoSearchEnquiry" id="c9ea8e8f-753f-4980-909c-6ae0b49f32ca">
        <source>setupCargoSearchEnquiry(qDef : CM_QueryDefinition output;
						startFrom,maxResults  : Integer) : CM_EnqControllerTI protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	jlier1	Initial creation TFS 53022

*/

constants
    QUERY_PARAM_CARGOTYPE = "CargoType";
    QUERY_PARAM_ISOTYPE = "ISOType";
    QUERY_PARAM_AVGRADES = "AVGrades";
    QUERY_PARAM_ID = "ID";
    QUERY_PARAM_SUBTYPE = "SubType";
    QUERY_PARAM_IMEX = "IMEX";
    QUERY_PARAM_OPERATOR = "Operator";
    QUERY_PARAM_SITE = "Site";
    QUERY_PARAM_TATYPE = "TAType";
    QUERY_PARAM_TAREA = "TerminalArea";
    QUERY_PARAM_BOL = "BOL";
    QUERY_PARAM_VOYAGE = "Voyage";
    QUERY_PARAM_DISCHARGEPORT = "DischargePort";
    QUERY_PARAM_BOOKING = "Booking";
    QUERY_PARAM_RELEASEID = "ReleaseID";
    QUERY_PARAM_CONSIGNEE = "Consignee";
	QUERY_PARAM_MARK = "Mark";
	QUERY_PARAM_MARKNUMBER = "MarkNumber";
	QUERY_PARAM_CARGOGROUPID = "CargoGroupID";
vars
	myEnqController : CM_EnqControllerTI;
	criteriaHolder	: CM_QueryCriteriaLineHolder;
	cargoType  : CM_CargoType;
	filterValue : String;
	cargoTypeID : Integer;
	cmifID 			: CMIF_IDConversion;
	isoType 		: CM_ISOType;
	imexCode 		: CM_IMEXStatus;
	product 		: CM_Product;
	operator 		: CM_Operator;
	voyage 			: CM_Voyage;
	terminalArea 	: CM_TerminalArea;
	availGrades		: StringArray;
	avGrades		: IntegerArray;
	avGrade 		: String;
	criteriaLine : CM_SelectorCriteriaLine;
	nvp  : WS_NameValuePair;
	taType : CM_TerminalAreaType;
begin
		app.writeLog(method.name,LogDEBUG);
	if app.logLevel = LogTRACE then
		foreach nvp in self.qsData do
			app.writeLog(nvp.name &amp; " - "  &amp; nvp.value,LogTRACE);
		endforeach;
	endif;


	create myEnqController transient; 
	create myEnqController.allObjects as CM_TIArray transient;			//cnwmc5 - 24 Sep 2014 - PAR 34927
	myEnqController.numItemsFoundLimit := (startFrom -1).max(0) + maxResults;
	create criteriaHolder transient;
	myEnqController.myTerminal := app.myPassport.myTerminal;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	filterValue:=self.qsData.getValue(QUERY_PARAM_CARGOTYPE);
	if filterValue &lt;&gt; null then
		cargoTypeID := filterValue.Integer;
		cargoType:=app.myRoot.allCargoTypesById[cargoTypeID];
	endif;
	
	//iso type
	filterValue:=self.qsData.getValue(QUERY_PARAM_ISOTYPE);
	if filterValue &lt;&gt; null then
		isoType := app.myRoot.allISOTypes[filterValue];
		if isoType &lt;&gt; null then
			cargoTypeID := TI_CargoType_Container;
			cargoType := app.myRoot.allCargoTypesById[ cargoTypeID ];
		endif;
	endif;
		
	filterValue:=self.qsData.getValue(QUERY_PARAM_AVGRADES);
	if filterValue &lt;&gt; null and cargoType = null  then
		cargoTypeID := TI_CargoType_Container;
		cargoType := app.myRoot.allCargoTypesById[ cargoTypeID ];
	endif;
		
	if cargoTypeID = TI_CargoType_Container  then 
		qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,TI_CargoType_Container];
	else	
		qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	endif;
	criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, app.myPassport.myTerminal);
	if criteriaLine &lt;&gt; null then
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	if cargoType &lt;&gt; null then 
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	
	if isoType &lt;&gt; null then	
		criteriaLine:=qDef.createCriteriaLine( CM_Container::isoType.name, CM_QueryOperator.Operator_Equal, isoType);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	

	if self.qsData.first = null then
		app.writeLog( " returning no query params "  ,LogINFO);
		return myEnqController;
	endif;

	//cargo ID
	filterValue:=self.qsData.getValue(QUERY_PARAM_ID);
	if filterValue &lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::id.name, CM_QueryOperator.Operator_StartsOrEndsWith, filterValue);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
		
	
	//cargo type
	if cargoType &lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
		//cargo sub type
		filterValue:=self.qsData.getValue(QUERY_PARAM_SUBTYPE);
		if filterValue &lt;&gt; null then
			product := cargoType.getProductFromCode(filterValue);
			if product &lt;&gt; null then
				criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::myProduct.name, CM_QueryOperator.Operator_Equal, product);
				if criteriaLine &lt;&gt; null then
					criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
				endif;
			endif;
		endif;
	endif;
	
	
	//IMEX
	filterValue:=self.qsData.getValue(QUERY_PARAM_IMEX);
	if filterValue &lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::imexStatus.name, CM_QueryOperator.Operator_Equal, filterValue.Integer);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	//operator
	filterValue:=self.qsData.getValue(QUERY_PARAM_OPERATOR);
	if filterValue &lt;&gt; null then
		operator:=app.myRoot.allOperators[filterValue.trimBlanks];
		if operator &lt;&gt; null then
			criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, operator);
			if criteriaLine &lt;&gt; null then
				criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
			endif;
		endif;
	endif;
	//av grades
	filterValue:=self.qsData.getValue(QUERY_PARAM_AVGRADES);
	if filterValue &lt;&gt; null and cargoTypeID = TI_CargoType_Container then	
		create availGrades transient;
		create avGrades transient;
		filterValue.getTokensForDelimiter(",",availGrades);
		foreach avGrade in availGrades discreteLock do
			if avGrade &lt;&gt; null then
				avGrades.add(avGrade.Integer);
			endif;
		endforeach;
		criteriaLine:=qDef.createCriteriaLine( CM_Container::availabilityGrade.name, CM_QueryOperator.Operator_IsOneOf, avGrades);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;

	//site
	filterValue:=self.qsData.getValue(QUERY_PARAM_SITE);
	if filterValue.Integer &gt; 0 then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, filterValue.Integer);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	//TA Type
	filterValue:=self.qsData.getValue(QUERY_PARAM_TATYPE);
	if filterValue &lt;&gt; null then	
		taType:=app.myRoot.allTerminalAreaTypes[filterValue.Integer];
		if taType &lt;&gt; null then
			criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::getTAType.name, CM_QueryOperator.Operator_Equal, taType);
			if criteriaLine &lt;&gt; null then
				criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
			endif;
		endif;
	endif;
	//Terminal Areas
	filterValue:=self.qsData.getValue(QUERY_PARAM_TAREA);
	if filterValue &lt;&gt; null then	
		terminalArea := myEnqController.myTerminal.allTerminalAreas[filterValue];
		if terminalArea &lt;&gt; null then
			criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::myTerminalArea.name, CM_QueryOperator.Operator_Equal,terminalArea);
			if criteriaLine &lt;&gt; null then
				criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
			endif;
		endif;	
	endif;
	// BOL
	filterValue:=self.qsData.getValue(QUERY_PARAM_BOL);
	if filterValue &lt;&gt; null then	
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::billOfLading.name, CM_QueryOperator.Operator_Equal, filterValue.toUpper);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	// Voyage
	filterValue:=self.qsData.getValue(QUERY_PARAM_VOYAGE);
	if filterValue &lt;&gt; null then
		voyage:=app.myPassport.getObjectOfTypeFromOid(filterValue,CM_Voyage).CM_Voyage;
		//TFS 54103 8/7/22 jlier1
		if voyage = null then
			voyage:= app.myPassport.myTerminal.lookupVoyage(filterValue,null,false);
		endif;
		if voyage &lt;&gt; null then
			criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, voyage);
			if criteriaLine &lt;&gt; null then
				criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
			endif;

		endif;
	endif;
	//discharge port
	filterValue:=self.qsData.getValue(QUERY_PARAM_DISCHARGEPORT);
	if filterValue &lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::dischargePort.name, CM_QueryOperator.Operator_Equal, filterValue);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	//booking ref		
	filterValue:=self.qsData.getValue(QUERY_PARAM_BOOKING);
	if filterValue&lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::bookingReference.name, CM_QueryOperator.Operator_Equal, filterValue.toUpper);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	//release ID
	filterValue:=self.qsData.getValue(QUERY_PARAM_RELEASEID);
	if filterValue&lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::bulkReleaseAssignedCode.name, CM_QueryOperator.Operator_Equal, filterValue);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	//consignee
	filterValue:=self.qsData.getValue(QUERY_PARAM_CONSIGNEE);
	if filterValue &lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::consignee.name, CM_QueryOperator.Operator_Equal, filterValue);	
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	
	//jlier1 TFS 55404 21/11/22
	//mark
	filterValue:=self.qsData.getValue(QUERY_PARAM_MARK);
	if filterValue &lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::mark.name, CM_QueryOperator.Operator_Equal, filterValue);	
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	
	//mark number - jlier1 17/1/22 56087
	filterValue:=self.qsData.getValue(QUERY_PARAM_MARKNUMBER);
	if filterValue &lt;&gt; "" then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::markNumber.name, CM_QueryOperator.Operator_Equal, filterValue);	
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	
	
	//cargo group
	filterValue:=self.qsData.getValue(QUERY_PARAM_CARGOGROUPID);
	if filterValue &lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::getMyCargoGroupId.name, CM_QueryOperator.Operator_Equal, filterValue);	
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	
	return myEnqController;
epilog
	delete cmifID;
	delete availGrades;
	delete avGrades;
end;</source>
        <access>protected</access>
        <Parameter name="qDef" type="CM_QueryDefinition" usage="output"/>
        <Parameter name="startFrom" type="Integer"/>
        <Parameter name="maxResults" type="Integer"/>
        <ReturnType type="CM_EnqControllerTI"/>
    </JadeMethod>
    <JadeMethod name="validateLicense" id="f676f06b-aa51-4562-980f-a330cf1d4459">
        <source>validateLicense(path: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2020	jlgrr1	Initial creation TFS 49227

*/

vars

begin
	// JMT Handheld does not require a separate subscription license
	// root.canDo(PmWebServiceModule) is checked on application start in initJMTRestService
	return true;

epilog

end;</source>
        <Parameter name="path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
