    <JadeMethod name="getOverallLengthString" id="c087d6ed-426a-43d7-bf5d-1453811ca5d6">
        <source>getOverallLengthString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	length : CM_MeasurementType;

begin

	if self.overallLength = 0 then
		return null;
	endif;

	length := app.getDefaultMeasurementForType(Type_Length);
	return app.convertMeasurementForDisplay(length.shortName, self.overallLength) &amp; " " &amp; length.shortName;

