<Class name="CMQF_ExportStiff" id="dcafdd9c-bf62-4cd5-a048-7399c21e7686">
    <superclass name="CMQF_Export"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allStiffRepDetail" id="794ad737-43fe-438c-801a-398d6ae1fbb1">
        <memberTypeInverse/>
        <type name="CMIF_ExportStiffByISODischLoad"/>
        <access>readonly</access>
