<Class name="CMIF_RectangleSegments" id="681bb871-c76b-460e-aa19-ee883ad8f345">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="temp"/>
    <ImplicitInverseRef name="allPolygons" id="5d6c592e-ed28-44ff-9f3d-b75a7cf79097">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="columns" id="af69a0b4-e6aa-46df-8bee-de9823b2878c">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <CompAttribute name="originalPoints" id="9d849434-2ddf-4236-ba84-f5d4df139e21">
        <type name="PointArray"/>
        <access>protected</access>
    </CompAttribute>
    <PrimAttribute name="rows" id="6de7bb04-0bd6-4255-867d-4dc041f7c09d">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="generateAllPolygons" id="9c18fdb6-08fd-4075-97c3-446eb2d85a7e">
        <updating/>
        <source>generateAllPolygons(_colRowPoints : ObjectArray input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theRow, theCol : Integer;
	firstPoints, secondPoints, newPolygon : PointArray;
	 pntX1, pntX2, pntY1, pntY2 : Integer;
	point1, point2, tmpPoint : Point;
	
begin
	self.allPolygons.purge;
	
	// the changes need to be made
	
	foreach theRow in 1 to self.rows do
		
		firstPoints := _colRowPoints[theRow].PointArray;
		secondPoints := _colRowPoints[theRow + 1].PointArray;
		create newPolygon transient; 
		
		// now we need 5 points to make up our mini rectangle polygon
		foreach theCol in 1 to self.columns do
			// ################
			// POINT ONE
			point1 := firstPoints[theCol];
			newPolygon.add(point1);

			// ################
			// POINT TWO
			point1 := firstPoints[theCol + 1];
			newPolygon.add(point1);

			// ################
			// POINT THREE
			point1 := secondPoints[theCol + 1];
			newPolygon.add(point1);

			// ################
			// POINT FOUR
			point1 := secondPoints[theCol];
			newPolygon.add(point1);
			
			// ################
			// POINT FIVE - same as the first point
			point1 := firstPoints[theCol];
			newPolygon.add(point1);
			
			// add each polygon into our collection
			self.allPolygons.add(newPolygon);
		endforeach;
		
		
	endforeach;
epilog
end;</source>
        <Parameter name="_colRowPoints" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="generatePolygons" id="d67efd4c-6e55-423c-8a3c-c734127adfe2">
        <updating/>
        <source>generatePolygons() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theWidth, theHeight, pntX1, pntX2, pntY1, pntY2, idx, tmpX,tmpY : Integer;
	point1, point2, tmpPoint : Point;
	theXs , theYs : IntegerArray;
	theRow, theCol, theSegments  : Integer;
	thePoints, rhPoints, lhPoints, topPoints : PointArray;
	colRowPoints : ObjectArray;
begin

	// work out the points along the right hand side
	theSegments := self.rows;
	create rhPoints transient;
	tmpPoint := self.originalPoints[2];
	pntX1 := tmpPoint.x;
	pntY1 := tmpPoint.y;
	tmpPoint := self.originalPoints[3];
	pntX2 := tmpPoint.x;
	pntY2 := tmpPoint.y;
	self.getPointsOnLine(theSegments,pntX1, pntY1, pntX2, pntY2,rhPoints);

	// work out the points along the left hand side
	create lhPoints transient;
	tmpPoint := self.originalPoints[5];
	pntX1 := tmpPoint.x;
	pntY1 := tmpPoint.y;
	tmpPoint := self.originalPoints[4];
	pntX2 := tmpPoint.x;
	pntY2 := tmpPoint.y;
	self.getPointsOnLine(theSegments,pntX1, pntY1, pntX2, pntY2,lhPoints);
	
	// work our way through the left and right hand points, work out the points along each line
	create colRowPoints transient;
	theSegments := self.columns;
	foreach idx in 1 to lhPoints.size do
		tmpPoint := lhPoints[idx];
		pntX1 := tmpPoint.x;
		pntY1 := tmpPoint.y;
		tmpPoint := rhPoints[idx];
		pntX2 := tmpPoint.x;
		pntY2 := tmpPoint.y;

		create topPoints transient;
		self.getPointsOnLine(theSegments,pntX1, pntY1, pntX2, pntY2,topPoints);
		colRowPoints.add(topPoints);
	endforeach;	

	self.generateAllPolygons(colRowPoints);
	
epilog 
	delete colRowPoints;		// PAR #27874
end;</source>
    </JadeMethod>
    <JadeMethod name="getPointsOnLine" id="f80949c3-f0b5-4c5c-b101-6571f8646beb">
        <source>getPointsOnLine(_theSegments,pntX1, pntY1, pntX2, pntY2 : Integer;_thePoints : PointArray input);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theWidth, theHeight : Real;
	point1, point2, tmpPoint : Point;
	theXs , theYs : IntegerArray;
	 theCol,  idx, tmpX,tmpY : Integer;
begin
	create theXs transient;
	create theYs transient;
	
	// the width/height of each line along the first side
	theWidth := (((pntX2 - pntX1) / (_theSegments)) );
	theHeight := (((pntY2 - pntY1) / (_theSegments)));
	
	// move along the first side and work out each point
	theXs.add(pntX1);
	foreach idx in 1 to _theSegments do
		tmpX := (pntX1 + (theWidth * idx)).Integer;
		theXs.add(tmpX);
	endforeach;

	theYs.add(pntY1);
	foreach idx in 1 to _theSegments do
		tmpY := (pntY1 + (theHeight * idx)).Integer;
		theYs.add(tmpY);
	endforeach;
	
	foreach idx in 1 to _theSegments + 1 do
		tmpPoint.set(theXs[idx],theYs[idx]);
		_thePoints.add(tmpPoint);
	endforeach;	

end;</source>
        <Parameter name="_theSegments" type="Integer"/>
        <Parameter name="pntX1" type="Integer"/>
        <Parameter name="pntY1" type="Integer"/>
        <Parameter name="pntX2" type="Integer"/>
        <Parameter name="pntY2" type="Integer"/>
        <Parameter name="_thePoints" type="PointArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupSegmentor" id="5e689e2a-17d7-452b-be11-d68325e7ae95">
        <updating/>
        <source>setupSegmentor(_rows : Integer; _columns : Integer;_polygon : PointArray) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	self.rows := _rows;
	self.columns := _columns;
	_polygon.copy(self.originalPoints);
end;</source>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_polygon" type="PointArray"/>
    </JadeMethod>
</Class>
