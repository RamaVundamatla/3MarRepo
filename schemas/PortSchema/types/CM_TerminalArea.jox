    <JadeMethod name="setForCreate" id="12fdc39e-c470-4d9d-9689-1e5885eaa9fc">
        <updating/>
        <source>setForCreate(_proxy : CM_TerminalArea input; _passport : CM_Passport input) updating;
//setForCreate(_proxy : CM_TerminalArea; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	11.7.2008 	cnwrd1		par #17515 
// ---------------------------------------------------------------------------
vars
	
begin

	inheritMethod(_proxy, _passport);
	
	self.hideFromOverView 				:= _proxy.hideFromOverView;
	self.autoRestrictionsEnabled 		:= _proxy.autoRestrictionsEnabled;
	self.isEmpty 						:= true;
	self.actAsReleasePoint				:= _proxy.actAsReleasePoint;
	
	// cnwjk3 ccms 1018 18/11/09
	self.leftLabel 						:= _proxy.leftLabel;
	self.rightLabel 					:= _proxy.rightLabel;
	self.topLabel 						:= _proxy.topLabel;
	self.bottomLabel 					:= _proxy.bottomLabel;

	//RTG areas these are transient which are created in setForUpdate looking at the proxy interchange areas
	// need to do this to avoid persistent objects can not reference transient objects exception
	if _proxy.allAssociatedInterchangeAreas.size &gt; 0 and
		not _proxy.allAssociatedInterchangeAreas.first.isTransient then
		_proxy.allAssociatedInterchangeAreas.copy(self.allAssociatedInterchangeAreas);
	endif;
	
	self.myDefaultInterchangeArea:=_proxy.myDefaultInterchangeArea;
	
	self.setDefalutLocationSize();
	
	if self.canBeStockControlled then
		self.isStockControlled := _proxy.isStockControlled;
	endif;
	self.createSwapStack();
	
	_proxy.allCargoBOLTypes.copy(self.allCargoBOLTypes);
//	_proxy.allAllowedMachineTypes.copy(self.allAllowedMachineTypes);

	self.setMyLayoutGraphic(_proxy);
		
	self.setPxyProductMinMax(_proxy);

end;</source>
        <Parameter name="_proxy" type="CM_TerminalArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7e56d343-83d3-46b6-9fe7-25679253c36e">
        <updating/>
        <source>setForUpdate(_proxy : CM_TerminalArea) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	concms1		ccms 1061 - Changed method signature to use proxy rather than controller
// 22/08/2011	cnwdap1		PAR #28047 CCMS POL 2095 Update machines for this terminal area
// ---------------------------------------------------------------------------
vars
	cargoBOLType	: CM_CargoBOLType;
	toDeleteCBTypes	: CM_CargoBOLTypeSet;
	newId			: String;
	attrArea		: CM_AttributeArea;
	machTypes		: CM_MachineTypeSet;

begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	newId := _proxy.id.trimBlanks.toUpper;
	
	if self.id &lt;&gt; newId then
		foreach attrArea in self.allAttributeAreas do
			attrArea.setTerminalAreaId(newId);
		endforeach;
		// 33418 Feb 2014 update anything else from an id change
		self.changeId(newId);
	endif;
	
	self.exclusiveLock(self.allCargoBOLTypes);

	self.comment						:= _proxy.comment;	
	self.autoRestrictionsEnabled 		:= _proxy.autoRestrictionsEnabled;
	self.isEmpty 						:= _proxy.isEmpty;
	self.actAsReleasePoint 				:= _proxy.actAsReleasePoint;
	self.id 							:= newId;
	self.hideFromOverView 				:= _proxy.hideFromOverView;
	
	// cnwjk3 ccms 1018 18/11/09
	self.leftLabel 						:= _proxy.leftLabel;
	self.rightLabel 					:= _proxy.rightLabel;
	self.topLabel 						:= _proxy.topLabel;
	self.bottomLabel 					:= _proxy.bottomLabel;
	
	//RTG areas these are transient which are created in setForUpdate looking at the proxy interchange areas
	// need to do this to avoid persistent objects can not reference transient objects exception
	if _proxy.allAssociatedInterchangeAreas.size &gt; 0 and
		not _proxy.allAssociatedInterchangeAreas.first.isTransient then
		self.allAssociatedInterchangeAreas.clear;
		_proxy.allAssociatedInterchangeAreas.copy(self.allAssociatedInterchangeAreas);
	endif;
	
	
	self.myDefaultInterchangeArea:=_proxy.myDefaultInterchangeArea;
	
	if self.canBeStockControlled then
		self.isStockControlled := _proxy.isStockControlled;
	endif;

	self.setMyLayoutGraphic(_proxy);

	// Efficiently maintain allCargoBOLTypes
	create toDeleteCBTypes transient;
	self.allCargoBOLTypes.copy(toDeleteCBTypes);
	foreach cargoBOLType in _proxy.allCargoBOLTypes do
		if toDeleteCBTypes.includes(cargoBOLType) then
			toDeleteCBTypes.remove(cargoBOLType);
		else
			self.allCargoBOLTypes.add(cargoBOLType);
		endif;
	endforeach;
	foreach cargoBOLType in toDeleteCBTypes do
		self.allCargoBOLTypes.remove(cargoBOLType);
	endforeach;
	
	//Maintain allAllowedMachineTypes
	create machTypes transient;
	self.setMachineTypes(machTypes);
	
	self.setPxyProductMinMax(_proxy);
	
	self.updateMachines(_proxy.allowedMachines);	// PAR #28047
	
	self.setGriddedStackHeights( _proxy );	//08 Sep 2020	NDL	TFS 49984
	
epilog
	delete machTypes;
	delete toDeleteCBTypes;
end;</source>
        <Parameter name="_proxy" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateInUse" id="abdf7777-d293-4d76-ab41-8fd82f3208bd">
        <updating/>
        <source>setForUpdateInUse(pProxy : CM_TerminalArea; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// cnwcs5	21/07/2009	ccms 1061 - change method signature to use procy instead of controller
// cnwddap1	22/08/2011	PAR #28047 CCMS POL 2095 update machines for this terminal area
vars
	handlingType	: CM_HandlingType;
	toDeleteHTypes	: CM_HandlingTypesByIdDict;
	cargoBOLType	: CM_CargoBOLType;
	toDeleteCBTypes	: CM_CargoBOLTypeSet;
	newId			: String;
	attrArea		: CM_AttributeArea;
	machTypes		: CM_MachineTypeSet;
begin
	pProxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	newId := pProxy.id.trimBlanks.toUpper;
	if self.id &lt;&gt; newId then
		foreach attrArea in self.allAttributeAreas do
			attrArea.setTerminalAreaId(newId);
		endforeach;
		// 33418 Feb 2014 update anything else from an id change
		self.changeId(newId);
	endif;
	
	self.exclusiveLock(self.allCargoBOLTypes);

	self.comment						:= pProxy.comment;
	self.actAsReleasePoint 				:= pProxy.actAsReleasePoint;
	self.id 							:= newId;
	self.hideFromOverView 				:= pProxy.hideFromOverView;
	self.autoRestrictionsEnabled 		:= pProxy.autoRestrictionsEnabled;
	self.isEmpty 						:= pProxy.isEmpty;
	
	// cnwer1 ccms 1100 02/02/10
	self.leftLabel 						:= pProxy.leftLabel;
	self.rightLabel 					:= pProxy.rightLabel;
	self.topLabel 						:= pProxy.topLabel;
	self.bottomLabel 					:= pProxy.bottomLabel;
	
	//RTG areas these are transient which are created in setForUpdate looking at the proxy interchange areas
	// need to do this to avoid persistent objects can not reference transient objects exception
	if pProxy.allAssociatedInterchangeAreas.size &gt; 0 and
		not pProxy.allAssociatedInterchangeAreas.first.isTransient then
		self.allAssociatedInterchangeAreas.clear;
		pProxy.allAssociatedInterchangeAreas.copy(self.allAssociatedInterchangeAreas) ;
	endif;
	
	self.myDefaultInterchangeArea:=pProxy.myDefaultInterchangeArea;
	
	if self.canBeStockControlled then
		self.isStockControlled := pProxy.isStockControlled;
	endif;

	self.setMyLayoutGraphic(pProxy);

	// Efficiently maintain allCargoBOLTypes
	create toDeleteCBTypes transient;
	self.allCargoBOLTypes.copy(toDeleteCBTypes);
	foreach cargoBOLType in pProxy.allCargoBOLTypes do
		if toDeleteCBTypes.includes(cargoBOLType) then
			toDeleteCBTypes.remove(cargoBOLType);
		else
			self.allCargoBOLTypes.add(cargoBOLType);
		endif;
	endforeach;
	foreach cargoBOLType in toDeleteCBTypes do
		self.allCargoBOLTypes.remove(cargoBOLType);
	endforeach;
	
	//Maintain allAllowedMachineTypes
	create machTypes transient;
//	pProxy.allAllowedMachineTypes.copy(machTypes);
	self.setMachineTypes(machTypes);
	
	self.updateMachines(pProxy.allowedMachines);		// PAR #28047
	
	self.setGriddedStackHeights( pProxy );	//08 Sep 2020	NDL	TFS 49984
	
epilog
	delete machTypes;
	delete toDeleteHTypes;
	delete toDeleteCBTypes;
end;</source>
        <Parameter name="pProxy" type="CM_TerminalArea"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
