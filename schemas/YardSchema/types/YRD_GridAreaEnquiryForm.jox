    <JadeMethod name="moveTrackedItemSource" id="3be46c5f-fea7-43ec-a6f3-68143dda64c0">
        <updating/>
        <source>moveTrackedItemSource() updating; 
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		NOTE the TI and the Source Location are set in somewhere like frmGridArea_contextMenu on YRD_GridForm
//				NOTE this code is duplicated in CM_ContainerEnqForm
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController = null');
		return;
	endif;
	
	app.myMoveController.moveTrackedItemSource(self.myTerminal);	
		
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="moveTrackedItemsSource" id="553524e6-002a-4156-a3d9-d2b5eb36bcf1">
        <updating/>
        <source>moveTrackedItemsSource(_ydc : YRD_ContainerDrawingController) updating; 
// ---------------------------------------------------------------------------
// Created:		7 September 2005 By Andrew Bishop cnwab1
//
// Purpose:		### BULK LOAD PLAN
//
// ---------------------------------------------------------------------------
vars
	theTIs : CM_TIArray;
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null then
		return;
	endif;
	create theTIs transient;
	_ydc.allSelectedObjects.copy(theTIs);
	
	app.myMoveController.moveTrackedItemsSource(self.myTerminal,theTIs);
	
epilog
	delete theTIs;

	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_ydc" type="YRD_ContainerDrawingController"/>
    </JadeMethod>
    <JadeMethod name="populateGridRows" id="7717fe6d-491b-4779-b9f8-0fda27bafb9e">
        <source>populateGridRows();
// ---------------------------------------------------------------------------
// Created:		13 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
08 Oct 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/

vars
	strArray : StringArray;
	termID, rowID, rowLabel : String;
	stIDX, endIDX, idx, subIDX : Integer;
	
	aTerm : CM_TerminalArea;
	aRow : CM_GridRow;
begin
	self.allGridRows.clear;
	
	if self.rowStr = null then
		return;
	endif;
	
	strArray := self.rowStr.getTokens();
	
	stIDX := 1;
	endIDX := strArray.size;
	
	foreach idx in stIDX to endIDX step 2 do
		termID := strArray[idx];
		rowID := strArray[idx + 1];
		
		aTerm := self.myTerminal.allTerminalAreas[termID];
		if not aTerm.isKindOf(CM_GridArea) then
			continue;
		endif;
		
		aRow := aTerm.CM_GridArea.allGridRowsByLabel[rowID];
		
		self.allGridRows.add(aRow);
		
		if not self.allTerminalAreas.includes(aRow.myGridArea) then
			self.allTerminalAreas.add(aRow.myGridArea);
		endif;
	endforeach;
	
epilog
	delete strArray;		// PAR #18009
	
end;</source>
    </JadeMethod>
