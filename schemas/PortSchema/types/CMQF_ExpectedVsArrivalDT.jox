    <PrimAttribute name="arrivedEarlierThan" id="2ea3b5aa-c8b8-456f-a9b7-9d15f5ba8bd7">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="arrivedLaterThan" id="b5a38ff6-af0c-4ad8-a253-1502399c0cea">
