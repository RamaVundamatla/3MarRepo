    </JadeMethod>
    <JadeMethod name="getAllCalendarsList" id="1ffc993d-8548-4cc2-b4fc-efdcc8b32da7">
        <source>getAllCalendarsList():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

	calendar : CM_Calendar;
	returnStr : String;

begin

	foreach calendar in self.allCalendars do
		if returnStr = null then
			returnStr := calendar.description;
		else
			returnStr := returnStr &amp; CrLf &amp; calendar.description;
		endif;
	endforeach;
	
	return returnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5da8e936-6b98-4552-8f29-eda48c125d74">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2010	cnwndl1	Initial creation

*/

vars

begin
	if _attrName = ETRow_Calendars then
		return self.allCalendars.size.String;
	elseif _attrName = ETRow_CalendarList then
		return self.getAllCalendarsList();
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4520aca9-688f-46ba-8e5c-10f6c8de9bef">
        <updating/>
        <source>setForCreate( pxyDayType : CM_DayType ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation

*/

vars

begin

	pxyDayType.raiseExceptionIfNotTransient(method);
	self.setForUpdate(pxyDayType);
	self.myRoot := app.myRoot;

epilog

end;</source>
        <Parameter name="pxyDayType" type="CM_DayType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="abff839a-51ee-43f9-8463-54ba13f423cb">
        <updating/>
        <source>setForUpdate( pProxyDayType : CM_DayType ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars

begin

	self.code := pProxyDayType.code.trimBlanks;
	self.description := pProxyDayType.description.trimBlanks;

epilog

end;</source>
        <Parameter name="pProxyDayType" type="CM_DayType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="eb27c8c0-e81b-4125-afc8-cf8f66b39177">
        <updating/>
        <source>setProxy(	_code : String;
			_description : String
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars

begin

	self.code := _code[1:10];
	self.description := _description[1:60];

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="9c6c3380-13a7-4d58-8d42-2b26ccc74d0e">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars

begin

	if app.myRoot.allDayTypes[self.code] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="4aaa08bc-1696-4bd9-835b-344134a8befa">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2020	jlgndl1	Initial creation	TFS 50279

*/

vars

	whereUsed : String;

begin

	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="62c9a89a-d5f6-4b69-90fc-42e136a85e60">
        <source>validateForUpdate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation	par 25530

*/

vars

begin

	self.validateMe;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="415b1a86-5579-4109-a8b8-8ee21a3b8692">
        <source>validateMe() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars

begin

	if self.code.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Day Type Code', null, null);
		app.raiseCMException(Input_required_field_dayTypeCd, null, null);
	endif;
	if self.description.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Day type Description', null, null);
		app.raiseCMException(Input_required_field_dyTypDesc, null, null); // cnwdb2	PAR 35364
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
