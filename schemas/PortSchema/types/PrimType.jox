<Class name="PrimType">
    <JadeMethod name="findMethod" id="51a2e952-b387-4342-be20-9001e7497400">
        <source>findMethod(methodName: String): Method;

vars
	meth:	Method;
begin
	meth := methods[methodName];
	if meth = null then
		if _isSubschemaCopy then
			meth := superschemaType.findMethod(methodName);
		endif;
	endif;		

	return meth;
end;</source>
        <Parameter name="methodName" type="String"/>
        <ReturnType type="Method"/>
    </JadeMethod>
    <JadeMethod name="typeConstant" id="e62885b7-912c-46b5-9fc8-4061a7cc745f">
        <source>typeConstant(): Integer;

begin
	return number;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
