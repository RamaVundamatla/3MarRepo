<Class name="CM_AutoTaskRunReports" id="89fa969b-3dca-4ae9-a497-525a6215029c">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Run Reports&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ExplicitInverseRef name="allReportTemplates" id="f3e15008-c7e9-4914-a042-eba99f0fda9c">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_MenuUserReportByNameDict"/>
        <access>readonly</access>
        <Inverse name="CM_MenuUserReport::allAutoTasks"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allReportTemplatesNew" id="34deaee2-3b33-4cec-9b9f-3e52329de290">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_ReportTemplateByNameDict"/>
        <access>readonly</access>
        <Inverse name="CM_ReportTemplate::allAutoTasks"/>
    </ExplicitInverseRef>
    <PrimAttribute name="reportNames" id="9cc65e4d-63db-4f6c-8cc5-c68e65441130">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addReportForConversion" id="bcdb75af-8410-4eb2-ab58-1552e6c19b10">
        <updating/>
        <source>addReportForConversion(_report : CM_MenuUserReport) updating;
// -------------------------------------------
// Created 09 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if not self.allReportTemplates.includes(_report) then
		self.allReportTemplates.add(_report);
	endif;


end;</source>
        <Parameter name="_report" type="CM_MenuUserReport"/>
    </JadeMethod>
    <JadeMethod name="addTemplateFor7_3_1Conversion" id="32a7e9b1-c6e2-4492-ac49-430f980249d9">
        <source>addTemplateFor7_3_1Conversion(_reportTemplate : CM_ReportTemplate);
// -------------------------------------------
// Created 17 January 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if not self.allReportTemplatesNew.includes(_reportTemplate) then
		self.allReportTemplatesNew.add(_reportTemplate);
	endif;


end;</source>
        <Parameter name="_reportTemplate" type="CM_ReportTemplate"/>
    </JadeMethod>
    <JadeMethod name="getEntryTableViewName" id="e6814a7f-9872-489b-ad1d-f9c85d594dca">
        <source>getEntryTableViewName(): String;

// cnwdvb1 20 January 2003 

vars

begin
	return 'bgpAutoViewRunReports';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="e83fac70-5bf9-4c04-94e1-27be5b22fc45">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;

// cnwdvb1 20 January 2003 

vars

begin

	if _rowName = ETRow_BgpAutoReportNames then
//		return self.reportNames;
		return self.allReportTemplatesNew;
	endif;
	
	return inheritMethod(_rowName, _obj);

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="509c3df1-5dfd-4640-96b0-6a230463f9c0">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 09 September 2004 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars

	autoTask : CM_AutoTaskRunReports;
	completedOK		: Boolean;
	
begin

	autoTask := inheritMethod();
	self.allReportTemplatesNew.copy(autoTask.allReportTemplatesNew);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return autoTask;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete autoTask;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeReportTemplate" id="f22c69d4-275d-4ab2-baee-c98e2c63b44e">
        <updating/>
        <source>removeReportTemplate(_reportTemplate : CM_ReportTemplate) updating;
// -------------------------------------------
// Created 16 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.allReportTemplatesNew.includes(_reportTemplate) then
		self.allReportTemplatesNew.remove(_reportTemplate);
	endif;


end;</source>
        <Parameter name="_reportTemplate" type="CM_ReportTemplate"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8f3e99c4-0ed9-49de-967d-ae2ef90d3a8d">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskRunReports) updating;

// cnwdvb1 20 January 2003 

vars

begin

	inheritMethod(_pxyAutoTask);
	self.requestClassName	:= BGP_AutoReportRequests.name;
//	self.reportNames		:= _pxyAutoTask.reportNames;
//	_pxyAutoTask.allReportTemplates.copy(self.allReportTemplates);
	_pxyAutoTask.allReportTemplatesNew.copy(self.allReportTemplatesNew);
	

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskRunReports"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5aef3b4c-d3f4-47be-8f52-c23e0bdceff9">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskRunReports) updating;

// cnwdvb1 20 January 2003 

vars

begin

	inheritMethod(_pxyAutoTask);
//	self.reportNames	:= _pxyAutoTask.reportNames;
//	self.allReportTemplates.clear();
	self.allReportTemplatesNew.clear();
//	_pxyAutoTask.allReportTemplates.copy(self.allReportTemplates);
	_pxyAutoTask.allReportTemplatesNew.copy(self.allReportTemplatesNew);

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskRunReports"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="f8604431-e3c7-41b4-a370-61cae0b90f14">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;

// cnwdvb1 20 January 2003 

vars

begin

	if _rowName = ETRow_BgpAutoReportNames then
		self.allReportTemplatesNew.clear();
		_value.ObjectArray.copy(self.allReportTemplatesNew);
//		self.reportNames := _value.String;
	else
		inheritMethod(_rowName, _value);
	endif;
	

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
