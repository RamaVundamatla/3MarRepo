<Class name="CM_QRefGLCodeMethod" id="caaedce2-818a-464d-a020-49ac281d8071">
    <superclass name="CM_QReferenceMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="f353eda7-a4a9-4aaf-a48f-16514628d4c7">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getGLCodesInPlay" id="8df4940f-09ab-4b21-b101-13ea486f19eb">
        <source>getGLCodesInPlay( _params: CM_QueryCriteriaLineHolder; glCodeObjSet : ObjectSet input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	bankObjSet : ObjectSet;
	obj : Object;
	bank : CM_Bank;
	glCode : CM_GLCode;
	
begin

	//We get GLCodes in play based on the banks in play.
	create bankObjSet  transient;
	self.getBanksInPlay( _params, bankObjSet );
	
	if bankObjSet.isEmpty then
		//nothing to do
		return;
	endif;
	
	//so populate the GLCodes based on the banks found
	foreach obj in bankObjSet do
		bank := obj.CM_Bank;
		foreach glCode in bank.glCodes discreteLock do
			glCodeObjSet.addNoDuplicates( glCode, false );
		endforeach;
	endforeach;

epilog

	delete bankObjSet;

end;</source>
        <access>protected</access>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="glCodeObjSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="1e4a5c52-405e-4ceb-97bc-a6b71adc61f8">
