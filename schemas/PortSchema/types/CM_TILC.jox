    <JadeMethod name="getOnboardQueuedCargo" id="0f5e6fa2-e987-4b6d-b348-249d600d3152">
        <source>getOnboardQueuedCargo(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 08 March 2024
TFS#		: 62840
Function	: Moved from getDisplayStringForAttribute

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	locationController	: CM_LocationsController;
	trackedItem			: CM_TrackedItem;
	tmpStr				: String;
	futureMove 			: CM_FutureMove;
	queuedCargoId		: String;
    failedDAC           : CM_DataAccessController;       //JIRA-34864 
begin
	foreach locationController in self.allLCs do
		foreach futureMove in locationController.allQueuedFutureMoves do
			if futureMove.CM_FutureMoveQueued.myTrackedItem = null then
				continue;
			endif;
			trackedItem := futureMove.CM_FutureMoveQueued.myTrackedItem;
           	if not trackedItem.canUserAccessSelf(null, failedDAC, app.myPassport) then  //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			if tmpStr = null then
				tmpStr := trackedItem.id;
			else
				tmpStr := tmpStr &amp; ', ' &amp; trackedItem.id;
			endif;
			
			if trackedItem.isKindOf( CM_TILC ) then // a stack of trailers
				queuedCargoId := trackedItem.getOnboardQueuedCargo();
				if queuedCargoId &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; queuedCargoId;
				endif;
			endif;
		endforeach;
	endforeach;	
	
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardReefer" id="eb4b245f-247a-4d5a-90f1-13adfa4096be">
        <source>getOnboardReefer(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2023	navmk20	Task 57224: Jade - New MAFI Columns

*/

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	isReefer : Boolean;
	tmpStr: String;
    failedDAC    : CM_DataAccessController;       //JIRA-34864 
begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
            if not ti.canUserAccessSelf(null, failedDAC, app.myPassport) then           //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			isReefer := ti.isReefer;
			if isReefer then
				tmpStr := app.getErrorString(Reefer);
				break;
			endif;
		endforeach;
	endforeach;
	return tmpStr;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardReeferBool" id="39369ca9-f9c8-44aa-a60c-30550374620b">
        <source>getOnboardReeferBool(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 Jan 2025		navcs2	MTN-33832 CUX | Selector queries based on Onboard fields - changes required

*/

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	isReefer : Boolean;
    failedDAC  : CM_DataAccessController;       //JIRA-34864 
begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
            if not ti.canUserAccessSelf(null, failedDAC, app.myPassport) then           //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			isReefer := ti.isReefer;
			if isReefer then
				return true;
			endif;
		endforeach;
	endforeach;
	return false;
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getOnboardSealNumbers" id="997c9e2c-79e5-4e70-9c02-9108bcf38579">
        <source>getOnboardSealNumbers(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
27 November 2023		jlizm1	Initial creation TFS 61271 adding fields for voyage ops live
12 December 2023		jlizm1	TFS 61751 needlessly displaying empty seals

*/

vars
	lc 		: CM_LocationsController;
	ti 		: CM_TrackedItem;
	seals	: String;
	tmpStr 	: String;
    failedDAC    : CM_DataAccessController;       //JIRA-34864 

begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
            if not ti.canUserAccessSelf(null, failedDAC, app.myPassport) then           //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			seals := ti.getAllSealNumbersCSV();
			
			/*
			if tmpStr = null then
				tmpStr := seals;
			elseif seals &lt;&gt; null and tmpStr.pos(seals, 1) = 0 then
				tmpStr := tmpStr &amp; ', ' &amp; seals;
			endif;
			*/
			
			tmpStr.addStringToList(seals, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			if ti.isKindOf( CM_TILC ) then // a stack of trailers
				seals := ti.getOnboardSealNumbers();
				if seals &lt;&gt; null then
					if tmpStr = null then
						tmpStr := seals;
					else
						tmpStr := tmpStr &amp; ', ' &amp; seals;
					endif;
				endif;
			endif;
			
		endforeach;
	endforeach;
	
	return tmpStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardStopsDetails" id="0e033614-02f0-4a5b-ac3b-7d6ef00f16cd">
        <source>getOnboardStopsDetails(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2023	navmk20	Task 57224: Jade - New MAFI Columns
14 Mar 2024	jlika1	TFS 62803 CUX | Onboard cargo - new get methods and additional locations
*/

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	tmpStr, stopsDetails : String;
    failedDAC           : CM_DataAccessController;       //JIRA-34864 
begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
            if not ti.canUserAccessSelf(null, failedDAC, app.myPassport) then           //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			stopsDetails := ti.stopsCode;
			if stopsDetails = null then
				continue;
			endif;
			
			/*
			if tmpStr = null then
				tmpStr := stopsDetails;
			elseif tmpStr.pos(stopsDetails, 1) = 0 then
				tmpStr := tmpStr &amp; ', ' &amp; stopsDetails;
			endif;
			*/
			
			tmpStr.addStringToList(stopsDetails, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			if ti.isKindOf( CM_TILC ) then // a stack of trailers
				stopsDetails := ti.getOnboardStopsDetails();
				if stopsDetails &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; stopsDetails;
				endif;
			endif;
		endforeach;
	endforeach;
	return tmpStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardSubTypes" id="b0d3abea-aa67-4259-8e54-2f1be7ad869c">
        <source>getOnboardSubTypes(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2023	navmk20	Task 57224: Jade - New MAFI Columns
14 Mar 2024	jlika1	TFS 62803 CUX | Onboard cargo - new get methods and additional locations
10 Jun 2024	jlika1	TFS 64524 CUX | Issues on Onboard Cargo Subtype Field in Transaction Enquiry screen
*/

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	tmpStr, subTypes : String;
    failedDAC        : CM_DataAccessController;       //JIRA-34864 
begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
            if not ti.canUserAccessSelf(null, failedDAC, app.myPassport) then           //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			subTypes := ti.getCargoSubTypeCode();
			
			if subTypes &lt;&gt; null then
				concatWithCommaDelimeter(tmpStr, subTypes);
			endif;
			if ti.isKindOf( CM_TILC ) then // a stack of trailers
				subTypes := ti.getOnboardSubTypes();
				if subTypes &lt;&gt; null then
					concatWithCommaDelimeter(tmpStr, subTypes);
				endif;
			endif;
		endforeach;
	endforeach;
	return tmpStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardTemperatures" id="61864316-6709-4857-9253-9f37979f62e7">
        <source>getOnboardTemperatures(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
27 November 2023		jlizm1	Initial creation TFS 61271 adding fields for voyage ops live
15 December 2023		jlizm1	TFS 61777 including null temperatures

*/

vars
	lc 			: CM_LocationsController;
	ti 			: CM_TrackedItem;
	temp		: String;
	returnStr 	: String;
    failedDAC   : CM_DataAccessController;       //JIRA-34864 

begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
            if not ti.canUserAccessSelf(null, failedDAC, app.myPassport) then           //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			temp := ti.getDisplayTemperature(false, not ti.displayTempFahrenheit);
			
			/*
			if temp &lt;&gt; null then
				if returnStr = null then
					returnStr := temp;
				elseif returnStr.pos(temp, 1) = 0 then
					returnStr := returnStr &amp; ', ' &amp; temp;
				endif;
			endif;
			*/
			
			returnStr.addStringToList(temp, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			if ti.isKindOf( CM_TILC ) then // a stack of trailers
				temp := ti.getOnboardTemperatures();
				if temp &lt;&gt; null then
					if returnStr = null then
						returnStr := temp;
					else
						returnStr := returnStr &amp; ', ' &amp; temp;
					endif;
				endif;
			endif;
			
		endforeach;
	endforeach;
	
	return returnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="d36430a7-15af-4b55-8880-6fbba90b0752">
        <source>getPicture(): Binary;
// ---------------------------------------------------------------------------
// Created:		14 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpFrame : Frame;
	tmpForm : Form;
	tmpPic : Binary;
begin

	tmpForm := app.activeForm();
	if tmpForm = null then
		return null;
	endif;

	create tmpFrame transient;
	tmpFrame.visible := true;
	tmpFrame.caption := null;
	tmpFrame.left:= -200;
	tmpFrame.width := 200;
	tmpFrame.height := 80;
	
	tmpForm.addControl(tmpFrame);
	tmpFrame.autoRedraw := true;
	
	if self.myCargoType.myTIBehaviourType &lt;&gt; null then
		self.myCargoType.myTIBehaviourType.myGraphic.drawGraphic(tmpFrame, 1 ,0,0,false,0,true,self.id, self,self.getDefaultColour); // ++ cnwrd1 for par #17201
	endif;
	tmpPic := tmpFrame.createPicture(false,false,24);
	
	return tmpPic;
epilog
	delete tmpFrame;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
