    <JadeMethod name="timerEvent" id="eb81648f-1738-4792-a569-e2875436c1ab">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

/*****************************************************
	Written by	:	cnwpra1		26 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	on Exception do app.defaultExceptionHandler(exception);
	
	if eventTag = 2 then
		myFileManagementDA.removeFile;
		myFileManagementDA.removeFolder;
		
		delete self;
	endif;
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateAbstractData" id="dcdeee5a-714c-4b18-8227-f384a71ad0b6">
        <updating/>
        <source>validateAbstractData(
	topWorksheetName, dataWorksheetName : String) : String updating;

vars
	wasTopSheetFound, wasDataSheetFound : Boolean;
	currentWorksheetNumber, numberOfWorksheets : Integer;
	
	currentSheet : IDispatch;
	currentSheetName : String;

begin

// Initialise data. ==================================================================
	
	self.myWorksheetTopsheet := null;
	self.myChartTopsheet := null;
	self.myWorksheetTopsheet := null;
	
	
// Check the Excel workbook is open already. =================================================

	if self.myExcelApplication = null or self.myExcelApplication.activeWorkbook = null then
		return "The workbook must be opened before validation can begin.";
	endif;
	
	
// Check to see if top and data worksheets are present under the specified names. ==========================

	currentWorksheetNumber := 1;
	numberOfWorksheets := self.myExcelApplication.activeWorkbook.sheets.count;
	
	wasTopSheetFound := false;
	wasDataSheetFound := false;
	
	while currentWorksheetNumber &lt;= numberOfWorksheets do
		currentSheet := self.myExcelApplication.activeWorkbook.sheets.item(currentWorksheetNumber);
		
		if currentSheet.isKindOf(I_Worksheet) then
			currentSheetName := currentSheet.I_Worksheet.name;
		elseif currentSheet.isKindOf(I_Chart) then
			currentSheetName := currentSheet.I_Chart.name;
		endif;
		
		if currentSheetName = topWorksheetName then
			wasTopSheetFound := true;
			
			if currentSheet.isKindOf(I_Worksheet) then
				self.myWorksheetTopsheet := currentSheet.I_Worksheet;
			elseif currentSheet.isKindOf(I_Chart) then
				self.myChartTopsheet := currentSheet.I_Chart;
			endif;
		elseif currentSheetName = dataWorksheetName then
			wasDataSheetFound := true;
			
			if currentSheet.isKindOf(I_Chart) then
				return "The data worksheet " &amp; dataWorksheetName &amp; " must be defined as a Worksheet, not a Chart.";
			else
				self.myDataWorksheet := currentSheet.I_Worksheet;
			endif;
		endif;
		
		if wasTopSheetFound and wasDataSheetFound then
			break;
		endif;
		
		currentWorksheetNumber := currentWorksheetNumber + 1;
	endwhile;

	
	
	if not wasTopSheetFound then
		
		if not wasDataSheetFound then
			return "The workbook does not contain either the top sheet '" &amp; topWorksheetName &amp; "' " &amp; CrLf &amp; 
				"or the data sheet '" &amp; dataWorksheetName &amp; "' that was set for the workbook definition.";
				
		else
			return "The workbook does not contain the top sheet '" &amp; topWorksheetName &amp; "' that was set for the workbook definition";
			
		endif;
		
	elseif not wasDataSheetFound then
		return "The workbook does not contain the data sheet '" &amp; dataWorksheetName &amp; "' that was set for the workbook definition";
		
	endif;
	

// ==========================================================================
	
epilog

end;</source>
        <Parameter name="topWorksheetName" type="String"/>
        <Parameter name="dataWorksheetName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateWorkbookAndDefinition" id="cbdd4b55-8c72-458f-ab14-ae84c29bbc70">
        <updating/>
        <source>validateWorkbookAndDefinition() : Boolean updating;

vars
	errorMessage : String;
	
begin
	errorMessage := self.validateAbstractData(self.myWorkbookDefinition.topWorksheet, self.myWorkbookDefinition.dataWorksheet);
	
	if errorMessage &lt;&gt; "" then
		app.msgBox(errorMessage, "Workbook Error", MsgBox_OK_Only);
		
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
