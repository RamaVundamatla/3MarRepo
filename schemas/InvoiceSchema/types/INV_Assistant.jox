    <JadeMethod name="printCashReceipt" id="bdcc82c0-a7e1-4d19-8a9f-23b755826a3d">
        <source>printCashReceipt(_cashReceipt : CM_CashReceipt; _copies : Integer; _printPreview : Boolean; _jrwReport : JadeReportWriterReport; _printer : String; _title : String;_isProformaPrint : Boolean) ;

// 32498 with cash receipt entry archived, print off the CM_CashReceipt object not from the cash receipt entry details
// from 36704 extend the choice of targets, use CMUI_ChoosePrint instead of a message box
// 07 Mar 2019	cnwma1	Bug 42198: GUQ - Proforma Invoice not Printing
vars
	ioClass		: CM_ExtFinanceIO;
	reportName	: String;
	cashReceipt : CM_CashReceipt;
	isDoha, 
	isGT,
	isGhana		: Boolean;

	theReturn   : Integer;
begin

	ioClass     := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	reportName  := app.myPassport.myTerminal.getConfig(GateCashReceiptReport).String;
	cashReceipt := _cashReceipt;

	isDoha  := app.myRoot.isClientMilaha();
	isGT    := app.myRoot.isClientUmmQasr();
	isGhana := app.myRoot.isClientGhana();

	// TFS 7611 - FOR TESTING
	if app.isSpecial() then
		if  app.msgBox("Print Special Report?","",MsgBox_Yes_No) = MsgBox_Return_Yes then
			isDoha    := false;
			isGT      := false;
			isGhana   := false;
	
	/*  // ### JIRA 36550 07NOV2025 NAVAB1
			// TFS 47847 re worded
			theReturn := app.msgBox("Click YES to print in QTerminals format" &amp; CrLf &amp;  CrLf &amp; 
														"Click NO to print in  Gulftainer forma" &amp; CrLf &amp;  CrLf &amp; 
														"Click CANCEL  to print in Ghana format",
														"CHOOSE AS SPECIAL", MsgBox_Yes_No_Cancel);
			if theReturn = MsgBox_Return_Yes then
				isDoha := true;
			endif;
			if theReturn = MsgBox_Return_No then
				isGT := true;
			endif;
			if theReturn = MsgBox_Return_Cancel then
				isGhana := true;
			endif;
			*/
			theReturn := app.msgBoxCustom("Please choose a cash receipt format", 
														"Selection", 
														MsgBoxCustom_Icon_Question_Mark + MsgBoxCustom_Default_First, 
														"QTerminals", "Gulftainer", "Ghana", "MTN Default");
			if theReturn = MsgBoxCustom_Return_One then
				isDoha := true;
			endif;
			if theReturn = MsgBoxCustom_Return_Two then
				isGT := true;
			endif;
			if theReturn = MsgBoxCustom_Return_Three then
				isGhana := true;
			endif;

		endif;
	endif;
	
	if isDoha then // Milaha Doha port
		self.doPrintCashReceiptQNS(_cashReceipt,_isProformaPrint);
		return;
		
	elseif isGT then // Gulftainer Umm Qasr
		_cashReceipt.doPrintGLT(_isProformaPrint);
		return;
		
	elseif isGhana then
		if reportName &lt;&gt; null then
			self.doPrintCashReceiptGPHA(cashReceipt, false, _isProformaPrint); // TFS 44275 added _isProformaPrint
		else
			cashReceipt.printReceipt(_copies, _printPreview, _jrwReport, reportName, _printer,_isProformaPrint) ;
		endif;
		return;
	endif;
	
	//Everybody else
	if reportName &lt;&gt; null then
		self.doPrintCashReceiptJRW(cashReceipt, _title, false);
	else
		cashReceipt.printReceipt(_copies, _printPreview, _jrwReport, reportName, _printer,_isProformaPrint) ;
	endif;

epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_copies" type="Integer"/>
        <Parameter name="_printPreview" type="Boolean"/>
        <Parameter name="_jrwReport" type="JadeReportWriterReport"/>
        <Parameter name="_printer" type="String"/>
        <Parameter name="_title" type="String"/>
        <Parameter name="_isProformaPrint" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCargoSearchForm" id="441bd9d0-9848-409e-9c87-fb7af1654a3b">
        <source>showCargoSearchForm(_parent			: CM_BaseForm;
					_mts			: Boolean; 
					_allSelectedTIs : CM_TIArray;
					_bItem			: CM_BookingRefItem;
					_reserveItem	: CM_ReserveDetail; 
					_cargoType		: CM_CargoType;
					_voyage			: CM_Voyage;
					_bol			: CM_BOL;
					_contextObject  : CM_Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2019	jlgzm1	Initial creation TFS 46054 STWO Adding Extra Details to Manual Invoice Lines
13 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
17 Apr 2023 navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
*/

vars
	form : INV_CargoSearchForm;
begin
	form := app.loadForm(INV_CargoSearchForm, 
							INV_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							null).INV_CargoSearchForm;	
	
	if form = null then
		return; //Was causing 1090s
	endif;
	
	form.setColumnsAndControlWidth(3, 175);
	form.setParentForm(_parent);
	form.setMTs(_mts);
	form.setSelectedTIs(_allSelectedTIs);
	
	form.setCargoType(_cargoType);
	form.setMyBookingItem(_bItem);
	form.setMyReserveDetail(_reserveItem);
	form.setContextSearchObject(_contextObject);				//13.03.2023 navma1 #56457:[56458]
	
	form.show;
epilog

end;</source>
        <Parameter name="_parent" type="CM_BaseForm"/>
        <Parameter name="_mts" type="Boolean"/>
        <Parameter name="_allSelectedTIs" type="CM_TIArray"/>
        <Parameter name="_bItem" type="CM_BookingRefItem"/>
        <Parameter name="_reserveItem" type="CM_ReserveDetail"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_contextObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showCompanyStructureForm" id="d4b8f418-57f8-4429-bf75-0b0476a25946">
        <source>showCompanyStructureForm(_object : CM_Object; _masterMenuAction : CMUI_MenuAction);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	invoiceForm : INV_CompanyStructure;
	menuAction : CMUI_MenuAction;
begin
	
	menuAction := app.myController.createMenuAction(PmAdmInvoicelistView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	invoiceForm := menuAction.goToObject(null, null, false, null).INV_CompanyStructure;
	if invoiceForm = null then
		return;
	endif;
	invoiceForm.show(); 

end;</source>
