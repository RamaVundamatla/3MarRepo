    <JadeMethod name="loadDB" id="df0942d5-93bc-4bc6-95e2-8ea5849380e0">
        <updating/>
        <source>loadDB(mergeCargo : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	14 October 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	Messina 1008 PAR 20320 
// ---------------------------------------------------------------------------
// 18/06/2012	cnwcs5	par 29747 - refactor into trx
vars
	
begin
//	return; //For release 7.7.3 Ship Manifests will not be loaded into the database. 
	// Tracked items are loaded via Bayplans PAR 20808 cnwgb1 28.10.09
	// Arm our base exception handlers
	on Exception do validationExceptionHandler( exception, _passport );
	
	app.setContinueCMExceptions( false );
	
	app.myTrxUA.trxProcessEDIBOLConsist(self, false, _passport);
epilog
	
end;</source>
        <Parameter name="mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="799f42bb-dc87-46b1-8966-37b9710a4c04">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//
// 11 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	propName : String;
begin
	if _property = null then
		return false;
	endif;
	propName := _property.name;
	if propName = CM_EDIDataBOL::currentBOLItemCode.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="8fd57bc3-2f0e-43c3-a4d4-bece571782b4">
