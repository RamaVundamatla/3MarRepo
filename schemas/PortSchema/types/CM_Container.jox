    <JadeMethod name="getHeightOfTI" id="e4e4d88b-4c7e-418c-95e1-f552736d6cec">
        <source>getHeightOfTI(): Integer;
/*
 ------------------------------------------------------------------------
Created:			05 October 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if 	self.sizeAttributes.bitAnd(ISO_HALF_HEIGHT) &lt;&gt; 0 or 
		self.sizeAttributes.bitAnd(ISO_HEIGHT_4) &lt;&gt; 0 or 		// 25/11/2025 	navkc1	JIRA MTN 36254
		self.sizeAttributes.bitAnd(ISO_HEIGHT_43) &lt;&gt; 0			// 25/11/2025 	navkc1	JIRA MTN 36254
		then
		return  Ti_Half_Height;	//Half height
	else
		return Ti_Full_Height;	//Full height
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
