        <source>getCargoGroupSpecialLift(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 August 2024	NAVBK1	Bug 65600: FR | 53813 - VAS Mobile App - FR issues (part 2)

*/

vars
	ti			: CM_TrackedItem;
	specialLift : CM_SpecialLift;
	strArr		: StringArray;
begin
	create strArr transient;
	foreach ti in self.allAssignedTrackedItems do
		foreach specialLift in ti.allSpecialLifts do
			if not strArr.includes(specialLift.description) then
				strArr.add(specialLift.description);
			endif;
		endforeach;
	endforeach;
	return strArr.concatenate(Comma);
epilog
	delete strArr;
end;</source>
