    <JadeMethod name="progressEnd" id="341c2790-b4e5-4284-885e-69e3eeb7a2da">
        <updating/>
        <source>progressEnd() updating;
// --------------------------------------------------------------------------------
// Created:		19 July 2002 by cnwdad1
//
// Purpose:		Unloads the progress form and deletes it.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myProgressForm.unload();
	delete self.myProgressForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="progressStart" id="b95305d2-e69b-4ff9-b304-b29d7e1272dc">
        <updating/>
        <source>progressStart(pSource:String; pTarget:String; pCopying:String; pParts:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		19 July 2002 by cnwdad1
//
// Purpose:		Creates and initializes the progress form.
//
// Parameters:	pSource - The file/directory being copied.
//				pTarget - The destination for the file/directory.
//				pCopying - The name of the file being copied.
//				pParts - The number of parts in the process.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProgressForm	: JSSFMProgressForm;
	
begin
	create theProgressForm;
	theProgressForm.startProgress(pSource, pTarget, pCopying, pParts);
	self.myProgressForm	:=	theProgressForm;
	theProgressForm.show();
	theProgressForm.refreshNow();
end;</source>
        <Parameter name="pSource" type="String"/>
        <Parameter name="pTarget" type="String"/>
        <Parameter name="pCopying" type="String"/>
        <Parameter name="pParts" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="readDiskFile" id="486fcc12-57f4-48c9-a81a-9e67048ed6b5">
        <updating/>
        <source>readDiskFile(pDiskFileObj:File; pIsCompressionUsed:Boolean; pOffset:Decimal io):Binary updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Purpose:		Reads a pre-set-size chunk of data from the specified file, starting
//				from the specified position (offset).  If the remainder of the file
//				(from the offset) is smaller than the pre-set size, then only return
//				the remainder of the file data.
//
// Parameters:	pDiskFileObj - The file to read the data from.
//				pIsCompressionUsed - If true, the the binary data will be
//					compressed before it is returned to the caller.
//				pOffset - The file position to start reading from.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileLength	: Decimal[23];
// cnwdad1 01/06/2004 - this will need to be changed to Decimal whenever the Plant
// provide a "readBinary" method that will accept decimal values.
	dataLength	: Decimal[23];
	fileData	: Binary;
	
begin
	fileLength	:=	pDiskFileObj.fileLengthDec();
	dataLength	:=	self.fileChunkSize;
	
	if pOffset &lt;= fileLength then
		if (fileLength - pOffset) &lt; dataLength then
			dataLength	:=	(fileLength - pOffset).Integer;
		endif;
		
		pDiskFileObj.seekDec(pOffset);
// cnwdad1 01/06/2004 - the casting to Integer this will need to be remove whenever the Plant
// provide a "readBinary" method that will accept a decimal value.
		fileData	:=	pDiskFileObj.readBinary(dataLength.Integer);
		pOffset		:=	pOffset + fileData.length;
		
		if pIsCompressionUsed then
// cnwdad1 25/02/2009.
//			fileData	:=	fileData.compress();
			fileData	:=	fileData.compressToBinary(Binary.Compression_ZLib);
		endif;
		
//		if pDiskFileObj.errorCode() &lt;&gt; 0 then
//			self.doFileErrorSet(pDiskFileObj.errorCode(), pDiskFileObj.fileName);
//		endif;
		
		return fileData;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pDiskFileObj" type="File"/>
        <Parameter name="pIsCompressionUsed" type="Boolean"/>
        <Parameter name="pOffset" type="Decimal" usage="io"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
