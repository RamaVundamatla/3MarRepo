end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultRetrospectiveTS" id="03b36471-d93f-433a-bb02-8a14c4d4d7ae">
        <source>setDefaultRetrospectiveTS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2021	navndl1	Initial creation	TFS 51199

*/

vars

	showEffectiveDate : Boolean;
	now : TimeStamp;
	retrospectiveDate : TimeStamp;

begin

	now := app.actualTimeServer;
	showEffectiveDate := self.cbRetrospective.value;

	self.lblEffectiveDate.visible := showEffectiveDate;
	self.txtDateBox.visible := showEffectiveDate;
	self.lblEffectiveTime.visible := showEffectiveDate;
	self.txtEffectiveTime.visible := showEffectiveDate;
	
	self.txtDateBox.enabled := true;
	self.txtEffectiveTime.enabled := true;
	
	retrospectiveDate := app.actualTimeAppServer;

	if showEffectiveDate then
		
		if self.myTerminal.getConfig(VoyageRetroDefault).Boolean
		and self.myCurrentVoyage &lt;&gt; null
		and self.myCurrentVoyage.shipExchangeCompleteDT.date.isValid
		and self.myCurrentVoyage.shipExchangeCompleteDT &lt;= now
		then
			//They are using the Ship Exchange Date - new functionality driven by new config
			retrospectiveDate := self.systemToLocalTime( self.myCurrentVoyage.shipExchangeCompleteDT );
			self.txtDateBox.enabled := false;
			self.txtEffectiveTime.enabled := false;
		
		
		elseif self.myCurrentVoyage &lt;&gt; null
		and self.myCurrentVoyage.nonPlannedEffectiveDT.date.isValid
		then
			//They are using the NON Planned Effective Date - pre-existing behaviour
			retrospectiveDate := self.systemToLocalTime( self.myCurrentVoyage.nonPlannedEffectiveDT );
			
		endif;
	
	endif;
	
	self.txtDateBox.setDate( retrospectiveDate.date );
	self.txtEffectiveTime.setTime( retrospectiveDate.time );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDisplayMode" id="9d205ef7-099b-4f54-a21e-2c97f26fffda">
        <updating/>
        <source>setDisplayMode(_mode: Integer) updating;
 
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
 
Date		Who		Reason
19 November 2009	cnwndl1	Initial creation	CCMS 1031
17/08/2011			cnwmh5	#27707 - Add updating of status bar
28/11/2022			navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
08/12/2022			navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
24/02/2024 			navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
29 Oct 2025 		navhl20 Bug MTN-36438: MTN - Modes no longer work in Voyage Operations
14 Jan 2026 		navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/
 
vars
	localFrame 	: CMUI_Frame;
begin
	localFrame := self.myActiveDisplayMenuFrame;
	self.myActiveDisplayMenuFrame := null;
	if localFrame &lt;&gt; null then
		if _mode &lt;&gt; getDisplayModeForFrame( localFrame ) then
			self.setTableDisplayMode( localFrame,  _mode);
			self.showTableDisplayMode( localFrame );
			//30 Jun 2010	NDL	Par 24602
			if localFrame = self.frmDispOnsite then
				self.loadOnsiteTable(null, true);	// 08/12/2022	navkc1	#55409
				self.tblOnsite.doClearFilters( true );
			elseif localFrame = self.frmDispOffsite then
				self.loadOffsiteTable(null, true); // 08/12/2022	navkc1	#55409
				self.tblOffsite.doClearFilters( true );
			elseif localFrame = self.frmDispOnship then
				self.loadOnShipTable(null, true); // 08/12/2022	navkc1	#55409
				self.tblOnship.doClearFilters( true );
			elseif localFrame = self.frmDispPreNote then
				self.loadPreNoteTable(null, true); // 08/12/2022	navkc1	#55409
				self.tblPreNote.doClearFilters( true );
			else
				self.doRefresh;
			endif;
			//self.doRefresh;
		endif;
	else
		if self.displayMode &lt;&gt; _mode then
			self.displayMode := _mode;
			self.stbGeneral.displayMode := _mode;
			self.doRefresh;
		endif;
	endif;
	self.stbGeneral.myFrameDisplayMode.enabled := false;
	self.stbGeneral.myFrameDisplayMode.clearGraphics;
 
	//self.updateStatusBarCounts();					// 17/08/2011 cnwmh5 #27707
	self.updateStatusBarCounts(true, null);		 // 28/10/2022	navkc1	#55408
epilog
	
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="fded34fd-848d-4c98-852a-ba9216c0505b">
        <updating/>
        <source>setEnableObjects(_table : CM_DataTable input) updating;
//--------------------------------------------------
// Created:	21 October 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 05/01/2015	cnwdap1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation
vars

begin
	self.btnCustomsEDI.visible := true;
	self.btnImportTasks.visible := true;

	if _table = self.tblOffsite then
		self.btnDeleteCargo.enabled := false;
		self.btnDischarge.enabled := false;
		//self.btnLoad.enabled := true;						// PAR #35397
		//self.btnLoad.userObject := _table;				// PAR #35397
		self.btnLoad.enabled := false;						// PAR #35397
		self.btnLoad.userObject := null;					// PAR #35397
		self.btnCustomsEDI.enabled := false;
		self.btnImportTasks.enabled := false;
	elseif _table = self.tblOnsite then
		self.btnDeleteCargo.enabled := false;
		self.btnDischarge.enabled := false;
		self.btnLoad.enabled := true;
		self.btnLoad.userObject := _table;		
		self.btnCustomsEDI.enabled := false;
		self.btnImportTasks.enabled := false;
	elseif _table = self.tblOnship then
		if self.myCurrentTrackedItem &lt;&gt; null
		and (not self.myCurrentTrackedItem.getReceiveDate().isValid) then
			self.btnDeleteCargo.enabled := true;
		else
			self.btnDeleteCargo.enabled := false;
		endif;	
		self.btnDischarge.enabled := true;
		self.btnLoad.enabled := false;
		self.btnLoad.userObject := null;		
		self.btnCustomsEDI.enabled := true;
		self.btnImportTasks.enabled := true;
	elseif _table = self.tblPreNote then					// PAR #35397
		self.btnDeleteCargo.enabled := true;				// PAR #35397
		self.btnDischarge.enabled := false;					// PAR #35397
		if self.moveModeForm = PLANNING_MODE then			// PAR #35397
			self.btnLoad.enabled := true;					// PAR #35397
			self.btnLoad.userObject := _table;				// PAR #35397
		else												// PAR #35397
			self.btnLoad.enabled := false;					// PAR #35397
			self.btnLoad.userObject := null;				// PAR #35397
		endif;												// PAR #35397
		self.btnCustomsEDI.enabled := false;				// PAR #35397
		self.btnImportTasks.enabled := false;				// PAR #35397
		if self.moveModeForm = PLANNING_MODE then			// PAR #35397
			self.btnLoad.enabled := true;					// PAR #35397
		endif;												// PAR #35397
	else
		self.btnDeleteCargo.enabled := false;
		self.btnCustomsEDI.enabled := false;
		self.btnImportTasks.enabled := false;
		self.btnDischarge.enabled := false;
		self.btnLoad.enabled := false;
		self.btnLoad.userObject := null;			
	endif;
	
	// enable / disable voyage-related toolbar buttons
	self.enableVoyageButtons();
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDeleteCargo.enabled := false;
		self.btnCustomsEDI.enabled := false;
		self.btnImportTasks.enabled := false;
		self.btnDischarge.enabled := false;
		self.btnLoad.enabled := false;
		self.btnAlloc.enabled:= false;

	endif;
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMoveMode" id="20530b58-d15f-4257-8b77-c91d5c930a8b">
        <updating/>
        <source>setMoveMode(_mode: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/01/2015	cnwdap1		Initial creation PAR #35397 CCM SSFW 1394 Voyage Rationalisation
//
vars
	actual, plan, queue	: String;
	discharge, load		: String;

begin
	inheritMethod(_mode);
	
	actual := app.getErrorString(Actual);
	plan := app.getErrorString(Planned);
	queue := app.getErrorString(Queued);
	discharge := app.getErrorString(Discharge);
	load := app.getErrorString(Load);
	if self.moveModeForm = REAL_MODE then
		self.btnDischarge.bubbleHelp := actual &amp; Space &amp; discharge &amp; " (Alt-D)";
		self.btnLoad.bubbleHelp := actual &amp; Space &amp; load &amp; " (Alt-L)";
	elseif self.moveModeForm = PLANNING_MODE then
		self.btnDischarge.bubbleHelp := plan &amp; Space &amp; discharge &amp; " (Alt-D)";
		self.btnLoad.bubbleHelp := plan &amp; Space &amp; load &amp; " (Alt-L)";
	elseif self.moveModeForm = QUEUE_MODE then
		self.btnDischarge.bubbleHelp := queue &amp; Space &amp; discharge &amp; " (Alt-D)";
		self.btnLoad.bubbleHelp := queue &amp; Space &amp; load &amp; " (Alt-L)";
	endif;
	
	// disable Load button if current table context is prenote table, and move mode is not Planned
	if self.moveModeForm &lt;&gt; PLANNING_MODE and self.myCurrentContextTbl = self.tblPreNote then
		self.btnLoad.enabled := false;
	elseif self.moveModeForm = PLANNING_MODE and self.myCurrentContextTbl = self.tblPreNote then
		self.btnLoad.enabled := true;
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="e8f71e6b-a243-4975-9f4f-9576679c26a7">
        <updating/>
        <source>setMyCurrentVoyage(_voyage : CM_Voyage)updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 10 May 2022  navlw1		TFS 53330 Changed Request for Change Barge Vessel 
vars
	str : String;
	vess : CM_Vessel;
	edLocal: TimeStamp;
begin

	//15 Mar 2021	NDL	TFS 50935  and out again 15 Apr 2021
//	if self.myCurrentVoyage &lt;&gt; null then
//		self.endNotification( self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_TI_Voyage_Chg) );
//	endif;

	// 10 May 2022 navlw1 TFS 53330
	if self.myCurrentVoyage &lt;&gt; null then
		if self.myCurrentVoyage.isBarge then
			self.endNotification( self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_BARGEVESSELCHANGE) );
		endif;
	endif;

	self.myCurrentVoyage := _voyage;
			   
	self.mnuGeneralCargo.visible := true;
	str := self.baseCaption;	
	if self.myCurrentVoyage = null then
		self.tblOffsite.rows := self.tblOffsite.fixedRows;
		self.tblOnsite.rows := self.tblOffsite.fixedRows;
		self.tblOnship.rows := self.tblOffsite.fixedRows;

		self.lblOffsiteCount.caption := null;
		self.lblOnshipCount.caption := null;
		self.lblOnsiteCount.caption := null;
	
		self.cbRetrospective.value := false;
//		self.txtDateBox.setDate(null);		
//		self.txtEffectiveTime.setTime(null);
//		self.cbRetrospective.value := false;						
	else
		if self.myCurrentVoyage.isBarge then
			self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_BARGEVESSELCHANGE), Response_Continuous , null);
		endif;
		
		// 10 May navlw tfs 53330
		str := getCaption(str);
		
		// commented out as been replace with the above method
		/*vess := self.myCurrentVoyage.getMyVessel();
		if vess &lt;&gt; null then
			str :=str &amp; " " &amp; vess.structureTypeString;
		endif;
		
		str := str &amp; " " &amp; self.myCurrentVoyage.getId.trimBlanks;  //epr TFS 2362 4/8/16
		*/
		
//		edLocal := self.systemToLocalTime(self.myCurrentVoyage.nonPlannedEffectiveDT);	// 10/5/16 cnwmp6 TFS 488 - Multi timezone support
//		self.txtDateBox.setDate(edLocal.date);		
//		self.txtEffectiveTime.setTime(edLocal.time);	
//		self.cbRetrospective.value := txtDateBox.getDate().isValid;

		//17 May 2021	NDL	TFS 51199
		if self.myCurrentVoyage.nonPlannedEffectiveDT.isValid
		or self.myTerminal.getConfig(VoyageRetroDefault).Boolean and self.myCurrentVoyage.shipExchangeCompleteDT.isValid then
			self.cbRetrospective.value := true;
		else
			self.cbRetrospective.value := false; //25.Aug.2023 navsp1 TFS 59919
		endif;
					
	endif;
	
	self.doRetrospectiveClick();
	
	self.setCaption(str); //epr TFS 2362 4/8/16
	self.setNavigatorHeading(str);
	
	//cnwjo3 par 23105
	if self.myCurrentVoyage &lt;&gt; null then
		app.setMyCurrentVoyage(self.myCurrentVoyage);
	endif;
	self.buildLoadToCombo();
	self.buildTransferTypeCombo();	//12 Mar 2018	NDL	TFS 37444
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setOffsitePanelVisibility" id="ff673e9c-76ac-4a5e-8bb2-2738bf5454e7">
        <updating/>
        <source>setOffsitePanelVisibility( _value : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2013	cnwndl1	Initial creation	Par 32152

*/
vars

begin
	self.dkcOffSite.visible := _value;
	self.doResize;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPreNotePanelVisibility" id="8a0cbb63-9e25-4ef3-81d5-5796b4c472cf">
        <updating/>
        <source>setPreNotePanelVisibility(_value : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars
	control : Control;
	idx : Integer;
	controls : CMUI_ControlArray;
	totalDim : Real;

begin
	self.dkcPreNotes.visible := _value;
	// see what container the prenotes table is part of, and how many other controls are also in that container
/*	create controls transient;
	foreach idx in 1 to self.controlCount do
		control := self.controls(idx);
		if control.parent = self.dkcPreNotes.parent then
			controls.add(control);
			totalDim := totalDim + control.height;
		endif;
	endforeach;
	// now divide the total dimension we have to play with by (nbr of controls in parent) + 1 (for the prenote table)
	if totalDim = 0 then
		// prenote container's parent is not visible - bit more work to do
	totalDim := totalDim / (controls.size + 1);
	
	// set the width / height of the prenote table according to what display mode the screen is in
	if self.btnVertical.value then
		foreach control in controls do
			control.width := totalDim;
		endforeach;
		self.dkcPreNotes.width := totalDim;
	elseif self.btnHorizontal.value then
		foreach control in controls do
			control.height := totalDim;
		endforeach;
		self.dkcPreNotes.height := totalDim;
	endif;
*/	
	self.doResize;
	
epilog
	delete controls;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="bedeb9fa-8935-4370-b83c-935ba9619013">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------------------
//Created: 21 October 2003 By: cnwgd1
// 28/11/2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
// 08/12/2022	navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
//--------------------------------------------------------------
vars

	msg : String;
	cmifMonitor : CMIF_Monitor;
begin
	on Exception do self.handleInterruptExceptions(exception);
	
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;

	//09 Mar 2021	NDL	TFS 50796
	//if self.performECO or ( self.performHybrid and not self.performAllowMore20 ) then
	if not self.performAllowMore20 then //30/07/2025	navkc1 JIRA MTN 35478
		if _theTable.columns &gt; 20 then
			msg := _theTable.columns.String &amp; " Columns selected!" &amp; CrLf;
			
			msg := msg &amp; "Press No - to re-open the Column Organiser." &amp; CrLf;
			msg := msg &amp; "Press Yes - to have MTN automatically truncate the number of displayed columns to 20.";
			if app.msgBox( msg, app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon ) = MsgBox_Return_Yes then
				_theTable.resetColumnsToMaxOf(20);
			else
				self.showColumnOrganiser( _theTable );
				return;
			endif;
		endif;
	endif;
	
	app.mousePointer := self.MousePointer_HourGlass;
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Reloading Table',  'Please Wait....');
	
	if _theTable = self.tblOffsite then
		self.loadOffsiteTable(null, true); 	// 08/12/2022	navkc1	#55409
	elseif _theTable = self.tblOnship then
		self.loadOnShipTable(null, true); 	// 08/12/2022	navkc1	#55409
	elseif _theTable = self.tblOnsite then
		self.loadOnsiteTable(null, true); 	// 08/12/2022	navkc1	#55409
	elseif _theTable = self.tblPreNote then
		self.loadPreNoteTable(null, true); 	// 08/12/2022	navkc1	#55409
	endif;
	
	//updateStatusBarCounts();	//30 Jun 2010	NDL Par 24603
	updateStatusBarCounts(true, null);	 // 28/10/2022	navkc1	#55408
epilog
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	app.mousePointer := self.MousePointer_Default;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDisplayMode" id="fce026f9-da91-45f5-a31b-06db983b4bed">
        <updating/>
        <source>setTableDisplayMode(_dispFrame : Frame; _displayMode : Integer) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars
	displayValue : Integer;
	
begin

	if _displayMode = DISPLAY_MODE_PLAN then
		displayValue := DISPLAY_MODE_PLAN;
	elseif _displayMode = DISPLAY_MODE_QUEUE then
		displayValue := DISPLAY_MODE_QUEUE;
	else
		displayValue := DISPLAY_MODE_ACTUAL;
	endif;
	
	if _dispFrame = self.frmDispOffsite then
		self.displayModeOffSite := displayValue;
	elseif _dispFrame = frmDispOnship then
		self.displayModeOnShip := displayValue;
	elseif _dispFrame = frmDispOnsite then
		self.displayModeOnSite := displayValue;
	elseif _dispFrame = frmDispPreNote then
		self.displayModePreNote := displayValue;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dispFrame" type="Frame"/>
        <Parameter name="_displayMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTableHeadings" id="71eacc7d-79b4-4a4b-b50a-8f0c57d302ca">
        <updating/>
        <source>setTableHeadings(_table : CM_DataTable input)updating;
//-----------------------------------------
//Created: 17 October 2003 By: cnwgd1
//-----------------------------------------
// 13/02/2009 cnwsh3 CCMS SFW 1039 PAR18889 - Changed to enable a greater number of fields to be visible on form.
vars
	theDef 	: EntTableDef;
begin
	if _table = null then
		return;
	endif;
	
	//theDef := app.myController.getEntTableDef(ETDef_NonPlannedVoyageOps);
	theDef := app.myController.getEntTableDef(ETDef_LlHeadings);	//CCMS1039
	
	_table.setTblDataEntRowsFromDef(theDef);
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableParentsFromXML" id="01228e97-4f01-4605-bd84-d493f7f1c1e4">
        <updating/>
        <source>setTableParentsFromXML(_userWindow: CM_UserWindow) updating;
//
// Purpose:			// PAR 37202
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
//
vars
	tmpTypeStr	: String;
	test : Boolean;
	str : String;
	count : Integer;
	layout : Integer;
	tableDetails : StringArray;

begin
	if _userWindow = null then
		return;
	endif;
	
	create tableDetails transient;

	
	// position and reparent if necessary the individual table dock containers
	// On Ship dock container
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_TagTablePosition &amp; self.dkcOnShip.name);
	if tmpTypeStr &lt;&gt; null then
		tmpTypeStr.getTokensForDelimiter(Comma, tableDetails);
		self.dkcOnShip.parent := self.getControlByName(tableDetails[1]);
	endif;
	tableDetails.clear;
	// On Terminal dock container
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_TagTablePosition &amp; self.dkcOnTerminal.name);
	if tmpTypeStr &lt;&gt; null then
		tmpTypeStr.getTokensForDelimiter(Comma, tableDetails);
		self.dkcOnTerminal.parent := self.getControlByName(tableDetails[1]);
	endif;
	tableDetails.clear;
	// Off Site dock container
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_TagTablePosition &amp; self.dkcOffSite.name);
	if tmpTypeStr &lt;&gt; null then
		tmpTypeStr.getTokensForDelimiter(Comma, tableDetails);
		self.dkcOffSite.parent := self.getControlByName(tableDetails[1]);
	endif;
	tableDetails.clear;
	// Pre Notes dock container
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_TagTablePosition &amp; self.dkcPreNotes.name);
	if tmpTypeStr &lt;&gt; null then
		tmpTypeStr.getTokensForDelimiter(Comma, tableDetails);
		self.dkcPreNotes.parent := self.getControlByName(tableDetails[1]);
	endif;
	tableDetails.clear;
epilog
	delete tableDetails;
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="setTablePositionsFromXML" id="71f4d454-51fd-44c4-bbdc-58074a7b6c9a">
        <updating/>
        <source>setTablePositionsFromXML(_userWindow: CM_UserWindow) updating;
//
// Purpose:			// PAR 37202
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
// 14/06/2016	cnwjre1		TFS 2136 screen settings not retained after forms has been maximised
//
vars
	formHeight,
	formWidth : Real;
	x1, x2,
	y1, y2,
	w1, w2,
	h1, h2	: Real;
	newW1, newW2	: Real;
	tmpTypeStr	: String;
	tableDetails : StringArray;

begin
	if _userWindow = null then
		return;
	endif;
	
	formHeight := self.height - self.dkcMain.top;
	formWidth := self.width;
	create tableDetails transient;
	// position the parent dock containers - "top" and "bottom"
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_TagTablePosition &amp; self.dkcTop.name);
	if tmpTypeStr &lt;&gt; null then
		tmpTypeStr.getTokensForDelimiter(Comma, tableDetails);
		x1 := tableDetails[2].Real;
		y1 := tableDetails[3].Real;
		w1 := tableDetails[4].Real;
		h1 := tableDetails[5].Real;
		//self.dkcTop.move(tableDetails[2].Real, tableDetails[3].Real, tableDetails[4].Real, tableDetails[5].Real); // this auto sets the Bottom
	endif;
	tableDetails.clear;
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_TagTablePosition &amp; self.dkcBottom.name);
	if tmpTypeStr &lt;&gt; null then
		tmpTypeStr.getTokensForDelimiter(Comma, tableDetails);
		h2 := tableDetails[5].Real;
	endif;
	// TFS 2136 scale the height the same way as the width
	if h1 + h2 &gt; formHeight then
		h1 := (h1 * (formHeight / (h1 + h2))).Integer.Real;
	endif;

	self.dkcTop.move(x1, y1, w1, h1); // this auto sets the Bottom
	tableDetails.clear;
	
	// position the individual table dock containers (parenting has been done in setTableParentsFromXML)
	// On Ship dock container
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_TagTablePosition &amp; self.dkcOnShip.name);
	if tmpTypeStr &lt;&gt; null then
		tmpTypeStr.getTokensForDelimiter(Comma, tableDetails);
		x1 := tableDetails[2].Real;
		y1 := tableDetails[3].Real;
		w1 := tableDetails[4].Real;
		h1 := tableDetails[5].Real;
		//self.dkcOnShip.move(tableDetails[2].Real, tableDetails[3].Real, tableDetails[4].Real, tableDetails[5].Real);
	endif;
	tableDetails.clear;
	// On Terminal dock container
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_TagTablePosition &amp; self.dkcOnTerminal.name);
	if tmpTypeStr &lt;&gt; null then
		tmpTypeStr.getTokensForDelimiter(Comma, tableDetails);
		x2 := tableDetails[2].Real;
		y2 := tableDetails[3].Real;
		w2 := tableDetails[4].Real;
		h2 := tableDetails[5].Real;
		//self.dkcOnTerminal.move(tableDetails[2].Real, tableDetails[3].Real, tableDetails[4].Real, tableDetails[5].Real);
	endif;
	// TFS 2136 if the dock containers are too wide for the current form width, scale each proportionally to keep the look much the same
	//  What happened when the saved postions were too big for the form was that the second dock container moved kept its width with the width of the
	//	first dock container being reduced to the remaining space, which could leave it all squashed up.

	if w1 + w2 &gt; formWidth then
		newW1 := (w1 * (formWidth / (w1 + w2))).Integer.Real;
		newW2 := formWidth - newW1;
		w1 := newW1;
		w2 := newW2;
		x2 := w1;
	endif;
	self.dkcOnShip.move(x1, y1, w1, h1);
	self.dkcOnTerminal.move(x2, y2, w2, h2);
	tableDetails.clear;
	// Off Site dock container
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_TagTablePosition &amp; self.dkcOffSite.name);
	if tmpTypeStr &lt;&gt; null then
		tmpTypeStr.getTokensForDelimiter(Comma, tableDetails);
		x1 := tableDetails[2].Real;
		y1 := tableDetails[3].Real;
		w1 := tableDetails[4].Real;
		h1 := tableDetails[5].Real;
		//self.dkcOffSite.move(tableDetails[2].Real, tableDetails[3].Real, tableDetails[4].Real, tableDetails[5].Real);
	endif;
	tableDetails.clear;
	// Pre Notes dock container
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_TagTablePosition &amp; self.dkcPreNotes.name);
	if tmpTypeStr &lt;&gt; null then
		tmpTypeStr.getTokensForDelimiter(Comma, tableDetails);
		x2 := tableDetails[2].Real;
		y2 := tableDetails[3].Real;
		w2 := tableDetails[4].Real;
		h2 := tableDetails[5].Real;
		//self.dkcPreNotes.move(tableDetails[2].Real, tableDetails[3].Real, tableDetails[4].Real, tableDetails[5].Real);
	endif;
	// TFS 2136 if the dock containers are too wide for the current form width, scale each proportionally to keep the look much the same
	if w1 + w2 &gt; formWidth then
		newW1 := (w1 * (formWidth / (w1 + w2))).Integer.Real;
		newW2 := formWidth - newW1;
		w1 := newW1;
		w2 := newW2;
		x2 := w1;
	endif;
	self.dkcOffSite.move(x1, y1, w1, h1);
	self.dkcPreNotes.move(x2, y2, w2, h2);
	tableDetails.clear;
epilog
	delete tableDetails;
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="setToolbarSearch" id="874cb160-8b88-482f-ada8-764ab1fd0939">
        <source>setToolbarSearch();
