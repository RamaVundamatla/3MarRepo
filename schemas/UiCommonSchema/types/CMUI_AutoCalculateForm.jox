    <JadeMethod name="doResize" id="8e4486ba-4a35-422e-b339-6dca054f8386">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars

begin

	self.grpMain.top := 1;
	self.grpMain.left := 1;

	self.width := self.grpMain.width + 20;
	self.height := self.grpMain.height + 80;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="d267088a-76c8-45fa-99a4-55b6778dbf52">
        <updating/>
        <source>doSave():Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars
	quantity : Integer;
	pieces	 : Integer;
	theReturn : Integer;
	weight : Decimal[14,4];
	remarks: String;
	length,
	width,
	height : Decimal[14,4];
	newVolume : Decimal[16,4];
	ti : CM_TrackedItem;
	reason: CM_VolumeDiscrepancyReason;
begin
	quantity := self.txtQty.text.Integer;
	pieces := self.txtPieces.text.Integer;
	length := self.tblLength.getConvertedValue();
	width := self.tblWidth.getConvertedValue();	
	height := self.tblHeight.getConvertedValue();	
	weight := self.tblWeight.getConvertedValue();	
	remarks := self.txtReason.text;
	reason := self.cmbReason.listObject.CM_VolumeDiscrepancyReason;
	self.setAutoTotalVolume();
	newVolume := self.newAutoVolume;
	foreach  ti in self.allTrackedItems do
		while true do 
			
			app.myTrxUA.trxVolumeDiscrepancy(true,ti,quantity,pieces.max(1),width,length,height,weight,newVolume, remarks, reason, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				break;			
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(BreakBulkDiscrepancy), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return false;
			endif;
			break;
			
		endwhile;
	endforeach;
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAutoTotalVolume" id="6de6f0a8-d116-499c-a31b-edd22a661601">
        <updating/>
        <source>setAutoTotalVolume()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars
	cargoType : CM_CargoType;
	pieces : Integer;
	qty : Integer;
	w,
	length,
	hight : Decimal[14,4];
	volumeM3 : Decimal[16,4];
	measureType : CM_MeasurementType;
	displayValue : String;
begin
	
	
	measureType := app.getDefaultMeasurementForType(Type_Volume);	
	cargoType := self.myTrackedItem.myCargoType;
	if measureType = null then
		return;
	endif;
	
	qty := self.txtQty.text.Integer.max(1);
	
	if  self.txtPieces.visible then
		pieces := self.txtPieces.text.Integer.max(1);
	endif;
	
	w:= self.tblWidth.getConvertedValue();
	length := self.tblLength.getConvertedValue();
	hight := self.tblHeight.getConvertedValue();
	 volumeM3 := app.convertMeasurementForStorage(measureType.shortName, self.myTrackedItem.totalVolume);
	volumeM3 := cargoType.calculateCargoVolume( null,qty,pieces,w,length,hight,volumeM3);
	self.lblVolumeReadOnly.caption :=app.convertMeasurementForDisplay(measureType.shortName, volumeM3) &amp; Space &amp; measureType.shortName;
	self.newAutoVolume := volumeM3;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="68cfca9c-38c8-49d8-8e36-cd5129ad9e0f">
        <updating/>
        <source>setMyTrackedItem(_tiArray : CM_TIArray input) :Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars

begin
	if _tiArray.isEmpty or _tiArray = null then
		return false;
	endif;
	self.myTrackedItem := _tiArray.first.CM_TrackedItem;
	
	self.allTrackedItems.clear();
	_tiArray.copy(self.allTrackedItems);
	return true;
epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupCombo" id="5c39e20a-52d9-4718-8255-d9aaa86b31d4">
        <updating/>
        <source>setupCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2019	jlgmp6	Initial creation	TFS41707

*/

vars
	idx: Integer;
	vdr: CM_VolumeDiscrepancyReason;
	terminal: CM_Terminal;
	hasReasons: Boolean;
begin
	terminal := self.myTerminal;

	if app.myRoot.allVolumeDiscrepancyReasons.size() = 0 then
		app.msgBox(app.getErrorString(There_curre_volum_discr_reaso_), app.getErrorString(TransType_189), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	else
		foreach vdr in app.myRoot.allVolumeDiscrepancyReasons where vdr.userCanSet(terminal) do
			hasReasons := true;
			idx := self.cmbReason.addItem(vdr.description);
			self.cmbReason.itemObject[idx] := vdr;
		endforeach;

		if not hasReasons then
			app.msgBox(app.getErrorString(Not_have_secur_right_avail_vol), app.getErrorString(TransType_189), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.unloadForm();
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="43250b04-db54-4d27-bea4-4dc4d02a058e">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars

begin
	inheritMethod();
	setupMeasurementControls();
	setupCombo();					// 3/5/19 MAP TFS41707
	if not app.myCurrentUserCan(self.myTerminal, PmAdmVolumeDiscrepancyMaint) then
		self.btnOk.enabled := false;
		self.grpMain.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMeasurementControls" id="8ff05e47-d90a-49a8-8529-734a46d4b835">
        <source>setupMeasurementControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars
	typeWeight,typeVolume : String;
	measureTypeWeight,
	meausreTypeVolume	: CM_MeasurementType;
	subType: CM_Product;
begin
	
	self.tblHeight.setup(Type_Height, self.backColor);
	self.tblLength.setup(Type_Length, self.backColor);
	self.tblWidth.setup(Type_Width, self.backColor);
	self.tblWeight.setup(Type_Weight, self.backColor);
	

	if self.myTrackedItem &lt;&gt; null then
		self.tblWidth.setValueDefault(self.myTrackedItem.width.asStringJMT);
		self.tblLength.setValueDefault(self.myTrackedItem.length.asStringJMT);
		self.tblHeight.setValueDefault(self.myTrackedItem.height.asStringJMT);
		self.txtQty.text := self.myTrackedItem.totalQuantity.asStringJMT;
		subType := self.myTrackedItem.myProduct;		// 20/6/19 MAP TFS41707
		if subType = null then
			subType := self.myTrackedItem.myCargoType.mySystemProductType;
		endif;
		if subType &lt;&gt; null 
			and subType.myQuantity &lt;&gt; null
			and subType.myQuantity.isViewable then
			self.txtPieces.visible := true;
			self.lblNewPieces.visible := true;
			self.txtPieces.text := self.myTrackedItem.quantity.asStringJMT;
		else
			self.txtPieces.visible := false;
			self.lblNewPieces.visible := false;
		endif;
	endif;
	
	measureTypeWeight := self.myTrackedItem.getDefaultMeasurementForType(Type_Weight);
	meausreTypeVolume := self.myTrackedItem.getDefaultMeasurementForType(Type_Volume);
	
	if measureTypeWeight &lt;&gt; null then
		typeWeight:= measureTypeWeight.shortName;
		self.tblWeight.setValues(app.convertMeasurementForDisplay(typeWeight, self.myTrackedItem.totalWeight) &amp; Space &amp; typeWeight);			
	endif;
	
	if meausreTypeVolume &lt;&gt; null then
		typeVolume := meausreTypeVolume.shortName;
		self.lblVolumeReadOnly.caption :=app.convertMeasurementForDisplay(typeVolume, self.myTrackedItem.totalVolume) &amp; Space &amp; typeVolume;
	endif;
	
epilog

end;</source>
    </JadeMethod>
