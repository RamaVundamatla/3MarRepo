    <JadeMethod name="setupForm" id="3ff5fc4d-1a51-4805-8f9a-7d5b14cd1f7e">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		19 November 2010 by cnwjo3
//
// Purpose:		
//
vars

begin
	inheritMethod();
	
	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;
	
	self.centreWindow();
	
	self.minimumHeight := 520;
	self.minimumWidth := 350;
	
	//set up toolbar here
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	//save size?	
	//self.getXMLSettingsForSetup();

	self.displayShipControllerInfo();
	
	self.tblInfo.left := 5;
	self.tblErrors.left := 5;
	self.lblErrorsWarning.left := 5;
	self.lblInfo.left := 5;
	self.tblInfo.width := self.clientWidth - 10;
	self.tblErrors.width := self.clientWidth - 10;
	self.btnClose.left := (self.tblErrors.width+5-self.btnClose.width);
	
	self.tblErrors.height := self.clientHeight - self.btnClose.height - self.tblInfo.height - self.frmToolbar.height - 80;
	self.btnClose.top := self.tblErrors.top + self.tblErrors.height + 10;
	
	//set smallest
	self.height := 520;
	self.width := 350;	
	
	self.btnClose.setFocus();	
end;</source>
    </JadeMethod>
    <JadeMethod name="showUnplannedItems" id="5ce07d8a-0fa2-46e8-9e10-012800508e1b">
        <updating/>
        <source>showUnplannedItems() updating;
// --------------------------------------------------------------------------------
// Created:		23 November 2010 by cnwjo3
//
// Purpose:		
//
vars
	tiS : CM_TIArray;
	aJob : CM_Job;
	aVJob : CM_VoyageJob;
	aTI : CM_TrackedItem;
begin
	if self.shipController.allTrackedItems.isEmpty then
		app.msgBox(app.getErrorString(LoadPlanInfo_NoExportCargoNotP), app.getErrorString(LoadPlanInfo_NothingToShow),MsgBox_Exclamation_Mark_Icon);
		return;
	else
		create tiS transient;
		if self.allJobs.isEmpty then
			self.shipController.allTrackedItems.copy(tiS);
		else
			foreach aTI in self.shipController.allTrackedItems do
				foreach aJob in self.allJobs do : jobLoop
					aVJob := aJob.CM_VoyageJob;
					if aVJob.isTISimilarToJob(aTI) then
						tiS.add(aTI);
						break jobLoop;
					endif;
				endforeach;
			endforeach;
		endif;
		if tiS.isEmpty() then 
			app.msgBox(app.getErrorString(LoadPlanInfo_NoUnplannedCargo), app.getErrorString(LoadPlanInfo_NothingToShow),MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		self.setMyTerminal(self.myTerminal);  //this is dumb but it works
		self.myAssistant.showCargoEnquiryForTIs(tiS.first, tiS, self.myMasterMenuAction, false);
	endif;
epilog
	delete tiS;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="eb7fe66a-818d-47bf-b308-b3202ce394a7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016076, locale);
	btnClose.translateCaption(Xlat_0016077, locale);
	btnReplanJobs.translateBubbleHelp(Xlat_0016078, locale);
	btnReplanJobs.translateCaption(Xlat_0016079, locale);
	btnShowNonPlan.translateBubbleHelp(Xlat_0016080, locale);
	btnShowNonPlan.translateCaption(Xlat_0016081, locale);
	btnUnplan.translateBubbleHelp(Xlat_0016082, locale);
	btnUnplan.translateCaption(Xlat_0016083, locale);
	lblErrorsWarning.translateCaption(Xlat_0016084, locale);
	lblInfo.translateCaption(Xlat_0016085, locale);
end;</source>
    </JadeMethod>
</GUIClass>
