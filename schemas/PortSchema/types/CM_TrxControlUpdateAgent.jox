    <JadeMethod name="trxUpdateTrainWagon" id="68d11b62-1275-4e7d-afc0-5896b2c48dc6">
        <updating/>
        <source>trxUpdateTrainWagon(_pxyWagon : CM_Wagon input; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2009	cnwmd1	Initial creation
11 Aug 2022		jlika1	TFS 53741 EUP  - Max Wagon Payload
*/

vars
	realWagon 	: CM_Wagon;
	wagonMaster	: CM_WagonMaster;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateTrainWagonDamageOnly(_pxyWagon, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	realWagon := _pxyWagon.pxyGetRealObject;
	wagonMaster := realWagon.myWagonMaster;
	
	if wagonMaster &lt;&gt; null then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(wagonMaster, true);
		
		if realWagon.maxCargoWeight &lt;&gt; null then
			wagonMaster.setMaxCargoWeight(realWagon.maxCargoWeight);
		endif;
		
		if realWagon.tareWeight &lt;&gt; null then
			wagonMaster.setTareWeight(realWagon.tareWeight);
		endif;
		
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(wagonMaster, false);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyWagon" type="CM_Wagon" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
