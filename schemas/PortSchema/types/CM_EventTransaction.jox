        <source>getVoyageNRT() : Integer;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 20 September 2022
TFS#		: 54850
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	voyage : CM_Voyage;
begin
	voyage	:= self.getVoyage();
	if voyage = null then
		return 0;
	endif;
	
	if voyage.myHMSVoyageData = null then
		return 0;
	endif;
	
	return voyage.myHMSVoyageData.dim_NetRegTonnes;
end;</source>
