    <JadeMethod name="displayTA" id="c6436244-e631-4099-b5bf-c0642fb7478b">
        <source>displayTA( _obj : Object ) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwrd1	Initial creation

*/

vars
	aTerminalArea 	: CM_TerminalArea;
	aGridObject		: CM_GridObject;
	numTIs 			: Integer;
	str 			: String;
begin

	if _obj.isKindOf(CM_TerminalArea) then
		aTerminalArea := _obj.CM_TerminalArea;
	
		str := aTerminalArea.id.trimBlanks &amp; Tab &amp;
			aTerminalArea.typeString.trimBlanks;
		   
	elseif _obj.isKindOf(CM_GridObject) then
	
		aGridObject := _obj.CM_GridObject;
		aTerminalArea := aGridObject.getGridArea();
	
		str := aTerminalArea.id.trimBlanks &amp; Tab &amp;
			aTerminalArea.typeString.trimBlanks &amp; '(' &amp; aGridObject.label &amp; ')';
	endif;


	// num ti's removed for perfomance reasons here. people using this form likely know the state of the yard.
	//numTIs := aTerminalArea.getNumTIs(REAL_MODE); //rs oct 2005 par 10886
	//str := str &amp; Tab &amp; numTIs.String;

	//if self.mltTermAreas.isSelected(_obj) and aTerminalArea.isGridArea() then  //didnt work ah well - was trying to only but best pick on the selected listbox but...
	/*if aTerminalArea.isGridArea() then
		if self.chkBestPick.value then
			str := str &amp; Tab &amp; app.getErrorString(Best_pick);
		endif;
	endif;*/

	return str;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doControlEvent" id="53cc5332-681b-41c5-835a-56ef96eef22d">
        <updating/>
        <source>doControlEvent(_control: Control) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwrd1	Initial creation

*/

vars
	objSelectedArray : ObjectArray;
begin
	inheritMethod(_control);
	
	if _control = self.mltTermAreas.myAddSelectedBtn or
	   _control = self.mltTermAreas.myAddAllBtn or		
	   _control = self.mltTermAreas.myRemoveSelectedBtn or
	   _control = self.mltTermAreas.myRemoveAllBtn then
		   
		create objSelectedArray transient;
		
		// Store the currently selected items
		self.mltTermAreas.getSelected(objSelectedArray);		
		//self.doSelectedTAChange(objSelectedArray);		
	endif;	
epilog
	delete objSelectedArray;

end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doPopulateTerminalAreas" id="7636de30-a396-4491-bed3-0b137491ee4b">
        <source>doPopulateTerminalAreas( _allTermAreas : CM_ObjectArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwrd1	Initial creation
01 Jul 2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
08 Sep 2022	jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/


vars
	aTerminalArea : CM_TerminalArea;
	aGridArea		: CM_GridArea;
	aGridObject		: CM_GridObject;
	numTIs,
	idx : Integer;
	str				: String;
	theFilter : CMQF_TerminalAreas;
	theQryReport : CM_QryReport;
	
begin
	
	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalArea);
	
	create theFilter transient;
	theFilter.allTerminals.add(self.myTerminal);
	theFilter.terminalAreaTypes.add(TA_TYPE_DEPOT_LCL);
	theFilter.terminalAreaTypes.add(TA_TYPE_BLOCK_STACK);
	theFilter.terminalAreaTypes.add(TA_TYPE_SUBBLOCK_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_WASH_AREA);			
	theFilter.terminalAreaTypes.add(TA_TYPE_PTI);				
	theFilter.terminalAreaTypes.add(TA_TYPE_REPAIR);				
	theFilter.terminalAreaTypes.add(TA_TYPE_DAIRY);
	theFilter.terminalAreaTypes.add(TA_TYPE_RORO_LANE_AREA);	//29 May 2012	NDL	Par 29642
	
	theFilter.terminalAreaTypes.add(TA_TYPE_STRADDLE_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_FORK_LIFT_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_RTG);	
	theFilter.terminalAreaTypes.add(TA_TYPE_RMG);
	theFilter.terminalAreaTypes.add(TA_TYPE_MAFI);
	
	theQryReport.doFilter(theFilter, app.myPassport);
		
	foreach aTerminalArea in theFilter.allQryTerminalAreas do
		if aTerminalArea.type = TA_TYPE_CRANE_TRANS
		or  aTerminalArea.type = TA_TYPE_DELETE then
			continue;
		endif;

		_allTermAreas.add(aTerminalArea);
		
				//cnwrd1 par 28628 4.11.11
		if not self.hideBestPick then         // 01/07/2015 cnwma1 PAR #36555  
			if self.myTerminal.getConfig(UseBestPickDirector).Boolean then
				if aTerminalArea.isGridArea then
					aGridArea := aTerminalArea.CM_GridArea;
					//OMG hideous hack for bays/rows
					if aGridArea.areLocationIdsColThenRow then
					// forklift/gbs
					//look at columns/bays
						foreach aGridObject in aGridArea.allGridColumns do
							_allTermAreas.add(aGridObject);
						endforeach;
					else
					//straddle etc lool at bays/rows
						foreach aGridObject in aGridArea.allGridRows do
							_allTermAreas.add(aGridObject);
						endforeach;			
					endif;
				endif;
			endif;
		endif;
	endforeach;

	
epilog
	delete theFilter;
end;</source>
        <Parameter name="_allTermAreas" type="CM_ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="fbf7abc9-0aca-4c4d-8b78-f8d002835002">
        <updating/>
        <source>doSave() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwrd1	Initial creation

*/

vars

begin

	if self.allWLEs.isEmpty then
	//must be from a form like releasecargo so just return ok;
		return true;
	else
	// am from a ops form and have wle's
		return self.doSaveWithWLEs();
	endif;

	
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveWithWLEs" id="4ebbaa61-2157-47da-a39d-3753ec043631">
        <updating/>
        <source>doSaveWithWLEs() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwrd1	Initial creation

*/

vars
	termArea 		: CM_TerminalArea;
	termAreaGridObjs	: CM_GridObjectArray;
	wleArray 		: CM_WLEArray;
	terminalAreas 	: CM_TerminalAreaArray;
	theReturn		: Integer;
begin

	if not self.validateForSave() then
		return false;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	
	create wleArray transient;
	create terminalAreas transient;
	create termAreaGridObjs transient;
	
	self.allWLEs.copy (wleArray);
	self.getAreasWithGridObjs(terminalAreas, termAreaGridObjs);
	//self.mltTermAreas.getSelected(terminalAreas);
			
			/*
	app.myTrxUA.trxUpdateWLEsQueueRequest(wleArray, terminalAreas , self.chkBestPick.value ,self.optFIFO.value,   app.myPassport);
	
	if (not app.myPassport.trxCompletedOK) then
		
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return false;
	else
		self.clearErrorWarnings();
	endif;*/																					
	
	
	while true do
		app.myTrxUA.trxUpdateWLEsQueueRequest(wleArray, terminalAreas , termAreaGridObjs , self.chkBestPick.value ,self.optFIFO.value,  app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else			
			theReturn := app.showErrorWarningDialog('Queue Request', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
	
	return true;
	
epilog
	delete wleArray;
	delete terminalAreas;
	delete termAreaGridObjs;
	app.mousePointer := MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectedTAChange" id="537f6f4c-3b36-43c8-867d-6b676d194e32">
        <source>doSelectedTAChange( _objSelectedArray : ObjectArray);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwrd1	Initial creation

*/

vars
	aTerminalArea 	: CM_TerminalArea;
	obj 			: Object;
	foundGrid 		: Boolean;
begin

	foreach obj in _objSelectedArray do
		if obj = null then
			continue;
		endif;
		aTerminalArea := obj.CM_TerminalArea;
		
		if aTerminalArea.isGridArea() then
			foundGrid := true;
		endif;		
	endforeach;

	self.chkBestPick.enabled := foundGrid;		
	
	
epilog

end;</source>
        <Parameter name="_objSelectedArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getAreasWithGridObjs" id="0c65f577-8974-43b5-93b3-765d18e2ada9">
        <source>getAreasWithGridObjs( _allTAareas : CM_TerminalAreaArray; _allTAGridObjects : CM_GridObjectArray);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2011	cnwrd1	Initial creation

*/

vars
	allSelected : ObjectArray;
	aTA 		: CM_TerminalArea;
	aGO			: CM_GridObject;
	obj			: Object;
	allTAs 		: CM_TerminalAreaArray;
	allGOs		: CM_GridObjectArray;
begin

	allTAs := _allTAareas;
	allGOs := _allTAGridObjects;
	
	allTAs.clear;
	allGOs.clear;

	create allSelected transient;
	self.mltTermAreas.getSelected(allSelected);
	
	foreach obj in allSelected do
		if obj.isKindOf(CM_TerminalArea) then
			allTAs.add(obj.CM_TerminalArea);
			allGOs.add(null);
		else
			allTAs.add(obj.CM_GridObject.getGridArea());
			allGOs.add(obj.CM_GridObject);
		endif;
	endforeach;

epilog
	delete allSelected;
end;</source>
        <Parameter name="_allTAareas" type="CM_TerminalAreaArray"/>
        <Parameter name="_allTAGridObjects" type="CM_GridObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="34baeb5d-6c15-4b07-8cdc-08c821969012">
        <updating/>
        <source>getDescription() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwrd1	Initial creation

*/

vars
	
begin

	if self.myDeliveryRequest &lt;&gt; null then
		self.getDescriptionDeliveryReq();
		return;
	endif;
	
	if self.myGTERelease &lt;&gt; null then
		self.getDescriptionGTERelease();
		return;
	endif;

	self.lblDesc.caption := self.descStr;
	self.lblDesc.fontBold := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getDescriptionDeliveryReq" id="3c84ef8a-f840-4f93-84f5-fb9f4e199a24">
        <source>getDescriptionDeliveryReq();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwrd1	Initial creation

*/

vars
	msgStr 		: String;
	isISOType	: Boolean;
	isEmpty		: Boolean;
	imex	: CM_IMEXStatus;
	rqst	: CM_DeliveryRequest;
begin

	rqst := self.myDeliveryRequest;
	if rqst.myCargoType &lt;&gt; null then
		isISOType := rqst.myCargoType.isISOType();
	endif;
	if isISOType then
	// container
		isEmpty := (rqst.commodity = self.myTerminal.getDefaultEmptyCommodity());
		if rqst.isoType &lt;&gt; null then
			msgStr := addString(msgStr, "ISO : " &amp; rqst.isoType.trimBlanks);
		endif;
		if rqst.isoGroup &lt;&gt; null then
			msgStr := addString(msgStr, "ISO Group : " &amp; rqst.isoGroup.trimBlanks);
		endif;
		if rqst.operatorCode &lt;&gt; null then
			msgStr := addString(msgStr, "Oper : " &amp; rqst.operatorCode);
		endif;
		if rqst.imexStatus &lt;&gt; TI_IMEX_STATUS_NULL then
			imex:= app.myRoot.allImexStatuses[rqst.imexStatus];
			if imex &lt;&gt; null then
				msgStr := addString(msgStr, "IMEX : " &amp; imex.description);
			endif;
		endif;
		if isEmpty then
			msgStr := addString(msgStr, rqst.commodity);
			if rqst.clean then
				msgStr := addString(msgStr, "Clean");
			endif;
			if rqst.heavyRated then
				msgStr := addString(msgStr, " Heavy Duty");
			endif;
		else
			if rqst.commodity &lt;&gt; null then
				msgStr := addString(msgStr, "Commodity : " &amp; rqst.commodity);
			endif;
			if rqst.voyageCode &lt;&gt; null then
				msgStr := addString(msgStr, "Voyage : " &amp; rqst.voyageCode);
			endif;
			if rqst.consignee &lt;&gt; null then
				msgStr := addString(msgStr, " Deliver To : " &amp; rqst.consignee.trimBlanks);
			endif;
			if rqst.billOfLading &lt;&gt; null then
				msgStr := addString(msgStr, "BOL : " &amp; rqst.billOfLading);
			endif;
		endif;
	
		if rqst.isKindOf(CM_YardDeliveryRequest) then
		// Also get mt grade &amp; target location
			msgStr := addString(msgStr, "Total Requested: " &amp; rqst.totalRequested.String);
			if rqst.CM_YardDeliveryRequest.targetLocation &lt;&gt; "" then
				msgStr := addString(msgStr, "Dest : " &amp; rqst.CM_YardDeliveryRequest.targetLocation);
			endif;			
			//cnwrd1 par 26633 17.12.2010
			//msgStr := addString(msgStr, "Avail. Grade : " &amp; app.myRoot.allAvailabilityGrades[ rqst.CM_YardDeliveryRequest.mtGrade].description);
			msgStr := addString(msgStr, "Avail. Grade : " &amp;  rqst.getAvailabilityGrades());
		else
			msgStr := addString(msgStr, "1 of " &amp; rqst.totalRequested.String);
		endif;
	else
		// general cargo
		if rqst.myCargoType &lt;&gt; null then
			msgStr := addString(msgStr, "Cargo : "&amp; rqst.myCargoType.description);
			if rqst.mySubCargoType &lt;&gt; null then
				msgStr := addString(msgStr, rqst.mySubCargoType.description);
			endif;
		endif;
		if rqst.operatorCode &lt;&gt; null then
			msgStr := addString(msgStr, "Oper : " &amp; rqst.operatorCode);
		endif;
		if rqst.mark &lt;&gt; null then
			msgStr := addString(msgStr, "Mark : " &amp; rqst.mark);
		endif;
		if rqst.voyageCode &lt;&gt; null then
			msgStr := addString(msgStr, "Voyage : " &amp; rqst.voyageCode);
		endif;
		if rqst.billOfLading &lt;&gt; null then
			msgStr := addString(msgStr, "BOL : " &amp; rqst.billOfLading);
		endif;
	
		if rqst.isKindOf(CM_YardDeliveryRequest) then
			msgStr := addString(msgStr, "Total Requested: " &amp; rqst.totalRequested.String);
			if rqst.CM_YardDeliveryRequest.targetLocation &lt;&gt; "" then
				msgStr := addString(msgStr, "Dest : " &amp; rqst.CM_YardDeliveryRequest.targetLocation);
			endif;
			//cnwrd1 par 26633 17.12.2010
			//msgStr := addString(msgStr, "Avail. Grade : " &amp; app.myRoot.allAvailabilityGrades[ rqst.CM_YardDeliveryRequest.mtGrade].description);
			msgStr := addString(msgStr, "Avail. Grade : " &amp;  rqst.getAvailabilityGrades());
		else
			msgStr := addString(msgStr, "1 of " &amp; rqst.totalRequested.String);
		endif;
	endif;

	self.lblDesc.caption := msgStr;
	self.lblDesc.fontBold := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDescriptionGTERelease" id="dcf3fa15-3813-4033-83fb-9510fb94e4f1">
        <updating/>
        <source>getDescriptionGTERelease() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwrd1	Initial creation

*/

vars

	msgStr 		: String;
	isISOType	: Boolean;
	isEmpty		: Boolean;
	imex	: CM_IMEXStatus;
	release	: CMGTE_Release;
begin

	self.lblDesc.caption := self.descStr;
	self.lblDesc.fontBold := true;

/*
	release := self.myGTERelease;
	if release.myCargoType &lt;&gt; null then
		isISOType := release.myCargoType.isISOType();
	endif;
	if isISOType then
	// container
		isEmpty := (release.commodity = self.myTerminal.getDefaultEmptyCommodity());
		if release.isoType &lt;&gt; null then
			msgStr := addString(msgStr, "ISO : " &amp; release.isoType.trimBlanks);
		endif;
		if release.isoGroup &lt;&gt; null then
			msgStr := addString(msgStr, "ISO Group : " &amp; release.isoGroup.trimBlanks);
		endif;
		if release.operatorCode &lt;&gt; null then
			msgStr := addString(msgStr, "Oper : " &amp; release.operatorCode);
		endif;
		if release.imexStatus &lt;&gt; TI_IMEX_STATUS_NULL then
			imex:= app.myRoot.allImexStatuses[release.imexStatus];
			if imex &lt;&gt; null then
				msgStr := addString(msgStr, "IMEX : " &amp; imex.description);
			endif;
		endif;
		if isEmpty then
			msgStr := addString(msgStr, release.commodity);
			if release.clean then
				msgStr := addString(msgStr, "Clean");
			endif;
			if release.heavyRated then
				msgStr := addString(msgStr, " Heavy Duty");
			endif;
		else
			if release.commodity &lt;&gt; null then
				msgStr := addString(msgStr, "Commodity : " &amp; release.commodity);
			endif;
			if release.voyageCode &lt;&gt; null then
				msgStr := addString(msgStr, "Voyage : " &amp; release.voyageCode);
			endif;
			if release.consigneeCode  &lt;&gt; null then
				msgStr := addString(msgStr, " Deliver To : " &amp; release.consigneeCode.trimBlanks);
			endif;
			if release.billOfLading &lt;&gt; null then
				msgStr := addString(msgStr, "BOL : " &amp; release.billOfLading);
			endif;
		endif;
	
		msgStr := addString(msgStr, "Total Requested: " &amp; release.numItems.asStringJMT);
	else
		// general cargo
		if release.myCargoType &lt;&gt; null then
			msgStr := addString(msgStr, "Cargo : "&amp; release.myCargoType.description);

		endif;
		if release.operatorCode &lt;&gt; null then
			msgStr := addString(msgStr, "Oper : " &amp; release.operatorCode);
		endif;
		if release.mark &lt;&gt; null then
			msgStr := addString(msgStr, "Mark : " &amp; release.mark);
		endif;
		if release.voyageCode &lt;&gt; null then
			msgStr := addString(msgStr, "Voyage : " &amp; release.voyageCode);
		endif;
		if release.billOfLading &lt;&gt; null then
			msgStr := addString(msgStr, "BOL : " &amp; release.billOfLading);
		endif;
	
	//	if release.isKindOf(CM_YardDeliveryRequest) then
		msgStr := addString(msgStr, "Total Requested: " &amp; release.numItems.asStringJMT);
		
			if release.CM_YardDeliveryRequest.targetLocation &lt;&gt; "" then
				msgStr := addString(msgStr, "Dest : " &amp; release.CM_YardDeliveryRequest.targetLocation);
			endif;
			msgStr := addString(msgStr, "Avail. Grade : " &amp; app.myRoot.allAvailabilityGrades[ release.CM_YardDeliveryRequest.mtGrade].description);
		else
			msgStr := addString(msgStr, "1 of " &amp; release.totalRequested.String);
		endif;
		
	endif;

	self.lblDesc.caption := msgStr;
	self.lblDesc.fontBold := true;
*/
epilog

end;</source>
