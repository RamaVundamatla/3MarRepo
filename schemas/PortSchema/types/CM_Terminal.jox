    <JadeMethod name="setXMLForTerminalLayout" id="de8353a2-4bfc-4b0d-9319-4ca90e42bb18">
        <updating/>
        <source>setXMLForTerminalLayout(_theXMLString : String) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aPxyGraphic,aRealGraphic : CM_LayoutGraphic;
	theXMLTagValue : String;
	idx,pos,theColour,theX, theY : Integer;
	theLabel,thePoints, thePoint : String;
	thePointsArray : PointArray;
	aPoint : Point;
	theXYStrings : StringArray;
	anError : CM_Error;
begin
	beginTransaction;
	self.allLayoutGraphics.purge;
	commitTransaction;

	create theXYStrings transient;
	create thePointsArray transient;
	pos := 1;
	while (pos &gt; 0) do
		theXMLTagValue := _theXMLString.cnEcGetNextTagValueOfName("GR",pos); 
		if theXMLTagValue = null then
			break;
		endif;
		theColour := theXMLTagValue.cnEcGetTagValueOfName("cl").Integer;
		theLabel := theXMLTagValue.cnEcGetTagValueOfName("lb");
		thePoints := theXMLTagValue.cnEcGetTagValueOfName("Points");

		if theLabel = null then
			theLabel := " T1 - Actual Terminal";
		endif;
		
		theXYStrings.clear;
		thePointsArray.clear;
		
		thePoints := thePoints.replaceString(",","/");
		idx := 1;
		while idx &gt; 0 do
			thePoint := thePoints.getNextToken(idx);
			if thePoint = null then
				break;
			endif;
			theXYStrings.add(thePoint);
		endwhile;
			
		theX := -99999;
		foreach idx in 1 to theXYStrings.size do
			if theX = -99999 then
				theX := theXYStrings[idx].Integer;
			else		
				theY := theXYStrings[idx].Integer;
			
				aPoint.set(theX, theY);
				thePointsArray.add(aPoint);
				theX := -99999;
			endif;	
		endforeach;
		
		create aPxyGraphic transient;
		aPxyGraphic.setProxy(0,0,null,theColour,0,0,0,thePointsArray,theLabel,self);
		app.myTrxCA.trxCreateLayoutGraphic(aPxyGraphic,aRealGraphic,app.myPassport);

		if app.myPassport.trxCompletedOK = false then
			foreach anError in app.myPassport.allErrorWarnings do
				app.writeStatement( "ERROR: " &amp; anError.errorCode.String &amp; " " &amp; anError.text &amp; " " &amp; anError.fieldName);
			endforeach;
		endif;
		delete aPxyGraphic;
	endwhile;
	
epilog
	delete aPxyGraphic;
	delete thePointsArray;
	delete theXYStrings;
end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupDynaDictForRoadOps" id="f8c5b09e-8f38-44a6-92c2-99f1cbc8fdb2">
        <source>setupDynaDictForRoadOps( _dynaDict : DynaDictionary input; _critArray : IntegerArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2016	cnwndl1	Initial creation	TFS 2995 / 2638

*/

vars

	type : Integer;

begin

	foreach type in self.allRoadOpsDisplayCriteria do
		if type = YACriteriaType_AvGrade then
			//CM_Container::availabilityGrade Integer
			_dynaDict.addExternalKey(String, 6, false, false);
		elseif type = YACriteriaType_BOL then
			//CM_TrackedItem::billOfLading
			_dynaDict.addExternalKey(String, 30, false, false);
		elseif type = YACriteriaType_BookingRef then
			//CM_TrackedItem::bookingReference
			_dynaDict.addExternalKey(String, 30, false, false);
		elseif type = YACriteriaType_CargoGroup then
			//CM_TrackedItem::getMyCargoGroupId
			_dynaDict.addExternalKey(String, 20, false, false);
		elseif type = YACriteriaType_CargoType then
			//CM_TrackedItem::cargoType.abbreviation String
			_dynaDict.addExternalKey(String, 10, false, false);
		elseif type = YACriteriaType_Colour then
			//CM_TrackedItem::getColour
			_dynaDict.addExternalKey(String, 60, false, false);
		elseif type = YACriteriaType_Commodity then
			//CM_TrackedItem::commodity String
			_dynaDict.addExternalKey(String, 4, false, false);
		elseif type = YACriteriaType_Consignee then
			//CM_TrackedItem::consignee String
			_dynaDict.addExternalKey(String, 5, false, false);
		elseif type = YACriteriaType_Consignor then
			//CM_TrackedItem::consignor String
			_dynaDict.addExternalKey(String, 5, false, false);
		elseif type = YACriteriaType_DestinationPort then
			//CM_TrackedItem::destinationPort String
			_dynaDict.addExternalKey(String, 5, false, false);
		elseif type = YACriteriaType_DischargePort then
			//CM_TrackedItem::dischargePort String
			_dynaDict.addExternalKey(String, 5, false, false);
		elseif type = YACriteriaType_FreightForward then
			//CM_TrackedItem::freightForwarderCode String
			_dynaDict.addExternalKey(String, 5, false, false);
		elseif type = YACriteriaType_Hazardous then
			//CM_TrackedItem::getHazardsFirstAsString String
			_dynaDict.addExternalKey(String, 30, false, false);
		elseif type = YACriteriaType_ImexStatus then
			//CM_TrackedItem::getImExStatusStringDesc(false) String
			_dynaDict.addExternalKey(String, 4, false, false);
		elseif type = YACriteriaType_ISO then
			//CM_TrackedItem::getISOType String
			_dynaDict.addExternalKey(String, 4, false, false);
		elseif type = YACriteriaType_LoadPort then
			//CM_TrackedItem::loadPort String
			_dynaDict.addExternalKey(String, 5, false, false);
		elseif type = YACriteriaType_Mark then
			//CM_TrackedItem::mark String
			_dynaDict.addExternalKey(String, 30, false, false);
		elseif type = YACriteriaType_OperatorItem then
			//CM_TrackedItem::operatorCode String
			_dynaDict.addExternalKey(String, 4, false, false);
		elseif type = YACriteriaType_Product then
			//CM_TrackedItem::myProduct::code String
			_dynaDict.addExternalKey(String, 30, false, false);
		elseif type = YACriteriaType_SpecialLift then
			//CM_TrackedItem::getSpecialLiftsCodes String
			_dynaDict.addExternalKey(String, 30, false, false);
		elseif type = YACriteriaType_SpecialStow then
			//CM_TrackedItem::getSpecialStowString String
			_dynaDict.addExternalKey(String, 30, false, false);
		elseif type = YACriteriaType_Voyage then
			//CM_TrackedItem::voyageCode String
			_dynaDict.addExternalKey(String, 20, false, false);
		endif;
		_critArray.add( type );
	endforeach;

epilog

end;</source>
        <Parameter name="_dynaDict" type="DynaDictionary" usage="input"/>
        <Parameter name="_critArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupPINEmailDefaults" id="57bf3783-0eb3-475a-be18-46f852ee74dd">
        <source>setupPINEmailDefaults();
//----------------------------------------------------------------
//	Created:	21 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	peDef			: CM_PINObjectDefaultEmail;
	sa				: StringArray;
	emailType		: Integer;
	emailName		: String;
	objectType		: String;
	
begin
	// cnwrl1 03/08/2009 PAR 20377
	// Changed to create system email defaults if the type does not exist
	// else update the system values that the users cannot change.
	// NOTE: The collection allPINObjectEmailDefaults has been changed from property name to type.
	
	create sa transient;
	
	sa.add('Release No (Booking Ref)');
	sa.add('Total Requested');
	sa.add('Consignee');
	sa.add('Pin No.');
	
	emailType	:= PINEmail_ReleaseRequest;						// ie 1
	emailName	:= ReleaseRequest_AddPin;						// ie 'Release Request Add Pin'
	objectType	:= PINEmail_Object_BR;
	peDef		:= self.allPINObjectEmailDefaults[ emailType ].CM_PINObjectDefaultEmail;
	if peDef = null then
		create peDef persistent;
		peDef.setForCreate(	ETDef_MTReleaseDataTable,			// entTable
							sa,									// fields
							null,								// message
							emailName,							// subject
							emailName,							// name
							objectType,							// objectType
							emailType,							// type
							self,								// terminal
							null,								// copyTo
							false,								// sendToCarrier
							false );							// sendToConsignee
	else
		// update those that can NOT be changed by the users.
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::name.name, emailName );
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::objectType.name, objectType);
	endif;
	
	emailType	:= PINEmail_ReleaseRequestDelete;				// ie 2
	emailName	:= ReleaseRequest_DeletePin;					// ie 'Release Request Delete Pin'
	objectType	:= PINEmail_Object_BR;
	peDef		:= self.allPINObjectEmailDefaults[ emailType ].CM_PINObjectDefaultEmail;
	if peDef = null then
		create peDef persistent;
		peDef.setForCreate(	ETDef_MTReleaseDataTable,
							sa,
							null,
							emailName,
							emailName,
							objectType,
							emailType,
							self,
							null,
							false,
							false );
	else
		// update those that can NOT be changed by the users.
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::name.name, emailName );
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::objectType.name, objectType);
	endif;
	
	sa.clear;
	sa.add('Consignee');
	sa.add('Cargo ID');
	sa.add('Total Weight (kg)');
	sa.add('ISO Type');
	sa.add('Commodity Group Desc');
	sa.add('Pin No.');
	
	emailType	:= PINEmail_CargoRelease;						// ie 3
	emailName	:= ReleaseRequest_Import;						// ie 'Import Release'
	objectType	:= PINEmail_Object_TI;
	peDef		:= self.allPINObjectEmailDefaults[ emailType ].CM_PINObjectDefaultEmail;
	if peDef = null then
		create peDef persistent;
		peDef.setForCreate(	ETDef_FullReleaseTblData,
							sa,
							null,
							emailName,
							emailName,
							objectType,
							emailType,
							self,
							null,
							false,
							false );
	else
		// update those that can NOT be changed by the users.
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::name.name, emailName );
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::objectType.name, objectType);
	endif;
	
	emailType	:= PINEmail_CargoReleaseDelete;					// ie 4
	emailName	:= ReleaseRequest_ImportDeleted;				// ie 'Import Release Deleted'
	objectType	:= PINEmail_Object_TI;
	peDef		:= self.allPINObjectEmailDefaults[ emailType ].CM_PINObjectDefaultEmail;
	if peDef = null then
		create peDef persistent;
		peDef.setForCreate(	ETDef_FullReleaseTblData,
							sa,
							null,
							emailName,
							emailName,
							objectType,
							emailType,
							self,
							null,
							false,
							false );
	else
		// update those that can NOT be changed by the users.
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::name.name, emailName );
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::objectType.name, objectType);
	endif;
	
	sa.clear;
	sa.add('Consignor');
	sa.add('Cargo ID');
	sa.add('Total Weight (kg)');
	sa.add('ISO Type');
	sa.add('Pin No.');
	
	emailType	:= PINEmail_Prenote;							// ie 5
	emailName	:= ReleaseRequest_Prenote;						// ie 'Prenote'
	objectType	:= PINEmail_Object_TI;
	peDef		:= self.allPINObjectEmailDefaults[ emailType ].CM_PINObjectDefaultEmail;
	if peDef = null then
		create peDef persistent;
		peDef.setForCreate(	ETDef_FullReleaseTblData,
							sa,
							null,
							emailName,
							emailName,
							objectType,
							emailType,
							self,
							null,
							false,
							false );
	else
		// update those that can NOT be changed by the users.
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::name.name, emailName );
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::objectType.name, objectType);
	endif;
	
	sa.clear;
	sa.add('Cargo ID');
	sa.add('Pin No.');
	
	emailType	:= PINEmail_PrenoteDelete;						// ie 6
	emailName	:= ReleaseRequest_PrenoteDeleted;				// ie 'Prenote Deleted'
	objectType	:= PINEmail_Object_TI;
	peDef		:= self.allPINObjectEmailDefaults[ emailType ].CM_PINObjectDefaultEmail;
	if peDef = null then
		create peDef persistent;
		peDef.setForCreate(	ETDef_FullReleaseTblData,
							sa,
							null,
							emailName,
							emailName,
							objectType,
							emailType,
							self,
							null,
							false,
							false );
	else
		// update those that can NOT be changed by the users.
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::name.name, emailName );
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::objectType.name, objectType);
	endif;
	
	emailType	:= PINEmail_PrenoteCustomsInspect;				// ie 7
	emailName	:= ReleaseRequest_CustomsPrenote;				// ie 'Customs Inspection Prenote'
	objectType	:= PINEmail_Object_TI;
	peDef		:= self.allPINObjectEmailDefaults[ emailType ].CM_PINObjectDefaultEmail;
	if peDef = null then
		create peDef persistent;
		peDef.setForCreate(	ETDef_FullReleaseTblData,
							sa,
							null,
							emailName,
							emailName,
							objectType,
							emailType,
							self,
							null,
							false,
							false );
	else
		// update those that can NOT be changed by the users.
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::name.name, emailName );
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::objectType.name, objectType);
	endif;
	
	sa.clear;
	sa.add('Release No (Booking Ref)');
	sa.add('Carrier');
	sa.add('Consignee');
	
	emailType	:= PINEmail_ReleaseStatusPending;				// ie 8
	emailName	:= ReleaseRequest_StatusPending;				// ie 'Release Request Status Change From Active To Pending'
	objectType	:= PINEmail_Object_BR;
	peDef		:= self.allPINObjectEmailDefaults[ emailType ].CM_PINObjectDefaultEmail;
	if peDef = null then
		create peDef persistent;
		peDef.setForCreate(	ETDef_MTReleaseDataTable,
							sa,
							null,
							emailName,
							emailName,
							objectType,
							emailType,
							self,
							null,
							false,
							false );
	else
		// update those that can NOT be changed by the users.
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::name.name, emailName );
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::objectType.name, objectType);
	endif;
	
	emailType	:= PINEmail_ReleaseStatusActive;				// ie 9
	emailName	:= ReleaseRequest_StatusActive;					// ie 'Release Request Status Change To Active'
	objectType	:= PINEmail_Object_BR;
	peDef		:= self.allPINObjectEmailDefaults[ emailType ].CM_PINObjectDefaultEmail;
	if peDef = null then
		create peDef persistent;
		peDef.setForCreate(	ETDef_MTReleaseDataTable,
							sa,
							null,
							emailName,
							emailName,
							objectType,
							PINEmail_ReleaseStatusActive,
							self,
							null,
							false,
							false );
	else
		// update those that can NOT be changed by the users.
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::name.name, emailName );
		peDef.setPropertyValue( CM_PINObjectDefaultEmail::objectType.name, objectType);
	endif;
	
		
epilog
	delete sa;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="98124f0a-b014-4be0-a13b-c7b32147b99d">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//--------------------------------------------------------------
//Created: 20 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if _property = null or
		_property.name = CM_Terminal::logNextSeqNoNumber.name or
		_property.name = CM_Terminal::logNextSeqNumber.name or
		_property.name = CM_Terminal::stockOrderNextSeqNumber.name or
		_property.name = 'bank' or
		_property.name = 'bolInNextSeqNumber' or
		_property.name = 'bolOutNextSeqNumber' or
		_property.name = 'gatePassNextSeqNumber' or
		_property.name = 'configuration' or
		_property.name = 'railJobSheet' or
		_property.name = 'roadJobSheet' or
		_property.name = 'layout' or
		_property.name = 'yardJobSheet' then
		return false;						
	endif;

	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="stockOrderNextSeqNumber" id="5ee9b3a1-1343-447d-b06b-9e9a709f469c">
        <methodInvocation>mapping</methodInvocation>
        <source>stockOrderNextSeqNumber(set: Boolean; _value: String io) mapping;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
constants
	KeyDesc = 'Stock Order Sequence Number';
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	prefix,
	suffix 			: String;
	root 			: Integer;
	keyLocked		: Boolean;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);	
		return;
	endif;
	
	//17 May 2012	NDL	Par 28193 - Being a mapping method this is
	// called from CardSchema when a system dump is being performed... 
	// If we are not in trans state, the crash caused by the 1048,
	// means we don't get the rest of the details for terminal in the dump
	if not self.isTransient then
		if not process.isInTransactionState then
			return;
		endif;
	endif;

	theKeySeries := self.allKeySeriesByCode[SN_StockOrderSeqNo];
	
	if theKeySeries = null then
		create theKeySeries persistent;
		theKeySeries.set(SN_StockOrderSeqNo, KeyDesc, self);
		create seriesKey persistent;
		seriesKey.set(self.code, 1);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		if seriesKey.prefix &lt;&gt; self.code then
			//Termnal code has changed, update key series
			seriesKey.set(self.code, seriesKey.root);
		endif;
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);
	keyLocked := true;	//17 May 2012	NDL	Par 28193

	theKeySeries.reserve(app.computerName, process.signOnUserCode, prefix, root, suffix);
	theKeySeries.issue(app.computerName, process.signOnUserCode);

	_value := prefix &amp; root.String;	// suffix not used at present.
	//_value := self.code &amp; self.stockOrderLastSeqNumber.String;
	
epilog
	if keyLocked then	//17 May 2012	NDL	Par 28193
		unlock(theKeySeries);
	endif;		
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tbaNextSeqNumber" id="dcfc29c6-563b-425e-8104-fe445796c00c">
        <updating/>
        <source>tbaNextSeqNumber() : String updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	KeyDesc = 'To Be Advised ID serialisation';
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	prefix,
	suffix 			: String;
	root 			: Integer;	
begin

	prefix := "TBA";

	theKeySeries := self.allKeySeriesByCode[SN_TBA];
	
	if theKeySeries = null then
		create theKeySeries persistent;
		theKeySeries.set(SN_TBA, KeyDesc, self);
		create seriesKey persistent;
		seriesKey.set(prefix, 1);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		if seriesKey.prefix &lt;&gt; prefix then
			seriesKey.set(prefix, 1);
		endif;
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);

	theKeySeries.reserve(app.computerName, process.signOnUserCode, prefix, root, suffix);
	theKeySeries.issue(app.computerName, process.signOnUserCode);

	return prefix &amp; root.padLeadingWith("0",7);	

epilog
	unlock(theKeySeries);		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="testYAOverstowTI" id="7b0dffbb-8ac2-410e-96fb-4b728453e038">
        <source>testYAOverstowTI( _trackedItem : CM_TrackedItem ): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2011	cnwrd1	Initial creation

*/

vars

begin
	if self.myYAConfig = null then
		return false;
	endif;
	
	//need to test the ya config option here.
	if self.myYAConfig.autoPlanOverstowRule = app.getErrorStringShortText(CMUI_YAConfigForm_HookCode).Integer +1 then
		return self.myYAConfig.testYAOverstowTI(_trackedItem);	
	else
		return false;
	endif;
	
	
	
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateKPICargoCounterByDate" id="1357f4f3-4f09-443a-9a64-85a70fad70a1">
        <updating/>
        <source>updateKPICargoCounterByDate(_startDate, _endDate : Date; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			_startDate, _endDate - the date range to calculate cargo counters for

Return Value:		

Date		Who		Reason
08/09/2010	cnwdap1	Initial creation PAR #25163 CCMS SFW 1108 TEU Counter
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

constants
	MaxTimeBetweenTransactions	= 2000;		// 2 seconds
	
vars
	startD, endD, kpiDate 		: Date;
	kpiCargo					: CM_KPICargoEntity;
	allTITransactions 			: CM_TITransactionByTypeDateDict;
	tiTxn 						: CM_TITransaction;
	cargoType					: CM_CargoType;
	startTS, endTS, timeStamp	: TimeStamp;
	lastTransCommitTime, now	: Decimal[20];
	iterator 					: Iterator; //cnwas3
	dt							: Date;
	root						: CM_Root;
begin
	// do a bit of fiddling with the dates - if they're &gt;= today, drop them back to yesterday
	// (this process only counts full days of data)
	dt	   := app.actualTimeServer.Date;
	startD := _startDate;
	
	if _startDate &gt; dt then
		startD := dt - 1;
	endif;
	endD := _endDate;
	if _endDate &gt; dt then
		endD := dt - 1;
	endif;
	if startD &gt; endD then
		startD := endD;
	endif;
	app.writeLog("Terminal " &amp; self.code &amp; " -  Start Date is " &amp; startD.asStringJMT &amp; ", End Date is " &amp; endD.asStringJMT, LogINFO);
	
	// clear all existing KPICargoEntity objects for the date range
	app.writeLog("Terminal " &amp; self.code &amp; " - Deleting KPI count data for the date range", LogINFO);
	lastTransCommitTime := app.relativeMachineTime();
	
	iterator := self.allKPICargo.createIterator();
	self.allKPICargo.startKeyGeq(startD.TimeStamp,null,iterator);
	
	while iterator.next(kpiCargo) do 
		kpiDate := iterator.getCurrentKey(1).Date;
		if kpiDate &lt; startD or kpiDate &gt; endD then
			continue;
		endif;

		// check if we need to commit
		now := app.relativeMachineTime;
		if now - lastTransCommitTime &gt; MaxTimeBetweenTransactions then
			_passport.doDeferredUpdates();
			app.cmsCommitTransaction(_passport);
			lastTransCommitTime := app.relativeMachineTime();
			beginTransaction;
		endif;
		
		// delete the existing KPI data
		//kpiDate := kpiCargo.dateTime.Date;
		//if kpiDate &gt;= startD and kpiDate &lt;= endD then
		delete kpiCargo;
		//endif;
	endwhile;
	//endforeach;				//- cnwas3
	
	_passport.doDeferredUpdates();
	app.cmsCommitTransaction(_passport);	// so finding all the receipt transactions doesn't happen in transaction state
	
	// for each date in the date range, get TI transactions for selected transaction types
	create allTITransactions transient;
	startTS.setDate(startD);
	startTS.setTime(null);
	endTS.setDate(endD);
	endTS.setTime("23:59:59".Time);
	self.getTITxnsForTypeAdvanced(	TRANS_TYPE_REASSEMBLY, 			startTS, endTS, null, null, allTITransactions	);
	self.getTITxnsForTypeAdvanced(	TRANS_TYPE_RECEIVE, 			startTS, endTS, null, null, allTITransactions	);
	self.getTITxnsForTypeAdvanced(	TRANS_TYPE_REC_RAIL, 			startTS, endTS, null, null, allTITransactions	);
	self.getTITxnsForTypeAdvanced(	TRANS_TYPE_REC_RAIL_INTER_TERM, startTS, endTS, null, null, allTITransactions	);
	self.getTITxnsForTypeAdvanced(	TRANS_TYPE_REC_ROAD, 			startTS, endTS, null, null, allTITransactions	);
	self.getTITxnsForTypeAdvanced(	TRANS_TYPE_REC_ROAD_INTER_TERM, startTS, endTS, null, null, allTITransactions	);
	self.getTITxnsForTypeAdvanced(	TRANS_TYPE_REC_SHIP, 			startTS, endTS, null, null, allTITransactions	);
	self.getTITxnsForTypeAdvanced(	TRANS_TYPE_EXPORT_RETURNED, 	startTS, endTS, null, null, allTITransactions	);
	self.getTITxnsForTypeAdvanced(	TRANS_TYPE_ReinstateReject, 	startTS, endTS, null, null, allTITransactions	);
	self.getTITxnsForTypeAdvanced(	TRANS_TYPE_BUSINESS_U_RECEIVE, 	startTS, endTS, null, null, allTITransactions	);
	self.getTITxnsForTypeAdvanced(	TRANS_TYPE_REC_TRANSHIP, 		startTS, endTS, null, null, allTITransactions	);
	
	// read all accumulated ti transactions
	app.writeLog("Terminal " &amp; self.code &amp; " -  Processing " &amp; allTITransactions.size.String &amp; " TI transactions", LogINFO);
	lastTransCommitTime := app.relativeMachineTime();
	beginTransaction;
	foreach tiTxn in allTITransactions discreteLock do
		// do we need to commit?
		now := app.relativeMachineTime;
		if now - lastTransCommitTime &gt; MaxTimeBetweenTransactions then
			_passport.doDeferredUpdates();
			app.cmsCommitTransaction(_passport);
			lastTransCommitTime := app.relativeMachineTime();
			beginTransaction;
		endif;
		
		// create / update a KPICargoEntity object for terminal/cargo type/date
		cargoType := root.allCargoTypesById[tiTxn.myTrackedItem.cargoType];
		timeStamp.setDate(tiTxn.dateTime.Date);
		timeStamp.setTime(null);
		kpiCargo := self.allKPICargo[timeStamp, cargoType];
		if kpiCargo = null then
			create kpiCargo persistent;
			kpiCargo.setKeys(self, cargoType, timeStamp.Date);
		endif;
		kpiCargo.addTransaction(tiTxn);
	endforeach;
	
	// mark the terminal as having been processed up to the end date
	// We may not be in transaction state here if the terminal had no KPI data to process
	if not process.isInTransactionState then
		beginTransaction;
	endif;
	self.lastKPICargoCounterBuild := endTS;
epilog
	delete allTITransactions;
	delete iterator;		// PAR #26678
	
end;</source>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateKPICargoCounterForBGP" id="e3c677aa-fdb7-4f2c-85c7-6821273d205d">
        <updating/>
        <source>updateKPICargoCounterForBGP(_startDate, _endDate : Date; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2010	cnwdap1	Initial creation PAR #25163 CCMS SFW 1108
*/
vars
	fromDate, toDate : Date;

begin
	// have we already run the stats for yesterday?
	if _startDate = null then		// we're a scheduled run, not an ad-hoc one
		if app.actualTimeServer.Date - 1 = self.lastKPICargoCounterBuild.Date then
			app.writeLog('Terminal ' &amp; self.code &amp; ' - KPI Cargo Counter - already run for ' &amp; self.lastKPICargoCounterBuild.Date.asStringJMT &amp; ' - stopping', LogINFO);
			return;
		endif;
	endif;
	
	if _startDate = null then
		app.writeLog('KPI Cargo Counter running from schedule', LogINFO);
		fromDate 	:= self.lastKPICargoCounterBuild.Date;
		toDate 		:= app.actualTimeServer.Date - 1;
	else
		fromDate	:= _startDate;
		toDate		:= _endDate;
	endif;
	app.writeLog('Terminal ' &amp; self.code &amp; ' - KPI Cargo Counter - running for start date ' &amp; fromDate.asStringJMT &amp; ' and end date ' &amp; toDate.asStringJMT, LogINFO);
	self.updateKPICargoCounterByDate(fromDate, toDate, _passport);
epilog

end;</source>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateVehicle" id="686d89c9-0f18-4abc-ae4b-de2a2f8a7b4c">
        <updating/>
        <source>updateVehicle(pRegNumber : String; pCarrier : CM_Carrier) updating;
// ---------------------------------------------------------------------------
// Created:     06 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  -------------------------------------------------
vars
	theVehicle	: CM_Vehicle;
	
begin
	theVehicle := self.vehicles[pRegNumber, ""];
	if theVehicle = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Cannot update - vehicle not found!');
		return;
	endif;
	
	theVehicle.set(pRegNumber, pCarrier);

end;</source>
        <Parameter name="pRegNumber" type="String"/>
        <Parameter name="pCarrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageFromVessel" id="0d56277e-202f-42ba-8d63-e6ffb977e209">
        <updating/>
        <source>updateVoyageFromVessel(_realVessel : CM_Vessel; _origVesselCode : String; _fromDT : TimeStamp; _passport : CM_Passport input)updating;
//--------------------------------------------------
// Created:	06 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	iter		: Iterator;
	tmpVoyage 	: CM_Voyage;
	tmpFromDT	: TimeStamp;
	
begin
	if _realVessel = null then
		return;
	endif;
	
	if _fromDT.isValid() then
		tmpFromDT := _fromDT;
	else
		tmpFromDT := app.serverTimestampAtTrxStart;
	endif;
	
	// need to check the departed date, not the arrival so don't use tmpFromDT as iter key
	iter := self.allVoyagesByVesselCodeArrivDT.createIterator();
	self.allVoyagesByVesselCodeArrivDT.startKeyGeq(_origVesselCode, null, iter);
	
	while iter.next(tmpVoyage) do
		if tmpVoyage.vesselCode &lt;&gt; _origVesselCode then
			break;
		endif;
		
		if (not tmpVoyage.departedDT.isValid())
		or tmpVoyage.departedDT &gt;= tmpFromDT
		then
			// departs after date to check therefore it qualifies	
			tmpVoyage.updateVoyageFromVessel(_realVessel, _passport);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_realVessel" type="CM_Vessel"/>
        <Parameter name="_origVesselCode" type="String"/>
        <Parameter name="_fromDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageStatistic" id="a7cc99ae-de89-442a-ab02-024b30214ae8">
        <source>updateVoyageStatistic(_code, _unitOfMeasure : String; _group : Integer; _monthYear : Date; _value : Real; _passport : CM_Passport input);
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpVoyageStat : CM_VoyageStatistic;
begin
	
	tmpVoyageStat := self.allVoyageStatistics[_monthYear, _group, _code];
	
	if tmpVoyageStat = null then
		create tmpVoyageStat persistent;
		tmpVoyageStat.set(_code, _unitOfMeasure, _group, _monthYear, self, _passport);		
	endif;
	
	tmpVoyageStat.updateAddValue(_value);
	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_unitOfMeasure" type="String"/>
        <Parameter name="_group" type="Integer"/>
        <Parameter name="_monthYear" type="Date"/>
        <Parameter name="_value" type="Real"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateBOLInDate" id="97e6fa69-2426-4133-ae03-cdeb602316e8">
        <source>validateBOLInDate(_ts : TimeStamp) : Boolean;
// ---------------------------------------------------------------------------
// Created:     24 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	checkPeriod		: Integer;

begin
	checkPeriod := self.getConfig(BOLDuplicateCheckPeriod).Integer;

	if checkPeriod = 0 then
		// no check done
		return true;
	endif;
	
	if _ts.date &lt; (app.serverTimestampAtTrxStart.date - checkPeriod) then
		return true;
	endif;
	
	return false;
	
end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateBulkReleaseNumber" id="58493239-ff58-414c-a4ca-9b539f19c8c3">
        <source>validateBulkReleaseNumber(_bulkRelease : CM_BulkRelease; _errStr : String);
//------------------------------------------------
// Created: 10 April 2006 By: cnwgd1
//------------------------------------------------
// 09/12/2014 cnwdb2 PAR 35364

vars
	bulkRel : CM_BulkRelease;
	tmpStr : String;
begin
	
	if _bulkRelease = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _bulkRelease');
		return;
	endif;
	
	if _errStr = null then
		tmpStr := 'Bulk Release';
	else
		tmpStr := _errStr;
	endif;
	
	if self.getConfig(AllowDuplicateReleaseNos).Boolean then
		if self.allBulkReleasesByCodeDate[_bulkRelease.code, _bulkRelease.dateRequested] &lt;&gt; null then // AKB2005MAY
		//	app.raiseCMException3(ERR_DUPLICATE_KEY, tmpStr, _bulkRelease.code," For requested Date Time '" &amp; _bulkRelease.dateRequested.String &amp; "'" ,'code', null);
			app.raiseCMException3(Already_exists_bulkFrReqst, tmpStr, _bulkRelease.code,_bulkRelease.dateRequested.String,'code', null); // cnwdb2 PAR 35364
		endif;		
	else
		bulkRel := self.allBulkReleasesByCodeDate.getAtKeyLeq(_bulkRelease.code, null);
		if bulkRel &lt;&gt; null and bulkRel.code = _bulkRelease.code then 
			app.raiseCMException2(ERR_DUPLICATE_KEY, tmpStr, _bulkRelease.code, ETRow_Code, null);
		endif;
	endif;
end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_errStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateCanCreateVoyageRequest" id="f91b0e3a-5b91-401d-9e09-38a0964ea867">
        <source>validateCanCreateVoyageRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlger1	Initial creation
11 Oct 2021	jlier1	TFS 51963
*/

vars
	voyageStatus : CM_VoyageStatus;
	voyProcessDesc : String;
	voyageProcess : CM_VoyageProcess;
begin

	voyageProcess := self.getDefaultVoyageProcess;
	if voyageProcess &lt;&gt; null then
		voyProcessDesc:=voyageProcess.description;
		voyageStatus:=voyageProcess.allStatuses.first ;
	endif;
	
	if voyageStatus = null or (voyageStatus.id &lt;&gt;  Voyage_Status_VoyRequested )  then
		//raise exception
		app.raiseCMException1(Voyage_process_create_voyage,voyProcessDesc,null,null);
		return;
	endif;
	
	if not voyageStatus.userCanSet(self) then
		app.raiseCMException2(Cannot_Set_Voyage_Status, self.code, voyProcessDesc, "status", null);	// TFS 37445
		return;		
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateCollection" id="8ff54160-ebf0-4fb5-b466-a52a28ffab7e">
        <source>validateCollection(pTerminalCol, pRootCol : Collection; pController : CnEcReleaseController) protected;
// ---------------------------------------------------------------------------
// Created:     06 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	s1, s2	: Integer;
	err		: String;

begin

	s1 := pTerminalCol.size;
	s2 := pRootCol.size;
	
	if s1 &lt;&gt; s2 then
		err := Tab &amp; '&lt;&lt;&lt;&lt;&lt;&lt; ERROR';
	endif;
	
	pController.logEntry('CM_Terminal::validateCollection &gt;&gt; ' &amp; 
					pTerminalCol.class.name &amp; ': ' &amp; s1.String &amp; Tab &amp;
					pRootCol.class.name &amp; ': ' &amp; s2.String &amp; err);
		  
end;</source>
        <access>protected</access>
        <Parameter name="pTerminalCol" type="Collection"/>
        <Parameter name="pRootCol" type="Collection"/>
        <Parameter name="pController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="3e282829-de26-4db3-9afe-38ea230b35be">
        <source>validateForCreate();
vars
	allTerminals	: ObjectArray;
	numExisting,
	numAllowed		: Integer;

begin

	// now check this will not exceed number of licensed terminals
	create allTerminals transient;
	//epr par 16884 shouldn't be counting CM_TerminalScenarios as well 
	CM_Terminal.allInstances(allTerminals, 0, false);
	
	numExisting := allTerminals.size;
	if numExisting &gt; 0 then
		// need to check how many are licensed for
		numAllowed := app.myRoot.numTerminalsAllowed();
		if numExisting + 1 &gt; numAllowed then
			app.raiseCMException1(ErrNumberOfLicensedTerminals, numAllowed.String, null, null);
			return;
		endif;
	endif;

	self.validateMe();

epilog
	delete allTerminals;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForShiftGaps" id="f421e1c2-3de8-4229-9086-5d9ac1e73120">
        <source>validateForShiftGaps() : String;
// ---------------------------------------------------------------------------
// Created:     09 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 21305
// ---------------------------------------------------------------------------

vars
	term : CM_Terminal;
	now : TimeStamp;
	shft, lastShift : CM_ShiftStd;
	day : Integer;
	daysMissing : Boolean;
	thisTime, lastTime : Time;
	messStr : String;
begin
	term := self;
	thisTime := null;
	lastTime := null;
	
	foreach day in  1 to 7 do
		shft := term.allShiftsStandard.getAtKeyGeq(day,null);
		if shft = null or shft.shiftDay &lt;&gt; day then
			messStr := messStr &amp; Cr &amp; app.getErrorString1(NO_Shifts, app.getShiftDayStrFromType(day));
			daysMissing := true;
		endif;
	endforeach;
	
	if not daysMissing then
	
		shft := term.allShiftsStandard .first;
		lastShift := term.allShiftsStandard.last;
		
		if (shft &lt;&gt; null and lastShift &lt;&gt; null)
		and (shft.startTime &lt;&gt; lastShift.endTime) then
			messStr := messStr   &amp; Cr &amp; app.getErrorString2(Missing_shift_between, lastShift.getShiftDay() &amp; " " &amp; lastShift.endTime.asStringJMT(), shft.getShiftDay() &amp; " " &amp; shft.startTime.asStringJMT());
		endif;
		
		foreach shft in term.allShiftsStandard discreteLock do
			thisTime := shft.startTime;
			if lastTime &lt;&gt; null then
				if lastTime &lt;&gt; thisTime then
		//			messStr := messStr &amp;   "Missing Shift between " &amp; lastShift.getShiftDay &amp; " " &amp; lastTime.asStringJMT() &amp; " &amp; " &amp; shft.getShiftDay &amp; " " &amp; thisTime.asStringJMT() &amp; Cr;
					messStr := messStr   &amp; Cr &amp; app.getErrorString2(Missing_shift_between, lastShift.getShiftDay() &amp; " " &amp; lastTime.asStringJMT(), shft.getShiftDay() &amp; " " &amp; thisTime.asStringJMT());
				endif;
			endif;
			
			lastTime := shft.endTime;
			lastShift := shft;
		endforeach;
	endif;

	return messStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="9f949a1c-2354-42c4-b627-6b75fcb08f94">
        <source>validateForUpdate();

vars
begin

	self.validateMe();
		
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="dd657d44-8293-472f-af1a-b9a4866c4ef2">
        <source>validateMe() protected;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/10/2008	consw1		SFW1030 - Rework of Yard Allocations
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable

vars
	realTerm,
	tmpTerm		: CM_Terminal;
	cargoBoL	: CM_CargoBOLType;
	exist		: Boolean;
	default		: Integer;
	
begin

	realTerm := self.pxyGetRealObject().CM_Terminal;

	if self.code.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, CM_Terminal::code.name, ETRow_Code, null);
		app.raiseCMException1(Input_required_field_Required, CM_Terminal::code.name, ETRow_Code, null); // cnwdb2	PAR 35364
	else
		tmpTerm := app.myRoot.allTerminals[self.code];
		if tmpTerm &lt;&gt; null and tmpTerm &lt;&gt; self.pxyGetRealObject then
			//app.raiseCMException2(DuplicateItem, 'Terminal', self.code, ETRow_Terminal, null); //14.06.2022 navds20 53760
			// Terminal already exists for %1 : Terminal_already_exists
			app.raiseCMException1(Terminal_already_exists, self.code, ETRow_Terminal, null); //14.06.2022 navds20 53760
		endif;
	endif;
	
	if self.name.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, CM_Terminal::name.name, ETRow_Name, null);
		app.raiseCMException1(Input_required_field_Required, CM_Terminal::name.name, ETRow_Name, null); // cnwdb2	PAR 35364
	endif;

	exist	:=	false;
	default	:=	self.defaultCargoBolType;

	foreach cargoBoL in self.allCargoBOLTypes do
		if cargoBoL.id = default then
			exist	:=	true;
			break;
		endif;
	endforeach;
	
	if (not exist) then
		app.raiseCMException1(ERR_CARGOBOLTYPE_DEFAULT,self.name,null,null);
	endif;
	
	if realTerm &lt;&gt; null then
		// we must be updating
		foreach cargoBoL in realTerm.allCargoBOLTypes where 
				(not self.allCargoBOLTypes.includes(cargoBoL)) do
			// Raise an exceptioin if any current on-site Cargo/BoL item's type 
			// has been removed from the list of selected Cargo/BoL types for this terminal.
			if cargoBoL.isCargoType then
				if realTerm.hasTrackedItemForCargoType(cargoBoL.id, true) then //22 Sep 2008 cnwdz2	 Par17976; Par16909 - Fix invalid property value error on Confirm Wagon Window.
					// raise exception error
					app.raiseCMException2(ERR_CargoTypeHasCargoOnSite, cargoBoL.abbreviation, self.name, null,null);
				endif;
			else
				if realTerm.hasBOLForType(cargoBoL.id) then //22 Sep 2008 cnwdz2 Par17976;
					// raise exception error
					app.raiseCMException2(ERR_CargoTypeHasCargoOnSite, cargoBoL.abbreviation, self.name, null,null);
				endif;
			endif;
		endforeach;
	endif;
		
//	if self.allRTAllocationCriteriaTypes.size() &gt; self.RT_CriteriaLimit then
//		app.raiseCMException1(RT_Criteria_Too_Many, self.RT_CriteriaLimit.String, null, null);
//	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateOnsiteTrackedItemIDs" id="32236cec-87c5-4647-a338-0cb6b5b959c6">
        <source>validateOnsiteTrackedItemIDs(_cargoType : Integer; _ids : StringArray; _foundIds : StringArray input; 
							_raiseException, _ignoreUnscaled : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     02 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	unscaledDict,
	onsiteDict		: CM_TIByIdCargoTypeDict;
	noneFound	: Boolean;
	errArray	: StringArray;
	errStr,
	idStr,
	termStr		: String;
	pos			: Integer;
	needBeginLoad	: Boolean;
begin
	noneFound := true;

	create errArray transient;

	needBeginLoad := process.isInLoadState;
	
	// because the dict we are checking here has high-contention
	// we explicitly endLoad here and release any locks caused
	// by this method
	if needBeginLoad then
		endLoad;
	endif;
	beginLoad;
	
	onsiteDict 		:= self.allOnsiteTIsByIdCargoType;
	if _ignoreUnscaled then
		unscaledDict	:= self.allUnscaledLogsByIdCargoType;
	endif;
	
	foreach idStr in _ids do
		if onsiteDict.includesKey(idStr, _cargoType) then
			if _ignoreUnscaled and unscaledDict.includesKey(idStr, _cargoType) then
				continue;
			endif;
			if _raiseException then
				errArray.add(idStr &amp; '::' &amp; self.code);
			endif;
			if _foundIds &lt;&gt; null then
				_foundIds.add(idStr);
			endif;
			noneFound := false;
		endif;
	endforeach;
	
	endLoad;		// free up lock on dict

	if _raiseException then
		foreach errStr in errArray do
			pos := errStr.pos('::', 1);
			if pos &gt; 0 then
				idStr 	:= errStr[1:pos-1];
				termStr	:= errStr[pos+2:end];
			else
				idStr 	:= '&lt;unknown&gt;';
				termStr	:= '&lt;unknown&gt;';
			endif;
			app.raiseCMException3(ERR_TI_ONSITE, 'Log', idStr, termStr, ETRow_Id, null);
		endforeach;
	endif;

	return noneFound;

epilog
	endLoad;
	if needBeginLoad then
		beginLoad;
	endif;
	delete errArray;

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_ids" type="StringArray"/>
        <Parameter name="_foundIds" type="StringArray" usage="input"/>
        <Parameter name="_raiseException" type="Boolean"/>
        <Parameter name="_ignoreUnscaled" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTerminalsForRelease" id="e67c2c7b-cf6c-4169-aa1a-80d0b3c7366e">
        <source>validateTerminalsForRelease(_otherTerminals : CM_TerminalSet) : Boolean;
// ---------------------------------------------------------------------------
// Created:     19 June 2008 by cnwab1
//
// Purpose:      PAR 17132 If they are removing a terminal, check whether there are any bulk releases set up to use that terminal for transfers.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	
// ---------------------------------------------------------------------------

vars
	aBR : CM_BulkRelease;
	tmpTerm : CM_Terminal;
begin
	if self.allTerminalsForRelease.membersSame(_otherTerminals) then
		return true;
	endif;


	foreach tmpTerm in self.allTerminalsForRelease  discreteLock do
		if not _otherTerminals.includes(tmpTerm) then // removing a terminal
			foreach aBR in self.allBulkReleaseByTypeByStByCd discreteLock where aBR.status = BR_ACTIVE do
				if aBR .myTransferToTerminal = tmpTerm then
					app.raiseCMException3(ERR_INTER_TERM_BR,self.code, tmpTerm.code, " See release request '" &amp; aBR.code &amp; "' for terminal " &amp; self.code &amp; ".",null,self);
					return false;
				endif;
			endforeach;
		endif;
	endforeach;
	return true;
end;</source>
        <Parameter name="_otherTerminals" type="CM_TerminalSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTicketSequence" id="6f2a6c32-28f0-40a7-8e4c-7d5e33baedd9">
        <source>validateTicketSequence(_ticketSeqSet : CM_TicketSequenceSet; _ticketSeq : CM_TicketSequence);
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
//The passed in _bol can be null if validating from the CMUI_TicketSequenceFrom modal, the set should not be null
//_bol should not be null when validating from Road Entry doSave but the set will be null
vars
	bol	: CM_BOL;
	ti	: CM_TrackedItem;
	id	: String;
	seq : CM_TicketSequence;
	pseudoIdArray : StringArray;
	rtValue : Boolean;
	ls			: Boolean;
begin

	create pseudoIdArray transient;
	
	app.cmsBeginLoad(ls);
	//Get ids of passed in set
	if _ticketSeqSet &lt;&gt; null and not _ticketSeqSet.isEmpty then
		foreach seq in _ticketSeqSet do
			if seq &lt;&gt; _ticketSeq then
				seq.allTicketIds.copy(pseudoIdArray);
			endif;
		endforeach;
		//Check against passed in set
		if _ticketSeq &lt;&gt; null then	
			rtValue := _ticketSeq.validateTicketSequenceId(pseudoIdArray);
			if not rtValue then
				return;
			endif;
		endif;
	endif;

	//Check against unmatched ticket sequences	
	pseudoIdArray.clear();
	self.getIdsOfUnmatchedTickets(pseudoIdArray, null);
	if _ticketSeq &lt;&gt; null then	
		rtValue := _ticketSeq.validateTicketSequenceId(pseudoIdArray);
		if not rtValue then
			return;
		endif;
	endif;

	//Check against onsite Logs
	if _ticketSeq &lt;&gt; null then	
		rtValue := self.validateTicketSequenceId(_ticketSeq);
		if not rtValue then
			return;
		endif;
	endif;
		
epilog
	app.cmsEndLoad(ls);
	delete pseudoIdArray;		
end;</source>
        <Parameter name="_ticketSeqSet" type="CM_TicketSequenceSet"/>
        <Parameter name="_ticketSeq" type="CM_TicketSequence"/>
    </JadeMethod>
    <JadeMethod name="validateTicketSequenceId" id="90e34f7d-cc2f-4272-a5cc-c37e17b93f90">
        <source>validateTicketSequenceId(_ticketSeq : CM_TicketSequence) : Boolean protected;
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
constants 
	MsgStr = "in the Database. These entries must be unique.";
vars
	id	: String;
	ext	: CM_BOLExtLogIn;
	
begin

	if _ticketSeq &lt;&gt; null then
		foreach id in _ticketSeq.allTicketIds do	
			if self.allOnsiteTIsByIdCargoType.includesKey(id, TI_CargoType_Log) then
				app.raiseCMException3(ERR_DUPLICATED_LABEL, 'Log ID', id, MsgStr, ETRow_FromId, self);
				return false;	//One duplicate is all we need to quit
			endif;
		endforeach;
	endif;				
			
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_ticketSeq" type="CM_TicketSequence"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTicketSequenceSet" id="93b39c6a-3149-4283-b713-726c064dc680">
        <source>validateTicketSequenceSet(_set : CM_TicketSequenceSet) : Boolean;
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
constants 
	MsgStr = "in the Database. These entries must be unique.";
vars
	id	: String;
	seq : CM_TicketSequence;
	ext	: CM_BOLExtLogIn;
	
begin

	foreach seq in _set do
		foreach id in seq.allTicketIds do
			if self.allOnsiteTIsByIdCargoType.includesKey(id, TI_CargoType_Log) then
				app.raiseCMException3(ERR_DUPLICATED_LABEL, 'Log ID', id, MsgStr, ETRow_FromId, self);
				return false;	//One duplicate is all we need to quit
			endif;
		endforeach;
	endforeach;

	return true;
end;</source>
        <Parameter name="_set" type="CM_TicketSequenceSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTrade" id="3a6e50fb-f3f8-4a1f-a4e0-ca7ca2393f5b">
        <source>validateTrade(id : String;
						operatorCode : String;
						imExStatus : Integer;
						loadPort : String;
						dischargePort : String;
						voyageCode : String) : Integer;

vars
	debtor : CM_Debtor;
	port : CM_Port;
	shipPort : CM_ShipPort;
	spg : CM_ShipPortGroup;
	str : String;
	result : Integer;
	voyage : CM_Voyage;
	sl : CM_ShippingLine;
	operatorOid : CM_Operator;

begin


	voyage := self.lookupVoyage(voyageCode, null, false);
	if voyage = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_VOYAGE, voyageCode, null, null);
		return 0;
	endif;
	sl := voyage.myShippingLine;
	if sl = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_SHIPPINGLINE_INVALID, voyageCode, null, null);
		return 0;
	endif;
	operatorOid := app.myRoot.allOperators[operatorCode];
	if operatorOid = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_OPERATOR, operatorCode, null, null);
		return 0;
	endif;
	if  (imExStatus = TI_IMEX_STATUS_IMPORT) then
		//port := app.myRoot.allPorts[loadPort];
		port := app.myRoot.allPorts[loadPort];
		shipPort := port.shippingPorts[voyage.myShippingLine.code];
		if shipPort &lt;&gt; null then
			spg := shipPort.shipPortGroup;
			if spg &lt;&gt; null then
				str := spg.shippingLine.code.padBlanks(4) &amp; spg.code.padBlanks(4) &amp;operatorOid.debtor.name;
				if spg.lineGroupDebtors[str] = null then
					app.setContinueCMExceptions(false);
					app.raiseCMException3(WARN_LGD_SHIPPINGLINE, id,  operatorOid.debtor.name, dischargePort, null, null);
					return 0;
				endif;
			else
				app.setContinueCMExceptions(false);
				app.raiseCMException3(WARN_LGD_SHIPPINGLINE, "",  operatorOid.debtor.name, loadPort, null, null);
				return 0;
			endif;
		else
			app.setContinueCMExceptions(false);
			app.raiseCMException3(WARN_LGD_SHIPPINGLINE, id,  operatorOid.debtor.name, loadPort, null, null);
			return 0;
		endif;
	elseif (imExStatus = TI_IMEX_STATUS_EXPORT) then
		//port := app.myRoot.allPorts[dischargePort];
		port := app.myRoot.allPorts[dischargePort];
		shipPort := port.shippingPorts[voyage.myShippingLine.code];
		if shipPort &lt;&gt; null then
			spg := shipPort.shipPortGroup;
			if spg &lt;&gt; null then
				str := spg.shippingLine.code.padBlanks(4) &amp; spg.code.padBlanks(4) &amp;operatorOid.debtor.name;
				if spg.lineGroupDebtors[str] = null then
					app.setContinueCMExceptions(false);
					app.raiseCMException3(WARN_LGD_SHIPPINGLINE, id,  operatorOid.debtor.name, dischargePort, null, null);
					return 0;
				endif;
			else
				app.setContinueCMExceptions(false);
				app.raiseCMException3(WARN_LGD_SHIPPINGLINE, id,  operatorOid.debtor.name, dischargePort, null, null);
			endif;
		else
			result := WARN_LGD_SHIPPINGLINE;
			app.setContinueCMExceptions(false);
			app.raiseCMException3(WARN_LGD_SHIPPINGLINE, id,  operatorOid.debtor.name, dischargePort, null, null);
		endif;
	elseif (imExStatus = TI_TransitStatusSOB) then
		if voyage.myDefaultLineGroupDebtor = null then
			app.setContinueCMExceptions(false);
			app.raiseCMException3(WARN_LGD_SHIPPINGLINE, id,  operatorOid.debtor.name, dischargePort, null, null);
		endif;
	elseif (imExStatus = TI_TransitStatusDLR) then
		if voyage.myDefaultLineGroupDebtor = null then
			app.setContinueCMExceptions(false);
			app.raiseCMException3(WARN_LGD_SHIPPINGLINE, id,  operatorOid.debtor.name, dischargePort, null, null);
		endif;
	elseif (imExStatus = TI_IMEX_STATUS_REMAINONBOARD) then
	elseif (imExStatus = TI_IMEX_STATUS_STORAGE) then
		//port := app.myRoot.allPorts[loadPort];
		port := app.myRoot.allPorts[loadPort];
		shipPort := port.shippingPorts[voyage.myShippingLine.code];
		if shipPort &lt;&gt; null then
			spg := shipPort.shipPortGroup;
			if spg &lt;&gt; null then
				str := spg.shippingLine.code.padBlanks(4) &amp; spg.code.padBlanks(4) &amp;operatorOid.debtor.name;
				if spg.lineGroupDebtors[str] = null then
					app.setContinueCMExceptions(false);
					app.raiseCMException3(WARN_LGD_SHIPPINGLINE, id,  operatorOid.debtor.name, dischargePort, null, null);
				endif;
			else
				app.setContinueCMExceptions(false);
				app.raiseCMException3(WARN_LGD_SHIPPINGLINE, id,  operatorOid.debtor.name, loadPort, null, null);
			endif;
		else
			app.setContinueCMExceptions(false);
			app.raiseCMException3(WARN_LGD_SHIPPINGLINE, id,  operatorOid.debtor.name, loadPort, null, null);
		endif;
	endif;

	return result;

end;</source>
        <Parameter name="id" type="String"/>
        <Parameter name="operatorCode" type="String"/>
        <Parameter name="imExStatus" type="Integer"/>
        <Parameter name="loadPort" type="String"/>
        <Parameter name="dischargePort" type="String"/>
        <Parameter name="voyageCode" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateVesselInPort" id="51311595-6269-43df-96b9-bdf37a2c9e75">
        <source>validateVesselInPort(_arriveDT, _departDT : TimeStamp; 	_theVessel : CM_Vessel; _theVoyage : CM_Voyage; _passport : CM_Passport input);
//--------------------------------------------------
// Created:	15 June 2005 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
04 Apr 2008	cnwkpd1	PAR #16373 - Also need to check linked voyages, and components of the same global voyage
08/08/2011	cnwmh5	#27968 - Add checking for cancelled voyages to be ignored
// 10 Sep 2019	cnwrs1	TFS 46030
*/

vars
	realVoyage,
	voyage			: CM_Voyage;
	tmpVessel		: CM_Vessel;
	iter			: Iterator;
	realVoyageGlobal,
	voyageGlobal	: CM_VoyageGlobal;

begin
 	// This method checks to see in the proposed visit for a ship is taking 
 	// place at the same time as an already booked visit of this ship - ie a 
 	// double entry of a booking.
 	if (not _arriveDT.isValid) then
		app.raiseCMException1(AutoScheduleDateError, 'Arrive Date/Time', ETRow_ArriveDT, null);
		return;
	endif;
	if (not _departDT.isValid) then
 		app.raiseCMException1(AutoScheduleDateError, 'Departure Date/Time', ETRow_DepartDT, null);
		return;
 	 endif;
 	 
	if _theVoyage = null then
		return;
	endif; 
	
	if _theVessel = null then
 		return;
 	endif;		

	// do not check same vessel in port for TBN vessel
	if _theVessel.isToBeNamed() then
		return;
	endif;

	if _theVoyage.isTransient then
		realVoyage := _theVoyage.pxyGetRealObject();
	endif;		
	
	if realVoyage = null then
		realVoyage := _theVoyage;
	endif;
	
	// PAR #16373
	realVoyageGlobal := realVoyage.getGlobalVoyage;
	
 	iter := self.allVoyagesByDepartDTCode.createIterator();
	self.allVoyagesByDepartDTCode.startKeyGeq(_arriveDT, null, iter);

 	while iter.next(voyage) do
 		if voyage.myHMSVoyageData = null then
 			//Only interested in voyages with harbour details
 			continue;
 		endif;
 		tmpVessel := voyage.getMyVessel();
 		if tmpVessel = null then
 			continue;
 		endif;
 		if tmpVessel &lt;&gt; _theVessel then
 			continue;
 		endif;
 		if voyage = realVoyage then
 			continue;
 		endif;

 		if voyage = _theVoyage then
 			continue;
 		endif; 
		
		if voyage.code = realVoyage.code then // same global voyage
			continue;
		endif;
		
		// PAR #16373 - if the two voyages are on the same global voyage, or they are in linked global 
		// voyeges, then skip the comparison
		if realVoyageGlobal &lt;&gt; null then
			voyageGlobal := voyage.getGlobalVoyage;
			
			// If they are on the same global voyage, then
			if realVoyageGlobal = voyageGlobal then
				continue;
			endif;
			
			if voyageGlobal &lt;&gt; null and realVoyageGlobal.isLinkedToVoyage(voyageGlobal) then
				continue;
			endif;
		endif;
		
		// Test for overlap
 		if not app.isConverting and 
		   self.myHarbour.isDoClearanceCheck then	// 10 Sep 2019	cnwrs1	TFS 46030
 			if voyage.arrivedDT &lt;= _departDT and voyage.departedDT &gt;= _arriveDT and not voyage.isCancelled then	 //jlier1 TFS 51963 5/10/21
				// Overlap occurs - ie there is already a booking in the system for this ship at this time
				app.raiseCMException1(BookingExists, _theVessel.name &amp;  " at " &amp;  self.code &amp; ', arrival ' &amp; voyage.arrivedDT.shortCurrentLocaleFormat() &amp; ' departure ' &amp; voyage.departedDT.shortCurrentLocaleFormat(), null, null); 
				return;
			endif;
		endif;	
 	endwhile;

 	// Proposed visit for this ship is not already booked in the system.
 	
epilog
	delete iter;
end;</source>
        <Parameter name="_arriveDT" type="TimeStamp"/>
        <Parameter name="_departDT" type="TimeStamp"/>
        <Parameter name="_theVessel" type="CM_Vessel"/>
        <Parameter name="_theVoyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateWagonId" id="fa147929-4df6-4966-964d-e4d1ff178c14">
        <source>validateWagonId(_code : String; _wagonClass : CM_WagonClass; ti : CM_TrackedItem; pUserObject : Object);
//AJA 19/4/01: Called for prenote creation or update
//This method validates a wagon id. Either the wagon exists and we check that
//it is offsite and there is space for the intended ti, or it is a new wagon
//and we check that it is one of a known wagon class. A new wagon cannot be
//created for an unknown class
vars
	wagonClass : CM_WagonClass;
	wagonClassId : String;
	wagonId : String;
	theWagon : CM_Wagon;
	wagonPos : Integer;
begin
	wagonId := _code.trimBlanks;
	if wagonId = "" then
		app.raiseCMWarning(ERR_NO_WAGON_ID, 'wagon', pUserObject, ti);		
		return;
	endif;
	
//	PAR 19710 theWagon := self.allWagons[wagonId, null];
	theWagon := self.getLatestWagonByCode(wagonId);
	
	
	if theWagon &lt;&gt; null then
		//Existing Wagon: Check there's space for this ti &amp; wagon is not onsite
		if theWagon.confirmed = true then
			app.raiseCMException(VB_WAGON_ONSITE, 'wagon', pUserObject);
		endif;
//		if ti.wagon.trimBlanks &lt;&gt; wagonId.trimBlanks then //GD Xpose 1094 if already on the wagon then don't bother checking for space	// cnwrl1 14/10/2009 PAR 21049 - what it was
		if ti &lt;&gt; null and ti.wagon.trimBlanks &lt;&gt; wagonId.trimBlanks then //GD Xpose 1094 if already on the wagon then don't bother checking for space
			wagonPos := theWagon.getNextFreeWagonPosition(ti,null,null,0,false);	// 06 Oct 2009	NDL	Par 20842 Param chg &amp; //10 May 2010	NDL Par 24064
			//if wagonPos = null then
			if wagonPos = null and theWagon.isFlatcar then	//19 Aug 2013	NDL	Par 32170
				//No free space or an internal error occurred
				app.raiseCMException2(ERR_NO_SPACE, ti.id, wagonId, 'wagon', pUserObject);
			endif;
		endif;

	elseif wagonId &lt;&gt; null and  _wagonClass &lt;&gt; null then	//12 May 2014
		// if they have passed the wagon id and wagon class we will be ok
	else
		//This is not an existing wagon. 
		//Check if it will be possible to create it.
		//We need the wagon class to know how long to make it..
		//wagonClassId := self.getWagonClassFromId(wagonId);
		wagonClassId := app.myRoot.getWagonClassViaHookCode(self,wagonId,null); //20 Jul 2009 NDL CCMS 1067
		if wagonClassId = null then
			app.raiseCMException(ERR_UNKNOWN_WAGON_CLASS, 'wagon', pUserObject);
		else
			wagonClass := self.myRoot.allWagonClasses[wagonClassId];
			if wagonClass = null then
				app.raiseCMException2(ERR_KEY_NOT_FOUND, wagonClassId, "Wagon Classes", 'wagon', pUserObject);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="vbCreateAlert" id="bf6db51f-2e9d-421f-aecd-606b2b181af6">
        <source>vbCreateAlert(heading : String; detail : String);

vars
	alert : CM_SystemAlert;

begin

	create alert;
	alert.details := heading;
	alert.addLogEntry(detail.trimRight);
	alert.setSeverity(SEVERE_INFO);
	alert.add;

end;</source>
        <Parameter name="heading" type="String"/>
        <Parameter name="detail" type="String"/>
    </JadeMethod>
    <JadeMethod name="yaFindByYACriteria" id="76d10b79-a9b9-4d0d-be7a-5f6f49c1a824">
        <source>yaFindByYACriteria(_yaType : Integer;_criteriaObject : Object) : CM_YardAllocation;
// ---------------------------------------------------------------------------
// Created:     20 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	yaCollection : CM_ObjectSet;
	term : CM_Terminal;
	tmpObj, objCri, searchObj : Object;
	theYA, yaLlocation : CM_YardAllocation;
	yaCriteria			: CM_YACriteria;
	yaData : CM_YADataObjects;
begin
	term := self;
	
	create yaCollection transient;
	
	term.yaFindByYAType(_yaType, yaCollection); //YACriteriaType_TrailerType

	foreach tmpObj in  yaCollection discreteLock do : outerLoop
		yaLlocation := tmpObj.CM_YardAllocation;
		foreach yaCriteria in yaLlocation.allCriteria  discreteLock do
			if not yaCriteria.myYACriteriaType.isKindOf(CM_YATypeTrailerType) then
				continue;
			endif;
			
			foreach objCri in yaCriteria.myYAData.CM_YADataObjects.allObjects  discreteLock do
				if objCri = _criteriaObject then
					theYA := yaLlocation;
					break outerLoop;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	return theYA;
	
epilog
	delete yaCollection;
end;</source>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_criteriaObject" type="Object"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="yaFindByYAType" id="b33b4fde-1773-49b0-8357-7aebbf84e299">
        <source>yaFindByYAType(_yaType : Integer; _yaCollection : CM_ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     20 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	yaLlocation : CM_YardAllocation;
	yaCriteria			: CM_YACriteria;
begin
	foreach yaLlocation in self.allYardAllocations discreteLock do : outerLoop
		foreach yaCriteria in yaLlocation.allCriteria  discreteLock do
			if yaCriteria.myYACriteriaType.type = _yaType then // YACriteriaType_TrailerType
				_yaCollection.add(yaLlocation);
				continue outerLoop;
			endif;
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_yaCollection" type="CM_ObjectSet" usage="input"/>
