        <updating/>
        <source>mnuRemovePlanned_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	obj : Object;
	rowIndex : Integer;
	size : Integer;

begin

	create tiArray transient;

	foreach rowIndex in self.tblSelectedCargo.fixedRows to self.tblSelectedCargo.rows do
		ti := self.tblSelectedCargo.accessRow(rowIndex).itemObject.CM_TrackedItem;
		if ti &lt;&gt; null and ti.myPrimaryPlannedLocation &lt;&gt; null then
			tiArray.add( ti );
		endif;
	endforeach;
	
	if not tiArray.isEmpty then
		foreach ti in tiArray do
			self.tblSelectedCargo.removeItemObject(ti);
			self.removeNotableTi( ti );
		endforeach;
		
		self.refreshTable( self.tblSelectedCargo, false );
	endif;

epilog

	delete tiArray;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
