    <JadeMethod name="doOK" id="8e652129-a583-4e74-a7f7-846a58c0ef71">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable

*/

vars
begin
	if self.saveCustomsReferences() then
		if app.myPassport.allErrors.isEmpty then
			inheritMethod();
			self.hasChanged := false;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
