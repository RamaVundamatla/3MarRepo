<Class name="CM_WorkOrderRelease" id="e45eed85-a540-484c-959c-c0894f2fcb10">
    <superclass name="CM_WorkOrderAssign"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <JadeMethod name="getDisplayStringForAttribute" id="931d99aa-8493-45c9-a3cc-d92752d9d0cc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars
	workOrder : CM_WorkOrderTI;
	invalidWO : Boolean;
	returnStr : String;
	br : CM_BulkRelease;
begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			on Exception do app.handleDeletedObject(exception, workOrder, invalidWO); 
			workOrder := self.myWorkOrder;
			if workOrder &lt;&gt; null then
				br := workOrder.getReleaseRequest(); // TFS 38524
				if br &lt;&gt; null then
					returnStr := "Assigned to " &amp; workOrder.id &amp; " : Release " &amp; br.code;
				else
					returnStr := "Assigned to " &amp; workOrder.id &amp; " : " &amp; workOrder.getDisplayString(); // TFS 38524
				endif;
			endif;
			return returnStr;			
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
