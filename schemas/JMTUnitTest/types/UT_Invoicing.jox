    <JadeMethod name="tDebtorTerminalCurrencyLocale" id="9d8c6592-fb35-4b72-b998-54b8665009ca">
        <source>tDebtorTerminalCurrencyLocale();
/*

Purpose:			Tests the following User Stories:
						53978.070 - Debtor Register - Invoice Currency
						53978.120 - Debtor Register - Language
						53978.100 - Debtor Register - Alternate Address
						53978.140 - Invoice Line - Translations and Printout

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
07 September 2022	navpw1	Initial creation TFS: 54571 - EUP - Inv Config - unit tests, upgrade scriptstinv

*/

//Tests Change Request 54564

constants
	Ref						: String = UT_DSL.TFS54374;
	UT_Debtor1 				: String = "UT_" &amp; Ref &amp; "_Debtor1";
	UT_LocaleID 			: String = "5129";
	UT_CurrencyCode 		: String = "USD";
	UT_DefaultInvoiceJRW 	: String = "Dave_BasicInvoice";
	
	//Address Constants
	UT_AddressCode			: String = "UT" &amp; Ref;
	UT_AddressDescription: String = "UT" &amp; Ref;
	UT_Address1: String = "UT" &amp; Ref;
	UT_Address2: String = "UT" &amp; Ref;
	UT_Address3: String = "UT" &amp; Ref;
	UT_AddressRegion: String = "UT" &amp; Ref;
	UT_AddressPostCode: String = "UT" &amp; Ref;
	UT_AddressCountryCode: String = "NZ";
	UT_AddressCity: String = "UT" &amp; Ref;
	UT_AddressDelIns: String = "UT" &amp; Ref;
	UT_AddressDefault : Boolean = false;
	
vars
	debtor1,
	pxyDebtor1				: CM_Debtor;
	theBank 				: CM_Bank;
	ls 						: Boolean;
	rdg	 		 			: CM_RootDebtorGroup;
	debtorNodeController	: CMIF_DebtorNode;
	realDN					: CM_DebtorNode;
	debtorTerminalDetail 	: CMIF_DebtorTerminalDetail;
	locale 					: CM_Locale;
	currencyType 			: CM_CurrencyType;
	debtorTerminal 			: CM_DebtorTerminal;
	pxyAddress,
	realAddress				: CM_Address;
	
begin
	/*
	** Cleanup
	*/
	debtor1 := app.myRoot.myRootCompany.debtors[UT_Debtor1];
	self.deleteDebtor(debtor1);
	
	/*
	** Global Setup
	*/
	debtor1 := self.addDebtor(UT_Debtor1, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtor1, "Debtor1");
	
	/*
	############################################## Start Test 1 ##############################################
	############################# 53978.070 - Debtor Register - Invoice Currency #############################
	################################# 53978.120 - Debtor Register - Language #################################
	
	Tests:
	1) Tests that a debtor terminal can be saved with currency, locale and jrw report (Happy day scenarios)
	
	*/
	
	/*
	** Setup
	*/
	
	/*
	** Run
	*/
	create debtorNodeController transient;
	
	//Setup Debtor node controller
	
	theBank := app.myRoot.myRootCompany;
	rdg 	:= theBank.getRootDebtorGroup();
	
	pxyDebtor1 := app.createUpdateProxy(debtor1).CM_Debtor;
	
	debtorNodeController.myBank 				   	:= theBank;
	debtorNodeController.myPxyDebtorNode 			:= pxyDebtor1;
	debtorNodeController.name 					   	:= pxyDebtor1.name[1:100];
	debtorNodeController.code 					   	:= pxyDebtor1.code;
	debtorNodeController.purchaseOrderCode 	   		:= pxyDebtor1.purchaseOrderCode[1:10];
	debtorNodeController.remarks 				   	:= pxyDebtor1.remarks;
	debtorNodeController.doDebtorInvoiceTypes     	:= true;
	debtorNodeController.doDebtorInvoiceLineTypes 	:= true;
	
	create debtorTerminalDetail transient;
	debtorTerminalDetail.setPaymentType(null);
	debtorTerminalDetail.setMyTerminal(app.myPassport.myTerminal);
	debtorTerminalDetail.setCashOnly(false);
	
	debtorTerminalDetail.setDefaultInvoiceJRW(UT_DefaultInvoiceJRW);
	locale := app.myRoot.allLocales[UT_LocaleID];
	debtorTerminalDetail.setMyLocale(locale);
	currencyType := app.myRoot.allCurrencyTypes[UT_CurrencyCode];
	debtorTerminalDetail.setMyCurrencyType(currencyType);
	
	debtorNodeController.allDebtorTerminalDetails.add(debtorTerminalDetail);
	
	app.myTrxUA.trxUpdateDebtorNode(debtorNodeController, app.myPassport);
	
	/*
	** Assert
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Get debtor node for checking
	debtor1 := app.myRoot.myRootCompany.debtors[UT_Debtor1];
	
	debtorTerminal := debtor1.allDebtorTerminals[app.myPassport.myTerminal];
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(debtorTerminal.myCurrencyType &lt;&gt; null, "myCurrencyType Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(debtorTerminal.myLocale &lt;&gt; null, "myLocale Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(debtorTerminal.defaultInvoiceJRW &lt;&gt; null, "defaultInvoiceJRW Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(debtorTerminal.myCurrencyType.code = UT_CurrencyCode, "myCurrencyType Expected: '" &amp; UT_CurrencyCode &amp; "' | Actual: '" &amp; debtorTerminal.myCurrencyType.code &amp; "'");
	self.assertTrueMsg(debtorTerminal.myLocale.localeId = UT_LocaleID, "myAccrualType Expected: '" &amp; UT_LocaleID &amp; "' | Actual: '" &amp; debtorTerminal.myLocale.localeId &amp; "'");
	self.assertTrueMsg(debtorTerminal.defaultInvoiceJRW = UT_DefaultInvoiceJRW, "myAccrualType Expected: '" &amp; UT_DefaultInvoiceJRW &amp; "' | Actual: '" &amp; debtorTerminal.defaultInvoiceJRW &amp; "'");
	
	/*
	############################################### End Test 1 ###############################################
	############################# 53978.070 - Debtor Register - Invoice Currency #############################
	################################# 53978.120 - Debtor Register - Language #################################
	*/
	
	/*
	############################################## Start Test 2 ##############################################
	############################ 53978.100 - Debtor Register - Alternate Address #############################
	
	Tests:
	1) Tests that is alternate address can be set on Debtor Addresses
	
	*/
	
	/*
	** Setup
	*/
	delete pxyDebtor1;
	
	/*
	** Run
	*/
	//Setup Debtor node controller
	
	theBank := app.myRoot.myRootCompany;
	rdg 	:= theBank.getRootDebtorGroup();
	
	pxyDebtor1 := app.createUpdateProxy(debtor1).CM_Debtor;
	
	//Create an address
	create pxyAddress transient;
	//pxyAddress.setProxy(UT_AddressCode, UT_AddressDescription, UT_Address1, UT_Address2, UT_Address3, UT_AddressRegion, UT_AddressPostCode, 
	//					UT_AddressCountryCode, UT_AddressCity, UT_AddressDelIns, UT_AddressDefault, true, debtor1);
	pxyAddress.setProxy(UT_AddressCode, UT_AddressDescription, UT_Address1, UT_Address2, UT_Address3, UT_AddressRegion, UT_AddressPostCode, 
						UT_AddressCountryCode, UT_AddressCity, "", UT_AddressDelIns, UT_AddressDefault, true, debtor1);	//navra1 - TFS 57086 - 1st May 2023
	
	app.myTrxCA.trxCreateDebtorAddress(pxyAddress, realAddress, app.myPassport);
	
	/*
	** Assert
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Get debtor node for checking
	debtor1 := app.myRoot.myRootCompany.debtors[UT_Debtor1];
	
	//Check address is not null
	self.assertNotNullMsg(debtor1.allAddressesByCode[UT_AddressCode], "Test 2: Debtor Address");
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realAddress.isAlternative, "Test 2: isAlternative Expected: '" &amp; true.asStringJMT() &amp; "' | Actual: '" &amp; realAddress.isAlternative.asStringJMT() &amp; "'");
	
	self.assertTrueMsg(debtor1.allAddressesByCode[UT_AddressCode].isAlternative, "Test 2: Saved isAlternative Expected: '" &amp; true.asStringJMT() &amp; "' | Actual: '" &amp; debtor1.allAddressesByCode[UT_AddressCode].isAlternative.asStringJMT() &amp; "'");
	
	/*
	############################################## Start Test 2 ##############################################
	############################ 53978.100 - Debtor Register - Alternate Address #############################
	*/
	
	/*
	############################################## Start Test 3 ##############################################
	################################ 53978.110 - Invoice - Alternate Address #################################
	
	Tests:
	1) Tests 
	
	*/
	
	/*
	** Setup
	*/
	delete debtorNodeController;	
	delete pxyDebtor1;
	
	/*
	** Run
	*/
	create debtorNodeController transient;
	
	//Setup Debtor node controller
	
	theBank := app.myRoot.myRootCompany;
	rdg 	:= theBank.getRootDebtorGroup();
	
	pxyDebtor1 := app.createUpdateProxy(debtor1).CM_Debtor;
	
	debtorNodeController.myBank 				   	:= theBank;
	debtorNodeController.myPxyDebtorNode 			:= pxyDebtor1;
	debtorNodeController.name 					   	:= pxyDebtor1.name[1:100];
	debtorNodeController.code 					   	:= pxyDebtor1.code;
	debtorNodeController.purchaseOrderCode 	   		:= pxyDebtor1.purchaseOrderCode[1:10];
	debtorNodeController.remarks 				   	:= pxyDebtor1.remarks;
	debtorNodeController.doDebtorInvoiceTypes     	:= true;
	debtorNodeController.doDebtorInvoiceLineTypes 	:= true;
	
	create debtorTerminalDetail transient;
	debtorTerminalDetail.setPaymentType(null);
	debtorTerminalDetail.setMyTerminal(app.myPassport.myTerminal);
	debtorTerminalDetail.setCashOnly(false);
	
	debtorTerminalDetail.setDefaultInvoiceJRW(UT_DefaultInvoiceJRW);
	locale := app.myRoot.allLocales[UT_LocaleID];
	debtorTerminalDetail.setMyLocale(locale);
	currencyType := app.myRoot.allCurrencyTypes[UT_CurrencyCode];
	debtorTerminalDetail.setMyCurrencyType(currencyType);
	
	debtorNodeController.allDebtorTerminalDetails.add(debtorTerminalDetail);
	
	app.myTrxUA.trxUpdateDebtorNode(debtorNodeController, app.myPassport);
	
	/*
	** Assert
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Get debtor node for checking
	debtor1 := app.myRoot.myRootCompany.debtors[UT_Debtor1];
	
	debtorTerminal := debtor1.allDebtorTerminals[app.myPassport.myTerminal];
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(debtorTerminal.myCurrencyType &lt;&gt; null, "myCurrencyType Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(debtorTerminal.myLocale &lt;&gt; null, "myLocale Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(debtorTerminal.defaultInvoiceJRW &lt;&gt; null, "defaultInvoiceJRW Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(debtorTerminal.myCurrencyType.code = UT_CurrencyCode, "myCurrencyType Expected: '" &amp; UT_CurrencyCode &amp; "' | Actual: '" &amp; debtorTerminal.myCurrencyType.code &amp; "'");
	self.assertTrueMsg(debtorTerminal.myLocale.localeId = UT_LocaleID, "myAccrualType Expected: '" &amp; UT_LocaleID &amp; "' | Actual: '" &amp; debtorTerminal.myLocale.localeId &amp; "'");
	self.assertTrueMsg(debtorTerminal.defaultInvoiceJRW = UT_DefaultInvoiceJRW, "myAccrualType Expected: '" &amp; UT_DefaultInvoiceJRW &amp; "' | Actual: '" &amp; debtorTerminal.defaultInvoiceJRW &amp; "'");
	
	/*
	############################################## Start Test 3 ##############################################
	################################ 53978.110 - Invoice - Alternate Address #################################
	*/
	
	/*
	############################################## Start Test 4 ##############################################
	########################## 53978.140 - Invoice Line - Translations and Printout ##########################
	
	Tests:
	1) Tests 
	
	*/
	
	/*
	** Setup
	*/
	delete debtorNodeController;
	delete pxyDebtor1;
	
	/*
	** Run
	*/
	create debtorNodeController transient;
	
	//Setup Debtor node controller
	
	theBank := app.myRoot.myRootCompany;
	rdg 	:= theBank.getRootDebtorGroup();
	
	pxyDebtor1 := app.createUpdateProxy(debtor1).CM_Debtor;
	
	debtorNodeController.myBank 				   	:= theBank;
	debtorNodeController.myPxyDebtorNode 			:= pxyDebtor1;
	debtorNodeController.name 					   	:= pxyDebtor1.name[1:100];
	debtorNodeController.code 					   	:= pxyDebtor1.code;
	debtorNodeController.purchaseOrderCode 	   		:= pxyDebtor1.purchaseOrderCode[1:10];
	debtorNodeController.remarks 				   	:= pxyDebtor1.remarks;
	debtorNodeController.doDebtorInvoiceTypes     	:= true;
	debtorNodeController.doDebtorInvoiceLineTypes 	:= true;
	
	create debtorTerminalDetail transient;
	debtorTerminalDetail.setPaymentType(null);
	debtorTerminalDetail.setMyTerminal(app.myPassport.myTerminal);
	debtorTerminalDetail.setCashOnly(false);
	
	debtorTerminalDetail.setDefaultInvoiceJRW(UT_DefaultInvoiceJRW);
	locale := app.myRoot.allLocales[UT_LocaleID];
	debtorTerminalDetail.setMyLocale(locale);
	currencyType := app.myRoot.allCurrencyTypes[UT_CurrencyCode];
	debtorTerminalDetail.setMyCurrencyType(currencyType);
	
	debtorNodeController.allDebtorTerminalDetails.add(debtorTerminalDetail);
	
	app.myTrxUA.trxUpdateDebtorNode(debtorNodeController, app.myPassport);
	
	/*
	** Assert
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Get debtor node for checking
	debtor1 := app.myRoot.myRootCompany.debtors[UT_Debtor1];
	
	debtorTerminal := debtor1.allDebtorTerminals[app.myPassport.myTerminal];
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(debtorTerminal.myCurrencyType &lt;&gt; null, "myCurrencyType Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(debtorTerminal.myLocale &lt;&gt; null, "myLocale Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(debtorTerminal.defaultInvoiceJRW &lt;&gt; null, "defaultInvoiceJRW Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(debtorTerminal.myCurrencyType.code = UT_CurrencyCode, "myCurrencyType Expected: '" &amp; UT_CurrencyCode &amp; "' | Actual: '" &amp; debtorTerminal.myCurrencyType.code &amp; "'");
	self.assertTrueMsg(debtorTerminal.myLocale.localeId = UT_LocaleID, "myAccrualType Expected: '" &amp; UT_LocaleID &amp; "' | Actual: '" &amp; debtorTerminal.myLocale.localeId &amp; "'");
	self.assertTrueMsg(debtorTerminal.defaultInvoiceJRW = UT_DefaultInvoiceJRW, "myAccrualType Expected: '" &amp; UT_DefaultInvoiceJRW &amp; "' | Actual: '" &amp; debtorTerminal.defaultInvoiceJRW &amp; "'");
	
	/*
	############################################## Start Test 4 ##############################################
	########################## 53978.140 - Invoice Line - Translations and Printout ##########################
	*/
	
epilog
	delete debtorNodeController;
	delete pxyDebtor1;
	delete pxyAddress;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tDeleteFPTAssignedToDebtors" id="b0747b63-4d73-4bec-9943-50823f485da2">
        <source>tDeleteFPTAssignedToDebtors();
/*

Purpose:			

Date		Who		Reason
08 December 2015	cnwmk3	Initial creation

*/
constants
	Desc                                             : String = "UT_Updated01";
	FPRemarks                                        : String = "UT_Created01";
	DebtorID										 : String = "UT_Debtor01";
vars
	dateTime                                         : TimeStamp;
	pxyFPDate, newFPDate, proxyUpdateFPDate          : CM_FinancialPeriodDateTime;
	pxyFPEnd, aFPEnd,pxyUpdateFPType   			     : CM_FinancialPeriodEnd;
	debtor											 : CM_DebtorNode;
	debtors                                          : CM_DebtorNodeByNameDict;
begin
	// delete financial period time/period 
   dateTime.setDateTime(2015, 11, 05, 14, 19, 0, 0);
	if app.myRoot.myRootCompany.allFinancialPeriods[Desc] &lt;&gt; null then
		newFPDate := app.myRoot.myRootCompany.allFinancialPeriods[Desc].allFinancialPeriodEndDates[dateTime];
		if newFPDate &lt;&gt; null then
			app.myTrxDA.trxDeleteFPDateTime(newFPDate, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endif;
	
	// delete financial period type
   aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[Desc];
   if aFPEnd &lt;&gt; null then
        app.myTrxDA.trxDeleteFPType(aFPEnd, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
   endif;
   aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[Desc];
   self.assertNull(aFPEnd);
   
    aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks];
   if aFPEnd &lt;&gt; null then
        app.myTrxDA.trxDeleteFPType(aFPEnd, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
   endif;
   aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks];
   self.assertNull(aFPEnd);

// create financial period type
   create pxyFPEnd transient;
   pxyFPEnd.setProxy(FPRemarks, false);
   app.myTrxCA.trxCreateFPType(pxyFPEnd,aFPEnd,app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(aFPEnd);

	// create debtor
	self.deleteDebtor(DebtorID);
	debtor := self.addDebtor(DebtorID, PaymentType_None);
	self.assertNotNull(debtor);
   
   // update financial period type
   beginLoad;
   pxyUpdateFPType := aFPEnd.pxyCreateUpdateProxy();
   endLoad;
   create debtors transient;
   debtors.add(debtor);
   pxyUpdateFPType.setPropertyValue("description", Desc);
   app.myTrxUA.trxUpdateFPType(pxyUpdateFPType,debtors, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
	
	// create financial period date/time   
   create pxyFPDate transient;
   aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[Desc];
   self.assertNotNull(aFPEnd);
   pxyFPDate.setProxy(dateTime, FPRemarks, aFPEnd);
   app.myTrxCA.trxCreateFPDateTime(pxyFPDate,newFPDate,app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
 
// update financial period date/time 
   beginLoad;
   proxyUpdateFPDate := newFPDate.pxyCreateUpdateProxy();
   endLoad;
   proxyUpdateFPDate.setPropertyValue("myFinancialPeriodEnd", newFPDate.myFinancialPeriodEnd);
   proxyUpdateFPDate.setPropertyValue("remarks", "Updated by UT");
   app.myTrxUA.trxUpdateFPDateTime(proxyUpdateFPDate, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
	// delete financial period type
   aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[Desc];
   if aFPEnd &lt;&gt; null then
		self.expectTrxError(Financ_period_cannot_delete_de);
        app.myTrxDA.trxDeleteFPType(aFPEnd, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[Desc];
		self.assertNotNull(aFPEnd);
   endif;
   
   aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks];
   if aFPEnd &lt;&gt; null then
		self.expectTrxError(Financ_period_cannot_delete_de);
        app.myTrxDA.trxDeleteFPType(aFPEnd, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks];
		self.assertNotNull(aFPEnd);
   endif;
   
	self.deleteDebtor(DebtorID);
epilog
	delete pxyFPDate;
   delete proxyUpdateFPDate;
   delete pxyFPEnd;
   delete debtors;
   delete pxyUpdateFPType;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDeleteFPTWithInvoiceType" id="68086d14-15e0-4ea8-acc5-15c6039ed15d">
        <source>tDeleteFPTWithInvoiceType();
/*

Purpose:			

Date		Who		Reason
08 December 2015	cnwmk3	Initial creation
*/
constants
   FPRemarks                                        : String = "UT_Created02";
   DebtorID											: String = "UT_Debtor02";
vars
	dateTime                                        : TimeStamp;
	pxyFPDate, newFPDate, proxyUpdateFPDate         : CM_FinancialPeriodDateTime;
	pxyFPEnd, aFPEnd				   			    : CM_FinancialPeriodEnd;
	narrationArray									: HugeStringArray;
	invType, pxyInvoiceType							: CM_InvoiceDesc;
	now												: Date;
begin
// delete financial period time/period 
   dateTime.setDateTime(2015, 11, 05, 14, 19, 0, 0);
	if app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks] &lt;&gt; null then
		newFPDate := app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks].allFinancialPeriodEndDates[dateTime];
		if newFPDate &lt;&gt; null then
			app.myTrxDA.trxDeleteFPDateTime(newFPDate, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endif;
	
// delete financial period type
   aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks];
   if aFPEnd &lt;&gt; null then
        app.myTrxDA.trxDeleteFPType(aFPEnd, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
   endif;
   aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks];
   self.assertNull(aFPEnd);
   
// create financial period type
   create pxyFPEnd transient;
   pxyFPEnd.setProxy(FPRemarks, false);
   app.myTrxCA.trxCreateFPType(pxyFPEnd,aFPEnd,app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
 
// create financial period date/time   
   create pxyFPDate transient;
   aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks];
   self.assertNotNull(aFPEnd);
   pxyFPDate.setProxy(dateTime, FPRemarks, aFPEnd);
   app.myTrxCA.trxCreateFPDateTime(pxyFPDate,newFPDate,app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
 
 // update financial period date/time 
   beginLoad;
   proxyUpdateFPDate := newFPDate.pxyCreateUpdateProxy();
   endLoad;
   proxyUpdateFPDate.setPropertyValue("myFinancialPeriodEnd", newFPDate.myFinancialPeriodEnd);
   proxyUpdateFPDate.setPropertyValue("remarks", "Updated by UT");
   app.myTrxUA.trxUpdateFPDateTime(proxyUpdateFPDate, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
    create narrationArray transient;
	narrationArray.add("None, cool!");
	narrationArray.add("___field = 0");
	narrationArray.add("The Debtors Name");
	narrationArray.add("___field = 1");
	narrationArray.add("The Voyage Code");
	narrationArray.add("___field = 2");
	narrationArray.add("The Vessel Name");
	narrationArray.add("___field = 3");
	narrationArray.add("08/12/2015");
	narrationArray.add("___field = 5");
   
// create invoice type
	self.deleteInvoiceType("INVOICE_TYPE");
	invType := self.createInvoiceTypeFull( CM_InvoiceDesc.Accrue_For_Financial_Period,
											narrationArray,
											"INVOICE_TYPE",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											aFPEnd,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now + 30,
											0,
											"");
	
	invType.getAccrualTypeDescription();
	// delete financial period type
   aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks];
   if aFPEnd &lt;&gt; null then
		self.expectTrxError(Finan_perio_canno_delet_invoi_);
        app.myTrxDA.trxDeleteFPType(aFPEnd, app.myPassport);
		aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks];
		self.assertNotNull(aFPEnd);
   endif;
   
	self.deleteInvoiceType("INVOICE_TYPE");
epilog
	delete pxyFPDate;
	delete proxyUpdateFPDate;
	delete pxyFPEnd;
	delete pxyInvoiceType;
	delete narrationArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEmptyPoolParty" id="a7f6a3ac-38a7-457c-806e-6fef54a7d851">
        <updating/>
        <source>tEmptyPoolParty() updating;
// cnwdap1
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/01/2017	cnwdap1		Initial creation TFS 3042 SNO Empty Container Pool Management
// 10/05/2017	cnwdap1		TFS 4370 Allow pooling parties acroos multiple terminals
//
constants
	Operator1 = "UPP1";
	Operator2 = "UPP2";
	Debtor = "UPPD";
	PoolParty = "UTPP";
	ContainerName1 = "UTDV1234567";
	ContainerName2 = "UTDV1234569";
	BlockStack = "UTBSDAVE";
	VoyageNameExport = 'UTPPSHIP01';
	ShipNameExport = 'UTPPSHIP';
	TestOperator = 'MSK';
	ExportCont1 = "UTDV9876543";
	ExportCont2 = "UTDV9876542";
	CraneTransferAreaId = "UPCT";
	CraneId = "UPC1";
	YardIC = "UP_BS_IC";
	
vars
	terminal : CM_Terminal;
	operator1, operator2, op : CM_Operator;
	cmifConfig : CMIF_OperatorTerminalConfig;
	cmifConfigDict : CMIF_OpTerminalConfigDict;
	codeGroups : CM_CodeGroupsByTypeDict;
	emailAddresses : CM_EmailEntityByTypeNameDict;
	debtor : CM_Debtor;
	pp, pxyPP : CM_MTPoolingParty;
	opTerm : CM_OperatorTerminal;
	pxyPartner1, pxyPartner2, partner1, partner2 : CM_MTPoolingPartner;
	pxyPartners : CM_MTPoolingPartnerByOperator;
	debtorType : CM_DebtorType;
	invoiceLineType : CM_InvoiceLineDesc;
	calcType : CM_CalculationType;
	invType : CM_InvoiceDesc;
	bank : CM_Bank;
	roadService, shipService : CM_Service;
	services : CM_ServiceByNameDict;
	fileContent, fileName : String;
	cargoMap : CM_TranMap;
	container1, container2, container3, container4 : CM_Container;
	yardIC : CM_InterchangeArea;
	blockStack : CM_BlockStack;
	singleGate : CM_Gate;
	vvr1, vvr2 : CM_VehicleVisitRecord;
	roadRelease, shipRelease : CM_TITransaction;
	invLine : CM_InvoiceLine;
	invoice : CM_Invoice;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	tis : CM_TISet;
	dischargePort : CM_Port;
	lc : CM_LocationsController;
	height : Integer;
	jobs : CM_JobArray;
	voyAlloc : CM_VoyageAllocation;
	wles : CM_WLEArray;
	straddle : CM_Machine;
	tas : StringArray;
	cta : CM_CraneTransferArea;
	slots : CM_SlotControllerArray;
	voyageJob : CM_VoyageJob;
	job : CM_Job;
	request : CM_Request;
	voyageQueue : CM_VoyageQueue;
	craneQueue : CM_VoyageCraneQueue;
	crane : CM_Machine;
	wle : CM_WorkListEntry;
	bayName : String;
	lineTotal : Decimal [14,6];
	allowRTSwithoutVGM : Boolean;
begin
	// Test invoicing of empty pool party container on road release and ship release
	// 1. Create an Empty Pool Party and assign 2 operators to it.
	// 2. Set the percentage charged for each operator on the pool party
	// 3. Create a debtor to map to one of the operators
	// 4. Create an invoice line type for debtor type "Empty Pool Party", and a rate
	// 5. Create a transaction map that includes the debtor and "Release - Road" and "Release - Ship" transaction types
	// 6. Create a container onsite for the operator in the pool party associated with the debtor
	// 7. Create a container onsite for the operator in the pool party NOT associated with the debtor
	// 8. Gate out both containers - both should have two Release Road invoice lines, for the percentage
	//    split in the pool party setup
	// 9. Create a container onsite for the operator in the pool party associated with the debtor
	// 10. Create a container onsite for the operator in the pool party NOT associated with the debtor
	// 11. Release both containers to a ship - both should have two Release Ship invoice lines, for the percentage
	//    split in the pool party setup
	
	allowRTSwithoutVGM := self.getTerminalConfig(AllowRTSwithoutVGM).Boolean;
	self.setTerminalConfig(AllowRTSwithoutVGM, true);
	
	// delete things first
	terminal := self.getTerminal();
	bank := terminal.getDefaultCompanyBank();
	self.deleteMTPoolParty(PoolParty);
	self.deleteOperator(Operator1);
	self.deleteOperator(Operator2);
	self.deleteDebtor(bank.debtors[Debtor]);
	self.deleteDebtor(app.myRoot.myRootCompany.debtors[Debtor]);
	self.deleteContainer(ContainerName1);
	self.deleteContainer(ContainerName2);
	self.deleteContainer(ExportCont1);
	self.deleteContainer(ExportCont2);
	self.deleteVoyage(VoyageNameExport);
	self.deleteVessel(ShipNameExport);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	self.deleteTerminalArea(BlockStack);
	self.deleteTerminalArea(YardIC);
	self.deleteInvoiceService("UTPP Road Release", NORMAL_ERASE);
	self.deleteInvoiceService("UTPP Ship Release", NORMAL_ERASE);
	self.deleteInvoiceLineType("Empty Pool Party Release Road", NORMAL_ERASE);
	self.deleteInvoiceLineType("Empty Pool Party Release Ship", NORMAL_ERASE);
	self.assertNullMsg(terminal.allMTPoolingParties[PoolParty], "Empty Pooling Party " &amp; PoolParty);
	self.assertNullMsg(app.myRoot.allOperators[Operator1], "Operator " &amp; Operator1);
	self.assertNullMsg(app.myRoot.allOperators[Operator2], "Operator " &amp; Operator2);
	self.assertNullMsg(bank.debtors[Debtor], "Debtor " &amp; Debtor);
	
	// 1. Create an Empty Pool Party
	// first create a couple of operators
	create codeGroups transient;
	create emailAddresses transient;
	create cmifConfig transient;
	create cmifConfigDict transient;
	cmifConfig.myTerminal := terminal;
	cmifConfigDict.add(cmifConfig);
	operator1 := self.addOperator(Operator1, "Empty Pool Party Test Operator 1", false, 0, 0, null, false, false, false, false, false, false, false, false, false, false, null, null, codeGroups, false, false, false, cmifConfigDict, emailAddresses, 0, null, false, false);
	self.assertNotNullMsg(operator1, "Operator UPP1");
	operator2 := self.addOperator(Operator2, "Empty Pool Party Test Operator 2", false, 0, 0, null, false, false, false, false, false, false, false, false, false, false, null, null, codeGroups, false, false, false, cmifConfigDict, emailAddresses, 0, null, false, false);
	self.assertNotNullMsg(operator2, "Operator UPP2");
	// now the pool party
	pp := self.addMTPoolingParty(PoolParty, "MT Pool Party UPP1 UPP2");
	self.assertNotNullMsg(pp, "Pooling Party UTPP");
	
	// 2. Set the percentage charged for each operator on the pool party
	beginTransaction;
	opTerm := operator1.allOperatorTerminals[terminal];
	opTerm.setMyPoolingParty(pp);
	opTerm := operator2.allOperatorTerminals[terminal];
	opTerm.setMyPoolingParty(pp);
	commitTransaction;
	create pxyPartner1 transient;
	pxyPartner1.setProxy(operator1, opTerm.myTerminal, 40);				// TFS 4370
	create pxyPartner2 transient;
	pxyPartner2.setProxy(operator2, opTerm.myTerminal, 60);				// TFS 4370
	create pxyPartners transient;
	pxyPartners.add(pxyPartner1);
	pxyPartners.add(pxyPartner2);
	beginLoad;
	pxyPP := pp.pxyCreateUpdateProxy();
	endLoad;
	pxyPP.setProxy(pp.code, pp.description, pp.myTerminal, pxyPartners);
	app.myTrxUA.trxUpdateMTPoolParty(pxyPP, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// 3. Create a debtor to map to one of the operators
	debtor := self.addDebtor(Debtor, PaymentType_None).CM_Debtor;
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(debtor, "Debtor UPPD");
	// take off the default operators and assign our operator
	beginTransaction;
	foreach op in debtor.operators do
		op.debtor := debtor.bank.rootDebtor;
	endforeach;
	operator1.debtor := debtor;
	commitTransaction;
	self.assertEqualMsg(operator1.debtor, debtor, "Operator UPP1 is not assigned to debtor UPPD");
	
	// 4. Create an invoice line type for debtor type "Empty Pool Party", and a rate
	// get the things we need - debtor type for "Empty Pool Party", calculation type for "Value of 1", invoice type for "Cargo"
	// and create a service for Road Release and Ship Release
	debtorType := app.myRoot.allDebtorTypes["SDT0"];
	self.assertNotNullMsg(debtorType, "Debtor Type SDT0");
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	self.assertNotNullMsg(calcType, "Calculation Type CCT00");
	invType := bank.invoiceTypes[42052];
	self.assertNotNullMsg(invType, "Invoice Type 42052");
	roadService := self.createInvoiceService("UTPP Road Release", null, calcType, null);
	self.assertNotNullMsg(roadService, "Service 'Road Release'");
	self.setServiceRate(roadService, debtor, "01/01/2017".Date, 100);
	shipService := self.createInvoiceService("UTPP Ship Release", null, calcType, null);
	self.assertNotNullMsg(shipService, "Service 'Ship Release'");
	self.setServiceRate(shipService, debtor, "01/01/2017".Date, 200);
	create services transient;
	services.add(roadService);
	invoiceLineType := self.createInvoiceLineType("Empty Pool Party Release Road", calcType, invType, services, debtorType.code);
	self.assertNotNullMsg(invoiceLineType, "Invoice Line Type for 'Empty Pool Party Release Road'");
	services.clear;
	services.add(shipService);
	invoiceLineType := self.createInvoiceLineType("Empty Pool Party Release Ship", calcType, invType, services, debtorType.code);
	self.assertNotNullMsg(invoiceLineType, "Invoice Line Type for 'Empty Pool Party Release Ship'");
	
	// 5. Create a transaction map that includes the debtor and Release - Road transaction type mapped to our service and
	// invoice line type
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
		'Cargo,MTPoolParty,CONT| ISO Container,(Default),(Default),Storage,(Default),(Default),Released - Road,,(Default),(Default) ›,(Default),Empty Pool Party Release Road' &amp; CrLf &amp;
		'Cargo,MTPoolParty,CONT| ISO Container,(Default),(Default),Export,(Default),(Default),Released - Ship,,(Default),(Default) ›,(Default),Empty Pool Party Release Ship' &amp; CrLf;
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	cargoMap := bank.myCurrentTranMapCargo["MTPoolParty"];
	self.assertNotNullMsg(cargoMap, "Cargo Map 'MTPoolParty'");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);	
	
	// 6. Create a container onsite for the operator in the pool party associated with the debtor
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	blockStack := self.addBlockStack(BlockStack, 999, null);
	self.assertNotNullMsg(blockStack, "Block Stack " &amp; BlockStack);
	container1 := self.addContainerAtLocation(ContainerName1, operator1, "2200", "MT", 3, blockStack);
	self.assertNotNullMsg(container1, "Container " &amp; ContainerName1);
	// 7. Create a container onsite for the operator in the pool party NOT associated with the debtor
	container2 := self.addContainerAtLocation(ContainerName2, operator2, "2200", "MT", 3, blockStack);
	self.assertNotNullMsg(container2, "Container " &amp; ContainerName2);
	
	// 8. Gate out both containers - both should have two Release Road invoice lines, for the percentage
	//    split in the pool party setup
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.deleteVehicle("UTDPTRK");
	self.opts.addAssoc("deliveryNumber", "999");	// to prevent more stops being added at release
	vvr1 := self.gateOutContainer("UTDPTRK", "", "UTDPTRKDRIVER", container1, true, singleGate , BlockStack);
	self.workVehicle(vvr1);
	self.roadExit(vvr1);
	vvr2 := self.gateOutContainer("UTDPTRK", "", "UTDPTRKDRIVER", container2, true, singleGate , BlockStack);
	self.workVehicle(vvr2);
	self.roadExit(vvr2);
	
	// Now check some stuff - both containers should have been invoiced, and both should have two Release-Road lines
	// One line should be $40, the other should be $60
	roadRelease := container1.getLastTransOfType(TRANS_TYPE_REL_ROAD);
	self.assertNotNullMsg(roadRelease, "Road Release transaction for " &amp; ContainerName1);
	self.assertEqualMsg(roadRelease.allInvoiceLines.size, 2, "Road Release for " &amp; ContainerName1 &amp; " has wrong number of invoice lines");
	lineTotal := null;
	foreach invLine in roadRelease.allInvoiceLines do
		self.assertIsOneOf(invLine.quantity, "Invoice Line quantity for " &amp; ContainerName1 &amp; " is incorrect", 0.4, 0.6);
		// if invoice line is for VOID debtor it will not have a total (VOID debtor is not mapped to a charge)
		if not invLine.debtor.isRDT then
			self.assertIsOneOf(invLine.lineTotal.asStringJMT, "Invoice Line total for " &amp; ContainerName1 &amp; " is incorrect", "40.000000", "60.000000");
			lineTotal := lineTotal + invLine.lineTotal;
		endif;
	endforeach;
	//self.assertEqualMsg(invoice.getTotalAmount.asStringJMT, "100.00", "Invoice total for " &amp; ContainerName1 &amp; " is incorrect");
	roadRelease := container2.getLastTransOfType(TRANS_TYPE_REL_ROAD);
	self.assertNotNullMsg(roadRelease, "Road Release transaction for " &amp; ContainerName2);
	self.assertEqualMsg(roadRelease.allInvoiceLines.size, 2, "Road Release for " &amp; ContainerName2 &amp; " has wrong number of invoice lines");
	lineTotal := null;
	foreach invLine in roadRelease.allInvoiceLines do
		self.assertIsOneOf(invLine.quantity, "Invoice Line quantity for " &amp; ContainerName2 &amp; " is incorrect", 0.4, 0.6);
		// if invoice line is for VOID debtor it will not have a total (VOID debtor is not mapped to a charge)
		if not invLine.debtor.isRDT then
			self.assertIsOneOf(invLine.lineTotal.asStringJMT, "Invoice Line total for " &amp; ContainerName2 &amp; " is incorrect", "40.000000", "60.000000");
			lineTotal := lineTotal + invLine.lineTotal;
		endif;
	endforeach;
	//self.assertEqualMsg(invoice.getTotalAmount.asStringJMT, lineTotal, "Invoice total for " &amp; ContainerName2 &amp; " is incorrect");
	
	// 9. Create an export container onsite for the operator in the pool party associated with the debtor
	// Create the vessel and voyage
	vessel := self.addVesselCellular(ShipNameExport, operator1);
	voyage := self.addVoyageWithContainerStructur(VoyageNameExport, ShipNameExport, Operator1, self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	// add second operator to voyage
	beginTransaction;
	voyage.allOperators.add(operator2);
	commitTransaction;
	self.assertNotNullMsg(voyage, VoyageNameExport);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	container3 := self.addContainerForExport(ExportCont1, operator1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, null, voyage.code, dischargePort.code, null).CM_Container;
	self.assertNotNullMsg(container3, "Container " &amp; ExportCont1);
	// 10. Create an export container onsite for the operator in the pool party NOT associated with the debtor
	container4 := self.addContainerForExport(ExportCont2, operator2, "2200", "GENL", TI_IMEX_STATUS_EXPORT, null, voyage.code, dischargePort.code, null).CM_Container;
	self.assertNotNullMsg(container4, "Container " &amp; ExportCont2);
	
	// 11. Release both containers to the ship - both should have two Release Ship invoice lines, for the percentage
	//    split in the pool party setup
	// create a crane transfer area
	create jobs transient;
	create wles transient;
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	// create a crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;
	// create load allocations and load job
	self.opts.purge;
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code, "GEN2", null, 1, false, false);
	bayName :='01';
	create slots transient;
	self.getJobSlotControllers(voyage.code, bayName, DeckOnDeck, 1, 2, 2, slots);
	self.assertEqualMsg(slots.size, 2, "Slots");
	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	self.assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	jobs.add(voyageJob);	
	
	// plan the export containers to the voyage
	self.move(container3, blockStack.getLocationsController);
	self.setCargoReadyToShip(container3);
	self.deleteStops(container3);
	self.move(container4, blockStack.getLocationsController);
	self.setCargoReadyToShip(container4);
	self.deleteStops(container4);
	self.movePlannedRequestToJob(container3, slots[1], slots[1].getRequest(true));
	self.movePlannedRequestToJob(container4, slots[2], slots[2].getRequest(true));
	delete slots;
	
	//load to ops
	self.loadAllJobsToOps(voyage, true);				
	self.addMachineRule(blockStack, crane.CM_Crane.transferArea, RTMoveMethod_23); //simple single straddle moves
	self.addMachineRule(crane.CM_Crane.transferArea, blockStack, RTMoveMethod_23); 
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	// Create Queues
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				wles.add(wle);
				self.queueWLE(wle);
			endforeach;
		endforeach;
	endforeach;
	
	// work Job using straddle
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(blockStack.id); 
	tas.add(yardIC.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	foreach wle in wles do
		self.machineAcceptTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
		self.machinePickup(straddle);
		self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, wle.allRTQueueEntries.first.allTasks.last.targetLocationId);
	endforeach;	
	self.assertTrue(container3.myPrimaryActualLocation.isVoyageController);
	self.assertTrue(container4.myPrimaryActualLocation.isVoyageController);
	
	// Now check some stuff - both containers should have been invoiced, and both should have two Release-Road lines
	// One line should be $40, the other should be $60
	shipRelease := container3.getLastTransOfType(TRANS_TYPE_REL_SHIP);
	self.assertNotNullMsg(shipRelease, "Ship Release transaction for " &amp; ExportCont1);
	self.assertEqualMsg(shipRelease.allInvoiceLines.size, 2, "Ship Release for " &amp; ExportCont1 &amp; " has wrong number of invoice lines");
	lineTotal := null;
	foreach invLine in shipRelease.allInvoiceLines do
		self.assertIsOneOf(invLine.quantity, "Invoice Line quantity for " &amp; ExportCont1 &amp; " is incorrect", 0.4, 0.6);
		// if invoice line is for VOID debtor it will not have a total (VOID debtor is not mapped to a charge)
		if not invLine.debtor.isRDT then
			self.assertIsOneOf(invLine.lineTotal.asStringJMT, "Invoice Line total for " &amp; ExportCont1 &amp; " is incorrect", "80.000000", "120.000000");
			lineTotal := lineTotal + invLine.lineTotal;
		endif;
	endforeach;
	//self.assertEqualMsg(invoice.getTotalAmount.asStringJMT, "200.00", "Invoice total for " &amp; ExportCont1 &amp; " is incorrect");
	shipRelease := container4.getLastTransOfType(TRANS_TYPE_REL_SHIP);
	self.assertNotNullMsg(shipRelease, "Ship Release transaction for " &amp; ExportCont2);
	self.assertEqualMsg(shipRelease.allInvoiceLines.size, 2, "Ship Release for " &amp; ExportCont2 &amp; " has wrong number of invoice lines");
	lineTotal := null;
	foreach invLine in shipRelease.allInvoiceLines do
		self.assertIsOneOf(invLine.quantity, "Invoice Line quantity for " &amp; ExportCont2 &amp; " is incorrect", 0.4, 0.6);
		// if invoice line is for VOID debtor it will not have a total (VOID debtor is not mapped to a charge)
		if not invLine.debtor.isRDT then
			self.assertIsOneOf(invLine.lineTotal.asStringJMT, "Invoice Line total for " &amp; ExportCont2 &amp; " is incorrect", "80.000000", "120.000000");
			lineTotal := lineTotal + invLine.lineTotal;
		endif;
	endforeach;
	//self.assertEqualMsg(invoice.getTotalAmount.asStringJMT, "200.00", "Invoice total for " &amp; ExportCont2 &amp; " is incorrect");
	
epilog
	self.setTerminalConfig(AllowRTSwithoutVGM, allowRTSwithoutVGM);
	delete codeGroups;
	delete emailAddresses;
	delete cmifConfig;
	delete cmifConfigDict;
	delete services;
	delete pxyPartner1;
	delete pxyPartner2;
	delete pxyPartners;
	pxyPP.erase(NORMAL_ERASE);
	// restore default transaction map
	if bank &lt;&gt; null then
		self.resetDefaultTranMap;
	endif;
	delete jobs;
	delete wles;
	delete tas;
	delete slots;
	app.isRTApp := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEscalatingCharges4RateMnsPert" id="ab59d346-7c89-42d4-a739-81d70cfeece9">
        <updating/>
        <source>tEscalatingCharges4RateMnsPert() updating;
// cnwma1
// cnwjre1 test 1280
//	create an invoice line per range (full escalating) is percentage
// 14 Dec 2021	navdap1	Unit test fixups after DMAST -&gt; WMAST code overwrite
vars
	start,
	expiry : TimeStamp;
	cStatus : CM_ContentsStatus;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate, editDate, today : Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate	: CM_DebtorRate;
 	rateEntry		: CM_RateEntry;
	storeTrans		: CM_TITransaction;
	invoiceLines	: ObjectArray;
	perDays, rangeStart, rangeEnd	: IntegerArray;
	costs : DecimalArray;
	isPrecentageRate,
	isAmount     : Boolean;
	roundTotal		: Boolean;
	rountTotalOpt   : Integer;
begin

	isPrecentageRate := true;
	isAmount		 := false;
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	
	// Keep track of the original value
	//roundTotal := self.getTerminal.getConfig(InvoiceRoundLineTotal).Boolean;   //19.03.2020 cnwma1 TFS #50925
	//self.getTerminal.setConfig(InvoiceRoundLineTotal, false);                  //19.03.2020 cnwma1 TFS #50925
	
	//rountTotalOpt := self.getTerminal.getConfig(InvoiceRoundLineTotal).Integer;  //19.03.2020 cnwma1 TFS #50925
	//self.setTerminalConfig(InvoiceRoundLineTotal,rountTotalOpt);            	//19.03.2020 cnwma1 TFS #50925
	rountTotalOpt := self.setTerminalConfig(InvoiceRoundLineTotal, CMIF_ConfigTerminal.InvLineRound_Value_NoRound).Integer;
	
	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_StorageEsc1');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree4", FORCED_ERASE);
	self.deleteInvoiceCalcType("UT_ESC");

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	// create an escalating charge cargo calculation type based on INV_CALC_TYPE_DAYS_SINCE_RECVL
	create perDays transient;
	create rangeStart transient;
	create rangeEnd transient;
	/* set up as in the functional spec - 1 to 5 days free
		6 - 10 days at $10 per day, 11 to 20 at $15 per day
		21 days plus at $20 per day, rate increasing by $8 every 10 days
	*/
	perDays.add(0); perDays.add(0); perDays.add(0); perDays.add(10);
	rangeStart.add(1); rangeStart.add(6); rangeStart.add(11); rangeStart.add(21);
	rangeEnd.add(5); rangeEnd.add(10); rangeEnd.add(20); rangeEnd.add(99999999);

	calType1 := self.createInvoiceCalcType(null, 6, "UT_ESC", "Escalating", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  true, false, false,
										  perDays, rangeStart, rangeEnd, null);
	self.assertNotNullMsg(calType1, "Calculation type Escalating Storage not created");
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStoreFree4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStoreFree4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStoreFree4 has null INV TYPE");
	endif;

	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadEscalatingChg3();
	
	// set up rates for this debtor and service used
	create costs transient;
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(theService, debtor);
	// rates are: $0 for 1-5, $10 for 6-10, $15 for 11-20, $20 for 21-max with $8 increment every 10 days
	costs.add(0.00);
	costs.add(10.00);
	costs.add(15.00);
	costs.add(20.00);
	costs.add(-8.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntryPercentage(pxyDebtorRate, start, expiry, false, costs,isPrecentageRate, isAmount);

	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);


	// Create Storage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300111"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	// set Trans to 65 days ago
	// ##################
	tranDate := tranDate - 65;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	cStatus := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	self.editIMEXStatus(cargo, TI_IMEX_STATUS_EXPORT,false);
	self.editCommodity(cargo, "GENL");
	
	// this creates the first storage transaction for 5 days
	editDate := tranDate + 5;
	// change the edit and storage tran to be 5 days later than receival
	foreach tran in cargo.allTransactions do
		if tran.dateTime.date &lt;&gt; today then
			continue;
		endif;
		tranTS.setDate(editDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	self.reevalStorageTrans(cargo);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);		// creates the second storage transaction and invoice lines
	
	self.validateEscalatingCharges3b(cargo, 1);
	self.reevalStorageTrans(cargo);
	// the transaction re-evaluate should not have changed anything
	self.validateEscalatingCharges3b(cargo, 2);

	storeTrans := cargo.getLastTransOfType(TRANS_TYPE_STORAGE);
	create invoiceLines transient;
	storeTrans.allInvoiceLines.copy(invoiceLines);
	self.invoiceLineReevaluate(invoiceLines);
	// the  invoice line re-evaluate should not have changed anything
	self.validateEscalatingCharges3b(cargo, 3);
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	//self.getTerminal.setConfig(InvoiceRoundLineTotal, roundTotal);		// Set back to original value //19.03.2020 cnwma1 TFS #50925
	self.setTerminalConfig(InvoiceRoundLineTotal, rountTotalOpt);            //19.03.2020 cnwma1 TFS #50925
	delete services;
	delete perDays;
	delete rangeStart;
	delete rangeEnd;
	delete costs;
	delete pxyDebtorRate;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEscalatingCharges4RatePlsPert" id="220d46a6-32b1-4933-9c87-e5f3c1722e18">
        <updating/>
        <source>tEscalatingCharges4RatePlsPert() updating;
// cnwma1
// cnwjre1 test 1280
//	create an invoice line per range (full escalating) is percentage
// 14/12/2021	navdap1	Unit test fixups after DMAST -&gt; WMAST code overwrite
vars
	start,
	expiry : TimeStamp;
	cStatus : CM_ContentsStatus;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate, editDate, today : Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate	: CM_DebtorRate;
 	rateEntry		: CM_RateEntry;
	storeTrans		: CM_TITransaction;
	invoiceLines	: ObjectArray;
	perDays, rangeStart, rangeEnd	: IntegerArray;
	costs : DecimalArray;
	isPrecentageRate,
	isAmount			: Boolean;
	roundTotal			: Boolean;
	roundTotalOpt       : Integer;
begin

	isPrecentageRate := true;
	isAmount		 := false;

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	// Keep track of the original value
	//roundTotal  := self.getTerminal.getConfig(InvoiceRoundLineTotal).Boolean;     //19.03.2020 cnwma1 TFS #50925
	//self.getTerminal.setConfig(InvoiceRoundLineTotal, false);                     //19.03.2020 cnwma1 TFS #50925
	//roundTotalOpt := self.getTerminal.getConfig(InvoiceRoundLineTotal).Integer;     //19.03.2020 cnwma1 TFS #50925
	//self.setTerminalConfig(InvoiceRoundLineTotal, roundTotalOpt);              		 //19.03.2020 cnwma1 TFS #50925
	roundTotalOpt := self.setTerminalConfig(InvoiceRoundLineTotal, CMIF_ConfigTerminal.InvLineRound_Value_NoRound).Integer;
	
	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_StorageEsc1');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree4", FORCED_ERASE);
	self.deleteInvoiceCalcType("UT_ESC");

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	// create an escalating charge cargo calculation type based on INV_CALC_TYPE_DAYS_SINCE_RECVL
	create perDays transient;
	create rangeStart transient;
	create rangeEnd transient;
	/* set up as in the functional spec - 1 to 5 days free
		6 - 10 days at $10 per day, 11 to 20 at $15 per day
		21 days plus at $20 per day, rate increasing by $8 every 10 days
	*/
	perDays.add(0); perDays.add(0); perDays.add(0); perDays.add(10);
	rangeStart.add(1); rangeStart.add(6); rangeStart.add(11); rangeStart.add(21);
	rangeEnd.add(5); rangeEnd.add(10); rangeEnd.add(20); rangeEnd.add(99999999);

	calType1 := self.createInvoiceCalcType(null, 6, "UT_ESC", "Escalating", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  true, false, false,
										  perDays, rangeStart, rangeEnd, null);
	self.assertNotNullMsg(calType1, "Calculation type Escalating Storage not created");
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStoreFree4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStoreFree4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStoreFree4 has null INV TYPE");
	endif;

	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadEscalatingChg3();
	
	// set up rates for this debtor and service used
	create costs transient;
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(theService, debtor);
	// rates are: $0 for 1-5, $10 for 6-10, $15 for 11-20, $20 for 21-max with $8 increment every 10 days
	costs.add(0.00);
	costs.add(10.00);
	costs.add(15.00);
	costs.add(20.00);
	costs.add(8.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntryPercentage(pxyDebtorRate, start, expiry, false, costs,isPrecentageRate, isAmount);

	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);


	// Create Storage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300111"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	// set Trans to 65 days ago
	// ##################
	tranDate := tranDate - 65;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	cStatus := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	self.editIMEXStatus(cargo, TI_IMEX_STATUS_EXPORT,false);
	self.editCommodity(cargo, "GENL");
	
	// this creates the first storage transaction for 5 days
	editDate := tranDate + 5;
	// change the edit and storage tran to be 5 days later than receival
	foreach tran in cargo.allTransactions do
		if tran.dateTime.date &lt;&gt; today then
			continue;
		endif;
		tranTS.setDate(editDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	self.reevalStorageTrans(cargo);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);		// creates the second storage transaction and invoice lines
	
	self.validateEscalatingCharges3a(cargo, 1);
	self.reevalStorageTrans(cargo);
	// the transaction re-evaluate should not have changed anything
	self.validateEscalatingCharges3a(cargo, 2);

	storeTrans := cargo.getLastTransOfType(TRANS_TYPE_STORAGE);
	create invoiceLines transient;
	storeTrans.allInvoiceLines.copy(invoiceLines);
	self.invoiceLineReevaluate(invoiceLines);
	// the  invoice line re-evaluate should not have changed anything
	self.validateEscalatingCharges3a(cargo, 3);
	
epilog
	self.resetDefaultTranMap();												    // 17/04/2013 cnwmh5
	//self.getTerminal.setConfig(InvoiceRoundLineTotal, roundTotal);			// Set back to original value  //19.03.2020 cnwma1 TFS #50925
	self.setTerminalConfig(InvoiceRoundLineTotal, roundTotalOpt);           //19.03.2020 cnwma1 TFS #50925
	delete services;
	delete perDays;
	delete rangeStart;
	delete rangeEnd;
	delete costs;
	delete pxyDebtorRate;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEscalatingCharges5AmntMns" id="e75d317a-518b-47ad-b20e-6287bc9f3b18">
        <updating/>
        <source>tEscalatingCharges5AmntMns()updating;
// cnwma1
// cnwjre1 test 1280
//	create an invoice line per range (full escalating) is percentage
// 14 Dec 2021	navdap1	Unit test fixups after DMAST -&gt; WMAST code overwrite
vars
	start,
	expiry : TimeStamp;
	cStatus : CM_ContentsStatus;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate, editDate, today : Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate	: CM_DebtorRate;
 	rateEntry		: CM_RateEntry;
	storeTrans		: CM_TITransaction;
	invoiceLines	: ObjectArray;
	perDays, rangeStart, rangeEnd	: IntegerArray;
	costs : DecimalArray;
	isPrecentageRate,
	isAmount 			: Boolean;
	roundTotalOpt	: Integer;
begin

	isAmount := true;

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	roundTotalOpt := self.setTerminalConfig(InvoiceRoundLineTotal, CMIF_ConfigTerminal.InvLineRound_Value_NoRound).Integer;
	
	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_StorageEsc1');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree4", FORCED_ERASE);
	self.deleteInvoiceCalcType("UT_ESC");

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	// create an escalating charge cargo calculation type based on INV_CALC_TYPE_DAYS_SINCE_RECVL
	create perDays transient;
	create rangeStart transient;
	create rangeEnd transient;
	/* set up as in the functional spec - 1 to 5 days free
		6 - 10 days at $10 per day, 11 to 20 at $15 per day
		21 days plus at $20 per day, rate increasing by $8 every 10 days
	*/
	perDays.add(0); perDays.add(0); perDays.add(0); perDays.add(10);
	rangeStart.add(1); rangeStart.add(6); rangeStart.add(11); rangeStart.add(21);
	rangeEnd.add(5); rangeEnd.add(10); rangeEnd.add(20); rangeEnd.add(99999999);

	calType1 := self.createInvoiceCalcType(null, 6, "UT_ESC", "Escalating", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  true, false, false,
										  perDays, rangeStart, rangeEnd, null);
	self.assertNotNullMsg(calType1, "Calculation type Escalating Storage not created");
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStoreFree4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStoreFree4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStoreFree4 has null INV TYPE");
	endif;

	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadEscalatingChg3();
	
	// set up rates for this debtor and service used
	create costs transient;
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(theService, debtor);
	// rates are: $0 for 1-5, $10 for 6-10, $15 for 11-20, $20 for 21-max with $8 increment every 10 days
	costs.add(0.00);
	costs.add(100.00);
	costs.add(150.00);
	costs.add(200.00);
	costs.add(-20.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntryPercentage(pxyDebtorRate, start, expiry, false, costs,isPrecentageRate, isAmount);

	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);


	// Create Storage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300111"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	// set Trans to 65 days ago
	// ##################
	tranDate := tranDate - 65;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	cStatus := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	self.editIMEXStatus(cargo, TI_IMEX_STATUS_EXPORT,false);
	self.editCommodity(cargo, "GENL");
	
	// this creates the first storage transaction for 5 days
	editDate := tranDate + 5;
	// change the edit and storage tran to be 5 days later than receival
	foreach tran in cargo.allTransactions do
		if tran.dateTime.date &lt;&gt; today then
			continue;
		endif;
		tranTS.setDate(editDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	self.reevalStorageTrans(cargo);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);		// creates the second storage transaction and invoice lines
	
	self.validateEscalatingCharges5b(cargo, 1);
	self.reevalStorageTrans(cargo);
	// the transaction re-evaluate should not have changed anything
	self.validateEscalatingCharges5b(cargo, 2);

	storeTrans := cargo.getLastTransOfType(TRANS_TYPE_STORAGE);
	create invoiceLines transient;
	storeTrans.allInvoiceLines.copy(invoiceLines);
	self.invoiceLineReevaluate(invoiceLines);
	// the  invoice line re-evaluate should not have changed anything
	self.validateEscalatingCharges5b(cargo, 3);
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	self.setTerminalConfig(InvoiceRoundLineTotal, roundTotalOpt);
	delete services;
	delete perDays;
	delete rangeStart;
	delete rangeEnd;
	delete costs;
	delete pxyDebtorRate;
	delete invoiceLines;
end;</source>
