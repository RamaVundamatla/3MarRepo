    <JadeMethod name="tDirectorReserveCargo2" id="71489f83-1021-4c14-b127-d77d255c7eb9">
        <updating/>
        <source>tDirectorReserveCargo2() updating;
// cnwer1
// cnwdw1	
// CCMS 2098 Director Task Cargo Assignment for Gridded Stacks
vars
	forkStack1: CM_ForkLiftStack;
	forkStack2: CM_ForkLiftStack;
	blockStack: CM_BlockStack;
	ti1, ti2, ti3 : CM_TrackedItem;
	operator : CM_Operator;
	moveRequest1, moveRequest2, moveRequest3, moveRequest4: CM_YardDeliveryRequest;
	forkLift: CM_Machine;
	tas: StringArray;
	queue: CM_RadioTelemetryQueue;
	queueEntry: CM_RTQueueEntry;
	configUBP,
	configDNCBR,
	configTBA: Boolean;
	configMTStrategy: Integer;
	sourceBays: CM_GridObjectArray;
	terminalAreas: CM_TerminalAreaArray;
	
begin
	self.setTerminalConfig(UseBestPickDirector, false);
	self.setTerminalConfig(DoNotCreateBulkRelease, true);
	self.setTerminalConfig(ShowRelReqOnShipLoadList, false);
	configMTStrategy := self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyTerminal).Integer;
	
	forkStack1 := self.addForkLiftStack("UTFKS1", 4,5,2);
	forkStack2 := self.addForkLiftStack("UTFKS2", 4,5,2);
	
	create terminalAreas transient;
	terminalAreas.add(forkStack1);
	terminalAreas.add(forkStack2);
	queue := self.addQueueToTA("UTFRKSQ", terminalAreas);

	blockStack := self.addBlockStack("UTBS1", 100, null);
	operator :=  self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_STORAGE);
	ti1 := self.addContainerOpts("UTTEST0001", "2200", "MT", operator);	
	move(ti1, self.getGridLocation(forkStack1, 1, 1));
	ti2 := self.addContainerOpts("UTTEST0002", "2201", "MT", operator);		
	move(ti2, self.getGridLocation(forkStack1,1, 1));
	ti3 := self.addContainerOpts("UTTEST0003", "2200", "MT", operator);		
	move(ti3, self.getGridLocation(forkStack2,1, 1));

	create sourceBays transient;
	moveRequest1 := self.moveDirector("UTYJ11", 1, operator.code, "2200", terminalAreas, sourceBays, blockStack); 
		assertEqual(moveRequest1.allWorkListEntries.first.allRTQueueEntries.first.allTasks.first.getSourceLocationId, "UTFKS1");
	
	create tas transient;
	tas.add("UTFKS1");
	tas.add("UTFKS2");
	tas.add("UTBS1");

	self.addMachineRule (forkStack2, blockStack, RTMoveMethod_24);  // Forklift
	forkLift := self.addForkLift("UTF1", 91, tas, "UTFRKSQ");
	self.machineAssignToQueue(forkLift, queue);
	self.machineLogon(forkLift);

	queueEntry := moveRequest1.allWorkListEntries.first.allRTQueueEntries.first;
		assertEqual(queueEntry.allTasks.size, 1);
	self.machineAcceptSpecifiedTask(forkLift, queueEntry);		// director task completed and ti pickup/setdowneated
	self.machinePickup(forkLift);
	self.machineSetdownTask(forkLift, queueEntry.allTasks.last , "UTBS1");
	
	self.machineLogOff(forkLift);
	
epilog
	delete tas;
	delete sourceBays;
	delete terminalAreas;
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, configMTStrategy);	
end;</source>
    </JadeMethod>
    <JadeMethod name="tDirectorTaskWithSubISOGrp" id="43e2f608-5162-4bc1-ba4e-73001ed39d26">
        <source>tDirectorTaskWithSubISOGrp();
/*

Purpose:			Testlink 01-893

Date		Who		Reason
13 May 2016	cnwmk3	Initial creation
//02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE

*/
constants
	ISOType				= "UTIS";
	ISOTypeGroupCode	= "UT01";
	ISOTypeDesc			= "UT ISO Group";
vars
	isoType				: CM_ISOType;
	isotypecoll			: CM_ISOTypeByCodeDict;
	isoTypeGroupSub		: CM_ISOTypeGroupByCodeDict;
	isoTypeGroup		: CM_ISOTypeGroup;
	gridArea			: CM_ForkLiftStack;
	ti1, ti2			: CM_TrackedItem;
	operator			: CM_Operator;
	release				: CM_BulkRelease;
	sourceBays			: CM_GridObjectArray;
	moveRequest			: CM_YardDeliveryRequest;
	terminalAreas		: CM_TerminalAreaArray;
	blockStack			: CM_BlockStack;
	locations			: CM_LCArray;
	ya					: CM_YardAllocation;
	tas					: StringArray;
	forkLift			: CM_Machine;
	queue				: CM_RadioTelemetryQueue;
	queueEntry			: CM_RTQueueEntry;
begin
	self.disableAllYA(true);
	self.deleteReleaseRequest("PACK_REL");
	// Create Iso Type
	isoType := self.addISOType(ISOType,
					"Unit Test Iso Type",app.myRoot.allCargoTypesById[TI_CargoType_Container], 
					true, false, false, false, false, false, false, false, false, false, false, true, false, false, false, false, true, 
					false, false, false, false, false, false, 2200);
	self.assertNotNull(isoType);

	create isotypecoll transient;
	isotypecoll.add(app.myRoot.allISOTypes[ISOType]);
	create isoTypeGroupSub transient;
	isoTypeGroupSub.add(app.myRoot.allISOTypeGroups["GEN2"]);
	
	//Create Iso Type Group
	isoTypeGroup := self.addISOGroup(ISOTypeGroupCode,ISOTypeDesc,isotypecoll,isoTypeGroupSub);
	self.assertNotNull(isoTypeGroup);
	
	// add a Gridded Block stack - source, add a block stack - target
	gridArea := self.addForkLiftStack("GBS01", 4, 4, 2);
	self.assertNotNull(gridArea);
	
	blockStack := self.addBlockStack("BS01", 100, null);
	self.assertNotNull(blockStack);
	queue := self.addQueueToTA("GRIDQ", blockStack);
	
	// yard allocation
	create locations transient;
	locations.add(gridArea.allGridControllersByRowColumn[1, 1]);
	locations.add(gridArea.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	
	// add two containers and move  to the gridArea
	operator :=  self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	ti1 := self.addContainer("UT00001893", operator,"UTIS", "MT", TI_IMEX_STATUS_STORAGE);	
	move(ti1, self.getGridLocation(gridArea, 1, 1));
	ti2 := self.addContainer("UT00002893", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);		
	move(ti2, self.getGridLocation(gridArea,1, 2));
	
	// create packing release by type with "Can be Hi or Low cube" set for the two containers.
	self.opts.purge();
	self.opts.addAssoc("ISOGroup", isoTypeGroup.code);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("Number", 2);
	release := self.addReleaseByTypeRequestOpts("PACK_REL", BR_TYPE_PACKING, TI_CargoType_Container);
	self.assertNotNull(release);
	
	// Create Internal Move
	create sourceBays transient;
	create terminalAreas transient;
	terminalAreas.add(gridArea);
	self.opts.purge();
	self.opts.addAssoc("Release", release);
	moveRequest := self.moveDirector("UTJOB", 2, operator.code, "", terminalAreas, sourceBays, blockStack); 
	self.assertEqual(moveRequest.allWorkListEntries.first.allRTQueueEntries.first.allTasks.first.getSourceLocationId, "GBS01(0001)");
	
	// work the director task
	create tas transient;
	tas.add("GBS01");
	tas.add("BS01");
	
	self.addMachineRule (gridArea, blockStack, RTMoveMethod_24);
	forkLift := self.addForkLift("FL01", 85, tas, "GRIDQ");
	self.machineAssignToQueue(forkLift, queue);
	self.machineLogon(forkLift);

	queueEntry := moveRequest.allWorkListEntries.first.allRTQueueEntries[1];
		assertEqual(queueEntry.allTasks.size, 1);
	self.moveRTTask(queueEntry, queue);
	
	queueEntry := moveRequest.allWorkListEntries.first.allRTQueueEntries[2];
		assertEqual(queueEntry.allTasks.size, 1);
	self.moveRTTask(queueEntry, queue);
	
	queueEntry := moveRequest.allWorkListEntries.last.allRTQueueEntries[1];
		assertEqual(queueEntry.allTasks.size, 1);
	self.moveRTTask(queueEntry, queue);
	
	queueEntry := moveRequest.allWorkListEntries.last.allRTQueueEntries[2];
		assertEqual(queueEntry.allTasks.size, 1);
	self.moveRTTask(queueEntry, queue);
	
	self.machineAcceptSpecifiedTask(forkLift, queue.allEntries.first);		// director task completed
	assertEqual(queueEntry.allTasks.size, 1);
	self.machineDirector(forkLift, ti1);
	self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);
	self.machineSetdownTask(forkLift, forkLift.allCurrentWorkingQueueTasks.first , "BS01");
	
	self.machineAcceptSpecifiedTask(forkLift, queue.allEntries[2]);		// ti1 pickup/setdowneated
	self.machinePickup(forkLift);
	self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);
	self.machineSetdownTask(forkLift, forkLift.allCurrentWorkingQueueTasks.first , "BS01");
	
	self.machineAcceptSpecifiedTask(forkLift, queue.allEntries[1]);		// director task completed
	self.machineDirector(forkLift, ti2);
	self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);
	self.machineSetdownTask(forkLift, forkLift.allCurrentWorkingQueueTasks.first, "BS01");
	
	self.machineAcceptSpecifiedTask(forkLift, queue.allEntries[2]);		// ti2 pickup/setdowneated
	self.machinePickup(forkLift);
	self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);
	self.machineSetdownTask(forkLift, forkLift.allCurrentWorkingQueueTasks.first , "BS01");
	
	machineLogOff(forkLift);
epilog
	delete isotypecoll;
	delete isoTypeGroupSub;
	delete sourceBays;
	delete terminalAreas;
	delete locations;
	delete tas;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tFLReseqOnOutOfOrder" id="825460e5-79b9-40ff-98a2-314ce5f9db1c">
        <source>tFLReseqOnOutOfOrder();
// cnwer1
//10 February 2011	cnwdw1	
// Test for PAR 28770
// 
vars
	fs: CM_ForkLiftStack;
	bs: CM_BlockStack;
	ti1, ti2, ti3, ti4: CM_TrackedItem;
	fl1, fl2: CM_Machine;
	tas: StringArray;
	q1: CM_RadioTelemetryQueue;
	task1, task2: CM_RTQueueTask;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
begin

	fs := self.addForkLiftStack("UT_FS", 5, 4, 1);
	bs := self.addBlockStack("UT_BS", 100, null);
	q1 := self.addQueueToTA("U_FS_Q", fs);
	
	create locations transient;
	locations.add(fs.allGridControllersByRowColumn[1, 1]);
	locations.add(fs.allGridControllersByRowColumn[5, 1]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);

	// add machine rule
	self.addMachineRule (bs, fs, RTMoveMethod_24);

	self.opts.addAssociation(UTTI_OverHeight, 20);		// Make over dimensional
	
	ti1 := self.addContainerOpts("UT100", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.move(ti1, bs);
	self.moveQueued(ti1, fs.allGridControllersByRowColumn[1, 1]);

	ti2 := self.addContainerOpts("UT101", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.move(ti2, bs);
	self.moveQueued(ti2, fs.allGridControllersByRowColumn[2, 1]);

	ti3 := self.addContainerOpts("UT102", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.move(ti3, bs);
	self.moveQueued(ti3, fs.allGridControllersByRowColumn[3, 1]);
	
	create tas transient;
	tas.add("UT_FS");
	tas.add("UT_BS");
	self.opts.addAssoc("AutoResequenceJobs", true);
	fl1 := self.addForkLift("UFL1", 91, tas, "U_FS_Q");
		assertNotNull(getTerminal.getRTVehicleConfigForObject(fl1));
		assertTrue(getTerminal.getRTVehicleConfigForObject(fl1).autoResequenceJobs);

	self.machineAssignToQueue(fl1, q1);
	
	self.machineLogon(fl1);
	task1 := q1.allEntries.last.allTasks.first;
	self.machineAcceptTask(fl1, task1);
		assertEqual(task1.ti.id, ti3.id);
		assertEqualMsg(task1.ultimateTargetLocationId, "UT_FS 000101", "Task not out of sequence has not been resequenced");

	self.machinePickup(fl1);
		assertEqual(task1.ultimateTargetLocationId, "UT_FS 000101");
		
	self.machineSetdown(fl1, ti3, "UT_FS 000101");
		assertEqual(ti3.myPrimaryActualLocation, fs.allGridControllersByRowColumn[1, 1]);

	task1 := q1.allEntries.last.allTasks.first;
	self.machineAcceptTask(fl1, task1);
		assertEqual(task1.ti.id, ti2.id);
		assertEqualMsg(task1.ultimateTargetLocationId, "UT_FS 000102", "Task not out of sequence has not been resequenced");

	self.machinePickup(fl1);
		assertEqual(task1.ultimateTargetLocationId, "UT_FS 000102");
		
	self.machineSetdown(fl1, ti2, "UT_FS 000102");
		assertEqual(ti2.myPrimaryActualLocation, fs.allGridControllersByRowColumn[2, 1]);

	task1 := q1.allEntries.last.allTasks.first;
	self.machineAcceptTask(fl1, task1);
		assertEqual(task1.ti.id, ti1.id);
		assertEqualMsg(task1.ultimateTargetLocationId, "UT_FS 000103", "Task not out of sequence has not been resequenced");

	self.machinePickup(fl1);
		assertEqual(task1.ultimateTargetLocationId, "UT_FS 000103");
		
	self.machineSetdown(fl1, ti1, "UT_FS 000103");
		assertEqual(ti1.myPrimaryActualLocation, fs.allGridControllersByRowColumn[3, 1]);

	self.machineLogOff(fl1);
	
epilog
	delete locations;
	opts.purge;
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFLReseqOverride" id="8406cf77-37df-4c01-a274-885a76f3b2f3">
        <source>tFLReseqOverride();
// jlgmd1
/* cnwkpd1

Purpose:			Test ability to manually override auto resequence.  Cloned from tFLReseqOnOutOfOrder and modified

Date		Who		Reason
25 Oct 2012	cnwkpd1	PAR #30276 - Override auto-resequence by control
11 Mar 2013	cnwkpd1	Remove height from target location checking

*/

vars
	fs				: CM_ForkLiftStack;
	bs				: CM_BlockStack;
	ti1, 
	ti2, 
	ti3, 
	ti4				: CM_TrackedItem;
	fl1, 
	fl2				: CM_Machine;
	tas				: StringArray;
	q1				: CM_RadioTelemetryQueue;
	task1, 
	task2			: CM_RTQueueTask;
	locations 		: CM_LCArray;
	ya				: CM_YardAllocation;
	entry,
	pxyEntry		: CM_RTQueueEntry;
	loadState		: Boolean;
	
begin
	fs := self.addForkLiftStack("UT_FS", 5, 4, 1);
	bs := self.addBlockStack("UT_BS", 100, null);
	q1 := self.addQueueToTA("U_FS_Q", fs);
	
	create locations transient;
	locations.add(fs.allGridControllersByRowColumn[1, 1]);
	locations.add(fs.allGridControllersByRowColumn[5, 1]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);

	// add machine rule
	self.addMachineRule (bs, fs, RTMoveMethod_24);

	self.opts.addAssociation(UTTI_OverHeight, 20);		// Make over dimensional
	
	ti1 := self.addContainerOpts("UT100", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.move(ti1, bs);
	self.moveQueued(ti1, fs.allGridControllersByRowColumn[1, 1]);

	ti2 := self.addContainerOpts("UT101", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.move(ti2, bs);
	self.moveQueued(ti2, fs.allGridControllersByRowColumn[4, 1]);

	ti3 := self.addContainerOpts("UT102", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.move(ti3, bs);
	self.moveQueued(ti3, fs.allGridControllersByRowColumn[5, 1]);
	
	create tas transient;
	tas.add("UT_FS");
	tas.add("UT_BS");
	self.opts.addAssoc("AutoResequenceJobs", true);
	fl1 := self.addForkLift("UFL1", 91, tas, "U_FS_Q");
	self.assertNotNull(getTerminal.getRTVehicleConfigForObject(fl1));
	self.assertTrue(getTerminal.getRTVehicleConfigForObject(fl1).autoResequenceJobs);

	self.machineAssignToQueue(fl1, q1);
	
	self.machineLogon(fl1);
	task1 := q1.allEntries.last.allTasks.first;
	self.machineAcceptTask(fl1, task1);
	self.assertEqual(task1.ti.id, ti3.id);
	self.assertEqualMsg(task1.ultimateTargetLocationId, "UT_FS 000101", "Task not out of sequence has not been resequenced");

	self.machinePickup(fl1);
	self.assertEqual(task1.ultimateTargetLocationId, "UT_FS 000101");
		
	self.machineSetdown(fl1, ti3, "UT_FS 000101");
	self.assertEqual(ti3.myPrimaryActualLocation, fs.allGridControllersByRowColumn[1, 1]);

	entry := q1.allEntries.last;
	
	task1 := entry.allTasks.first;
	self.assertEqualMsg(task1.ultimateTargetLocationId, "UT_FS 000104", "Original queueing did not queue to correct location");
	
	// Set Override Flags on the entry
	app.cmsBeginLoad(loadState);
	pxyEntry := entry.pxyCreateUpdateProxy;
	pxyEntry.setProxyOverRideFlags(entry);
	app.cmsEndLoad(loadState);
	app.myTrxUA.trxUpdateQueueEntryFlag(pxyEntry, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotEqualMsg(entry.overRideFlags, 0, "Override flags have not been set");
	
	self.machineAcceptTask(fl1, task1);
	self.assertEqual(task1.ti.id, ti2.id);
	self.assertEqualMsg(task1.ultimateTargetLocationId, "UT_FS 000104", "Resequence override did not work");

	self.machinePickup(fl1);
	self.assertEqual(task1.ultimateTargetLocationId, "UT_FS 000104");
		
	self.machineSetdown(fl1, ti2, "UT_FS 000104");
	self.assertEqual(ti2.myPrimaryActualLocation, fs.allGridControllersByRowColumn[4, 1]);

	// Check that the subsequent resequence still works correctly
	task1 := q1.allEntries.last.allTasks.first;
	self.machineAcceptTask(fl1, task1);
	self.assertEqual(task1.ti.id, ti1.id);
	self.assertEqualMsg(task1.ultimateTargetLocationId, "UT_FS 000105", "Task not out of sequence has not been resequenced");

	self.machinePickup(fl1);
	self.assertEqual(task1.ultimateTargetLocationId, "UT_FS 000105");
		
	self.machineSetdown(fl1, ti1, "UT_FS 000105");
	self.assertEqual(ti1.myPrimaryActualLocation, fs.allGridControllersByRowColumn[5, 1]);

	self.machineLogOff(fl1);
	
epilog
	delete locations;
	self.opts.purge;
	delete tas;
	delete pxyEntry;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tFLResequenceOnHeightLimit" id="cad06313-f23f-48a7-8398-973732989585">
        <source>tFLResequenceOnHeightLimit();
// cnwer1
//10 February 2011	cnwdw1	
// Test for PAR 26948
vars
	fs: CM_ForkLiftStack;
	ti1, ti2, ti3, ti4: CM_TrackedItem;
	fl1, fl2: CM_Machine;
	tas: StringArray;
	q1: CM_RadioTelemetryQueue;
	task1, task2: CM_RTQueueTask;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
begin

	fs := self.addForkLiftStack("UT_FS", 3, 4, 3);
	q1 := self.addQueueToTA("U_FS_Q", fs);
	
	create locations transient;
	locations.add(fs.allGridControllersByRowColumn[1, 1]);
	locations.add(fs.allGridControllersByRowColumn[3, 1]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);

	ti1 := self.addContainer("UT100", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti1, fs.allGridControllersByRowColumn[1, 1]);
	
	ti2 := self.addContainer("UT102", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti2, fs.allGridControllersByRowColumn[1, 1]);

	ti3 := self.addContainer("UT103", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti3, fs.allGridControllersByRowColumn[1, 3]);
	self.moveQueued(ti3, fs.allGridControllersByRowColumn[1, 1]);
	
	ti4 := self.addContainer("UT104", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti4, fs.allGridControllersByRowColumn[1, 2]);
	self.moveQueued(ti4, fs.allGridControllersByRowColumn[2, 1]);

	create tas transient;
	tas.add("UT_FS");
	self.opts.addAssoc("AutoResequenceJobs", true);
	self.opts.addAssoc("MaxStackHeightFull", 28.5);		// Machines can lift to 3rd teir
	self.opts.addAssoc("MaxStackHeightMT", 28.5);
	fl1 := self.addForkLift("UFL1", 91, tas, "U_FS_Q");
		assertEqual(fl1.maxHeightFull, 28.5);
		assertEqual(fl1.maxHeightMT, 28.5);
		assertNotNull(getTerminal.getRTVehicleConfigForObject(fl1));
		assertTrue(getTerminal.getRTVehicleConfigForObject(fl1).autoResequenceJobs);
	
	fl2 := self.addForkLift("UFL2", 92, tas, "U_FS_Q");
		assertEqual(fl2.maxHeightFull, 28.5);
		assertEqual(fl2.maxHeightMT, 28.5);
		assertNotNull(getTerminal.getRTVehicleConfigForObject(fl2));
		assertTrue(getTerminal.getRTVehicleConfigForObject(fl2).autoResequenceJobs);

	self.machineAssignToQueue(fl1, q1);
	self.machineAssignToQueue(fl2, q1);
	
	self.machineLogon(fl1);
	task1 := self.machineTaskRequest(fl1);
	self.machineAcceptTask(fl1, task1);
		assertEqual(task1.ultimateTargetLocationId, "UT_FS 000101");

	self.machineLogon(fl2);
	task2 := self.machineTaskRequest(fl2);
	self.machineAcceptTask(fl2, task2);
		assertEqual(task2.ultimateTargetLocationId, "UT_FS 000101");

	self.machinePickup(fl1);
		assertEqual(task1.ultimateTargetLocationId, "UT_FS 000101");
	self.machineSetdown(fl1, ti3, "UT_FS 000101");
		assertEqual(ti3.myPrimaryActualLocation, fs.allGridControllersByRowColumn[1, 1]);

	self.machinePickup(fl2);
		assertEqual(task2.ultimateTargetLocationId, "UT_FS 000102");
	self.machineSetdown(fl2, ti4, "UT_FS 000102");
		assertEqual(ti4.myPrimaryActualLocation, fs.allGridControllersByRowColumn[2, 1]);

	self.machineLogOff(fl1);
	self.machineLogOff(fl2);
	
epilog
	delete locations;
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFullMoveQueueing" id="dc810355-5f38-4fc1-9e54-9eb2c5d015f8">
        <updating/>
        <source>tFullMoveQueueing() updating;
/*
Purpose:
	We're going to use multi-machine moves to queue a container 
		1. from road to gridded block stack			- same queue for both legs
		2. from gridded block stack to block stack	- same queue for both legs
		3. from gridded block stack to road			- same queue for both legs
		4. from gridded block stack to ship			- voyage queue for 1stleg, crane queue for 2nd leg
	using new "Full Move Queueing" as described in CCMS 2008

Parameters:			

Return Value:		

Date		Who		Reason
02/09/2011	cnwdap1	Initial creation PAR #25693 CCMS POL 2008
28/09/2011	cnwdap1	PAR #28280 Additions to check queue ordering and bi-directional queues
*/
constants
	Container1			= "UTDP0000001";
	GriddedBlockStack1	= "UT_DPGBS1";
	BlockStack1			= "UT_DPBS1";
	YardIC				= "UT_DP_IC";
	Truck1				= "UTDPTRUCK";
	Ship				= "UTDPSHIP";
	Voyage1				= "UTDPVOYAGE";
	TestOperator		= "MSK";
	FirstQueue			= "UT_DPQ1";
	SecondQueue			= "UT_DPQ2";
	
vars
	ti				: CM_Container;
	gbs				: CM_ForkLiftStack;
	bs				: CM_BlockStack;
	yardIC			: CM_InterchangeArea;
	machineRule		: CM_RTQueueMultiRule;
	vvr				: CM_VehicleVisitRecord;
	wle				: CM_WorkListEntry;
	gate 			: CM_Gate;
	gateOut			: CM_GateArea;
	taType			: CM_TerminalAreaType;
	release			: CM_BulkRelease;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	tis				: CM_TIArray;
	slots 			: CM_SlotControllerArray;
	tmpLoadCC		: CMIF_LoadColorCode;
	voyageJob		: CM_VoyageJob;
	wlesToMove, 
	wlesWithWarning : CM_WLEArray;
	job				: CM_Job;
	masterQueue		: CM_MasterQueue;
	voyageQueue		: CM_RadioTelemetryQueue;
	crane			: CM_Crane;
	firstQueue		: CM_SubQueue;
	secondQueue		: CM_SubQueue;
	allowRTS		: Boolean;
	qEntry : CM_RTQueueEntry;
	task 			: CM_RTQueueTask;
	truck	 		: CM_Vehicle;
begin
	// delete everything first
	self.deleteContainer(Container1);
	self.deleteTerminalArea(GriddedBlockStack1);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVehicle(Truck1);
	self.deleteQueue(FirstQueue);
	self.deleteQueue(SecondQueue);
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	gbs := self.addForkLiftStack(GriddedBlockStack1, 2, 2, 1);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);
	
	allowRTS := self.setTerminalConfig(AllowRTSwithoutVGM, true).Boolean;
	
	// create the gates
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	gateOut := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	assertNotNull(gateOut);
	
	// PAR #28280 create the queues and insert them in the master queue order array
	// first queue is bi-directional with no default terminal areas, and will be the highest queue in the master queue order array
	// second queue is bi-directional with our gridded block stack as a "To Terminal Area"
	firstQueue := self.addQueue(FirstQueue, null, null, false);
	secondQueue := self.addQueue(SecondQueue, null, gbs, false);
	assertTrueMsg(firstQueue.isUnidirectional = false, "Queue " &amp; FirstQueue &amp; " is not Bi-Directional");
	assertTrueMsg(secondQueue.isUnidirectional = false, "Queue " &amp; SecondQueue &amp; " is not Bi-Directional");
	assertTrueMsg(secondQueue.allMoveToTAMasters.includes(gbs), "Queue " &amp; SecondQueue &amp; " doesn't have " &amp; gbs.id &amp; " in its to terminal areas");
	beginTransaction;
	self.getTerminal.radioTelemetry.masterQueue.moveSubQueue(firstQueue, 1);
	self.getTerminal.radioTelemetry.masterQueue.moveSubQueue(secondQueue, (self.getTerminal.radioTelemetry.masterQueue.allSubQueuesByOrder.size - 2));
	commitTransaction;
	assertTrue(self.getTerminal.radioTelemetry.masterQueue.allSubQueuesByOrder[1] = firstQueue);
	assertTrue(self.getTerminal.radioTelemetry.masterQueue.allSubQueuesByOrder.indexOf(secondQueue) &gt; 1);
	
	// the machine move rules created here will be created with Full Move Queuing
	// create a machine move rule for gridded block stack to Source IC to road
	taType := self.getRoot.allTerminalAreaTypes[TA_TYPE_GATE_ROAD];
	// delete old rule first
	machineRule := self.getTerminal.allRTQueueMultiRuleTATypes[taType, gbs.myType];
	if machineRule &lt;&gt; null then
		beginTransaction;
		delete machineRule;
		commitTransaction;
	endif;
	self.addMachineRuleType(taType, gbs.myType, RTMoveMethod_25, FullMoveQueuing);
	// and vice versa (road to Target IC to GBS)
	// delete old first
	machineRule := self.getTerminal.allRTQueueMultiRuleTATypes[gbs.myType, taType];
	if machineRule &lt;&gt; null then
		beginTransaction;
		delete machineRule;
		commitTransaction;
	endif;
	self.addMachineRuleType(gbs.myType, taType, RTMoveMethod_26, FullMoveQueuing);
	// and a machinde rule for GSB -&gt; Target IC - &gt; BS
	// delete old first
	machineRule := self.getTerminal.allRTQueueMultiRuleTATypes[gbs.myType, bs.myType];
	if machineRule &lt;&gt; null then
		beginTransaction;
		delete machineRule;
		commitTransaction;
	endif;
	self.addMachineRuleType(gbs.myType, bs.myType, RTMoveMethod_26, FullMoveQueuing);
	
	// gate in container
	self.opts.purge;
	self.opts.addAssociation("Location", gbs.id &amp; " 000101 1");
	self.opts.addAssociation("AutoComplete", false);
	vvr := self.gateInContainer(Truck1, Container1, "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "GENL", gate); 
	ti := self.getTrackedItem(Container1).CM_Container;
	assertNotNull(ti);
	assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
	assertEqual(ti.getPrimaryLocation(QUEUE_MODE).myTerminalArea, gbs);
	// check the queues on the WLE tasks are all the same
	wle := self.getVehicle(Truck1).allRoadJobs.first.workListEntries.first;
	assertNotNull(wle);
	assertEqual(wle.allRTQueueEntries.size, 2);
	assertEqual(wle.allRTQueueEntries.first.myQueue, wle.allRTQueueEntries.last.myQueue);
	// PAR #28280 check the TI is queued in the first queue we created (highest in priority order under the Master Queue)
	assertEqual(wle.allRTQueueEntries.first.myQueue, firstQueue);
	
	//jira 35614 jlier1 11/8/25 
	//check the source and target of the queue entry tasks  - this is forklift -&gt; source IC -&gt;fork lift - RTMoveMethod_25
	truck:=vvr.vehicle;
	qEntry:=wle.allRTQueueEntries.first;

	self.assertNotNullMsg(qEntry,"First leg queue entry is null");
	task:=qEntry.getTaskOfType(TASK_PICKUP,null);
	self.assertNotNullMsg(task, "First leg pickup task is null");
	//source should be truck location 
	self.assertEqualMsg(task.sourceLocation, truck.locationsController,"Task source not the vehicle controller");
	//target should be source area interchange location 
	self.assertEqualMsg(task.targetLocation, vvr.myGateIn.myDefaultInterchangeArea.getFirstAvailalableLane,"Task target not the source road gate area interchange lane");
	
	// now move the container to the gbs and get rid of the vehicle
	self.moveVehicleToLane(vvr.vehicle, gate.allGateAreas_IN.first.myGateArea, 1);
	self.moveVehicleToYard(vvr.vehicle);
	self.workVehicle(vvr);
	self.moveVehicleToLane(vvr.vehicle, gateOut, 1);
	self.roadExit(vvr);
	assertEqual(ti.getPrimaryLocation(REAL_MODE).myTerminalArea, gbs);
	
	// queue the container from GBS to BS
	self.moveQueued(ti, bs);
	assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
	assertEqual(ti.getPrimaryLocation(QUEUE_MODE).myTerminalArea, bs);
	// check the queues on the WLE tasks are all the same
	wle := ti.allWorklistEntries.last;
	assertNotNull(wle);
	assertEqual(wle.allRTQueueEntries.size, 2);
	assertEqual(wle.allRTQueueEntries.first.myQueue, wle.allRTQueueEntries.last.myQueue);
	//jira 35614 jlier1 11/8/25 
	//rule is fork -&gt; target IC -&gt; fork check that the pickup task target is the BS area interchange
	qEntry:=wle.allRTQueueEntries.first;
	self.assertNotNullMsg(qEntry,"First leg queue entry is null");
	task:=qEntry.getTaskOfType(TASK_PICKUP,null);
	self.assertNotNullMsg(task, "First leg pickup task is null");
	//source should be where the container is 
	self.assertEqualMsg(task.sourceLocation, ti.getPrimaryLocation(REAL_MODE),"Task source not the the containers location");
	//target should be target area interchange location 
	self.assertEqualMsg(task.targetLocation, bs.myDefaultInterchangeArea.getFirstAvailalableLane,"Task target not the target block stack interchange area lane");
	
	// move ti to the bs
	self.moveQueuedCargo(wle);
	// and back to the gbs for the next test
	self.move(ti, gbs);
	assertEqual(ti.getPrimaryLocation(REAL_MODE).myTerminalArea, gbs);
	
	// create a road release for the ti
	self.deleteReleaseRequest("UT_DPREL");
	release := self.addReleaseById("UT_DPREL", BR_TYPE_ROAD, ti);
	self.deleteVehicle(Truck1);
	self.opts.purge;
	self.opts.addAssociation("Release", release);
	vvr := self.gateOutContainer(Truck1, null, "UTDRIVER", ti, true, gateOut.getFirstExitGate, null);
	assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
	// check the queues on the WLE tasks are all the same
	wle := self.getVehicle(Truck1).allRoadJobs.first.workListEntries.first;
	assertNotNull(wle);
	assertEqual(wle.allRTQueueEntries.size, 2);
	assertEqual(wle.allRTQueueEntries.first.myQueue, wle.allRTQueueEntries.last.myQueue);
	//jira 35614 jlier1 11/8/25 
	//check the target interchange 
	qEntry:=wle.allRTQueueEntries.first;
	self.assertNotNullMsg(qEntry,"First leg queue entry is null");
	task:=qEntry.getTaskOfType(TASK_PICKUP,null);
	self.assertNotNullMsg(task, "First leg pickup task is null");
	//source should be where the container is 
	self.assertEqualMsg(task.sourceLocation, ti.getPrimaryLocation(REAL_MODE),"Task source not the the containers location");
	//target should be target area interchange location 
	self.assertEqualMsg(task.targetLocation, vvr.myGateIn.myDefaultInterchangeArea.getFirstAvailalableLane,"Task target not the target block stack interchange area lane");
	
	
	// get rid of the wle, release and vvr, as we don't want them any more
	beginTransaction;
	ti.doForcedUnqueue(app.myPassport);
	delete wle;
	commitTransaction;
	self.deleteVVR(vvr);
	self.deleteReleaseRequest(release.code);
	assertEqual(ti.getPrimaryLocation(QUEUE_MODE), null);
	assertEqual(ti.allWorklistEntries.size, null);
	
	// create a machine rule for gbs -&gt; IC -&gt; voyage
	taType := self.getRoot.allTerminalAreaTypes[TA_TYPE_CRANE_TRANS];
	// delete old rule first
	machineRule := self.getTerminal.allRTQueueMultiRuleTATypes[gbs.myType, taType];
	if machineRule &lt;&gt; null then
		beginTransaction;
		delete machineRule;
		commitTransaction;
	endif;
	self.addMachineRuleType(gbs.myType, taType, RTMoveMethod_26, FullMoveQueuing);
	
	// create a voyage
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.opts.purge;
	// Create Export voyage
	vessel := self.addVesselCellular(Ship, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add export vessel failed');
	voyage := self.addVoyageWithContainerStructur(	Voyage1,
													Ship,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg(voyage, 'Add export voyage failed');
	voyage := self.getVoyage(Voyage1);
	self.assertNotNull(voyage);
	// assign ti to voyage
	beginTransaction;
	ti.setMyVoyage(voyage, app.myPassport);
	ti.setImExStatus(TI_IMEX_STATUS_EXPORT);
	ti.setDischargePort("NZAKL");
	ti.updateContentsStatus;
	commitTransaction;
	assertEqualMsg(ti.contentsStatus, TI_CONTENTS_STATUS_FCL, "Container contents status is not FCL");
	// now plan the TI to the export voyage
	// remove stops
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	self.deleteStops(ti);
	// mark as ready to ship
	create tis transient;
	voyage.allOnsiteTIsByCargoTypeId.copy(tis);
	app.myTrxUA.trxUpdateTIsReadyToShip(tis, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	// create voyage job and slots
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType := true;
	tmpLoadCC.myDischargePort := app.myRoot.allPorts["NZAKL"];
	self.getJobSlotControllers(voyage.code, "01", DeckOnDeck, 1, 1, 1, slots);
	self.markSlotsAsLoadJob(slots, tmpLoadCC);
	voyageJob := self.addVoyageJob(voyage, "CRN1", slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	// create voyage queue and crane queue
	masterQueue := self.getTerminal.radioTelemetry.masterQueue;
	beginTransaction;
	masterQueue.createVoyageQueue(voyage, voyageQueue);
	crane := voyageJob.getJobCrane;
	crane.setPropertyValue(CM_Crane::myPrimaryQueue.name, voyageQueue);
	if crane &lt;&gt; null then
		voyageQueue.CM_VoyageQueue.createCraneQueue(crane, voyageQueue);
	endif;
	commitTransaction;
	
	// plan item
	self.planLoadItem(voyage, "CRN1");
	// and queue
	create wlesToMove transient;
	create wlesWithWarning transient;
	foreach job in voyage.allVoyageJobs discreteLock do
		if job.CM_VoyageJob.isHatchLidJob() then
			continue;
		endif;
		foreach wle in job.workListEntries discreteLock do
			wlesToMove.clear();
			wlesWithWarning.clear();
			wlesToMove.add(wle);
			app.myTrxUA.trxUpdateWLEsDoMove(wlesToMove, wlesWithWarning, QUEUE_MODE, true, null,app.myPassport);
			//process.sleep(5000);
		endforeach;
	endforeach;
	wle := voyageJob.workListEntries.first;
	assertNotNullMsg(wle, "no WLE on voyage job");
	assertNotNullMsg(ti.getPrimaryLocation(QUEUE_MODE), "TI has no queued location");
	assertEqualMsg(voyageJob.workListEntries.size, 1, "More than 1 WLE on voyage job");
	assertEqualMsg(wle.allRTQueueEntries.size, 2, "WLE does not have 2 RT queue entries");
	assertTrueMsg(wle.allRTQueueEntries.first.myQueue.isKindOf(CM_VoyageQueue), "RT queue for first leg is not a Voyage queue");
	assertTrueMsg(wle.allRTQueueEntries.last.myQueue.isKindOf(CM_VoyageCraneQueue), "RT queue for second leg is not a Voyage Crane queue");
	assertTrueMsg((wle.allRTQueueEntries.first.myQueue.CM_VoyageQueue.myVoyage = voyage), "RT queue for first leg is the WRONG voyage");
	assertTrueMsg((wle.allRTQueueEntries.last.myQueue.CM_VoyageCraneQueue.myVoyage = voyage), "RT queue for second leg is the WRONG voyage");
epilog
	delete tis;
	delete slots;
	delete tmpLoadCC;
	delete wlesToMove;
	delete wlesWithWarning;
	self.setTerminalConfig(AllowRTSwithoutVGM, allowRTS);
	abortTransaction;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tGateInTargetIC" id="c89e868e-0024-4ce6-a08a-138d55637d2c">
        <source>tGateInTargetIC();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2025	jlier1	Initial creation - test the rule Forklift -&gt; Target IC - Fork lift - make sure after gate in the target of the first rt task is the target areas interchange area and not the road gate interchange

*/
constants
	Container1			= "UTDP0000001";
	BlockStack1			= "UT_DPBS1";
	YardIC				= "UT_DP_IC";
	Truck1				= "UTDPTRUCK";
	FirstQueue			= "UT_DPQ1";
vars
	ti				: CM_Container;
	bs				: CM_BlockStack;
	yardIC			: CM_InterchangeArea;
	machineRule		: CM_RTQueueMultiRule;
	vvr				: CM_VehicleVisitRecord;
	wle				: CM_WorkListEntry;
	gate 			: CM_Gate;
	gateOut			: CM_GateArea;
	taType			: CM_TerminalAreaType;
	firstQueue		: CM_SubQueue;
	allowRTS		: Boolean;
	qEntry : CM_RTQueueEntry;
	task 			: CM_RTQueueTask;
	truck	 		: CM_Vehicle;
	machineRulesAdded : ObjectSet;
begin
	// delete everything first
	self.deleteContainer(Container1);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVehicle(Truck1);
	self.deleteQueue(FirstQueue);
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);
	
	allowRTS := self.setTerminalConfig(AllowRTSwithoutVGM, true).Boolean;
	
	// create the gates
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	gateOut := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	assertNotNull(gateOut);
	
	// PAR #28280 create the queues and insert them in the master queue order array
	// first queue is bi-directional with no default terminal areas, and will be the highest queue in the master queue order array
	// second queue is bi-directional with our gridded block stack as a "To Terminal Area"
	firstQueue := self.addQueue(FirstQueue, null, null, false);
	beginTransaction;
	self.getTerminal.radioTelemetry.masterQueue.moveSubQueue(firstQueue, 1);
	commitTransaction;
	assertTrue(self.getTerminal.radioTelemetry.masterQueue.allSubQueuesByOrder[1] = firstQueue);

	
	// the machine move rules created here will be created with Full Move Queuing
	// create a machine move rule for gate are to Target IC to block stack
	taType := self.getRoot.allTerminalAreaTypes[TA_TYPE_GATE_ROAD];
	// delete old rule first
	machineRule := self.getTerminal.allRTQueueMultiRuleTATypes[taType, bs.myType];
	if machineRule &lt;&gt; null then
		beginTransaction;
		delete machineRule;
		commitTransaction;
	endif;
	self.addMachineRuleType(taType, bs.myType, RTMoveMethod_26, FullMoveQueuing);
	
	create machineRulesAdded transient;
	machineRule := self.getTerminal.allRTQueueMultiRuleTATypes[taType, bs.myType];
	if machineRule &lt;&gt; null then
		machineRulesAdded.add(machineRule);
	endif;
	
	// gate in container
	self.opts.purge;
	self.opts.addAssociation("Location", bs.id);
	self.opts.addAssociation("AutoComplete", false);
	vvr := self.gateInContainer(Truck1, Container1, "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "GENL", gate); 
	ti := self.getTrackedItem(Container1).CM_Container;
	assertNotNull(ti);
	assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
	assertEqual(ti.getPrimaryLocation(QUEUE_MODE).myTerminalArea, bs);
	// check the queues on the WLE tasks are all the same
	wle := self.getVehicle(Truck1).allRoadJobs.first.workListEntries.first;
	assertNotNull(wle);
	assertEqual(wle.allRTQueueEntries.size, 2);
	assertEqual(wle.allRTQueueEntries.first.myQueue, wle.allRTQueueEntries.last.myQueue);
	// PAR #28280 check the TI is queued in the first queue we created (highest in priority order under the Master Queue)
	assertEqual(wle.allRTQueueEntries.first.myQueue, firstQueue);
	
	//jira 35614 jlier1 11/8/25 
	//check the source and target of the queue entry tasks  - this is forklift -&gt; source IC -&gt;fork lift - RTMoveMethod_25
	truck:=vvr.vehicle;
	qEntry:=wle.allRTQueueEntries.first;

	self.assertNotNullMsg(qEntry,"First leg queue entry is null");
	task:=qEntry.getTaskOfType(TASK_PICKUP,null);
	self.assertNotNullMsg(task, "First leg pickup task is null");
	//source should be truck location 
	self.assertEqualMsg(task.sourceLocation, truck.locationsController,"Task source not the vehicle controller");
	//target should be source area interchange location 
	self.assertEqualMsg(task.targetLocation, bs.myDefaultInterchangeArea.getFirstAvailalableLane,"Task target not the source road gate area interchange lane");

epilog
	if machineRulesAdded &lt;&gt; null then
		beginTransaction;
			machineRulesAdded.purge;
		commitTransaction;
		delete machineRulesAdded;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGetQueuesForFLtoIMVtoFL" id="30189a4c-a9e3-4452-a5c3-b6a9d99d63e4">
        <source>tGetQueuesForFLtoIMVtoFL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2012	cnwer1	Initial creation PAR 30376

*/
	
constants
	TheContainer = 	"UT1001";
	Q4BS1 = "BS1_Q";
	Q4BS2 = "BS2_Q";
	QIMV  ="IMV_Q";
	BS1 = "UT_BS1";
	BS2 = "UT_BS2";
vars
	bs1,bs2 : CM_BlockStack;
	container : CM_Container;
	q1,q2,q3 : CM_SubQueue;
	entry : CM_RTQueueEntry;
	task : CM_RTQueueTask;
begin
	self.deleteContainer(TheContainer);
	self.deleteQueue(Q4BS1);
	self.deleteTerminalArea(BS1);
	self.deleteQueue(Q4BS2);
	self.deleteTerminalArea(BS2);
	self.deleteQueue(QIMV);
	
	bs1 := self.addBlockStack(BS1, 10, null);
	assertNotNull(bs1);
	self.opts.purge;
	self.opts.addAssoc("AllowedMachineTypeGrp", MACHINETYPEGRP_LIFTER);
	q3:=self.addQueue(QIMV, null,null,false);
	q1 := self.addQueue(Q4BS1, BS1,null,false);
	assertNotNull(q1);
	
	bs2 := self.addBlockStack(BS2, 10, null);
	assertNotNull(bs2);
	self.opts.purge;
	self.opts.addAssoc("AllowedMachineTypeGrp", MACHINETYPEGRP_LIFTER);
	q2 := self.addQueue(Q4BS2, BS2,null,false);
	assertNotNull(q2);

	//Fork L -&gt; IMV -&gt; Fork L
	self.addMachineRule(bs1,bs2,RTMoveMethod_4);
	
	
	self.opts.purge;
	self.opts.addAssoc("AllowedMachineTypeGrp", MACHINETYPEGRP_IMV);
	q3:=self.addQueue(QIMV, BS1,BS2,false);
	
	
	container:= self.addContainer(TheContainer, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	
	assertNotNull(container);
	
	self.move(container, bs1.myLocationsController);
	self.assertEqual(container.myPrimaryActualLocation, bs1.myLocationsController);
	
	// queue TI to other straddle stack
	self.moveQueued(container, bs2.myLocationsController);
	
	// entry in q1 should be from BS1 to IMV
	
	self.assertEqual(q1.allEntries.size, 1);
	entry:=q1.allEntries.first;
	self.assertNotNull(entry);
	self.assertEqual(entry.machineTypeGroup, MACHINETYPEGRP_LIFTER);
	task:=entry.allTasks.first;
	self.assertNotNull(task);
	self.assertEqual(task.machineTypeGroup, MACHINETYPEGRP_LIFTER);
	self.assertEqual(task.sourceLocationId.trimWhiteSpace, BS1);
	self.assertEqual(task.targetLocationId, "IMV");
	//entry in q2 should be from IMV to BS2
	
	self.assertEqual(q2.allEntries.size, 1);
	entry:=q2.allEntries.first;
	self.assertNotNull(entry);
	self.assertEqual(entry.machineTypeGroup, MACHINETYPEGRP_LIFTER);
	task:=entry.allTasks.first;
	self.assertNotNull(task);
	self.assertEqual(task.machineTypeGroup, MACHINETYPEGRP_IMV);
	self.assertEqual(task.sourceLocationId,"IMV");
	self.assertEqual(task.targetLocationId.trimWhiteSpace,  BS2);
	
	//entry in IMV q should be from BS1 to BS2
	
	self.assertEqual(q3.allEntries.size, 1);
	entry:=q3.allEntries.first;
	self.assertNotNull(entry);
	self.assertEqual(entry.machineTypeGroup, MACHINETYPEGRP_IMV);
	task:=entry.allTasks.first;
	self.assertNotNull(task);
	self.assertEqual(task.machineTypeGroup, MACHINETYPEGRP_IMV);
	self.assertEqual(task.sourceLocationId.trimWhiteSpace,BS1);
	self.assertEqual(task.targetLocationId.trimWhiteSpace,  BS2);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tMoveRTQHeldManuallyHeld" id="1f47cbed-25ac-4d8e-8065-9f1057a18f57">
        <source>tMoveRTQHeldManuallyHeld();

/*

Purpose:		

Date			Who		Reason
20 January 2016	cnwmh5	Initial creation

*/

vars

	bs						: CM_BlockStack;
	bs2						: CM_BlockStack;
	queue					: CM_SubQueue;
	internalJob				: CM_YardInternalJob;
	rtqEntry				: CM_RTQueueEntry;

begin

	bs := self.addBlockStack("UTMHJI1", 999, null);
	self.assertNotNull(bs);
	
	bs2 := self.addBlockStack("UTMHJI2", 999, null);
	self.assertNotNull(bs2);

	queue := self.addQueueFromTA("UTMHJ12", bs);
	self.assertNotNull(queue);
	
	self.opts.purge();
	self.opts.addAssoc("HoldMove", true);
	internalJob := self.createInternalMove(5, bs, bs2, queue);
	self.assertNotNull(internalJob);
	
	foreach rtqEntry in internalJob.allEntries discreteLock do
		self.assertEqual(rtqEntry.status, ENTRY_USER_HELD);
	endforeach;
	
epilog

	self.deleteJob(internalJob);

end;</source>
    </JadeMethod>
    <JadeMethod name="tMultiQueueMoveWith2Machines" id="cb0f052f-907d-496a-b5b3-3453fa010d1f">
        <source>tMultiQueueMoveWith2Machines();
// cnwer1
//07 January 2009	cnwdw1	
// Par 18638
constants
	Container = "UT100";
	StraddleStack = "UT_ST";
	StraddleStack1 = "UT_ST1";
	QueueForStraddleStack1 = "UT_ST1_Q";
	StraddleStack2 = "UT_ST2";
	QueueForStraddleStack2 = "UT_ST2_Q";
	Straddle1 = "UTS1";
	Straddle2 = "UTS2";
vars
	ti: CM_TrackedItem;
	st, st1, st2: CM_GridArea;
	q1, q2: CM_RadioTelemetryQueue;
	tas: StringArray;
	straddle1, straddle2: CM_Machine;
	task: CM_RTQueueTask;
begin
	self.deleteContainer(Container);
	self.deleteTerminalArea(StraddleStack);
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteMachine(Straddle1);
	self.deleteMachine(Straddle2);
	self.deleteRTDevice("91");
	self.deleteRTDevice("92");
	
	st := self.addStraddleStack(StraddleStack, 2, 2, 2);
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	q1 := self.addQueueToTA(QueueForStraddleStack1, StraddleStack1);
	assertNotNull(q1);
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	q2 := self.addQueueToTA(QueueForStraddleStack2, StraddleStack2);
	assertNotNull(q2);
	
	ti := self.addContainer(Container, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, st.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti.myPrimaryActualLocation, st.allGridControllersByRowColumn[1, 1]);
	
	self.moveQueued(ti, st1.allGridControllersByRowColumn[1, 1]);
	self.moveQueued(ti, st2.allGridControllersByRowColumn[1, 1]);
	
	create tas transient;
	tas.add(StraddleStack); tas.add(StraddleStack1);
	straddle1 := self.addStraddle(Straddle1, 91, tas, QueueForStraddleStack1);
	tas.clear; tas.add(StraddleStack1); tas.add(StraddleStack2);
	straddle2 := self.addStraddle(Straddle2, 92, tas, QueueForStraddleStack2);

	// Assign straddles to theer queues
	self.machineAssignToQueue(straddle1, q1);
	assertEqual(straddle1.myPrimaryQueue, q1);
	self.machineAssignToQueue(straddle2, q2);
	assertEqual(straddle2.myPrimaryQueue, q2);

	// No tasks for straddle2 - need to wait until the first queue move is completed
	self.machineLogon(straddle2);
	assertTrue(straddle2.loggedOn);
	self.expectTrxError(No_Tasks);
	task := self.machineTaskRequest(straddle2);
	assertNull(task);
	
	// Work first straddle task - move to Area 1
	self.machineLogon(straddle1);
	task := self.machineTaskRequest(straddle1);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(straddle1, task);
	self.machinePickup(straddle1);
	self.machineSetdown(straddle1, ti, "UT_ST1 010001");
	
	assertEqual(ti.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);

	// No more tasks for straddle1
	self.expectTrxError(No_Tasks);
	task := self.machineTaskRequest(straddle1);
	assertNull(task);
	
	// Work second straddle task - move back to area 2
	task := self.machineTaskRequest(straddle2);
	assertNotNull(task);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(straddle2, task);
	self.machinePickup(straddle2);
	self.machineSetdown(straddle2, ti, "UT_ST2 010001");
	assertEqual(ti.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);

	self.machineLogOff(straddle1);
	self.machineLogOff(straddle2);
	

epilog
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMultiQueuedMoveWith1Machine" id="fd030333-0441-4594-89f5-d32cc071b28b">
        <source>tMultiQueuedMoveWith1Machine();
// cnwer1
//07 January 2009	cnwdw1	
// Par 18638
constants
	Container = "UT100";
	StraddleStack1 = "UT_ST1";
	QueueForStraddleStack1 = "UT_ST1_Q";
	StraddleStack2 = "UT_ST2";
	QueueForStraddleStack2 = "UT_ST2_Q";
	Straddle1 = "UTS1";
vars
	ti: CM_TrackedItem;
	st1, st2: CM_GridArea;
	q1, q2: CM_RadioTelemetryQueue;
	tas: StringArray;
	straddle: CM_Machine;
	task: CM_RTQueueTask;
begin
	self.deleteContainer(Container);
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteMachine(Straddle1);
	self.deleteRTDevice("91");
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	q1 := self.addQueueToTA(QueueForStraddleStack1, StraddleStack1);
	assertNotNull(q1);
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	q2 := self.addQueueToTA(QueueForStraddleStack2, StraddleStack2);
	assertNotNull(q2);
	
	ti := self.addContainer(Container, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	
	self.moveQueued(ti, st2.allGridControllersByRowColumn[1, 1]);
	self.moveQueued(ti, st1.allGridControllersByRowColumn[2, 2]);
	
	create tas transient;
	tas.add(StraddleStack1); tas.add(StraddleStack2);
	self.addStraddle(Straddle1, 91, tas, QueueForStraddleStack2);
	
	
	// Work first straddle task - move to Area 2
	straddle := self.getMachine(Straddle1);
	assertNotNull(straddle);
	self.machineLogon(straddle);
	task := self.machineTaskRequest(straddle);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(straddle, task);
	self.machinePickup(straddle);
	self.machineSetdown(straddle, ti, "UT_ST2 010001");
	
	// Work second straddle task - move back to area 1
	task := self.machineTaskRequest(straddle);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(straddle, task);
	self.machinePickup(straddle);
	self.machineSetdown(straddle, ti, "UT_ST1 020002");
	self.machineLogOff(straddle);

epilog
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tQueueCriteria" id="7e80152c-b3b6-44e9-828c-5d3371cca8fd">
        <source>tQueueCriteria();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 October 2025		jlizm1	Initial creation MTN 35861 RTQueue configuration - cargo attribute criteria

*/

constants
	CONT_ID1		: String = "ZJMU2509291";
	CONT_ID2		: String = "ZJMU2509292";
	CONT_ID3		: String = "ZJMU2509293";

	BlockStackName1	: String = "ZBS1";
	BlockStackName2	: String = "ZBS2";

	QueueName1		: String = "UT_ZQ1";
	QueueName2		: String = "UT_ZQ2";
	QueueName3		: String = "UT_ZQ3";
	QueueName4		: String = "UT_ZQ4";
	
vars
	originalConfig 	: Boolean;
	ti1, ti2, ti3	: CM_Container;
	bs1, bs2		: CM_BlockStack;
	q1, q2, q3, q4		: CM_RadioTelemetryQueue;
	allTransientCriteriaObj	: CMIF_Array;
	cargoType : CM_CargoType;
	masterQueue: CM_MasterQueue;
	wle : CM_WorkListEntry;

begin
	originalConfig := self.getTerminalConfig(RtQPrioritiseCriteria).Boolean;
	
	self.deleteContainer(CONT_ID1);
	self.deleteContainer(CONT_ID2);
	self.deleteContainer(CONT_ID3);
	self.deleteQueue(QueueName1);
	self.deleteQueue(QueueName2);
	self.deleteQueue(QueueName3);
	self.deleteQueue(QueueName4);
	self.deleteTerminalArea(BlockStackName1);
	self.deleteTerminalArea(BlockStackName2);
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	
	// create block stack
	bs1 := self.addBlockStack(BlockStackName1, 0, null);
	self.assertNotNullMsg(bs1, BlockStackName1);
	bs2 := self.addBlockStack(BlockStackName2, 0, null);
	self.assertNotNullMsg(bs2, BlockStackName2);
	
	masterQueue := self.getTerminal.radioTelemetry.masterQueue;
	self.assertTrueMsg(masterQueue &lt;&gt; null, "Failed to find master queue");
	
	create allTransientCriteriaObj transient;
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], "CONT" );
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity], "AIRC" );
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISO], "2200" );
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsHazardous], CM_YADataBoolean.VALUE_FALSE );
	self.opts.purge();
	self.opts.addAssoc("Criteria", allTransientCriteriaObj);
	q1 := self.addQueue(QueueName1, bs1, bs2, false);
	allTransientCriteriaObj.purge();
	
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], "CONT" );
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity], "MT" );
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISO], "2200" );
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsHazardous], CM_YADataBoolean.VALUE_FALSE );
	self.opts.purge();
	self.opts.addAssoc("Criteria", allTransientCriteriaObj);
	q2 := self.addQueue(QueueName2, bs1, bs2, false);
	allTransientCriteriaObj.purge();
	
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], "CONT" );
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity], "ALUM" );
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISO], "2200" );
	self.getQueueCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsHazardous], CM_YADataBoolean.VALUE_FALSE );
	self.opts.purge();
	self.opts.addAssoc("Criteria", allTransientCriteriaObj);
	q3 := self.addQueue(QueueName3, bs1, bs2, false);
	allTransientCriteriaObj.purge();
	
	self.opts.purge();
	q4 :=  self.addQueue(QueueName4, bs1, bs2, false);
	
	beginTransaction;
	masterQueue.moveSubQueue(q1, 1);
	masterQueue.moveSubQueue(q2, 2);
	masterQueue.moveSubQueue(q3, 3);
	masterQueue.moveSubQueue(q4, 1);	// queue with no criteria will have highest normal queue priority
	commitTransaction;
	
	// Create Containers
	ti1 := self.addContainerAtLocation(CONT_ID1, self.getOperator("APL"),"2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
	self.assertNotNullMsg(ti1, "ti1");
	ti2 := self.addContainerAtLocation(CONT_ID2, self.getOperator("APL"),"2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
	self.assertNotNullMsg(ti2, "ti2");
	ti3 := self.addContainerAtLocation(CONT_ID3, self.getOperator("APL"),"2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
	self.assertNotNullMsg(ti3, "ti3");
	
	self.setTerminalConfig(RtQPrioritiseCriteria, true);
	
	self.moveQueued(ti1, bs2);

	
	self.assertNotNullMsg(ti1.getPrimaryLocation(QUEUE_MODE), "ti1 queue location");
	self.assertEqualMsg(ti1.getPrimaryLocation(QUEUE_MODE).myTerminalArea, bs2, "t1 not queued to bs2");
	wle := ti1.allWorklistEntries.last;
	self.assertNotNullMsg(wle, "wle for ti1");
	self.assertTrueMsg(wle.allRTQueueEntries.size &gt; 0, "Ti1 doesn't have a queue entry");
	self.assertEqualMsg(wle.allRTQueueEntries.first.myQueue, q2, "Not queued to correct queue");
	
	
	self.setTerminalConfig(RtQPrioritiseCriteria, false);
	
	self.moveQueued(ti2, bs2);
	
	// check entry is queued and in the correct queue
	self.assertNotNullMsg(ti2.getPrimaryLocation(QUEUE_MODE), "ti2 queue location");
	self.assertEqualMsg(ti2.getPrimaryLocation(QUEUE_MODE).myTerminalArea, bs2, "ti2 not queue to bs2");
	wle := ti2.allWorklistEntries.last;
	self.assertNotNullMsg(wle, "wle for ti2");
	self.assertTrueMsg(wle.allRTQueueEntries.size &gt; 0, "Ti2 doesn't have a queue entry");
	self.assertEqualMsg(wle.allRTQueueEntries.first.myQueue, q4, "Not queued to correct queue");
	
	
	self.deleteQueue(QueueName1);
	self.deleteQueue(QueueName2);
	self.deleteQueue(QueueName3);
	self.deleteQueue(QueueName4);
	self.deleteContainer(CONT_ID1);
	self.deleteContainer(CONT_ID2);
	self.deleteContainer(CONT_ID3);
	self.deleteTerminalArea(BlockStackName1);
	self.deleteTerminalArea(BlockStackName2);
	
epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;

	self.setTerminalConfig(RtQPrioritiseCriteria, originalConfig);
	
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge();
		delete allTransientCriteriaObj;
	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="tQueueOverStowToICArea" id="6f2aa2a8-a00e-416f-9c89-d7649cf0211c">
        <source>tQueueOverStowToICArea();
/*

Purpose:	Queue OverStow cargo to IC Area

Date		Who		Reason
09/05/2014  cnwma1	Initial creation
16/05/2014  cnwma1	Update Terminal area IC 

*/
constants
	
	 STAREA ="ST_OVS";
	 CONT1   = "CNTR1";
	 CONT2   = "CNTR2";
	 CONT3   = "CNTR3";
	 ICArea  = "ICA555";
	 ICArea1  = "ICA666";
	 FRK ="FK999";
vars

	straddleArea		: CM_StraddleStack;
	ti1,ti2,ti3 		: CM_TrackedItem;
	overStowTis  		: CM_TIArray;
	locations 			: CM_LCArray;
	sideAccessDirection : Integer;
	icArea,icArea1      : CM_InterchangeArea;
	iCA    				: CM_InterchangeAreaArray;
	forkLift			: CM_Machine;
begin

     //Delete RTG Area
	 self.deleteTerminalArea(STAREA);
	 self.deleteTerminalArea(ICArea);
	 
	 // Create Interchange Area
	 icArea := self.addInterchangeArea(ICArea, null);
	 self.assertNotNull(icArea);
	 
	 icArea1 := self.addInterchangeArea(ICArea1, null);
	 self.assertNotNull(icArea1);
	 
	 //Create Straddle Stack
	 self.opts.addAssoc("DefaultYIC", icArea);
	 straddleArea := self.addStraddleStack(STAREA,5,20,6);
	 self.assertNotNull(straddleArea);
	  
	 create iCA transient;
	 iCA.add(icArea);
	 beginTransaction;
	 straddleArea.setICAreas(iCA);
	 commitTransaction;
	 // Delete Containers
	 self.deleteContainer(CONT1);
	 self.deleteContainer(CONT2);
	 self.deleteContainer(CONT3);


	 // Create Containers
	ti1 := self.addContainer(CONT1, self.getOperator("APL"),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti1);
	ti2 := self.addContainer(CONT2, self.getOperator("APL"),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti2);
	ti3 := self.addContainer(CONT3, self.getOperator("APL"),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti3);
	
	// Move Containers
	self.move(ti1, straddleArea.allGridControllersByRowColumn[1, 1]);  // this is overstowed
	self.move(ti2, straddleArea.allGridControllersByRowColumn[1, 1]);	 // Over It
	self.move(ti3, straddleArea.allGridControllersByRowColumn[1, 1]);	 // Over It

	self.moveQueued(ti1,straddleArea.allGridControllersByRowColumn[3, 1]); 

	create overStowTis transient;
	ti1.getAllOverstowedTIs(overStowTis,true,sideAccessDirection,null);
	
	
	 //Queue OverStow to IC Area
	app.myTrxUA.trxQueueOverstowCargoToICArea(ti1,overStowTis,straddleArea.myDefaultInterchangeArea,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Update Terminal Area IC areas
	 iCA.add(icArea1);
	app.myTrxUA.trxUpdateTerminalAreaICAreas(straddleArea,iCA,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete overStowTis;
	delete iCA;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRTGReAutoPlanOnTargetLocFull" id="98b43a65-9819-4e1e-8844-67036bfdd4cb">
        <updating/>
        <source>tRTGReAutoPlanOnTargetLocFull() updating;
// jlgmd1
// cnwkpd1
/*

Purpose:		Test that for a RMG Area that validates over height correctly	

Parameters:			

Return Value:		


Date			Who		Reason
04 August 2011	cnwdz2	Initial creation par27008

*/
constants
	RMGAreaId			: String  = "UTDZRMGA1";
	RTQueueId           : String  = "UTDZRMGA1Q";
	ContainerId1		: String  = "UTDZQR00001";
	ContainerId2		: String  = "UTDZQR00002";
	ContainerId3		: String  = "UTDZQR00003";
	ContainerId4		: String  = "UTDZQR00004";
	ContainerId5		: String  = "UTDZQR00005";
	ISOType				: String  = "2200";
	ContainerCommodity  : String  = "GENL";
	ImexStatus		    : Integer = 3;
vars
	rmgArea				: CM_RTGArea;
	rmgAreaQueue		: CM_RadioTelemetryQueue;
	container1			: CM_Container;
	container2			: CM_Container;
	container3			: CM_Container;
	container4			: CM_Container;
	operator			: CM_Operator;
	lc					: CM_LocationsController;
	tas					: StringArray;
begin
	self.disableAllYA(true);
	
	// setup any default values
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNull(operator);
	
	rmgArea := self.addRMGArea(RMGAreaId, 4, 3, 2);
	rmgAreaQueue := self.addQueueToTA(RTQueueId, rmgArea);
	
	// ok lets create some containers
	lc := rmgArea.getLC("010001");
	container1 := self.addContainerAtLocation(ContainerId1, operator, ISOType, ContainerCommodity, ImexStatus, lc);
	
	//create a container that will be queued to the full location
	lc := rmgArea.getLC("020001");
	container3 := self.addContainerAtLocation(ContainerId3, operator, ISOType, ContainerCommodity, ImexStatus, lc);
	
	//queue a container to the full location will result in an error if there is no yard allocation created to cover the area matching the container
	self.opts.purge;
	self.opts.addAssoc("IsForcedMove", false);
	self.opts.addAssoc("AutoResequenceJobs", true);
	
	//queue the container to the max height of the location
	lc := rmgArea.getLC("010001");
	self.moveQueued(container3, lc);
	
	//create the container and move it to the max height lcoation that the container3 just queued to 
	container2 := self.addContainerAtLocation(ContainerId2, operator, ISOType, ContainerCommodity, ImexStatus, lc);
	
	//try to move a container whose queued target location is full and there is no yard allocation setup for the area that matching the cotainer
	//will result in an error
//	self.testMoveContainerToLocWithErr(container3, lc, Move_FullReplacementText);
	self.testMoveContainerToLocWithErr(container3, lc, Move_WillBeOverCap);	//12 Sep 2012	NDL	Par 30346
	
	//create a RMG machine
	create tas transient;
	tas.add(RMGAreaId);
	
	self.testRTGReAutoPlanOnRTMachines(container3,ISOType,rmgArea,tas, rmgAreaQueue);
	
epilog
	self.disableAllYA(false);
	
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRTMoveMixedDirectorStraddle" id="bda4d7cd-f1d0-4599-937b-00d2085ecba4">
        <source>tRTMoveMixedDirectorStraddle();
// cnwer1
// 12.7.2011 cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2011	cnwrd1	Initial creation

*/

constants
	ContainerName1	= 'RJD0101011';
	ContainerName2	= 'RJD0101012';
	ContainerName3	= 'RJD0101013';
	ContainerName4	= 'RJD0101014';

	TestOperator	= 'RAJD';
	BlockStackName	= 'BLOCKSTACK';
	StraddleAreaName = 'UTSTRD';
	QueueName		= "UT_QUEUE";
	MachineName		= "FKP";
vars
	tempStr	: String;
	container1,
	container2,
	container3,
	container4 : CM_Container;
	operator : CM_Operator;
	passport : CM_Passport;
	bs : CM_BlockStack;
	ss : CM_GridArea;
	operatorDict : CM_OperatorByCodeDict;
	machine :CM_Machine;
	queue :CM_SubQueue;
	tas :StringArray;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	rtqt1,
	rtqt2 : CM_RTQueueTask;
	location: CM_LocationsController;
	job1 : CM_YardInternalJob;
	job2 : CM_YardInternalJob;
begin
//	=========== stuff we need to get started =============================================================================	
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	self.setTerminalConfig(UseBestPickDirector, false);

//	=========== DELETES =============================================================================	

	// delete the cargo
	self.deleteContainer(ContainerName1);
	self.deleteContainer(ContainerName2);
	self.deleteContainer(ContainerName3);
	self.deleteContainer(ContainerName4);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);	
	// delete machine
	self.deleteMachine (MachineName);
	machine := self.getMachine (MachineName);
	self.assertIsDeleted(machine);
	// delete queue
	self.deleteQueue (QueueName);
	queue := self.getQueue (QueueName).CM_SubQueue;
	self.assertIsDeleted(queue);
	// delete block stack
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	
	self.deleteYA("UT");

	deleteTerminalArea("UTSTRD");
	ss := self.getTerminalArea(StraddleAreaName).CM_GridArea;
	self.assertIsDeleted(bs);

	
	
//	=========== CREATES =============================================================================	
	create locations transient;
	
	// create block stack
	bs := self.addBlockStack(BlockStackName, 0, null);
	self.assertNotNull (bs);
	
	//create straddle area	
	ss:= addStraddleStack(StraddleAreaName, 4, 4, 2);
	assertNotNullMsg(ss, "straddleStack");
	

	// add machine rule between 2 areas - will get deleted if one area deleted
	self.addMachineRule (ss, bs, RTMoveMethod_23);
	// create queue
	queue := self.addQueueToTA(QueueName, bs);
	assertNotNull (queue);
	// create machine
	create tas transient;
	tas.add(bs.id); tas.add(ss.id);
	
	
	//TWIN_LIFT
	//TANDEM_LIFT
	//NORMAL_LIFT
	
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	
	machine := self.addStraddle(MachineName,91,tas,queue.id);
	assertNotNull(machine);
	
	// Add the container and move to block stack
	container1 	:= self.createContainer(ContainerName1, "2200", "MT", operator,false).CM_Container;
	tempStr		:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	self.move(container1, bs);
	
	
	container2 	:= self.createContainer(ContainerName2, "2200", "MT", operator,false).CM_Container;
	tempStr		:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	self.move(container2, bs);
	
		
	container3 	:= self.createContainer(ContainerName3, "2200", "MT", operator,false).CM_Container;
	tempStr		:= 'Adding Container ' &amp; ContainerName3.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container3, tempStr);
	self.move(container3, bs);
	
	
		
	container4 	:= self.createContainer(ContainerName4, "2200", "MT", operator,false).CM_Container;
	tempStr		:= 'Adding Container ' &amp; ContainerName4.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container4, tempStr);
	self.move(container4, bs);


	locations.add(ss.allGridControllersByRowColumn[1, 1]);
	locations.add(ss.allGridControllersByRowColumn[1, 2]);	
	locations.add(ss.allGridControllersByRowColumn[1, 3]);
	locations.add(ss.allGridControllersByRowColumn[1, 4]);
	
	locations.add(ss.allGridControllersByRowColumn[2, 1]);
	locations.add(ss.allGridControllersByRowColumn[2, 2]);
	locations.add(ss.allGridControllersByRowColumn[2, 3]);
	locations.add(ss.allGridControllersByRowColumn[2, 4]);
	
	locations.add(ss.allGridControllersByRowColumn[3, 1]);
	locations.add(ss.allGridControllersByRowColumn[3, 2]);
	locations.add(ss.allGridControllersByRowColumn[3, 3]);
	locations.add(ss.allGridControllersByRowColumn[3, 4]);
	
	
	locations.add(ss.allGridControllersByRowColumn[4, 1]);
	locations.add(ss.allGridControllersByRowColumn[4, 2]);
	locations.add(ss.allGridControllersByRowColumn[4, 3]);
	locations.add(ss.allGridControllersByRowColumn[4, 4]);
	
	
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, TestOperator, locations);

	
		
	location := ss.allGridControllersByRowColumn[1, 1];
	self.move(container1, location);
	self.assertEqualMsg(container1.myPrimaryActualLocation, location, "Did not move ti1 to correct location");
	
	
	location := ss.allGridControllersByRowColumn[1, 2];
	self.move(container2, location);
	self.assertEqualMsg(container2.myPrimaryActualLocation, location, "Did not move ti1 to correct location");
	
	location := ss.allGridControllersByRowColumn[1, 3];
	self.move(container3, location);
	self.assertEqualMsg(container3.myPrimaryActualLocation, location, "Did not move ti1 to correct location");
	
	
	location := ss.allGridControllersByRowColumn[1, 4];
	self.move(container4, location);
	self.assertEqualMsg(container4.myPrimaryActualLocation, location, "Did not move ti1 to correct location");
	
	//create queued moves
	self.moveQueued(container1, bs);
	job1 := self.createInternalMove (1, ss, bs, queue); 
	self.moveQueued(container3, bs);
	job2 := self.createInternalMove (1, ss, bs, queue); 
	// complete the job
	self.machineLogon (machine);
	// accept the task
	rtqt1 := queue.allEntries[1].getFirstUncompletedTask;
	rtqt2 := queue.allEntries[2].getFirstUncompletedTask;
	self.machineAcceptSpecifiedTwinTask(machine, 
										queue.allEntries[1],
										queue.allEntries[2]);
	// do the pickp
	self.machineDirectorTwin (machine, container1.id, container2.id);
	// do the setdown
	rtqt1 := queue.allEntries[1].getFirstUncompletedTask;
	rtqt2 := queue.allEntries[2].getFirstUncompletedTask;
	
	self.machineSetdownTwinTask (machine,rtqt1, rtqt2, bs.id);
	
	self.machineLogOff (machine);

	assertEqual(container1.getPrimaryLocation(REAL_MODE), bs.getLocationsController);
	assertEqual(container2.getPrimaryLocation(REAL_MODE), bs.getLocationsController);
	
	
epilog

	self.deleteJob(job1);
	self.deleteJob(job2);
	
	opts.purge();
	delete operatorDict;
	delete tas;
	delete locations;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tRTMoveTwinDirector" id="2a3c745f-6536-4b61-ad85-a44f72ad2ae4">
        <source>tRTMoveTwinDirector();
// cnwer1
// 12.7.2011 cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2011	cnwrd1	Initial creation

*/
constants
	ContainerName1	= 'RJD0109911';
	ContainerName2	= 'RJD0109912';

	TestOperator	= 'RAJD';
	BlockStackName	= 'BLOCKSTACK';
	PackAreaName	= 'PACKAREA';
	PackRequest		= 'UT_PACK001';
	QueueName		= "UT_QUEUE";
	MachineName		= "FKP";
vars
	tempStr	: String;
	container1,
	container2 : CM_Container;
	operator : CM_Operator;
	passport : CM_Passport;
	bs : CM_BlockStack;
	pack :CM_Depot;
	operatorDict : CM_OperatorByCodeDict;
	allPackAreas : CM_TAByIdDict;
	machine :CM_Machine;
	queue :CM_SubQueue;
	tas :StringArray;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	rtqt1,
	rtqt2 : CM_RTQueueTask;
begin
//	=========== stuff we need to get started =============================================================================	
	passport := app.myPassport;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).display);
	

//	=========== DELETES =============================================================================	

	// delete the cargo
	self.deleteContainer(ContainerName1);
	self.deleteContainer(ContainerName2);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	// delete machine
	self.deleteMachine (MachineName);
	machine := self.getMachine (MachineName);
	self.assertIsDeleted(machine);
	// delete queue
	self.deleteQueue (QueueName);
	queue := self.getQueue (QueueName).CM_SubQueue;
	self.assertIsDeleted(queue);
	// delete block stack
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	// delete pack area
	self.deleteTerminalArea(PackAreaName);
	pack := self.getTerminalArea(PackAreaName).CM_Depot;
	self.assertIsDeleted(pack);
	
	self.deleteYA("UT");
	
	
	
//	=========== CREATES =============================================================================	
	create locations transient;
	
	// create block stack
	bs := self.addBlockStack(BlockStackName, 0, null);
	self.assertNotNull (bs);
	// create pack area
	pack := self.addPackArea(PackAreaName, 0, null);
	self.assertNotNull (pack);
	// add machine rule between 2 areas - will get deleted if one area deleted
	self.addMachineRule (bs, pack, RTMoveMethod_24);
	// create queue
	queue := self.addQueueToTA (QueueName, BlockStackName);
	assertNotNull (queue);
	// create machine
	create tas transient;
	tas.add(bs.id); tas.add(pack.id);
	
	
	//TWIN_LIFT
	//TANDEM_LIFT
	//NORMAL_LIFT
	
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	
	machine := self.addForkLift (MachineName, 91, tas, queue.id);
	assertNotNull(machine);
	
	// Add the container and move to block stack
	//container1 	:= self.createContainer(ContainerName1, "2200", "MT", operator,false).CM_Container;
	//addContainerOpts(_id: String; _isoType: String; _commodity: String; _operator: CM_Operator; _opts: CM_AssociationDict) : CM_TrackedItem; 
	self.opts.addAssocIfNotNull( UTTI_IMEX, TI_IMEX_STATUS_STORAGE );
		
	container1 	 := self.addContainerOpts(ContainerName1, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString)).CM_Container;
	tempStr		:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	self.move(container1, bs);
	
	
	//container2 	:= self.createContainer(ContainerName2, "2200", "MT", operator,false).CM_Container;
	
	container2 	 := self.addContainerOpts(ContainerName2, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString)).CM_Container;
	
	tempStr		:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	self.move(container2, bs);


	locations.add(bs.myLocationsController);	
	locations.add(pack.myLocationsController);
	
	ya := self.addYA1("UT", YACriteriaType_IsTwenty,  CM_YADataBoolean.VALUE_TRUE, locations);

	
	// create internal move to pack area
	self.createInternalMove (null, bs, pack, queue); //&lt;-- creates 1 !!
	self.createInternalMove (null, bs, pack, queue);  //&lt;-- creates 1 !!
	// complete the job
	self.machineLogon (machine);
	// accept the task
	rtqt1 := queue.allEntries[1].getFirstUncompletedTask;
	rtqt2 := queue.allEntries[2].getFirstUncompletedTask;
	self.machineAcceptSpecifiedTwinTask(machine, 
										queue.allEntries[1],
										queue.allEntries[2]);
	// do the pickp
	self.machineDirectorTwin (machine, container1.id  , container2.id);
	// do the setdown
	rtqt1 := queue.allEntries[1].getFirstUncompletedTask;
	rtqt2 := queue.allEntries[2].getFirstUncompletedTask;
	self.machineSetdownTwinTask (machine,rtqt1, rtqt2, pack.id);
	
	self.machineLogOff (machine);

	assertEqual(container1.getPrimaryLocation(REAL_MODE), pack.getLocationsController);
	assertEqual(container2.getPrimaryLocation(REAL_MODE), pack.getLocationsController);
	
	
	//ok now do tandem lift
	//********************************
	
	self.deleteMachine (MachineName);
	machine := self.getMachine (MachineName);
	self.assertIsDeleted(machine);	
	self.opts.purge();
	self.opts.addAssoc("MachineLiftType", TANDEM_LIFT);
	
	machine := self.addForkLift (MachineName, 91, tas, queue.id);
	assertNotNull(machine);
	
		// create internal move to pack area
	self.createInternalMove (null, pack, bs, queue); //&lt;-- creates 1 !!
	self.createInternalMove (null, pack, bs, queue);  //&lt;-- creates 1 !!
	// complete the job
	self.machineLogon (machine);
	// accept the task
	rtqt1 := queue.allEntries[1].getFirstUncompletedTask;
	rtqt2 := queue.allEntries[2].getFirstUncompletedTask;
	self.machineAcceptSpecifiedTwinTask(machine, 
										queue.allEntries[1],
										queue.allEntries[2]);
	// do the pickp
	self.machineDirectorTwin (machine, container1.id, container2.id);
	// do the setdown
	rtqt1 := queue.allEntries[1].getFirstUncompletedTask;
	rtqt2 := queue.allEntries[2].getFirstUncompletedTask;
	self.machineSetdownTwinTask (machine,rtqt1, rtqt2, bs.id);
	
	self.machineLogOff (machine);

	assertEqual(container1.getPrimaryLocation(REAL_MODE), bs.getLocationsController);
	assertEqual(container2.getPrimaryLocation(REAL_MODE), bs.getLocationsController);
	
epilog
	opts.purge();
	delete operatorDict;
	delete allPackAreas;
	delete tas;
	delete locations;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tRTMoveTwinDirectorPartID" id="383b2585-0f80-4467-9b20-340fac13098d">
        <source>tRTMoveTwinDirectorPartID();
// cnwer1
// 12.7.2011 cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2011	cnwrd1	Initial creation

*/

constants
	ContainerName1	= 'RJD0109911';
	ContainerName2	= 'RJD0109912';

	TestOperator	= 'RAJD';
	BlockStackName	= 'BLOCKSTACK';
	PackAreaName	= 'PACKAREA';
	PackRequest		= 'UT_PACK001';
	QueueName		= "UT_QUEUE";
	MachineName		= "FKP";
vars
	tempStr	: String;
	container1,
	container2 : CM_Container;
	operator : CM_Operator;
	passport : CM_Passport;
	bs : CM_BlockStack;
	pack :CM_Depot;
	operatorDict : CM_OperatorByCodeDict;
	allPackAreas : CM_TAByIdDict;
	machine :CM_Machine;
	queue :CM_SubQueue;
	tas :StringArray;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	rtqt1,
	rtqt2 : CM_RTQueueTask;
begin
//	=========== stuff we need to get started =============================================================================	
	passport := app.myPassport;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).display);
	

//	=========== DELETES =============================================================================	

	// delete the cargo
	self.deleteContainer(ContainerName1);
	self.deleteContainer(ContainerName2);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	// delete machine
	self.deleteMachine (MachineName);
	machine := self.getMachine (MachineName);
	self.assertIsDeleted(machine);
	// delete queue
	self.deleteQueue (QueueName);
	queue := self.getQueue (QueueName).CM_SubQueue;
	self.assertIsDeleted(queue);
	// delete block stack
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	// delete pack area
	self.deleteTerminalArea(PackAreaName);
	pack := self.getTerminalArea(PackAreaName).CM_Depot;
	self.assertIsDeleted(pack);
	
	self.deleteYA("UT");
	
	
	
//	=========== CREATES =============================================================================	
	create locations transient;
	
	// create block stack
	bs := self.addBlockStack(BlockStackName, 0, null);
	self.assertNotNull (bs);
	// create pack area
	pack := self.addPackArea(PackAreaName, 0, null);
	self.assertNotNull (pack);
	// add machine rule between 2 areas - will get deleted if one area deleted
	self.addMachineRule (bs, pack, RTMoveMethod_24);
	// create queue
	queue := self.addQueueToTA (QueueName, BlockStackName);
	assertNotNull (queue);
	// create machine
	create tas transient;
	tas.add(bs.id); tas.add(pack.id);
	
	
	//TWIN_LIFT
	//TANDEM_LIFT
	//NORMAL_LIFT
	
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	
	machine := self.addForkLift (MachineName, 91, tas, queue.id);
	assertNotNull(machine);
	
	// Add the container and move to block stack
	//container1 	:= self.createContainer(ContainerName1, "2200", "MT", operator,false).CM_Container;
	//addContainerOpts(_id: String; _isoType: String; _commodity: String; _operator: CM_Operator; _opts: CM_AssociationDict) : CM_TrackedItem; 
	self.opts.addAssocIfNotNull( UTTI_IMEX, TI_IMEX_STATUS_STORAGE );
		
	container1 	 := self.addContainerOpts(ContainerName1, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString)).CM_Container;
	
	tempStr		:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	self.move(container1, bs);
	
	
	//container2 	:= self.createContainer(ContainerName2, "2200", "MT", operator,false).CM_Container;
	
	container2 	 := self.addContainerOpts(ContainerName2, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString)).CM_Container;
	
	tempStr		:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	self.move(container2, bs);


	locations.add(bs.myLocationsController);	
	locations.add(pack.myLocationsController);
	
	ya := self.addYA1("UT", YACriteriaType_IsTwenty,  CM_YADataBoolean.VALUE_TRUE, locations);

	
	// create internal move to pack area
	self.createInternalMove (null, bs, pack, queue); //&lt;-- creates 1 !!
	self.createInternalMove (null, bs, pack, queue);  //&lt;-- creates 1 !!
	// complete the job
	self.machineLogon (machine);
	// accept the task
	rtqt1 := queue.allEntries[1].getFirstUncompletedTask;
	rtqt2 := queue.allEntries[2].getFirstUncompletedTask;
	self.machineAcceptSpecifiedTwinTask(machine, 
										queue.allEntries[1],
										queue.allEntries[2]);
	// do the pickp
	self.machineDirectorTwin (machine, container1.id[container1.id.length-3:4]  , container2.id[container2.id.length-3:4]);
	// do the setdown
	rtqt1 := queue.allEntries[1].getFirstUncompletedTask;
	rtqt2 := queue.allEntries[2].getFirstUncompletedTask;
	self.machineSetdownTwinTask (machine,rtqt1, rtqt2, pack.id);
	
	self.machineLogOff (machine);

	assertEqual(container1.getPrimaryLocation(REAL_MODE), pack.getLocationsController);
	assertEqual(container2.getPrimaryLocation(REAL_MODE), pack.getLocationsController);
	
	
	//ok now do tandem lift
	//********************************
	
	self.deleteMachine (MachineName);
	machine := self.getMachine (MachineName);
	self.assertIsDeleted(machine);	
	self.opts.purge();
	self.opts.addAssoc("MachineLiftType", TANDEM_LIFT);
	
	machine := self.addForkLift (MachineName, 91, tas, queue.id);
	assertNotNull(machine);
	
		// create internal move to pack area
	self.createInternalMove (null, pack, bs, queue); //&lt;-- creates 1 !!
	self.createInternalMove (null, pack, bs, queue);  //&lt;-- creates 1 !!
	// complete the job
	self.machineLogon (machine);
	// accept the task
	rtqt1 := queue.allEntries[1].getFirstUncompletedTask;
	rtqt2 := queue.allEntries[2].getFirstUncompletedTask;
	self.machineAcceptSpecifiedTwinTask(machine, 
										queue.allEntries[1],
										queue.allEntries[2]);
	// do the pickp
	self.machineDirectorTwin (machine, container1.id, container2.id);
	// do the setdown
	rtqt1 := queue.allEntries[1].getFirstUncompletedTask;
	rtqt2 := queue.allEntries[2].getFirstUncompletedTask;
	self.machineSetdownTwinTask (machine,rtqt1, rtqt2, bs.id);
	
	self.machineLogOff (machine);

	assertEqual(container1.getPrimaryLocation(REAL_MODE), bs.getLocationsController);
	assertEqual(container2.getPrimaryLocation(REAL_MODE), bs.getLocationsController);
	
epilog
	opts.purge();
	delete operatorDict;
	delete allPackAreas;
	delete tas;
	delete locations;
end;
</source>
