    <JadeMethod name="isEDIType" id="fb0b94a9-e3ab-49d7-9b0b-fa25139caa4c">
        <source>isEDIType() : Boolean;
/*
Purpose:	

Date		Who		Reason
14 March 2025	navab1	JIRA 34233
*/

vars

begin
	if self.myReceivalCutoffTermDef = null then
		return false;
	endif;
	
	return self.myReceivalCutoffTermDef.isEDIType();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="nullPrenoteCutoffs" id="9f18152b-f89a-499a-af98-01f1e3226ce2">
        <updating/>
        <source>nullPrenoteCutoffs() updating;
/*
Purpose:	

Date		Who		Reason
12 August 2025	navab1	JIRA 35634
*/

vars

begin
	self.cutoffDateTimePN := null;
	self.earliestDateTimePN := null;
	self.hoursCutoffPN := null;
	self.hoursEarlyPN := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ae26f795-fc83-46f9-8204-e3f78d82966d">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:	

Date		Who		Reason
11 March 2025	navab1	JIRA 34233
*/

vars
	pxyMe : SelfType;
begin
	pxyMe :=  inheritMethod();

	pxyMe.myOperator := self.myOperator;
	pxyMe.myVoyage := self.myVoyage;
	pxyMe.myReceivalCutoffTermDef := self.myReceivalCutoffTermDef; // ### JIRA 34233 14MAR 2025 NAVAB1
	
	return pxyMe;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreateVoyage" id="90ed049a-fd81-4460-adf9-7ae98382ac14">
        <updating/>
        <source>setForCreateVoyage(_voyage : CM_Voyage; _proxy: CM_ReceivalCutoffVoyage) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2009	cnwar2	Initial creation

*/

vars

begin
	self.setForCreate(_proxy);

	// ### JIRA 34233 11MAR 2025 NAVAB1
	self.hoursCutoff := _proxy.hoursCutoff;
	self.hoursCutoffPN := _proxy.hoursCutoffPN;
	self.hoursEarly := _proxy.hoursEarly;
	self.hoursEarlyPN := _proxy.hoursEarlyPN;
	self.defaultRelativeTo := _proxy.defaultRelativeTo;

	self.myOperator := _proxy.myOperator;
	self.myVoyage 	:= _voyage; //cnwgb1 PAR 23207 29.3.2010 Voyage passed in not got from proxy
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_proxy" type="CM_ReceivalCutoffVoyage"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9af28da6-df52-4fbb-b61e-91a44a4f4d5c">
        <updating/>
        <source>setProxy(_code: String; _cutoffDateTime: TimeStamp; _earliestDateTime: TimeStamp; _voyage : CM_Voyage; _operator : CM_Operator; _cutoffDateTimePN : TimeStamp; _earliestDateTimePN : TimeStamp;
				_hoursCutoff, _hoursCutoffPN, _hoursEarly, _hoursEarlyPN : Decimal; _relativeTo : Integer) updating;

/*
Date		Who		Reason
27 May 2009	cnwar2	Initial creation

*/
vars

begin
	self.code 				:= _code;
	self.cutoffDateTime 	:= _cutoffDateTime;
	self.earliestDateTime 	:= _earliestDateTime;
	self.myOperator			:= _operator;
	self.myVoyage 			:= _voyage;
	self.cutoffDateTimePN 	:= _cutoffDateTimePN; 		//04/03/2025	navkc1 JIRA Story MTN-34227
	self.earliestDateTimePN	:= _earliestDateTimePN;		//04/03/2025	navkc1 JIRA Story MTN-34227
	
	
	// ### JIRA 34233 10MAR 2025 NAVAB1
	self.cutoffDateTime := _cutoffDateTime;
	self.cutoffDateTimePN := _cutoffDateTimePN;
	self.earliestDateTime := _earliestDateTime;
	self.earliestDateTimePN := _earliestDateTimePN;
	self.defaultRelativeTo := _relativeTo;
	self.hoursCutoff := _hoursCutoff ;
	self.hoursCutoffPN := _hoursCutoffPN ;
	self.hoursEarly := _hoursEarly ;
	self.hoursEarlyPN := _hoursEarlyPN ;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_cutoffDateTime" type="TimeStamp"/>
        <Parameter name="_earliestDateTime" type="TimeStamp"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cutoffDateTimePN" type="TimeStamp"/>
        <Parameter name="_earliestDateTimePN" type="TimeStamp"/>
        <Parameter name="_hoursCutoff" type="Decimal"/>
        <Parameter name="_hoursCutoffPN" type="Decimal"/>
        <Parameter name="_hoursEarly" type="Decimal"/>
        <Parameter name="_hoursEarlyPN" type="Decimal"/>
        <Parameter name="_relativeTo" type="Integer"/>
    </JadeMethod>
