    <JadeMethod name="moveFromSelected" id="1f818707-6c71-4f7f-808a-ab4efb4077ab">
        <source>moveFromSelected();

vars
	index		: Integer;
	
begin
	foreach index in 1 to lstSelected.listCount do
		if lstSelected.itemSelected[index] then
			lstAvailable.itemForeColor[index]	:=	Black;
			lstSelected.itemForeColor[index]	:=	Gray;
			lstSelected.itemSelected[index]		:=	false;
		endif;
	endforeach;
	
	self.setButtons();
end;</source>
    </JadeMethod>
    <JadeMethod name="moveToSelected" id="ce88d2d5-c8c3-476e-aee6-795583b4d3d7">
        <source>moveToSelected();

vars
	index		: Integer;
	
begin
	foreach index in 1 to lstAvailable.listCount do
		if lstAvailable.itemSelected[index] then
			lstSelected.itemForeColor[index]	:=	Black;
			lstAvailable.itemForeColor[index]	:=	Gray;
			lstAvailable.itemSelected[index]	:=	false;
		endif;
	endforeach;
	
	self.setButtons();
end;</source>
    </JadeMethod>
    <JadeMethod name="populateDefaults" id="90270e95-20ee-4675-96d1-b2b91f2bebbd">
        <source>populateDefaults();

begin
	cmbParentClass.listCollection(self.aAllPotentialParents, false, 0);
end;</source>
    </JadeMethod>
    <JadeMethod name="populateListBoxes" id="54cbb393-5180-426d-b2bc-dfba2347b71d">
        <source>populateListBoxes();

vars
	classCollObj	: ClassColl;
	classObj		: Class;
	parentPosition	: Integer;
	
begin
	lstAvailable.clear();
	lstSelected.clear();
	
	create classCollObj transient;
	self.aAllAvailableClasses.copy(classCollObj);
	
	while classCollObj.size() &gt; 0 do
		classObj := classCollObj[1];
		
		if self.isClassValid(classObj) = false then
			classCollObj.remove(classObj);
		else
			parentPosition := lstAvailable.findObject(classObj.getSuperclass());
			
			if parentPosition &gt; 0 then
				lstAvailable.itemExpanded[parentPosition]	:=	true;
				lstAvailable.addItemAt(classObj.name, parentPosition + 1);
				lstAvailable.itemObject[parentPosition + 1]	:=	classObj;
				lstAvailable.itemLevel[parentPosition + 1]	:=	lstAvailable.itemLevel[parentPosition] + 1;
				
				lstSelected.itemExpanded[parentPosition]	:=	true;
				lstSelected.addItemAt(classObj.name, parentPosition + 1);
				lstSelected.itemObject[parentPosition + 1]	:=	classObj;
				lstSelected.itemLevel[parentPosition + 1]	:=	lstSelected.itemLevel[parentPosition] + 1;
			else
				lstAvailable.itemObject[lstAvailable.addItem(classObj.name)]	:=	classObj;
				lstSelected.itemObject[lstSelected.addItem(classObj.name)]		:=	classObj;
			endif;
		 	
			classCollObj.remove(classObj);
		endif;
	endwhile;
epilog
	delete classCollObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateModelSchema" id="1a29f9e9-6112-467d-bc16-23262a47325f">
        <source>populateModelSchema();

vars
	allSubschemas	: SchemaColl;
	
begin
	create allSubschemas transient;
	currentSchema.allSubschemas(allSubschemas);
	cmbModelSchema.listCollection(allSubschemas, false, 0);
epilog
	delete allSubschemas;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateMyParentArray" id="5cc843af-3845-4a4e-8b86-76a0bee4ca75">
        <source>populateMyParentArray();

vars
	total		: Integer;
	row			: Integer;
	firstValue	: String;	// Class name
	secondValue	: String;	// Creating Class name i.e. The parent Class
	secondIndex : Integer;
	thirdValue	: String;	// Name of the attribute on the child class that is the Creating class
	
begin
	total := tblParent.rows;
	
	foreach row in 2 to total do
		tblParent.row		:=	row;
		tblParent.column	:=	1;
		firstValue			:=	tblParent.text;
		tblParent.column	:=	2;
		secondIndex			:=	tblParent.text.pos(" (", 1);
		
		if secondIndex &gt; 0 then
			secondValue	:=	tblParent.text[1:secondIndex - 1];
			thirdValue	:=	tblParent.text[secondIndex + 2 : end].trimBlanks();
			thirdValue	:=	thirdValue[1:thirdValue.length - 1]; // drop the last ")"
		else
			secondValue	:=	tblParent.text;
			thirdValue	:=	"";
		endif;
		
		self.aMyParentArray.cnEcAdd(firstValue, secondValue);
		self.aMyParentPropertyArray.add(thirdValue);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateTableParent" id="7d8c621a-f93b-4226-b8f1-113f8a9dffd2">
        <source>populateTableParent(pAllClasses:ClassColl);

vars
	classObj			: Class;
	potentialValues		: String;
	comboValue			: String;
	defaultClassName	: String;
	pos					: Integer;
	total				: Integer;
	isNew				: Boolean;
	allProperties		: PropertyNDict;
	propertyObj			: Property;
	classParentOptions	: String;
	comboListValue		: Integer;
	
begin
	//create parents transient;
	//mySelectForm.allPotentialParents.copy(parents);
	defaultClassName := cmbParentClass.text;
	tblParent.clear();
	tblParent.row := 1;
	
	tblParent.setCellText(1, 1, "Class");
	tblParent.setCellText(1, 2, "Parent Class ( one who performs create )");
	
	if pAllClasses.size() &gt; 0 then
		total := cmbParentClass.listCount;
		potentialValues := cmbParentClass.text &amp; Tab;
		
		foreach pos in 1 to total do
			if pos &lt;&gt; cmbParentClass.listIndex then
				potentialValues :=  potentialValues &amp; cmbParentClass.itemText[pos] &amp; Tab;
			endif;
		endforeach;
		
		tblParent.rows := 2;
		tblParent.row := 2;
		tblParent.accessMode := Table.AccessMode_Cell;

		total := pAllClasses.size();
		
		foreach pos in 1 to total do
			classObj := pAllClasses[pos].Class;
			
			tblParent.inputType := Table.InputType_None;
			tblParent.setCellText(tblParent.row, 1, classObj.name);
			
			tblParent.column := 2;
			tblParent.inputType := Table.InputType_ComboBox;
			
isNew := true;
			
			if not isNew then // i.e original code
				comboValue := self.setComboValue(potentialValues, classObj.name);
				tblParent.comboList := comboValue;
				
				if classObj.name &lt;&gt; defaultClassName then
					tblParent.comboIndex := 1;
				endif;
			else
				classParentOptions	:=	"";
				allProperties		:=	classObj.getProperties();
				
				foreach propertyObj in allProperties do
					if propertyObj.isKindOf(Reference) and not propertyObj.type.isKindOf(CollClass) then
						classParentOptions := classParentOptions &amp; propertyObj.type.name &amp; " (" &amp; propertyObj.name &amp; ")"&amp; Tab;
					endif;
				endforeach;
				
// cnwdad1 28/02/2003.
//				delete allProperties;
				tblParent.comboList := classParentOptions;
				comboListValue := self.setComboValueNew(classParentOptions, defaultClassName);
				
				if comboListValue &gt; 0 then
					tblParent.comboIndex := comboListValue;
				else
					if classParentOptions = null and classObj.name = defaultClassName then
						tblParent.comboList := cmbTrxSchema.text;
						tblParent.comboIndex := 1;
					elseif classParentOptions = null then
						tblParent.comboList := defaultClassName;
						tblParent.comboIndex := 1;
					else
						tblParent.comboIndex := 1;
					endif;
				endif;
			endif;
			
			if pos &lt; total then
				tblParent.rows := tblParent.rows + 1;
				tblParent.row := tblParent.row + 1;
			endif;
		
		endforeach;
		
		tblParent.row := 2;
	endif;
end;</source>
        <Parameter name="pAllClasses" type="ClassColl"/>
    </JadeMethod>
    <JadeMethod name="populateTheClassColl" id="7456891d-0dc9-41c2-a2ed-6e9c6351a02a">
        <source>populateTheClassColl(pClassCollObj:ClassColl io);

vars
	index		: Integer;
	
begin
	foreach index in 1 to lstSelected.listCount do
		if lstSelected.itemForeColor[index] = Black then
			pClassCollObj.add(lstSelected.itemObject[index].Class);
		endif;
	endforeach;
end;</source>
        <Parameter name="pClassCollObj" type="ClassColl" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populateTrxAgent" id="01308f05-6a38-4fb7-9d0a-df2f2b086463">
        <source>populateTrxAgent();

vars
	allClasses	: ClassColl;
	classObj	: Class;
	schemaObj	: Schema;
	
begin
	cmbTrxAgent.clear();
	
	if cmbTrxSchema.text &lt;&gt; null then
		schemaObj	:=	currentSchema.getSchema(cmbTrxSchema.text);
		create allClasses transient;
		CnEcAgent.allSubclassesInSubschemas(allClasses);
		
		foreach classObj in allClasses where schemaObj.getClass(classObj.name) &lt;&gt; null do
			if cmbTrxAgent.findStringExact(1, classObj.name) &lt; 0 then
				cmbTrxAgent.addItem(classObj.name);
			endif;
		endforeach;
		
		if cmbTrxAgent.listCount = 0 then
			cmbTrxAgent.addItem(CnEcAgent.name);
		endif;
		
		if cmbTrxAgent.listCount = 1 then
			cmbTrxAgent.listIndex	:=	1;
		endif;
	endif;
epilog
	delete allClasses;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateTrxAgentSchema" id="af791194-5370-4704-9520-fcf7dae4cede">
        <source>populateTrxAgentSchema();

vars
	schemaObj		: Schema;
	modelSchemaObj	: Schema;
	allSubschemas	: SchemaColl;
	
begin
	// set theModel Schema
	create allSubschemas transient;
	currentSchema.withAllSubschemas(allSubschemas);
	
	foreach schemaObj in allSubschemas do
		if schemaObj.name = cmbModelSchema.text then
			modelSchemaObj	:=	schemaObj;
			break;
		endif;
	endforeach;
	
	//populate the TrxAgentSchema combo
	cmbTrxSchema.clear();
	allSubschemas.clear();
	modelSchemaObj.withAllSubschemas(allSubschemas);
	
	foreach schemaObj in allSubschemas do
		cmbTrxSchema.addItem(schemaObj.name);
	endforeach;

	self.populateTrxAgent();
epilog
	delete allSubschemas;
end;</source>
    </JadeMethod>
    <JadeMethod name="selectDefault" id="211f9dfd-7d7c-497f-b71b-371b280e44f9">
        <source>selectDefault();

vars
	classCollObj	: ClassColl;
	
begin
	create classCollObj transient;
	
	self.populateTheClassColl(classCollObj);
	self.populateTableParent(classCollObj);
epilog
	delete classCollObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="setButtonState" id="aed69bbf-06f0-4d21-8809-330a32b1c52d">
        <source>setButtonState();

begin
	if shtCodeGen.visible then
		btnBack.enabled	:=	false;
		btnNext.enabled	:=	true;
		
	elseif shtMethods.visible then
		btnBack.enabled	:=	true;
		btnNext.enabled	:=	true;
		
	elseif shtTranAgent.visible then
		btnBack.enabled	:=	true;
		btnNext.enabled	:=	true;
		
	elseif shtClassSelect.visible then
		btnBack.enabled	:=	true;
		btnNext.enabled	:=	true;
		
	elseif shtClassParent.visible then
		btnBack.enabled	:=	true;
		btnNext.enabled	:=	true;
		
	elseif shtOutcome.visible then
		//bBack.enabled	:=	true; controlled by generateFile();
		btnNext.enabled	:=	false;
		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setButtons" id="3d0519ab-7552-4432-a03a-9c508066cbe8">
        <source>setButtons();

vars
	classCollObj	: ClassColl;
	
begin
	btnNext.enabled := true;
	
	create classCollObj transient;
	self.populateTheClassColl(classCollObj);
	
	if classCollObj.size() &gt; 0 then
		btnNext.enabled	:=	true;
	endif;
epilog
	delete classCollObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="setComboValue" id="09531791-67ad-4e2a-8f18-6f0e5edc3047">
        <source>setComboValue(pPotentialValue : String; pClassName : String) : String;

vars
	retValue	: String;
	pos			: Integer;
	
begin
	retValue	:=	pPotentialValue;
	pos			:=	retValue.pos(pClassName &amp; Tab, 1);

	if pos = 0 then
		//do nothing
		
	elseif pos = 1 then
		if retValue.length &gt; pClassName.length + 2 then
			retValue	:=	retValue[(pClassName.length + 2):end];
		else
			retValue	:=	"";
		endif;
		
	elseif pos &gt; 1 then
		if (pos + pClassName.length + 2) &gt; retValue.length then
			retValue	:=	retValue[1:(pos - 1)];
		else
			retValue	:=	retValue[1:(pos - 1)] &amp; retValue[(pos + pClassName.length + 1):end];
		endif;
		
	endif;

	// drop last Tab
	if retValue.length &gt; 1 then
		retValue	:=	retValue[1:(retValue.length - 1)];
	endif;
	
	return retValue;
end;</source>
        <Parameter name="pPotentialValue" type="String"/>
        <Parameter name="pClassName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValueNew" id="09f947ca-baec-4f93-a241-f1f389f79750">
        <source>setComboValueNew(pPotentialValue : String; pDefaultClass : String) : Integer;

vars
	retValue	: Integer;
	workString	: String;
	char		: Character;
	pos			: Integer;
	size		: Integer;
	
begin
	pos := pPotentialValue.pos(pDefaultClass, 1);

	if pos = 0 then
		//do nothing
	elseif pos &gt; 0 then
		workString	:=	pPotentialValue[1:pos];
		size		:=	workString.length();
		retValue	:=	1;
		
		foreach pos in 1 to size do
			char	:=	workString[pos:1].Character;
			
			if char = Tab then
				retValue	:=	retValue + 1;
			endif;
		endforeach;
	endif;
	
	return retValue;
end;</source>
        <Parameter name="pPotentialValue" type="String"/>
        <Parameter name="pDefaultClass" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCreateObjectVisibility" id="ef2ce78d-777c-4bc3-ad40-adc3568b82e9">
        <source>setCreateObjectVisibility();

begin
	if chkObjectCreate.value then
		chkCreateTrx.caption	:=	"Generate 'trx&lt;Class.name&gt;Create' methods";
		chkCreateTrx.enabled	:=	true;
	else
		chkCreateTrx.caption	:=	"Generate 'trx&lt;Class.name&gt;Create' methods. ('Generate '&lt;Object&gt;Create' methods' is a prerequisite)";
		chkCreateTrx.enabled	:=	false;
		chkCreateTrx.value		:=	false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultColour" id="d5b6859c-6977-4a04-b365-12998c3e4df8">
        <source>setDefaultColour(pModelSchemaObj:Schema; pTrxSchemaObj:Schema);

vars
	classObj	: Class;
	
begin
	self.aAllPotentialParents.clear();
	
	foreach classObj in self.aAllAvailableClasses where self.isClassValid(classObj) do
		if classObj.transient = true
		or classObj.abstract
		or classObj.inheritsFrom(Window)
		or classObj.inheritsFrom(Application)
		or classObj.inheritsFrom(Collection)
		or classObj.inheritsFrom(Global)
		or classObj.inheritsFrom(Schema)
		or classObj.inheritsFrom(WebSession)
		or classObj.inheritsFrom(CollClass)
		or classObj.name = "JadeScript"
		or classObj.name = "Node"
		or classObj.name = "Process"
		or classObj.name = "Feature"
		or classObj.name = "Class"
		or classObj.name = "ExplicitInverseRef"
		then
			lstAvailable.itemForeColor[lstAvailable.findObject(classObj)]	:=	Black;
			lstSelected.itemForeColor[lstSelected.findObject(classObj)]		:=	Gray;
		else
			lstAvailable.itemForeColor[lstAvailable.findObject(classObj)]	:=	Gray;
			lstSelected.itemForeColor[lstSelected.findObject(classObj)]		:=	Black;
			self.aAllPotentialParents.add(classObj);
		endif;			
	endforeach;
end;</source>
        <Parameter name="pModelSchemaObj" type="Schema"/>
        <Parameter name="pTrxSchemaObj" type="Schema"/>
    </JadeMethod>
    <JadeMethod name="setJadeMethodDefinition" id="b2830534-b7f0-4ba2-84ac-1945090bc5d4">
        <source>setJadeMethodDefinition(pNumber : Integer io;
						pFileObj : File io;
						pClassObj : Class;
						pMethodName : String);

begin
	pNumber	:=	pNumber + 1;
	pFileObj.writeLine(Tab &amp; pClassObj.name &amp; "(");
	pFileObj.writeLine(Tab &amp; Tab &amp; "jadeMethodDefinitions");
	pFileObj.writeLine(Tab &amp; Tab &amp;  pMethodName &amp; "(");
end;</source>
        <Parameter name="pNumber" type="Integer" usage="io"/>
        <Parameter name="pFileObj" type="File" usage="io"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pMethodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setModifiedLine" id="cd3f20b7-b454-48ce-8032-6f07749e8b17">
        <source>setModifiedLine(pFileObj : File io; pTimeStamp : String);

begin
	pFileObj.writeLine('setModifiedTimeStamp "JediMethodGenerator" "' &amp; app.getSystemVersion() &amp; '" ' &amp; pTimeStamp &amp; ';');
	pFileObj.writeLine(")");
end;</source>
        <Parameter name="pFileObj" type="File" usage="io"/>
        <Parameter name="pTimeStamp" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSheetState" id="c2dbf56d-9281-4349-b3b8-1057f7fd02ff">
        <updating/>
        <source>setSheetState(pDisplaySheet : Integer) updating;

vars
	isDoChange		: Boolean;
	modelSchemaObj	: Schema;
	trxSchemaObj	: Schema;
	classObj		: Class;
	allSubclasses	: ClassColl;
	
begin
	app.mousePointer		:=	Busy;
	
	isDoChange				:=	true;
	shtCodeGen.visible		:=	false;
	shtMethods.visible		:=	false;
	shtTranAgent.visible	:=	false;
	shtClassSelect.visible	:=	false;
	shtClassParent.visible	:=	false;
	shtOutcome.visible		:=	false;

	if pDisplaySheet = 1 then
		if isDoChange then
			shtCodeGen.visible	:=	true;
		endif;
		
	elseif pDisplaySheet = 2 then
		shtMethods.visible	:=	true;
		
	elseif pDisplaySheet = 3 then
		self.setCreateObjectVisibility();
		
		if self.aSheetVisible = 2 then
			if self.hasErrorsDB() then
				isDoChange	:=	false;
			endif;
		endif;
		
		if isDoChange then
			shtTranAgent.visible	:=	true;
		endif;
		
	elseif pDisplaySheet = 4 then
		if self.aSheetVisible = 3 then
			if self.hasErrorsTA() then
				isDoChange	:=	false;
			endif;
			
			if isDoChange then
				self.aAllAvailableClasses.clear();
				create allSubclasses transient;
				trxSchemaObj	:=	currentSchema.getSchema(cmbTrxSchema.text);
				modelSchemaObj	:=	currentSchema.getSchema(cmbModelSchema.text);
				
			//	foreach modelSchemaObj in currentSchema.withAllSuperschemas do
			//		if modelSchemaObj.name = cmbModelSchema.text then
			//			break;
			//		endif;
			//	endforeach;
			
				classObj	:=	trxSchemaObj.getClass("Object");
				//classObj.allLocalSubclasses(subs);
				classObj.allSubclassesUpToSchema(modelSchemaObj, allSubclasses);
				allSubclasses.copy(self.aAllAvailableClasses);
				self.populateListBoxes();
				self.setDefaultColour(modelSchemaObj, trxSchemaObj);
				self.setButtons();
			endif;
		endif;
		
		if isDoChange then
			shtClassSelect.visible	:=	true;
		endif;

		btnNext.caption	:=	"Next =&gt;";
		
	elseif pDisplaySheet = 5 then
		if self.aSheetVisible = 4 then
			self.populateDefaults();
		endif;
		
		if isDoChange then
			shtClassParent.visible	:=	true;
		endif;
		
		btnNext.caption	:=	"Finish";
		
	elseif pDisplaySheet = 6 then
		if self.aSheetVisible = 5 then
			if chkObjectCreate.value or chkCreateTrx.value then
				self.populateMyParentArray();
			endif;
		endif;
		
		if isDoChange then
			shtOutcome.visible	:=	true;
			self.generateFile();
		endif;
		
	endif;
	
	if isDoChange then
		self.aSheetVisible	:=	pDisplaySheet;
	else
		self.setSheetState(self.aSheetVisible);
	endif;
	
	self.setButtonState();
epilog
	delete allSubclasses;
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="pDisplaySheet" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblParent_click" id="92136cf9-7122-4d64-b011-5307007bb15b">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblParent_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		20 March 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if table.row &lt;= table.fixedRows then
		table.clearAllSelected();
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateMethod" id="df815a66-6beb-42d4-b1bd-fdabf0934ac6">
        <source>trxCreateMethod(pFileObj : File io;
				pTrxClassObj : Class;
				pClassObj : Class;
				pMethodName : String;
				pModelSchemaObj : Schema;
				pAllClassProperties : PropertyNDict io);

vars
	codeLine			: String;
	propertyObj			: Property;
	timeCreated			: Time;
	dateCreated			: Date;
	parentClassObj		: Class;
	parentPropertyObj	: Property;
	schemaClassName		: String;
	
begin
	parentClassObj		:=	self.getParentClass(pModelSchemaObj, pClassObj);
	parentPropertyObj	:=	self.getMyParentProperty(pModelSchemaObj, pClassObj);
	schemaClassName		:=	cmbTrxSchema.text;

	pFileObj.writeLine(Tab &amp; Tab &amp; pTrxClassObj.name &amp; " (");
	pFileObj.writeLine("__method " &amp; pMethodName &amp; " =");
	
	if parentClassObj.name = schemaClassName then
		codeLine := pMethodName &amp; "(";
	else
		codeLine := pMethodName &amp; "(" &amp; Tab &amp; "p" &amp; parentClassObj.name &amp; "Parent : " &amp; parentClassObj.name &amp; " io";
	endif;
	
	foreach propertyObj in pAllClassProperties where  ( not propertyObj.isKindOf(CollClass) and propertyObj &lt;&gt; parentPropertyObj ) do
		codeLine := codeLine &amp; ";" &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj) &amp; ":" &amp; propertyObj.getType.name;
	endforeach;
	
	if codeLine[codeLine.length:1] = "(" then
		codeLine := codeLine &amp; Tab &amp;  "p" &amp; pClassObj.name &amp; "New : " &amp; pClassObj.name &amp; " output";
	else
		codeLine := codeLine &amp; ";" &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp;  "p" &amp; pClassObj.name &amp; "New : " &amp; pClassObj.name &amp; " output";
	endif;
	
	codeLine := codeLine &amp; ")";
	codeLine := codeLine &amp; ": String updating; ";
	pFileObj.writeLine(codeLine);
	pFileObj.writeLine("");
	pFileObj.writeLine("// This method created by JediMethodGenerator at " &amp; timeCreated.String &amp; " on " &amp; dateCreated.String);
	pFileObj.writeLine("// Please add any validation required then delete this comment.");
	pFileObj.writeLine("");
	pFileObj.writeLine("// --------------------------------------------------------------------------------");
	pFileObj.writeLine("// Purpose:		Transaction method to create a " &amp; pClassObj.name &amp; " object.");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// Parameters:	The object (Parent) that performs the create.");
	pFileObj.writeLine("//              The keys and property values of the entity to be created.");
	pFileObj.writeLine("//				The newly created object is returned in the output parameter.");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// Returns:		Null if the transaction is successful, otherwise an error message");
	pFileObj.writeLine("//				is returned.");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// Changed On	Changed By	Reason");
	pFileObj.writeLine("// ----------	----------	-------------------------------------------------------");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// --------------------------------------------------------------------------------");
	pFileObj.writeLine("vars");
	pFileObj.writeLine("");
//	pFileObj.writeLine(Tab &amp; "errorMessage" &amp; Tab &amp; ": String;");
//	pFileObj.writeLine("");
	pFileObj.writeLine("begin");
	pFileObj.writeLine(Tab &amp; "// Initialize the activity first.");
	pFileObj.writeLine(Tab &amp; "self.agentInitializeActivity;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Arm our base exception handlers (local exception handlers which are");
	pFileObj.writeLine(Tab &amp; "// disarmed when the method returns).");
	pFileObj.writeLine(Tab &amp; "on Exception do self.agentExceptionHandler(exception);");
	pFileObj.writeLine(Tab &amp; "on LockException do self.agentLockExceptionHandler(exception);");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Validate the request.");
	pFileObj.writeLine("");
	
	if parentClassObj.name = schemaClassName then
	else
		pFileObj.writeLine(Tab &amp; "if p" &amp; parentClassObj.name &amp; "Parent = null then");
		pFileObj.writeLine(Tab &amp; "	return self.agentSetError('No " &amp; parentClassObj.name &amp; " selected to create from  ');");
		pFileObj.writeLine(Tab &amp; "endif;");
	endif;
	
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Start the Transaction.");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "beginTransaction;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Perform the operation.");
	pFileObj.writeLine("");
	
	if parentClassObj.name = schemaClassName then
		codeLine := Tab &amp; "app." &amp; pClassObj.name.toLower &amp; "Create(";
		
		foreach propertyObj in pAllClassProperties where  (not propertyObj.isKindOf(CollClass) and propertyObj &lt;&gt; parentPropertyObj) do
			if codeLine = Tab &amp; "app." &amp; pClassObj.name.toLower &amp; "Create(" then
				codeLine := codeLine &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj);
			else
				codeLine := codeLine &amp; "," &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj);
			endif;
		endforeach;
	else
		codeLine := Tab &amp; "p" &amp; parentClassObj.name &amp; "Parent." &amp; pClassObj.name.toLower &amp; "Create(";
		
		foreach propertyObj in pAllClassProperties where  (not propertyObj.isKindOf(CollClass) and propertyObj &lt;&gt; parentPropertyObj) do
			if codeLine = Tab &amp; "p" &amp; parentClassObj.name &amp; "Parent." &amp; pClassObj.name.toLower &amp; "Create(" then
				codeLine := codeLine &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj);
			else
				codeLine := codeLine &amp; "," &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj);
			endif;
		endforeach;
	endif;
	
	if codeLine[codeLine.length:1] = "(" then
		codeLine := codeLine &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "New";
	else
		codeLine := codeLine &amp; "," &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "New";
	endif;
	
	codeLine := codeLine &amp; ");";
	pFileObj.writeLine(codeLine);
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// If the operation raises an exception, our handler will resume to here.");
	pFileObj.writeLine(Tab &amp; "if self.lastError = null then");
	pFileObj.writeLine(Tab &amp; "	// No errors, so commit.");
	pFileObj.writeLine(Tab &amp; "	commitTransaction;");
	pFileObj.writeLine(Tab &amp; "else");
	pFileObj.writeLine(Tab &amp; "	// We got an error so abort the transaction. Although TransactionAgent");
	pFileObj.writeLine(Tab &amp; "	// exception handlers abort the transaction before resuming, we do so");
	pFileObj.writeLine(Tab &amp; "	// here as well for completeness and symmetry with the beginTransaction.");
	pFileObj.writeLine(Tab &amp; "	// An abortTransaction when not in transaction state does nothing.");
	pFileObj.writeLine(Tab &amp; "	abortTransaction;");
	pFileObj.writeLine(Tab &amp; "endif;");
	pFileObj.writeLine("");
	pFileObj.writeLine("epilog");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "return self.lastError;");
	pFileObj.writeLine(Tab &amp; "// Always return the error to the caller (which will be null if no errors).");
	pFileObj.writeLine("end;");
	pFileObj.writeLine("");
	pFileObj.writeLine("__endMethod;");
	pFileObj.writeLine(Tab &amp; Tab &amp; ")");
end;</source>
        <Parameter name="pFileObj" type="File" usage="io"/>
        <Parameter name="pTrxClassObj" type="Class"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pMethodName" type="String"/>
        <Parameter name="pModelSchemaObj" type="Schema"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteMethod" id="7c937abf-f031-44e3-b45a-f326fd4aa0e1">
        <source>trxDeleteMethod(pFileObj : File io; pTrxClassObj : Class; pClassObj : Class; pMethodName : String);

vars
	line		: String;
	time		: Time;
	date		: Date;
	
begin
	pFileObj.writeLine(Tab &amp; Tab &amp; pTrxClassObj.name &amp; " (");
	pFileObj.writeLine("__method " &amp; pMethodName &amp; " =");
	
	line := pMethodName &amp; "(" &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "ToDelete : " &amp; pClassObj.name &amp; " io ): String updating; ";
	pFileObj.writeLine(line);
	pFileObj.writeLine("");
	pFileObj.writeLine("// This method created by JediMethodGenerator at " &amp; time.String &amp; " on " &amp; date.String);
	pFileObj.writeLine("");
	pFileObj.writeLine("// --------------------------------------------------------------------------------");
	pFileObj.writeLine("// Purpose:		Transaction to delete a " &amp; pClassObj.name &amp; ".");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// Parameters:	The object to be deleted. This will be set to null by the delete.");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// Returns:		Null if the transaction is successful, otherwise an error message");
	pFileObj.writeLine("//				is returned.");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// Changed On	Changed By	Reason");
	pFileObj.writeLine("// ----------	----------	-------------------------------------------------------");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// --------------------------------------------------------------------------------");
	pFileObj.writeLine("vars");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "errorMessage" &amp; Tab &amp; ": String;");
	pFileObj.writeLine("");
	pFileObj.writeLine("begin");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Initialize the activity first.");
	pFileObj.writeLine(Tab &amp; "self.agentInitializeActivity;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Arm our base exception handlers");
	pFileObj.writeLine(Tab &amp; "on Exception do self.agentExceptionHandler(exception);");
	pFileObj.writeLine(Tab &amp; "on LockException do self.agentLockExceptionHandler(exception);");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Validate the request.");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "if p" &amp; pClassObj.name &amp; "ToDelete = null then");
	pFileObj.writeLine(Tab &amp; '	return self.agentSetError("No ' &amp; pClassObj.name &amp; ' selected to delete  ");');
	pFileObj.writeLine(Tab &amp; "endif;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Start the transaction");
	pFileObj.writeLine(Tab &amp; "beginTransaction;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// If the owner object is invalid, then we want our exception handlers to");
	pFileObj.writeLine(Tab &amp; "// return a message saying so.  After registering the object and a message");
	pFileObj.writeLine(Tab &amp; "// here, if any subsequent invalid object exceptions occur, the exception");
	pFileObj.writeLine(Tab &amp; '// handler will then find the registered object and set the "errorMsg"');
	pFileObj.writeLine(Tab &amp; "// property on the app class.  Therefore, by checking this errorMsg value");
	pFileObj.writeLine(Tab &amp; "// after performing an operation on the object (app.getLastError), the");
	pFileObj.writeLine(Tab &amp; "// appropriate error message can be returned for the exception.");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// If a validation method is used, then this step shouldn't be necessary");
	pFileObj.writeLine(Tab &amp; "// here, since the object will already have been validated.");
	pFileObj.writeLine(Tab &amp; 'self.agentRegisterObjectAndError(p' &amp; pClassObj.name &amp; 'ToDelete, "Invalid ' &amp; pClassObj.name &amp; ' object.");');
	pFileObj.writeLine(Tab &amp; "	// The delete will do nothing if the reference is already null.");
	pFileObj.writeLine(Tab &amp; "delete p" &amp; pClassObj.name &amp; "ToDelete;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// If the operation raises an exception, our handler will resume to here.");
	pFileObj.writeLine(Tab &amp; "if self.lastError = null then");
	pFileObj.writeLine(Tab &amp; "	// No errors, so commit");
	pFileObj.writeLine(Tab &amp; "	commitTransaction;");
	pFileObj.writeLine(Tab &amp; "else");
	pFileObj.writeLine(Tab &amp; "	// We got an error so abort the transaction. Although TransactionAgent");
	pFileObj.writeLine(Tab &amp; "	// exception handlers abort the transaction before resuming, we do so");
	pFileObj.writeLine(Tab &amp; "	// here as well for completeness and symmetry with the beginTransaction.");
	pFileObj.writeLine(Tab &amp; "	// An abortTransaction when not in transaction state does nothing.");
	pFileObj.writeLine(Tab &amp; "	abortTransaction;");
	pFileObj.writeLine(Tab &amp; "endif;");
	pFileObj.writeLine("");
	pFileObj.writeLine("epilog");
	pFileObj.writeLine(Tab &amp; "	// Always return the error to the caller (which will be null if no errors).");
	pFileObj.writeLine(Tab &amp; "return self.lastError;");
	pFileObj.writeLine("");
	pFileObj.writeLine("end;");
	pFileObj.writeLine("");
	pFileObj.writeLine("__endMethod;");
	pFileObj.writeLine(Tab &amp; Tab &amp; ")");
end;</source>
        <Parameter name="pFileObj" type="File" usage="io"/>
        <Parameter name="pTrxClassObj" type="Class"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pMethodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="trxMethodTypeDefinition" id="0632e4c8-0550-48f0-9890-2b21d3510c9e">
        <source>trxMethodTypeDefinition(	pNumber : Integer io;
							pFileObj : File io;
							pTimeStamp : String;
							pTrxClassObj : Class;
							pClassObj : Class;
							pMethodName : String;
							pMethodType : String;
							pModelSchemaObj : Schema;
							pAllClassProperties : PropertyNDict io);

vars
	line			: String;
	propertyObj		: Property;
	parentClassObj	: Class;
	
begin
	self.setJadeMethodDefinition(pNumber, pFileObj, pTrxClassObj, pMethodName);
	
	if pMethodType = "Create" then
		parentClassObj := self.getParentClass(pModelSchemaObj, pClassObj);
		
		if parentClassObj &lt;&gt; null then
			line := pMethodName &amp; "(" &amp; Tab &amp; "p" &amp; parentClassObj.name &amp; "Parent : " &amp; parentClassObj.name &amp; " io";
			
			foreach propertyObj in pAllClassProperties where  not propertyObj.isKindOf(CollClass) do
				line := line &amp; ";" &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj) &amp; ":" &amp; propertyObj.getType.name;
			endforeach;
			
			line := line &amp; ";" &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp;  "p" &amp; pClassObj.name &amp; "New : " &amp; pClassObj.name &amp; " output )";
		endif;
		
	elseif pMethodType = "Update" then
		line := pMethodName &amp; "(" &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "ToUpdate : " &amp; pClassObj.name &amp; " io";
		line := line &amp; ";" &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; "pRequiredEdition : Integer";
		
		foreach propertyObj in pAllClassProperties where  not propertyObj.isKindOf(CollClass) do
			line := line &amp; ";" &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj) &amp; ":" &amp; propertyObj.getType.name;
		endforeach;
		
		line := line &amp; ")";
		
	elseif pMethodType = "Delete" then
		line := pMethodName &amp; "(" &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "ToDelete : " &amp; pClassObj.name &amp; " io )";
	else
		// unknown method type
	endif;
	
	line := line &amp; ": String updating, number = " &amp; pNumber.String &amp; ";";
	pFileObj.writeLine(line);
	
	self.setModifiedLine(pFileObj, pTimeStamp);
end;</source>
        <Parameter name="pNumber" type="Integer" usage="io"/>
        <Parameter name="pFileObj" type="File" usage="io"/>
        <Parameter name="pTimeStamp" type="String"/>
        <Parameter name="pTrxClassObj" type="Class"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pMethodName" type="String"/>
        <Parameter name="pMethodType" type="String"/>
        <Parameter name="pModelSchemaObj" type="Schema"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trxMethodsCreate" id="94baae61-d9a5-449e-8b15-f91fab7f77d9">
        <source>trxMethodsCreate(	pClassCollObj : ClassColl;
					pFileObj : File io;
					pIsReplaceExisting : Boolean;
					pIsCreate : Boolean;
					pIsDelete : Boolean;
					pIsUpdate : Boolean);

vars
	classObj					: Class;
	classNameInMethodName		: String;
	trxClassObj					: Class;
	methodName					: String;
	methodType					: String;
	date						: Date;
	time						: Time;
	timeStamp					: String;
	number						: Integer;
	parentClassObj				: Class;
	trxSchemaObj				: Schema;
	modelSchemaObj				: Schema;
	allClassProperties			: PropertyNDict;
	
begin
//	foreach theTrxSchema in currentSchema.withAllSuperschemas do
//		if theTrxSchema.name = cmbTrxSchema.text then
//			break;
//		endif;
//	endforeach;

	create allClassProperties transient;
	modelSchemaObj	:=	currentSchema.getSchema(cmbModelSchema.text);
	trxSchemaObj	:=	currentSchema.getSchema(cmbTrxSchema.text);
	trxClassObj		:=	trxSchemaObj.getClass(cmbTrxAgent.text);
// cnwdad1 16/04/2003 - Removed the ".ttt" from the end of the timestamp.
//	timeStamp		:=	date.format("yyy:MM:dd:") &amp; time.format("hh:mm:ss.ttt");
	timeStamp		:=	date.format("yyy:MM:dd:") &amp; time.format("hh:mm:ss");
	number 			:=	1000;

	// create the standard .scm file header stuff....
	
	self.writeScmHeader(pFileObj, trxSchemaObj);

	// create the TypeDefinitions.
	
	foreach classObj in pClassCollObj do
		self.getPropertyList(classObj, allClassProperties);
		
		// Make sure the name isn't going to be too big
		classNameInMethodName := classObj.name;
		
		if classNameInMethodName.length &gt; 21 then
			classNameInMethodName := classNameInMethodName[1:21];
		endif;
		
		// create trx--Create TypeDefinition
		
		methodName := "trx" &amp; classNameInMethodName &amp; "Create";
		methodType := "Create";
		
		if pIsCreate and (trxClassObj.getMethod(methodName) = null or pIsReplaceExisting) then
			parentClassObj := self.getParentClass(modelSchemaObj, classObj);
			
			if parentClassObj &lt;&gt; null then
				self.trxMethodTypeDefinition(number, pFileObj, timeStamp, trxClassObj, classObj, methodName, methodType, modelSchemaObj, allClassProperties);
				
				if trxClassObj.getMethod(methodName) &lt;&gt; null and pIsReplaceExisting then
					txtOutcome.text := txtOutcome.text &amp; methodName &amp; " will be overwritten." &amp; CrLf;
				endif;
			else
				txtOutcome.text := txtOutcome.text &amp; "Parent not selected, trx" &amp; trxClassObj.name &amp; "Create not generated." &amp; CrLf;
			endif;
		endif;
		
		// create trx--Update TypeDefinition
		
		methodName := "trx" &amp; classNameInMethodName &amp; "Update";
		methodType := "Update";
		
		if pIsUpdate and (trxClassObj.getMethod(methodName) = null or pIsReplaceExisting) then
			self.trxMethodTypeDefinition(number, pFileObj, timeStamp, trxClassObj, classObj, methodName, methodType, modelSchemaObj, allClassProperties);
			
			if trxClassObj.getMethod(methodName) &lt;&gt; null and pIsReplaceExisting then
				txtOutcome.text := txtOutcome.text &amp; methodName &amp; " will be overwritten." &amp; CrLf;
			endif;
		endif;
		
		// create trx---Delete TypeDefinition
		
		methodName := "trx" &amp; classNameInMethodName &amp; "Delete";
		methodType := "Delete";
		
		if pIsDelete and (trxClassObj.getMethod(methodName) = null or pIsReplaceExisting) then
			self.trxMethodTypeDefinition(number, pFileObj, timeStamp, trxClassObj, classObj, methodName, methodType, modelSchemaObj, allClassProperties);
			
			if trxClassObj.getMethod(methodName) &lt;&gt; null and pIsReplaceExisting then
				txtOutcome.text := txtOutcome.text &amp; methodName &amp; " will be overwritten." &amp; CrLf;
			endif;
		endif;
		
		//break;	//test
	endforeach;
	
	pFileObj.writeLine("inverseDefinitions");
	pFileObj.writeLine("__methodImplementations");
	
	// create each of the methods.
	
	foreach classObj in pClassCollObj do
		self.getPropertyList(classObj, allClassProperties);
		classNameInMethodName := classObj.name;
		
		if classNameInMethodName.length &gt; 21 then
			classNameInMethodName := classNameInMethodName[1:21];
		endif;
		
		// trx---Create method code
		
		methodName		:=	"trx" &amp; classNameInMethodName &amp; "Create";
		parentClassObj	:=	self.getParentClass(modelSchemaObj, classObj);
		
		if pIsCreate and parentClassObj &lt;&gt; null and (trxClassObj.getMethod(methodName) = null or pIsReplaceExisting) then
			self.trxCreateMethod(pFileObj, trxClassObj, classObj, methodName, modelSchemaObj, allClassProperties);
		endif;
		
		// trx---Update method code
		
		methodName := "trx" &amp; classNameInMethodName &amp; "Update";
		
		if pIsUpdate and (trxClassObj.getMethod(methodName) = null or pIsReplaceExisting) then
			self.trxUpdateMethod(pFileObj, trxClassObj, classObj, methodName, allClassProperties);
		endif;
		
		// trx---Delete method code
		
		methodName := "trx" &amp; classNameInMethodName &amp; "Delete";
		
		if pIsDelete and (trxClassObj.getMethod(methodName) = null or pIsReplaceExisting) then
			self.trxDeleteMethod(pFileObj, trxClassObj, classObj, methodName);
		endif;
		
		//break;	//test
	endforeach;
epilog
	delete allClassProperties;
end;</source>
        <Parameter name="pClassCollObj" type="ClassColl"/>
        <Parameter name="pFileObj" type="File" usage="io"/>
        <Parameter name="pIsReplaceExisting" type="Boolean"/>
        <Parameter name="pIsCreate" type="Boolean"/>
        <Parameter name="pIsDelete" type="Boolean"/>
        <Parameter name="pIsUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateMethod" id="fa2621b1-cf80-4596-b7c0-f63630b5c026">
        <source>trxUpdateMethod(pFileObj : File io;
				pTrxClassObj : Class;
				pClassObj : Class;
				pMethodName : String;
				pAllClassProperties : PropertyNDict io);

vars
	line		: String;
	propertyObj	: Property;
	time		: Time;
	date		: Date;
	
begin
	pFileObj.writeLine(Tab &amp; Tab &amp; pTrxClassObj.name &amp; " (");
	pFileObj.writeLine("__method " &amp; pMethodName &amp; " =");
	
	line := pMethodName &amp; "(" &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "ToUpdate : " &amp; pClassObj.name &amp; " input";
	line := line &amp; ";" &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; "pRequiredEdition : Integer";
	
	foreach propertyObj in pAllClassProperties where  not propertyObj.isKindOf(CollClass) do
		line := line &amp; ";" &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj) &amp; ":" &amp; propertyObj.getType.name;
	endforeach;
	
	line := line &amp; ")";
	line := line &amp; ": String updating; ";
	pFileObj.writeLine(line);
	pFileObj.writeLine("");	
	pFileObj.writeLine("// This method created by JediMethodGenerator at " &amp; time.String &amp; " on " &amp; date.String);
	pFileObj.writeLine("// Please add any validation required then delete this comment.");
	pFileObj.writeLine("");
	pFileObj.writeLine("// --------------------------------------------------------------------------------");
	pFileObj.writeLine("// Purpose:		Transaction method to update a " &amp; pClassObj.name &amp; " object.");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// Parameters:	The object being updated, and its key and property values.");
	pFileObj.writeLine("//              If pRequiredEdition is greater than zero, the transaction will");
	pFileObj.writeLine("//				check that the latest edition of the object is equal to");
	pFileObj.writeLine("//				pRequiredEdition. If not, then an 'Object out-of-date' message");
	pFileObj.writeLine("//				will be returned.");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// Returns:		Null if the transaction is successful, otherwise an error message");
	pFileObj.writeLine("//				is returned.");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// Changed On	Changed By	Reason");
	pFileObj.writeLine("// ----------	----------	-------------------------------------------------------");
	pFileObj.writeLine("//");
	pFileObj.writeLine("// --------------------------------------------------------------------------------");
	pFileObj.writeLine("vars");
	pFileObj.writeLine("");
//	pFileObj.writeLine(Tab &amp; "errorMessage" &amp; Tab &amp; ": String;");
//	pFileObj.writeLine("");
	pFileObj.writeLine("begin");
	pFileObj.writeLine(Tab &amp; "// Initialize the activity first.");
	pFileObj.writeLine(Tab &amp; "self.agentInitializeActivity;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Arm our base exception handlers (local exception handlers which are");
	pFileObj.writeLine(Tab &amp; "// disarmed when the method returns).");
	pFileObj.writeLine(Tab &amp; "on Exception do self.agentExceptionHandler(exception);");
	pFileObj.writeLine(Tab &amp; "on LockException do self.agentLockExceptionHandler(exception);");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Validate the request.");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "if p" &amp; pClassObj.name &amp; "ToUpdate = null then");
	pFileObj.writeLine(Tab &amp; "	return self.agentSetError('No " &amp; pClassObj.name &amp; " selected to update  ');");
	pFileObj.writeLine(Tab &amp; "endif;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// If the owner object is invalid, then we want our exception handlers to");
	pFileObj.writeLine(Tab &amp; "// return a message saying so.  After registering the object and a message");
	pFileObj.writeLine(Tab &amp; "// here, if any subsequent invalid object exceptions occur, the exception");
	pFileObj.writeLine(Tab &amp; "// handler will then find the registered object and set the 'errorMsg'");
	pFileObj.writeLine(Tab &amp; "// property on the app class.  Therefore, by checking this errorMsg value");
	pFileObj.writeLine(Tab &amp; "// after performing an operation on the object (app.getLastError), the");
	pFileObj.writeLine(Tab &amp; "// appropriate error message can be returned for the exception.");
	pFileObj.writeLine(Tab &amp; "self.agentRegisterObjectAndError(p" &amp; pClassObj.name &amp; "ToUpdate, 'Invalid {" &amp; pClassObj.name &amp; " Object.');");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "beginTransaction;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// Exclusive transaction lock to obtain the latest edition of the object and");
	pFileObj.writeLine(Tab &amp; "// lock it. We need the latest edition to check it against pRequiredEdition.");
	pFileObj.writeLine(Tab &amp; "// This lock will be released automatically at the next commit/abort transaction.");
	pFileObj.writeLine(Tab &amp; "// We obtain an exclusive lock (as opposed to a shared lock) because we're");
	pFileObj.writeLine(Tab &amp; "// about to update the object, and JADE will automatically try to lock it");
	pFileObj.writeLine(Tab &amp; "// exclusively (if we don't already have it) before updating it. Getting an");
	pFileObj.writeLine(Tab &amp; "// exclusive lock up front avoids JADE having to upgrade the lock from shared");
	pFileObj.writeLine(Tab &amp; "// to exclusive at the point the object is updated.");
	pFileObj.writeLine(Tab &amp; "exclusiveLock(p" &amp; pClassObj.name &amp; "ToUpdate);");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// If the exclusiveLock gets an exception, our handler will resume to here.");
	pFileObj.writeLine(Tab &amp; "if self.lastError = null and pRequiredEdition &gt; 0 then");
	pFileObj.writeLine(Tab &amp; "	// We obtained the lock, now check the edition.");
	pFileObj.writeLine(Tab &amp; "	if p" &amp; pClassObj.name &amp; "ToUpdate.edition &lt;&gt; pRequiredEdition then");
	pFileObj.writeLine(Tab &amp; "		// The edition has changed, so the object on which the sender based");
	pFileObj.writeLine(Tab &amp; "		// this update is out-of-date.");
	pFileObj.writeLine(Tab &amp; "		self.agentSetError('Object is out-of-date.');");
	pFileObj.writeLine(Tab &amp; "	endif;");
	pFileObj.writeLine(Tab &amp; "endif;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// If we're still error free, then perform the operation.");
	pFileObj.writeLine(Tab &amp; "if self.lastError = null then");
//	line := Tab &amp; Tab &amp; "errorMessage := p" &amp; pClassObj.name &amp; "ToUpdate.updateMe(";
	line := Tab &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "ToUpdate.updateMe(";
	
	foreach propertyObj in pAllClassProperties where  not propertyObj.isKindOf(CollClass) do
//		if line = Tab &amp; Tab &amp; "errorMessage := p" &amp; pClassObj.name &amp; "ToUpdate.updateMe(" then
		if line = Tab &amp; Tab &amp; "p" &amp; pClassObj.name &amp; "ToUpdate.updateMe(" then
			line := line &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj);
		else
			line := line &amp; "," &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; self.getParameterName(propertyObj);
		endif;
	endforeach;
	
	line := line &amp; ");";
	pFileObj.writeLine(line);
//	pFileObj.writeLine(Tab &amp; "		self.agentSetError(errorMessage);");
	pFileObj.writeLine(Tab &amp; "endif;");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "// If the operation raises an exception, our handler will resume to here.");
	pFileObj.writeLine(Tab &amp; "if self.lastError = null then");
	pFileObj.writeLine(Tab &amp; "	// No errors, so commit.");
	pFileObj.writeLine(Tab &amp; "	commitTransaction;");
	pFileObj.writeLine(Tab &amp; "else");
	pFileObj.writeLine(Tab &amp; "	// We got an error so abort the transaction. Although TransactionAgent");
	pFileObj.writeLine(Tab &amp; "	// exception handlers abort the transaction before resuming, we do so");
	pFileObj.writeLine(Tab &amp; "	// here as well for completeness and symmetry with the beginTransaction.");
	pFileObj.writeLine(Tab &amp; "	// An abortTransaction when not in transaction state does nothing.");
	pFileObj.writeLine(Tab &amp; "	abortTransaction;");
	pFileObj.writeLine(Tab &amp; "endif;");
	pFileObj.writeLine("");
	pFileObj.writeLine("epilog");
	pFileObj.writeLine("");
	pFileObj.writeLine(Tab &amp; "return self.lastError;");
	pFileObj.writeLine(Tab &amp; "// Always return the error to the caller (which will be null if no errors).");
	pFileObj.writeLine("end;");
	pFileObj.writeLine("");
	pFileObj.writeLine("__endMethod;");
	pFileObj.writeLine(Tab &amp; Tab &amp; ")");
end;</source>
        <Parameter name="pFileObj" type="File" usage="io"/>
        <Parameter name="pTrxClassObj" type="Class"/>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pMethodName" type="String"/>
        <Parameter name="pAllClassProperties" type="PropertyNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="unload" id="4ce04c51-4df0-4f54-b311-d39d580f159e">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	delete self.aMyParentArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="writeScmHeader" id="633d1b94-aca6-4b60-9226-543270056d79">
        <source>writeScmHeader(pFileObj : File; pSchemaObj : Schema);

begin
	pFileObj.writeLine('jadeVersionNumber "' &amp; app.getSystemVersion() &amp; '";');
	pFileObj.writeLine('schemaDefinition');
	pFileObj.writeLine(	pSchemaObj.name
						&amp; " subschemaOf "
						&amp; pSchemaObj.superschema.name
						&amp; " partialDefinition, patchVersioningEnabled = false;");
	pFileObj.writeLine('localeDefinitions');
	pFileObj.writeLine(Tab &amp; '5129 "English (New Zealand)";');
	pFileObj.writeLine(Tab &amp; '10249 "English (Belize)" _cloneOf 5129;');
	pFileObj.writeLine(Tab &amp; '1033 "English (United States)" _cloneOf 5129;');
	pFileObj.writeLine(Tab &amp; '11273 "English (Trinidad y Tobago)" _cloneOf 5129;');
	pFileObj.writeLine(Tab &amp; '2057 "English (United Kingdom)" _cloneOf 5129;');
	pFileObj.writeLine(Tab &amp; '3081 "English (Australia)" _cloneOf 5129;');
	pFileObj.writeLine(Tab &amp; '4105 "English (Canada)" _cloneOf 5129;');
	pFileObj.writeLine(Tab &amp; '6153 "English (Ireland)" _cloneOf 5129;');
	pFileObj.writeLine(Tab &amp; '7177 "English (South Africa)" _cloneOf 5129;');
	pFileObj.writeLine(Tab &amp; '8201 "English (Jamaica)" _cloneOf 5129;');
	pFileObj.writeLine(Tab &amp; '9225 "English (Caribbean)" _cloneOf 5129;');
	pFileObj.writeLine('libraryDefinitions');
	pFileObj.writeLine('typeHeaders');
	pFileObj.writeLine('membershipDefinitions');
	pFileObj.writeLine('typeDefinitions');
end;</source>
        <Parameter name="pFileObj" type="File"/>
        <Parameter name="pSchemaObj" type="Schema"/>
    </JadeMethod>
</GUIClass>
