    <JadeMethod name="doResize" id="24e8640f-07e1-4f7a-bc90-1676e9e74f81">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/****Changes

Date		Name	TFS#	Description
============================================================================
16/01/2019	jlgka1	41708	Add Bill of Lading the the Search Criteria. 
							Increase table height from 11 to 12 rows.
============================================================================*/
constants
	RowHeight	: Integer = 20;
vars

begin
	inheritMethod();

	// Group Box and child controls
	
	grpDetail.top	:= self.frmToolbar.height; //WinTopMargin;
	//grpDetail.left	:= WinLeftMargin;
	grpDetail.width	:= self.clientWidth;// - WinLeftMargin - WinRightMargin;
	
	tblInput.cnEcResizeContents;
	
	if self.chkUseFilter.value then //cnwrd1 par 22789 
		//jlgka1 TFS 41708 --&gt;
	//	if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
		if self.useTotReqAllowedFld then	//28 Aug 2019	NDL	TFS 46118
			tblInput.height := (13 * RowHeight); 
		else
			tblInput.height := (12 * RowHeight); 
		endif;
		//jlgka1 TFS 41708 &lt;--
	else
		tblInput.height := (5 * RowHeight);
	endif;
	
	//tblInput.width	:= grpDetail.width - HorizontalSpacing;//(VerticalSpacing * 2);  //cnwrd1 par 22789 

	btnRemove.top	:= tblInput.top + tblInput.height + VerticalSpacing;
	btnRemove.left	:= tblInput.width - btnRemove.width - WinLeftMargin;

	btnAdd.top		:= btnRemove.top;
	btnAdd.left		:= btnRemove.left - HorizontalSpacing - btnAdd.width;

	btnRetrieve.top		:= btnRemove.top;
	self.lblNoSelected.top := btnRemove.top;
	//btnRetrieve.left	:= self.width - (self.btnRetrieve.width + 10);
	btnRetrieve.left := btnRemove.left;  //position over remove btn. //cnwrd1  par 22789
	grpDetail.height := btnRemove.top + btnRemove.height + VerticalSpacing;

	// Fit tblAll into whats left
	self.sptTIs.top	:= grpDetail.top + grpDetail.height + 1;
	self.sptTIs.left := 1;
	self.sptTIs.height	:= self.clientHeight - grpDetail.height - grpDetail.top - 1;
	self.sptTIs.width	:= grpDetail.width-1;
	self.sptTIs.cnEcResizeContents();	
	
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataDragTrackedItem" id="2a23298b-20b3-4fee-a39b-cb5928a82a3b">
        <updating/>
        <source>doTblDataDragTrackedItem() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	06 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	obj			: Object;
	pic			: Picture;
	otherTI,
	ti			: CM_TrackedItem;
begin
	ti := self.tblListAll.allSelectedObjects.first.CM_TrackedItem;
	if ti = null then
		return;
	endif;
	
	delete app.myMoveController;
	create app.myMoveController transient;
	app.myMoveController.setMyTrackedItem(ti);
	foreach obj in self.tblListAll.allSelectedObjects where obj &lt;&gt; ti do
		otherTI := obj.CM_TrackedItem;
		if otherTI.site &lt;&gt; TI_SITE_ONSITE then
			continue;
		endif;
		app.myMoveController.allOtherTrackedItems.add(otherTI);
	endforeach;
	
	app.myMoveController.isRehandleMove := ti.isRehandle;
	app.myMoveController.setMoveMode(REAL_MODE);	
	
	self.tblListAll.dragMode := DragMode_Drag;

	create pic transient;
	self.setPictureDragCursor(pic);
	if pic.picture &lt;&gt; null then
		self.tblListAll.dragCursor := pic.picture;
	endif;

epilog
	delete pic;
	
end;







</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getTiDisplay" id="1bad8288-0fba-49e5-bb6b-7bc86a1af550">
        <source>getTiDisplay( _ti : CM_TrackedItem ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2019	jlgndl1	Initial creation	TFS 46118

*/

vars

	str : String;

begin

	if self.useColumnOrganiser then	//14 Jun 2021	NDL	TFS 51338
		str :=  _ti.getAttributeStringForDefArray(self.tblListAll.allTblDataEntRows);
	elseif self.useTotReqAllowedFld then	
		str := _ti.id &amp; Tab &amp;
			   _ti.cargoTypeDescr &amp; Tab &amp;
			   _ti.getISOType &amp; Tab &amp;
			   _ti.voyageCode &amp; Tab &amp;
			   _ti.operatorCode &amp; Tab &amp;
			   _ti.totalQuantity.String &amp; Tab &amp;
			   _ti.locationId &amp; Tab &amp;
			   _ti.billOfLading;
	else
		str := _ti.id &amp; Tab &amp;
			   _ti.cargoTypeDescr &amp; Tab &amp;
			   _ti.getISOType &amp; Tab &amp;
			   _ti.voyageCode &amp; Tab &amp;
			   _ti.operatorCode &amp; Tab &amp;
			   _ti.totalQuantity.String &amp; Tab &amp;
			   _ti.locationId;
	endif;
	
	return str;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
