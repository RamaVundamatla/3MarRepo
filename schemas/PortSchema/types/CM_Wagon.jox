    <JadeMethod name="getTIDataForClearanceCheck" id="ca6f7462-b4f7-4c78-97b0-d5b69e7d1f6a">
        <source>getTIDataForClearanceCheck(_tiArray : CM_TIArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2010	cnwas3	Initial creation

*/
vars	
	cont : CM_LocationsController;
	ti : CM_TrackedItem;	
	futureMove : CM_FutureMove;
	
	futureMovePlanned : CM_FutureMovePlanned;
	futureMoveQueued :	CM_FutureMoveQueued;
begin

	
	
	//foreach cont in self.allLocationsControllers discreteLock do
	foreach cont in self.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345
		
		foreach ti in cont.allTrackedItems discreteLock do
			if self.isTIOutward(ti) then
				if cont &lt;&gt; ti.myPrimaryActualLocation then
					continue;
				endif;
				if (not _tiArray.includes(ti)) then					
					_tiArray.add(ti);					
				endif;
			endif;
		endforeach;		
					
		foreach futureMove in cont.allPlannedFutureMoves do
			futureMovePlanned := futureMove.CM_FutureMovePlanned;
			ti := futureMovePlanned.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if ti.myPrimaryPlannedLocation &lt;&gt; cont then
				// not the primary location for this ti.
				continue;
			endif;
			if (not _tiArray.includes(ti)) then				
				_tiArray.add(ti);				
			endif;
		endforeach;		
		
		foreach futureMove in cont.allQueuedFutureMoves do
			futureMoveQueued := futureMove.CM_FutureMoveQueued;
			ti := futureMoveQueued.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if ti.myPrimaryQueuedLocation &lt;&gt; cont then
				// not the primary location for this ti.
				continue;
			endif;
			if (not _tiArray.includes(ti)) then				
				_tiArray.add(ti);				
			endif;
		endforeach;		
		
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTIDataForPosiRuleCheck" id="f4d2db21-b0bc-4880-a505-b0cbc999937c">
        <source>getTIDataForPosiRuleCheck( wagPosiDataDict : CMIF_WagonPositionDataDict input );

/*

Purpose:			
	Planned and Actual TIs
	provided that the actuals are staying on the wagon for its outward journey.
	( It is presumed that the actuals that are not staying on the wagon will
		be removed before the wagon leaves...)
Parameters:			

Return Value:		


Date		Who		Reason
27 July 2009	cnwndl1	Initial creation
30 Mar 2010	NDL	- Add check for Queued items as well.

*/

vars

	tiArray : CM_TIArray;
	cont : CM_LocationsController;
	ti : CM_TrackedItem;
	tiPosition : Integer; // 20 foot position.
	tiLength : Integer;
	wagPosiData : CMIF_WagonPositionData;
	futureMove : CM_FutureMove;
	futureMovePlanned : CM_FutureMovePlanned;
	futureMoveQueued : CM_FutureMoveQueued;
	
begin

	create tiArray transient;
	
	//foreach cont in self.allLocationsControllers discreteLock do
	foreach cont in self.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345
	
		tiPosition := ( ( self.allLocationsControllersArray.indexOf(cont.CM_WagonController) + 1) / 2 ) .Integer; // the position on the wagon
		
		foreach ti in cont.allTrackedItems discreteLock do
			if self.isTIOutward(ti) then
				if cont &lt;&gt; ti.myPrimaryActualLocation then
					continue;
				endif;
				if (not tiArray.includes(ti)) then
					tiLength := ti.getActualLength().Integer;
					tiArray.add(ti);
					wagPosiDataDict.addTI(ti,tiPosition,tiLength);
				endif;
			endif;
		endforeach;
		
		foreach futureMove in cont.allPlannedFutureMoves do
			futureMovePlanned := futureMove.CM_FutureMovePlanned;
			ti := futureMovePlanned.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if ti.myPrimaryPlannedLocation &lt;&gt; cont then
				// not the primary location for this ti.
				continue;
			endif;
			if (not tiArray.includes(ti)) then
				tiLength := ti.getActualLength().Integer;
				tiArray.add(ti);
				wagPosiDataDict.addTI(ti,tiPosition,tiLength);
			endif;
		endforeach;
		
		//30 Mar 2010	NDL	Par 23487
		foreach futureMove in cont.allQueuedFutureMoves do
			futureMoveQueued := futureMove.CM_FutureMoveQueued;
			ti := futureMoveQueued.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if ti.myPrimaryQueuedLocation &lt;&gt; cont then
				// not the primary location for this ti.
				continue;
			endif;
			if (not tiArray.includes(ti)) then
				tiLength := ti.getActualLength().Integer;
				tiArray.add(ti);
				wagPosiDataDict.addTI(ti,tiPosition,tiLength);
			endif;
		endforeach;
		
	endforeach;
	
epilog

	delete tiArray;
	
end;</source>
        <Parameter name="wagPosiDataDict" type="CMIF_WagonPositionDataDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTIString" id="ff873395-e2d5-4397-ada0-4501bc7a3165">
        <source>getTIString(_ti : CM_TrackedItem; _transit : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     03 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _transit then
		if _ti.getImExStatus() = TI_IMEX_STATUS_REMAINONBOARD then
			return _ti.id;
		endif;
	else
		if _ti.getImExStatus() &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then
			return _ti.id;
		endif;
	endif;

	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIWagonPosition" id="c6438d15-7767-48a3-acc0-cf306f252e3c">
        <source>getTIWagonPosition(ti	:	CM_TrackedItem; mode : Integer)	:	Integer;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		Return the position on the wagon. The wagon it made up of 10 foot controller units
//				which ever controller the TI starts on is it posistion i.e the left hand side of the container.
//				This used to return N, S or C but not anymore!
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pos : Integer;
	lc : CM_WagonController;
begin
	if ti = null then
		return null;
	endif;
	//Find the TI on the wagon. As each LC has its own collection of TIs, we need to ask each controller if
	//it has the ti.
	foreach lc in self.allLocationsControllersArray do
		if lc.includesTI(ti, mode) then
			//----------------------
			//Return the element in the string array
			//----------------------
			pos := self.allLocationsControllersArray.indexOf(lc);
			return pos;
			/*if self.myWagonClass.locationIds.size &gt;= pos then
				return self.myWagonClass.locationIds[pos];
			endif;*/
			break;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIs" id="bfcd82f5-0a59-4157-b32a-abe36137a9e2">
        <source>getTIs(_tiArray : CM_TIArray input; _mode : Integer);
/*
 ------------------------------------------------------------------------
Created:			12 September 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	controller : CM_WagonController;
	ti : CM_TrackedItem;
	tmpArray : CM_TIArray;
begin

	_tiArray.clear;
	foreach controller in self.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
		controller.getTIs(_tiArray, _mode, false); // jlier1 TFS 56772 13/3/22 - this was true which meant it only got the cargo from the last controller on the wagon
	endforeach;
	//---------------------
	//Make sure each TI is only here once (40's and big TIs will be in multiple lcs)
	create tmpArray transient;

	foreach ti in _tiArray do
		if tmpArray.includes(ti) then
			continue;
		endif;
		tmpArray.add(ti);
	endforeach;
	
	_tiArray.clear;
	tmpArray.copy(_tiArray);
	
epilog
	delete tmpArray;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIsWeight" id="64286ed0-d53e-4408-91bf-e4115f931f97">
        <source>getTIsWeight(_tiArray : CM_TIArray) : Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2010	cnwas3	Initial creation

*/

vars	
	lWeight	: Decimal[14,4];
	lTI	: CM_TrackedItem;
begin
	
	foreach lTI in _tiArray do
		if lTI = null then
			continue;
		endif;
		lWeight := lWeight + lTI.totalWeight;
	endforeach;
	
	return lWeight;
epilog
	
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
