<Class name="CMIF_VoyageExtraMoveDtl" id="4d61ecf7-f450-4df4-b94d-dd15fd359470">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyageEvents"/>
    <ImplicitInverseRef name="myVoyage" id="4599883e-a272-4903-ac05-aaae56e7ceba">
        <embedded/>
        <type name="CM_Voyage"/>
    </ImplicitInverseRef>
    <PrimAttribute name="numCageMoves" id="e2e8dda1-a415-4de9-a350-f1900515f2ae">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numExtraMoves" id="c2913fd9-5a71-44ee-8602-a612254b829b">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numLashingBinMoves" id="311eb889-efbb-40dd-ba0e-d01affaa5c0e">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numLashings" id="f7f11f13-18ae-44bc-b33a-0880c4ce83da">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numUnlashings" id="86e4d15e-cf00-4e6a-a935-aae24bb5bf40">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="voyageEdition" id="ee38a90c-9181-4a43-86f2-7176eb3e1256">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setFromVoyage" id="035cd4e8-d063-47fa-8276-62a221501793">
        <updating/>
        <source>setFromVoyage(_voyage : CM_Voyage) updating;
/* ---------------------------------------------------------------------------
Created:     01 July 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	beginLoad;

	self.myVoyage := _voyage;
	
	sharedLock(_voyage);		// to get ensure we get latest edition
	
	self.voyageEdition		:= _voyage.edition;
	
	self.numCageMoves		:= _voyage.getNumCageMoves();
	self.numExtraMoves		:= _voyage.getNumExtraMoves();
	self.numLashingBinMoves	:= _voyage.getNumLashingBinMoves();
	self.numLashings		:= _voyage.getNumLashings();
	self.numUnlashings		:= _voyage.getNumUnlashings();
	
epilog
	endLoad;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
</Class>
