    <JadeMethod name="doResize" id="48001ba5-4a17-4c10-b1a5-3ad8a0d00572">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	anObj : Object;
	cdb : YRD_ContainerGridAreaDockBar;
begin

	inheritMethod();
	
	self.frmSelectorPane.cnEcResizeContents;	//29 July 2011	NDL	Par 27890
	
	foreach anObj in self.allDockBars do
		cdb := anObj.YRD_ContainerGridAreaDockBar;
		cdb.cnEcResizeContents();		
	endforeach;

	self.frmStatusLine.doResize();
	

end;</source>
