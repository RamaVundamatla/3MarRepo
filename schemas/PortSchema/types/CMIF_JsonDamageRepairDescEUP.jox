<Class name="CMIF_JsonDamageRepairDescEUP" id="41b1a8d0-3f6f-4094-b0a0-15a798c5a4ff">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Created for the JSON for EUP TFS - 55859</text>
    <DbClassMap file="cams"/>
    <ImplicitInverseRef name="goods" id="8cb35452-1cdd-4844-a7f3-45bffe35dbc4">
        <memberTypeInverse/>
        <type name="CMIF_JsonGoodsArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="header" id="1e6d05ba-9c86-4a56-a0a4-12da98651f02">
        <embedded/>
        <type name="CMIF_JsonHeaderEUP"/>
    </ImplicitInverseRef>
    <JadeMethod name="addDamOfManyGoodManyItemOfOp" id="f881f033-14af-44c2-9be5-8c3a8d48490d">
        <updating/>
        <source>addDamOfManyGoodManyItemOfOp(processingOperatorCode : String; _tiDict : CM_TIByCargoOperatorIdDict; isDamageTrx : Boolean) updating;

/*

Purpose:			
	This method is used to build the json for multiple TIs(itemized) that belong to different good(cargo groups)
Parameters:			

Return Value:		

Date				Who		Reason
15 September 2023	navra1	Initial creation for TFS 60208 - EUP | FR 54536 - D&amp;R - File Generation.
08 November 2023	navhn30 Bug 61126: EUP | FR - Damage and Repair - Mill Order Number
19 December 2023	navcs2	Bug 61010: EUP | FR - 53824 Transport Manifest MilOrderNumber / MillOrderLineNumber Mapping Differences to Call Off
17 January 2024		NAVCS2	Bug 61038: EUP | FR 54536 Damage and Repair Non-Itemised - field mapping issues
05 March 2024		NAVCS2	(Take 2) Bug 61038: EUP | FR 54536 Damage and Repair Non-Itemised - field mapping issues
25 June 2024		navmd1	TFS 61725 Fix Repair Date(time) not being reported in UTC (as the mapper expects UTC/Zulu time)
22 Aug  2024        navsp1	TFS Bug 64805: EUP | FR 54536 - Damage and Repair - Field Corrections
23 Aug  2024 		navhn30 Bug 64803: EUP | FR - 53824 Transport Manifest - Good/Items/Item/StorageLocation Format Incorrect
11 Nov  2024		navhn30 Bug MTN-33392: EUP NTO-443 - Damage/Repair Message sends Rolling Length in CM instead of default measurement type (mm)
12 Nov  2024		navhn30 Bug MTN-33409: EUP | FR 54536 - Operator Voyage Number is mapped incorrectly
13 Nov  2024		navhn30 Bug MTN-33408: EUP | FR 54536 - Shipping Line Code and Shipping Line Name missing from Damage/Repair Message
21 Mar  2025		navhn30 Bug MTN-34397: EUP FR | 54536 - Damage/Repair Message Does Not Use EDI Translations
*/

vars
	onegood : CMIF_JsonGoodEUP;
	goodsOwner : CMIF_JsonGoodsOwnerEUP;
	mill : CMIF_JsonMillEUP;
	buyer : CMIF_JsonBuyerEUP;
	forwardingAgent : CMIF_JsonForwardingAgentEUP;	
	carrierPartyForGood : CMIF_JsonCarrierPartyEUP;	
	damagetemp : CMIF_JsonDamageEUP;
	damage : CM_DamageInstance;
	ti : CM_TrackedItem;	
	tiOfCargoGrp : CM_TrackedItem;	
	item : CMIF_JsonItemEUP;	
	carrierPartyForItem : CMIF_JsonCarrierPartyEUP;	
	repairForItem : CMIF_JsonRepairEUP;	
	itemized : Boolean;
	discrepancyTransaction : CM_BBDiscrepancy;
	translationOperator : CM_Operator;
	foundMatch : Boolean;
	cargoGroupsProcessed : StringArray;
	damageInstancesofOneItem : CM_DamageInstanceByLocDict; 
	cargoGroupIdBeingProcessed : String;
	cargoGroupIdInIter : String;
	millOrderPos, storageLocPos : Integer;
	bbDiscrepancy : CM_BBDiscrepancy;
	lengthUOM,
	widthUOM,
	thicknessUOM,
	volumeUOM	: String;
	product	: CM_Product;
	truck	: CM_Vehicle;		// 17/01/2024	NAVCS2	Bug 61038
	wagon	: CM_Wagon;			// 17/01/2024	NAVCS2	Bug 61038
	vvr : CM_VehicleVisitRecord;
begin	
	if self.goods = null then
		return;
	endif;	
	
	create cargoGroupsProcessed transient;	
	
	foreach ti in _tiDict do
		if ti.myOperator.code &lt;&gt; processingOperatorCode then
			continue;
		endif;
		
		if ti.myCargoGroup = null then
			cargoGroupIdBeingProcessed := "UNKNOWN";
		else 
			cargoGroupIdBeingProcessed := ti.myCargoGroup.id;
			if cargoGroupIdBeingProcessed = null or cargoGroupIdBeingProcessed = "" then
				cargoGroupIdBeingProcessed := "UNKNOWN";
			endif;
		endif;	
	
		if not cargoGroupsProcessed.includes(cargoGroupIdBeingProcessed) then
			cargoGroupsProcessed.add(cargoGroupIdBeingProcessed);
			////////////////////////ONECARGO GROUP ie ONEGOOD////////////////////////////
			////////////////////////ONECARGO GROUP ie ONEGOOD////////////////////////////
			////////////////////////ONECARGO GROUP ie ONEGOOD////////////////////////////
			create onegood transient;			
			
			//determine if the good is itemized or not	
			itemized := true;	
			if ti.myCargoType.isBulkByVolume or ti.myCargoType.isBulkByWeight then
				itemized  := false;
			endif;			
			
			onegood.movementType := ti.getImexStatusStrDesc;
			onegood.bOLNumber := ti.billOfLading;
			onegood.bOLReference := ti.myVoyage.code;
			
			create goodsOwner transient;
			goodsOwner.code := ti.operatorCode;
			goodsOwner.name := ti.operatorDescription;
			
			translationOperator := ti.myTerminal.myRoot.allOperators[ti.operatorCode];
			
			if translationOperator &lt;&gt; null then																										//17/01/2024	NAVCS2	Bug 61038
				onegood.bOLReference := translationOperator.getXlationForeignCode( ti.myVoyage.code, XLATION_TYPE_VOYAGETERMINAL, foundMatch);		//17/01/2024	NAVCS2	Bug 61038
				goodsOwner.code		 := translationOperator.getXlationForeignCode( ti.operatorCode, XLATION_TYPE_OPERATOR_BYOP, foundMatch);		//21/03/2025	navhn30 MTN-34397
			endif;																																	//17/01/2024	NAVCS2	Bug 61038
			
			onegood.goodsOwner := goodsOwner;
			
			onegood.iD := (self.goods.size + 1).String; // 01/09/2023 navcs2 Bug 60159		//TODO: should this be a sequentially increasing number starting from 1 for each CMIF_CamDamageRepairDescEUP, as done now? or should it be changed?
			
			//if ti.myCargoGroup &lt;&gt; null then 
				onegood.keyMarks := cargoGroupIdBeingProcessed;
			//endif;
			
			onegood.reference := ti.mark;
			
			millOrderPos := ti.orderNumber.pos("|",1);	// 19/12/2023	navcs2	Bug 61010					// 08.11.23		navhn30		#61126
	
			if millOrderPos &gt; 0 then
				onegood.millOrderNumber := ti.orderNumber[1:millOrderPos -1];			// 19/12/2023	navcs2	Bug 61010
				
				onegood.millOrderLineNumber := ti.orderNumber[millOrderPos + 1 : end];	// 19/12/2023	navcs2	Bug 61010
			endif;
			
			onegood.description := ti.description;
			
			onegood.grade := ti.getGrade;
			
			onegood.remarks := ti.remarks;
			
			onegood.colour := ti.getColour;
			
			product := ti.myProduct;
			
			// 17/01/2024	NAVCS2	Bug 61038 Start
			if product &lt;&gt; null then
				lengthUOM := product.getDefaultMeasurementForType(Type_Length).shortName;
				widthUOM := product.getDefaultMeasurementForType(Type_Width).shortName;
				thicknessUOM := product.getDefaultMeasurementForType(Type_Height).shortName;
			else
				lengthUOM := app.getDefaultMeasurementForType(Type_Length).shortName;
				widthUOM := app.getDefaultMeasurementForType(Type_Width).shortName;
				thicknessUOM := app.getDefaultMeasurementForType(Type_Height).shortName;
			endif;
			// 17/01/2024	NAVCS2	Bug 61038 End
			
			onegood.width := app.convertMeasurementForDisplay(widthUOM, ti.width).asDecimalJMT; 	
			
			onegood.length := app.convertMeasurementForDisplay(lengthUOM, ti.length).asDecimalJMT;
			
			onegood.thickness := app.convertMeasurementForDisplay(thicknessUOM, ti.height).asDecimalJMT;
			
			onegood.diameter:= app.convertMeasurementForDisplay(lengthUOM, ti.getDiameter).asDecimalJMT;
			
			onegood.lengthUOM:=  lengthUOM; // 30/08/2023 navcs2 Bug 60155
			
			onegood.grammage := ti.getGrammage;
			onegood.piecesPerPack := ti.quantity;
			
			onegood.directOperation := ti.directDelivery;
			
			if translationOperator &lt;&gt; null then
				onegood.cargoType := translationOperator.getXlationSystemCode(ti.cargoTypeCode, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);
				if not foundMatch then	
					onegood.cargoType := ti.cargoTypeDescr;
				endif;
			else 
				onegood.cargoType := ti.cargoTypeDescr;
			endif;
			
			onegood.packageType:= ti.getCargoSubTypeDescr;
			onegood.quality := ti.commodity;
			onegood.quantityEffective := ti.totalQuantity;
			
			if isDamageTrx then		
				onegood.grossWeightEffective:= ti.totalWeight.Integer;	
			
				onegood.nettWeightEffective:= ti.weight.Integer;		
				
				onegood.aDMTEffective:= ti.totalWeight.Integer;		
			else
				if ti.allDamageInstancesByTS.last.CM_DamageInstance.myRepairDetail &lt;&gt; null then
					bbDiscrepancy := ti.allDamageInstancesByTS.last.CM_DamageInstance.myRepairDetail.myBBTransReference;
			
					if bbDiscrepancy &lt;&gt; null then
						onegood.grossWeightEffective := bbDiscrepancy.newTotalWeight.Integer - bbDiscrepancy.totalWeight.Integer;		
					
						onegood.nettWeightEffective:= bbDiscrepancy.newCargoWeight.Integer;
					
						onegood.aDMTEffective:= bbDiscrepancy.newTotalWeight.Integer - bbDiscrepancy.cargoWeightChange.Integer;		
					endif;
				endif;
			endif;
			
			onegood.volumeEffective:= app.convertMeasurementForDisplay(onegood.volumeUOM, ti.totalVolume).asDecimalJMT;
			
			create mill transient;
			if ti.getConsignorObject &lt;&gt; null then
				if translationOperator &lt;&gt; null then
					mill.code:= translationOperator.getXlationSystemCode(ti.getConsignorObject.code, XLATION_TYPE_OPERATOR_BYOP, foundMatch);
					if foundMatch then
						mill.code:=ti.getConsignorObject.code;
					endif;
				else
					mill.code:=ti.getConsignorObject.code;
				endif;
				mill.name:=ti.getConsignorObject.description;
			endif;
			
			onegood.mill := mill;
			
			create buyer transient;
			if ti.getConsigneeObject &lt;&gt; null then		
				if translationOperator &lt;&gt; null then			
					buyer.code := translationOperator.getXlationSystemCode(ti.getConsigneeObject.code, XLATION_TYPE_OPERATOR_BYOP, foundMatch);
					if foundMatch then
						buyer.code := ti.getConsigneeObject.code;
					endif;
				else
					buyer.code := ti.getConsigneeObject.code;
				endif;
				buyer.name:=ti.getConsigneeObject.description;
			endif;
			
			onegood.buyer := buyer;
			
			create forwardingAgent transient;
			forwardingAgent.code := ti.freightForwarderCode;
			if ti.myFreightForwarder &lt;&gt; null then
				forwardingAgent.name:=ti.myFreightForwarder.description;	
			endif;
			
			onegood.forwardingAgent := forwardingAgent;
			
			if not ti.itemised then
				onegood.goodsBarcode:=ti.alternativeId;
			endif;
			
			onegood.certificate:=ti.condition;
			
			onegood.containerNumber := ti.getMyUnpackedFromContainerId;
			
			onegood.loadingPort := ti.loadPort;
			
			onegood.unloadingPort := ti.dischargePort;
			
			onegood.finalDestinationPort := ti.destinationPort;
			
			onegood.destinationPort := ti.destinationPort;
			
			onegood.dangerousGoods := ti.isHazardous;		
			
			if ti.getHazardFirst &lt;&gt; null then
				onegood.iMOClass := ti.getHazardFirstCode;
			
				onegood.uNCode:= ti.getHazardFirst.getUNDGCode1;			
			
				onegood.packingGroup:=ti.getHazardPackingGroup;
			
				onegood.limitedQuantity:=ti.getHazardFirst.limitedQuantity;
			endif;
			
			onegood.flashpoint:=ti.getHazFlashpoint;
			
			onegood.customerReference:=ti.clientRef;
			
			onegood.stowageMode:=ti.specialStow;
			
			onegood.countryOfOrigin:=ti.getCountryOfOriginCode;		
			
			onegood.warehouse := ti.terminalAreaId;
			
			// 06/07/2023 navcs2 Bug 59014 Start
			//if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.myTerminalArea &lt;&gt; null and ti.myPrimaryActualLocation.myTerminalArea.isIrregularBlockArea and 
			storageLocPos := ti.locationId.pos(" ",1); // 23.08.24	navhn30	TFS 64803
			if storageLocPos &gt; 0 then
				onegood.storageLocation := ti.locationId[storageLocPos + 1 : end];
			else
				onegood.storageLocation := ti.locationId;
			endif;
			// 06/07/2023 navcs2 Bug 59014 End
			
			onegood.blocked:=ti.hasStops;
			
			//is this correct?
			onegood.blockingReason:=ti.stopsCode;	
			
			if ti.damaged then	//it has damages
				onegood.productCondition := "Damaged";
			endif;
			
			if not ti.damaged then	//it has been repaired
				onegood.productCondition := "Repaired";
			endif;			
			
			onegood.operatorVoyageNumber := ti.carrierRemarks;		//12.11.24	 navhn30	MTN-33409
			
			create onegood.transport transient;
			onegood.transport.transportationMode := app.transModeToString(ti.receiptTransportMode);
			onegood.transport.dischargingPlace :=ti.myTerminal.code;		//17/01/2024	NAVCS2	Bug 61038			
			create carrierPartyForGood transient;
			
			// 17/01/2024	NAVCS2	Bug 61038 start
			if ti.receiptTransportMode= TI_TRANSMODE_ROAD then
				//what is truckcarriername?
				//vvr := app.myPassport.myTerminal.allVehicleVisitsByNumDT[ti.getTruckNumber, null];
				vvr := ti.getVehicleVisitReceival;
				if vvr &lt;&gt; null then
					truck := vvr.vehicle;
					if truck &lt;&gt; null and truck.carrier &lt;&gt; null then		// 13.11.24		navhn30		MTN-33408
						carrierPartyForGood.name := truck.carrier.description;
						carrierPartyForGood.code := truck.carrier.code;
					endif;
				endif;
			elseif ti.receiptTransportMode= TI_TRANSMODE_RAIL then
				//carrierPartyForGood.code := ti.getWagonId;												//TFS 64805	
				//what is wagoncarriername?
				wagon := ti.myTerminal.allWagons.getAtKeyGeq(ti.getWagonId, "31,12,3001".Date.TimeStamp); 	//TFS 64805	
				if wagon &lt;&gt; null and wagon.myCarrier &lt;&gt; null then
					carrierPartyForGood.name := wagon.myCarrier.description;							  	//TFS 64805
					carrierPartyForGood.code := wagon.myCarrier.code;										//TFS 64805
				endif;
			elseif ti.receiptTransportMode= TI_TRANSMODE_SHIP then	
				if ti.getShippingLineCode &lt;&gt; null then			// 13.11.24		navhn30		MTN-33408	start
					carrierPartyForGood.code := ti.getShippingLineCode;	
					carrierPartyForGood.name := ti.getShippingLineDesc;
				else
					if ti.myVoyage.myShippingLine &lt;&gt; null then
						carrierPartyForGood.code := ti.myVoyage.myShippingLine.code;
						carrierPartyForGood.name := ti.myVoyage.myShippingLine.description;
					endif;
				endif;											// 13.11.24		navhn30		MTN-33408	 end
			endif;	
			//17/01/2024	NAVCS2	Bug 61038 End
			
			onegood.transport.carrierParty := carrierPartyForGood;			
			
			if itemized then
				//////////////EACH ITEM(ie TI) IN THE GOOD(ie. CARGO GROUP)///////////////////
				//////////////EACH ITEM(ie TI) IN THE GOOD(ie. CARGO GROUP)///////////////////
				//////////////EACH ITEM(ie TI) IN THE GOOD(ie. CARGO GROUP)///////////////////
				foreach tiOfCargoGrp in _tiDict do
					if tiOfCargoGrp.myOperator.code &lt;&gt; processingOperatorCode then
						continue;
					endif;
					
					if tiOfCargoGrp.myCargoGroup = null then
						cargoGroupIdInIter := "UNKNOWN";
					else
						cargoGroupIdInIter := tiOfCargoGrp.myCargoGroup.id;
					endif;
					
					if cargoGroupIdInIter &lt;&gt; cargoGroupIdBeingProcessed then
						continue;
					endif;
					
					create item transient;
					
					item.itemId := tiOfCargoGrp.id;
					
					item.itemBarcode1 := tiOfCargoGrp.alternativeId;			// 17/01/2024	NAVCS2	Bug 61038
					
					item.itemBarcode2 := tiOfCargoGrp.secondaryBarcodeId;		// 17/01/2024	NAVCS2	Bug 61038
					
					item.quantityEffective := tiOfCargoGrp.totalQuantity;
					
					if isDamageTrx then		
						item.grossWeightEffective:= ti.totalWeight.Integer;		
						
						item.nettWeightEffective:= ti.weight.Integer;		
						
						item.aDMTEffective:= ti.totalWeight.Integer;		
					else
						if ti.allDamageInstancesByTS.last.CM_DamageInstance.myRepairDetail &lt;&gt; null then
							bbDiscrepancy := ti.allDamageInstancesByTS.last.CM_DamageInstance.myRepairDetail.myBBTransReference;
			
							if bbDiscrepancy &lt;&gt; null then
								item.grossWeightEffective := bbDiscrepancy.newTotalWeight.Integer - bbDiscrepancy.totalWeight.Integer;		
					
								item.nettWeightEffective:= bbDiscrepancy.newCargoWeight.Integer;
					
								item.aDMTEffective:= bbDiscrepancy.newTotalWeight.Integer - bbDiscrepancy.cargoWeightChange.Integer;		
							endif;
						endif;
					endif;
					
					item.volumeEffective := tiOfCargoGrp.totalVolume;
					
					// 17/01/2024	NAVCS2	Bug 61038 Start
					if product &lt;&gt; null then
						lengthUOM := product.getDefaultMeasurementForType(Type_Length).shortName;
						widthUOM := product.getDefaultMeasurementForType(Type_Width).shortName;
						thicknessUOM := product.getDefaultMeasurementForType(Type_Height).shortName;
						volumeUOM := product.getDefaultMeasurementForType(Type_Volume).shortName;	
					else
						lengthUOM := app.getDefaultMeasurementForType(Type_Length).shortName;
						widthUOM := app.getDefaultMeasurementForType(Type_Width).shortName;
						thicknessUOM := app.getDefaultMeasurementForType(Type_Height).shortName;
						volumeUOM := app.getDefaultMeasurementForType(Type_Volume).shortName;	
					endif;
					// 17/01/2024	NAVCS2	Bug 61038 End
					
					item.weightUOM := app.getDefaultMeasurementForType(Type_Weight).shortName; // 30/08/2023 navcs2 Bug 60155
						
					item.volumeUOM:= volumeUOM; // 30/08/2023 navcs2 Bug 60155
						
					item.width := app.convertMeasurementForDisplay(widthUOM, tiOfCargoGrp.width).asDecimalJMT; 	
						
					item.length := app.convertMeasurementForDisplay(lengthUOM, tiOfCargoGrp.length).asDecimalJMT;
						
					item.thickness := app.convertMeasurementForDisplay(thicknessUOM, tiOfCargoGrp.height).asDecimalJMT;
						
					item.diameter:= app.convertMeasurementForDisplay(lengthUOM, tiOfCargoGrp.getDiameter).asDecimalJMT;
						
					item.lengthUOM:=  lengthUOM; // 30/08/2023 navcs2 Bug 60155
					
					item.diameter := tiOfCargoGrp.getDiameter().Integer;
					
					item.piecesPerPack := tiOfCargoGrp.quantity;
					
					
					if tiOfCargoGrp.damaged then	//it has damages
						item.productCondition := "Damaged";
					endif;
					if not tiOfCargoGrp.damaged then	//it has been repaired
						item.productCondition := "Repaired";
					endif;		
				
					item.containerNumber := tiOfCargoGrp.getMyUnpackedFromContainerId;
										
					item.runningLengthUOM := lengthUOM; // 30/08/2023 navcs2 Bug 60155
					
					item.runningLength := app.convertMeasurementForDisplay(lengthUOM,tiOfCargoGrp.getRollingLength).Integer;	// 11.11.24		navhn30		MTN-33392
					
					item.dedicatedWarehouse := tiOfCargoGrp.terminalAreaId;		// 23.08.24	navhn30	TFS #64803
					
					//item.storageLocation := tiOfCargoGrp.locationId;
					//if tiOfCargoGrp.myPrimaryActualLocation &lt;&gt; null and tiOfCargoGrp.myPrimaryActualLocation.myTerminalArea &lt;&gt; null and tiOfCargoGrp.myPrimaryActualLocation.myTerminalArea.isIrregularBlockArea and 
					storageLocPos := tiOfCargoGrp.locationId.pos(" ",1);	// 23.08.24	 navhn30  TFS #64803
					if storageLocPos &gt; 0 then
						onegood.storageLocation := tiOfCargoGrp.locationId[storageLocPos + 1 : end];	// 19/12/2023	navcs2	Bug 61010
					else
						onegood.storageLocation := tiOfCargoGrp.locationId;
					endif;
					
					item.blocked := tiOfCargoGrp.hasStops;
					
					item.blockingReason := tiOfCargoGrp.stopCodes;	
					
					create item.transport transient;
					item.transport.transportationMode := app.transModeToString(tiOfCargoGrp.receiptTransportMode);
					item.transport.dischargingPlace :=tiOfCargoGrp.subTerminalCode;	
				
					create carrierPartyForItem transient;
					
					if ti.receiptTransportMode= TI_TRANSMODE_ROAD then
						//what is truckcarriername?
						//vvr := ti.myTerminal.allVehicleVisitsByNumDT[ti.getTruckNumber, null];
						vvr := ti.getVehicleVisitReceival;
						if vvr &lt;&gt; null then
							truck := vvr.vehicle;
							if truck &lt;&gt; null and truck.carrier &lt;&gt; null then		// 13.11.24		navhn30		MTN-33408
								carrierPartyForItem.name := truck.carrier.description;
								carrierPartyForItem.code := truck.carrier.code;
							endif;
						endif;
					elseif ti.receiptTransportMode= TI_TRANSMODE_RAIL then
						//carrierPartyForItem.code := ti.getWagonId;												//TFS 64805	
						//what is wagoncarriername?
						wagon := ti.myTerminal.allWagons.getAtKeyGeq(ti.getWagonId, "31,12,3001".Date.TimeStamp); 	//TFS 64805	
						if wagon &lt;&gt; null and wagon.myCarrier &lt;&gt; null then
							carrierPartyForItem.name := wagon.myCarrier.description;								//TFS 64805
							carrierPartyForItem.code := wagon.myCarrier.code;										//TFS 64805
						endif;
					elseif ti.receiptTransportMode= TI_TRANSMODE_SHIP then	
						if ti.getShippingLineCode &lt;&gt; null then			// 13.11.24		navhn30		MTN-33408	start
							carrierPartyForItem.code := ti.getShippingLineCode;	
							carrierPartyForItem.name := ti.getShippingLineDesc;
						else
							if ti.myVoyage.myShippingLine &lt;&gt; null then
								carrierPartyForItem.code := ti.myVoyage.myShippingLine.code;
								carrierPartyForItem.name := ti.myVoyage.myShippingLine.description;
							endif;
						endif;											// 13.11.24		navhn30		MTN-33408	 end
					endif;			
					
					item.transport.carrierParty := carrierPartyForItem;
					
					damageInstancesofOneItem := tiOfCargoGrp.allDamageInstances;
					foreach damage in damageInstancesofOneItem do
						if item.damages = null then
							create item.damages transient;
						endif;
						
						create damagetemp transient;
						
						damagetemp.date := damage.damageDateTime.localToUTCTime;					// 07.07.2023 navcs2 Bug 59014
						
						damagetemp.type := damage.getDamageCode;
						
						damagetemp.position := damage.getDamagePositionCode;
						
						damagetemp.size := damage.damageSize.String;
						
						if damage.myDamageReason &lt;&gt; null then
							damagetemp.reason := damage.myDamageReason.code;
						endif;
						
						damagetemp.remarks := damage.remarks;
						
						if damage.myDamagePlace &lt;&gt; null then
							damagetemp.place := damage.myDamagePlace.code;
						endif;
						
						if damage.myDamageParty &lt;&gt; null then
							damagetemp.responsibleParty := damage.myDamageParty.code;
						endif;
						
						damagetemp.severity := damage.severity.String;
						
						if damage.status = DamageStatusRefused then
							damagetemp.refused := true;
						else
							damagetemp.refused := false;
						endif;
						
						
						if damage.myRepairDetail &lt;&gt; null then
							create repairForItem transient;			
							
							
							repairForItem.date := damage.myRepairDetail.repairedDateTime.localToUTCTime;
							if damage.myRepairDetail.myRepairReason &lt;&gt; null then							//navra1 - TFS56946 - 2 Mar 2023
								repairForItem.reason :=damage.myRepairDetail.myRepairReason.code;
							endif;																			//navra1 - TFS56946 - 2 Mar 2023
							
							repairForItem.remarks := damage.myRepairDetail.remarks;
						
							//30/08/2023 navcs2 Bug 60155 Start
							discrepancyTransaction := damage.myRepairDetail.myBBTransReference;
							
							if discrepancyTransaction &lt;&gt; null then
								repairForItem.newGrossWeight := discrepancyTransaction.newTotalWeight.Integer;
								repairForItem.newNettWeight := discrepancyTransaction.newCargoWeight.Integer;
							
								repairForItem.lostWeight:= discrepancyTransaction.weightChange.Integer;	 // 30/08/2023 navcs2 Bug 60155	
							endif;
							//30/08/2023 navcs2 Bug 60155 end
							
							create damagetemp.repairs transient;
							damagetemp.repairs.add(repairForItem);		
						endif;
						
						item.damages.add(damagetemp);			
						
					endforeach;	
					
					//add the item to items array of the good
					if onegood.items = null then
						create onegood.items transient;
					endif;
					
					onegood.items.add(item);	
				endforeach;
				//////////////EACH ITEM(ie TI) IN THE GOOD(ie. CARGO GROUP)///////////////////
				//////////////EACH ITEM(ie TI) IN THE GOOD(ie. CARGO GROUP)///////////////////
				//////////////EACH ITEM(ie TI) IN THE GOOD(ie. CARGO GROUP)///////////////////	
			else
				create onegood.damages transient;			
				
				//can there be 2 cargo items with the same good(cargo group?).. then how will this work?
				//foreach damage in damageInstancesofOneGood do
				foreach damage in ti.allDamageInstances do
					create damagetemp transient;
					
					damagetemp.date := damage.damageDateTime.localToUTCTime;					// 07.07.2023 navcs2 Bug 59014
					
					damagetemp.type := damage.getDamageCode;
					
					damagetemp.position := damage.getDamagePositionCode;
					
					damagetemp.size := damage.damageSize.String;
					
					damagetemp.reason := damage.myDamageReason.code;
					
					damagetemp.remarks := damage.remarks;
					
					damagetemp.place := damage.myDamagePlace.code;
					
					damagetemp.responsibleParty := damage.myDamageParty.code;
					
					damagetemp.severity := damage.severity.String;
					
					if damage.status = DamageStatusRefused then
						damagetemp.refused := true;
					else
						damagetemp.refused := false;
					endif;			
					
					create repairForItem transient;			
					create damagetemp.repairs transient;
					
					repairForItem.date := damage.myRepairDetail.repairedDateTime.localToUTCTime;
					
					if damage.myRepairDetail &lt;&gt; null then
						if damage.myRepairDetail.myRepairReason &lt;&gt; null then									//navra1 - TFS56946 - 2 Mar 2023
							repairForItem.reason :=damage.myRepairDetail.myRepairReason.code;					
						endif;																					//navra1 - TFS56946 - 2 Mar 2023

						repairForItem.remarks := damage.myRepairDetail.remarks;

						//30/08/2023 navcs2 Bug 60155 Start
						discrepancyTransaction := damage.myRepairDetail.myBBTransReference;
						
						if discrepancyTransaction &lt;&gt; null then
							repairForItem.newGrossWeight := discrepancyTransaction.newTotalWeight.Integer;
							repairForItem.newNettWeight := discrepancyTransaction.newCargoWeight.Integer;
						
							repairForItem.lostWeight:= discrepancyTransaction.weightChange.Integer;	 // 30/08/2023 navcs2 Bug 60155	
						endif;
						//30/08/2023 navcs2 Bug 60155 Start
					endif;
					
					damagetemp.repairs.add(repairForItem);
					
					onegood.damages.add(damagetemp);
					
				endforeach;	
				
			endif;
			
			
			//finally add the good to the goods array
			self.goods.add(onegood);
			////////////////////////ONECARGO GROUP ie ONEGOOD////////////////////////////
			////////////////////////ONECARGO GROUP ie ONEGOOD////////////////////////////
			////////////////////////ONECARGO GROUP ie ONEGOOD////////////////////////////	
			
		endif;
	endforeach;

	
epilog
	delete cargoGroupsProcessed;
end;</source>
        <Parameter name="processingOperatorCode" type="String"/>
        <Parameter name="_tiDict" type="CM_TIByCargoOperatorIdDict"/>
        <Parameter name="isDamageTrx" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addDamagesOfOneGoodDetails" id="60caa72c-2e50-43b1-acf0-b6e004dd573f">
        <updating/>
        <source>addDamagesOfOneGoodDetails(damageInstancesofOneGood : CM_DamageInstanceByLocDict; isDamageTrx : Boolean; isForRepair : Boolean) updating;
/*

Purpose:			

	This method is used to build up the json for 1 TI(itemized or non-itemized), which means there will be only 1 good(which is expected of this method) 
	in the goods and only 1 item in the items of the good(Which is the TI for which this is being constructed

Parameters:			

Return Value:		

Date				Who		Reason
13 January 2023		navra1	Initial creation for TFS - 55859
21 March 2023		navmd1	TFS Fix Confignee/or names coming out incorrectly
06/07/2023			navcs2	Bug 59014: FR | 54536 EUP - Damage and Repair Missing or Incorrect Fields in Message
11/08/2023			jlika1	TFS 59784 EUP - The CAMS message is not showing the full gridded block stack location
29/08/2023			navcs2	Bug 60155: EUP | FR 54536 - Damage and Repair CAMS - Items found WP1
01/09/2023			navcs2	Bug 60159: EUP | FR 54536 - Damage and Repair CAMS - Transform Change (ID)
11/09/2023			jlika1	TFS 60337  EUP | FR EDI - EUP CAMS protocols: Translations based on Receiver
29/09/2023			navcs2	ChangeRequest 60697: EUP | FR 54536 - Damage and Repair CAMS protocol transaction inclusion
08 November 2023	navhn30 Bug 61126: EUP | FR - Damage and Repair - Mill Order Number
19/12/2023			navcs2	Bug 61010: EUP | FR - 53824 Transport Manifest MilOrderNumber / MillOrderLineNumber Mapping Differences to Call Off
17/01/2024			NAVCS2	Bug 61038: EUP | FR 54536 Damage and Repair Non-Itemised - field mapping issues
25/06/2024			navmd1	TFS 61725 Fix Repair Date(time) not being reported in UTC (as the mapper expects UTC/Zulu time)
22 Aug  2024        navsp1	TFS Bug 64805: EUP | FR 54536 - Damage and Repair - Field Corrections
23 Aug  2024 		navhn30 Bug 64803: EUP | FR - 53824 Transport Manifest - Good/Items/Item/StorageLocation Format Incorrect
11 Nov  2024		navhn30 Bug MTN-33392: EUP NTO-443 - Damage/Repair Message sends Rolling Length in CM instead of default measurement type (mm)
12 Nov  2024		navhn30 Bug MTN-33409: EUP | FR 54536 - Operator Voyage Number is mapped incorrectly
13 Nov  2024		navhn30 Bug MTN-33408: EUP | FR 54536 - Shipping Line Code and Shipping Line Name missing from Damage/Repair Message
21 Mar  2025		navhn30 Bug MTN-34397: EUP FR | 54536 - Damage/Repair Message Does Not Use EDI Translations
*/

vars
	onegood : CMIF_JsonGoodEUP;
	goodsOwner : CMIF_JsonGoodsOwnerEUP;
	mill : CMIF_JsonMillEUP;
	buyer : CMIF_JsonBuyerEUP;
	forwardingAgent : CMIF_JsonForwardingAgentEUP;	
	carrierPartyForGood : CMIF_JsonCarrierPartyEUP;	
	damagetemp : CMIF_JsonDamageEUP;
	damage : CM_DamageInstance;
	ti : CM_TrackedItem;	
	item : CMIF_JsonItemEUP;	
	carrierPartyForItem : CMIF_JsonCarrierPartyEUP;	
	repairForItem : CMIF_JsonRepairEUP;	
	itemized : Boolean;
	discrepancyTransaction : CM_BBDiscrepancy;
	translationOperator : CM_Operator;
	foundMatch : Boolean;
	millOrderPos, storageLocPos : Integer;
	bbDiscrepancy : CM_BBDiscrepancy;
	lengthUOM,
	widthUOM,
	thicknessUOM,
	volumeUOM	: String;
	product	: CM_Product;
	truck	: CM_Vehicle;
	wagon	: CM_Wagon;
	vvr		: CM_VehicleVisitRecord;
begin

	/* This is done with the assumption that the TI and the Item are the same thing. Is this assumption correct? 
	Because of this the details of ongood(the involved TI) and the item(again the TI) would be the same thing. Is 
	that correct? If then, why do we have containerNumber(as unpacked from container id)?  */
	
	if self.goods = null then
		return;
	endif;
	
	create onegood transient;
	
	//all the damage instances are of the same TI, so use the TI of the first damage instance
	ti := damageInstancesofOneGood.first.myTrackedItem;
	
	//determine if the good is itemized or not	
	itemized := true;	
	if ti.myCargoType.isBulkByVolume or ti.myCargoType.isBulkByWeight then
		itemized  := false;
	endif;		
	
	translationOperator := ti.myTerminal.myRoot.allOperators[ti.operatorCode];

	onegood.movementType := ti.getImexStatusStrDesc;
	onegood.bOLNumber := ti.billOfLading;
	
	create goodsOwner transient;
	goodsOwner.code := ti.operatorCode;
	goodsOwner.name := ti.operatorDescription;
	
	translationOperator := ti.myTerminal.myRoot.allOperators[ti.operatorCode];

	if translationOperator &lt;&gt; null then																										//17/01/2024	NAVCS2	Bug 61038
		onegood.bOLReference := translationOperator.getXlationForeignCode( ti.myVoyage.code, XLATION_TYPE_VOYAGETERMINAL, foundMatch);		//17/01/2024	NAVCS2	Bug 61038
		goodsOwner.code		 := translationOperator.getXlationForeignCode( ti.operatorCode, XLATION_TYPE_OPERATOR_BYOP, foundMatch);		//21/03/2025	navhn30 MTN-34397
	endif;																																	//17/01/2024	NAVCS2	Bug 61038
	
	onegood.goodsOwner:=goodsOwner;
	
	onegood.iD := (self.goods.size + 1).String; // 01/09/2023 navcs2 Bug 60159		//TODO: should this be a sequentially increasing number starting from 1 for each CMIF_CamDamageRepairDescEUP, as done now? or should it be changed?
	
	if ti.myCargoGroup &lt;&gt; null then 
		onegood.keyMarks := ti.myCargoGroup.id;
	endif;
	
	onegood.reference := ti.mark;
	
	millOrderPos := ti.orderNumber.pos("|",1);							// 08.11.23	navhn30	#61126			// 20/12/2023 navcs2 61010
	
	if millOrderPos &gt; 0 then
		onegood.millOrderNumber := ti.orderNumber[1:millOrderPos -1];				// 20/12/2023	navcs2	Bug 61010
		
		onegood.millOrderLineNumber := ti.orderNumber[millOrderPos + 1 : end];		// 20/12/2023	navcs2	Bug 61010
	endif;
	
	onegood.description := ti.description;
	
	onegood.grade := ti.getGrade;
	
	onegood.remarks := ti.remarks;
	
	onegood.colour := ti.getColour;
	
	onegood.directOperation := ti.directDelivery;
	
	product := ti.myProduct;
	
	// 17/01/2024	NAVCS2	Bug 61038 Start
	if product &lt;&gt; null then
		lengthUOM := product.getDefaultMeasurementForType(Type_Length).shortName;
		widthUOM := product.getDefaultMeasurementForType(Type_Width).shortName;
		thicknessUOM := product.getDefaultMeasurementForType(Type_Height).shortName;
		volumeUOM := product.getDefaultMeasurementForType(Type_Volume).shortName;
	else
		lengthUOM := app.getDefaultMeasurementForType(Type_Length).shortName;
		widthUOM := app.getDefaultMeasurementForType(Type_Width).shortName;
		thicknessUOM := app.getDefaultMeasurementForType(Type_Height).shortName;
		volumeUOM := app.getDefaultMeasurementForType(Type_Volume).shortName;
	endif;
	// 17/01/2024	NAVCS2	Bug 61038 End	
		
	onegood.width := app.convertMeasurementForDisplay(widthUOM, ti.width).asDecimalJMT; 	
			
	onegood.length := app.convertMeasurementForDisplay(lengthUOM, ti.length).asDecimalJMT;
			
	onegood.thickness := app.convertMeasurementForDisplay(thicknessUOM, ti.height).asDecimalJMT;
			
	onegood.diameter:= app.convertMeasurementForDisplay(lengthUOM, ti.getDiameter).asDecimalJMT;
			
	onegood.lengthUOM:=  lengthUOM; // 30/08/2023 navcs2 Bug 60155
	
	onegood.grammage := ti.getGrammage;
	onegood.piecesPerPack := ti.quantity;
	
	if translationOperator &lt;&gt; null then
		onegood.cargoType := translationOperator.getXlationSystemCode(ti.cargoTypeCode, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);
		if not foundMatch then	
			onegood.cargoType := ti.cargoTypeDescr;
		endif;
	else 
		onegood.cargoType := ti.cargoTypeDescr;
	endif;
	
	onegood.packageType:= ti.getCargoSubTypeDescr;
	onegood.quality := ti.commodity;
	onegood.quantityEffective := ti.totalQuantity;
	
	//THIS METHOD WOULD ONLY FILL ONE GOOD ONE ONE ITEM WHICH IS THE TI THAT THIS METHOD CALL IS FOR

	if not isForRepair then		
		onegood.grossWeightEffective:= ti.totalWeight.Integer;		
		
		onegood.nettWeightEffective:= ti.weight.Integer;		
		
		onegood.aDMTEffective:= ti.totalWeight.Integer;		
	else
		if ti.allDamageInstancesByTS.last.CM_DamageInstance.myRepairDetail &lt;&gt; null then
			bbDiscrepancy := ti.allDamageInstancesByTS.last.CM_DamageInstance.myRepairDetail.myBBTransReference;
			
			if bbDiscrepancy &lt;&gt; null then
				onegood.grossWeightEffective := bbDiscrepancy.newTotalWeight.Integer - bbDiscrepancy.totalWeight.Integer;		
				
				onegood.nettWeightEffective:= bbDiscrepancy.newCargoWeight.Integer - bbDiscrepancy.cargoWeight.Integer;
				
				onegood.aDMTEffective:= bbDiscrepancy.newTotalWeight.Integer - bbDiscrepancy.cargoWeightChange.Integer;		
			endif;
		endif;
	endif;
		
	onegood.volumeEffective :=  app.convertMeasurementForDisplay(volumeUOM, ti.totalVolume).asDecimalJMT;
	
	create mill transient;
	if ti.getConsignorObject &lt;&gt; null then
		if translationOperator &lt;&gt; null then
			mill.code:= translationOperator.getXlationSystemCode(ti.getConsignorObject.code, XLATION_TYPE_OPERATOR_BYOP, foundMatch);
			if foundMatch then
				mill.code:=ti.getConsignorObject.code;
			endif;
		else
			mill.code:=ti.getConsignorObject.code;
		endif;
		mill.name:=ti.getConsignorObject.description;
	endif;
	
	onegood.mill := mill;
	
	create buyer transient;
	if ti.getConsigneeObject &lt;&gt; null then		
		if translationOperator &lt;&gt; null then			
			buyer.code := translationOperator.getXlationSystemCode(ti.getConsigneeObject.code, XLATION_TYPE_OPERATOR_BYOP, foundMatch);
			if foundMatch then
				buyer.code := ti.getConsigneeObject.code;
			endif;
		else
			buyer.code := ti.getConsigneeObject.code;
		endif;
		buyer.name:=ti.getConsigneeObject.description;
	endif;
	
	onegood.buyer := buyer;
	
	create forwardingAgent transient;
	forwardingAgent.code := ti.freightForwarderCode;
	if ti.myFreightForwarder &lt;&gt; null then
		forwardingAgent.name:=ti.myFreightForwarder.description;	
	endif;
	
	onegood.forwardingAgent := forwardingAgent;
	
	if not ti.itemised then
		onegood.goodsBarcode:=ti.alternativeId;
	endif;
	
	onegood.certificate:=ti.condition;
	
	onegood.containerNumber := ti.getMyUnpackedFromContainerId;
	
	onegood.loadingPort := ti.loadPort;
	
	onegood.unloadingPort := ti.dischargePort;
	
	onegood.finalDestinationPort := ti.destinationPort;
	
	onegood.destinationPort := ti.destinationPort;
	
	onegood.dangerousGoods := ti.isHazardous;
	
	//is this correct?
	if ti.getHazardFirst &lt;&gt; null then
		onegood.iMOClass := ti.getHazardFirstCode;
	
		onegood.uNCode:= ti.getHazardFirst.getUNDGCode1;
	
	
	
		onegood.packingGroup:=ti.getHazardPackingGroup;
	
		onegood.limitedQuantity:=ti.getHazardFirst.limitedQuantity;
	endif;
	
	onegood.flashpoint:=ti.getHazFlashpoint;
	
	onegood.customerReference:=ti.clientRef;
	
	onegood.stowageMode:=ti.specialStow;
	
	onegood.countryOfOrigin:=ti.getCountryOfOriginCode;
	
	//is this correct?
	onegood.warehouse := ti.terminalAreaId;
	
	// 06/07/2023 navcs2 Bug 59014 Start
	//if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.myTerminalArea &lt;&gt; null and ti.myPrimaryActualLocation.myTerminalArea.isIrregularBlockArea and 
	storageLocPos := ti.locationId.pos(" ",1);
	if storageLocPos &gt; 0 then
		onegood.storageLocation := ti.locationId[storageLocPos + 1 : end];	// 23.08.24	 navhn30	 TFS 64803
	else
		onegood.storageLocation := ti.locationId;
	endif;
	// 06/07/2023 navcs2 Bug 59014 End
	
	onegood.blocked:=ti.hasStops;
	
	//is this correct?
	onegood.blockingReason:=ti.stopsCode;	
	
	if ti.damaged then	//it has damages
		onegood.productCondition := "Damaged";
	endif;
	
	if not ti.damaged then	//it has been repaired
		onegood.productCondition := "Repaired";
	endif;		
	
	onegood.operatorVoyageNumber := ti.carrierRemarks;		//12.11.24	 navhn30	MTN-33409
	
	create onegood.transport transient;
	onegood.transport.transportationMode := app.transModeToString(ti.receiptTransportMode);
	onegood.transport.dischargingPlace :=ti.myTerminal.code;		//17/01/2024	NAVCS2	Bug 61038
	
	create carrierPartyForGood transient;
	
	if ti.receiptTransportMode= TI_TRANSMODE_ROAD then
		//what is truckcarriername?
		//vvr := app.myPassport.myTerminal.allVehicleVisitsByNumDT[ti.getTruckNumber, null];
		vvr := ti.getVehicleVisitReceival;
		if vvr &lt;&gt; null then
			truck := vvr.vehicle;
			if truck &lt;&gt; null and truck.carrier &lt;&gt; null then		// 13.11.24		navhn30		MTN-33408
				carrierPartyForGood.name := truck.carrier.description;
				carrierPartyForGood.code := truck.carrier.code;
			endif;
		endif;
	elseif ti.receiptTransportMode= TI_TRANSMODE_RAIL then
		//carrierPartyForGood.code := ti.getWagonId;												//TFS 64805	
		//what is wagoncarriername?
		wagon := ti.myTerminal.allWagons.getAtKeyGeq(ti.getWagonId, "31,12,3001".Date.TimeStamp); 	//TFS 64805	
		if wagon &lt;&gt; null and wagon.myCarrier &lt;&gt; null then
			carrierPartyForGood.name := wagon.myCarrier.description;								//TFS 64805
			carrierPartyForGood.code := wagon.myCarrier.code;										//TFS 64805
		endif;
	elseif ti.receiptTransportMode= TI_TRANSMODE_SHIP then
		if ti.getShippingLineCode &lt;&gt; null then			// 13.11.24		navhn30		MTN-33408	start
			carrierPartyForGood.code := ti.getShippingLineCode;	
			carrierPartyForGood.name := ti.getShippingLineDesc;
		else
			if ti.myVoyage.myShippingLine &lt;&gt; null then
				carrierPartyForGood.code := ti.myVoyage.myShippingLine.code;
				carrierPartyForGood.name := ti.myVoyage.myShippingLine.description;
			endif;
		endif;											// 13.11.24		navhn30		MTN-33408	 end
	endif;	
	
	onegood.transport.carrierParty := carrierPartyForGood;	
	
	
	//There will be only one item in the good, which is the itemizable TI that we talk about here, for the next one it will be in an entirely new good
	if itemized then
		//create itemsArray transient;
		create item transient;
	
		item.itemId := ti.id;
		item.itemBarcode1 := ti.alternativeId;			// 17/01/2024	NAVCS2	Bug 61038
		item.itemBarcode2 := ti.secondaryBarcodeId; 	// 17/01/2024	NAVCS2	Bug 61038
		
		//item.itemBarcode1 := null; // null for now
		
		// 17/01/2024	NAVCS2	Bug 61038 Start
		if product &lt;&gt; null then
			lengthUOM := product.getDefaultMeasurementForType(Type_Length).shortName;
			widthUOM := product.getDefaultMeasurementForType(Type_Width).shortName;
			thicknessUOM := product.getDefaultMeasurementForType(Type_Height).shortName;
			volumeUOM := product.getDefaultMeasurementForType(Type_Volume).shortName;	
		else
			lengthUOM := app.getDefaultMeasurementForType(Type_Length).shortName;
			widthUOM := app.getDefaultMeasurementForType(Type_Width).shortName;
			thicknessUOM := app.getDefaultMeasurementForType(Type_Height).shortName;
			volumeUOM := app.getDefaultMeasurementForType(Type_Volume).shortName;	
		endif;
		// 17/01/2024	NAVCS2	Bug 61038 End
		
		item.weightUOM := app.getDefaultMeasurementForType(Type_Weight).shortName; // 30/08/2023 navcs2 Bug 60155

		item.volumeUOM:= volumeUOM; // 30/08/2023 navcs2 Bug 60155
		
		item.quantityEffective := ti.totalQuantity;
		
		if not isForRepair then		
			item.grossWeightEffective:= ti.totalWeight.Integer;		
					
			item.nettWeightEffective:= ti.weightCargo.Integer;		
						
			item.aDMTEffective:= ti.totalWeight.Integer;		
		else
			if ti.allDamageInstancesByTS.last.CM_DamageInstance.myRepairDetail &lt;&gt; null then
				bbDiscrepancy := ti.allDamageInstancesByTS.last.CM_DamageInstance.myRepairDetail.myBBTransReference;
				
				if bbDiscrepancy &lt;&gt; null then
					item.grossWeightEffective := bbDiscrepancy.newTotalWeight.Integer + bbDiscrepancy.weightChange.abs.Integer;	
					
					item.nettWeightEffective:= bbDiscrepancy.newCargoWeight.Integer +  bbDiscrepancy.cargoWeightChange.abs.Integer;
					
					item.aDMTEffective:= bbDiscrepancy.newTotalWeight.Integer + bbDiscrepancy.weightChange.abs.Integer;	
				endif;
			endif;
		endif;
		
		item.volumeEffective :=  app.convertMeasurementForDisplay(volumeUOM, ti.totalVolume).asDecimalJMT;
		
		item.width := app.convertMeasurementForDisplay(widthUOM, ti.width).asDecimalJMT; 	
			
		item.length := app.convertMeasurementForDisplay(lengthUOM, ti.length).asDecimalJMT;
			
		item.thickness := app.convertMeasurementForDisplay(thicknessUOM, ti.height).asDecimalJMT;
			
		item.diameter:= app.convertMeasurementForDisplay(lengthUOM, ti.getDiameter).asDecimalJMT;
			
		item.lengthUOM:=  lengthUOM; // 30/08/2023 navcs2 Bug 60155
		
		item.piecesPerPack := ti.quantity;
		
		if ti.damaged then	//it has damages
			item.productCondition := "Damaged";
		endif;
		if not ti.damaged then	//it has been repaired
			item.productCondition := "Repaired";
		endif;		
	
		item.containerNumber := ti.getMyUnpackedFromContainerId;
				
		item.runningLengthUOM := lengthUOM; // 30/08/2023 navcs2 Bug 60155
		
		item.runningLength := app.convertMeasurementForDisplay(lengthUOM,ti.getRollingLength).Integer;	// 11.11.24		navhn30		MTN-33392
		
		item.dedicatedWarehouse := ti.terminalAreaId;	 // 23.08.24	navhn30	TFS #64803
		
		//if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.myTerminalArea &lt;&gt; null and ti.myPrimaryActualLocation.myTerminalArea.isIrregularBlockArea and 
		storageLocPos := ti.locationId.pos(" ",1);	// 23.08.24	 navhn30  TFS 64803
		if storageLocPos &gt; 0 then
			item.storageLocation := ti.locationId[storageLocPos + 1 : end];	
		else
			item.storageLocation := ti.locationId;
		endif;
		
		item.blocked := ti.hasStops;
		
		item.blockingReason := ti.stopCodes;	
		
		create item.transport transient;
		item.transport.transportationMode := app.transModeToString(ti.receiptTransportMode);
		item.transport.dischargingPlace :=ti.subTerminalCode;	
	
		create carrierPartyForItem transient;
		
		// //17/01/2024	NAVCS2	Bug 61038 Start
		if ti.receiptTransportMode= TI_TRANSMODE_ROAD then
			//what is truckcarriername?
			//vvr := app.myPassport.myTerminal.allVehicleVisitsByNumDT[ti.getTruckNumber, null];
			vvr := ti.getVehicleVisitReceival;
			if vvr &lt;&gt; null then
				truck := vvr.vehicle;
			if truck &lt;&gt; null and truck.carrier &lt;&gt; null then		// 13.11.24		navhn30		MTN-33408
				carrierPartyForItem.name := truck.carrier.description;
				carrierPartyForItem.code := truck.carrier.code;
			endif;
			endif;
		elseif ti.receiptTransportMode= TI_TRANSMODE_RAIL then
			//carrierPartyForItem.code := ti.getWagonId;												//TFS 64805	
			//what is wagoncarriername?
			wagon := ti.myTerminal.allWagons.getAtKeyGeq(ti.getWagonId, "31,12,3001".Date.TimeStamp); 	//TFS 64805	
			if wagon &lt;&gt; null and wagon.myCarrier &lt;&gt; null then
				carrierPartyForItem.name := wagon.myCarrier.description;								//TFS 64805
				carrierPartyForItem.code := wagon.myCarrier.code;										//TFS 64805
			endif;
		elseif ti.receiptTransportMode= TI_TRANSMODE_SHIP then	
			if ti.getShippingLineCode &lt;&gt; null then			// 13.11.24		navhn30		MTN-33408	start
				carrierPartyForItem.code := ti.getShippingLineCode;	
				carrierPartyForItem.name := ti.getShippingLineDesc;
			else
				if ti.myVoyage.myShippingLine &lt;&gt; null then
					carrierPartyForItem.code := ti.myVoyage.myShippingLine.code;
					carrierPartyForItem.name := ti.myVoyage.myShippingLine.description;
				endif;
			endif;											// 13.11.24		navhn30		MTN-33408	 end
		endif;
		//17/01/2024	NAVCS2	Bug 61038 End
		
		item.transport.carrierParty := carrierPartyForItem;
		
		foreach damage in damageInstancesofOneGood do
			if item.damages = null then
				create item.damages transient;
			endif;
			
			create damagetemp transient;
			
			damagetemp.date := damage.damageDateTime.localToUTCTime;					// 07.07.2023 navcs2 Bug 59014
			
			damagetemp.type := damage.getDamageCode;
			
			damagetemp.position := damage.getDamagePositionCode;
			
			damagetemp.size := damage.damageSize.String;
			
			if damage.myDamageReason &lt;&gt; null then
				damagetemp.reason := damage.myDamageReason.code;
			endif;
			
			damagetemp.remarks := damage.remarks;
			
			if damage.myDamagePlace &lt;&gt; null then
				damagetemp.place := damage.myDamagePlace.code;
			endif;
			
			if damage.myDamageParty &lt;&gt; null then
				damagetemp.responsibleParty := damage.myDamageParty.code;
			endif;
			
			damagetemp.severity := damage.severity.String;
			
			if damage.status = DamageStatusRefused then
				damagetemp.refused := true;
			else
				damagetemp.refused := false;
			endif;
			
			if isForRepair then																		// 29/03/2023 navcs2 60697
				if damage.myRepairDetail &lt;&gt; null then
					create repairForItem transient;			
					
					repairForItem.date := damage.myRepairDetail.repairedDateTime.localToUTCTime;
					if damage.myRepairDetail.myRepairReason &lt;&gt; null then							//navra1 - TFS56946 - 2 Mar 2023
						repairForItem.reason :=damage.myRepairDetail.myRepairReason.code;
					endif;																			//navra1 - TFS56946 - 2 Mar 2023
					
					repairForItem.remarks := damage.myRepairDetail.remarks;
					
					//30/08/2023 navcs2 Bug 60155 Start
					discrepancyTransaction := damage.myRepairDetail.myBBTransReference;
					
					if discrepancyTransaction &lt;&gt; null then
						repairForItem.newGrossWeight := discrepancyTransaction.newTotalWeight.Integer;
						repairForItem.newNettWeight := discrepancyTransaction.newCargoWeight.Integer;
					
						repairForItem.lostWeight:= discrepancyTransaction.weightChange.Integer;	 // 30/08/2023 navcs2 Bug 60155	
					endif;
					//30/08/2023 navcs2 Bug 60155 end
					
					create damagetemp.repairs transient;
					damagetemp.repairs.add(repairForItem);		
				endif;
			endif;																					// 29/03/2023 navcs2 60697
			
			item.damages.add(damagetemp);			
			
		endforeach;	
		
		//add the item to items array of the good
		create onegood.items transient;
		onegood.items.add(item);	
		
	else
		create onegood.damages transient;
		
		foreach damage in damageInstancesofOneGood do
			create damagetemp transient;
			
			damagetemp.date := damage.damageDateTime.localToUTCTime;					// 07.07.2023 navcs2 Bug 59014
			
			damagetemp.type := damage.getDamageCode;
			
			damagetemp.position := damage.getDamagePositionCode;
			
			damagetemp.size := damage.damageSize.String;
			
			damagetemp.reason := damage.myDamageReason.code;
			
			damagetemp.remarks := damage.remarks;
			
			damagetemp.place := damage.myDamagePlace.code;
			
			damagetemp.responsibleParty := damage.myDamageParty.code;
			
			damagetemp.severity := damage.severity.String;
			
			if damage.status = DamageStatusRefused then
				damagetemp.refused := true;
			else
				damagetemp.refused := false;
			endif;			
			
			if isForRepair then																				// 29/03/2023 navcs2 60697
				create repairForItem transient;			
				create damagetemp.repairs transient;

				repairForItem.date := damage.myRepairDetail.repairedDateTime.localToUTCTime;
					
				if damage.myRepairDetail &lt;&gt; null then
					if damage.myRepairDetail.myRepairReason &lt;&gt; null then									//navra1 - TFS56946 - 2 Mar 2023
						repairForItem.reason :=damage.myRepairDetail.myRepairReason.code;					
					endif;																					//navra1 - TFS56946 - 2 Mar 2023
					
					repairForItem.remarks := damage.myRepairDetail.remarks;
	
					//30/08/2023 navcs2 Bug 60155 Start
					discrepancyTransaction := damage.myRepairDetail.myBBTransReference;
					
					if discrepancyTransaction &lt;&gt; null then
						repairForItem.newGrossWeight := discrepancyTransaction.newTotalWeight.Integer;
						repairForItem.newNettWeight := discrepancyTransaction.newCargoWeight.Integer;
						
						repairForItem.lostWeight:= discrepancyTransaction.weightChange.Integer;	 // 30/08/2023 navcs2 Bug 60155	
					endif;
					//30/08/2023 navcs2 Bug 60155 Start
				endif;
				
				damagetemp.repairs.add(repairForItem);
			endif;																							// 29/03/2023 navcs2 60697

			onegood.damages.add(damagetemp);
			
		endforeach;	
		
	endif;
	
	
	//finally add the good to the goods array
	self.goods.add(onegood);
	
epilog
	
end;</source>
        <Parameter name="damageInstancesofOneGood" type="CM_DamageInstanceByLocDict"/>
        <Parameter name="isDamageTrx" type="Boolean"/>
        <Parameter name="isForRepair" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addOneDamOfOneItem" id="8232be21-8026-45e5-8666-ac0e633c7b95">
        <source>addOneDamOfOneItem(_damagedTi: CM_TrackedItem; _damageInstance : CM_DamageInstance; _isDamageTrx : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 September 2023	navra1	Initial creation for TFS 60208 - EUP | FR 54536 - D&amp;R - File Generation.
08 November 2023	navhn30 Bug 61126: EUP | FR - Damage and Repair - Mill Order Number
19 December 2023	navcs2	Bug 61010: EUP | FR - 53824 Transport Manifest MilOrderNumber / MillOrderLineNumber Mapping Differences to Call Off
17 January 2024		NAVCS2	Bug 61038: EUP | FR 54536 Damage and Repair Non-Itemised - field mapping issues
25 June 2024		navmd1	TFS 61725 Fix Repair Date(time) not being reported in UTC (as the mapper expects UTC/Zulu time)
22 Aug  2024        navsp1	TFS Bug 64805: EUP | FR 54536 - Damage and Repair - Field Corrections
23 Aug  2024 		navhn30 Bug 64803: EUP | FR - 53824 Transport Manifest - Good/Items/Item/StorageLocation Format Incorrect
11 Nov  2024		navhn30 Bug MTN-33392: EUP NTO-443 - Damage/Repair Message sends Rolling Length in CM instead of default measurement type (mm)
12 Nov  2024		navhn30 Bug MTN-33409: EUP | FR 54536 - Operator Voyage Number is mapped incorrectly
13 Nov  2024		navhn30 Bug MTN-33408: EUP | FR 54536 - Shipping Line Code and Shipping Line Name missing from Damage/Repair Message
21 Mar  2025		navhn30 Bug MTN-34397: EUP FR | 54536 - Damage/Repair Message Does Not Use EDI Translations
*/
vars
	onegood : CMIF_JsonGoodEUP;
	goodsOwner : CMIF_JsonGoodsOwnerEUP;
	mill : CMIF_JsonMillEUP;
	buyer : CMIF_JsonBuyerEUP;
	forwardingAgent : CMIF_JsonForwardingAgentEUP;	
	carrierPartyForGood : CMIF_JsonCarrierPartyEUP;	
	damagetemp : CMIF_JsonDamageEUP;
	damage : CM_DamageInstance;
	ti : CM_TrackedItem;	
	item : CMIF_JsonItemEUP;	
	carrierPartyForItem : CMIF_JsonCarrierPartyEUP;	
	repairForItem : CMIF_JsonRepairEUP;	
	itemized : Boolean;
	discrepancyTransaction : CM_BBDiscrepancy;
	translationOperator : CM_Operator;
	foundMatch : Boolean;
	millOrderPos, storageLocPos : Integer;
	lengthUOM,
	widthUOM,
	thicknessUOM,
	volumeUOM	: String;
	product	: CM_Product;
	bbDiscrepancy : CM_BBDiscrepancy;
	truck	: CM_Vehicle;
	wagon	: CM_Wagon;
	vvr : CM_VehicleVisitRecord;
begin
	
	if self.goods = null then
		return;
	endif;
	
	create onegood transient;
	
	ti := _damagedTi;
	
	//determine if the good is itemized or not	
	itemized := true;	
	if ti.myCargoType.isBulkByVolume or ti.myCargoType.isBulkByWeight then
		itemized  := false;
	endif;			
	
	onegood.movementType := ti.getImexStatusStrDesc;
	onegood.bOLNumber := ti.billOfLading;
	onegood.bOLReference := ti.myVoyage.code;
	
	create goodsOwner transient;
	goodsOwner.code := ti.operatorCode;
	goodsOwner.name := ti.operatorDescription;
	
	translationOperator := ti.myTerminal.myRoot.allOperators[ti.operatorCode];
	
	if translationOperator &lt;&gt; null then																									//17/01/2024	NAVCS2	Bug 61038
		onegood.bOLReference := translationOperator.getXlationForeignCode( ti.myVoyage.code, XLATION_TYPE_VOYAGETERMINAL, foundMatch);	//17/01/2024	NAVCS2	Bug 61038
		goodsOwner.code		 := translationOperator.getXlationForeignCode( ti.operatorCode, XLATION_TYPE_OPERATOR_BYOP, foundMatch);	//21/03/2025	navhn30 MTN-34397
	endif;																																//17/01/2024	NAVCS2	Bug 61038
	
	onegood.goodsOwner:=goodsOwner;
	
	onegood.iD := (self.goods.size + 1).String; // 01/09/2023 navcs2 Bug 60159		//TODO: should this be a sequentially increasing number starting from 1 for each CMIF_CamDamageRepairDescEUP, as done now? or should it be changed?
	
	if ti.myCargoGroup &lt;&gt; null then 
		onegood.keyMarks := ti.myCargoGroup.id;
	endif;
	
	onegood.reference := ti.mark;
	
	millOrderPos := ti.orderNumber.pos("|",1);	// 19/12/2023	navcs2	Bug 61010					// 08.11.23		navhn30		#61126
	
	if millOrderPos &gt; 0 then
		onegood.millOrderNumber := ti.orderNumber[1:millOrderPos -1];			// 19/12/2023	navcs2	Bug 61010
		
		onegood.millOrderLineNumber := ti.orderNumber[millOrderPos + 1 : end];	// 19/12/2023	navcs2	Bug 61010
	endif;
	
	onegood.description := ti.description;
	
	onegood.grade := ti.getGrade;
	
	onegood.remarks := ti.remarks;
	
	onegood.colour := ti.getColour;
	
	// 17/01/2024	NAVCS2	Bug 61038 Start
	if product &lt;&gt; null then
		lengthUOM := product.getDefaultMeasurementForType(Type_Length).shortName;
		widthUOM := product.getDefaultMeasurementForType(Type_Width).shortName;
		thicknessUOM := product.getDefaultMeasurementForType(Type_Height).shortName;
	else
		lengthUOM := app.getDefaultMeasurementForType(Type_Length).shortName;
		widthUOM := app.getDefaultMeasurementForType(Type_Width).shortName;
		thicknessUOM := app.getDefaultMeasurementForType(Type_Height).shortName;
	endif;
	// 17/01/2024	NAVCS2	Bug 61038 End
	
	onegood.width := app.convertMeasurementForDisplay(widthUOM, ti.width).asDecimalJMT; 	
			
	onegood.length := app.convertMeasurementForDisplay(lengthUOM, ti.length).asDecimalJMT;
			
	onegood.thickness := app.convertMeasurementForDisplay(thicknessUOM, ti.height).asDecimalJMT;
			
	onegood.diameter:= app.convertMeasurementForDisplay(lengthUOM, ti.getDiameter).asDecimalJMT;
			
	onegood.lengthUOM:=  lengthUOM; // 30/08/2023 navcs2 Bug 60155
	
	onegood.grammage := ti.getGrammage;
	onegood.piecesPerPack := ti.quantity;
	
	onegood.directOperation := ti.directDelivery;
	
	if translationOperator &lt;&gt; null then
		onegood.cargoType := translationOperator.getXlationSystemCode(ti.cargoTypeCode, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);
		if not foundMatch then	
			onegood.cargoType := ti.cargoTypeDescr;
		endif;
	else 
		onegood.cargoType := ti.cargoTypeDescr;
	endif;
	
	onegood.packageType:= ti.getCargoSubTypeDescr;
	onegood.quality := ti.commodity;
	onegood.quantityEffective := ti.totalQuantity;
	
	if _isDamageTrx then		
		onegood.grossWeightEffective:= ti.totalWeight.Integer;		
		
		onegood.nettWeightEffective:= ti.weight.Integer;		
		
		onegood.aDMTEffective:= ti.totalWeight.Integer;		
	else
		bbDiscrepancy := ti.allDamageInstancesByTS.last.CM_DamageInstance.myRepairDetail.myBBTransReference;
		
		if bbDiscrepancy &lt;&gt; null then
			onegood.grossWeightEffective := bbDiscrepancy.newTotalWeight.Integer - bbDiscrepancy.totalWeight.Integer;		
			
			onegood.nettWeightEffective:= bbDiscrepancy.newCargoWeight.Integer;
			
			onegood.aDMTEffective:= bbDiscrepancy.newTotalWeight.Integer - bbDiscrepancy.cargoWeightChange.Integer;		
		endif;
	endif;

	onegood.volumeEffective:=ti.totalVolume;
	
	create mill transient;
	if ti.getConsignorObject &lt;&gt; null then
		if translationOperator &lt;&gt; null then
			mill.code:= translationOperator.getXlationSystemCode(ti.getConsignorObject.code, XLATION_TYPE_OPERATOR_BYOP, foundMatch);
			if foundMatch then
				mill.code:=ti.getConsignorObject.code;
			endif;
		else
			mill.code:=ti.getConsignorObject.code;
		endif;
		mill.name:=ti.getConsignorObject.description;
	endif;
	
	onegood.mill := mill;
	
	create buyer transient;
	if ti.getConsigneeObject &lt;&gt; null then		
		if translationOperator &lt;&gt; null then			
			buyer.code := translationOperator.getXlationSystemCode(ti.getConsigneeObject.code, XLATION_TYPE_OPERATOR_BYOP, foundMatch);
			if foundMatch then
				buyer.code := ti.getConsigneeObject.code;
			endif;
		else
			buyer.code := ti.getConsigneeObject.code;
		endif;
		buyer.name:=ti.getConsigneeObject.description;
	endif;
	
	onegood.buyer := buyer;
	
	create forwardingAgent transient;
	forwardingAgent.code := ti.freightForwarderCode;
	if ti.myFreightForwarder &lt;&gt; null then
		forwardingAgent.name:=ti.myFreightForwarder.description;	
	endif;
	
	onegood.forwardingAgent := forwardingAgent;
	
	if not ti.itemised then
		onegood.goodsBarcode:=ti.alternativeId;
	endif;
	
	onegood.certificate:=ti.condition;
	
	onegood.containerNumber := ti.getMyUnpackedFromContainerId;
	
	onegood.loadingPort := ti.loadPort;
	
	onegood.unloadingPort := ti.dischargePort;
	
	onegood.finalDestinationPort := ti.destinationPort;
	
	onegood.destinationPort := ti.destinationPort;
	
	onegood.dangerousGoods := ti.isHazardous;
	
	if ti.getHazardFirst &lt;&gt; null then
		onegood.iMOClass := ti.getHazardFirstCode;
	
		onegood.uNCode:= ti.getHazardFirst.getUNDGCode1;	
	
		onegood.packingGroup:=ti.getHazardPackingGroup;
	
		onegood.limitedQuantity:=ti.getHazardFirst.limitedQuantity;
	endif;
	
	onegood.flashpoint:=ti.getHazFlashpoint;
	
	onegood.customerReference:=ti.clientRef;
	
	onegood.stowageMode:=ti.specialStow;
	
	onegood.countryOfOrigin:=ti.getCountryOfOriginCode;
	
	onegood.warehouse := ti.terminalAreaId;
	
	// 06/07/2023 navcs2 Bug 59014 Start
	//if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.myTerminalArea &lt;&gt; null and ti.myPrimaryActualLocation.myTerminalArea.isIrregularBlockArea and 
	storageLocPos := ti.locationId.pos(" ",1);	//23.08.24	 navhn30 	TFS 64803
	if storageLocPos &gt; 0 then
		onegood.storageLocation := ti.locationId[storageLocPos + 1 : end];
	else
		onegood.storageLocation := ti.locationId;
	endif;
	// 06/07/2023 navcs2 Bug 59014 End
	
	onegood.blocked:=ti.hasStops;
	
	onegood.blockingReason:=ti.stopsCode;	
	
	if ti.damaged then	//it has damages
		onegood.productCondition := "Damaged";
	endif;
	
	if not ti.damaged then	//it has been repaired
		onegood.productCondition := "Repaired";
	endif;	
	
	onegood.operatorVoyageNumber := ti.carrierRemarks;		//12.11.24	 navhn30	MTN-33409
	
	create onegood.transport transient;
	onegood.transport.transportationMode := app.transModeToString(ti.receiptTransportMode);
	onegood.transport.dischargingPlace :=ti.myTerminal.code;		//17/01/2024	NAVCS2	Bug 61038		
	
	create carrierPartyForGood transient;
	
	if ti.receiptTransportMode= TI_TRANSMODE_ROAD then
		//what is truckcarriername?
		//vvr := ti.myTerminal.allVehicleVisitsByNumDT[ti.getTruckNumber, null];
		vvr := ti.getVehicleVisitReceival;
		if vvr &lt;&gt; null then
			truck := vvr.vehicle;
			if truck &lt;&gt; null and truck.carrier &lt;&gt; null then		// 13.11.24		navhn30		MTN-33408
				carrierPartyForGood.name := truck.carrier.description;
				carrierPartyForGood.code := truck.carrier.code;
			endif;
		endif;
	elseif ti.receiptTransportMode= TI_TRANSMODE_RAIL then
		//carrierPartyForGood.code := ti.getWagonId;												//TFS 64805
		//what is wagoncarriername?
		wagon := ti.myTerminal.allWagons.getAtKeyGeq(ti.getWagonId, "31,12,3001".Date.TimeStamp); 	//TFS 64805	
		if wagon &lt;&gt; null and wagon.myCarrier &lt;&gt; null then
			carrierPartyForGood.name := wagon.myCarrier.description;								//TFS 64805
			carrierPartyForGood.code := wagon.myCarrier.code;										//TFS 64805
		endif;
	elseif ti.receiptTransportMode= TI_TRANSMODE_SHIP then	
		if ti.getShippingLineCode &lt;&gt; null then			// 13.11.24		navhn30		MTN-33408	start
			carrierPartyForGood.code := ti.getShippingLineCode;	
			carrierPartyForGood.name := ti.getShippingLineDesc;
		else
			if ti.myVoyage.myShippingLine &lt;&gt; null then
				carrierPartyForGood.code := ti.myVoyage.myShippingLine.code;
				carrierPartyForGood.name := ti.myVoyage.myShippingLine.description;
			endif;
		endif;											// 13.11.24		navhn30		MTN-33408	 end
	endif;			
	
	onegood.transport.carrierParty := carrierPartyForGood;	
	
	if itemized then		
		create item transient;
	
		item.itemId := ti.id;
		
		item.itemBarcode1 := ti.alternativeId;			// 17/01/2024	NAVCS2	Bug 61038 Start
		
		item.itemBarcode2 := ti.secondaryBarcodeId;		// 17/01/2024	NAVCS2	Bug 61038 Start
		
		//item.itemBarcode1 := null; // null for now
		
		// 17/01/2024	NAVCS2	Bug 61038 Start
		if product &lt;&gt; null then
			lengthUOM := product.getDefaultMeasurementForType(Type_Length).shortName;
			widthUOM := product.getDefaultMeasurementForType(Type_Width).shortName;
			thicknessUOM := product.getDefaultMeasurementForType(Type_Height).shortName;
			volumeUOM := product.getDefaultMeasurementForType(Type_Volume).shortName;	
		else
			lengthUOM := app.getDefaultMeasurementForType(Type_Length).shortName;
			widthUOM := app.getDefaultMeasurementForType(Type_Width).shortName;
			thicknessUOM := app.getDefaultMeasurementForType(Type_Height).shortName;
			volumeUOM := app.getDefaultMeasurementForType(Type_Volume).shortName;	
		endif;
		// 17/01/2024	NAVCS2	Bug 61038 End
		
		item.weightUOM := app.getDefaultMeasurementForType(Type_Weight).shortName; // 30/08/2023 navcs2 Bug 60155

		item.volumeUOM:= volumeUOM; // 30/08/2023 navcs2 Bug 60155
		
		item.quantityEffective := ti.totalQuantity;
		
		
		if _isDamageTrx then		
			item.grossWeightEffective:= ti.totalWeight.Integer;		
		
			item.nettWeightEffective:= ti.weight.Integer;		
		
			item.aDMTEffective:= ti.totalWeight.Integer;		
		else
			bbDiscrepancy := ti.allDamageInstancesByTS.last.CM_DamageInstance.myRepairDetail.myBBTransReference;
		
			if bbDiscrepancy &lt;&gt; null then
				item.grossWeightEffective := bbDiscrepancy.newTotalWeight.Integer - bbDiscrepancy.totalWeight.Integer;		
				
				item.nettWeightEffective:= bbDiscrepancy.newCargoWeight.Integer;
				
				item.aDMTEffective:= bbDiscrepancy.newTotalWeight.Integer - bbDiscrepancy.cargoWeightChange.Integer;		
			endif;
		endif;
		
		item.volumeEffective := ti.totalVolume;
	
		item.width := app.convertMeasurementForDisplay(widthUOM, ti.width).asDecimalJMT; 	
			
		item.length := app.convertMeasurementForDisplay(lengthUOM, ti.length).asDecimalJMT;
			
		item.thickness := app.convertMeasurementForDisplay(thicknessUOM, ti.height).asDecimalJMT;
			
		item.diameter:= app.convertMeasurementForDisplay(lengthUOM, ti.getDiameter).asDecimalJMT;
			
		item.lengthUOM:=  lengthUOM; // 30/08/2023 navcs2 Bug 60155
		
		item.piecesPerPack := ti.quantity;
		
		
		if ti.damaged then	//it has damages
			item.productCondition := "Damaged";
		endif;
		if not ti.damaged then	//it has been repaired
			item.productCondition := "Repaired";
		endif;		
	
		item.containerNumber := ti.getMyUnpackedFromContainerId;
				
		item.runningLengthUOM := lengthUOM; // 30/08/2023 navcs2 Bug 60155
		
		item.runningLength := app.convertMeasurementForDisplay(lengthUOM,ti.getRollingLength).Integer;	// 11.11.24		navhn30		MTN-33392
		
		item.dedicatedWarehouse := ti.terminalAreaId;	 // 23.08.24	navhn30	TFS #64803
		
		//if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.myTerminalArea &lt;&gt; null and ti.myPrimaryActualLocation.myTerminalArea.isIrregularBlockArea and 
		storageLocPos := ti.locationId.pos(" ",1);	//23.08.24	navhn30	TFS 64803
		if storageLocPos &gt; 0 then
			item.storageLocation := ti.locationId[storageLocPos + 1 : end];
		else
			item.storageLocation := ti.locationId;
		endif;
		
		item.blocked := ti.hasStops;
		
		item.blockingReason := ti.stopCodes;	
		
		create item.transport transient;
		item.transport.transportationMode := app.transModeToString(ti.receiptTransportMode);
		item.transport.dischargingPlace :=ti.subTerminalCode;	
	
		create carrierPartyForItem transient;
		
		//17/01/2024	NAVCS2	Bug 61038 start
		if ti.receiptTransportMode= TI_TRANSMODE_ROAD then
			//what is truckcarriername?
			//vvr := ti.myTerminal.allVehicleVisitsByNumDT[ti.getTruckNumber, null];
			vvr := ti.getVehicleVisitReceival;
			if vvr &lt;&gt; null then
				truck := vvr.vehicle;
				if truck &lt;&gt; null and truck.carrier &lt;&gt; null then		// 13.11.24		navhn30		MTN-33408
					carrierPartyForItem.name := truck.carrier.description;
					carrierPartyForItem.code := truck.carrier.code;
				endif;
			endif;
		elseif ti.receiptTransportMode= TI_TRANSMODE_RAIL then
			//carrierPartyForItem.code := ti.getWagonId;												//TFS 64805		
			//what is wagoncarriername?
			wagon := ti.myTerminal.allWagons.getAtKeyGeq(ti.getWagonId, "31,12,3001".Date.TimeStamp); 	//TFS 64805	
			if wagon &lt;&gt; null and wagon.myCarrier &lt;&gt; null then
				carrierPartyForItem.name := wagon.myCarrier.description;								//TFS 64805
				carrierPartyForItem.code := wagon.myCarrier.code;										//TFS 64805
			endif;
		elseif ti.receiptTransportMode= TI_TRANSMODE_SHIP then	
			if ti.getShippingLineCode &lt;&gt; null then			// 13.11.24		navhn30		MTN-33408	start
				carrierPartyForItem.code := ti.getShippingLineCode;	
				carrierPartyForItem.name := ti.getShippingLineDesc;
			else
				if ti.myVoyage.myShippingLine &lt;&gt; null then
					carrierPartyForItem.code := ti.myVoyage.myShippingLine.code;
					carrierPartyForItem.name := ti.myVoyage.myShippingLine.description;
				endif;
			endif;											// 13.11.24		navhn30		MTN-33408	 end
		endif;			
		//17/01/2024	NAVCS2	Bug 61038 End
		
		item.transport.carrierParty := carrierPartyForItem;
		
		//we want to only for that one damageInstance that was passed in
		//foreach damage in damageInstancesofOneGood do
		
			damage := _damageInstance;
		
			if item.damages = null then
				create item.damages transient;
			endif;
			
			create damagetemp transient;
			
			damagetemp.date := damage.damageDateTime.localToUTCTime;					// 07.07.2023 navcs2 Bug 59014
			
			damagetemp.type := damage.getDamageCode;
			
			damagetemp.position := damage.getDamagePositionCode;
			
			damagetemp.size := damage.damageSize.String;
			
			if damage.myDamageReason &lt;&gt; null then
				damagetemp.reason := damage.myDamageReason.code;
			endif;
			
			damagetemp.remarks := damage.remarks;
			
			if damage.myDamagePlace &lt;&gt; null then
				damagetemp.place := damage.myDamagePlace.code;
			endif;
			
			if damage.myDamageParty &lt;&gt; null then
				damagetemp.responsibleParty := damage.myDamageParty.code;
			endif;
			
			damagetemp.severity := damage.severity.String;
			
			if damage.status = DamageStatusRefused then
				damagetemp.refused := true;
			else
				damagetemp.refused := false;
			endif;
			
			
			if damage.myRepairDetail &lt;&gt; null then
				create repairForItem transient;			
				
				
				repairForItem.date := damage.myRepairDetail.repairedDateTime.localToUTCTime;
				if damage.myRepairDetail.myRepairReason &lt;&gt; null then							//navra1 - TFS56946 - 2 Mar 2023
					repairForItem.reason :=damage.myRepairDetail.myRepairReason.code;
				endif;																			//navra1 - TFS56946 - 2 Mar 2023
			
				repairForItem.remarks := damage.myRepairDetail.remarks;
					
				//30/08/2023 navcs2 Bug 60155 Start
				discrepancyTransaction := damage.myRepairDetail.myBBTransReference;
				
				if discrepancyTransaction &lt;&gt; null then
					repairForItem.newGrossWeight := discrepancyTransaction.newTotalWeight.Integer;
					repairForItem.newNettWeight := discrepancyTransaction.newCargoWeight.Integer;
				
					repairForItem.lostWeight:= discrepancyTransaction.weightChange.Integer;	 // 30/08/2023 navcs2 Bug 60155	
				endif;
				//30/08/2023 navcs2 Bug 60155 end
				
				create damagetemp.repairs transient;
				damagetemp.repairs.add(repairForItem);		
			endif;
			
			item.damages.add(damagetemp);			
			
		//endforeach;	//we only talk about one damage here which is the _damageInstance that is passed in
		
		//add the item to items array of the good
		create onegood.items transient;
		onegood.items.add(item);	
		
	else
		create onegood.damages transient;
		
		//we want to only for that one damageInstance that was passed in
		//foreach damage in damageInstancesofOneGood do
		
			damage := _damageInstance;
			
			create damagetemp transient;
			
			damagetemp.date := damage.damageDateTime.localToUTCTime;					// 07.07.2023 navcs2 Bug 59014
			
			damagetemp.type := damage.getDamageCode;
			
			damagetemp.position := damage.getDamagePositionCode;
			
			damagetemp.size := damage.damageSize.String;
			
			damagetemp.reason := damage.myDamageReason.code;
			
			damagetemp.remarks := damage.remarks;
			
			damagetemp.place := damage.myDamagePlace.code;
			
			damagetemp.responsibleParty := damage.myDamageParty.code;
			
			damagetemp.severity := damage.severity.String;
			
			if damage.status = DamageStatusRefused then
				damagetemp.refused := true;
			else
				damagetemp.refused := false;
			endif;			
			
			create repairForItem transient;			
			create damagetemp.repairs transient;
			
			repairForItem.date := damage.myRepairDetail.repairedDateTime.localToUTCTime;
			
			if damage.myRepairDetail &lt;&gt; null then
				if damage.myRepairDetail.myRepairReason &lt;&gt; null then									//navra1 - TFS56946 - 2 Mar 2023
					repairForItem.reason :=damage.myRepairDetail.myRepairReason.code;					
				endif;																					//navra1 - TFS56946 - 2 Mar 2023
	
				repairForItem.remarks := damage.myRepairDetail.remarks;

				//30/08/2023 navcs2 Bug 60155 Start
				discrepancyTransaction := damage.myRepairDetail.myBBTransReference;
				
				if discrepancyTransaction &lt;&gt; null then
					repairForItem.newGrossWeight := discrepancyTransaction.newTotalWeight.Integer;
					repairForItem.newNettWeight := discrepancyTransaction.newCargoWeight.Integer;
				
					repairForItem.lostWeight:= discrepancyTransaction.weightChange.Integer;	 // 30/08/2023 navcs2 Bug 60155	
				endif;
				//30/08/2023 navcs2 Bug 60155 Start
			endif;
			
			damagetemp.repairs.add(repairForItem);
			
			onegood.damages.add(damagetemp);
			
		//endforeach;	//we only talk about one damage here which is the _damageInstance that is passed in
		
	endif;
	
	
	//finally add the good to the goods array
	self.goods.add(onegood);
	
epilog

end;</source>
        <Parameter name="_damagedTi" type="CM_TrackedItem"/>
        <Parameter name="_damageInstance" type="CM_DamageInstance"/>
        <Parameter name="_isDamageTrx" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildHeader" id="ff2828f6-dd33-4d2c-8744-cf04ac202319">
        <updating/>
        <source>buildHeader(damageInstance : CM_DamageInstance input; _camProtocol : CM_CamProtocol) updating;
/*

Purpose:			

Parameters:			

	This method is used to populate the self's(CMIF_CamDamageRepairDescEUP) header portion from the passed in CM_DamageInstance

Return Value:		

Date			Who		Reason
13 January 2023	navra1	Initial creation for TFS - 55859
28 March   2023 navra1	57338 - EUP | Damage and Repair Message - Temp Sender Code
26 April   2023	navmd1	TFS 57678 Fix number and ID not being unique
19 June	   2023	navmd1	TFS 58711 EUP Change Header/Receiver to be Financial Id (CM_Debtor::code)
07.07.2023		navcs2	Bug 59014: FR | 54536 EUP - Damage and Repair Missing or Incorrect Fields in Message
22 Aug     2024 navsp1  TFS Bug 64805: EUP | FR 54536 - Damage and Repair - Field Corrections
*/

vars
	now : TimeStamp;
	op : CM_Operator;
	guid : String;
begin

	if damageInstance = null then	
		return;
	endif;
	
	if self.header = null then
		create self.header transient;
	endif;
	
	if damageInstance.myTrackedItem &lt;&gt; null then
		self.header.sender := damageInstance.myTrackedItem.myTerminal.code;
		op := damageInstance.myTrackedItem.myOperator;
		if op &lt;&gt; null and op.debtor &lt;&gt; null then
			//self.header.receiver := op.debtor.externalReference;										//navra1 - TFS 57338 - 28th Mar 2023
			self.header.receiver := op.debtor.code;		// navmd1 TFS 58711 19/06/2023
		endif;
	endif;
	
	self.header.date := app.actualTimeAppServer.localToUTCTime;											// 07.07.2023 navcs2 Bug 59014
	self.header.status := CMIF_JsonHeaderEUP.Status_Create;
	self.header.type := _camProtocol.code;	// Name
	guid := self.generateGUID();
	self.header.number := guid;		//TFS 64805 - uncommented
	self.header.id := guid;
	
epilog

end;</source>
        <Parameter name="damageInstance" type="CM_DamageInstance" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d83f82a9-94cb-4747-9738-78d1fe32c0d0">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

	This method is used to clean up the self(CMIF_CamDamageRepairDescEUP) of all the obejcts it holds. This should be used to ensure that the self(CMIF_CamDamageRepairDescEUP) is emptied properly.
	After calling this method, the self also should be deleted seperately, it is not done as a part of this method to make it clean
	
Parameters:			

Return Value:		

Date		Who		Reason
08 February 2023	navra1	Initial creation for TFS - 55859

*/

vars
	good : CMIF_JsonGoodEUP;
	damage : CMIF_JsonDamageEUP;
	item : CMIF_JsonItemEUP;
begin
	if self.goods &lt;&gt; null and self.goods.size&gt;0 then
		foreach good in self.goods do			
				if good.mill &lt;&gt; null then
					delete good.mill;
				endif;
				
				if good.buyer &lt;&gt; null then
					delete good.buyer;
				endif;
				if good.forwardingAgent &lt;&gt; null then
					delete good.forwardingAgent;
				endif;
				
				if good.goodsOwner &lt;&gt; null then
					delete good.goodsOwner;
				endif;
				
				
				if good.transport &lt;&gt; null then
					if good.transport.carrierParty &lt;&gt; null then
						delete good.transport.carrierParty;
					endif;				
				
					delete good.transport;
				endif;
				
				if good.damages &lt;&gt; null and good.damages.size &gt;0  then
					foreach damage in good.damages do
						
						if damage.repairs &lt;&gt; null and damage.repairs.size &gt;0 then
							damage.repairs.purge;
							delete damage.repairs;
						endif;
					endforeach;			
					good.damages.purge;
					delete good.damages;
				endif;
				
				if good.items &lt;&gt; null and good.items.size &gt;0 then
					
					foreach item in good.items do
						if item.transport &lt;&gt; null then
							if item.transport.carrierParty &lt;&gt; null then
								delete item.transport.carrierParty;
							endif;
						
							delete item.transport;			
						endif;
					
						if item.damages &lt;&gt; null and item.damages.size &gt;0 then
							foreach damage in item.damages do
								if damage.repairs &lt;&gt; null and damage.repairs.size &gt; 0 then
									damage.repairs.purge;
									delete damage.repairs;							
								endif;
								
							endforeach;
							item.damages.purge;
							delete item.damages;
						endif;
					endforeach;
					
					good.items.purge;
					delete good.items;
				endif;
			endforeach;
	endif;
	
	if self.goods &lt;&gt; null and self.goods.size &gt; 0 then
		self.goods.purge();
	endif;
	
	if self.header &lt;&gt; null then 
		delete self.header;
	endif;
	
epilog
	if app.isValidObject(good) then
		delete good;
	endif;
	if app.isValidObject(damage) then
		delete damage;
	endif;
	if app.isValidObject(item) then
		delete item;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="generateGUID" id="723c85c9-b5e0-4d19-939a-617811e4ce8e">
        <source>generateGUID(): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 April 2023	navmd1	Initial creation TFS 57678 Fix number and ID not being unique

*/

vars

begin
	return app.generateUuid(VariantMicrosoft).uuidAsString();
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJsonOfDamageAndRepairObj" id="b67bcbb3-d962-488b-9ddd-fd3a7bd010a2">
        <source>getJsonOfDamageAndRepairObj() : String;
/*

Purpose:			

Parameters:			

	This method converts the self(CMIF_CamDamageRepairDescEUP) object into a json string

Return Value:		

	A json string of self(CMIF_CamDamageRepairDescEUP). 

Date				Who			Reason
13 January 2023		navra1		Initial creation for TFS - 55859
21 February 2023 	navra1		Changed to create the json so that the header is on top and is followed by the Goods tag
21 March 2023		navmd1		TFS 57092 Refactor to let dll take care of any formatting

*/

vars

	jsonHelper : JadeJson;	
	fullJsonString : String;
	
begin
	create jsonHelper transient;	
	
	// Any exceptions generated by this will bubble up to the top CAMS handlers
	return jsonHelper.generateJson(self, JadeJson.Format_Json_Microsoft);	// Let the transform dll take care of the Microsoft Date formats. JADE2022 can generate them natively, but not 2020 :(
	
epilog
	delete jsonHelper;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
