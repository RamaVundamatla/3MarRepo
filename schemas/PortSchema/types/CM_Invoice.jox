    <JadeMethod name="isMatch" id="b96ad04a-938b-4421-b4a9-3c93736dfadd">
        <source>isMatch(param: CMIF_InvoiceSelection): Boolean;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------
// 16/09/2015	cnwdap1		PAR #36909 CCMS ADP 2357 Bill of Lading matching
begin
	
	// ### Bank and Terminal and other high level data should be checked first because the code is looking at all invoices for a debtor, so could be invoices across many terminals and banks etc.
	
	 // PAR 17895
	if param.myBank &lt;&gt; null
	and param.myBank &lt;&gt; self.bank then
		return false;
	endif;

	// PAR 17895
	if param.myTerminal &lt;&gt; null
	and param.myTerminal &lt;&gt; self.bank.terminal then
		return false;
	endif;
	
	if param.companyCode &lt;&gt; null and 
		param.companyCode.trimRight &lt;&gt; bank.code.trimRight then
		return false;
	endif;

	if param.status &lt;&gt; INVOICE_ALL_STATUS and 
		param.status &lt;&gt; status then
		return false;
	endif;

	if param.debtor &lt;&gt; null and 
		param.debtor &lt;&gt; debtor then
		return false;
	endif;

	if param.invoiceTypeNumber &lt;&gt; null 
	and invoiceType&lt;&gt; null // ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1
	and param.invoiceTypeNumber &lt;&gt; invoiceType.number then
		return false;
	endif;

	// ### TFS 54565 (54384) 22Sep2022 NAVPW1
	if param.hasinvDebtorSeparation() then
		 return param.checkInvDebtorSeparation(self);
	endif;
	// ### TFS 54565 (54384) 22Sep2022 NAVPW1

	if param.checkManual = true and
		param.isManual &lt;&gt; isManual then
		return false;
	endif;

		
	// ### TFS 51219 25MAY2021 NAVAB1
	if param.voyageGroupCode &lt;&gt; null 
	and param.invoiceKey = CM_InvoiceDesc.Key_VoyageGroup
	and	param.voyageGroupCode.trimRight &lt;&gt; self.voyageGroupCode.trimRight then
		return false;
	endif;

	if param.voyageCode &lt;&gt; null 
	and param.invoiceKey &lt;&gt; CM_InvoiceDesc.Key_VoyageGroup // ### TFS 51219 28MAY2021 NAVAB1
	and	param.voyageCode.trimRight &lt;&gt; self.voyageCode.trimRight then
		return false;
	endif;	

	// PAR 17895
	if param.trackedItemId &lt;&gt; null then
		if self.myTrackedItem &lt;&gt; null then
			if param.trackedItemId.trimRight &lt;&gt; self.myTrackedItem.id then
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	if param.bolNumber &lt;&gt; null then													// PAR #36909
		if self.myTrackedItem &lt;&gt; null then											// PAR #36909
			if param.bolNumber.trimRight &lt;&gt; self.myTrackedItem.billOfLading then	// PAR #36909
				return false;														// PAR #36909
			endif;																	// PAR #36909
		else                                                       //30 May  2025 navrv30 MTN 34789
			if self.myBOL &lt;&gt; null then
				if param.bolNumber.trimRight &lt;&gt; self.myBOL.number then
					return false;
				endif;
			endif;
		endif;
	endif;
	
	//09 Oct 2018	NDL	TFS 41281
	if param.paymentType &lt;&gt; self.paymentType then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="param" type="CMIF_InvoiceSelection"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isNSWFinancialSystem" id="930cf413-43c6-44a3-8334-f8c145bc0d14">
        <source>isNSWFinancialSystem() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2025	jlier1	Initial creation  MTN-34357

*/

vars
	terminal : CM_Terminal;
	finIOClass : CM_ExtFinanceIO;
begin	

	terminal:= self.getMyTerminal;
	
	if terminal = null then
		return false;
	endif;
	
	finIOClass := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		
	if finIOClass &lt;&gt; null then
		return finIOClass.isNSW();
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
