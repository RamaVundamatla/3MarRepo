    <JadeMethod name="createTopLevelObject" id="767276e6-cc76-4a41-ae8a-d8764628c5c6">
        <source>createTopLevelObject(_class : Class) : SOP_ViewModelObject protected;

// cnwdvb1 29 October 2002 

vars

	obj	: SOP_ViewModelObject;
	
begin

	create obj as _class transient;
	obj.loadTreeViewArray(self.allVMObjects, 1, self, null);
	obj.createEmptyPeer(null);
	return obj;

end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="SOP_ViewModelObject"/>
    </JadeMethod>
