<Class name="CM_RemoteReticketDtl" id="185ef74f-0325-45ee-9ba1-68702f205830">
    <superclass name="CM_RemoteDataDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <Constant name="RejectItemsArray" id="e52921c8-85ae-42b7-9b51-816539e584fb">
        <source>'Items to Reticket'</source>
        <type name="String"/>
    </Constant>
    <CompAttribute name="allNewAndOld" id="9fb130b5-aad4-4fe6-90cd-1a1033295d02">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="tagAttribute" id="d0cb6220-904d-4870-9ceb-8408c9ed3dc6">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doReticket" id="f6494ecb-8472-4bc3-850a-0208ceff5cc6">
        <source>doReticket(_errorSet : CM_ErrorSet input; _set : CMIF_TIReticketSet io; _terminal : CM_Terminal);

vars

	tiType		: Integer;
	str,new,
	old			: String;
	reticket	: CMIF_TIReticket;
	pos			: Integer;
	taType		: Integer;
	
begin

	self.getLogConstant(self.tagAttribute, tiType, taType);
	if tiType = 0 then
		app.raiseCMException1(Err_InvalidClass, self.tagAttribute, null, null);
	endif;
	
	foreach str in self.allNewAndOld do
		pos 	:= 1;
		old		:= str.scanUntil(',', pos);
		new		:= str[pos + 1: end];
		create reticket transient;
		reticket.oldId := old;
		reticket.newId := new;
		_set.add(reticket);
	endforeach;
		
end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_set" type="CMIF_TIReticketSet" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="3f877554-50bf-4901-bbcd-4e374af87066">
        <source>getDescription(): String;

vars

begin
	return 'Reticking detail';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfItems" id="83a29232-2c90-4607-9ce9-294251b768ce">
        <source>getNumberOfItems(): String;
// -------------------------------------------
// Created 05 July 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	return self.allNewAndOld.size.String;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveFromArray" id="10a129b1-7471-48fa-882f-dfe1e354e7a8">
        <updating/>
        <source>saveFromArray(_array: StringArray) updating;

// cnwdvb1 20 November 2002 
vars

	ti		: Integer;
	string	: String;

begin

	if _array.size &gt; 0 then
		if _array[1] = RejectItemsArray then
			self.allNewAndOld.clear;
			foreach ti in 2 to _array.size do
				if _array[ti] &lt;&gt; null then
					self.allNewAndOld.add(_array[ti]);
				endif;
			endforeach;
		endif;
	endif;

end;</source>
        <Parameter name="_array" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="5c12a839-51ff-4968-9e08-39358769c6b4">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns : Integer) updating;


begin

	inheritMethod(_table, _entryTableColumns);

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b323ac94-29ac-4631-a96e-3885ca366104">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteReticketDtl; _realRemoteHdr: CM_RemoteDataHdr) updating;


begin

	inheritMethod(_proxy, _realRemoteHdr);
	_proxy.allNewAndOld.copy(self.allNewAndOld);
	self.tagAttribute	:= _proxy.tagAttribute;

end;</source>
        <Parameter name="_proxy" type="CM_RemoteReticketDtl"/>
        <Parameter name="_realRemoteHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForReticket" id="48fb3622-6441-4f89-b9a8-ec55c4a9a1ed">
        <updating/>
        <source>setProxyForReticket(_remoteHdr : CM_RemoteDataHdr; _array : StringArray; _tagAttribute : String) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	_array.copy(self.allNewAndOld);
	self.tagAttribute	:= _tagAttribute;
	self.setProxy(_remoteHdr);


end;</source>
        <Parameter name="_remoteHdr" type="CM_RemoteDataHdr"/>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_tagAttribute" type="String"/>
    </JadeMethod>
</Class>
