<Class name="CM_XlCriteria_Commodity" id="45f87fff-379d-47ab-9bd7-1505294cddd0">
    <superclass name="CM_XlationCriteria"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="temperatureFrom" id="507817e8-c74c-42b7-aa5e-c5beca6c4e56">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="temperatureTo" id="6eec6d5c-b21c-480b-8cc2-11834b7cca3b">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="552ae59e-b81a-412b-843f-8d244d707a48">
        <updating/>
        <source>create() updating;
/*
Date		Who		Reason
27 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	self.temperatureFrom	:= NULL_TEMPERATURE;
	self.temperatureTo		:= NULL_TEMPERATURE;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCriteriaDisplay" id="f4bf2742-8dea-4d29-ab98-bc57eca1ed8c">
        <source>getCriteriaDisplay(_short :Boolean):String;
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	tempFrom, tempTo	:Real;
	operator			:CM_Operator;
	displayF			:Boolean;
begin
	tempFrom 	:= self.temperatureFrom;
	tempTo		:= self.temperatureTo;
	operator	:= self.getMyOperator;
	
	if operator &lt;&gt; null then
		displayF 	:= operator.displayTempFahrenheit;
		
		if displayF then
			tempFrom 	:= app.temperatureConversion(true, tempFrom);
			tempTo		:= app.temperatureConversion(true, tempTo);
		endif;
	endif;	
	
	if _short then
		if displayF then
			return app.getErrorString2 (Xlation_Temp_RangeF, tempFrom.asStringJMT, tempTo.asStringJMT);
		else
			return app.getErrorString2 (Xlation_Temp_Range, tempFrom.asStringJMT, tempTo.asStringJMT);
		endif;
	else
		if displayF then
			return app.getErrorString3 (Xlation_Criteria_TempF, self.myXlation.foreignCode, tempFrom.asStringJMT, tempTo.asStringJMT);
		else
			return app.getErrorString3 (Xlation_Criteria_Temp, self.myXlation.foreignCode, tempFrom.asStringJMT, tempTo.asStringJMT);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCriteriaMatch" id="aa331073-ce31-4dca-8376-f244eae91637">
        <source>isCriteriaMatch(_score :Integer output; _params: ParamListType): Boolean;
/*
Date		Who		Reason
02 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	count	:Integer;
	temp	:Real;
	param	:Any;
begin
	count := app.getParamListTypeLength (_params);
	
	temp := NULL_TEMPERATURE;

	if count = 1 then
		param := app.getParamListTypeEntry (1, _params);
		
		if param.isKindOf(Real) then
			temp := param.Real;
		else
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called with incorrect parameter type');
		endif;
	else
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called with incorrect number of parameters');
	endif;
	
	// we expect a temperature - no criteria will match a null temperature
	if temp &gt;= self.temperatureFrom and temp &lt;= self.temperatureTo then
		_score := 1;
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_score" type="Integer" usage="output"/>
        <Parameter name="_params" type="ParamListType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSameAs" id="ace1b2ad-a19c-48fa-b7ec-cdbbe5813c55">
        <source>isSameAs(_criteria: CM_XlCriteria_Commodity): Boolean;
/*
Date		Who		Reason
03 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	return self.temperatureFrom = _criteria.temperatureFrom and
			self.temperatureTo = _criteria.temperatureTo;
epilog

end;</source>
        <Parameter name="_criteria" type="CM_XlCriteria_Commodity"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f2ecdedc-0b46-4ea2-9b3d-7930bf4f5828">
        <updating/>
        <source>setForUpdate(_proxy :CM_XlCriteria_Commodity)updating;
/*
Date		Who		Reason
26 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	self.temperatureFrom	:= _proxy.temperatureFrom;
	self.temperatureTo		:= _proxy.temperatureTo;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_XlCriteria_Commodity"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="71d1a528-e268-40e8-9049-08d00770daee">
        <updating/>
        <source>setProxy(_tempFrom,_tempTo :Real) updating;
/*
Date		Who		Reason
26 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	self.temperatureFrom	:= _tempFrom;
	self.temperatureTo		:= _tempTo;
epilog

end;</source>
        <Parameter name="_tempFrom" type="Real"/>
        <Parameter name="_tempTo" type="Real"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="1d9f10ca-7357-4b40-853a-abb5f19045be">
        <source>validateMe();
/*
Date		Who		Reason
26 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	// neither or both should be entered
	if self.temperatureFrom = NULL_TEMPERATURE	and self.temperatureTo = NULL_TEMPERATURE then
		// GUI should have taken care of this
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Expecting temperatures - none entered');
		return;
	endif;

	self.validateTemperatureRange (self.temperatureFrom, self.temperatureTo);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateTemperatureRange" id="a1fd40d0-1620-42ab-b98e-7ed6ae700a31">
        <source>validateTemperatureRange(_from: Real; _to: Real) protected;
/*
Date		Who		Reason
27 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	commodity	:CM_Commodity;
begin
	inheritMethod(_from, _to);
	
	// check we are in the temperature range for the commodity
	commodity := self.myXlation.getObjectForSystemCode (XLATION_TYPE_COMMODITY_BYOP, null).CM_Commodity;
	
	if commodity &lt;&gt; null and commodity.hasTemp then
		if not (self.temperatureFrom &gt;= commodity.minTemp and self.temperatureTo &lt;= commodity.maxTemp) then
			app.raiseCMWarning2 (TEMP_RANGE_ERROR3, commodity.minTemp.asStringJMT, commodity.maxTemp.asStringJMT, null, null, null);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_from" type="Real"/>
        <Parameter name="_to" type="Real"/>
    </JadeMethod>
</Class>
