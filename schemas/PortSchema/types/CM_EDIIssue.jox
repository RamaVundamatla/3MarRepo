    <JadeMethod name="getAuditText" id="f7ff8a96-df8a-4108-8a53-be879b2d2d70">
        <source>getAuditText(): String;
// ##### CR 64617 TASK 65067 NAVAB1 09JUL2024
vars
	txt,
	tmpStr, field	: String;
	template : CM_EmailTemplate;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr := self.myTerminal.code;
	txt := txt &amp;'Terminal'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := self.getEDIFileTypesAsString();
	txt := txt &amp;'EDI Types'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;

	template := self.myEmailTemplate;
	if template &lt;&gt; null then
		
		tmpStr := template.toAddresses;
		txt := txt &amp;'Email TO'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
		tmpStr := template.ccAddresses;
		txt := txt &amp;'Email CC'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
		tmpStr := template.bccAddresses;
		txt := txt &amp;'Email BCC'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
		tmpStr := template.subject;
		txt := txt &amp;'Email Subject'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
		tmpStr := template.body;
		txt := txt &amp;'Email Body'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
		tmpStr := template.sendtoOperatorVoyage.getYesNo();
		txt := txt &amp;'Email Show First 5'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
		tmpStr := template.bccAddresses;
		txt := txt &amp;'Email BCC'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
		tmpStr := "";
		foreach field in template.allIncludedFields do
			if tmpStr = null then
				tmpStr := field &amp; CrLf;
			else
				tmpStr := tmpStr  &amp; field &amp;CrLf;
			endif;
		endforeach;
		txt := txt &amp;'Email Fields'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
	endif;
	
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="28fa362d-c777-4b9e-9411-2cdd5916df26">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:	

Date		Who		Reason
10 July 2024	navab1	CR 64617 TASK 64638
*/

vars

begin
	if _attrName = ETRow_IncludeLoad then
		return self.includeLoadIssue.getYes();
	elseif _attrName = ETRow_IncludeVerify then
		return self.includeVerifyIssue.getYes();
	elseif _attrName = ETRow_EdiFileTypes then
		return self.getEDIFileTypesAsString();
	elseif _attrName = ETRow_EmailSet then
		return (self.myEmailTemplate &lt;&gt; null).getYes();
	else

		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIFileTypes" id="cf683a9e-b705-4c71-b607-c004ac03e8be">
        <source>getEDIFileTypes(_types : CM_EDIFileTypeByNameDict input; _term : CM_Terminal);
/*
Purpose:	

Date		Who		Reason
10 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	mapping : CM_EDIIssueMapping;
begin
	if _types = null then
		return;
	endif;
	
	_types.clear();
	
	foreach mapping in self.allEDIIssueMappings discreteLock do
		_types.tryAddIfNotNull(mapping.myEDIFileType);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_types" type="CM_EDIFileTypeByNameDict" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getEDIFileTypesAsString" id="ac91a974-12e8-43c5-b16c-e9d60f123890">
        <source>getEDIFileTypesAsString() : String;
/*
Purpose:	

Date		Who		Reason
10 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	types : CM_EDIFileTypeByNameDict;
	type : CM_EDIFileType;
	retStr : String;
begin

	create types transient;
	self.getEDIFileTypes(types, self.myTerminal);
	
	foreach type in types do
		if retStr = null then
			retStr := type.name;
		else
			retStr := retStr &amp; ", " &amp; type.name;
		endif;
	endforeach;
	
	return retStr;
epilog
	delete types;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="fecb7ec8-3b40-4a7b-a9ea-aa0147b61780">
        <source>pxyCreateUpdateProxy(): SelfType;
// ##### CR 64617 TASK 65065 NAVAB1 09JUL2024
vars
	pxySelf : SelfType;
	realMapping, pxyMapping : CM_EDIIssueMapping;
begin
	pxySelf :=  inheritMethod();
	
	pxySelf.myTerminal := self.myTerminal;

	return pxySelf;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="sendEmail" id="35ba4ae6-8929-46f7-a99d-b9bc3b7c0d03">
        <updating/>
        <source>sendEmail(_ediData : CM_EDIData) updating;
/*
Purpose:	

Date		Who		Reason
16 Jul 2024	navab1	CR 64617 TASK 64637
29 Jul 2024	navdap1	TFS 65400 EUP | CallOff - Error 1300 - Array index out of bounds
*/

vars
	email 			: CM_EDIDefaultEmail;
	emailController	: CMIF_EmailTemplateController;

begin
	if app.isInProformaMode then
		return;
	endif;
	
	if app.isJMTUnitTest then
		return;
	endif;
	
	if app.isGarbageCollectionProcess then
		return;
	endif;
	
	if self.isTransient then
		return;
	endif;
	
	if self.myEmailTemplate &lt;&gt; null and self.myEmailTemplate.toAddresses &lt;&gt; null then
		create email transient;
		create emailController transient;
		email.setEmailController(emailController);
		email.setFromEmailTemplate(self.myEmailTemplate);
	
		_ediData.emailNotify(email, false, null);
	endif;
	
epilog
	
	delete email;
	//delete emailController;		// TFS 65400
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="40af2d66-299b-4ce5-9301-e3b7a06f1459">
        <updating/>
        <source>setForCreate(_pxy : SelfType) updating;
// ##### CR 64617 TASK 65065 NAVAB1 09JUL2024
vars

begin
	
	self.myTerminal := _pxy.myTerminal;

	self.setForUpdate(_pxy);
epilog

end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="57de0bba-bb00-4d07-a42d-7c6723bec5b8">
        <updating/>
        <source>setForUpdate(_pxy : SelfType) updating;
// ##### CR 64617 TASK 65065 NAVAB1 09JUL2024
vars
	pxyMapping, realMapping : CM_EDIIssueMapping;
	template : CM_EmailTemplate;

begin

	self.code := _pxy.code.trimBlanks();
	self.description := _pxy.description;
	self.includeLoadIssue := _pxy.includeLoadIssue;
	self.includeVerifyIssue := _pxy.includeVerifyIssue;
	
	if self.myEmailTemplate = null then
		create template persistent;
		template.setMyParent(self);
	endif;
	if self.myEmailTemplate &lt;&gt; null and _pxy.myEmailTemplate &lt;&gt; null then
		self.myEmailTemplate.setForUpdate(_pxy.myEmailTemplate);
	endif;
	
	self.allEDIIssueMappings.purge();
	
	foreach pxyMapping in _pxy.allEDIIssueMappings do
		pxyMapping.setProxyHeader(self);
		create realMapping;
		realMapping.setForCreate(pxyMapping);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="26b664d8-00fb-4332-a8bd-97e99b697b4a">
        <updating/>
        <source>setProxy(_term : CM_Terminal; _code, _desc : String; _includeLoadIssue, _includeVerifyIssue : Boolean; _template : CM_EmailTemplate input)  updating;
// ##### CR 64617 TASK 65065 NAVAB1 09JUL2024
vars

begin

	self.code := _code;
	self.description := _desc;
	self.includeLoadIssue := _includeLoadIssue;
	self.includeVerifyIssue := _includeVerifyIssue;
	
	if _template &lt;&gt; null then
		_template.setMyParent(self);
	endif;
	
	self.myTerminal := _term;
epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_includeLoadIssue" type="Boolean"/>
        <Parameter name="_includeVerifyIssue" type="Boolean"/>
        <Parameter name="_template" type="CM_EmailTemplate" usage="input"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="725b7803-c94f-4ae0-83a4-f08b2cc10461">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
// ##### CR 64617 TASK 65067 NAVAB1 09JUL2024
begin

	if _property.name = CM_EDIIssue::myEmailTemplate.name 
	or _property.name = CM_EDIIssue::myTerminal.name  then
		return false;
	endif;
	
	
	return inheritMethod(_rootClass, _property);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7a5b5309-9e7f-4108-9a84-0ed73b61e822">
        <source>validateForCreate();
// ##### CR 64617 TASK 65065 NAVAB1 09JUL2024
vars

begin

	if self.myTerminal = null then
		app.raiseCMException(Issue_must_have_termina,null,null);
	endif;
	
	self.validateForUpdate();
epilog

end;</source>
    </JadeMethod>
