vars
	bItem : CM_BookingRefItem;
	tmpStr : String;
begin
	foreach bItem in self.allLinkedStockBookingItems do
		if tmpStr = null then
			tmpStr := bItem.getDisplayString();
		else
			tmpStr := tmpStr &amp; ", " &amp; bItem.getDisplayString();
