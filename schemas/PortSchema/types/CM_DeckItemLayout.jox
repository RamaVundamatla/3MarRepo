    <JadeMethod name="importFromXMLDocReference" id="62406e28-14c5-422e-9301-8444cc62de49">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2011	cnwer1	Initial creation

*/

vars
	typeClass		: Class;
	xmlAttribute	 : JadeXMLAttribute;
	allPointElements : JadeXMLElementArray;
	pointElement, childElement : JadeXMLElement;
	decimal : Decimal[12,2];
	point : Point;
	code	: String;
	deck	: CM_Deck;
	pxyDeckItem : CM_DeckItem;
begin
	if _property = CM_DeckItemLayout::myPolygonPixels then
		create allPointElements transient;
		_xmlElement.getAllElementsByTagName(Point.name,allPointElements);
		
		foreach pointElement in allPointElements do
			point:=pointElement.textData.Point;
			self.myPolygonPixels.add(point);
		
		endforeach;
	elseif _property = CM_DeckItemLayout::myPolygonCMs then
		create allPointElements transient;
		_xmlElement.getAllElementsByTagName(Decimal.name,allPointElements);
		foreach pointElement in allPointElements do
				decimal:=pointElement.textData.Decimal;
				self.myPolygonCMs.add(decimal);
			
		endforeach;
	elseif _property = CM_DeckItemLayout::myDeckItem then
		xmlAttribute:=_xmlElement.getAttributeByName('type');
		typeClass:= currentSchema.getClass(xmlAttribute.value);
		// N.B any deck items that can be created on the deck i.e. ramp, lifts, machinery, general items
		// check if it has already been created if so just set the inverse reference
		//have to get the pxy deck see if the ramp item is already there
		deck:=self.myDeckLayer.myDeckLayout.myDeck;
		if typeClass.inheritsFrom(CM_RORORamp) or
			typeClass.inheritsFrom(CM_ROROGeneralArea) or
			typeClass.inheritsFrom(CM_ROROEquipment) then
			
			childElement:=_xmlElement.getElementByTagName(CM_DeckItem::code.name);
			code:=childElement.textData.String;
			pxyDeckItem:= deck.allDeckItems[code];
			
			if pxyDeckItem &lt;&gt; null then
				self.myDeckItem:=pxyDeckItem;
			endif;
		endif;
		
		if pxyDeckItem = null then
			create self.myDeckItem as typeClass transient;
			self.myDeckItem.setMyDeck(deck);
			self.myDeckItem.importFromXMLDoc(_xmlElement);
		endif;
	else
		inheritMethod(_property, _xmlElement);
	endif;
	
	
	

epilog
	delete allPointElements;

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="is40BackendForJob" id="79dd9d78-29b0-462c-bd01-d8ce2480db29">
        <source>is40BackendForJob( _job : CM_VoyageDeckJob) : Boolean;
/*

Date		Who		Reason
05 November 2014	cnwer1	Initial creation PAR

*/

vars
	deckItem : CM_ROROLocnDefnVoyage;
	allControllers 	: CM_VoyageROROControllerArray;
	fwdLocn : CM_ROROLocnDefn;
	controller		: CM_VoyageROROController;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	request :	CM_RORORequest;
begin
	if not self.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
		return false;
	endif;
	
	deckItem:=self.myDeckItem.CM_ROROLocnDefnVoyage;
	
	if deckItem.myAdjacentSlotFwd = null then
		return false;
	endif;
	
	create allControllers transient;
	fwdLocn :=deckItem.getFwdLocnDefn();
	if fwdLocn = null then
		return false;
	endif;
	
	deckItem.myAdjacentSlotFwd.getAllVoyageControllers(allControllers);
	
	foreach controller in allControllers do
		request:=null;
		if _job.isDischarge then
			request:=controller.myRORORequestDischarge ;
		else
			request:=controller.myRORORequestLoad ;			
		endif;
			
		if request&lt;&gt; null  then //and allRequests.includes(request)
			foreach wle in  request.allWorkListEntries do
				if wle.myTrackedItem &lt;&gt; null then
					// if aft locn check fwd loc doesn't have 40s
					if  not wle.myTrackedItem.is20 then
						return true;
					endif;
				endif;
			endforeach;
			continue;
		endif;
	endforeach;
	
	return false;
epilog
	delete allControllers;
end;</source>
        <Parameter name="_job" type="CM_VoyageDeckJob"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCovered" id="9ad01a6f-b50b-4eae-8bbf-6cf147c114fd">
        <source>isCovered(_type : Integer; _checkVisible : Boolean) : Boolean;
/*
Purpose:			
Date		Who		Reason
07 September 2011	cnwab1	Initial creation
*/

vars
	deckItemlayout : CM_DeckItemLayout;
begin
	deckItemlayout:=self.allCoveringPolygons[_type];
	
	if deckItemlayout = null then
		return false;
	endif;
	
	//epr par 29079 need to check that layoutItem isVisible 
	// In actual mode when the discharge OOTL is complete will set the deckItemLayout visible to false
	if  _checkVisible and not deckItemlayout.isVisible then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_checkVisible" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
