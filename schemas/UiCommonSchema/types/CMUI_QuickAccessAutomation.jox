    <JadeMethod name="create" id="cfa72867-cb27-4143-bf4b-83690d7c8694">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/03/2020	jlgdap1		Initial creation TFS 48992 MTN Automation Testing - Table Navigation
//
vars
	allRegisteredKeyCodes : IntegerArray;

begin
	create allRegisteredKeyCodes transient;
