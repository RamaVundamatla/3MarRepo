    <JadeMethod name="getData" id="aac84cae-c3d9-4e79-b33d-d7c3f4654e5b">
        <updating/>
        <source>getData(pText: String input; pType: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2011 By Andrew Bishop cnwab1
//
// Purpose:		CALLED by CMUI_GetData -  no references
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	newVessel:CM_Vessel;
	result : Boolean;
	isLoad : Boolean;
	theSlots,
	theSlotsAlt		: CM_VoyageROROControllerArray;
	anLC : CM_VoyageROROController;
	aReq : CM_RORORequest;
	obj : Object;
	tmpLoadCC	: CMIF_LoadColorCode;
	theReturn, numItems : Integer;
	itemLayout :CM_DeckItemLayout;
	editions : CM_ObjectByOidEditionDict;
begin

	app.mousePointer := Window.MousePointer_HourGlass;
	
	// PAR 28985
	if pType = self.GetData_QuantityUpdate then
		numItems := pText.Integer;
		if numItems &lt;= 0 then
			numItems := 1;
		endif;
		self.updateRORORequestQuantity(numItems);
	elseif pType = self.GetData_Quantity then
		numItems := pText.Integer;
		if numItems &lt;= 0 then
			numItems := 1;
		endif;
	
		self.updateSlotRequestAttributes(self.myCurrentAllocation, numItems);

	endif;

	self.myCurrentRORORequest := null; // PAR 28985

epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="pText" type="String" usage="input"/>
        <Parameter name="pType" type="Integer" usage="input"/>
    </JadeMethod>
