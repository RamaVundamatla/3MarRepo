    <JadeMethod name="action" id="a9bce224-4091-4f1f-a659-3b812c5970e5">
        <updating/>
        <source>action(_passport : CM_Passport input) : CM_Request updating;
//--------------------------------------------------------------
//Created: 01 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	newRequest	: CM_Request;
begin
	if self.mode = Mode_Add then
		newRequest := self.actionForCreate(_passport);
	elseif self.mode = Mode_Update then
		self.actionForUpdate(_passport);
	else
		app.raiseUnexpectedProgramError(class.name,method.name, 'Invalid Mode ' &amp; self.mode.String);
	endif;
	return newRequest;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="actionForCreate" id="6b2827be-4236-41ad-beac-da70021b683a">
        <updating/>
        <source>actionForCreate(_passport : CM_Passport input) : CM_Request protected, updating;
//--------------------------------------------------------------
//Created: 01 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	newJob		: CM_Job;
	newRequest	: CM_Request;
	pxyYRequest : CM_YardRequest;
	ti			: CM_TrackedItem;
	consignee	: CM_ConsigneeConsignor;
begin

	if self.isTIRequest then
		create pxyYRequest as CM_TIRequest transient;
	else
		create pxyYRequest as CM_DeliveryRequest transient;		
	endif;

	pxyYRequest.setFromCMIF_Request(self);

	if pxyYRequest.getTotalRequested() = 0 then // PAR 19710 we are now passing through the correct number to create
		return null;
	endif;
	
	app.myUtilityCA.utlCreateJobAndRequest(self.myProxyJob, newJob, pxyYRequest, newRequest, _passport);
	
	//jlier1 TFS 56733 27/4/24
	self.myNewJob:=newJob;
	self.myNewRequest:=newRequest;
	if CM_TIRequest.hasInstance(newRequest) then
		
		ti := newRequest.CM_TIRequest.trackedItem;
		consignee := newRequest.getMyConsignee();
		if consignee &lt;&gt; null and ti.myConsignee &lt;&gt; consignee then
			app.myUtilityUA.utlUpdateTIConsignee(ti, consignee, _passport);
		endif;	
	endif;
	return newRequest;

epilog
	delete pxyYRequest;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="actionForUpdate" id="6a47a418-c233-4b0f-b45a-2bb38dd86bf9">
        <updating/>
        <source>actionForUpdate(_passport : CM_Passport input)protected, updating;
//--------------------------------------------------------------
//Created: 01 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	edition		: Integer;
	realRequest	: CM_Request;
	ti			: CM_TrackedItem;
	consignee	: CM_ConsigneeConsignor;
begin

	self.myProxyRequest.pxyGetRealObjectAndEdition(realRequest, edition);
	if realRequest = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, self.myProxyRequest.class.name, null, null);
		return;
	endif;
	exclusiveLock(realRequest);
	if _passport.noErrors and realRequest.edition &lt;&gt; self.expectedEditionRequest then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Request', null, null);
		return;
	endif;

	realRequest.setFromCMIF_Request(self);
	realRequest.validate(null);
	if _passport.hasErrors then
		return;
	endif;
	
	if realRequest.isKindOf(CM_DeliveryRequest) then
		realRequest.CM_DeliveryRequest.updateWLEs();
	endif;
	
	if realRequest.isKindOf(CM_TIRequest) then
		ti := realRequest.CM_TIRequest.trackedItem;
		consignee := realRequest.getMyConsignee();
		if ti.myConsignee &lt;&gt; consignee then
			app.myUtilityUA.utlUpdateTIConsignee(ti, consignee, _passport);
		endif;	
	endif;

	// do the update status stuff in the service layer for notification purposes.	
	app.myUtilityUA.utlUpdateJobStatus(realRequest.myJob, _passport);
		
epilog
	delete self.myProxyRequest;	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="4f22afe3-fada-4d24-8a59-6c97c2bda1b6">
        <updating/>
        <source>setMyTrackedItem(): Boolean updating;
//--------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	//Make sure TI exists before continuing
	if self.cargoId = null then
		app.raiseCMException(ERR_INVALID_TI_ID, 'id', null);
		return false;
	else		
		self.myTrackedItem := self.myTerminal.allOnsiteTIsByIdCargoType[self.cargoId, self.myCargoBOLType.id];
		if self.myTrackedItem = null then
			app.raiseCMException1(ERR_TI_NOT_ONSITE, self.cargoId, 'id', null);
			return false;
		endif;
	endif;
	
	exclusiveLock(self.myTrackedItem);
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="27160577-560e-4a0e-89ea-c1556c4dd23d">
        <updating/>
        <source>validate()updating;
//--------------------------------------------------------------
//Created: 01 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpRequest 		: CM_YardRequest;
	trnsController	: CMIF_TIUpdateController;
	passport		: CM_Passport;
begin

	if self.mode = Mode_Update then
		if self.myProxyRequest = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Proxy Request', null, null);	
			app.raiseCMException(Input_required_field_proxReqst, null, null);	 // cnwdb2	PAR 35364
			return;	
		endif;	
	endif;
	
	if self.mode &lt; Mode_Add and self.mode &gt; Mode_Update then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Mode ' &amp; self.mode.String);
		return;
	endif;	

	if self.isTIRequest then
		if self.myTrackedItem = null then
			if (not self.setMyTrackedItem()) then
			//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Id', null, null);
				app.raiseCMException(Input_required_field_cargoId, null, null); // cnwdb2	PAR 35364
			endif;
		endif;
		if self.myTrackedItem &lt;&gt; null then
			exclusiveLock(self.myTrackedItem);
			// par 12837 - 09/11/2006  changed to raise todo task warning when requesting to release an item. 09/11/2006
			passport := app.myPassport;
			trnsController := app.createTIUpdateControl(TI_UPDMODE_RELEASE, passport.getUserCode(), self.myTrackedItem);
			//th2 04/06/2007 for PARS 14125 and 14172 - added bool to controller to not check for delivery release number
			//see CM_TrackedItem::validateOperatorRequirements for useage.
			trnsController.validateDeliveryRelNo := false;
			self.myTrackedItem.validateTrackedItem(trnsController, passport);
			
			
		tmpRequest := self.myTrackedItem.releaseRequest;
			if tmpRequest &lt;&gt; null then
				if self.mode = Mode_Update then
					if tmpRequest &lt;&gt; self.myProxyRequest.pxyGetRealObject() then
						app.raiseCMException2(ERR_TI_HAS_BULK_REL, self.myTrackedItem.id, tmpRequest.deliveryNumber, null, null);					
					endif;
				else
					app.raiseCMException2(ERR_TI_HAS_BULK_REL, self.myTrackedItem.id, tmpRequest.deliveryNumber, null, null);
				endif;	
		 	endif;
		endif;
	endif;
	
	if self.myProxyJob = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Proxy Job', null, null);
		app.raiseCMException(Input_required_field_proxJob, null, null); // cnwdb2	PAR 35364


	endif;

epilog
	delete trnsController;
end;</source>
    </JadeMethod>
</Class>
