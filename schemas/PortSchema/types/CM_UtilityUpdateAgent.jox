    <JadeMethod name="utlUpdateQueueEntryFlag" id="e7b06961-5715-4c52-acc6-2f88874e6722">
        <source>utlUpdateQueueEntryFlag(pProxyEntry : CM_RTQueueEntry; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realEntry:CM_RTQueueEntry;
	expectedEdition:Integer;
	
begin
	self.initialiseActivity();

	pProxyEntry.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyEntry.pxyGetRealObjectAndEdition(realEntry, expectedEdition);
	
	if realEntry = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_RTQueueEntry.name, null, null);
		return;
	endif;
	app.myValUA.valQueueEntry(pProxyEntry);
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realEntry);

	if _passport.noErrors and realEntry.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Queue Entry', null, null);
		return;
	endif;
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEntry, true);
	endif;
	if _passport.noErrors then
		realEntry.setOverRideFlags(pProxyEntry);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEntry, false);
	endif;
	
end;</source>
        <Parameter name="pProxyEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateQueueEntryPosition" id="1884faab-af0b-4671-ba50-8e628911f6e4">
        <source>utlUpdateQueueEntryPosition(pEntry : CM_RTQueueEntry input; pShiftBefore : CM_Object);
// ---------------------------------------------------------------------------
// Created:     10 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	terminal : CM_Terminal;

begin

	self.initialiseActivity();
	
	if pEntry = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'queue entry', null, null);
		app.raiseCMException(Input_required_field_queEntry, null, null); // cnwdb2	PAR 35364
		return;
