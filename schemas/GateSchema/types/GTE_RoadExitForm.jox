    <JadeMethod name="mnuCancelVisit_click" id="9b84facf-7992-4417-ba83-f2c137bb93b1">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCancelVisit_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2023	navpw1	Initial creation TFS: 54049 (55843)
09 Sep 2023 navma1	Bug 60419: EUP| FR | 53429 - VBS changes - Road Exit screen
01 Apr 2024 navlc30 ChangeRequest 63191: FR - 53429 - VBS - Dis-association of a VBS slot upon cancelling a VVR
*/

vars
	vvr     : CM_VehicleVisitRecord;
	roadJob : CM_RoadJob;
	terminal   : CM_Terminal;
	vbsProcess : CM_VBSProcess;
begin

	terminal	:= self.myTerminal;										//04.04.2024 navlc30 #63191
	
	if terminal &lt;&gt; null then											
		vbsProcess := terminal.getMyVBSProcess();						//04.04.2024 navlc30 #63191
	endif;
	
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then		//04.04.2024 navlc30 #63191
		self.doDisAssocBooking(null);					
	endif;	
		
	roadJob := self.myCurrentObject.CM_RoadJob;			//08.09.2023 navma1 #60419
	
	if roadJob &lt;&gt; null then								//08.09.2023 navma1 #60419
		vvr := roadJob.myVehicleVisit;
	endif;
	
	if vvr &lt;&gt; null then									//08.09.2023 navma1 #60419
		self.doCancelVVR(vvr);
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
