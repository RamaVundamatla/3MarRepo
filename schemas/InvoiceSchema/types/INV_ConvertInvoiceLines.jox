    <JadeMethod name="lstLineDescs_click" id="3fba0dba-1cd6-4808-b33d-a827924017a8">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstLineDescs_click(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
