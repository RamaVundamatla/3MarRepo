<Class name="CM_RemoteReticketDtl">
    <JadeMethod name="loadRemoteArray" id="8a3a8bbb-fc0e-454f-bb35-b999d08bc73b">
        <updating/>
        <source>loadRemoteArray(_table: CM_EntryTable io) updating;

constants

	AllTiArrayRow = 2;
	ColumnHeading = 'Old/New';
	
vars

	ti 					: String;

begin

	if _table.row = AllTiArrayRow then
		inheritMethod(_table);
		_table.setColumnHeadings(RejectItemsArray, ColumnHeading);
		foreach ti in self.allNewAndOld do
			self.addRemoteRow(_table, ti, ti, null);
		endforeach;
	endif;

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadRemoteTable" id="16bde6a4-1b46-4729-ae56-87f5689dfe69">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

vars

	tmpRow	: Integer;

begin

	inheritMethod(_table);

	_table.setColumnHeadings('Item', 'Value');
	self.addRemoteRow(_table, 'All Reticket Items', Click, self);
	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
