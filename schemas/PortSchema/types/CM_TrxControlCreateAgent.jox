    <JadeMethod name="trxCreateCustDocDetails" id="ef867da9-d0b3-4b7a-ab6d-73368779da9c">
        <updating/>
        <source>trxCreateCustDocDetails(_cmifCustDocDetails : CMIF_CustomDocumentDetail io;
					  _passport : CM_Passport input)updating;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/


vars
	theTerminal : CM_Terminal;
	pxyCustDocDetail,
	realCustDocDetail : CM_CustomDocumentDetail;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	if _passport.hasErrors() then
		return;
	endif;
	
	foreach pxyCustDocDetail in _cmifCustDocDetails.allProxyCustDocDetails do
		app.myUtilityCA.utlCreateCustDocDetail(pxyCustDocDetail,  realCustDocDetail,  _passport);
		
		if _passport.hasErrorsOrWarnings() then
			return;
		endif;
		
		_cmifCustDocDetails.allRealCustDocDetails.add(realCustDocDetail);
	endforeach;
	
	_cmifCustDocDetails.validateTIs(); // ### TFS 60508 15SEP2023 NAVAB1
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmifCustDocDetails" type="CMIF_CustomDocumentDetail" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
