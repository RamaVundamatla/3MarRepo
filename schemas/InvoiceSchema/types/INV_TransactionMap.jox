    <JadeMethod name="mnuAudits_click" id="c5dc1fc0-f126-45ec-86db-b4f4627a1589">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAudits_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 January 2017	cnwma1	Initial creation

*/

vars
	selectedObj		: Object;
begin
	selectedObj := self.lstData.listObject;
	if  selectedObj&lt;&gt; null then
		if selectedObj.isKindOf(CMIF_TMCGroup) then
		selectedObj:=	selectedObj.CMIF_TMCGroup.getRealMapObject;
		if selectedObj &lt;&gt; null  then
			app.viewAuditForm(selectedObj.CM_Object, self.myAssistant.class, self.myTerminal);
		endif;
		endif;
	
	endif;
epilog

end;</source>
