    <JadeMethod name="getTerminalCode" id="d91505ce-cf82-4eb0-9a0a-5bea0b01e2a1">
        <source>getTerminalCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/
vars
	invalid : Boolean;
	code : String;

begin
	on Exception do app.handleDeletedObject(exception, self.myInvoice, invalid);	
	
	code := self.myInvoice.myTerminal.code;
	
	if invalid then 
		return null;
	endif;
	
	return code;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyInvoice" id="976b6f16-caf6-4149-b227-8e41090a4811">
        <updating/>
        <source>setMyInvoice(_invoice : CM_Invoice) updating;
//
// Purpose:			
