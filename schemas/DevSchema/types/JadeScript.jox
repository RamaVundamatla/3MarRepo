    <JadeMethod name="ediExtractFiles" id="a92a20fa-0545-4196-9605-6a23f22bd660">
        <source>ediExtractFiles();

vars
	str : String;
	holdFileName : String;
	ediData : CM_EDIData;
	ediFile : CM_EDIFile;
	idx : Integer;
	terminal : CM_Terminal;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals['UT'];
	
	foreach ediData in terminal.myEdiConfig.allEDIDatasByTypeNumber do
		foreach ediFile in ediData.ediFileArray do
			if ediFile.myEDIFileType = null then
				continue;
			endif;
			idx := idx + 1;
			if idx &gt; 10 then
//				break;
			endif;
			holdFileName := ediFile.fileName;
			str := holdFileName.getFileNameAndExtension;
			beginTransaction;
			ediFile.fileName := "c:\testdb\c_misc\edi\UT\"&amp;str&amp;idx.String[1:1]&amp;".txt";
			commitTransaction;
			ediFile.writeFile();
			beginTransaction;
			ediFile.fileName := holdFileName;
			commitTransaction;
		endforeach;
	endforeach;	
end;
</source>
    </JadeMethod>
    <JadeMethod name="ediJMTInternalXMLCreate" id="b4af0543-f566-4a26-a4bc-bd48ac5038f1">
        <source>ediJMTInternalXMLCreate();
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//
constants
	OutputDir = "c:\temp\JMT_EDI\Dmast2\";
	Terminal : String = "UT";
vars
	terminal : CM_Terminal;
	ediData : CM_EDIData;
	ediFileTypeJMTXML : CM_EDIFileTypeXMLJMTInternal;
	cls : Class;
	coll : ClassColl;
	xmlDoc : JadeXMLDocument;
	file : File;
	str : String;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	create coll transient;
	create xmlDoc transient;
	CM_EDIData.allSubclasses(coll);
	foreach cls in coll do
		if cls = CM_EDIDataGeneric or
		   cls = CM_EDIDataGenCSV or
		   cls = CM_EDIDataGenXML then
			continue;
		endif;
		if cls.abstract	then
			continue;
		endif;
//write cls.name;
if cls &lt;&gt; CM_EDIDataTransManifest then continue; endif;
		create ediData as cls transient;
		ediFileTypeJMTXML := CM_EDIFileTypeXMLJMTInternal.firstInstance;
		ediFileTypeJMTXML.createSampleXMLFile(ediData, xmlDoc);
//		xmlDoc.writeToFile(OutputDir &amp; ediData.getJMTInternalName() &amp; '.xml');
//		write xmlDoc.writeToString;
	endforeach;
	create file transient;
	file.fileName := OutputDir &amp; ediData.getJMTInternalName() &amp; '.xml';
	str := xmlDoc.writeToString;
	write str;
	file.writeLine(str);
	file.close;
epilog
	delete ediData;
	delete coll;
	delete xmlDoc;
	delete file;
end;
</source>
    </JadeMethod>
    <JadeMethod name="ediJMTInternalXMLCreateData" id="b1252bd9-9456-4e9c-b426-f39ddc7c9b4b">
        <source>ediJMTInternalXMLCreateData();
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
//10 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
constants
	OutputDir = "c:\temp\JMT_EDI\Dmast2\";
	Terminal : String = 'UT';
vars
	terminal : CM_Terminal;
	ediData : CM_EDIData;
	ediFileTypeJMTXML : CM_EDIFileTypeXMLJMTInternal;
	file : File;
	count : Integer;
	filename : String;
	str : String;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	app.setPassBackExceptions(true, true);
	create file transient;
//	foreach ediData in terminal.myEdiConfig.allEDIDatasByTypeNumber do
//		if ediData.allEDITrackedItems.size = 0 then
//			continue;
//		endif;
	ediData := "10650.209585".asOid.CM_EDIData;
//	ediData := "16931.9171".asOid.CM_EDIData;
		count := count + 1;
		filename := ediData.fileName;
		filename := filename.removeInvalidChars();
		if filename = null then
			filename := "file"&amp;count.String;
		endif;
		file.fileName := OutputDir&amp;ediData.class.name[11:end]&amp;'_'&amp;filename&amp;".xml";
		file.mode := File.Mode_Output;
//		on FileException do 
		file.open;
		ediFileTypeJMTXML := CM_EDIFileTypeXMLJMTInternal.firstInstance;
		str := ediFileTypeJMTXML.extractDataXMLFile(ediData);
		file.writeLine(str);
		file.close;
//	endforeach;
epilog
	file.close;
	delete file;
end;
</source>
    </JadeMethod>
    <JadeMethod name="ediJMTInternalXMLFindStringArrays" id="ad433a7d-7950-4b51-aad7-686fbed98e2a">
        <source>ediJMTInternalXMLFindStringArrays();
//
//01 August 2018	jlgrs1	Initial creation
//
vars
	lClass : Class;
	prop : Property;
	subClasses : ClassColl;
begin
	app.initialize;
	create subClasses transient;
	CM_EDITrackedItem.allSubclasses(subClasses);
	subClasses.add(CM_EDITrackedItem);
	foreach lClass in subClasses do
		foreach prop in lClass.getProperties do
			if prop.type = IntegerArray then
				write class.name&amp;'::'&amp;method.name&amp;' '&amp;lClass.name&amp;' '&amp;prop.name;
			endif;
		endforeach;
	endforeach;
epilog
	delete subClasses;
end;</source>
    </JadeMethod>
    <JadeMethod name="ediJMTInternalXSDCreate" id="d6dec54b-29f2-4c3b-b102-ca94382405c1">
        <source>ediJMTInternalXSDCreate();
//
// 01 Sep 2014	cnwrs1	Par 34702 - Add support for JMT XML
//11 August 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//
//	**** NOTE: The Release Extract uses the similar method on DEV_ReleaseExtractAgent::extractXSDs, not this one! ****
//
constants
	OutputDir		= "c:\temp\JMT_EDI\";
	Terminal : String = 'UT';
vars
	terminal : CM_Terminal;
	ediData : CM_EDIData;
	ediFileTypeJMTXML : CM_EDIFileTypeXMLJMTInternal;
	cls : Class;
	coll : IntegerArray;
	xsdString : String;
	xml : JadeXMLDocument;
	ediControllerAgent : CM_EDIControllerAgent;
	ediConfig : CM_EDIConfig;
	xsdFileString,
	xsdFileAllString : String;
	idx : Integer;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	ediConfig := terminal.myEdiConfig;
	
	xsdFileAllString := '&lt;?xml version="1.0"?&gt;';
	xsdFileAllString := xsdFileAllString &amp; '&lt;xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified"&gt;';
	
	xsdFileAllString := xsdFileAllString &amp; '&lt;xs:element name="JMTInternalAll"&gt;';
    xsdFileAllString := xsdFileAllString &amp; '&lt;xs:complexType&gt;';
    xsdFileAllString := xsdFileAllString &amp; '&lt;xs:sequence&gt;';
	
	create coll transient;
	create ediControllerAgent transient;
 
	ediControllerAgent.getAllEDIDataTypeValues(coll, false);	
//	CM_EDIData.allSubclasses(coll);
//	foreach cls in coll do
	foreach idx in coll do
		cls := ediConfig.getEDIDataClassForType(idx);
		if cls = CM_EDIDataGeneric or
		   cls = CM_EDIDataGenCSV or
		   cls = CM_EDIDataGenXML or
		   cls = null then 
			continue;
		endif;
		if cls.abstract	then
			continue;
		endif;

//		if cls &lt;&gt; CM_EDIDataTrainConsist then continue; endif;
		
		create ediData as cls transient;
		ediFileTypeJMTXML := CM_EDIFileTypeXMLJMTInternal.firstInstance;
		
		xsdString := ediFileTypeJMTXML.getXSDDefinition(ediData);
		
		xsdFileString := '&lt;?xml version="1.0"?&gt;';
		xsdFileString := xsdFileString &amp; '&lt;xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified"&gt;';
	
		xsdFileString := xsdFileString &amp; xsdString;
		xsdFileString := xsdFileString &amp; '&lt;/xs:schema&gt;';
		
		delete xml;
		create xml transient;
		xml.parseString(xsdFileString);
		
		xml.outputDeclaration := true;
		xml.indentString := '  ';
		
		xml.writeToFile(OutputDir &amp; ediData.getJMTInternalName()[12:end] &amp; '.xsd');
		
		xsdFileAllString := xsdFileAllString &amp; xsdString;
		
	endforeach;

    xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:sequence&gt;';
    xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:complexType&gt;';
	xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:element&gt;';

	xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:schema&gt;';

	delete xml;
	create xml transient;
	xml.parseString(xsdFileAllString);
	
	xml.outputDeclaration := true;
	xml.indentString := '  ';
	
	xml.writeToFile(OutputDir &amp; 'JMTInternalAll.xsd');
epilog
	delete ediData;
	delete coll;
	delete xml;
	delete ediControllerAgent;
end;
</source>
    </JadeMethod>
    <JadeMethod name="ediJMTInternalXSDCreateSingle" id="d293c005-6f11-4bc4-8e00-c9e0f6440117">
        <source>ediJMTInternalXSDCreateSingle();
//
// 01 Sep 2014	cnwrs1	Par 34702 - Add support for JMT XML
//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//
constants
	OutputDir		= "c:\temp\JMT_EDI\";
	TerminalUT : String = 'UT';
vars
	terminal : CM_Terminal;
	ediData : CM_EDIData;
	ediFileTypeJMTXML : CM_EDIFileTypeXMLJMTInternal;
	cls : Class;
	coll : ClassColl;
	xsdString : String;
	xml : JadeXMLDocument;
	xsdFileString,
	xsdFileAllString : String;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[TerminalUT];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; TerminalUT);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode("SARGE");
	
	xsdFileAllString := '&lt;?xml version="1.0"?&gt;';
	xsdFileAllString := xsdFileAllString &amp; '&lt;xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified"&gt;';
	
	xsdFileAllString := xsdFileAllString &amp; '&lt;xs:element name="JMTInternalAll"&gt;';
    xsdFileAllString := xsdFileAllString &amp; '&lt;xs:complexType&gt;';
    xsdFileAllString := xsdFileAllString &amp; '&lt;xs:sequence&gt;';
	
	create coll transient;
	CM_EDIData.allSubclasses(coll);
//	cls := CM_EDIDataBooking;  // Multi Booking
//	cls := CM_EDIDataBookingRef;	// Single Booking
//	cls := CM_EDIDataRequestMultiLine;
//	cls := CM_EDIDataTrainConsist;
//	cls := CM_EDIDataShipManifest;
//	cls := CM_EDIDataOpCarrierAcessByCT;
	cls := CM_EDIDataTransManifest;
//	cls := CM_EDIDataCallOff;
		
		create ediData as cls transient;
		ediFileTypeJMTXML := CM_EDIFileTypeXMLJMTInternal.firstInstance;
		
		xsdString := ediFileTypeJMTXML.getXSDDefinition(ediData);
		
		xsdFileString := '&lt;?xml version="1.0"?&gt;';
		xsdFileString := xsdFileString &amp; '&lt;xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified"&gt;';
	
		xsdFileString := xsdFileString &amp; xsdString;
		xsdFileString := xsdFileString &amp; '&lt;/xs:schema&gt;';
		
		delete xml;
		create xml transient;
		xml.parseString(xsdFileString);
		
		xml.outputDeclaration := true;
		xml.indentString := '  ';
		
		xml.writeToFile(OutputDir &amp; ediData.getJMTInternalName() &amp; '.xsd');
		
		xsdFileAllString := xsdFileAllString &amp; xsdString;
		

    xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:sequence&gt;';
    xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:complexType&gt;';
	xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:element&gt;';

	xsdFileAllString := xsdFileAllString &amp; '&lt;/xs:schema&gt;';

	delete xml;
	create xml transient;
	xml.parseString(xsdFileAllString);
	
	xml.outputDeclaration := true;
	xml.indentString := '  ';
	
	xml.writeToFile(OutputDir &amp; 'JMTInternalAll.xsd');
epilog
	delete ediData;
	delete coll;
	delete xml;
end;
</source>
    </JadeMethod>
    <JadeMethod name="ediLockTester" id="42ec0f68-0146-4952-adeb-ae19e9af0212">
        <source>ediLockTester();
//
//27 Feb 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
//
vars
	ti : CM_TrackedItem;
	terminal : CM_Terminal;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals["T01"];
	ti := terminal.lookupTrackedItem("XONU4562345", 1, TI_STATE_NORMAL, "", false);
	ti.lock(ti, Reserve_Lock, Session_Duration, LockTimeout_Immediate);
	app.msgBox(null, null, 0);
	unlock(ti);
end;
</source>
    </JadeMethod>
    <JadeMethod name="ediLockTesting" id="30c71a23-9589-4f5f-af5a-4d5c6fa04a51">
        <source>ediLockTesting();
vars
	obj : CM_InvoiceLine;
	ti : CM_TrackedItem;
begin
	app.initialize;
//	ti := "".asOid.CM_TrackedItem;
	ti := "2367.10530854".asOid.CM_TrackedItem;
	beginTransaction;
//	ti.updateObjectEdition(ti);
	self.exclusiveLock(ti.myTerminal.allTITransactions);
	self.exclusiveLock(ti.myTerminal.allTITransactionsByTypeDate);
	self.exclusiveLock(ti.myTerminal.allTITransactionsByCamsTS);		
//	obj.myTransactionTI.updateObjectEdition(obj.myTransactionTI);
	app.msgBox("Update 1", ti.String, 0);
	ti.updateObjectEdition(ti);
	app.msgBox("Update 2", ti.String, 0);
	commitTransaction;
//	app.msgBox(obj.String, obj.transaction.mySnapShot.String, 0);
//	obj.inspect;
epilog
	ti.unlock(ti.myTerminal.allTITransactions);
end;</source>
    </JadeMethod>
    <JadeMethod name="ediRun" id="c331e92c-a92b-4b82-939f-edfd6b07dedd">
        <source>ediRun();

vars
	ediControllerAgent :CM_EDIControllerAgent;
	terminal : CM_Terminal;
	coll :IntegerArray;
begin
	app.initialize;
	create coll transient;
	create ediControllerAgent transient;
	terminal := app.myRoot.allTerminals["T01"];
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode("CONSW1");
	app.changeLogLevel(LogDEBUG);
	ediControllerAgent.setTerminal(terminal);	
	ediControllerAgent.getAllEDIDataTypeValues(coll, false);	
	ediControllerAgent.actionForAutoTerminal(true, false, false, coll);
epilog
	delete ediControllerAgent;
	delete coll;
end;
</source>
    </JadeMethod>
    <JadeMethod name="ediUnload" id="0a20e376-7417-4b8d-91a1-15b7e34c0537">
        <source>ediUnload();
//
// use to unload all the files of a type
//
vars
	str : String;
	holdFileName : String;
	ediData : CM_EDIDataDeckPlan;
	ediFile : CM_EDIFile;
	idx : Integer;
begin
	app.initialize;
	foreach ediData in CM_EDIDataDeckPlan.instances do
		idx := idx + 1;
		ediFile := ediData.ediFileArray.first;
		holdFileName := ediFile.fileName;
		str := holdFileName.getFileNameAndExtension;
		beginTransaction;
		ediFile.fileName := "d:\mesrjmt\edi\"&amp;str&amp;idx.String&amp;".txt";
		commitTransaction;
		ediFile.writeFile();
		beginTransaction;
		ediFile.fileName := holdFileName;
		commitTransaction;
	endforeach;	
end;</source>
    </JadeMethod>
    <JadeMethod name="epr31523" id="f372b41e-4e31-4db8-8b17-25e22873cbdf">
        <source>epr31523();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2013	cnwer1	Initial creation CCMS DPH 2274

*/

vars
	startCol , endCol : CM_GridColumn;
	allCols : ObjectSet;
	obj : Object;
begin
	endCol:="7853.12114".asOid.CM_GridColumn; //A01 col 19 label 37
	//endCol:="7853.12123".asOid.CM_GridColumn; //A01 col 12 label 23
	startCol:="7853.12113".asOid.CM_GridColumn;//B01 col 4 label 07
	create allCols transient;
	startCol.myGridArea.getColumnsBetweenCols(startCol,endCol,allCols);
	
	foreach obj in allCols do
		write obj.CM_GridColumn.label;
	endforeach;
epilog
	delete allCols;
end;</source>
    </JadeMethod>
    <JadeMethod name="epr33153" id="c9fd5106-c166-41c6-ace8-d5d24bd03cce">
        <source>epr33153();
/*

Date		Who		Reason
06 December 2013	cnwer1	Initial creation PAR

*/

vars
	dg : CM_UNDangerousGoods;
	newCode : String;
	codesToDelete : ObjectArray;
	obj : Object;
begin
	app.initialize;
	create codesToDelete transient;
	foreach dg in CM_UNDangerousGoods.instances do
		if dg.code.length &lt; 4 and dg.code.isInteger and dg.code.Integer &lt; 1000 then
			newCode:=dg.code.padLeadingZeros(4);
			if app.myRoot.allUNDangerousGoodsCodes[newCode] &lt;&gt; null then
				codesToDelete.add(dg);
			endif;
			
		endif;
		
	endforeach;
	
	foreach obj in codesToDelete do
		write obj.CM_Code.code;
	endforeach;
	beginTransaction;
		codesToDelete.purge;
	commitTransaction;
	
epilog
	delete codesToDelete;
end;</source>
    </JadeMethod>
