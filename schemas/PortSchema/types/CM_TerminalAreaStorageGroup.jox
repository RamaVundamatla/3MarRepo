    <JadeMethod name="getBank" id="d9939b70-f700-40a3-a86d-5e083aaff041">
        <source>getBank() : CM_Bank;
/*
Purpose:		 // PAR 36275	
Date		Who		Reason
21 May 2015	cnwab1	Initial creation
*/

vars

begin
	if self.myTerminal &lt;&gt; null then
		return self.myTerminal.getDefaultCompanyBank();
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
