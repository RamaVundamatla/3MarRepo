    <JadeMethod name="findMyTrackedItem" id="70eb3518-2a04-47a3-8567-59765aa09a4d">
        <source>findMyTrackedItem(_id: String; _cargoType: Integer; 
		_includeOnSite, _includePreNotes, _includeOnShip : Boolean): CM_TrackedItem;
/* ---------------------------------------------------------------------------
Created:     08 March 2010 by cnwrs2

Purpose:     Used to find a tracked item to process
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	trackedItem 	: CM_TrackedItem;
	voyage 			: CM_Voyage;
	terminal 		: CM_Terminal;
	invalidVoyage	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, voyage, invalidVoyage); //PAR24233 - cnwsh3 skip invalid voyage objects
	
	terminal := self.getMyTerminal();
	
	// First Check Onsites
	if _includeOnSite then
		trackedItem := terminal.allOnsiteTIsByIdCargoType[ _id, _cargoType ];
	endif;
	
	// If not found check Prenotes
	if _includePreNotes and trackedItem = null then
		trackedItem := terminal.allNotifiedTIsByCargoTypeId[ _cargoType, _id ];
	endif;

	//If not found check onship on voyages released by the ship planners
	if _includeOnShip and trackedItem = null  then
		foreach voyage in terminal.myEdiConfig.allVoyagesToProcess do
			if not voyage.hasDeparted() then
				trackedItem := voyage.allOnshipTIsByIdCargoType[ _id, _cargoType ];
				if trackedItem &lt;&gt; null then
					break;
				endif;
			endif;
		endforeach;
	endif;
	
	return trackedItem;
epilog
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_includeOnSite" type="Boolean"/>
        <Parameter name="_includePreNotes" type="Boolean"/>
        <Parameter name="_includeOnShip" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
