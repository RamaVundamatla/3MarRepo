    <JadeMethod name="tblWLEDragDropEvent" id="36551fc9-df4c-4d29-8825-eacf7c8b7ca6">
        <updating/>
        <source>tblWLEDragDropEvent(table: Table input; win: Window input; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 June 2009 by cnwab1
//
