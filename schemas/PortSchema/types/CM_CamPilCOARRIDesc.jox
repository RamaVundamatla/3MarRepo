    <JadeMethod name="outputHeader_NAD" id="a11dee34-783a-4cf2-b75e-b6aeaed3a2c4">
        <updating/>
        <source>outputHeader_NAD(_protocol: CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input; _camMessage: CM_CamMessage input; _coll: HugeStringArray input) : String updating, protected;
/* 
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
16 October 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	strLine : String;
begin
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment (_protocol, null, "CF", _protocol.camGroup.shippersCode.trimBlanks, '160', '87'), _coll);

	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
