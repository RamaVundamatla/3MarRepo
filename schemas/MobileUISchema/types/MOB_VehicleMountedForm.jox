    <JadeMethod name="isWeightCertified" id="c3b84109-16bb-4676-aa07-9333247caec0">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::isWeightCertified"/>
        </interfaceImplements>
        <source>isWeightCertified() : Boolean;
// TFS 2357 from IF_VehicleMountedDetails interface, return the 'is 'certified' value
vars
	text	: String;
	result	: Boolean;
begin
	text := self.myMoveTableDetails.getDataForEntRowName(ETRow_IsWeightCertified).String;
	if text = "1" then
		result := true;
	endif;
	return result;
end;
