    <JadeMethod name="setForConversion" id="d0249b31-6ec4-440e-90a4-be8b9c792ca4">
        <updating/>
        <source>setForConversion(_menuUserReport : CM_MenuUserReport input) updating;
// -------------------------------------------
// Created 13 December 2004 by cnwdvb1
// -------------------------------------------
vars

	task	: CM_AutoTask;

begin
/*  NO LONGER NEED SO COMMENT OUT REFERNCES TO MENU ITEM STUFF
	/* 7.3.1 CONVERSION STUFF. 
	BASICALLY TAKING DATA FROM A MENU USER REPORT AND STICKING
	IT ON A REPORT TEMPLATE OBJECT. 
	
	self.name				:= _menuUserReport.name;
	self.description		:= _menuUserReport.description;
	self.myQryReport		:= _menuUserReport.myQryReport;
	self.myUserToRunAs		:= _menuUserReport.getMyUser();
	self.createdDateTime	:= _menuUserReport.createdDateTime;
	
	if _menuUserReport.myEmailTemplate &lt;&gt; null then
		_menuUserReport.myEmailTemplate.setReportTemplate(self);
	endif;
	
	foreach task in _menuUserReport.allAutoTasks do
		task.CM_AutoTaskRunReports.addTemplateFor7_3_1Conversion(self);
	endforeach;

	self.allUsersToGetOutput.add(self.myUserToRunAs);
	self.myReportRequest := _menuUserReport.myReportRequest;
*/
end;</source>
        <Parameter name="_menuUserReport" type="CM_MenuUserReport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateSavedReport" id="6b4ec4b0-8f66-4f46-863c-cf6507c8aabd">
        <updating/>
        <source>setForCreateSavedReport(_name,		
						_description	: String;
						_user			: CM_User;
						_jadeReport		: JadeReport;
						_root			: CM_MenuRoot;
						_menu			: CM_MenuEntity) updating;
// -------------------------------------------
// Created 20 December 2004 by cnwdvb1
// -------------------------------------------
vars

	menuUserReport	: CM_MenuUserReport;

begin

	self.name				:= _name[1:30]; // adm 010808 PAR 17648
	self.description		:= _description;
	self.createdDateTime	:= app.actualTimeServer;
	
	self.cloneJadeReport(_jadeReport);

	create menuUserReport persistent;
	// Not a proxy today.
	menuUserReport.setForProxy(self, _root, _menu);	
	_user.causeEvent(CM_User.BGP_REPORT_CREATED, false, menuUserReport);
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_jadeReport" type="JadeReport"/>
        <Parameter name="_root" type="CM_MenuRoot"/>
        <Parameter name="_menu" type="CM_MenuEntity"/>
    </JadeMethod>
    <JadeMethod name="setForCreateTemplate" id="71d70988-fea0-408f-af82-992dc2fc4081">
        <updating/>
        <source>setForCreateTemplate(_pxyReportTemplate : CM_ReportTemplate; _newMenuUserReport	: CM_MenuUserReport output; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 10 December 2004 by cnwdvb1
// -------------------------------------------
vars


begin

	create self.myReportRequest as BGP_ReportRequestStatic persistent;
	
	self.setForUpdateTemplate(_pxyReportTemplate, _newMenuUserReport, _passport);	


end;</source>
        <Parameter name="_pxyReportTemplate" type="CM_ReportTemplate"/>
        <Parameter name="_newMenuUserReport" type="CM_MenuUserReport" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="ea9d7aff-f2ab-4196-95d6-80cdeac50bac">
        <updating/>
        <source>setForProxy(	_name,
				_description,
				_profileName,
				_printerName,
				_networkFilePath		: String;
				_destination,
				_outputType 			: Integer;
				_stopEmailWhenNoDataRpt	: Boolean;
				_filter					: CMQF_FilterReports;
				_reportDef 				: CM_QryReport; 
				_extraDetail 			: CM_ExtraDetail; 
				_emailTemplate			: CM_EmailTemplate input;
				_userToRunAs			: CM_User;
				_allUsersToGetOutput	: CM_UserSet;
				_allUsersWhoCanEdit		: CM_UserSet;
                _ftpEntity              : CM_FTPEntity;
				_passport				: CM_Passport) updating;
// -------------------------------------------
// Created 10 December 2004 by cnwdvb1
// -------------------------------------------
vars

	user			: CM_User;
	menu			: CM_MenuUserItem;
	menuUserReport	: CM_MenuUserReport;
	removeSet,
	addSet			: ObjectSet;
	root			: CM_MenuRootUserTemplates;
	failedDAC  :CM_DataAccessController;

begin

	create addSet transient;
	create removeSet transient;
	
	self.name					:= _name[1:30]; // adm 010808 PAR 17648
	self.description			:= _description;
	self.myQryReport			:= _reportDef;
	self.createdDateTime		:= app.actualTimeServer;
	self.networkFilepath		:= _networkFilePath;
	self.stopEmailWhenNoDataRpt	:= _stopEmailWhenNoDataRpt;
	self.myFTPEntity            := _ftpEntity;      //MTN-36668
    
	if _emailTemplate &lt;&gt; null then
		_emailTemplate.setReportTemplate(self);
	endif;
	
	if _userToRunAs &lt;&gt; null then
		self.myUserToRunAs		:= _userToRunAs;
	endif;
	
	// Go through existing users.
	foreach user in self.allUsersToGetOutput do
		// If they aren't selected and user can see them then they are removed.
		if not _allUsersToGetOutput.includes(user) and user.canUserAccessSelf(null, failedDAC,_passport) then
		else
			addSet.add(user);
		endif;
	endforeach;
	
	// Add selected ones to set.
	foreach user in _allUsersToGetOutput do
		if not addSet.includes(user) then
			addSet.add(user);
		endif;
	endforeach;
	
	self.allUsersToGetOutput.clear();
	// Copy to object.
	addSet.copy(self.allUsersToGetOutput);
	
	addSet.clear();
	
	foreach menu in self.allMenuUserReports do
		user := menu.CM_MenuUserReport.getMyUser();
		if user = null or (not _allUsersWhoCanEdit.includes(user) and user.canUserAccessSelf(null, failedDAC,_passport)) then
			delete menu;
		else
			addSet.add(user);
		endif;
	endforeach;
	
	foreach user in _allUsersWhoCanEdit do
		if not addSet.includes(user) then 
			root := user.myMenuRootBGRTemplate;
			create menuUserReport transient;
			menuUserReport.setForProxy(self, root, root);
		endif;
	endforeach;
	
	create self.myReportRequest as BGP_ReportRequestStatic transient;
	
	self.myReportRequest.BGP_ReportRequestStatic.setForProxy(_filter, _profileName, _destination, _extraDetail, _printerName, _outputType);
		
epilog

	delete addSet;
	delete removeSet;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_profileName" type="String"/>
        <Parameter name="_printerName" type="String"/>
        <Parameter name="_networkFilePath" type="String"/>
        <Parameter name="_destination" type="Integer"/>
        <Parameter name="_outputType" type="Integer"/>
        <Parameter name="_stopEmailWhenNoDataRpt" type="Boolean"/>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_reportDef" type="CM_QryReport"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate" usage="input"/>
        <Parameter name="_userToRunAs" type="CM_User"/>
        <Parameter name="_allUsersToGetOutput" type="CM_UserSet"/>
        <Parameter name="_allUsersWhoCanEdit" type="CM_UserSet"/>
        <Parameter name="_ftpEntity" type="CM_FTPEntity"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateTemplate" id="ce2e2b24-6c16-44c3-9976-3ee4b260a954">
        <updating/>
        <source>setForUpdateTemplate(_pxyReportTemplate : CM_ReportTemplate; _newMenuUserReport	: CM_MenuUserReport output; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 10 December 2004 by cnwdvb1
// -------------------------------------------
// A method that does everything.

vars

	emailTemplate		: CM_EmailTemplate;
	pxyMenuUserReport,
	realMenuUserReport	: CM_MenuUserItem;
	user,
	userForMenu			: CM_User;
	pxyBGP				: BGP_ReportRequestStatic;
	root				: CM_MenuRootUserTemplates;
	addSet				: CM_MenuUserItemSet;

begin

	// Set basic attributes.
	self.name				:= _pxyReportTemplate.name;
	self.description		:= _pxyReportTemplate.description;
	
	// Not point using this here we have the BGP Request.
	// Used when we don't have one e.g after BGP report is run.
	self.outputDestination 	:= null;
	self.myQryReport		:= _pxyReportTemplate.myQryReport;
	self.myUserToRunAs		:= _pxyReportTemplate.myUserToRunAs;
	self.createdDateTime	:= _pxyReportTemplate.createdDateTime;
	self.networkFilepath	:= _pxyReportTemplate.networkFilepath;
	self.myFTPEntity        := _pxyReportTemplate.myFTPEntity;      //MTN-36668
    
	// CCMS 1325
	self.stopEmailWhenNoDataRpt	:= _pxyReportTemplate.stopEmailWhenNoDataRpt;
	

	user := _passport.myUser;
	
	// Get the template menu folder.
	root := user.myMenuRootBGRTemplate;
	
	// Get rid of original email if any.
	emailTemplate := self.myEmailTemplate;
	delete emailTemplate;
	
	// Create new email template if there is one.
	if  _pxyReportTemplate.myEmailTemplate &lt;&gt; null then
		emailTemplate := _pxyReportTemplate.myEmailTemplate.cloneSelf(false);
		emailTemplate.cloneReferences( _pxyReportTemplate.myEmailTemplate, false);
		emailTemplate.setReportTemplate(self);
	endif;

	// Clear output users.
	self.allUsersToGetOutput.clear();
	
	// Copy new ones onto persistent report template.
	_pxyReportTemplate.allUsersToGetOutput.copy(self.allUsersToGetOutput);

	create addSet transient;
	
	// Because this update does all the work for creates and updates we
	// don't want to delete and re add because this screws up menu structures.
	// Sooooo we create new ones if we can't find the appropriate proxy.
	// We use the appropriate proxy if we can find one
	foreach pxyMenuUserReport in _pxyReportTemplate.allMenuUserReports do
		userForMenu := pxyMenuUserReport.CM_MenuUserReport.getMyUser();
		realMenuUserReport := pxyMenuUserReport.pxyGetRealObject;
		if realMenuUserReport = null then
			realMenuUserReport := pxyMenuUserReport.cloneSelf(false);
			userForMenu.causeEvent(EVENT_QRYREPORTUSER_CREATE, false, realMenuUserReport);
		else
			// We are editing an existing so lock it.
			self.exclusiveLock(realMenuUserReport);
			userForMenu.causeEvent(EVENT_QRYREPORTUSER_UPDATE, false, realMenuUserReport);
		endif;
		realMenuUserReport.CM_MenuUserReport.setForCreateTemplate(pxyMenuUserReport.CM_MenuUserReport);
		realMenuUserReport.CM_MenuUserReport.setReportTemplate(self);
		if realMenuUserReport.myMenuRoot = root then
			_newMenuUserReport := realMenuUserReport.CM_MenuUserReport;
		endif;
		addSet.add(realMenuUserReport);
	endforeach;
	
	// If it's not in the set then we don't want it.
	foreach realMenuUserReport in self.allMenuUserReports do
		if not addSet.includes(realMenuUserReport)then
			// Lock this.
			self.exclusiveLock(realMenuUserReport);
			realMenuUserReport.erase(NORMAL_ERASE);
		endif;
	endforeach;
	
	// Get the proxy request template.
	pxyBGP := _pxyReportTemplate.myReportRequest.BGP_ReportRequestStatic;
	
	self.exclusiveLock(self.myReportRequest);
	// Call the init method to set it all up correctly.
	self.myReportRequest.init(pxyBGP.myFilter, null, pxyBGP.profileName, pxyBGP.outputDestination, pxyBGP.myExtraDetail, pxyBGP.printerName, pxyBGP.outputType);

epilog

	delete addSet;
end;</source>
        <Parameter name="_pxyReportTemplate" type="CM_ReportTemplate"/>
        <Parameter name="_newMenuUserReport" type="CM_MenuUserReport" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromBlob" id="b1577105-9111-4777-a792-5b28d6c010cd">
        <updating/>
        <source>setFromBlob(_csv : Binary) updating;

// cnwdvb1 19 November 2002 

vars

	offset,
	binaryLength,
	dataLength		: Integer;
	csv				: CM_FileDataStorageDetail;
	data			: Binary;

begin

	binaryLength	:=	_csv.length();
	if not binaryLength &gt; 0 then
		return;
	endif;
	dataLength	:=	CM_FileDataStorageDetail.COPY_CHUNK_SIZE;

	offset := 1;
	beginTransaction;
	while offset &lt;= binaryLength do
		if (binaryLength - offset) &lt; dataLength then
			dataLength	:=	(binaryLength - offset) + 1;
		endif;
		
		data		:=	_csv[offset : dataLength];
		offset		:=	offset + data.length;
// cnwdad1 25/02/2009 - PAR #18366.
//		data		:= data.compress();
		data		:= data.compressToBinary(Binary.Compression_ZLib);
		create csv persistent;
		csv.set('FormBased', data, self, null);
		if offset &gt;= binaryLength then
			break;
		endif;
	endwhile;
	commitTransaction;	


end;</source>
        <Parameter name="_csv" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setFromFile" id="c49d3fa7-6ecc-4368-8eb0-660078f96599">
        <updating/>
        <source>setFromFile(_fileName : String; _onlyBlob : Boolean; _retryEmptyFile : Boolean) : Binary updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 May 2003 		cnwdvb1	Initial creation
13 March 2025		jlizm1	MTN 34050 BGP Reports not being received by cusotomer

*/
constants
	RetryLimit : Integer = 5;
	
vars

	file		: File;
	folder		: FileFolder; // ### TFS 52363 17Nov2021 NAVPW1
	str			: String;
	offset,
	fileLength	: Integer;
	dataLength	: Integer;
	fileData,
	tempBlob	: Binary;
	csv			: CM_FileDataStorageDetail;
	excOccurred : Boolean;
	i			: Integer;
	
begin
	// Put this here because file has not been available straight after report writer
	// has supposedly closed it.
	process.sleep(1000);
	create file transient;
	file.fileName					:= _fileName;
	file.mode						:=	File.Mode_Input;
	file.shareMode					:=	File.Share_Exclusive;
	file.kind						:=	File.Kind_Binary;

	create folder transient;									// ### TFS 52363 17Nov2021 NAVPW1
	folder.fileName					:= file.cnEcFilePath;		// ### TFS 52363 17Nov2021 NAVPW1
	app.writeLog("File Name: " &amp; file.fileName, LogINFO);		// ### TFS 52509 11July2023 NAVMP20
	app.writeLog("Folder Name: " &amp; folder.fileName, LogINFO);	// ### TFS 52509 11July2023 NAVMP20
	
	// ### TFS 52363 17Nov2021 NAVPW1
	if not folder.isAvailable then
		app.writeLog( 'Background reports encountered a folder error. Folder ' &amp; folder.fileName &amp; 
						' is unavailable. Check folder path settings, security permissions or read accessibility restrictions for user '
						&amp; app.myPassport.getUserCode(), LogINFO);
		app.remoteErrorWarningToAlert('Background reports encountered a folder error. Folder ' &amp; folder.fileName &amp; 
										' is unavailable. Check folder path settings, security permissions or read accessibility restrictions for user ' 
										&amp; app.myPassport.getUserCode(), null, null, null, false, true);
		return null;
	endif;
	// ### TFS 52363 17Nov2021 NAVPW1
	
	if not file.isAvailable then
		app.writeLog( 'Background reports encountered a file error. ' &amp; 'File ' &amp; _fileName &amp; 
						' is unavailable. Possibly because the report produced no output or the file could not be located/created for user '
						&amp; app.myPassport.getUserCode(), LogINFO);													// ### TFS 52363 17Nov2021 NAVPW1
		app.remoteErrorWarningToAlert('Background reports encountered a file error. ' &amp; 'File ' &amp; _fileName &amp; 
										' is unavailable. Possibly because the report produced no output or the file could not be located/created for user '
									   &amp; app.myPassport.getUserCode(), null, null, null, false, true);				// ### TFS 52363 17Nov2021 NAVPW1	
		return null;
	endif;
//	beginTransaction;	
	fileLength	:=	file.fileLength();
	
	if fileLength = 0 and _retryEmptyFile then
		// File appears to have been created and available but remain empty after begin printed to pdf
		// Wait a little longer and retry the file before proceeding
		foreach i in 1 to RetryLimit do
			app.writeLog("file length is 0, waiting and rechecking", LogINFO);
			process.sleep(1000);
			fileLength	:=	file.fileLength();
			if fileLength &lt;&gt; 0 then
				break;
			endif;
		endforeach;
		
		app.writeLog("file length is " &amp; fileLength.String, LogINFO);
	endif;
	
	dataLength	:=	CM_FileDataStorageDetail.COPY_CHUNK_SIZE;

	while offset &lt;= fileLength do
		if (fileLength - offset) &lt; dataLength then
			dataLength	:=	fileLength - offset;
		endif;
		
		if offset &lt;&gt; 0 then
			file.seek(offset);
		endif;
		
		fileData	:=	file.readBinary(dataLength);
		offset		:=	offset + fileData.length;
		tempBlob	:= tempBlob &amp; fileData;
				
		if not _onlyBlob then
// cnwdad1 25/02/2009 - PAR #18366.
//			fileData	:=	fileData.compress();
			fileData	:=	fileData.compressToBinary(Binary.Compression_ZLib);
			create csv persistent;
			csv.set(_fileName, fileData, self, null);
		endif;

		if offset &gt;= fileLength then
			break;
		endif;
	endwhile;
	app.writeLog('File (' &amp; _fileName &amp; ') loaded.  Size = ' &amp; fileLength.String, LogINFO);
	self.completedDateTime := app.actualTimeServer();	
//	commitTransaction;
	file.close;
	file.purge();
	return tempBlob;

epilog
	delete file;
	delete folder; // ### TFS 52363 17Nov2021 NAVPW1
	
end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_onlyBlob" type="Boolean"/>
        <Parameter name="_retryEmptyFile" type="Boolean"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setOutputDestination" id="13168624-daa7-4604-bb4e-e8746cc94dd7">
        <updating/>
        <source>setOutputDestination(_outputDestination : Integer) updating;
// -------------------------------------------
// Created 18 April 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.outputDestination := _outputDestination;


end;</source>
        <Parameter name="_outputDestination" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validate" id="9c5dece6-453a-4ef8-8264-2e821d8c0dc0">
        <source>validate();
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

	user 		: CM_User;
	menu		: CM_MenuUserItem;

begin

	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Name), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Name), null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.myUserToRunAs = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'user to run report as', null, null);
		app.raiseCMException(Input_required_field_usrRunRpt, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.allMenuUserReports.isEmpty() then
		app.raiseCMException1(MustHaveAtLeast, 'one user selected who can edit this report', null, null);
	endif;
	
	if self.allUsersToGetOutput.isEmpty() then
		app.raiseCMException1(MustHaveAtLeast, 'one user selected who can receive the output', null, null);
	endif;
	
	if  self.myQryReport = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'myQryReport is null', null, null);
	endif;
	
	//if not self.myQryReport.canBeRunInBackground then
//	if  self.myQryReport.reportProcessType = CM_QryReport.ReportProcessType_Foreground then
//		app.raiseCMException1(Full_Replacement_Message, self.myQryReport.reportName &amp; ' cannot be run in the background', null, null);
//	endif;
	
	if self.myReportRequest = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'myReportRequest is null', null, null);
	endif;
	
	foreach menu in self.allMenuUserReports do
		user := menu.CM_MenuUserReport.getMyUser();
		if not self.validateUserAgainstFilter(user, true, self.myReportRequest.myFilter, self.myQryReport) then
			// Don't want to repeat error messages.
			return;
		endif;
	endforeach;
	
	self.myReportRequest.validate();
	foreach user in self.allUsersToGetOutput do
		self.validateUserAgainstFilter(user, true, self.myReportRequest.myFilter, self.myQryReport);
	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="validateUserAgainstFilter" id="f69e32d6-dd2b-4fbc-8103-acc2aa25fda2">
        <source>validateUserAgainstFilter(_user : CM_User; _raiseException : Boolean; _filter : CMQF_FilterReports; _qryReport : CM_QryReport) : Boolean protected;
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

	userToRun	: CM_User;
	strArray	: StringArray;
	hadError	: Boolean;
	alert		: CM_SystemAlert;
	message		: String;
	class		: Class;
	doException	: Boolean;

begin

	userToRun := self.getUserToRunAgainst();
	
	if _user = userToRun then
		return true;
	endif;
	
	if not _user.canUserViewReport(_qryReport) then
		//message := 'User ' &amp; _user.code &amp; ' does not have security access to report ' &amp; _qryReport.reportName; //- cnwmd1, Par 20524
		if _raiseException then
			app.raiseCMException2(User_does_have_secur_acces_rep, _user.code, _qryReport.reportName, null, null); //+ cnwmd1, Par 20524
		endif;
		message := app.getErrorString2(User_does_have_secur_acces_rep, _user.code, _qryReport.reportName);//+ cnwmd1, Par 20524
		doException := true;
	endif;
	
	if not doException then
		create strArray transient;
		// Can user run specific filter. If not see if their access can match that of the runner.
		class := _filter.canUserRunReport(_user);
		if class &lt;&gt; null then
			if not userToRun.compareUsersDataAccess(_user, class) then
				/*message := 'User ' &amp; _user.code &amp; ' does not have correct Data Access.' &amp; _user.code &amp; ' must have same access as ' &amp; userToRun.code &amp;
					' for ' &amp; class.getNiceName() &amp; ' or the report filtering must specify values that this user has permission to view.';*/ //- cnwmd1, Par 20524
				if _raiseException then
					app.raiseCMException3(User_does_have_corre_data_acce, _user.code, userToRun.code, class.getNiceName(), null, null); //+ cnwmd1, Par 20524
				endif;
				message := app.getErrorString3(User_does_have_corre_data_acce, _user.code, userToRun.code, class.getNiceName()); //+ cnwmd1, Par 20524
				doException := true;
			endif;
		endif;
	endif;
	
	if not doException then
		return true;
	endif;
	
	if _raiseException then
		//app.raiseCMException1(Full_Replacement_Message, message, null, null); //- cnwmd1, Par 20524 - Exception is now raised immediately
		return false;
	else
		create alert;
		alert.details := 'User ' &amp; _user.code &amp; ' not receiving output for report ' &amp; self.name &amp; ' user ' &amp; userToRun.code;
		alert.addLogEntry(message);
		alert.setSeverity(SEVERE_ERROR);
		alert.add;
		app.commitAlert();
		return false;
	endif;
	
epilog

	delete strArray;

end;</source>
        <access>protected</access>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_raiseException" type="Boolean"/>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_qryReport" type="CM_QryReport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeCSVBlobToFile" id="408488b0-3395-4f1c-8a04-bef6966c30a0">
        <source>writeCSVBlobToFile(_fileName : String) : Boolean;

vars

	file		: File;
	fileDtl		: CM_FileDataStorageDetail;
	tmpBin		: Binary;

begin

	create file transient;
	file.mode		:=	File.Mode_Output;
	file.shareMode	:=	File.Share_Exclusive;
	file.kind		:=	File.Kind_Binary;
	file.fileName	:= _fileName;
	
	if not file.tryOpen() then
		return false;
	endif;
	
	// Will concat all files on this object as csv can know come
	// from multiple runs e.g detail + summary reports.
	foreach fileDtl in self.allMenuCSVFileData do
		if fileDtl.csvBlob = null then
			continue;
		endif;
		
// cnwdad1 25/02/2009 - PAR #18366.
//		tmpBin := fileDtl.csvBlob.uncompress;
		tmpBin := fileDtl.csvBlob.uncompressToBinary();
		file.writeBinary(tmpBin);
	endforeach;
	
	return true;
epilog
	if file &lt;&gt; null then
		file.close();
	endif;
	
	delete file;
end;</source>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
