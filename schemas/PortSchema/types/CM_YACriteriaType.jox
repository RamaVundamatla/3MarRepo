    <JadeMethod name="isObjectBeingUsedInCriteria" id="0aea9b86-3b2f-4aa8-9493-c41dc5ab96fc">
        <source>isObjectBeingUsedInCriteria(
	_object : Object;
	_yardAllocationName : String io;
	_terminalName : String io ) : Boolean;

/*

Purpose:		Returns true if supplied object is being used in a criteria somewhere.
				This is similar logic to method removeMyDataObject but returns true if found anywhere.
				It is intended to be used where the System Admin deletes data that makes up criteria eg CM_WeightRange.
Parameters:		
Return Value:	true if a match found else false.
				Plus return the first found Yard Allocation name or Terminal name.

Date				Who		Reason
09 April 2009		cnwrl1	PAR 19373
05/06/2009			cnwrl1	PAR 19856 - To avoid ambiguous error message

*/
	
vars
	criteria	: CM_YACriteriaPriority;
	tempStr		: String;
	
begin
	if self.isTransportModeType or self.isPrimitiveValue then
		return false;
	endif;
	
	foreach criteria in self.allYACriteria discreteLock do
		if criteria.myYAData &lt;&gt; null and criteria.myYAData.CM_YADataObjects.includes( _object ) then
			if criteria.CM_YACriteria.myYardAllocation &lt;&gt; null then
				tempStr := criteria.CM_YACriteria.myYardAllocation.getDisplayForInUseValidation();	//27 Nov 2012	NDL	Par 30767
		/*		if criteria.CM_YACriteria.myYardAllocation.myTerminal = null then
					tempStr	:=	criteria.CM_YACriteria.myYardAllocation.code;
				else
					tempStr	:=	app.getString( Terminal ) &amp; Space &amp;
								criteria.CM_YACriteria.myYardAllocation.myTerminal.code &amp; ' / ' &amp;
								criteria.CM_YACriteria.myYardAllocation.code;
				endif;*/
			endif;
			_yardAllocationName	:= tempStr;
			_terminalName		:= null;
			return true;
		endif;
	endforeach;
	
	// should have been found in criteria but just in case check priorities as well!
	foreach criteria in self.allYAPriorities discreteLock do
		if criteria.myYAData &lt;&gt; null and criteria.myYAData.CM_YADataObjects.includes( _object ) then
			if criteria.CM_YAPriority.myTerminal = null then
				tempStr	:= app.getString( Unknown ) &amp; Space &amp; app.getString( Terminal );
			else
				tempStr	:= app.getString( Terminal ) &amp; Space &amp; criteria.CM_YAPriority.myTerminal.code;
			endif;
			_yardAllocationName	:= null;
			_terminalName		:= tempStr;
			return true;
		endif;
	endforeach;
	
	// 23/05/2009 cnwar2 CCMS1040/#19796
	foreach criteria in self.allRecRestrictCriteria discreteLock do
		if criteria.myYAData &lt;&gt; null and criteria.myYAData.CM_YADataObjects.includes( _object ) then
			if criteria.CM_ReceivalCutoffCriteria.myReceivalCutoffTermDef.myTerminal = null then
				tempStr	:= app.getString( Unknown ) &amp; Space &amp; app.getString( Terminal );
			else
				tempStr	:= app.getString( Terminal ) &amp; Space &amp; criteria.CM_ReceivalCutoffCriteria.myReceivalCutoffTermDef.myTerminal.code;
			endif;
			_yardAllocationName	:= null;
			_terminalName 		:= tempStr;
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog
	
end;
</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_yardAllocationName" type="String" usage="io"/>
        <Parameter name="_terminalName" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
