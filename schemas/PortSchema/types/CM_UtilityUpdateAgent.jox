	if realSFTPEntity = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SFTPEntity.name, null, null);
		return;
	endif;
	app.myValUA.valSFTPEntity(realSFTPEntity, _proxySFTPEntity);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	exclusiveLock(realSFTPEntity);
	if _passport.noErrors and 
	   realSFTPEntity.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'SFTP Entity', null, null);
		return;
	endif;
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSFTPEntity, true);
	endif;
	if _passport.noErrors then
		realSFTPEntity.setForUpdate(_proxySFTPEntity);
	endif;
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSFTPEntity, false);
	endif;
epilog
	
end;
</source>
