    <JadeMethod name="erase" id="40b39db5-0fa3-46b9-970d-35765cb84ba5">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
//05/09/2023	navkc1	CR 59934 Task 59935: Jade - Cust Doc Cargo Transactions
vars
	
begin
	// ### TFS CR 59942 TASK 59943 29AUG2023 NAVAB1 - apply  stops that have been cleared - clear stops that have been applied
	self.reverseStops();
	self.createTransactionForTI(TRANS_TYPE_CUSTDOCDELETE); //05/09/2023	navkc1	CR 59934 Task 59935
	
	inheritMethod(_eraseLevel);
	


epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="86aa9dd5-5345-483e-809e-0c184d749b78">
        <source>getAuditText(): String;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1 - audit tags all said Custom DOc Type
// 06 November 2023 navmv20 CR 60425 Task 60987: Jade - Cust Doc Cancellation TRX
vars
	txt,
	tmpStr	: String;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	if self.myCustomDocumentType &lt;&gt; null then
		tmpStr := self.myCustomDocumentType.auditId();
		txt := txt &amp; 'Custom Doc Type' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.myCustomLicense &lt;&gt; null then
		tmpStr := self.myCustomLicense.auditId();
		txt := txt &amp; 'Custom Doc License' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.myCustomsAgent &lt;&gt; null then
		tmpStr := self.myCustomsAgent.auditId();
		txt := txt &amp; 'Custom Doc Agent' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := CM_CustomDocumentType@getDirectStrFromInt(self.direction);
	txt := txt &amp; "Direction" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	//06/11/2023 navmv20 CR 60425 Task 60987 - start
	tmpStr := CM_CustomDocument@getStatusStrFromInt(self.status);
	txt := txt &amp; "Status" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	//06/11/2023 navmv20 CR 60425 Task 60987 - end
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoSubTypeCode" id="572ad80b-5389-4407-9a6e-5ecdecaa81f7">
        <source>getCargoSubTypeCode():String;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
*/

vars
	detail      : CM_CustomDocumentDetail;
	displayStr, returnStr : String;
	ti : CM_TrackedItem;
begin
	foreach detail in self.allCustomDocumentDetails  
			where detail.isIncluded() do
		ti := detail.myTrackedItem;
		if ti = null then
			continue;
		endif;
		displayStr := ti.productCode;
		/*
		if displayStr &lt;&gt; null then
			if returnStr.pos(displayStr,1) = 0 then
				if returnStr = null then
					returnStr := displayStr;
				else
					returnStr := returnStr &amp; ", " &amp; displayStr;
				endif;
			endif;
		endif;
		*/
		
		returnStr.addStringToList(displayStr, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return returnStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoSubTypeDesc" id="1fb56cf7-b425-4225-ad34-010dacf07edb">
        <source>getCargoSubTypeDesc():String;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
*/

vars
	detail      : CM_CustomDocumentDetail;
	displayStr, returnStr : String;
	ti : CM_TrackedItem;
	cargoSubType : CM_Product;
begin
	foreach detail in self.allCustomDocumentDetails 
				where detail.isIncluded() do

		ti := detail.myTrackedItem;
		if ti = null then
			continue;
		endif;
		
		cargoSubType := ti.myProduct;
		if cargoSubType &lt;&gt; null then
			displayStr := cargoSubType.description;
			/*
			if displayStr &lt;&gt; null then
				if returnStr.pos(displayStr,1) = 0 then
					if returnStr = null then
						returnStr := displayStr;
					else
						returnStr := returnStr &amp; ", " &amp; displayStr;
					endif;
				endif;
			endif;
			*/
			
			returnStr.addStringToList(displayStr, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
		endif;
	endforeach;
	
	return returnStr;
epilog

end;</source>
