    <JadeMethod name="checkVersionDownloadRequired" id="ce1b1336-7cdf-46f0-87ad-97f2fa33528e">
        <source>checkVersionDownloadRequired();
/*

Purpose:	Doesn't actually do anything.  Just used to check if there is a 
			client download required

Date		Who		Reason
18/06/2014	cnwmh5	Initial creation

*/

vars

begin

	app.initialize();
	
	app.writeLog("Running " &amp; method.name, LogINFO);
	app.writeLog("Exit Code: " &amp; process.userExitCode.String, LogINFO);

epilog

	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="cnGetEnvironmentId" id="beef6284-c165-4170-9bb7-10b559a00d1d">
        <source>cnGetEnvironmentId() : String;

constants
	CN_BACK_SLASH = "\";
vars
	posn	: Integer;
	
	env_id,
	str		: String;
begin
	posn 	:= 1;
	str 	:= app.dbPath();
	posn	:= 1;
	str.scanUntil(CN_BACK_SLASH, posn);					// get past drive letter part
	posn	:= posn + 1;
	env_id 	:= str.scanUntil(CN_BACK_SLASH, posn);		
	return env_id;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="copyFileToAppServer" id="76f776ad-9f7f-43fe-9982-449f6b6bbe4b">
        <source>copyFileToAppServer(_sourceFileName : String) : String;
// ---------------------------------------------------------------------------
// Created:     14 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  The fully pathed name of the source file on the
//				client
//
// Returns:     The fully pathed name of file on the app server
//
/*

Date				Who		Reason
25 October 2025		navmd1	DOMTN-403 A slightly managed version of the same method on PortSchema
*/

vars
	targetDir	: String;
	targetFile	: String;
	nodeOptions	: Integer;
	ff			: FileFolder;
	ts			: TimeStamp;
	sep			: String;
	sourceFile	: File;
begin
	create ff transient;
	sep := ff.directorySeparator();
	ff.usePresentationFileSystem := false;	// use the appServer file system
	
	targetDir := self.getStagingDirectory();
	
	ff.fileName := targetDir;
	if (not ff.isAvailable) then
		ff.make();
	endif;
	
	create sourceFile transient;
	sourceFile.usePresentationFileSystem := true;
	sourceFile.mode := File.Mode_Input;
	sourceFile.kind := File.Kind_Binary;
	sourceFile.fileName := _sourceFileName;
	
	if not sourceFile.isAvailable then
		app.writeLog(_sourceFileName &amp; " is unable to be accessed, unable to copy to server", LogERROR);
		return null;
	endif;

	ts := app.actualTimeServer;
	targetFile := _sourceFileName[_sourceFileName.reversePos(sep)+1:end];
	
	targetFile := targetDir &amp; sep &amp; targetFile;
	
	nodeOptions := JSSFMPublicInterface.NODE_SOURCE_CLIENT +
					JSSFMPublicInterface.NODE_TARGET_APPSERVER;
	self.myFileManager.copyFile(_sourceFileName, targetFile, nodeOptions);

	return targetFile;

epilog
	delete ff;
	delete sourceFile;
end;</source>
        <Parameter name="_sourceFileName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="copyFileToLocalMachine" id="2eabf290-79c7-43b7-8655-e508fc0a98bb">
        <source>copyFileToLocalMachine(_sourceFileName, _targetFileName : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2021	navpw1	Initial creation TFS: 52202

*/

constants
	Err_DirectoryNotAvailable	: Integer = 79749;
vars
	sourceDir,
	targetDir		: String;
	nodeOptions		: Integer;
	ff				: FileFolder;
	lf				: FileFolder;
	
begin
	create ff transient;
	ff.usePresentationFileSystem := false;	// use the appServer file system
	sourceDir := _sourceFileName.cnEcGetPathOfFileName();
	ff.fileName := sourceDir;

	if (not ff.isAvailable) then
		self.raiseCMException2(Err_DirectoryNotAvailable, sourceDir, self.computerNameAppServer, null, null); 
		return null;
	endif;
	
	create lf transient;
	lf.usePresentationFileSystem := true;	// use the local file system
	targetDir := _targetFileName.cnEcGetPathOfFileName();
	lf.fileName := targetDir;

	if (not lf.isAvailable) then
		lf.make;
	endif;
	
	if (not lf.isAvailable) then
		app.raiseCMException2(Err_DirectoryNotAvailable, targetDir, app.computerName, null, null); 
		return null;
	endif;
	
	nodeOptions := JSSFMPublicInterface.NODE_SOURCE_APPSERVER + JSSFMPublicInterface.NODE_TARGET_CLIENT;
	
	self.myFileManager.copyFile(_sourceFileName, _targetFileName, nodeOptions);

	return _targetFileName;

epilog
	delete ff;
	delete lf;
	
end;</source>
        <Parameter name="_sourceFileName" type="String"/>
        <Parameter name="_targetFileName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorString2" id="2b8df1fc-1ed3-4bf4-90e3-a946092bb87b">
        <source>getErrorString2(errorCode : Integer; param1, param2 : String) : String;

/*

Date		Who		Reason
24 Sep 2025	navmd1	A *very* slimmed down version of the same in PortSchema

*/

constants
	Err_DirectoryNotAvailable	: Integer = 79749;
vars
	
begin
	if errorCode &lt; self.baseErrorNum then
		return getJadeErrorString(errorCode);
	endif;
	
	if errorCode = Err_DirectoryNotAvailable then
		return "The directory %1 on %2 does not exist or you do not have permission to access it.  Please contact your system administrator.".replace__("%1", param1, true).replace__("%2", param2, true);
	endif;
	
	return "Error " &amp; errorCode.String &amp; ": Unknown message";
	
epilog
	
end;</source>
        <Parameter name="errorCode" type="Integer"/>
        <Parameter name="param1" type="String"/>
        <Parameter name="param2" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorString3" id="aa8a1fcb-c5ca-489b-ba44-30184590af1a">
        <source>getErrorString3(errorCode : Integer; param1, param2, param3 : String) : String;

/*

Date		Who		Reason
24 Sep 2025	navmd1	A *very* slimmed down version of the same in PortSchema

*/

constants
	UNEXPECTED_PROGRAM_ERROR	: Integer = 75768;
vars
	
begin
	if errorCode &lt; self.baseErrorNum then
		return getJadeErrorString(errorCode);
	endif;
	
	if errorCode = UNEXPECTED_PROGRAM_ERROR then
		return "Unexpected Program Error in %1::%2 (%3) ".replace__("%1", param1, true).replace__("%2", param2, true).replace__("%3", param3, true);
	endif;
	
	return "Error " &amp; errorCode.String &amp; ": Unknown message";
	
epilog
	
end;</source>
        <Parameter name="errorCode" type="Integer"/>
        <Parameter name="param1" type="String"/>
        <Parameter name="param2" type="String"/>
        <Parameter name="param3" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJadeErrorString" id="b8388940-b05d-4640-a61b-b2eaa1b27ee1">
        <source>getJadeErrorString(errorCode : Integer) : String protected;
// ---------------------------------------------------------------------------
// Created:			21 May 2001 by cnwdwq1
// Purpose:			Creates a temp exception, and asks the exception to get the jade string     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ex : Exception;
begin
	if errorCode &gt; self.baseErrorNum then
		return "Unknown Jade Exception :" &amp; errorCode.String &amp; " greater than baseNum! " &amp; self.baseErrorNum.String;
	endif;
	create ex;
	ex.errorCode := errorCode;
	return ex.text();
epilog
	delete ex;
end;</source>
        <access>protected</access>
        <Parameter name="errorCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJadeLogDir" id="9580cd7f-e331-4c3f-ba86-c1c2f8bdc795">
        <source>getJadeLogDir() : String;
// A stripped down version of PortSchema::getJadeLogDir
vars
	iniFileName,
	dirName		: String;
begin
	if node.isApplicationServer then
		iniFileName := self.getIniFileNameAppServer();
		dirName := self.getProfileStringAppServer(iniFileName, 'JadeLog', 'LogDirectory', null);
	else
		iniFileName := self.getIniFileName();
		dirName := self.getProfileString(iniFileName, 'JadeLog', 'LogDirectory', null);
	endif;
	
	return dirName;
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLoggingLevelString" id="c2b4c166-3829-4d2e-9874-ada69fe91075">
        <source>getLoggingLevelString( _index : Integer ): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

	logLevelStr : String;

begin

	if _index = LogINFO then	//0
		logLevelStr := "INFO";
	elseif _index = LogFATAL then	//1
		logLevelStr := "FATAL";
	elseif _index = LogERROR then	//2
		logLevelStr := "ERROR";
	elseif _index = LogWARN then	//3
		logLevelStr := "WARN";
	elseif _index = LogDEBUG then	//4
		logLevelStr := "DEBUG";
	elseif _index = LogTRACE then	//5
		logLevelStr := "TRACE";
	else
		logLevelStr := "*** UNKNOWN ***";
	endif;
	
	return logLevelStr;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStagingDirectory" id="6f2d5b0a-446f-4fe2-8391-329acb8d75e5">
        <source>getStagingDirectory(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 October 2025		navmd1	DOMTN-403 Initial creation

*/

vars
	ff			: FileFolder;
	targetDir	: String;
	sep			: String;
begin
	create ff transient;
	sep := ff.directorySeparator();
	
	targetDir := app.getJadeInstallDirAppServer();				// eg, D:\navKmast\server\c_bin
	targetDir := targetDir[1:targetDir.reversePos(sep)];		// D:\navKmast\server\
	targetDir &amp;= "c_misc" &amp; sep &amp; "gitDeployStaging";			// D:\navKmast\server\c_misc\gitDeployStaging
	
	return targetDir;
epilog
	delete ff;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="d419fcfe-7ecd-4523-8039-125f5111c094">
        <updating/>
        <source>init(_initParams: HugeStringArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 October 2025		navmd1	Initial creation DOMTN-285

*/

vars	
	agent				: GitFileLoadAgent;
	logger				: CMIF_Logger;
	clientLog			: File;
begin
	beginTransaction;
	process.userExitCode := 63;
	commitTransaction;
	
	create logger transient;
	self.setLogger(logger);
	
	create self.myFileManager transient;	
	
	create clientLog transient;
	clientLog.usePresentationFileSystem := true;
	clientLog.mode := File.Mode_Output;
	clientLog.kind := File.Kind_ANSI;
	clientLog.fileName := GitFileLoadAgent.getName() &amp; ".log";
	
	app.logLevel := LogWARN;

	agent := create GitFileLoadAgent(_initParams) transient;
	agent.loadFiles();
	
epilog
	if clientLog &lt;&gt; null then
		clientLog.writeString(logger.getLogs());
		clientLog.commit();
		clientLog.close();
	endif;
	
	delete agent;
	
	// Unlink/delete our logger cmif
	self.setLogger(null);
	delete clientLog;
	
	terminate;
end;</source>
        <Parameter name="_initParams" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="initGetCommitHash" id="727e0a51-2130-41d9-ae75-5970e23eb20a">
        <source>initGetCommitHash();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 October 2025		navmd1	Initial creation DOMTN-285

*/

vars
	clientLog 	: File;
begin
	beginTransaction;
	process.userExitCode := 63;
	commitTransaction;
	
	create clientLog transient;
	clientLog.usePresentationFileSystem := true;
	clientLog.mode := File.Mode_Output;
	clientLog.kind := File.Kind_ANSI;
	clientLog.fileName := app.name &amp; ".log";
	
	clientLog.writeLine(GitFileLoadAgent@getLastGitHash());
	clientLog.commit();
	clientLog.close();
	
	beginTransaction;
	process.userExitCode := 0;
	commitTransaction;
epilog
	delete clientLog;
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="initLogFile" id="9ab1ff65-038e-411a-846a-f27c0231ef39">
        <updating/>
        <source>initLogFile() updating ,protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	24 Sep 2025	navmd1		A slimmed down version of the same from PortSchema
// ---------------------------------------------------------------------------
constants
	CN_BYTES_PER_MEGABYTE	: Integer = 1048576;
	CN_BYTES_PER_KILOBYTE	: Integer = 1024;
vars
	log			: JadeLog;
	sizeStr		: String;
	len			: Integer;
	factor		: String;
	maxSize		: Integer;
begin

	if self.myLogFile &lt;&gt; null then
		return;
	endif;
	
	sizeStr := self.getProfileStringAppServer(self.getIniFileNameAppServer(), "CardLog", "LogFileMaxSize", null);
	len		:= sizeStr.length;
	factor	:= sizeStr[len].toUpper();
	if factor = "M" then
		maxSize	:= sizeStr[1 : len - 1].trimBlanks.Integer * CN_BYTES_PER_MEGABYTE;
	elseif factor = "K" then
		maxSize	:= sizeStr[1 : len - 1].trimBlanks.Integer * CN_BYTES_PER_KILOBYTE;
	else
		maxSize	:= sizeStr.Integer;
	endif;
	
	if maxSize = 0 then
		maxSize := 10000;
	endif;
	
	create log;
	log.filePath		:= self.logPath;
	log.fileName		:= self.setLogFilename();
	log.versionFile		:= true;
	log.maxFileSize		:= maxSize;
	log.formatOutput	:= false;
	log.bufferOutput	:= true;

	self.myLogFile := log;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isInReorgOrVersionedState" id="74db1049-036d-489e-9c8e-3a537b90f732">
        <source>isInReorgOrVersionedState() : Boolean;
/*

Purpose:			Similar to CnJadeDatabaseAdminExternal::getVersionedOrReorgState work out if we're in a state that doing db commits would be bad

Parameters:			

Return Value:		

Date					Who		Reason
16 October 2024			navmd1	Initial creation Jira MTN-33098 Prevent Post-Refresh app from running in the middle of a online reorg

*/

vars
	scms	: SchemaColl;
	scm		: Schema;
begin
	if rootSchema.sendMsg("_reorgIsWaitingForTransition").Boolean then
		return true;
	endif;
	
	create scms transient;
	rootSchema.allSubschemas(scms);
	foreach scm in scms do
		if scm.sendMsg("_isVersioned").Boolean then
			return true;
		endif;
	endforeach;
	
	return false;
epilog
	delete scms;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="log" id="ef0f3345-da2f-40d3-946d-4f372c8146fe">
        <source>log(_log: String) protected;
//21 September 2010	cnwdw1	
//
vars

begin
	if self.myLogger &lt;&gt; null then
		self.myLogger.log(_log);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_log" type="String"/>
    </JadeMethod>
    <JadeMethod name="logPath" id="85e82a4d-6dbf-47e6-9900-08ad494fd750">
        <methodInvocation>mapping</methodInvocation>
        <source>logPath(set : Boolean; _value : String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 October 2025		navmd1	Initial creation

*/

vars
	logStr	: String;
begin
	if set then
		// set code here
	else
		logStr := self.getProfileStringAppServer(self.getIniFileNameAppServer(), "CardLog", "LogPath", null);
		if logStr = null or logStr.length &lt; 5 then
			self.raiseUnexpectedProgramError(class.name, method.name, "Unknown Log File location");
			return;
		endif;
		_value := logStr;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="raiseCMException2" id="249fc322-2dbd-4656-a5a3-351a9bf71b17">
        <source>raiseCMException2(errNo : Integer; param1, param2 : String; 
				  pAttrNameString : String; pGuiObject : Object);

vars
	exObj		: CM_Exception;
	sa  		: HugeStringArray;
begin

	create exObj transient;
	exObj.set(errNo, self.getErrorString2(errNo, param1, param2), false, pAttrNameString, pGuiObject, null);
	
	raise exObj;
epilog
	delete sa;
end;</source>
        <Parameter name="errNo" type="Integer"/>
        <Parameter name="param1" type="String"/>
        <Parameter name="param2" type="String"/>
        <Parameter name="pAttrNameString" type="String"/>
        <Parameter name="pGuiObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="raiseCMException3" id="c5abb1b2-6c99-4da3-9a05-2d4e781ed0ab">
        <source>raiseCMException3(errNo : Integer; param1, param2, param3 : String; 
				  pAttrNameString : String; pGuiObject : Object);

vars
	exObj		: CM_Exception;
	sa  		: HugeStringArray;
begin

	create exObj transient;
	exObj.set(errNo, self.getErrorString3(errNo, param1, param2, param3), false, pAttrNameString, pGuiObject, null);
	
	raise exObj;
epilog
	delete sa;
end;</source>
        <Parameter name="errNo" type="Integer"/>
        <Parameter name="param1" type="String"/>
        <Parameter name="param2" type="String"/>
        <Parameter name="param3" type="String"/>
        <Parameter name="pAttrNameString" type="String"/>
        <Parameter name="pGuiObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="raiseUnexpectedProgramError" id="ce1c45db-a245-4b44-ad9f-e486ebee5daf">
        <source>raiseUnexpectedProgramError(pClassName, pMethodName, pMessage : String);
// ---------------------------------------------------------------------------
// Created:     23 March 2001 by cnwrs2
//
// Purpose:     Raise an error for an unexpected exception. That indicate a
//				programming error, rather than a user input error.
//				ie. when a value is null that should never be null.
//
// Parameters:  Class name, Method name, Error message string
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	UNEXPECTED_PROGRAM_ERROR	: Integer = 75768;
vars

begin

	//app.setContinueCMExceptions(false);
	app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, pClassName, pMethodName, pMessage, null, null);

end;</source>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pMethodName" type="String"/>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLogFilename" id="7628ae81-f97a-4987-8b34-bb483ff073b3">
        <source>setLogFilename() : String protected;

/*

Date		Who		Reason
24 Sep 2025	navmd1	A slimmed down version of the same from PortSchema
	
*/

vars
	appName	: String;
begin
	appName := app.name;
	
	// If we're initialising app from a package exported from PortSchema, then use the calling Schema Apps name instead
	if appContext.initialPackage &lt;&gt; null then
		appName := appContext.initialProcess.persistentApp.name;
	endif;

	if process.isUsingThinClient then
		return appName &amp; "_" &amp; app.computerName &amp; "_ltl_" &amp; app.actualTimeServer.date.format('yyyMMdd') &amp; self.getInstanceIdForObject64(process).String;
	else
		return appName &amp; "_ltl_" &amp; app.actualTimeServer.date.format('yyyMMdd') &amp; self.getInstanceIdForObject64(process).String;
	endif;	

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setLogger" id="629f4c1f-e97a-4d61-b51b-00c7b32b625a">
        <updating/>
        <source>setLogger(_logger: CMIF_Logger) updating, protected;
//21 September 2010	cnwdw1	
//
vars

begin
	if self.myLogger &lt;&gt; null then
		delete self.myLogger;
	endif;
	self.myLogger := _logger;
	
end;</source>
        <access>protected</access>
        <Parameter name="_logger" type="CMIF_Logger"/>
    </JadeMethod>
    <JadeMethod name="writeLog" id="784c5132-1187-4625-9205-bbb8d9f57eca">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>writeLog(message : String; messageLevel : Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     15 December 2000 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Jan 2010	cnwkpd1		PAR #22185 - Fix up timestamp logging
// 08 May 2018	jlgkpd1		TFS 38556 - added clientExecution to signature
// 22 Nov 2019	NDL	TFS 47053
// ---------------------------------------------------------------------------
/*

	This writes to a log file called something like 
	
	jmterminal_&lt;pc name&gt;_ltl_&lt;number&gt;.log
	
*/
vars

	ts : TimeStamp;
	logStr : String;
	dateTimeStr : String;
	logLevelStr : String;
	threadId : String;

begin

	if messageLevel &gt; self.logLevel then
		return;
	endif;

	if self.myLogFile = null then
		self.initLogFile;
	endif;

	ts := app.actualTimeServer();	
	dateTimeStr :=  ts.date.format("dd-MM-yy") &amp; ' ' &amp; ts.time.format("HH:mm:ss") &amp; '.' &amp; ts.time.milliSecond.padLeadingWith("0", 3);
	
	logLevelStr := app.getLoggingLevelString( messageLevel );
	
	threadId := app.name &amp; "/" &amp; self.cnGetInstanceId64(process).String;
			  
	logStr := dateTimeStr &amp; ' ' &amp; logLevelStr &amp; ' ' &amp; threadId &amp; ' ' &amp; message;

	self.myLogFile.log(logStr);		// Log Server
	self.log(logStr);				// Log Client
end;</source>
        <Parameter name="message" type="String"/>
        <Parameter name="messageLevel" type="Integer"/>
    </JadeMethod>
</Class>
