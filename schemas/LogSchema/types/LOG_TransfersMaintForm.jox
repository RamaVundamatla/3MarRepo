    <JadeMethod name="displayLocation" id="90111805-96c9-44c2-b3e6-cbf1c084e1dc">
        <updating/>
        <source>displayLocation(_location: CM_LogController input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2008	cnwar2	Initial creation
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	ti			: CM_TrackedItem;
	analysis	: CM_SOHLocation;
	tmpDef		: CMIF_DocketLogDef;
	bol			: String;
	bolFound	: Boolean;
	logProduct	: CM_ProductLog;
	failedDAC  	: CM_DataAccessController;
	volume		: Decimal[12,2];
	species, grade, type, treatment, length : String;
		
begin
	if not self.selection = LOGLOCATDOCKET then
		inheritMethod(_location);
	else
	
		if _location &lt;&gt; null then
			self.allDocketLogDef.purge;
			
			if _location.myTerminalArea.isStockControlled then
				// Get analysis data from location.
				foreach analysis in _location.allProductLocations do
					if analysis.myProduct.isKindOf(CM_ProductLog) and analysis.allTrackedItems.size &gt; 0 then	
						logProduct := analysis.myProduct.CM_ProductLog;
						if (not logProduct.canUserAccessSelf(null, failedDAC,app.myPassport)) then
							continue;
						endif;
						// Once we have a code extract relevant details.
						grade 		:= logProduct.gradeCode;
						species 	:= logProduct.speciesCode;
						type 		:= logProduct.typeCode;
						length 		:= logProduct.lengthCode;
						treatment	:= logProduct.treatmentCode;
					endif;
					
					foreach ti in analysis.allTrackedItems do
						bol	:= ti.billOfLading;
						if bol = null then
							if ti.myReceivalBOL &lt;&gt; null then
								bol := ti.myReceivalBOL.number;
							elseif ti.myReleaseBOL &lt;&gt; null then
								bol := ti.myReleaseBOL.number;
							endif;
						endif;
						
						// Search for tmpDef for docket, if found add ti
						bolFound := false;
						foreach tmpDef in self.allDocketLogDef do
							if tmpDef.id = bol then
								bolFound := true;
								tmpDef.init(tmpDef.myLocationsController, tmpDef.myOperator, tmpDef.species, tmpDef.grade, tmpDef.type, tmpDef.treatment, tmpDef.length, false, tmpDef.numberOfLogs + 1, tmpDef.volume + ti.getMyTotalVolume, null);
								tmpDef.id := bol;
								tmpDef.allTi.add(ti);
								break;
							endif;
						endforeach;
						
						// If not, create tmpDef for docket
						if not bolFound then
							create tmpDef transient;
							tmpDef.init(_location, logProduct.myOperator, species, grade, type, treatment, length, false, 1, ti.getMyTotalVolume, null);
							tmpDef.id := bol;
							tmpDef.allTi.add(ti);
							self.allDocketLogDef.add(tmpDef);
						endif;
					endforeach;
					
				endforeach;
				
			else
				create tmpDef transient;
				tmpDef.init(_location, null, null, null, null, null, null, false, 0,0, null);
				beginLoad;
				tmpDef.copyTis(_location.allTrackedItems, true);
				endLoad;
				self.allDocketLogDef.add(tmpDef);
			endif;
			
			// Load up data for display.
			self.setSelectionData();
			self.myLocation := _location;
		endif;
		
	endif;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <access>protected</access>
        <Parameter name="_location" type="CM_LogController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="9ada969d-8159-42a9-bc9a-843747d2aa05">
        <updating/>
        <source>doRefresh() updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 July 2006 by cnwdad1
//
// Purpose:		Reimplementation of the standard refresh method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/07/2006	cnwdad1		PAR #11909 - Implemented this method.
// --------------------------------------------------------------------------------
vars
	locationObj	: Object;
	listPointer	: Integer;
	
begin
	if (self.selection = LOGLOCATION or self.selection = LOGLOCATDOCKET) and cmbLocation.listIndex &lt;&gt; CNEC_NULL_INDEX then
		locationObj	:=	cmbLocation.listObject;
	endif;

	inheritMethod();
	
	if (self.selection = LOGLOCATION or self.selection = LOGLOCATDOCKET) and locationObj &lt;&gt; null then
		listPointer	:=	cmbLocation.findObject(locationObj);
		
		if listPointer &lt;&gt; CNEC_NULL_INDEX then
			cmbLocation.listIndex	:=	listPointer;
			self.startSearch();
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
