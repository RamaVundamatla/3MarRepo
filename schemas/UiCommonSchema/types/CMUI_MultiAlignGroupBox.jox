    <JadeMethod name="setAsAlignOnly" id="f90ed4f8-f3fa-486b-8933-1d46bd3e2098">
        <source>setAsAlignOnly();
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		this gets rid of the left hand table so that you just have the single list and up/down buttons
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
//	self.mySelectedLbl.visible := false;
//	self.mySelectedListBox.visible := false;
	self.myAvailableLbl.visible := false;
	self.myAvailableListBox.visible := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="setItemsOnLeftSide" id="83386e72-9e4f-4202-a25c-eaa7be788202">
        <updating/>
        <source>setItemsOnLeftSide(_theLeftCollection : Collection; _doClearSelectedFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		: Object;
	idx		: Integer;
	iter	: Iterator;
	include	: Boolean;
	tmpStr	: String;
	
begin

	self.myAvailableListBox.clear;
	self.myAvailableListBox.sorted := false;
	
	if _doClearSelectedFirst then
		self.myAvailableListBox.clear;
	endif;

	iter := _theLeftCollection.createIterator();
	while (iter.next(obj)) do
		tmpStr := self.displayEntry(obj);
		if tmpStr &lt;&gt; null then
			idx := self.myAvailableListBox.addItem(tmpStr);
			self.myAvailableListBox.itemObject[idx] := obj;
		endif;
	endwhile;
	self.selectFirst(true);
	
epilog
	delete iter;

end;</source>
        <Parameter name="_theLeftCollection" type="Collection"/>
        <Parameter name="_doClearSelectedFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setItemsOnRightSide" id="c2b20684-2bc9-4019-b2ca-69d8dfe11629">
        <updating/>
        <source>setItemsOnRightSide(_theRightCollection : Collection; _doClearSelectedFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		: Object;
	idx		: Integer;
	iter	: Iterator;
	include	: Boolean;
	tmpStr	: String;
	
begin

	self.mySelectedListBox.clear;
	self.mySelectedListBox.sorted := false;
	if _doClearSelectedFirst then
		self.mySelectedListBox.clear;
	endif;

	iter := _theRightCollection.createIterator();
	while (iter.next(obj)) do
		tmpStr := self.displayEntry(obj);
		if tmpStr &lt;&gt; null then
			idx := self.mySelectedListBox.addItem(tmpStr);
			self.mySelectedListBox.itemObject[idx] := obj;
		endif;
	endwhile;
	self.selectFirst(true);
	
epilog
	delete iter;

end;</source>
        <Parameter name="_theRightCollection" type="Collection"/>
        <Parameter name="_doClearSelectedFirst" type="Boolean"/>
    </JadeMethod>
