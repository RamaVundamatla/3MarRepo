    <JadeMethod name="isWOWaterInvoice" id="0005f372-b186-44b8-b059-ea720d16f914">
        <source>isWOWaterInvoice() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2019	jlger1	Initial creation TFS 44550 refactored from CM_Pelindo1Interface

*/

vars
	wo     : CM_WorkOrder;
	woDtl  : CM_WorkOrderDtl;
	invLine: CM_InvoiceLine; 
begin
	
	if self.myVoyage = null then
		return false;
	endif;
	
	
	foreach wo in self.myVoyage.allWorkOrders discreteLock do
		if not wo.isVoyageWorkOrder then
			continue;
		endif;
		if wo.isCancelled then
			continue;
		endif;
		
		if wo.isWorkOrderForWater then //10/10/21 jlier1	TFS 51963
			break;
		endif;
	
	endforeach;
	
	if wo &lt;&gt; null then
		if wo.isWorkOrderForWater then
			woDtl := wo.allWoDtls.first;
			if woDtl &lt;&gt; null and woDtl.isKindOf(CM_WodWaterRequest) then
				foreach invLine in self.invoiceLines discreteLock do
				
				if invLine.myTransactionHMS &lt;&gt; null and invLine.myTransactionHMS.myResourceUsed &lt;&gt; null then            //10.12.2018 cnwma1	Bug 42455
					if woDtl.CM_WodWaterRequest.myHMSResource = invLine.myTransactionHMS.myResourceUsed .myResource	then
							return true;
					endif;
				endif;
				endforeach;
			endif;
		
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWebInvoice" id="d1d647ce-6d35-4ac7-8e9b-098d96fb24b7">
