    <JadeMethod name="validateView" id="9ceb6b40-e66c-44c9-a609-b50880908e4b">
        <source>validateView(_viewName : String) : Integer;
// validate a given reporter view, returning the error count
vars
	scm		: Schema;
	cls		: Class;
	mkd		: MemberKeyDictionary;
	root	: Object;	// JRDRoot
	context	: Object;	// JRDReportContext;
	view	: Object;	// JRDReportingView
	collDef	: Object;	// JRDReportingCollectionDefn;
	typeDef	: Object;	// JRDReportingTypeDefn;
	fieldDef	: Object; // JRDReportingFieldDefn;
	typeDefnType	: Type;
	pathName	: String;
	scmName		: String;
	result	: Integer;
	errorCount	: Integer;
begin
	scm := rootSchema.getSchema("JadeReportWriterSchema");
	if scm = null then
		return -1;
	endif;
	cls := scm.getClass("JRDRoot");
	if cls = null then
		return -1;
	endif;
	root := cls.firstInstance;
	if root = null then
		return -1;
	endif;
	// create a transient JRDReportContext if missing, is needed by the report writer methods
	context := root.sendMsg("getContext").Object;
	mkd := root.getPropertyValue("allReportingViews").MemberKeyDictionary;
	view := mkd.getAtKey(_viewName);
	if view = null then
		return -1;
	endif;
	
	cls := scm.getClass("JRDReportContext");
	if cls = null then
		return -1;
	endif;
	// can't validate if view lowestLevelSchemaName is not defined (gets exceptions in the report writer methods)
	scmName := view.getPropertyValue("lowestLevelSchemaName").String;
	if rootSchema.getSchema(scmName) = null then
		return -1;
	endif;
	
	mkd := view.getPropertyValue("allReportCollDefns").MemberKeyDictionary;
	foreach collDef in mkd do
		pathName := collDef.getPropertyValue("pathName").String;
		result := view.sendMsgWithParams("validateCollectionPath", pathName).Integer;
		if result &lt;&gt; 0 then
			errorCount := errorCount + 1;
		endif;
		mkd := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		foreach typeDef in mkd do
			result := view.sendMsgWithParams("validateTypeDefinitionT", typeDef).Integer;
			if result &lt;&gt; 0 then
				errorCount := errorCount + 1;
			endif;
			typeDefnType := typeDef.sendMsg("getType").Type;

			mkd := typeDef.getPropertyValue("allReportingFields").MemberKeyDictionary;
			foreach fieldDef in mkd do
				result := typeDef.sendMsgWithParams("validateFieldDefnT", fieldDef, typeDefnType).Integer;	
				if result &lt;&gt; 0 then
					errorCount := errorCount + 1;
				endif;
			endforeach;
		endforeach;
	endforeach;

	return errorCount;
epilog

end;</source>
        <Parameter name="_viewName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
