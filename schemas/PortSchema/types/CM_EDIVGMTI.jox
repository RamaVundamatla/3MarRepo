    <JadeMethod name="assignValueSpecial" id="5a66e70c-22b8-4ef0-ae8c-03c434721ff4">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//4/9/24 		navsaa30 Bug 63853: EUP | FR 53158 (CARGO ON SHIP) - Additional Fields - EDI loaded dimensions are not processed correctly (Precision issue)
//
vars

begin
	if _propName = ETRow_TotalWeight then
		if _processedValue = null then
			self.setPropertyValue(ETRow_TotalWeight, NULL_WEIGHT);
		else
			self.setPropertyValue(ETRow_TotalWeight, _processedValue.asDecimalJMT);				//4/9/24   navsaa30  #63853
		endif;
		return true;
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="b0b37bd8-f3a0-4970-836f-33eae3f748aa">
        <updating/>
        <source>create() updating;
//
//15 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
//26 Apr 2016	cnwrs1	TFS 1906 VGM via CSV
vars

begin
	self.messageMode := CM_EDITrackedItem.EDI_ACTION_UPDATE;
	self.cargoType := TI_CargoType_Container;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5d2e1fea-eaa7-45f9-a165-c00de467b760">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
vars
	str : String;
	type : String;
begin
	if _attrName.isMeasurementType then												// PAR #31155
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	// PAR #31155
		_attrName.getRowNameMeasureType(str, type);									// PAR #31155
		return self.getMeasurementStringForAttrib(str, type, _short);				// PAR #31155
	else
		return inheritMethod(_attrName, _short);
	endif;
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
