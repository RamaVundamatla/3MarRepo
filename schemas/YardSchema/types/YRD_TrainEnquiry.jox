    <JadeMethod name="doMnuContextVisibility" id="b9edd3c6-03e1-4b19-9a4a-35b286462495">
        <source>doMnuContextVisibility(_value : Boolean)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2009	cnwmd1	Initial creation
27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI
*/

vars

	obj : Object;
	hasAudits : Boolean;

begin
	self.mnuInspectObject.visible := app.isAllowedToInspect and _value;
	
	self.mnuContextJobNew.visible := _value;
	self.mnuContextJobEdit.visible := _value;
	self.mnuContextJobDelete.visible := false; // DQ said no
	self.mnuContextCopy.visible := _value;
	self.mnuContextSep02.visible := _value;
	
	self.mnuContextRailRequest.visible := _value;
	self.mnuContextConfirmInwd.visible := false; // DQ said no
	self.mnuContextConfirmOutwd.visible := false; // DQ said no
	self.mnuContextMoveTrain.visible := false; // DQ said no
	self.mnuContextDeparturePrc.visible := false; // DQ said no
	self.mnuContextTrainRemarks.visible := _value;
	self.mnuContextSep03.visible := _value;
	
	self.mnuContextTrainRemarks.visible := _value;
	self.mnuContextEnquiryIn.visible := _value;
	self.mnuContextEnquiryOut.visible := _value;
	self.mnuContextCargoRcd.visible := _value;
	self.mnuContextCargoRel.visible := _value;
	self.mnuContextSummarizeIn.visible := _value;
	self.mnuContextSummarizeOut.visible := _value;
	self.mnuContextSepe04.visible := _value;
	
	self.mnuInvRefresh.visible := _value;
	
	self.mnuContextSep01.visible := _value;
	
	self.mnuContextRailOps.visible := _value;	//21 Jul 2009 NDL CCMS 1067
	self.mnuContextTrainPlan.visible := _value; //21 Jul 2009 NDL CCMS 1067
	self.mnuContextLoadList.visible := _value;	//30 Jul 2009 NDL CCMS 1067
	
	//12 Jun 2013	NDL	Par 31687
	if _value then
		obj := self.tblData.accessedRow.itemObject;
		if obj &lt;&gt; null and CM_Train.hasInstance(obj) then
			hasAudits := obj.CM_Train.hasAudits; //14 Jan 2021	NDL	TFS 50152
		endif;
	endif;
	/* TFS BUG 58789 26JUNE2023 NAVAB1
	self.mnuInvAudits.visible := _value and hasAudits;	//12 Jun 2013	NDL	Par 31687
	self.mnuInvAudits.caption := app.getErrorString(View_audits);
	*/
	self.mnuAuditsForObject.visible := _value and hasAudits; // TFS BUG 58789 26JUNE2023 NAVAB1
	
	self.mnuCargoReview.visible  := _value;//27/09/2023	navkc1	CR 60428 Task 60702
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuContextJobNew.visible := false;
		self.mnuContextJobEdit.visible := false;
		self.mnuContextJobDelete.visible := false; 
		self.mnuContextCopy.visible := false;
		self.mnuContextSep02.visible := false;
		
		self.mnuContextRailRequest.visible := false;
		self.mnuContextConfirmInwd.visible := false; 
		self.mnuContextConfirmOutwd.visible := false; 
		self.mnuContextMoveTrain.visible := false;
		self.mnuContextDeparturePrc.visible := false; 
		self.mnuContextTrainRemarks.visible := false;
		self.mnuContextSep03.visible := false;
		
		self.mnuContextTrainRemarks.visible := false;
		self.mnuContextSepe04.visible := false;
		
		
		
		self.mnuContextSep01.visible := false;
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
