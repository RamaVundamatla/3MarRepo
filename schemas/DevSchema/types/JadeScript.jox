    <JadeMethod name="sh3CheckLogRows" id="57c2e24a-08df-476d-a1fb-0c46a4619466">
        <source>
sh3CheckLogRows();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 17 September 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars
	lc : CM_LogController;
	pl : CM_SOHLocation;
	logProduct : CM_ProductLog;
	failedDAC  	: CM_DataAccessController;
	volume		: Decimal[12,2];
	species, grade, type, treatment, length : String;
	ti			: CM_TrackedItem;
	bol			: String;
	bolFound	: Boolean;
	tmpDef		: CMIF_DocketLogDef;
	allDocketLogDef : CMIF_DocketLogDefByLocation;
begin
	self.sh3StandardInitialize();
	create allDocketLogDef transient;
	lc := '4353.139'.asOid.CM_LogController;
	if lc.myTerminalArea.isStockControlled then
		// Get pl data from location.
		foreach pl in lc.allProductLocations do
			if pl.myProduct.isKindOf(CM_ProductLog) and pl.allTrackedItems.size &gt; 0 then	
				logProduct := pl.myProduct.CM_ProductLog;
				if (not logProduct.canUserAccessSelf(null, failedDAC,app.myPassport)) then
					continue;
				endif;
				// Once we have a code extract relevant details.
				grade 		:= logProduct.gradeCode;
				species 	:= logProduct.speciesCode;
				type 		:= logProduct.typeCode;
				length 		:= logProduct.lengthCode;
				treatment	:= logProduct.treatmentCode;
			endif;
			
			foreach ti in pl.allTrackedItems do
				bol	:= ti.billOfLading;
				if bol = null then
					if ti.myReceivalBOL &lt;&gt; null then
						bol := ti.myReceivalBOL.number;
					elseif ti.myReleaseBOL &lt;&gt; null then
						bol := ti.myReleaseBOL.number;
					endif;
				endif;
				
				// Search for tmpDef for docket, if found add ti
				bolFound := false;
				foreach tmpDef in allDocketLogDef do
					if tmpDef.id = 'YITEST001' then
					//	write  'here';
					endif;
					if tmpDef.id = bol then
						bolFound := true;
						tmpDef.init(tmpDef.myLocationsController, tmpDef.myOperator, tmpDef.species, tmpDef.grade, tmpDef.type, tmpDef.treatment, tmpDef.length, false, tmpDef.numberOfLogs + 1, tmpDef.volume + ti.getMyTotalVolume, null);
						tmpDef.id := bol;
						tmpDef.allTi.add(ti);
						break;
					endif;
				endforeach;
				
				// If not, create tmpDef for docket
				if not bolFound then
					create tmpDef transient;
					tmpDef.init(lc, logProduct.myOperator, species, grade, type, treatment, length, false, 1, ti.getMyTotalVolume, null);
					tmpDef.id := bol;
					tmpDef.allTi.add(ti);
					write CrLf;
					write tmpDef.id &amp; ' id';
					write tmpDef.myLocationsController.String &amp; ' lc';
					write tmpDef.myOperator.String &amp; ' Op';
					write tmpDef.species &amp; ' species';
					write tmpDef.grade &amp; ' grade' ;
					write tmpDef.type &amp; ' type';
					write tmpDef.treatment &amp; ' treatment' ;
					write tmpDef.length &amp; ' length';
					write tmpDef.isNoNumber.String &amp; ' isNN' ;
					write tmpDef.myBol.String &amp; ' mybol';
					allDocketLogDef.add(tmpDef);
				endif;
			endforeach;
			
		endforeach;
	endif;
epilog
	delete allDocketLogDef;
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3CheckRevenueTons" id="33e28199-8a55-411e-b345-48fc8ccb5770">
        <source>sh3CheckRevenueTons();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 20 September 2012
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	invLineDesc	: CM_InvoiceLineDesc;
	invLine		: CM_InvoiceLine;
	val			: Real;
begin
	foreach invLineDesc in CM_InvoiceLineDesc.instances where invLineDesc.getChargeByUnits() = INV_CALC_TYPE_REVENUE_TONS do
		write invLineDesc;
	endforeach;
	
	foreach invLine in CM_InvoiceLine.instances do
		val := invLine.getTrackedItemVolume();
		if val &gt; 0 then
			write invLine.String &amp; ' - ' &amp; val.String;
		endif;
	endforeach;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3CheckValidASCIIChars" id="8472f822-29af-4c50-81d4-ebe489fb3814">
        <source>sh3CheckValidASCIIChars();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 05 December 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
//----------------------------------------------------------------------
constants
TheString = "Buon giorno,

a partire da oggi 2 dicembre riceverete in automatico il report relativo alle giacenze dei rotabili al terminal. Il report avrŕ periodicitŕ mensile. Come indicato dall'avv. Domini si tengono in considerazione giacenze uguali o superiori ai 100 giorni.

Per eventuali modifiche o richieste potete contattarci al seguente indirizzo e-mail: 

ppr.controlroom@messinaline.it

o a questi numeri diretti:

2462 Bregante

2827 Vaccarezza

Grazie.

Saluti";
vars
	isCurrentLineTruncated	:	Boolean;	//V2
	startPtr				:	Integer;
	endPtr					:	Integer;
	msgLength				:	Integer;
	linePtr					:	Integer;
	tmpMessage				:	String;
	className				:	String;
	line					:	String;

begin

    //Validate the contents of the message (e.g. all characters must be within the ASCII set)

 //   on CnSmtpConnectionException do validationExceptionHandler(exception);

    tmpMessage	:=	TheString;
    
    // pOutMessage is the string that we're going to build
    //	:=	null;
    className	:=	self.getName &amp; "::" &amp; method.name;	//V5

    startPtr	:=	1;
	msgLength	:=	tmpMessage.length;

    //Iterate through whole message doing various checks
    while startPtr &lt;= msgLength do

    	// Look for CrLf so we can isolate the next line
    	endPtr	:=	tmpMessage.pos(CrLf, startPtr);

    	//If CrLf not found, this partial line is at the end of a block
    	if endPtr = null then
    		line					:=	tmpMessage[startPtr : end];
    		isCurrentLineTruncated	:=	true;	//V2
    	else

    		// We found CrLf.

    		//Cater for case where the line consists only of CrLf. The CrLf will be appended to pOutMessage further down.
    		if endPtr = startPtr then
    			line	:=	"";						//V2
    		else	

    			// Line contains at least one character followed by CrLf
    			line	:=	tmpMessage[startPtr : endPtr - startPtr];

            endif;

    		//Cater for case where CrLf are the last characters of the block
    		if endPtr = tmpMessage.length -1 and tmpMessage[endPtr:2] = CrLf then
    			line	:=	line &amp; CrLf;	//Append the CrLf now	//V2
    			endPtr	:=	null;		//Indicates end of block reached
    		endif;
    	endif;

     	// We now have a line. This is either a line terminated by CrLf, a line that ends with Cr (which we regard as a
     	// truncated line) or a line that does not contain CrLf at all (also a truncated line).

    	//Check that the line is not greater than 1000 characters (RFC 821 limit)
    	if line.length &gt; 1000 then
    		//raiseValidationException(Err_Line_Exceeds_1000, className &amp; " One of the message lines exceeds 1000 characters");//V4
    	endif;

        //Check that no character is outside the ASCII range (RFC 821 rule)
        linePtr			:=	1;

        while linePtr &lt;= line.length do
        	if line[linePtr].Character.Integer &gt; 127 or line[linePtr].Character.Integer = null then
				write line[linePtr].Character;
				write 'found it';
	    		//raiseValidationException(Err_Non_ASCII_Character, className &amp; " The message contains a non-ASCII character in the following line (" &amp; line &amp; ")");//V4
        	endif;
        	linePtr		:=	linePtr + 1;
        endwhile;

        //If this line starts with a period, then 'stuff' another period into the beginning of the line. Allows for data transparency (See RFC 821 section 4.5.2).
        //If the previous line was truncated, because it straddled two blocks, we don't treat the current line as a new line, but as part
        //of the previous one. 
     /*   if pWasPreviousLineTruncated = false then	//V2
         	if	line[1] = "." then					//V2
        	 	line	:=	"." &amp; line;
        	endif;
        else

        	//If the previous line was truncated, the last character of the previous line could have been Cr.
			//Therefore when handling truncated lines, we look for a Lf as the first character of the current line, and if it exists, we
			//look at the SECOND character to see if it's a period.

        	if line.length &gt; 1 and line[1] = Lf and line[2] = "." then	//V3
        		line	:=	Lf &amp; "." &amp; line[2:end];     //V2
        	endif;				                    //V2
        endif;                                      //V2
        pWasPreviousLineTruncated	:=	false;		//V2 We've now dealt with that line, so set the flag false

        //If this is the last (or only) line in the block, or a part-line that occurs on the block boundary, don't add a CrLf
        if endPtr = null then
        	pOutMessage := pOutMessage &amp; line;
           break;	//Exit from the method
        else
       		pOutMessage := pOutMessage &amp; line &amp; CrLf;
        endif;		
*/
    	startPtr := endPtr + 2;
    endwhile;

	// Indicate whether the last line of the block was truncated. This parameter is passed back to us next time we enter the method.
	//pWasPreviousLineTruncated	:=	isCurrentLineTruncated;	//V2			

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3CleanupRoadOps" id="fe970420-fa08-4137-9841-afeace4acf00">
        <source>sh3CleanupRoadOps();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		30 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
//----------------------------------------------------------------------
constants
	Reg : String = "54534";
vars
	vehicle: CM_Vehicle;
	job: CM_Job;
	terminal: CM_Terminal;
	reg : String;
	ti : CM_TrackedItem;
begin
	self.sh3StandardInitialize();
	
	terminal := app.myPassport.myTerminal;
	
	vehicle := terminal.vehicles[Reg.String, ""];

	if vehicle &lt;&gt; null then
		foreach job in vehicle.allRoadJobs do
			//self.deleteJob(job);
			if job.isKindOf(CM_RoadJob) then
				foreach ti in job.CM_RoadJob.allReceiveTrackedItems do
					self.sh3UnplanTI(ti);
					self.sh3UnqueueTI(ti);
					app.myPassport.setWarningsIgnored(true);
					app.myTrxDA.trxDeleteTI(ti, true, app.myPassport);
					//delete ti
				endforeach;
				foreach ti in job.CM_RoadJob.allReleaseTrackedItems do
					self.sh3UnplanTI(ti);
					self.sh3UnqueueTI(ti);
					app.myPassport.setWarningsIgnored(true);
					app.myTrxDA.trxDeleteTI(ti, true, app.myPassport);
					
					//delete ti
				endforeach;
			endif;
			app.myPassport.setWarningsIgnored(true);
			app.myTrxDA.trxDeleteJob(job, app.myPassport);
		endforeach;
		
		app.myPassport.setWarningsIgnored(true);
		
		app.myTrxDA.trxDeleteVehicle(vehicle, app.myPassport); 
		//assertNoTrxErrorsOrWarnings();
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="sh3DateTest" id="bbea94f8-63eb-43d5-bf88-ad838238f8d7">
        <source>sh3DateTest();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 01 March 2012
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	date : Date;
	cont : CM_Container;
begin
	write date;
	date := null;
	write '1';
	write date;
	write '2';
	
	cont := '2367.1156985'.asOid.CM_Container;
	write cont.unpackedDT.date();
	write '3';
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3ExtractConstant" id="0efdd9c2-7e84-4b84-a945-f7380fd122ed">
        <source>sh3ExtractConstant();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 24 November 2010
//
// Implemented version: JMT 7.9.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	deRef : Any;
	entTblAgent	: EntTableAgent;
	tmpArray : StringArray;
	agent : CM_TranslationAgent;
begin
	app.initialize();
	create entTblAgent transient;
	create agent transient;
	entTblAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	create tmpArray transient;
	write ETDef_MachineHistoryReport;
	tmpArray.add('ETDef_MachineHistoryReport');
	
	// Do update/add Entry Table global constants
	entTblAgent.trxUpdateFromConstant(tmpArray);
	app.finalize();
epilog
	delete entTblAgent;
	delete tmpArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3FileRead" id="1008fb17-c1b3-4502-92f3-aaffea64e07a">
        <source>sh3FileRead();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 30 August 2013
//
// Implemented version: JMT 8.2.1
// Date  		User  		Change
//----------------------------------------------------------------------
constants
	
vars
	file1,
	outputFile : File;
	fileOpen : CMDFileOpen;
	fieldArray : StringArray;
	codeArray : StringArray;
	entry : String;
	theCode : String;
	greaterThan5,
	alreadyExists : Integer;
begin

	create fieldArray transient;
	create codeArray transient;
	
	create fileOpen transient;
	fileOpen.fileMustExist := true;
	fileOpen.filter := "CSV (*.csv)|*.csv|All files (*.*)|*.*";
	
	if fileOpen.open &lt;&gt; 0 then
		return;
	endif;
	
	create file1 transient;
	file1.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	
	file1.fileName := fileOpen.fileName;
	file1.mode := File.Mode_Input;
	if not file1.tryOpen then
		write 'Failed';
		return;
	endif;
	
	create outputFile transient;
	outputFile.mode := File.Mode_Input;
	outputFile.allowCreate := true;
	outputFile.allowReplace := true;
	outputFile.fileName := "c:\aJunk\ConsigneeOUTPUT2.csv";
	outputFile.openOutput(outputFile.fileName);
	
	while not file1.endOfFile do
		process.sleep(1);
		
		fieldArray.clear;
		entry := file1.readLine();
		entry.csvToStringArray(fieldArray, ",");
		
		theCode := fieldArray[1];
		
		//write theCode;
		//continue;
		if theCode.length &gt; 5 then
			write theCode &amp; ' is greater than 5. Should be ' &amp; theCode[1:5];
			greaterThan5 := greaterThan5 + 1;
			theCode := theCode[1:5];
			fieldArray[1] := theCode;
		endif;
		
		outputFile.writeLine(fieldArray.asCSV(true));
		
		continue;
		if codeArray.includes(theCode) then
			write theCode &amp; ' has already been added';
			alreadyExists := alreadyExists + 1;
		else
			codeArray.add(theCode);
		endif;
	
	endwhile;
	
	write greaterThan5.String &amp; ' consignees have a code greater than 5 chars in length';
	write alreadyExists.String &amp; ' consignees have duplicate codes';
	
epilog
	outputFile.close;
	delete fileOpen;
	delete fieldArray;
	delete codeArray;
	delete file1;
	
	delete outputFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3FileSeparatorCheck" id="a6ee17b0-1cc7-4256-bc02-0916d243aad5">
        <source>sh3FileSeparatorCheck();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		28 July 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	fileName 	: String;
	namePos,
	pos,
	fileLength 	: Integer;
begin
		fileName	:=	'E:\BGP';
		fileLength := fileName.length;
		if fileName.pos("\", 1) &gt; 0 then
			if not fileName[fileLength] = '\' and
			   not fileName[fileLength] = '/' then
				fileName := fileName &amp; '\';
			endif;
		elseif fileName.pos("/", 1) &gt; 0 then
			if not fileName[fileLength] = '/' and
			   not fileName[fileLength] = '\'then
				fileName := fileName &amp; '/';
			endif;
		endif;
		
		write fileName;
		
epilog
end;</source>
    </JadeMethod>
