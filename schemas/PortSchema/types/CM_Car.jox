    <JadeMethod name="setUserDefinedTI" id="179d3134-3f33-4bc1-8ecd-bc29fea5a113">
        <updating/>
        <source>setUserDefinedTI(_ediTi: CM_EDICargoTI; _site: Integer; _terminal: CM_Terminal; _updateController: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	26 February 2010 By Graeme Black cnwgb1 PAR 22476
// Purpose:	Sets the values from an EDi Cargo load
// ---------------------------------------------------------------------------
// 30 May 2012	cnwrs1	DPH Cargo TI changes
// 20 Sep 2013	cnwdap1	PAR #32215 CCMS DPH 2290 New Car Attributes
vars
	
begin
	inheritMethod(_ediTi, _site, _terminal, _updateController, _passport);
	self.hasRadio := _ediTi.hasRadio.Integer;// cnwgb1 HACK in 781 misses "Don't Know" (=-1)
	self.selfPropelled := _ediTi.selfPropelled;
	self.carType := _ediTi.carType;
	self.certificate1 := _ediTi.certificate1;
	self.certificate1Expiry := _ediTi.certificate1Expiry;
	self.certificate2 := _ediTi.certificate2;
	self.certificate2Expiry := _ediTi.certificate2Expiry;
	self.chassisNo := _ediTi.chassisNo;
	self.colour := _ediTi.colour;
	self.engineNo := _ediTi.engineNo;
	self.make := _ediTi.make;
	self.model := _ediTi.model;
	self.registration := _ediTi.registration;
	self.vin := _ediTi.vin;
	self.year := _ediTi.year;
	
	self.trackingNumber1 := _ediTi.trackingNumber1;			// PAR #32215
	self.trackingNumber2 := _ediTi.trackingNumber2;			// PAR #32215
	self.docsReceived.setDate(_ediTi.docsReceived);			// PAR #32215
	self.docsSent.setDate(_ediTi.docsSent);					// PAR #32215
	self.docsCleared.setDate(_ediTi.docsCleared);			// PAR #32215
	self.docsReturned.setDate(_ediTi.docsReturned);			// PAR #32215
	self.selfPropelled := _ediTi.selfPropelled;				// PAR #32215
	self.nbrDoors := _ediTi.doors;							// PAR #32215
	self.isNew := _ediTi.isNew;								// PAR #32215
epilog
end;</source>
        <Parameter name="_ediTi" type="CM_EDICargoTI"/>
        <Parameter name="_site" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setUserDefinedTIForModify" id="e65b348b-5d22-411d-b485-c1783a5b1905">
        <updating/>
        <source>setUserDefinedTIForModify(_ediTi: CM_EDICargoTI; _terminal: CM_Terminal; _updateController: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2014	cnwmc5	Initial creation	CCMS 2352

*/

vars

begin
	inheritMethod(_ediTi, _terminal, _updateController, _passport);
	
	self.hasRadio := _ediTi.hasRadio.Integer;// cnwgb1 HACK in 781 misses "Don't Know" (=-1)
	
	if _ediTi.selfPropelled &lt;&gt; null then
		self.selfPropelled := _ediTi.selfPropelled;
	endif;
	
	if _ediTi.carType &lt;&gt; null then
		self.carType := _ediTi.carType;
	endif;
	
	if _ediTi.certificate1 &lt;&gt; null then
		self.certificate1 := _ediTi.certificate1;
	endif;
	
	if _ediTi.certificate1Expiry &lt;&gt; null then
		self.certificate1Expiry := _ediTi.certificate1Expiry;
	endif;
	
	if _ediTi.certificate2 &lt;&gt; null then
		self.certificate2 := _ediTi.certificate2;
	endif;
	
	if _ediTi.certificate2Expiry &lt;&gt; null then
		self.certificate2Expiry := _ediTi.certificate2Expiry;
	endif;
	
	if _ediTi.chassisNo &lt;&gt; null then
		self.chassisNo := _ediTi.chassisNo;
	endif;
	
	if _ediTi.colour &lt;&gt; null then
		self.colour := _ediTi.colour;
	endif;
	
	if _ediTi.engineNo &lt;&gt; null then
		self.engineNo := _ediTi.engineNo;
	endif;
	
	if _ediTi.make &lt;&gt; null then
		self.make := _ediTi.make;
	endif;
	
	if _ediTi.model &lt;&gt; null then
		self.model := _ediTi.model;
	endif;
	
	if _ediTi.registration &lt;&gt; null then
		self.registration := _ediTi.registration;
	endif;
	
	if _ediTi.vin &lt;&gt; null then
		self.vin := _ediTi.vin;
	endif;
	
	if _ediTi.year &lt;&gt; null then
		self.year := _ediTi.year;
	endif;
	
	if _ediTi.trackingNumber1 &lt;&gt; null then
		self.trackingNumber1 := _ediTi.trackingNumber1;			// PAR #32215
	endif;
	
	if _ediTi.trackingNumber2 &lt;&gt; null then
		self.trackingNumber2 := _ediTi.trackingNumber2;			// PAR #32215
	endif;
	
	if _ediTi.docsReceived &lt;&gt; null then
		self.docsReceived.setDate(_ediTi.docsReceived);			// PAR #32215
	endif;
	
	if _ediTi.docsSent &lt;&gt; null then
		self.docsSent.setDate(_ediTi.docsSent);					// PAR #32215
	endif;
	
	if _ediTi.docsCleared &lt;&gt; null then
		self.docsCleared.setDate(_ediTi.docsCleared);			// PAR #32215
	endif;
	
	if _ediTi.docsReturned &lt;&gt; null then
		self.docsReturned.setDate(_ediTi.docsReturned);			// PAR #32215
	endif;
	
	if _ediTi.doors &lt;&gt; null then
		self.nbrDoors := _ediTi.doors;							// PAR #32215
	endif;
	
	if _ediTi.isNew &lt;&gt; null then
		self.isNew := _ediTi.isNew;								// PAR #32215
	endif;
	
epilog

end;</source>
        <Parameter name="_ediTi" type="CM_EDICargoTI"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
