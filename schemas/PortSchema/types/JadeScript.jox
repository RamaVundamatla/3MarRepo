    <JadeMethod name="rel811_par30136" id="61334de3-7be4-483b-ae1d-1ee627d66b84">
        <source>rel811_par30136();
/*
Date		Who		Reason
02 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	xlAgent : CM_TranslationAgent;
	etAgent	: EntTableAgent;
	array 	: StringArray;
	task	: CM_AutoTaskEDITerminal;
begin
	app.initialize;
	
	create xlAgent transient;
	create array transient;
	
	array.add ('EDI_BGP_Error1');
	array.add ('EDIFORM_VERIFY_MSG');
	
	xlAgent.trxLoadSpecificErrors (array);
	
	delete array;
	
	create etAgent transient;
	create array transient;
	
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	array.add ("ETRow_BgpEDIReprocessFiles");
	array.add ("ETRow_BgpEDIProcessNewFiles");
	array.add ("ETRow_BgpEDIProcessEvReqStops");
	array.add ("ETRow_BgpEDIDeleteOldEDIData");
	array.add ("ETDef_BgpAutoTasks");
	array.add ("ETGrp_BGPBackground");
	
	array.add ("ETRow_EDIUnprocOperStopExpiry");
	array.add ("ETRow_EDIUnprocCusResExpiry");
	array.add ("ETRow_EDIUnprocReleaseExpiry");
	array.add ("ETRow_EDIUnprocBookExpiry");
	array.add ("ETDef_EDIConfig");
	array.add ("ETGrp_ConfigGroup");
	
	etAgent.trxUpdateFromConstant(array);	
	
	app.writeLog( method.qualifiedName &amp; 'Upgrading EDI BGP Task data', LogINFO);
	
	beginTransaction;

	foreach task in CM_AutoTaskEDITerminal.instances do
		if not task.processEventRequestStops and 
			not task.processNewFiles and 
			not task.deleteOldData and
			task.allEDIDataTypes.isEmpty then
			//  if they have nothing set then set everything
			app.writeLog( method.qualifiedName &amp; 'Upgrading EDI BGP Task data - ' &amp; task.description, LogINFO);
			
			task.setPropertyValue (CM_AutoTaskEDITerminal::processEventRequestStops.name, true);
			task.setPropertyValue (CM_AutoTaskEDITerminal::processNewFiles.name, true);
			task.setPropertyValue (CM_AutoTaskEDITerminal::deleteOldData.name, true);
			
			task.allEDIDataTypes.add (EDIDataType_BookingMultiLine);
			task.allEDIDataTypes.add (EDIDataType_CustomStop);
			task.allEDIDataTypes.add (EDIDataType_OperatorStop);
			task.allEDIDataTypes.add (EDIDataType_ReleaseRequest);
			task.allEDIDataTypes.add (EDIDataType_Pack);
			task.allEDIDataTypes.add (EDIDataType_Prenote);
		endif;
	endforeach;
	
	commitTransaction;

	app.writeLog( method.qualifiedName &amp; 'Completed upgrade of EDI BGP Task data', LogINFO);	
	
epilog
	delete xlAgent;
	delete etAgent;
	
	return;
	
	write EDI_BGP_Error1;
	write EDIFORM_VERIFY_MSG;
	
	write ETGrp_BGPBackground;
	write ETDef_BgpAutoTasks;
	write ETRow_BgpEDIDeleteOldEDIData;
	write ETRow_BgpEDIProcessEvReqStops;
	write ETRow_BgpEDIProcessNewFiles;
	write ETRow_BgpEDIReprocessFiles;
	
	write ETGrp_ConfigGroup;
	write ETDef_EDIConfig;
	write ETRow_EDIUnprocBookExpiry;
	write ETRow_EDIUnprocReleaseExpiry;
	write ETRow_EDIUnprocCusResExpiry;
	write ETRow_EDIUnprocOperStopExpiry;
end;</source>
    </JadeMethod>
