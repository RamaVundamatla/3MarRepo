    <JadeMethod name="idFilterIsMatch" id="53b16e80-d7f8-43b4-8985-1d181d9727e2">
        <source>idFilterIsMatch(testId : String) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2008	cnwrd1	Initial creation

*/

vars
	pos : Integer;
begin
	//1: No filter applies
	if self.filterID  = null then
		return true;
	endif;

	//2: Id is exact match
	if testId = self.filterID  then
		return true;
	endif;
	
	/*
	//3: filterId is a substring of testId (eg first or last few characters	)
	if self.filterID .length &lt; testId.length then
		pos := testId.pos(self.filterID , 1);
	endif;
	return (pos &lt;&gt; 0);
	*/
	
	if testId[1 : self.filterID.length ] = self.filterID  then
		return true;
	endif;

	if testId.reverse[1 : self.filterID.length ] = self.filterID.reverse  then
		return true;
	endif;
	
return false;

end;</source>
        <Parameter name="testId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="cec37252-f5cb-4e02-b25b-90e0bfe2a9ce">
        <source>// 15/05/2024	navcs2	MTN-34843

includeObject(_master : CM_TIMaster) : Boolean;

vars
	result : Boolean;
begin

	result := true;
	
	result := self.idFilterIsMatch( _master.id ) ;

/*
	if self.filterID &lt;&gt; null then
		if _master.id &lt;&gt; self.filterID then
			return false;
		endif;
	endif;
	
	*/
// -----------------------------------------------------------
//							T I L C
// -----------------------------------------------------------
//	if _master.isKindOf(CM_TIMasterTILC) then 
	if _master.isTILC() then 
	
		if self.filterOperator &lt;&gt; null then
			if _master.CM_TIMasterTILC.myOperatorNew = null or _master.CM_TIMasterTILC.myOperatorNew.code &lt;&gt; self.filterOperator then // cnwrd1 ccms 1034 13.8.2008
				result := false;
			endif;
		endif;
	
	
		if self.filterCargoType &lt;&gt; null then
			if _master.CM_TIMasterTILC.myTILCType = null or _master.CM_TIMasterTILC.myTILCType.code &lt;&gt; self.filterCargoType then
				result := false;
			endif;
		endif;
		
	endif;
	
// 15/05/2024	navcs2	MTN-34843 START
// -----------------------------------------------------------
//							M A F I
// -----------------------------------------------------------

	if _master.isMAFI() then 
	
		if self.filterOperator &lt;&gt; null then
			if _master.CM_TIMasterTILC.myOperatorNew = null or _master.CM_TIMasterTILC.myOperatorNew.code &lt;&gt; self.filterOperator then 
				result := false;
			endif;
		endif;
	
	
		if self.filterCargoType &lt;&gt; null then
			if _master.CM_TIMasterTILC.myTILCType = null or _master.CM_TIMasterTILC.myTILCType.code &lt;&gt; self.filterCargoType then
				result := false;
			endif;
		endif;
		
	endif;
// 15/05/2024	navcs2	MTN-34843 END

// -----------------------------------------------------------
//							Generator
// -----------------------------------------------------------
	if _master.isGenerator() then 
	
		if self.filterGeneratorType &lt;&gt; null then
			if _master.CM_TIMasterGenerator.myGeneratorType.code &lt;&gt; self.filterGeneratorType then
				result := false;
			endif;
		endif;
		
	endif;

// -----------------------------------------------------------
//							Container
// -----------------------------------------------------------
	if _master.isContainer() then 
	
		if self.filterOperator &lt;&gt; null then
			if _master.CM_TIMasterContainer.myOperatorNew = null or _master.CM_TIMasterContainer.myOperatorNew.code &lt;&gt; self.filterOperator then
				result := false;
			endif;
		endif;
		
		
		if self.filterISOType &lt;&gt; null then
			if _master.CM_TIMasterContainer.isoType = null or _master.CM_TIMasterContainer.isoType &lt;&gt; self.filterISOType then 
				result := false;
			endif;
		endif;
	
		
		//upper &amp; lower
		if self.filterLower &lt;&gt; null then
			if _master.CM_TIMasterContainer.id &lt; self.filterLower then
				result := false;
			endif;
		endif;
		
		if self.filterUpper &lt;&gt; null then
			if _master.CM_TIMasterContainer.id &gt; self.filterUpper then
				result := false;
			endif;
		endif;
		
		/*
		if self.filterUpper &lt;&gt; null and  self.filterLower &lt;&gt; null  then
			if ( _master.CM_TIMasterContainer.id  &lt;= self.filterLower ) and ( _master.CM_TIMasterContainer.id &gt;= self.filterUpper ) then
				return false;
			endif;
		endif;
		*/
	endif;

	return result;
	
end;
</source>
        <Parameter name="_master" type="CM_TIMaster"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initCmbFleetType" id="df4fed84-5af1-445f-86af-b4d43d289c43">
        <source>initCmbFleetType();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
