// ---------------------------------------------------------------------------
// Created:     07 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := ( self.remarks.trimRight &lt;&gt; null);
end;</source>
