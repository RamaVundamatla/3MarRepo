    <JadeMethod name="eprTestTruckLoadCMIF" id="143a240c-2073-482d-9503-7845d0375b92">
        <source>eprTestTruckLoadCMIF();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2018	jlger1	Initial creation

*/

vars

truckUnLoaderController: CMIF_MobileTruckLoaderUnloader;
ti : CM_TrackedItem;
truck : CM_Vehicle;
tmpFoundLC : CM_LocationsController;
foundHeight : Integer;
	wle : CM_WorkListEntry;
begin
	
	app.initialize;
	app.myPassport.setMyUserFromCode("JLIER1");
	//ti := "2365.356033".asOid.CM_TrackedItem;
	/*ER2*/
	//ti :="4949.1914249".asOid.CM_TrackedItem;//ALUM123654
	//ti :="2365.935886".asOid.CM_TrackedItem;//BOX Of Chooks CHOK178932
	ti:="4949.1802802".asOid.CM_TrackedItem;
	//truck := "2414.518118".asOid.CM_Vehicle;
	//wle:="2425.3283594".asOid.CM_WorkListEntry;
	//ti:= wle.myTrackedItem;
	//truck:= wle.myRequest.myJob.CM_RoadJob.myVehicle;
	truck:="2414.28713".asOid.CM_Vehicle;
	ti:="4949.1815834".asOid.CM_TrackedItem;
	//ti:=wle.myTrackedItem;//ALUM123654on the truck
	//wle:="2425.1433173".asOid.CM_WorkListEntry; //loaded wle any id
	/*ER5
	ti :="2365.942477".asOid.CM_TrackedItem; //MCAR18081712
	truck := "2414.28714".asOid.CM_Vehicle;
	wle:="2425.1432130".asOid.CM_WorkListEntry;*/
	
	app.myPassport.setMyTerminal(ti.myTerminal);
	create truckUnLoaderController transient;
	
	truckUnLoaderController.setMyTerminal(app.myPassport.myTerminal);
	truckUnLoaderController.setTruck(truck);
	//truckUnLoaderController.setMyWle(wle);
	app.myPassport.setWarningsIgnored(true); 
	//app.myPassport.warningsAcknowledged := true; 
	truckUnLoaderController.setDoNotShowMsgBox(true);
	
		
