<CollClass name="CM_TIByCargoGroupIdDict" id="f2000930-3cd7-4128-83ad-49e1f6e7442a">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_TrackedItemDicts"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tiDicts"/>
    <MemberKey>
        <property name="CM_TrackedItem::myCargoGroup"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_TrackedItem::id"/>
    </MemberKey>
    <JadeMethod name="getCargoGroups" id="b3ee68d5-3469-4a1e-b8fe-0a240af35752">
        <source>getCargoGroups(_cargoGroups : CM_TISet input; _term : CM_Terminal);
/*
Purpose:			

Date		Who		Reason
30 June 2023	navab1	 CR 58857 TASK 58967 
*/

vars

	cargoGroupId, keys : String;
	keyIds : StringArray;
	cargoGroup : CM_CargoGroup;
begin
	if _cargoGroups= null then
		return;
	endif;
	
	create keyIds transient;
	
	keys :=  self.getUniqueKeys("|");
	keyIds.cnGetTokens(keys,"|",false);
	
	foreach cargoGroupId in keyIds do
		cargoGroup := _term.allCargoGroupsByIdCargoType.getAtKeyGeq(cargoGroupId.trimBlanks(),null).CM_CargoGroup;
		if cargoGroup &lt;&gt; null and cargoGroup.id = cargoGroupId.trimBlanks() then
			_cargoGroups.addNoDuplicates(cargoGroup, false);
		endif;
	endforeach;


epilog
	delete keyIds;
end;</source>
        <Parameter name="_cargoGroups" type="CM_TISet" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getUniqueKeys" id="07195ec6-bdec-4973-8a84-7e0a3e12a2f6">
        <source>getUniqueKeys(_delimiter : String) : String;
/*
Purpose:			

Date		Who		Reason
30 June 2023	navab1	 CR 58857 TASK 58967 
*/

vars
	ti : CM_TrackedItem;
	cargoGroupId, cargoGroupIds : String;
	cargoGroup : CM_CargoGroup;
	idx : Integer;

begin
	if self.isEmpty() then
		return null;
	endif;
	
	ti := self.getAtKeyGtr(null,null);
	cargoGroup := ti.myCargoGroup;
	cargoGroupId := ti.getMyCargoGroupId();
	cargoGroupIds := cargoGroupIds &amp; " " &amp; cargoGroupId;
	
	while ti &lt;&gt; null do
		idx += 1;
		ti := self.getAtKeyGtr(cargoGroup,"ZZZZZZZZZZZZZZZZZZZZ");
		if ti = null then
			break;
		endif;
		cargoGroup := ti.myCargoGroup;
		cargoGroupId := ti.getMyCargoGroupId().trimBlanks();
		
		if cargoGroupIds = null then
			cargoGroupIds := cargoGroupId;
		else	
			cargoGroupIds := cargoGroupIds &amp; _delimiter &amp; cargoGroupId;
		
		endif;
		if idx &gt; 1000 then
			break;
		endif;
	endwhile;

	return cargoGroupIds;
epilog

end;</source>
        <Parameter name="_delimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
