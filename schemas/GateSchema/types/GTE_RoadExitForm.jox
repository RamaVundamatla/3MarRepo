    <JadeMethod name="setupContextMenuItems" id="d23d45a6-6c51-4ee0-93a0-61128286c85a">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//  Date 30 May 2007
//	
//  Date        Who     Reason
//  22 Dec 2022 navmp20 ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
//	06 Apr 2023	jlizm1	TFS 57098 EUP Seal numbers on trucks
//	25 Nov 2024	jlizm1	MTN 33235 Delete current entry reverting already exported cargo
//  08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
//  16 Sep 2025 navhl20 Defect MTN-36050: The page goes blank after clicking on the Photo Checks on the Truck Unloader app
//  08 Oct 2025 navhl20 Story MTN-36217: TPT | Enable Uploading of Photos into MTN Production
//----------------------------------------------------------------------

vars
	tmpMenu,
	tmpSubMnu, clonedStatus, clonedSend,					//14.12.2022 navmp20 TFS 55580
	clonedCancelVisit,										// ### TFS 54049 (55843) 18May2023 NAVPW1
	clonedDisAssocBooking,									// ### TFS 54049 (55843) 18May2023 NAVPW1
	clonedVbsSlot 			: MenuItem;						// ### TFS 54049 (55843) 18May2023 NAVPW1
	vvr 					: CM_VehicleVisitRecord;
	roadJobObj 				: CM_RoadJob;
	vbsProcess 				: CM_VBSProcess;				// ### TFS 54049 (55843) 18May2023 NAVPW1
	idx 					: Integer;						// ### TFS 54049 (55843) 19May2023 NAVPW1
	vbts 					: CM_VehicleBookingTimeSlot;	// ### TFS 54049 (55843) 19May2023 NAVPW1
	
begin
	inheritMethod(conwin);
	
	vbsProcess := self.myVBSProcess; // ### TFS 54049 (55843) 19May2023 NAVPW1
	
	// ### TFS 54049 (55843) 17May2023 NAVPW1
	self.mnuDisAssocBooking.visible := false;
	// ### TFS 54049 (55843) 17May2023 NAVPW1
	self.mnuSendReport.visible := false;							//08.08.2025 navhl20 #35650
	
	//Start 22.12.2022 navmp20 TFS 55580
	roadJobObj := self.myCurrentObject.CM_RoadJob;
    if roadJobObj &lt;&gt; null then
        vvr := roadJobObj.myVehicleVisit;
    endif;
	
	foreach idx in 1 to self.menuItemCount do
		tmpMenu := self.menuItems(idx);
		if tmpMenu.caption = self.mnuChangeInspectionStatus.caption or tmpMenu.caption = self.mnuSendInspectionOut.caption then
			tmpMenu.visible := false;
		endif;
	endforeach;
	
	if vvr &lt;&gt; null then
		if app.myPassport.myUser.canDo(self.myTerminal, PmGteInspectionManualMsgSend) then
			clonedSend := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSendInspectionOut, false); 
			clonedSend.visible := true;
		endif;

		if app.myCurrentUserCan(self.myTerminal, PmGteInspectionStatusChange) then
			clonedStatus := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuChangeInspectionStatus, false); 
			clonedStatus.visible := true;
		endif;
		
		self.mnuOutCompleted.enabled := true;
		self.mnuOutNA.enabled := true;
		self.mnuOutPending.enabled := true;
		self.mnuOutFailed.enabled := true;
		
		if vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionCompleted then
			self.mnuOutCompleted.enabled := false;
		elseif vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionNA then
			self.mnuOutNA.enabled := false;
		elseif vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionPending then
			self.mnuOutPending.enabled := false;
		elseif vvr.gateOutCheckStatus = CM_VehicleVisitRecord.InspectionFailed then
			self.mnuOutFailed.enabled := false;
		endif;
		
		if app.myCurrentUserCan(self.myTerminal, PmGteInspectionStatusChange) then
			self.zCloneMenu(clonedStatus, self.mnuOutNA, true);
			self.zCloneMenu(clonedStatus, self.mnuOutPending, true);
			self.zCloneMenu(clonedStatus, self.mnuOutCompleted, true);
			self.zCloneMenu(clonedStatus, self.mnuOutFailed, true);
		endif;
		
	endif;
	//End 22.12.2022 navmp20 TFS 55580
	
	self.mnuMaintainSeals.visible := false;
	self.mnuCheckSeals.visible := false;
	
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then	// TFS 57098
		if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_RoadJob) then
			
			if roadJobObj.isJobComplete and roadJobObj.myVehicleVisit &lt;&gt; null then
				self.mnuCheckSeals.visible := true;								// TFS 57098
				self.mnuCheckSeals.userObject := roadJobObj.myVehicleVisit;		// TFS 57098
				self.mnuMaintainSeals.visible := true; 							// TFS 57098
				self.mnuMaintainSeals.userObject := roadJobObj.myVehicleVisit;	// TFS 57098
			endif;
		endif;
	endif;
	
	if self.tblData.allSelectedObjects.size = 1 then							//08.08.2025 navhl20 #35650
		self.mnuSendReport.visible := true;									
	endif;
	
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCheckSeals, false);		// TFS 57098
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuMaintainSeals, false);	// TFS 57098
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargoReview, false); 		//23/02/2023	navkc1 CR 62580 Task 62581
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSendReport, false);		//08.08.2025 navhl20 #35650
	
	clonedCancelVisit := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCancelVisit, false);
	if canCancelVisit then
		self.mnuCancelVisit.visible := true;
		clonedCancelVisit.visible := true;
	else
		self.mnuCancelVisit.visible := false;
		clonedCancelVisit.visible := false;
	endif;
	
	if self.myTerminal.isVehicleBookingEnabled then
		foreach idx in 1 to self.clonedMenuCount do
			tmpMenu := self.mnuTblVCloneDataTbl.getMenuItem(idx);
			if tmpMenu &lt;&gt; null then
				if tmpMenu.caption = self.mnuDisAssocBooking.caption then
					tmpMenu.visible := false;
				endif;
			endif;
		endforeach;
		
		// TFS 2198 CNWAB1
		if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			if vbsProcess = null or (vbsProcess &lt;&gt; null and vbsProcess.isVbsStandard) then
				if vvr.allVehicleBookingSlots.isNotEmpty then
					self.mnuDisAssocBooking.visible := true;
					clonedDisAssocBooking := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDisAssocBooking, false);
					clonedDisAssocBooking.setEventMapping("click", GTE_RoadExitForm::doDisAssocBooking.name);
					clonedDisAssocBooking.visible := true;
				endif;
				
			elseif vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then
				if vvr &lt;&gt; null and vvr.allVehicleBookingSlots.isNotEmpty then
					clonedDisAssocBooking := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDisAssocBooking, false);
					clonedDisAssocBooking.visible := true;
					foreach idx in 1 to 20 do
						clonedVbsSlot := clonedDisAssocBooking.getMenuItem(idx);
						if clonedVbsSlot = null then
							break;
						endif;
						clonedVbsSlot.caption := null;
						clonedVbsSlot.userObject := null;
						clonedVbsSlot.visible := false;
					endforeach;
					
					idx := 0;
					foreach vbts in vvr.allVehicleBookingSlots do
						idx := idx + 1;
						clonedVbsSlot := clonedDisAssocBooking.getMenuItem(idx);
						if clonedVbsSlot = null then
							clonedVbsSlot := clonedDisAssocBooking.loadSubMenu(idx);
						endif;
						clonedVbsSlot.caption := vbts.id;
						clonedVbsSlot.userObject := vbts;
						clonedVbsSlot.visible := true;
						clonedVbsSlot.setEventMapping("click", GTE_RoadExitForm::doVbsSlotClick.name);
					endforeach;
				endif;
			endif;
		endif;
		
	endif;
	
	// ### TFS 54049 (55843) 16May2023 NAVPW1
	
	//Process Unactioned Road Exit Items and Add Chassis Stuff	
	if app.myPassport.myUser.canDo(self.myTerminal, PmAdmRoadopsMaint) then
		tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuTblVCloneDataTbl, false); 
		tmpMenu.visible := true;
		tmpMenu.caption := app.getErrorString(Process_road_exit);
	endif;
	
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="11c84466-48f4-46f3-84a0-0ee627ef7e07">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			Sets up the road exit form

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
16 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

begin
	inheritMethod();
	
	self.myVBSProcess := self.myTerminal.getMyVBSProcess();
	
	self.frmTableFilter.setCallbackMethod(GTE_RoadExitForm::doFilterTable.name); //25/06/2024	navkc1 CR 64823 Task 64824
end;</source>
