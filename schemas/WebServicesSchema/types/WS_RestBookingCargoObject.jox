    <JadeMethod name="setProxyFromBookingItem" id="13b86811-3361-4907-b5ba-bf22a3d9d185">
        <updating/>
        <source>setProxyFromBookingItem(_bookingRefItem : CM_BRefItemContainer; _objectsToBeDeleted : ObjectArray input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2023	navpw1	Initial creation TFS: 56850 (56871)
08 March 2024 	naviv1	TFS: 62796 - CR - CUX | EDBIC - Modify Booking API to be independent of Prenotes
06 Oct   2025   navsp1  MTN-32915 CUX - MTN-EDBIC - 010 - Process Export Cargo - Booking Refinement - Unit Tests GET
*/

vars
	cargoType	: CM_CargoType;
	product		: CM_Product;
	hazard		: CM_TIHazard;
	wsHazard	: WS_RestHazardObject;
	isoType		: CM_ISOType;
	specialStow	: CM_SpecialStow;
	wsDimension : WS_RestDimensionsObject;  //MTN-32915
    wsReefer    : WS_RestReeferObject;      //MTN-32915
    wsWeight    : WS_RestWeightObject;      //MTN-32915
begin
	cargoType := _bookingRefItem.myCargoType;
	if cargoType &lt;&gt; null then
		self.cargoTypeId := cargoType.abbreviation;
	endif;
	
	product := _bookingRefItem.myProduct;
	if product &lt;&gt; null then
		self.cargoSubTypeId := product.code;
	endif;
	
	self.colour := _bookingRefItem.colour;
	self.commodityId := _bookingRefItem.commodity;
	self.curtains := _bookingRefItem.getCurtainsIn;
	self.density := _bookingRefItem.density;
	self.description := _bookingRefItem.description;
	
	create wsDimension transient;                   //MTN-32915
	wsDimension.length := _bookingRefItem.length;
	wsDimension.width := _bookingRefItem.width;
	wsDimension.height := _bookingRefItem.height;
    
    self.dimensions := wsDimension;
    
	_objectsToBeDeleted.add(wsDimension);           //MTN-32915
    
	self.generatorTypeId := _bookingRefItem.generatorType;
	
	foreach hazard in _bookingRefItem.allTIHazards as CM_TIHazard do
		create wsHazard transient;
		wsHazard.setProxyFromObject(hazard);
		self.hazards.add(wsHazard);
        _objectsToBeDeleted.add(wsHazard);          //MTN-32915
	endforeach;
	
	//self.id := _bookingRefItem.id;		//08.03.2024 naviv1	#62796
	
	self.isoGroupId := _bookingRefItem.isoTypeGroup;
	
	isoType := _bookingRefItem.myISOType;
	if isoType &lt;&gt; null then
		self.isoTypeId := isoType.code;
	endif;
	
	self.markNumber := _bookingRefItem.markNumber;
	self.marks := _bookingRefItem.shippingMarks;
	self.onsiteCount := _bookingRefItem.numOnsiteTIs;
	self.prenoteCount := _bookingRefItem.numPrenotedTIs;
	self.purchaseOrder := _bookingRefItem.purchaseOrder;
	
	create wsReefer transient;
	wsReefer.carbonDioxide := _bookingRefItem.getCarbonDioxide;
	wsReefer.humidity := _bookingRefItem.getHumidity;
	wsReefer.oxygen := _bookingRefItem.getOxygen;
	wsReefer.vent := _bookingRefItem.getVentilation;
	wsReefer.ventUnits := _bookingRefItem.getVentilationUnits;
	wsReefer.temperature := _bookingRefItem.tempCelcius;
	self.reeferProperties   := wsReefer;
    
    _objectsToBeDeleted.add(wsReefer);          //MTN-32915
    
	self.remarks := _bookingRefItem.remarks;
	self.serviceOrder := _bookingRefItem.serviceOrder;
	
	specialStow := _bookingRefItem.mySpecialStow;
	if specialStow &lt;&gt; null then
		self.specialStow := specialStow.code;
	endif;
	
	self.trailerTypeId := _bookingRefItem.trailerType;
	self.volume := _bookingRefItem.volume;
	
    create wsWeight transient;
	wsWeight.gross := _bookingRefItem.weight;
	wsWeight.net := null;
	wsWeight.tare := null;
    self.weights    := wsWeight;
    
    _objectsToBeDeleted.add(wsWeight);         //MTN-32915
    
	self.quantity := _bookingRefItem.quantity; //22.Mar.24 navsp1 TFS 63028
	
	self.matchMode := _bookingRefItem.matchMode;				//navra1 - CR 63764/Task 64227 - 23rd May 2024
end;</source>
        <Parameter name="_bookingRefItem" type="CM_BRefItemContainer"/>
        <Parameter name="_objectsToBeDeleted" type="ObjectArray" usage="input"/>
    </JadeMethod>
</Class>
