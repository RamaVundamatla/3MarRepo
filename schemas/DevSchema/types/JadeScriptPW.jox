    <JadeMethod name="pwToolbarUserResetAll" id="a1ca01df-5039-4827-8199-2eb07d3261c6">
        <source>pwToolbarUserResetAll();
/*

Purpose:			Resets the toolbar icons for all users

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
14 October 2022	navpw1	Initial creation

*/

vars
	toolbarButton : CM_MenuToolbar;
	userToolbarButton : CM_MenuUserToolbar;
	menuUserToolbarRoot : CM_MenuUserToolbarRoot;
	user : CM_User;
	count : Integer;
	
	toolbarItems : CM_MenuToolbarByIdDict;
	
begin
	create toolbarItems transient;
	
	foreach toolbarButton in app.myRoot.allToolbarEntities do
		toolbarItems.add(toolbarButton);
	endforeach;
	
	if toolbarItems.isEmpty then
		return;
	endif;
	
	beginTransaction;
	
	foreach toolbarButton in toolbarItems do
		count := 0;
		foreach userToolbarButton in toolbarButton.allUserToolbars as CM_MenuUserToolbar do
			menuUserToolbarRoot := userToolbarButton.myMenuUserToolbarRoot;
			
			if menuUserToolbarRoot = null then
				continue;
			endif;
			
			user := menuUserToolbarRoot.myUser;
			
			if user = null then
				continue;
			endif;
			
			if toolbarButton.pictureButton &lt;&gt; userToolbarButton.pictureButton or
				toolbarButton.pictureButtonDown &lt;&gt; userToolbarButton.pictureButtonDown or
				toolbarButton.pictureIcon &lt;&gt; userToolbarButton.pictureIcon
			then
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureButton.name, toolbarButton.pictureButton);
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureButtonDown.name, toolbarButton.pictureButtonDown);
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureIcon.name, toolbarButton.pictureIcon);
				
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureStringButton.name, toolbarButton.pictureStringButton);
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureStringButtonDown.name, toolbarButton.pictureStringButtonDown);
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureStringIcon.name, toolbarButton.pictureStringIcon);
				count += 1;
			endif;
		endforeach;
		write toolbarButton.heading &amp; " Total Processed: " &amp; count.String;
	endforeach;
	
	commitTransaction;
	
epilog
	delete toolbarItems;
end;</source>
    </JadeMethod>
    <JadeMethod name="pwToolbarUserResetSpecific" id="974584a5-4221-4369-a7f2-a720081d6b1e">
        <source>pwToolbarUserResetSpecific();
/*

Purpose:			Resets specific toolbar icons for all users

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
14 October 2022	navpw1	Initial creation

*/

constants
	TextTranslationName = "Text Translation";
	TextTranslationMenuID = "_TB913";
	
	AgentDebtorName = "Agent Debtor Maintenance";
	AgentDebtorMenuID = "_TB1269";
	
	CashCreditName = "Cash Credit";
	CashCreditMenuID = "_TB1300";

	CargoLabelName = "Cargo Label Print Request";
	CargoLabelMenuID = "_TB1124";
	
vars
	toolbarButton : CM_MenuToolbar;
	userToolbarButton : CM_MenuUserToolbar;
	menuUserToolbarRoot : CM_MenuUserToolbarRoot;
	user : CM_User;
	count : Integer;
	
	toolbarItems : CM_MenuToolbarByIdDict;
	
begin
	create toolbarItems transient;
	
	toolbarButton := app.myRoot.allToolbarEntities[TextTranslationMenuID];
	if toolbarButton.heading = TextTranslationName or 
		toolbarButton.toolTip = TextTranslationName
	then
		toolbarItems.add(toolbarButton);
	endif;
	
	toolbarButton := app.myRoot.allToolbarEntities[AgentDebtorMenuID];
	if toolbarButton.heading = AgentDebtorName or 
		toolbarButton.toolTip = AgentDebtorName
	then
		toolbarItems.add(toolbarButton);
	endif;
	
	toolbarButton := app.myRoot.allToolbarEntities[CashCreditMenuID];
	if toolbarButton.heading = CashCreditName or 
		toolbarButton.toolTip = CashCreditName
	then
		toolbarItems.add(toolbarButton);
	endif;
	
	toolbarButton := app.myRoot.allToolbarEntities[CargoLabelMenuID];
	if toolbarButton.heading = CargoLabelName or 
		toolbarButton.toolTip = CargoLabelName
	then
		toolbarItems.add(toolbarButton);
	endif;
	
	if toolbarItems.isEmpty then
		return;
	endif;
	
	beginTransaction;
	
	foreach toolbarButton in toolbarItems do
		count := 0;
		foreach userToolbarButton in toolbarButton.allUserToolbars as CM_MenuUserToolbar do
			menuUserToolbarRoot := userToolbarButton.myMenuUserToolbarRoot;
			
			if menuUserToolbarRoot = null then
				continue;
			endif;
			
			user := menuUserToolbarRoot.myUser;
			
			if user = null then
				continue;
			endif;
			
			if toolbarButton.pictureButton &lt;&gt; userToolbarButton.pictureButton or
				toolbarButton.pictureButtonDown &lt;&gt; userToolbarButton.pictureButtonDown or
				toolbarButton.pictureIcon &lt;&gt; userToolbarButton.pictureIcon
			then
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureButton.name, toolbarButton.pictureButton);
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureButtonDown.name, toolbarButton.pictureButtonDown);
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureIcon.name, toolbarButton.pictureIcon);
				
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureStringButton.name, toolbarButton.pictureStringButton);
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureStringButtonDown.name, toolbarButton.pictureStringButtonDown);
				userToolbarButton.setPropertyValue(CM_MenuToolbar::pictureStringIcon.name, toolbarButton.pictureStringIcon);
				count += 1;
			endif;
		endforeach;
		write toolbarButton.heading &amp; " Total Processed: " &amp; count.String;
	endforeach;
	
	commitTransaction;
	
epilog
	delete toolbarItems;
end;</source>
    </JadeMethod>
    <JadeMethod name="pwVehicleVisitCancel" id="802bde9d-8dea-4c93-bde8-a1dd855758a5">
        <source>pwVehicleVisitCancel();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2021	navpw1	Initial creation

*/

vars
	visit 		: CM_VehicleVisitRecord;
