    <JadeMethod name="startNotifications" id="101f37ad-db03-4d7f-b5a8-40b7ee58de65">
        <source>startNotifications();
/*
Purpose - 	
Who - NAVAB1
Date - 18JUL2024
ADO - CR 64612 TASK 64659
*/

vars

begin
