        <updating/>
        <source>setMyRoot() updating;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	self.myRoot := app.myRoot;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="4e9903f3-f6a2-46aa-9a42-9c50f1a63dc9">
        <updating/>
        <source>setProxy(pName, pDescription: String; pPriority : Integer)  updating;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.code 			:= pName[1:5].trimBlanks;
	self.description 	:= pDescription[1:30].trimBlanks;
	self.priority		:= pPriority;
	self.myRoot 		:= app.myRoot;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pPriority" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="00666dd4-a385-418f-a7c0-091d3ba20cdf">
        <source>validateForCreate();
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars
	
begin

	if app.myRoot.allCustomerPriorities[self.code] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;	
	
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="83fe65bf-2a9f-4b6a-80fc-13bf0530e673">
        <source>validateForUpdate();
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
vars

begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="23f62d87-72e0-44a7-bb09-afca00b243e1">
        <source>validateMe() protected;
//-----------------------------------------
//
// Created : by CNWAER1 
//-----------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
19/11/2023	jlika1	TFS 61128 61013 CUX | System Admin - Customer Priority
============================================================================*/
vars	
	customerPriority : CM_CustomerPriority;
begin
	if self.code.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Customer Priority Code', null, null);
		app.raiseCMException(Input_required_field_custPriCd, null, null);

	endif;
	if self.description.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Customer Priority Description', null, null);
		app.raiseCMException(Input_required_field_cstPriDes, null, null);
		
	endif;
		
	if self.priority &gt; 0 then		
		foreach customerPriority in app.myRoot.allCustomerPriorities do
			if customerPriority.priority = self.priority and customerPriority.code &lt;&gt; self.code  then
				app.raiseCMException1(PRIORITY_DUPLICATE_ITEM, self.priority.asStringJMT, null, null);
			endif;
		endforeach;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
