    <JadeMethod name="sapPelSendRequests" id="11fe6e21-e616-431a-a31a-4ac58825303d">
        <source>sapPelSendRequests();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2018	jlgma1	Initial creation

*/

vars
	wo 		 : CM_WorkOrder;
	terminal : CM_Terminal;
	bank : CM_Bank;
	action   : Integer;
	invoice : CM_Invoice;
	bgpRequest : BGP_ExternalWSRequest;
	proxyBGPRequest : BGP_SAPWSRequest;
begin
	app.initialize();
	action := 11;
	//terminal := app.myRoot.allTerminals["1013"];
	//bank := terminal.companies["DFBU"];
	
	create proxyBGPRequest transient;
	//proxyBGPRequest.setTerminal(terminal);
	
	//wo := terminal.allWorkOrders["0173"];
	//invoice := bank.allInvoices[terminal,bank,60131];
	
	
	if action = 1 then					//37189.001 Perform Credit Check for Auto-Collection Customer
		proxyBGPRequest.isSAPAutoEstReq := true;
	elseif action = 2 then  			//37189.002 Perform Credit Check for Pre-Billing Customer
		proxyBGPRequest.isSAPPreBillCheckLimitReq := true;
	elseif action = 3 then				//37189.003 Perform Credit Check for Post-Billing Customer
		proxyBGPRequest.isSAPPostBillEstReq := true;
	elseif action = 4 then              //37189.004 Send Release Hold and Debit for Auto-Collection Customer
		proxyBGPRequest.isSAPReleaseHoldDebit := true;
	elseif action = 5 then				//37189.005 Send Invoice / Data for Auto-Collection Customer
		proxyBGPRequest.isSAPAutoInvReq := true;
	elseif action = 6 then				//37189.006 Send Invoice/Data for Pre-Billing Customer
		proxyBGPRequest.isSAPPreBillInvoiceReq := true;
	elseif action = 7 then				//37189.007 Send Invoice/Data for Post-Billing Customer
		proxyBGPRequest.isSAPPostBillInvReq := true;
	elseif action = 9 then				//37189.009 Cancel Estimation
		proxyBGPRequest.isSAPCancelEstimate := true;
	elseif action = 10 then				//37189.010 Cancel Payment Code
		proxyBGPRequest.isSAPCancelPaymentCode := true;
	elseif action = 11 then
		proxyBGPRequest.isSAPDataKinerja := true;
	endif;
	/*
	if wo &lt;&gt; null then
		proxyBGPRequest.myWorkOrder := wo;
	endif;
	if invoice &lt;&gt; null then
		proxyBGPRequest.myInvoice    := invoice;
	endif;
	*/
	app.myTrxCA.trxCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
	
epilog
	app.finalize();
	delete proxyBGPRequest;
end;</source>
    </JadeMethod>
