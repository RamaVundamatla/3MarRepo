    <JadeMethod name="displayStops" id="e7882494-d19f-4651-9ccf-6706b8678ab7">
        <updating/>
        <source>displayStops() updating, protected;
// ---------------------------------------------------------------------------
// Created:	15 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
	
begin
	tblStops.rows := 0;	
	if self.myTrackedItem &lt;&gt; null then
		self.getSessionAgent().loadStopsTable( self.tblStops, self.myTrackedItem );
	endif;	
	self.tblStops.cnAdjustColumnWidths();
	self.setForView();
epilog
end;</source>
