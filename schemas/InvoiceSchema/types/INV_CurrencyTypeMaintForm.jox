    <JadeMethod name="loadCurrencyType" id="5a72ae77-8463-4737-b857-d1b657963ae0">
        <source>loadCurrencyType(_currencyType : CM_CurrencyType; _idx : Integer io) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars
	expandIdx,
	theLevel : Integer;
	tmpCurrencyTypeList : ListBox;
	tmpRate : CM_CurrencyRate;
begin

	if _currencyType = null then
		return;
	endif;
	tmpCurrencyTypeList := self.lstData;
	theLevel := 2;
	_idx := _idx+1;
	
	tmpCurrencyTypeList.addItemAt(_currencyType.getDisplayDetails(false), _idx);	
	tmpCurrencyTypeList.itemObject[_idx] := _currencyType;
	tmpCurrencyTypeList.itemLevel[_idx] := theLevel;
//	tmpCurrencyTypeList.itemPicture[_idx] := self.picTaxCode.picture;
	tmpCurrencyTypeList.itemExpanded[_idx] := true;	
	expandIdx := _idx;
				
	theLevel := 3;
	foreach tmpRate in _currencyType.allCurrencyRates do
		_idx := _idx + 1;
		tmpCurrencyTypeList.addItemAt(self.systemToLocalTime(tmpRate.effectiveDT).shortCurrentLocaleFormat() &amp; Tab &amp; tmpRate.rate.String, _idx);
		tmpCurrencyTypeList.itemObject[_idx] := tmpRate;
		tmpCurrencyTypeList.itemLevel[_idx] := theLevel;
//		tmpCurrencyTypeList.itemPicture[_idx] := self.picTaxRate.picture;
	endforeach;		

	tmpCurrencyTypeList.itemExpanded[expandIdx] := true;	

end;</source>
