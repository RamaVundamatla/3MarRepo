    <JadeMethod name="convertCargoIdForSearch" id="469ac15e-7389-4caf-ae9a-bad0370fb5cd">
        <source>convertCargoIdForSearch(	_rawId: String;
							_cargoType : Integer;
							_imex : Integer;
							_voyage : CM_Voyage;
							_convertedCargoId: String output;
							_convertedAltId: String output
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2016	cnwndl1	Initial creation	TFS 2275 / 2216

*/

vars

	cargoTypeInt : Integer;
	cargoType : CM_CargoType;
	imexStatusInt : Integer;
	voyage : CM_Voyage;
	imexCode : CM_IMEXStatus;

begin

	
	if _cargoType &gt; 0 then
		cargoTypeInt := _cargoType;
	else
		cargoType := cmbFiltTiType.listObject.CM_CargoType;
		if cargoType &lt;&gt; null then
			cargoTypeInt := cargoType.id;
		endif;
	endif;
	
	if _voyage &lt;&gt; null then
		voyage := _voyage;
	else
		voyage := cmbFiltVoyage.listObject.CM_Voyage;
	endif;
	
	if _imex &gt; 0 then
		imexStatusInt := _imex;
	else
		imexCode := self.cmbFilterIMEX.listObject.CM_IMEXStatus;
		if imexCode &lt;&gt; null then
			imexStatusInt := imexCode.code;
		endif;
	endif;

	inheritMethod(	_rawId,	//_rawId: String;
					cargoTypeInt,	//_cargoType : Integer;
					imexStatusInt,	//_imex : Integer;
					voyage,	//_voyage : CM_Voyage;
					_convertedCargoId,	//_convertedCargoId: String output;
					_convertedAltId	//_convertedAltId: String output
					);
		
epilog

end;</source>
        <Parameter name="_rawId" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_convertedCargoId" type="String" usage="output"/>
        <Parameter name="_convertedAltId" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doBolSearchForTermAreas" id="5d782b35-1416-49e7-87ea-bb0c92fbd11d">
        <source>doBolSearchForTermAreas( 	bol : CM_BOL;	
							bolTaTypes : CM_TATypeByTypeDict io;
							bolTAs : CM_TAByTerminalIdDict io;
							bolLocs : CM_LCSet io
							) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2010	cnwndl1	Initial creation	Par 26055

*/

vars

	term : CM_Terminal;
	ti : CM_TrackedItem;
	location : CM_LocationsController;
	ta : CM_TerminalArea;
	taType : CM_TerminalAreaType;
	
begin

	term := self.myMobileGenericAgent.myTerminal;

	foreach ti in bol.allTrackedItems do
		location := ti.myPrimaryActualLocation;
		if location = null or location.isVoyageController or bolLocs.includes(location) then
			continue;
		endif;
		bolLocs.add(location);
		ta := location.myTerminalArea;
		if ta = null or bolTAs.includes(ta) or ta.myTerminal &lt;&gt; term then
			continue;
		endif;
		bolTAs.add(ta);
		taType := ta.myType;
		if taType = null or bolTaTypes.includes(taType) then
			continue;
		endif;
		bolTaTypes.add(taType);
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="bol" type="CM_BOL"/>
        <Parameter name="bolTaTypes" type="CM_TATypeByTypeDict" usage="io"/>
        <Parameter name="bolTAs" type="CM_TAByTerminalIdDict" usage="io"/>
        <Parameter name="bolLocs" type="CM_LCSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doCreateCriteriaLine" id="17b353d1-e081-443c-a624-8d390d53ff64">
        <source>doCreateCriteriaLine(	_qDef : CM_QueryDefinition;
						_propName : String;
						_qOperatorStr : String;
						_value : Any
						) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2013	cnwndl1	Initial creation

*/

vars

	criteriaLine : CM_SelectorCriteriaLine;

begin

	criteriaLine := _qDef.createCriteriaLine(_propName, _qOperatorStr, _value);
	criteriaLine.setMyCriteriaLineHolder(self.myEnqController.myCriteriaLineHolder);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doCurrentColourListActions" id="eddc609d-fc26-4fb8-9d97-8f995d5df12a">
        <updating/>
        <source>doCurrentColourListActions(  _populate : Boolean; _gotFocus : Boolean; _lostFocus : Boolean; _colourRowIndex : Integer; _stringArray : StringArray io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2016	cnwndl1	Initial creation	TFS 3024/2370

*/

vars

	rowIndex : Integer;
	site : Integer;
	voyage : CM_Voyage;
	dict : CM_TIByCargoTypeIdDict;
	ti : CM_TrackedItem;
	colour : String;
	colours : StringArray;
	count : Integer;
	previousArray : StringArray;

begin

	if _populate then
	
		//Find the colours that are currently used on the cargo
		rowIndex := self.tblSearch.getRowByName( ETRow_FilterColourList );
		if rowIndex &lt; 1 then
			return;
		endif;
		
		create previousArray transient;
		self.doCurrentColourListActions( false, false, false, rowIndex, previousArray );
		
		if self.cmbFiltSite.listIndex &gt; 0 then
			site := self.cmbFiltSite.itemData[cmbFiltSite.listIndex];
		endif;
		
		if site &lt;&gt; TI_SITE_ONSITE and site &lt;&gt; TI_SITE_ONSHIP then
			self.tblColour.rows := 0;
			self.tblSearch.setCellText( rowIndex, 2, app.getErrorString(Only_site_ship_suppo_curre_col) );
			return;
		endif;
		
		voyage := self.cmbFiltVoyage.listObject.CM_Voyage;
		
		if site = TI_SITE_ONSHIP then
			if voyage = null then
				self.tblColour.rows := 0;
				self.tblSearch.setCellText( rowIndex, 2, app.getErrorString(Ship_requi_voyag_suppo_curre_c) );
				return;
			endif;
			dict := voyage.allOnshipTIsByCargoTypeId;
		elseif site = TI_SITE_ONSITE then
			if voyage = null then
				dict := self.myTerminal.allOnsiteTIsByCargoTypeId;
			else
				dict := voyage.allOnsiteTIsByCargoTypeId;
			endif;
		endif;
	
		create colours transient;
		foreach ti in dict do
			colour := ti.getColour[1:60];
			if colour &lt;&gt; null then
				if not colours.includes( colour ) then
					colours.add(colour);
				endif;
			endif;
		endforeach;
		
		if colours.isEmpty then
			self.tblColour.rows := 0;
			self.tblSearch.setCellText( rowIndex, 2, app.getErrorString(NO_Current_colours_found) );
			return;
		endif;
		
		self.tblColour.rows := 0;
		self.tblSearch.setCellText( rowIndex, 2, app.getErrorString1(N_Colours_available, colours.size.String) );
		foreach colour in colours do
			if previousArray.includes( colour ) then
				self.tblColour.addItem('1' &amp; Tab &amp; colour);
				count := count + 1;
			else
				self.tblColour.addItem('0' &amp; Tab &amp; colour);
			endif;
		endforeach;
		
		if count &gt; 0 then
			self.tblSearch.setCellText( rowIndex, 2, app.getErrorString1( N_Colours_selected, count.String ) );
		endif;
		self.setActionButton();
	
	elseif _gotFocus then
		//make the cell in the parent table big enough to select from 
		if self.tblColour.rows &gt; 5 then
			self.tblSearch.accessRow(_colourRowIndex).height := self.tblSearch.defaultRowHeight * 5;
		elseif self.tblColour.rows &gt; 1 then
			self.tblSearch.accessRow(_colourRowIndex).height := self.tblSearch.defaultRowHeight * self.tblColour.rows;
		endif;
		self.setActionButton();
	
	elseif _lostFocus then
		// reset the cell in the parent table size, and display some appropriate text
		self.tblSearch.accessRow(_colourRowIndex).height := self.tblSearch.defaultRowHeight;
		if self.tblColour.rows &gt; 0 then
			foreach rowIndex in 1 to self.tblColour.rows do
				if self.tblColour.accessCell(rowIndex,1).text = "1" then
					count := count + 1;
				endif;
			endforeach;
			if count &gt; 0 then
				self.tblSearch.setCellText( _colourRowIndex, 2, app.getErrorString1( N_Colours_selected, count.String ) );
			endif;
		endif;
		self.setActionButton();
	
	elseif _stringArray &lt;&gt; null then
		//gather up the 'selected' colour strings
		if self.tblColour.rows &gt; 0 then
			foreach rowIndex in 1 to self.tblColour.rows do
				if self.tblColour.accessCell(rowIndex,1).text = "1" then
					colour := self.tblColour.accessCell(rowIndex,2).text[1:60];
					if colour &lt;&gt; null and not _stringArray.includes( colour ) then
						_stringArray.add( colour );
					endif;
				endif;
			endforeach;
		endif;
	
	endif;

epilog

	delete colours;
	delete previousArray;

end;</source>
        <Parameter name="_populate" type="Boolean"/>
        <Parameter name="_gotFocus" type="Boolean"/>
        <Parameter name="_lostFocus" type="Boolean"/>
        <Parameter name="_colourRowIndex" type="Integer"/>
        <Parameter name="_stringArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doNarrowSerachCriteria" id="ddd4a3db-5eed-4aea-ba0a-c8da0e63de93">
        <updating/>
        <source>doNarrowSerachCriteria() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2010	cnwndl1	Initial creation	CCMS MES 1005
//28 Nov 2016	cnwrs1	TFS 2866 use new HH config matchFindCargoConsignee
*/

vars

	voyage : CM_Voyage;
	bol : CM_BOL;
	row : Integer;
	id  : String;
	booking : String;
	accessRow : JadeTableRow;
	ti : CM_TrackedItem;
	delReq : CM_DeliveryRequest;
	site : Integer;
	preventSiteChange : Boolean;
	reefersOnly : Boolean;
	canSplitOnly : Boolean;
	canMergeOnly : Boolean;
	lc : CM_LocationsController;
	cargoType : CM_CargoType;
	int : Integer;
	avail : CM_MTGrade;
	index : Integer;
	colour : String;
	matchFindCargoConsignee : Boolean;
begin

	voyage := app.myMobileCargoFindAgent.myVoyage;
	bol := app.myMobileCargoFindAgent.myBOL;
	id := app.myMobileCargoFindAgent.id;
	booking := app.myMobileCargoFindAgent.bookingRef;
	delReq := app.myMobileCargoFindAgent.myDeliveryRequest;
	site := app.myMobileCargoFindAgent.searchStateSite;	//11 Oct 2010	NDL	Par 25836
	preventSiteChange := app.myMobileCargoFindAgent.preventSiteChange; //cnwrd1 28868 9.1.2012
	lc := app.myMobileCargoFindAgent.myYardLoc;
	cargoType := app.myMobileCargoFindAgent.myCargoType;	//01 May 2013	NDL	Par 31506
	reefersOnly := app.myMobileCargoFindAgent.reefersOnly;	//02 May 2013	NDL	Par 31506
	canSplitOnly := app.myMobileCargoFindAgent.canSplitOnly;	//28 May 2013 NDL	CCMS 2275
	canMergeOnly := app.myMobileCargoFindAgent.canMergeOnly;	//28 May 2013 NDL	CCMS 2275
	colour := app.myMobileCargoFindAgent.colourString;	//25 Oct 2016	NDL TFS 2850 / 2370
	
	if voyage &lt;&gt; null then
		cmbFiltVoyage.listIndex := cmbFiltVoyage.findObject(voyage);
		cmbFiltVoyage_lostFocus(cmbFiltVoyage);
		cmbFiltVoyage.enabled := false;
		
		// Can't have a Bol without a voyage.	// 03 Nov 2010	NDL	Part of Par 26055
		row := tblSearch.getRow(ETRow_FilterBols);
		if row &gt; 0 and bol &lt;&gt; null then
			cmbFiltBol.listIndex := cmbFiltBol.findObject(bol);
			cmbFiltBol_lostFocus(cmbFiltBol);
			cmbFiltBol.enabled := false;
		endif;
		
		//11 Jul 2011	NDL	Par 26476
		if self.myMobileGenericAgent &lt;&gt; null and self.myMobileGenericAgent.myPackTi &lt;&gt; null then
			if self.myMobileGenericAgent.myPackTi.dischargePort &lt;&gt; null then
				self.cmbFiltDisPort.listIndex := self.cmbFiltDisPort.findStringExact( 1, self.myMobileGenericAgent.myPackTi.dischargePort );
				cmbFiltDisPort_lostFocus(cmbFiltDisPort);
			endif;
		endif;

	endif;
	
	if id &lt;&gt; null then
		row := tblSearch.getRow(ETRow_FilterId);
		if row &gt; 0 then
			tblSearch.setCellText(row,2,id);
		endif;
		cmbFiltSite.listIndex := cmbFiltSite.findStringExact(1, app.siteEnumToString(TI_SITE_ONSITE));
		cmbFiltSite_lostFocus(cmbFiltSite);
	endif;
	
	//11 Oct 2010	NDL	Par 25836
	if site &gt; 0 then
		if preventSiteChange then //cnwrd1 9.1.2012 par 28868
			self.cmbFiltSite.clear();
			self.cmbFiltSite.itemData[self.cmbFiltSite.addItem(app.siteEnumToString(site))] := site;
		endif;
			
		cmbFiltSite.listIndex := cmbFiltSite.findStringExact(1, app.siteEnumToString(site));
		cmbFiltSite_lostFocus(cmbFiltSite);
	endif;
	
	//01 Jun 2010	NDL	Par 23903
	if delReq &lt;&gt; null then
		if delReq.myCargoType &lt;&gt; null then
			cmbFiltTiType.listIndex := cmbFiltTiType.findObject(delReq.myCargoType);
			cmbFiltTiType_lostFocus(cmbFiltTiType);
		endif;
		if delReq.mySubCargoType &lt;&gt; null then
			cmbFiltProd.listIndex := cmbFiltProd.findObject(delReq.mySubCargoType);
			cmbFiltProd_lostFocus(cmbFiltProd);
		endif;
		//24 Sep 2013	NDL	Par 32556
		if delReq.myTILCType &lt;&gt; null then
			cmbFiltTrailer.listIndex := cmbFiltTrailer.findObject(delReq.myTILCType);
			cmbFiltTrailer_lostFocus(cmbFiltTrailer);
		endif;
		if delReq.isoType &lt;&gt; null then
			cmbFiltISOType.listIndex := cmbFiltISOType.findObject(app.myRoot.allISOTypes[delReq.isoType]);
			cmbFiltISOType_lostFocus(cmbFiltISOType);
		endif;
		if delReq.operatorCode &lt;&gt; null then
			cmbFiltOperator.listIndex := cmbFiltOperator.findObject(app.myRoot.allOperators[delReq.operatorCode]);
			cmbFiltOperator_lostFocus(cmbFiltOperator);
		endif;
		
	
		
		// 15 Nov 2010	NDL	Part of Par 26055
		if delReq.voyageCode &lt;&gt; null then
			voyage := self.myMobileGenericAgent.getVoyageFromCode(delReq.voyageCode);
			if voyage &lt;&gt; null then
				cmbFiltVoyage.listIndex := cmbFiltVoyage.findObject(voyage);
				cmbFiltVoyage_lostFocus(cmbFiltVoyage);
				cmbFiltVoyage.enabled := false;	
		
				if delReq.billOfLading &lt;&gt; null then
				// Can't have a Bol without a voyage.	
					row := tblSearch.getRow(ETRow_FilterBols);
					if row &gt; 0 then
						cmbFiltBol.listIndex := cmbFiltBol.findStringExact(1,delReq.billOfLading);
						cmbFiltBol_lostFocus(cmbFiltBol);
						cmbFiltBol.enabled := false;
					endif;
				endif;
				
			endif;
		endif;
		
		
		matchFindCargoConsignee := app.myPassport.myTerminal.getConfig(IgnoreHHFindCargoConsignee).Boolean;
		if matchFindCargoConsignee then
			//epr TFS 2460 10/8/16 set consignee after the BOL cmb is set because this reloads the consignee combo
			if delReq.consigneeCode &lt;&gt; null then  // 36376
				cmbFiltConsignee.listIndex := cmbFiltConsignee.findObject(app.myRoot.allConsigneeConsignors[delReq.consigneeCode]);
				cmbFiltConsignee_lostFocus(cmbFiltConsignee);
			endif;
		endif;
		cmbFiltSite.listIndex := cmbFiltSite.findStringExact(1, app.siteEnumToString(TI_SITE_ONSITE));
		cmbFiltSite_lostFocus(cmbFiltSite);
		
		if not delReq.allAvailabilityGrades.isEmpty then
			foreach int in delReq.allAvailabilityGrades do
				avail := app.myRoot.allAvailabilityGrades.getAtKey(int);
				if avail &lt;&gt; null then
					self.tblAvail.findObjectInRow(avail, index);
					if index &gt; self.tblAvail.fixedRows and index &lt;= self.tblAvail.rows then
						self.tblAvail.setCellText(index,1,"1"); // selects the item
					endif;
				endif;
			endforeach;
			self.tblAvail.lostFocus( self.tblAvail );
		endif;
		
	endif;
	
	if booking &lt;&gt; null then
		row := tblSearch.getRow(ETRow_FilterBookingRef);
		if row &gt; 0 then
			tblSearch.setCellText(row,2,booking);
		endif;
	endif;
	
	if cargoType &lt;&gt; null then	//01 May 2013	NDL	Par 31506
		self.cmbFiltTiType.listIndex := cmbFiltTiType.findObject(cargoType);
		self.cmbFiltTiType_lostFocus(cmbFiltTiType);
	endif;
	
	if lc &lt;&gt; null then
	
		cmbFiltTermArea.listIndex := cmbFiltTermArea.findObject(lc.myTerminalArea);
		cmbFiltTermArea_lostFocus(cmbFiltTermArea);
		cmbFiltTermArea.enabled := false;
		
		if cmbFiltTermArea.listIndex &gt; 0 then
			self.cmbFiltYardLocn.listIndex := cmbFiltYardLocn.findObject(lc);
			cmbFiltYardLocn_lostFocus(cmbFiltYardLocn);
			cmbFiltYardLocn.enabled := false;
		endif;
		
	endif;
	
	//27 Oct 2016	NDL TFS 2850 / 2370
	if colour &lt;&gt; null then
		row := tblSearch.getRow(ETRow_FilterColour);
		if row &gt; 0 then
			tblSearch.setCellText(row,2,id);
		endif;
	endif;
	
	if app.myMobileCargoFindAgent.doSearchImmediate then
		app.myMobileCargoFindAgent.setDoSearchImmediate(false);
		doSearchUsingSelector();
		
		// if we only found one match then select it and return;
		if self.tblResults.rows = self.tblResults.fixedRows + 1 then
			accessRow := self.tblResults.accessRow(self.tblResults.rows);
			ti := accessRow.itemObject.CM_TrackedItem;
			app.myMobileCargoFindAgent.setMyTrackedItemToProcess(ti);
			app.myMobileCargoFindAgent.clearHistory(false);
			self.doBackButtonClick();
		endif;
		
	else
		self.setActionButton(); 
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRePopulateSearchResults" id="f94de3c6-7e07-4d3e-b171-b79a50bbaa3d">
        <updating/>
        <source>doRePopulateSearchResults() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	isoType : CM_ISOType;
	cargoType : CM_CargoType;
	voyage : CM_Voyage;
	bol : CM_BOL;
	product : CM_Product;
	id : String;
	imexCode : CM_IMEXStatus; 
	site : Integer;
	operator : CM_Operator;
	booking : String;
	disPort : CM_Port;//26 Jul 2010	NDL	Par 23761
	taType : CM_TerminalAreaType;//26 Jul 2010	NDL	Par 23761
	termArea : CM_TerminalArea;//26 Jul 2010	NDL	Par 23761
	yardLoc : CM_LocationsController;//26 Jul 2010	NDL	Par 23761
	reefersOnly : Boolean;
	canSplitOnly : Boolean;	//28 May 2013 NDL	CCMS 2275
	canMergeOnly : Boolean;	//28 May 2013 NDL	CCMS 2275
	trailerType : CM_TILCType;
	row : Integer;
	selectRow : Integer;
	index : Integer;
	viewedTrackedItem : CM_TrackedItem;
	avail : CM_MTGrade;
	colour : String;	//25 Oct 2016	NDL TFS 2850 / 2370
	mark : String;	//25 Oct 2016	NDL TFS 2850 / 2370
	
	cargoWeightKgs : Decimal [16,4];	//14 Nov 2016	NDL TFS 2959 / 2420
	tareWeightKgs : Decimal [16,4];	//14 Nov 2016	NDL TFS 2959 / 2420
	measureControl : CMUI_MeasurementTable;	//15 Nov 2016	NDL TFS 2959 / 2420
	measure : CM_MeasurementType;	//15 Nov 2016	NDL TFS 2959 / 2420

	
begin

	viewedTrackedItem := app.myMobileCargoFindAgent.myTrackedItemToView;
	
	isoType := app.myMobileCargoFindAgent.mySearchIsoType;	//29 Mar 2010	NDL	Par 23454
	cargoType :=  app.myMobileCargoFindAgent.myCargoType.CM_CargoType;
	voyage := app.myMobileCargoFindAgent.myVoyage;
	bol := app.myMobileCargoFindAgent.myBOL;	//11 Nov 2010	NDL	26055
	product := app.myMobileCargoFindAgent.myProduct;
	operator := app.myMobileCargoFindAgent.myOperator;	//01 Jun 2010	NDl	Par 23903
	id := app.myMobileCargoFindAgent.id;
	imexCode := app.myMobileCargoFindAgent.mySearchIMEX;	//29 Mar 2010	NDL	Par 23454
	site := app.myMobileCargoFindAgent.searchStateSite;	//29 Mar 2010	NDL	Par 23454
	disPort := app.myMobileCargoFindAgent.myDischargePort;//26 Jul 2010	NDL	Par 23761
	taType := app.myMobileCargoFindAgent.myTAType;//26 Jul 2010	NDL	Par 23761
	termArea := app.myMobileCargoFindAgent.myTermArea;//26 Jul 2010	NDL	Par 23761
	yardLoc := app.myMobileCargoFindAgent.myYardLoc;//26 Jul 2010	NDL	Par 23761
	booking := app.myMobileCargoFindAgent.bookingRef;//26 Jul 2010	NDL	Par 23761
	reefersOnly := app.myMobileCargoFindAgent.reefersOnly;	//02 May 2013	NDL	Par 31506
	canSplitOnly := app.myMobileCargoFindAgent.canSplitOnly;	//28 May 2013 NDL	CCMS 2275
	canMergeOnly := app.myMobileCargoFindAgent.canMergeOnly;	//28 May 2013 NDL	CCMS 2275
	trailerType := app.myMobileCargoFindAgent.myTILCType;	//24 Sep 2013	NDL	Par 32556
	colour := app.myMobileCargoFindAgent.colourString;	//25 Oct 2016	NDL TFS 2850 / 2370
	mark := app.myMobileCargoFindAgent.mark;	//25 Oct 2016	NDL TFS 2850 / 2370
	cargoWeightKgs := app.myMobileCargoFindAgent.cargoWeightKgs;		//14 Nov 2016	NDL TFS 2959 / 2420
	tareWeightKgs := app.myMobileCargoFindAgent.tareWeightKgs;		//14 Nov 2016	NDL TFS 2959 / 2420
	
	if not app.myMobileCargoFindAgent.allFilterAvailCodes.isEmpty then
		app.myMobileCargoFindAgent.allFilterAvailCodes.copy( self.allFilterAvailCodes );
		foreach avail in self.allFilterAvailCodes do
			self.tblAvail.findObjectInRow(avail, index);
			if index &gt; self.tblAvail.fixedRows and index &lt;= self.tblAvail.rows then
				self.tblAvail.setCellText(index,1,"1"); // selects the item
			endif;
		endforeach;
	endif;
	
	app.myMobileCargoFindAgent.clearRePopulateData();	//29 Mar 2010	NDL	Par 23454
	
	if id &lt;&gt; null then
		row := tblSearch.getRow(ETRow_FilterId);
		if row &gt; 0 then
			tblSearch.setCellText(row,2,id);
		endif;
	endif;
	
	if cargoType &lt;&gt; null then
		cmbFiltTiType.listIndex := cmbFiltTiType.findObject(cargoType);
		cmbFiltTiType_lostFocus(cmbFiltTiType);
	else
		cmbFiltTiType.listIndex := -1;
	endif;
	
	if isoType &lt;&gt; null then
		cmbFiltISOType.listIndex := cmbFiltISOType.findObject(isoType);
		cmbFiltISOType_lostFocus(cmbFiltISOType);
	else
		cmbFiltISOType.listIndex := -1;
	endif;
	
	//29 Mar 2010	NDL	Par 23454
	if imexCode &lt;&gt; null then
		cmbFilterIMEX.listIndex := cmbFilterIMEX.findObject(imexCode);
		cmbFilterIMEX_lostFocus(cmbFilterIMEX);
	else
		cmbFilterIMEX.listIndex := -1;
	endif;
	
	if voyage &lt;&gt; null then
		cmbFiltVoyage.listIndex := cmbFiltVoyage.findObject(voyage);
		cmbFiltVoyage_lostFocus(cmbFiltVoyage);
		if voyage = app.myMobileCargoFindAgent.myVoyage then
			cmbFiltVoyage.enabled := false;
		endif;
		if bol &lt;&gt; null then
			cmbFiltBol.listIndex := cmbFiltBol.findObject(bol);
			cmbFiltBol_lostFocus(cmbFiltBol);
			cmbFiltBol.enabled := false;
		endif;
	else
		cmbFiltVoyage.listIndex := -1;
	endif;
	
	if product &lt;&gt; null then
		cmbFiltProd.listIndex := cmbFiltProd.findObject(product);
		cmbFiltProd_lostFocus(cmbFiltProd);
	else
		cmbFiltProd.listIndex := -1;
	endif;
	
	//01 Jun 2010	NDL	Par 23903
	if operator &lt;&gt; null then
		cmbFiltOperator.listIndex := cmbFiltOperator.findObject(operator);
		cmbFiltOperator_lostFocus(cmbFiltOperator);
	else
		cmbFiltOperator.listIndex := -1;
	endif;
	
	//29 Mar 2010	NDL	Par 23454
	if site &gt; 0 then
		foreach index in 1 to cmbFiltSite.listCount do
			if self.cmbFiltSite.itemData[index] = site then
				cmbFiltSite.listIndex := index;
				cmbFiltSite_lostFocus(cmbFiltSite);
				break;
			endif;
		endforeach;
	else
		cmbFiltSite.listIndex := -1;
	endif;
	
	//26 Jul 2010	NDL	Par 23761
	if disPort &lt;&gt; null then
		cmbFiltDisPort.listIndex := cmbFiltDisPort.findObject(disPort);
		cmbFiltDisPort_lostFocus(cmbFiltDisPort);
	else
		cmbFiltDisPort.listIndex := -1;
	endif;
	
	if taType &lt;&gt; null then
		cmbFiltTAType.listIndex := cmbFiltTAType.findObject(taType);
		cmbFiltTAType_lostFocus(cmbFiltTAType);
	else
		cmbFiltTAType.listIndex := -1;
	endif;
	
	if termArea &lt;&gt; null then
		cmbFiltTermArea.listIndex := cmbFiltTermArea.findObject(termArea);
		cmbFiltTermArea_lostFocus(cmbFiltTermArea);
	else
		cmbFiltTermArea.listIndex := -1;
	endif;
	
	if yardLoc &lt;&gt; null then
		cmbFiltYardLocn.listIndex := cmbFiltYardLocn.findObject(yardLoc);
		cmbFiltYardLocn_lostFocus(cmbFiltYardLocn);
	else
		cmbFiltYardLocn.listIndex := -1;
	endif;
	//end of Par 23761
	
	//24 Sep 2013	NDL	Par 32556
	if trailerType &lt;&gt; null then
		cmbFiltTrailer.listIndex := cmbFiltTrailer.findObject(trailerType);
		cmbFiltTrailer_lostFocus(cmbFiltTrailer);
	else
		cmbFiltTrailer.listIndex := -1;
	endif;
	
	if colour &lt;&gt; null then
		row := tblSearch.getRow(ETRow_Colour);
		if row &gt; 0 then
			tblSearch.setCellText(row,2,colour);
		endif;
	endif;
	
	if mark &lt;&gt; null then
		row := tblSearch.getRow(ETRow_Mark);
		if row &gt; 0 then
			tblSearch.setCellText(row,2,mark);
		endif;
	endif;
	
	//14 Nov 2016	NDL TFS 2959 / 2420
	measure := app.getDefaultMeasurementForType( Type_Weight );
	if cargoWeightKgs &lt;&gt; 0 then
		row := tblSearch.getRow(ETRow_WeightCargo);
		if row &gt; 0 then
			measureControl := self.tblMeasurement.getControl(1).CMUI_MeasurementTable;
			measureControl.setValues(app.convertMeasurementForDisplay(measure.shortName, cargoWeightKgs) &amp; Space &amp; measure.shortName);
		endif;
	endif;
	if tareWeightKgs &lt;&gt; 0 then
		row := tblSearch.getRow(ETRow_WeightTare);
		if row &gt; 0 then
			measureControl := self.tblMeasurement.getControl(2).CMUI_MeasurementTable;
			measureControl.setValues(app.convertMeasurementForDisplay(measure.shortName, tareWeightKgs) &amp; Space &amp; measure.shortName);
		endif;
	endif;		
										
	self.loadTblResults( app.myMobileCargoFindAgent.allSearchResults );
	
	app.myMobileCargoFindAgent.setMyTrackedItemToView(null);
	
	if viewedTrackedItem &lt;&gt; null then
		foreach row in 1 to self.tblResults.rows do
			if self.tblResults.accessRow(row).itemObject = viewedTrackedItem then
				selectRow := row;
				break;
			endif;
		endforeach;
	endif;
	
	if selectRow &gt; 1 then
		self.tblResults.row := selectRow;
		self.tblResults.topRow := selectRow;
		self.tblResults.selectRow(selectRow);
		self.tblResults.leftColumn := 1;
	endif;
	
	setActionButton();
	
epilog

//	delete localTiArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="a3389a95-1d85-4831-90a7-90325c0720a4">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation

*/

vars

	folderHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	folderHeight := self.clientHeight - (self.resizedMargin * 3) - self.getCMDButtonsHeight;

	self.fldCargo.move(	self.resizedMargin,
						self.resizedMargin,
						self.clientWidth - self.resizedMargin - self.resizedMargin,
						folderHeight
						);
						
	self.tblSearch.cnAdjustColumnWidths();
	self.tblResults.cnAdjustColumnWidths();
						
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearchUsingSelector" id="d7672b58-fa7e-4b17-b728-4bc35487d7a0">
        <updating/>
        <source>doSearchUsingSelector() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2013	cnwndl1	Initial creation
//28 Nov 2016	cnwrs1	TFS 2866 use new HH config matchFindCargoConsignee
*/

vars

	isoType : CM_ISOType;
	cargoType : CM_CargoType;
	voyage : CM_Voyage;
	bol : CM_BOL;
	product : CM_Product;
	operator : CM_Operator;
	row : Integer;
	id : String;
	
	imexCode : CM_IMEXStatus;
	site : Integer;
	allQrySites : IntegerArray;
	
	terminal : CM_Terminal;
	termAreaType : CM_TerminalAreaType;
	termArea : CM_TerminalArea;
	location : CM_LocationsController;
	booking : String;
	disPort : CM_Port;
	reefersOnly : Boolean;
	canSplitOnly : Boolean;	//28 May 2013 NDL	CCMS 2275
	canMergeOnly : Boolean;	//28 May 2013 NDL	CCMS 2275
	alternateId : String;
	trailerType : CM_TILCType; //24 Sep 2013	NDL	Par 32556
	qDef : CM_QueryDefinition;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	iter : Iterator;
	startAtObject : Object;
	ti : CM_TrackedItem;
	failedDAC  :CM_DataAccessController;
	intArray : IntegerArray;
	availGrade : CM_MTGrade;
	int : Integer;
	checkAvail : Boolean;
	consignee : CM_ConsigneeConsignor;
	hidePackeditems : Boolean;
	rawId : String;
	mark : String;
	colour : String;
	tiMark : String;
	tiColour : String;
	cargoWeightKgs : Decimal [16,4];	//14 Nov 2016	NDL TFS 2959 / 2420
	tareWeightKgs : Decimal [16,4];	//14 Nov 2016	NDL TFS 2959 / 2420
	measureTbl : CMUI_MeasurementTable;	//14 Nov 2016	NDL TFS 2959 / 2420
	matchFindCargoConsignee : Boolean;
	colourList : StringArray;	//08 Dec 2016	NDL	TFS 3024 / 2370
	
begin

	app.myMobileCargoFindAgent.allSearchResults.clear();

	//find all the search values...to use off the form
	cargoType := self.cmbFiltTiType.listObject.CM_CargoType;
	isoType := self.cmbFiltISOType.listObject.CM_ISOType;
	voyage := self.cmbFiltVoyage.listObject.CM_Voyage;
	bol := self.cmbFiltBol.listObject.CM_BOL;	//03 Nov 2010	NDL	Par 26055
	product := self.cmbFiltProd.listObject.CM_Product;
	operator := self.cmbFiltOperator.listObject.CM_Operator;	//01 Jun 2010	NDL	Par 23903
	matchFindCargoConsignee := app.myPassport.myTerminal.getConfig(IgnoreHHFindCargoConsignee).Boolean;
	if matchFindCargoConsignee then
		consignee := self.cmbFiltConsignee.listObject.CM_ConsigneeConsignor;
	endif;
	row := self.tblSearch.getRow(ETRow_FilterId);
	if row &gt; 0 then
	//	id := self.tblSearch.getCellText(row,2).trimBlanks.toUpper;
	//	alternateId := id;
		//07 Jul 2016	NDL	TFS 2275 / 2216
		rawId := self.tblSearch.getCellText(row,2).trimBlanks.toUpper;
		self.convertCargoIdForSearch( rawId, null, null, null, id, alternateId );
		if rawId &lt;&gt; id then
			self.tblSearch.accessCell(self.tblSearch.row,self.tblSearch.column).text := id;
		endif;
	endif;
	imexCode := self.cmbFilterIMEX.listObject.CM_IMEXStatus;
	create allQrySites transient;
	if self.cmbFiltSite.listIndex &gt; 0 then
		site := self.cmbFiltSite.itemData[cmbFiltSite.listIndex];
		if site &gt; 0 then
			allQrySites.add(site);
		endif;
	endif;
	if allQrySites.isEmpty then
		if voyage &lt;&gt; null then
			if ( self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo
				or self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShiftOnBoard ) then
				allQrySites.add(TI_SITE_ONSHIP);
			elseif self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo then
				allQrySites.add(TI_SITE_ONSITE);
			else
				allQrySites.add(TI_SITE_ONSITE);
				allQrySites.add(TI_SITE_ONSHIP);
			endif; 
		else
			allQrySites.add(TI_SITE_ONSITE);
			allQrySites.add(SEL_QUERYSITE_NOTIFIED);
		endif;
	endif;
	termAreaType := self.cmbFiltTAType.listObject.CM_TerminalAreaType;
	termArea := self.cmbFiltTermArea.listObject.CM_TerminalArea;
	location := self.cmbFiltYardLocn.listObject.CM_LocationsController;
	row := self.tblSearch.getRow(ETRow_FilterBookingRef);
	if row &gt; 0 then
		booking := tblSearch.getCellText(row,2).trimBlanks.toUpper;
	endif;
	disPort := self.cmbFiltDisPort.listObject.CM_Port;
	reefersOnly := app.myMobileCargoFindAgent.reefersOnly;
	canSplitOnly := app.myMobileCargoFindAgent.canSplitOnly;	//28 May 2013 NDL	CCMS 2275
	canMergeOnly := app.myMobileCargoFindAgent.canMergeOnly;	//28 May 2013 NDL	CCMS 2275
	terminal := self.myMobileDataAgent.myTerminal;
	trailerType := self.cmbFiltTrailer.listObject.CM_TILCType; //24 Sep 2013	NDL	Par 32556
	hidePackeditems := app.myMobileCargoFindAgent.hidePackeditems;	//16 July 2014	NDL	Par 34571
	row := self.tblSearch.getRow(ETRow_Mark);
	if row &gt; 0 then
		mark := tblSearch.getCellText(row,2).trimBlanks.toUpper;
	endif;
	row := self.tblSearch.getRow(ETRow_FilterColour);
	if row &gt; 0 then
		colour := tblSearch.getCellText(row,2).trimBlanks.toUpper;
	endif;
	
	//08 Dec 2016	NDL	TFS 3024 / 2370
	row := self.tblSearch.getRow(ETRow_FilterColourList);
	if row &gt; 0 then
		create colourList transient;
		self.doCurrentColourListActions( false, false, false, row, colourList );
	endif;
	
	//14 Nov 2016	NDL TFS 2959 / 2420
	row := self.tblSearch.getRow(ETRow_WeightCargo);
	if row &gt; 0 then
		measureTbl := self.tblMeasurement.getControl(1).CMUI_MeasurementTable;
		if measureTbl &lt;&gt; null then
			cargoWeightKgs := measureTbl.getConvertedValue;
		endif;
	endif;
	
	//14 Nov 2016	NDL TFS 2959 / 2420
	row := self.tblSearch.getRow(ETRow_WeightTare);
	if row &gt; 0 then
		measureTbl := self.tblMeasurement.getControl(2).CMUI_MeasurementTable;
		if measureTbl &lt;&gt; null then
			tareWeightKgs := measureTbl.getConvertedValue;
		endif;
	endif;
	
	//establish the correct query definition to use
	if isoType &lt;&gt; null
	or reefersOnly
	or cargoType = app.myRoot.allCargoTypesById[ TI_CargoType_Container ]
	then
		qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,TI_CargoType_Container];
	else
		qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	endif;
	
	if canSplitOnly or canMergeOnly then
		qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	endif;

	if self.myEnqController &lt;&gt; null then
		delete self.myEnqController;
	endif;
	
	//create the selector query object.
	create self.myEnqController;
	create self.myEnqController.allObjects as  CM_TISet transient;
	create criteriaHolder transient;
	self.myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	//create the individual query lines
	self.doCreateCriteriaLine(qDef, CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, terminal);
	if isoType &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, CM_Container::isoType.name, CM_QueryOperator.Operator_Equal, isoType);
	endif;
	if cargoType &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
	endif;
	if voyage &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, voyage);
	endif;
	if bol &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::billOfLading.name, CM_QueryOperator.Operator_Equal, bol.number); //epr par 32963 11/11/13
	endif;
	if product &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::myProduct.name, CM_QueryOperator.Operator_Equal, product);
	endif;
	if operator &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, operator);
	endif;
	if consignee &lt;&gt; null then  // 36376
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::consignee.name, CM_QueryOperator.Operator_Equal, consignee);
	endif;
	if id &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::id.name, CM_QueryOperator.Operator_StartsOrEndsWith, id);
	endif;
	if imexCode &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::imexStatus.name, CM_QueryOperator.Operator_Equal, imexCode);
	endif;
	if not allQrySites.isEmpty then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::site.name, CM_QueryOperator.Operator_IsOneOf, allQrySites);
	endif;
	if termArea &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::myTerminalArea.name, CM_QueryOperator.Operator_Equal, termArea);
	endif;
	if location &lt;&gt; null then
		if location.isWagon then
			// so it finds all cargo on the wagon. 02 Oct 2014	NDL - Par 34981  // 13 Mar 2015	NDL	Par 35828
			// TFS 2450 28/07/2016 take the RailDefaultWCIdFormat configuration setting into account - is either location id or wagon id
			//self.doCreateCriteriaLine(qDef, CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_StartsWith, location.CM_WagonController.myWagon.id );
			//epr TFS 37241 5/3/17 tfs 2450 never fixed the problem doesn't look like it was ever tested
			self.doCreateCriteriaLine(qDef, CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_StartsWith, location.getLocationArea);
			
		else
			self.doCreateCriteriaLine(qDef, CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_Equal, location.getFullId);
		endif;
	endif;
	if booking &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::bookingReference.name, CM_QueryOperator.Operator_Equal, booking);
	endif;
	if disPort &lt;&gt; null 	then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::dischargePort.name, CM_QueryOperator.Operator_Equal, disPort);
	endif;
	if reefersOnly then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::isReefer.name, CM_QueryOperator.Operator_Equal, true.getYes );
	endif;
	if canSplitOnly then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::canSplitTotalQuantity.name, CM_QueryOperator.Operator_Equal, true.getYes );
	endif;
	if canMergeOnly then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::canMergeBreakBulk.name, CM_QueryOperator.Operator_Equal, true.getYes );
	endif;
	if hidePackeditems then	//16 July 2014	NDL	Par 34571
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::isChild.name, CM_QueryOperator.Operator_Equal, null );
	endif;
	
	create intArray transient;
	if not self.allFilterAvailCodes.isEmpty then
		foreach availGrade in self.allFilterAvailCodes do
			int := availGrade.code;
			intArray.add(int);
		endforeach;
		if qDef.mode = TI_CargoType_Container then
			self.doCreateCriteriaLine(qDef, CM_Container::availabilityGrade.name, CM_QueryOperator.Operator_IsOneOf, intArray);
		endif;
	endif;
	
	if colourList &lt;&gt; null and not colourList.isEmpty then
		//08 Dec 2016	NDL	TFS 3024 / 2370
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::getColour.name, CM_QueryOperator.Operator_IsOneOf, colourList );
	elseif colour &lt;&gt; null then
		//25 Oct 2016	NDL TFS 2850 / 2370
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::getColour.name, CM_QueryOperator.Operator_Contains, colour );
	endif;
	//25 Oct 2016	NDL TFS 2850 / 2370
	if mark &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, CM_TrackedItem::mark.name, CM_QueryOperator.Operator_Contains, mark );
	endif;
	//14 Nov 2016	NDL TFS 2959 / 2420
	if cargoWeightKgs &gt; 0 then
		self.doCreateCriteriaLine(qDef, "kg_" &amp; CM_TrackedItem::weightCargo.name, CM_QueryOperator.Operator_Equal, cargoWeightKgs );	
	endif;
	//14 Nov 2016	NDL TFS 2959 / 2420
	if tareWeightKgs &gt; 0 then
		self.doCreateCriteriaLine(qDef, "kg_" &amp; CM_TrackedItem::weightTare.name, CM_QueryOperator.Operator_Equal, tareWeightKgs );
	endif;
	
	//08 Feb 2017	NDL	TFS 3191/2876
	if app.myMobileCargoFindAgent.reUseSearchCriteria then
		// save off the search criteria from the table for future use.
		self.setSearchCriteriaAsXML();
	endif;

	// call the query
	self.myEnqController.doQuery( qDef );
	
	//populate collection from the results
	checkAvail := ( qDef.mode &lt;&gt; TI_CargoType_Container and not intArray.isEmpty );
	foreach ti in self.myEnqController.allObjects.CM_TISet do
		//26 Feb 2015	NDL	Par 35604 - Oops we were getting TBAs occasionally.
		if  ti.isTBAorIsRRP then
			continue;
		endif;
			
		//24 Sep 2013	NDL	Par 32556
		if trailerType &lt;&gt; null then
			if not ti.isKindOf(CM_TILC) then
				continue;
			endif;
			if ti.CM_TILC.myTILCType &lt;&gt; trailerType then
				continue;
			endif;
		endif;
		
		if checkAvail then
			if not intArray.includes(ti.getAvailabilityGrade) then
				continue;
			endif;
		endif;
	
		if termAreaType = null or ( ti.myTerminalArea &lt;&gt; null and ti.myTerminalArea.myType = termAreaType) then
			app.myMobileCargoFindAgent.allSearchResults.add( ti );
		endif;
	endforeach;
	
	
	
	// add in any with matching alternate ids
	if allQrySites.includes(TI_SITE_ONSITE) and alternateId &lt;&gt; null then
		iter := terminal.allOnsiteTIsByAlternativeId.createIterator;
		startAtObject := terminal.allOnsiteTIsByAlternativeId.getAtKeyGeq( alternateId );
		if startAtObject &lt;&gt; null then
			iter.startAtObject(startAtObject);
			while iter.next( ti ) do
				if ti.alternativeId &lt;&gt; alternateId then
					break;
				endif;
				if app.myMobileCargoFindAgent.allSearchResults.includes( ti ) then
					continue;
				endif;
				
				//27 Oct 2016	NDL TFS 2850 / 2370
				if colour &lt;&gt; null then
					tiColour := ti.getColour.toUpper;
					if tiColour = null or tiColour.pos(colour,1) &lt; 1 then
						continue;
					endif;
				//08 Dec 2016	NDL TFS 3024 / 2370
				elseif colourList &lt;&gt; null and not colourList.isEmpty then
					tiColour := ti.getColour;
					if tiColour = null or not colourList.includes( tiColour) then
						continue;
					endif;
				endif;
				//27 Oct 2016	NDL TFS 2850 / 2370
				if mark &lt;&gt; null then
					tiMark := ti.mark.toUpper;
					if tiMark = null or tiMark.pos(mark,1) &lt; 1 then
						continue;
					endif;
				endif;
				
				if (voyage = null or ti.myVoyage = voyage
					or (ti.isTranshipItem and (ti.myExportVoyage = voyage) or (ti.myImportVoyage = voyage)))
				and (operator = null or ti.myOperator = operator) 
				and (isoType = null or ti.getISOTypeObject = isoType) 
				and	(cargoType = null or ti.cargoType = cargoType.id)
				and	(product = null or ti.productCode = product.code)
				and (disPort = null or ti.dischargePort = disPort.code)
				and (bol = null or ti.billOfLading = bol.number)
				and (imexCode = null or ti.getImExStatusObject = imexCode)
				and (termArea = null or ti.myTerminalArea = termArea)
				and (termAreaType = null or ( ti.myTerminalArea &lt;&gt; null and ti.myTerminalArea.myType = termAreaType) )
				and (location = null or ti.locationId = location.getFullId)
				and (booking = null or ti.bookingReference = booking)
				and (cargoWeightKgs = 0 or ti.weightCargo = cargoWeightKgs)	//14 Nov 2016	NDL	TFS 2959 / 2420
				and (tareWeightKgs = 0 or ti.weightTare = tareWeightKgs)	//14 Nov 2016	NDL	TFS 2959 / 2420
				and (not reefersOnly or ti.isReefer)
				and (not canSplitOnly or ti.canSplitTotalQuantity)
				and (not canMergeOnly or ti.canMergeBreakBulk)
				and (trailerType = null or ( ti.isKindOf(CM_TILC) and ti.CM_TILC.myTILCType = trailerType) )	//24 Sep 2013	NDL	Par 32556
				and (intArray.isEmpty or intArray.includes(ti.getAvailabilityGrade) )
				then
					if (not ti.canUserAccessSelf(null, failedDAC, app.myPassport)) then
						continue;
					endif;
				endif;
				app.myMobileCargoFindAgent.allSearchResults.add(ti);
			endwhile;
		endif;
	endif;
	
	//28 Sep 2015	NDL	Par 36338
	//Handle direct search for a Cargo Group by ID when cargo type not selected.
	if id &lt;&gt; null and cargoType = null and app.isCargoGroupEnabled then
		iter := terminal.allCargoGroupsByIdCargoType.createIterator;
		startAtObject := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq( id, null );
		if startAtObject &lt;&gt; null then
			iter.startAtObject(startAtObject);
			while iter.next( ti ) do
				if ti.id &lt;&gt; id then
					break;
				endif;
				if app.myMobileCargoFindAgent.allSearchResults.includes( ti ) then
					continue;
				endif;
				
				//27 Oct 2016	NDL TFS 2850 / 2370
				if colour &lt;&gt; null then
					tiColour := ti.getColour.toUpper;
					if tiColour = null or tiColour.pos(colour,1) &lt; 1 then
						continue;
					endif;
				//08 Dec 2016	NDL TFS 3024 / 2370
				elseif colourList &lt;&gt; null and not colourList.isEmpty then
					tiColour := ti.getColour;
					if tiColour = null or not colourList.includes( tiColour) then
						continue;
					endif;
				endif;
				//27 Oct 2016	NDL TFS 2850 / 2370
				if mark &lt;&gt; null then
					tiMark := ti.mark.toUpper;
					if tiMark = null or tiMark.pos(mark,1) &lt; 1 then
						continue;
					endif;
				endif;
				
				if (voyage = null or ti.myVoyage = voyage
					or (ti.isTranshipItem and (ti.myExportVoyage = voyage) or (ti.myImportVoyage = voyage)))
				and (operator = null or ti.myOperator = operator) 
				and (isoType = null or ti.getISOTypeObject = isoType) 
				and	(product = null or ti.productCode = product.code)
				and (disPort = null or ti.dischargePort = disPort.code)
				and (bol = null or ti.billOfLading = bol.number)
				and (imexCode = null or ti.getImExStatusObject = imexCode)
				and (termArea = null or ti.myTerminalArea = termArea)
				and (termAreaType = null or ( ti.myTerminalArea &lt;&gt; null and ti.myTerminalArea.myType = termAreaType) )
				and (location = null or ti.locationId = location.getFullId)
				and (booking = null or ti.bookingReference = booking)
				and (cargoWeightKgs = 0 or ti.weightCargo = cargoWeightKgs)	//14 Nov 2016	NDL	TFS 2959 / 2420
				and (tareWeightKgs = 0 or ti.weightTare = tareWeightKgs)	//14 Nov 2016	NDL	TFS 2959 / 2420
				and (not reefersOnly or ti.isReefer)
				and (not canSplitOnly or ti.canSplitTotalQuantity)
				and (not canMergeOnly or ti.canMergeBreakBulk)
				and (trailerType = null or ( ti.isKindOf(CM_TILC) and ti.CM_TILC.myTILCType = trailerType) )	//24 Sep 2013	NDL	Par 32556
				and (intArray.isEmpty or intArray.includes(ti.getAvailabilityGrade) )
				then
					if (not ti.canUserAccessSelf(null, failedDAC, app.myPassport)) then
						continue;
					endif;
				endif;
				app.myMobileCargoFindAgent.allSearchResults.add(ti);
			endwhile;
		endif;
	endif;
	
	
	self.loadTblResults( app.myMobileCargoFindAgent.allSearchResults );
	
									
	// 25 Mar 2010	NDL	Par 23325
	// so that the filter is set up for when we return to the form again if we go off and do a view...
	app.myMobileCargoFindAgent.setID(id);
	app.myMobileCargoFindAgent.setMyBOL(bol);
	app.myMobileCargoFindAgent.setMyBookingRef( booking );
	app.myMobileCargoFindAgent.setMyCargoType(cargoType);
	app.myMobileCargoFindAgent.setMyDischargePort(disPort);
	app.myMobileCargoFindAgent.setMyIMEX(imexCode);
	app.myMobileCargoFindAgent.setMyIsoType(isoType);
	app.myMobileCargoFindAgent.setMyOperator(operator);
	app.myMobileCargoFindAgent.setMyProduct(product);
	app.myMobileCargoFindAgent.setMyTAType(termAreaType);
	app.myMobileCargoFindAgent.setMyTermArea(termArea);
	app.myMobileCargoFindAgent.setMyVoyage(voyage);
	app.myMobileCargoFindAgent.setMyYardLoc(location);
	app.myMobileCargoFindAgent.setReefersOnly(reefersOnly);
	app.myMobileCargoFindAgent.setCanSplitOnly(canSplitOnly);
	app.myMobileCargoFindAgent.setCanMergeOnly(canMergeOnly);	//28 May 2013 NDL	CCMS 2275
	app.myMobileCargoFindAgent.setSearchSite(allQrySites.first);
	app.myMobileCargoFindAgent.setMyTILCType(trailerType);	//24 Sep 2013	NDL	Par 32556
	app.myMobileCargoFindAgent.setHidePackItems(hidePackeditems);	//16 July 2014	NDL	Par 34571
	app.myMobileCargoFindAgent.setColourString(colour);	//25 Oct 2016	NDL TFS 2850 / 2370
	app.myMobileCargoFindAgent.setMark( mark);		//25 Oct 2016	NDL TFS 2850 / 2370
	app.myMobileCargoFindAgent.setCargoWeightKgs(cargoWeightKgs); //14 Nov 2016	NDL	TFS 2959 / 2420
	app.myMobileCargoFindAgent.setTareWeightKgs(tareWeightKgs); //14 Nov 2016	NDL	TFS 2959 / 2420
		
epilog

	
	delete allQrySites;
	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fldCargo_sheetChg" id="bd82e75d-3616-4563-b1d1-185a7b6cac89">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldCargo_sheetChg(folder: Folder input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	nullArray : StringArray;

begin

	self.setActionButton();
	if folder.topSheet = self.shtFind then
		self.doCurrentColourListActions( true, false, false, 0, nullArray );	//08 Dec 2016	TFS 3024  2370
	endif;
	
epilog

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCurrentlySelectedTi" id="83eebed5-36e2-46d5-b3a0-fc58f1bb8a4b">
        <source>getCurrentlySelectedTi() : CM_TrackedItem protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	row : Integer;
	accessRow : JadeTableRow;
	ti : CM_TrackedItem;
	
begin

	row := tblResults.row;
	if row &gt; 0 then
		accessRow := tblResults.accessRow(row);
		if accessRow.selected then
			ti := accessRow.itemObject.CM_TrackedItem;
		endif;
	endif;
	
	return ti;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getEntryTableForRow" id="867380d1-55ba-486a-b4bf-3cb543b21c11">
        <source>getEntryTableForRow(_rowName: String): CM_MobEntryTable;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2016	cnwndl1	Initial creation	TFS 2959 / 2420

*/

vars

begin
	return self.tblSearch;

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="CM_MobEntryTable"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="afb2cfb1-37d4-403e-8b5b-1088784b35b4">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	ti : CM_TrackedItem;
	
begin

	if self.actionButtonState = self.SelectCargo then
		ti := self.getCurrentlySelectedTi();
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(ti);
		app.myMobileCargoFindAgent.clearHistory(false);
		self.doBackButtonClick();
	
	elseif self.actionButtonState = self.FindCargo then
		self.doSearchUsingSelector();
	
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnThree" id="c684d43d-0e8c-4d23-8d54-662212dc5c3f">
        <updating/>
        <source>handleBtnThree() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	app.myMobileCargoFindAgent.setHideOnTransportTIs(false);			// TFS 38111 13/04/2018 jlgmd1
	app.myMobileCargoFindAgent.clearHistory(false);
	self.doBackButtonClick();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="d5e489d0-3a79-424b-bc04-621e37257aba">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	ti : CM_TrackedItem;
begin

	//user clicked View
	ti := self.getCurrentlySelectedTi();
	if ti &lt;&gt; null then
		app.myMobileCargoFindAgent.setMyTrackedItemToView(ti);
		app.myMobileCargoFindAgent.setFiltAvailGardes( self.allFilterAvailCodes );
		if self.myTerminal.getHandHeldConfig( null ) &lt;&gt; null then	//07 Dec 2016	NDL	TFS 3008 / 2370
			self.gotoForm( MOB_HHCargoView, false );
		else
			self.gotoForm( MOB_HHCargoDisplay, false );
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTblResults" id="8de841e3-bde9-46d5-a0f8-f65acc52572e">
        <updating/>
        <source>loadTblResults( _coll : CM_TIArray ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	str : String;
	rowIdx : Integer;
	
begin

	self.tblResults.rows := self.tblResults.fixedRows;
	
	if _coll.isEmpty then
		self.msgBox(app.getErrorString(No_Cargo_Match_search_criteria), app.getErrorString(Warning), MsgBox_OK_Only, false);
		return;
	endif;
	
	iter := _coll.createIterator;
	while iter.next( ti ) do
		//str := ti.getAttributeStringForDefArray(self.myResultsEntTableView.allEntTableRows);
		str := ti.getAttributeStringForDefArray( self.myResultsTblEntRows );
		if str &lt;&gt; null then
			rowIdx := self.tblResults.addItem(str);
			self.tblResults.accessRow(rowIdx).itemObject := ti; 
			if rowIdx &gt; 31999 then	// Tomek testing....
				self.msgBox(app.getErrorString1(MaxTablesRowsReached, JadeTableRowLimit.String), app.getErrorString(Warning), MsgBox_OK_Only, false);
				break;
			endif;
		endif;
	endwhile;
	
	self.tblResults.leftColumn := 1;
	
	self.tblResults.cnAdjustColumnWidths();
	
	self.shtResults.setFocus();
	//self.setActionButton();
	
epilog

	delete iter;
	self.setActionButton();
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="loadTblSearch" id="34cb04f3-bc46-4086-9f3e-c532447d0891">
        <updating/>
        <source>loadTblSearch() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	//load up combos used in table
	self.populateSearchCombos();
	
	self.populateTblAvail();
	
	self.setWeightSearchFields();	//15 Nov 2016	NDL	TFS 2959 / 2420
	
	self.tblResults.cnAdjustColumnWidths();
	// 36675 make search table left-justified
	self.tblSearch.leftColumn := 1;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbFiltBol" id="21514b66-d4ff-411c-a8e5-153387ea5732">
        <source>populateCmbFiltBol();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2010	cnwndl1	Initial creation	Par 26055

*/

vars

	voyage : CM_Voyage;
	beforeBol : CM_BOL;
	bol : CM_BOL;

begin

	voyage := self.cmbFiltVoyage.listObject.CM_Voyage;
	beforeBol := self.cmbFiltBol.listObject.CM_BOL;
	
	self.cmbFiltBol.clear();
	
	if voyage = null then
		return;
	endif;

	foreach bol in voyage.allBOLOutByTypeStatusNumDT do
		self.cmbFiltBol.itemObject[self.cmbFiltBol.addItem(bol.number)] := bol;
	endforeach;
	foreach bol in voyage.allBOLInByTypeStatusNumDT do
		self.cmbFiltBol.itemObject[self.cmbFiltBol.addItem(bol.number)] := bol;
	endforeach;
	
	if beforeBol &lt;&gt; null then
		self.cmbFiltBol.listIndex := self.cmbFiltBol.findObject(beforeBol);
	endif;
	cmbFiltBol.lostFocus(cmbFiltBol);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateConsignees" id="0b542701-08e4-4052-83f4-da4c8d5a1330">
        <source>populateConsignees();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwdw1	Initial creation  36376
*/
vars
	bol: CM_BOL;
	ti: CM_TrackedItem;
	consignee : CM_ConsigneeConsignor;
	beforeConsignee : CM_ConsigneeConsignor;
begin



	// PAR 36376
	beforeConsignee := cmbFiltConsignee.listObject.CM_ConsigneeConsignor;
	
	self.cmbFiltConsignee.clear();
	self.cmbFiltConsignee.addItem(null); //31 Aug 2015	NDL	Par 36839
	bol := self.cmbFiltBol.listObject.CM_BOL;
	if bol &lt;&gt; null then
		foreach ti in bol.allTrackedItems do
			if ti.myConsignee &lt;&gt; null and self.cmbFiltConsignee.findObject(ti.myConsignee) = -1 then
				self.cmbFiltConsignee.itemObject[self.cmbFiltConsignee.addItem(ti.myConsignee.code)] := ti.myConsignee;
			endif;
		endforeach;
	else
		foreach consignee in app.myRoot.allConsigneeConsignors where not consignee.isNotAvailableForEntry do
			if consignee.isConsignee then
				self.cmbFiltConsignee.itemObject[self.cmbFiltConsignee.addItem(consignee.code)] := consignee;
			endif;
		endforeach;
	endif;
	
	if beforeConsignee &lt;&gt; null then
		self.cmbFiltConsignee.listIndex := self.cmbFiltConsignee.findObject(beforeConsignee);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateDischargePorts" id="0f12ec1d-45b8-4f8e-8b66-886e5abe44bd">
        <source>populateDischargePorts();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	cnwndl1	Initial creation		CCMS 1077 Par 23761

*/

vars

	voyage : CM_Voyage;
	beforeDischargePort : CM_Port;
	port : CM_Port;
	
begin

	voyage := self.cmbFiltVoyage.listObject.CM_Voyage;
	beforeDischargePort := self.cmbFiltDisPort.listObject.CM_Port;
	
	self.cmbFiltDisPort.clear();
	
	if voyage = null then
		return;
	endif;

	foreach port in voyage.allPorts do
		self.cmbFiltDisPort.itemObject[self.cmbFiltDisPort.addItem(port.code)] := port;
	endforeach;
	
	if beforeDischargePort &lt;&gt; null then
		self.cmbFiltDisPort.listIndex := self.cmbFiltDisPort.findObject(beforeDischargePort);
	endif;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateFilterLocations" id="5ea0b4cb-a23f-45c3-bb8a-e2065e1e2656">
        <source>populateFilterLocations( _combo : ComboBox );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	cnwndl1	Initial creation		CCMS 1077 Par 23761
16 Nov 2010		NDL 	Par 26055

*/

vars

	beforeTAType : CM_TerminalAreaType;
	beforeTA : CM_TerminalArea;
	beforeLocCont : CM_LocationsController;
	
	iter : Iterator;
	index : Integer;
	taType : CM_TerminalAreaType;
	locCont : CM_LocationsController;
	
	combo : ComboBox;
	bol : CM_BOL;
	bolTaTypes : CM_TATypeByTypeDict;
	bolTAs : CM_TAByTerminalIdDict;
	bolLocs : CM_LCSet;
	taMaster : CM_TerminalAreaMaster;
	ta : CM_TerminalArea;
	filtByTaType : Boolean;
	
begin

	combo := _combo;
	
	beforeTAType := cmbFiltTAType.listObject.CM_TerminalAreaType;
	beforeTA := cmbFiltTermArea.listObject.CM_TerminalArea;
	beforeLocCont := cmbFiltYardLocn.listObject.CM_LocationsController;
	bol := self.cmbFiltBol.listObject.CM_BOL;
	
	if bol &lt;&gt; null then
		create bolTaTypes transient;
		create bolTAs transient;
		create bolLocs transient;
		self.doBolSearchForTermAreas( bol, bolTaTypes, bolTAs , bolLocs);
	endif;
	
	if combo = self.cmbFiltBol then
		// lost focus on Bill of Lading
		if bol = null then
			// No selection, treat as if loading from scratch.
			combo := null;
		elseif bol &lt;&gt; null then
			// has a bol, only show area types and areas relevant to onsite cargo for this Bol.
			self.cmbFiltTAType.clear;
			iter :=  bolTaTypes.createIterator;
			index := self.cmbFiltTAType.addItem("");
			self.cmbFiltTAType.itemObject[index] := null;
			while iter.next( taType ) do
				index := self.cmbFiltTAType.addItem(taType.description);
				self.cmbFiltTAType.itemObject[index] := taType;
			endwhile;
			delete iter;
			
			if beforeTAType &lt;&gt; null then
				self.cmbFiltTAType.listIndex := self.cmbFiltTAType.findObject(beforeTAType);
				filtByTaType := self.cmbFiltTAType.listIndex &gt; 1;
			endif;
			
			self.cmbFiltTAType.lostFocus(self.cmbFiltTAType);
		
			return;
			
		endif;
	endif;
	
	
	if combo = null then
		// loading from scratch.
		
		// load Term Area Type
		self.cmbFiltTAType.clear;
		iter :=  app.myRoot.allTerminalAreaTypes.createIterator;
		index := self.cmbFiltTAType.addItem("");
		self.cmbFiltTAType.itemObject[index] := null;
		while iter.next( taType ) do
			if taType.getIsNotAvailableForEntry then
				continue;
			endif;
			if taType.type = TA_TYPE_BUILDING then
				continue;
			endif;
			index := self.cmbFiltTAType.addItem(taType.description);
			self.cmbFiltTAType.itemObject[index] := taType;
		endwhile;
		delete iter;
		
		if beforeTAType &lt;&gt; null then
			self.cmbFiltTAType.listIndex := self.cmbFiltTAType.findObject(beforeTAType);
		endif;
		
		self.cmbFiltTAType.lostFocus(self.cmbFiltTAType);
		
		
	elseif combo = self.cmbFiltTAType then
		// lost focus on Term Area Type
		self.cmbFiltTermArea.clear();
		
		if bol = null then
			if beforeTAType = null then
				//load all term areas.
				self.getSessionAgent().loadTermAreaCmb( self.cmbFiltTermArea, TA_TYPE_NULL );
			else
				//load all term areas of teh type beforeTAType.
				self.getSessionAgent().loadTermAreaCmb( self.cmbFiltTermArea, beforeTAType.type );
			endif;
			
			index := self.cmbFiltTermArea.addItem("");
			self.cmbFiltTermArea.itemObject[index] := null;
			
		elseif bol &lt;&gt; null then
			index := self.cmbFiltTermArea.addItem("");
			self.cmbFiltTermArea.itemObject[index] := null;
			foreach taMaster in bolTAs do
				ta := taMaster.CM_TerminalArea;
				if beforeTAType &lt;&gt; null then
					if ta.myType &lt;&gt; beforeTAType then
						continue;
					endif;
				endif;
				index := self.cmbFiltTermArea.addItem(ta.id);
				self.cmbFiltTermArea.itemObject[index] := ta;
			endforeach;
			
		endif;
		
		if beforeTA &lt;&gt; null then
			self.cmbFiltTermArea.listIndex := self.cmbFiltTermArea.findObject(beforeTA);
		endif;
		
		self.cmbFiltTermArea.lostFocus(self.cmbFiltTermArea);
	
	elseif combo = self.cmbFiltTermArea then
		// lost focus on Term Area
		self.cmbFiltYardLocn.clear();
		if beforeTA &lt;&gt; null then
			if bol = null then
				iter := beforeTA.allLocationsControllers.createIterator;
				while iter.next( locCont ) do
					if locCont.isWagon then
						if locCont.CM_WagonController.isDeparted then
							continue;
						endif;
					endif;
					index := self.cmbFiltYardLocn.addItem( locCont.getFullId );
					self.cmbFiltYardLocn.itemObject[index] := locCont;
				endwhile;
				delete iter;
			
			elseif bol &lt;&gt; null then
				iter := bolLocs.createIterator;
				while iter.next( locCont ) do
					if locCont.myTerminalArea &lt;&gt; beforeTA then
						continue;
					endif;
					if locCont.isWagon then
						if locCont.CM_WagonController.isDeparted then
							continue;
						endif;
					endif;
					index := self.cmbFiltYardLocn.addItem( locCont.getFullId );
					self.cmbFiltYardLocn.itemObject[index] := locCont;
				endwhile;
				delete iter;
				
			endif;
			
			index := self.cmbFiltYardLocn.addItem("");
			self.cmbFiltYardLocn.itemObject[index] := null;
		
		endif;
		
		if beforeLocCont &lt;&gt; null then
			self.cmbFiltYardLocn.listIndex := self.cmbFiltYardLocn.findObject(beforeLocCont);
		endif;
		
		self.cmbFiltYardLocn.lostFocus(self.cmbFiltYardLocn);
	
	endif;
	
epilog

	delete iter;
	delete bolTaTypes;
	delete bolTAs;
	delete bolLocs;
	
end;</source>
        <Parameter name="_combo" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="populateSearchCombos" id="a7b48e9d-d1f4-4c7c-b366-63f162ed832c">
        <source>populateSearchCombos();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	isoType : CM_ISOType;
	cargoType : CM_CargoType;
	voyage : CM_Voyage;
	product : CM_Product;
	stat : CM_IMEXStatus;
	operator : CM_Operator;
	term : CM_Terminal;
	nullVoyage : CM_Voyage;
	
begin
	term := self.myMobileGenericAgent.getTerminal();
	
	self.cmbFiltTiType.clear();
	foreach cargoType in app.myRoot.allCargoTypesById do
		if cargoType.isNotAvailableForEntry then
			continue;
		endif;
		if term &lt;&gt; null and not cargoType.allTerminals.includes(term) then
			continue;
		endif;
		
		self.cmbFiltTiType.itemObject[self.cmbFiltTiType.addItem(cargoType.description)] := cargoType;	
	endforeach;
	
	self.cmbFiltVoyage.clear();
	self.myMobileGenericAgent.setCurrentVoyages();
	//11 Oct 2011	NDL	Par 28396
	self.cmbFiltVoyage.itemObject[self.cmbFiltVoyage.addItem(null)] := null;	
	
	if term &lt;&gt; null then
		nullVoyage := term.getNullVoyage;
		if nullVoyage &lt;&gt; null then
			self.cmbFiltVoyage.itemObject[self.cmbFiltVoyage.addItem(nullVoyage.code)] := nullVoyage;
		endif;
	endif;
	foreach voyage in self.myMobileGenericAgent.allCurrentVoyages do
		self.cmbFiltVoyage.itemObject[self.cmbFiltVoyage.addItem(voyage.code)] := voyage;
	endforeach;
	
	self.cmbFiltTiType.enabled := cmbFiltTiType.listCount &gt; 0;
	self.cmbFiltVoyage.enabled := cmbFiltVoyage.listCount &gt; 0;
	
	self.populateSubCargo( cmbFiltProd.listObject.CM_CargoType );
	
	self.cmbFilterIMEX.clear();
	foreach stat in app.myRoot.allImexStatuses do
		self.cmbFilterIMEX.itemObject[self.cmbFilterIMEX.addItem(stat.description)] := stat;
	endforeach;
	
	self.cmbFiltSite.clear();
	self.cmbFiltSite.sorted := false;
	self.cmbFiltSite.itemData[self.cmbFiltSite.addItem(app.siteEnumToString(TI_SITE_ONSITE))] := TI_SITE_ONSITE;
	self.cmbFiltSite.itemData[self.cmbFiltSite.addItem(app.siteEnumToString(TI_SITE_ONSHIP))] := TI_SITE_ONSHIP;
	self.cmbFiltSite.itemData[self.cmbFiltSite.addItem(app.siteEnumToString(TI_SITE_TBA))] := TI_SITE_TBA;
	self.cmbFiltSite.itemData[self.cmbFiltSite.addItem(app.siteEnumToString(TI_SITE_PLACEHOLDER))] := TI_SITE_PLACEHOLDER;	//13 Mar 2020	NDL	TFS 47004
	self.cmbFiltSite.itemData[self.cmbFiltSite.addItem(app.siteEnumToString(TI_SITE_OFFSITE))] := TI_SITE_OFFSITE;
//	self.cmbFiltSite.itemData[self.cmbFiltSite.addItem(app.siteEnumToString(TI_SITE_UNDEFINED))] := TI_SITE_UNDEFINED;

	//01 Jun 2010	NDL	Par 23903
	self.cmbFiltOperator.clear();
	foreach operator in app.myRoot.allOperators where not operator.isNotAvailableForEntry do
		self.cmbFiltOperator.itemObject[self.cmbFiltOperator.addItem(operator.code)] := operator;
	endforeach;
	
	self.populateDischargePorts();
	self.populateCmbFiltBol();	//03 Nov 2010	NDL	Par 26055
	self.populateConsignees();
	
	self.populateFilterLocations(null);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateSubCargo" id="f736e05e-659f-4bbb-a3c3-05fdcf05d9a8">
        <source>populateSubCargo( _cargoType : CM_CargoType ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	beforeProd : CM_Product;
	beforeIsoType : CM_ISOType;
	beforeTrailerType : CM_TILCType;		//24 Sep 2013	NDL	Par 32556
	iter : Iterator;
	product : CM_Product;
	isoType : CM_ISOType;
	trailerType : CM_TILCType;		//24 Sep 2013	NDL	Par 32556
	
begin

	beforeProd := cmbFiltProd.listObject.CM_Product;
	beforeIsoType := cmbFiltISOType.listObject.CM_ISOType;
	beforeTrailerType := cmbFiltTrailer.listObject.CM_TILCType;	//24 Sep 2013	NDL	Par 32556
	self.cmbFiltProd.clear();
	self.cmbFiltISOType.clear();
	self.cmbFiltTrailer.clear();
	
	if _cargoType = null then
	
		
	else
		foreach product in _cargoType.allProducts do
			if product.isNotActive then
				continue;
			endif;
			self.cmbFiltProd.itemObject[self.cmbFiltProd.addItem(product.description )] := product;
		endforeach; 
		
		if _cargoType.id = TI_CargoType_Container then
			foreach isoType in app.myRoot.allISOTypes do
				if isoType.isNotAvailableForEntry then
					continue;
				endif;
				self.cmbFiltISOType.itemObject[self.cmbFiltISOType.addItem(isoType.getTableDisplay)] := isoType;
			endforeach;
		
			//24 Sep 2013	NDL	Par 32556
		elseif _cargoType.isTrailer then //epr par 33302 15/1/14 
			foreach trailerType in app.myRoot.allTILCTypes do
				if trailerType.isNotAvailableForEntry then
					continue;
				endif;
				self.cmbFiltTrailer.itemObject[self.cmbFiltTrailer.addItem(trailerType.description)] := trailerType;
			endforeach;
		
		endif;
	
	endif;
	
	if beforeProd &lt;&gt; null then
		self.cmbFiltProd.listIndex := self.cmbFiltProd.findObject(beforeProd);
		self.tblSearch.setValueByControlName(self.cmbFiltProd.name, self.cmbFiltProd.text);
	endif;
	if beforeIsoType &lt;&gt; null then
		self.cmbFiltISOType.listIndex := self.cmbFiltISOType.findObject(beforeIsoType);
		self.tblSearch.setValueByControlName(self.cmbFiltISOType.name, self.cmbFiltISOType.text);
	endif;
		//24 Sep 2013	NDL	Par 32556
	if beforeTrailerType &lt;&gt; null then
		self.cmbFiltTrailer.listIndex := self.cmbFiltTrailer.findObject(beforeTrailerType);
		self.tblSearch.setValueByControlName(self.cmbFiltTrailer.name, self.cmbFiltTrailer.text);
	endif;
	
	self.cmbFiltISOType.enabled := cmbFiltISOType.listCount &gt; 0;
	self.cmbFiltProd.enabled := cmbFiltProd.listCount &gt; 0;
	self.cmbFiltTrailer.enabled := cmbFiltTrailer.listCount &gt; 0;		//24 Sep 2013	NDL	Par 32556
	
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="populateTblAvail" id="29e7bc59-2c49-4081-8596-7588f56650d0">
        <source>populateTblAvail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2013	cnwndl1	Initial creation

*/

vars

	entTableRow : EntTableRow;
	rowIndex : Integer;
	jadeTableCell : JadeTableCell;
	
	avail : CM_MTGrade;
	index : Integer;
	
begin
	
	rowIndex := tblSearch.getRow(ETRow_FilterAvaGrade);
	if rowIndex &gt; 0 then
		jadeTableCell := tblSearch.accessCell(rowIndex,2);
		if jadeTableCell &lt;&gt; null then
			jadeTableCell.cellControl := self.tblAvail;
			jadeTableCell.inputType := Table.InputType_TextBox;
			
			self.tblAvail.columns := 2;
			self.tblAvail.rows := 1;
			self.tblAvail.fixedRows := 1;
			self.tblAvail.fixedColumns := 0;
			
			self.tblAvail.setCellText(1,1,"Sel" &amp; Tab &amp; "Availability");
			
			foreach avail in app.myRoot.allAvailableAvailabilityGrades do
				index := self.tblAvail.addItem( Tab &amp; avail.description );
				self.tblAvail.accessRow(index).itemObject := avail;
				self.tblAvail.accessCell(index,1).inputType := Table.InputType_CheckBox;
			endforeach;
			
			self.tblAvail.cnAdjustColumnWidths();
			
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setActionButton" id="eed82f0e-03b8-42b7-a13a-e8823d525df2">
        <updating/>
        <source>setActionButton() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005
22 03 2018	jlgrh7 37732 Handheld app (mobile app also probably) can pack or unpack cargo which is on transport
13 04 2018	jlgmd1	TFS 38111 Lander App - Cannot select cargo item to discharge

*/

vars

	ti : CM_TrackedItem;
	hasCriteria,
	hideOnTransportTIs	: Boolean;
	row : Integer;
	rowControl : Control;
	
begin

	if self.fldCargo.topSheet = shtResults then
		self.btnOne.caption := app.getErrorString(Select_Item);
		hideOnTransportTIs := app.myMobileCargoFindAgent.hideOnTransportTIs;														//TFS 38111 13/04/2018 jlgmd1
		ti := self.getCurrentlySelectedTi();
		//self.btnOne.enabled := ti &lt;&gt; null;																						//-TFS37573 
		//self.btnOne.enabled := ti &lt;&gt; null and (not ti.isOnTransport());								//+TFS37573 disable Select Button if cargo on the transport
		self.btnOne.enabled := ti &lt;&gt; null and (not hideOnTransportTIs or (hideOnTransportTIs and not ti.isOnTransport()));			//TFS 38111 13/04/2018 jlgmd1
		self.btnTwo.enabled := ti &lt;&gt; null;
		self.actionButtonState := self.SelectCargo;
	else
		self.btnOne.caption := app.getErrorString(Search);		
		
		foreach row in 1 to self.tblSearch.rows do
			rowControl := self.tblSearch.accessCell(row,2).cellControl;
			if rowControl &lt;&gt; null and rowControl.isKindOf(ComboBox) then
				hasCriteria := rowControl.ComboBox.listObject &lt;&gt; null;
			else
				hasCriteria := self.tblSearch.getCellText(row,2).trimBlanks &lt;&gt; null;
			endif;
			if hasCriteria then
				break;
			endif;
		endforeach;
		self.btnOne.enabled := hasCriteria;
		self.btnTwo.enabled := false;
		self.actionButtonState := self.FindCargo;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSearchCritFromSavedXML" id="b8e53545-290b-430e-b2d2-dce07145d28e">
        <updating/>
        <source>setSearchCritFromSavedXML( xmlStr : String ) updating, protected;
/*

Purpose:			

Parameters:			Find the values stored for the last search in the XML
					and reset the line in the table for the new search based on the old values if
					they are still available.
					
Return Value:		

Date		Who		Reason
08 February 2017	cnwndl1	Initial creation	TFS 3191/2876

*/

vars

	
	xmlDocumentParser : JadeXMLDocumentParser;
	xmlDocument : JadeXMLDocument;
	nullArray : StringArray;

begin

	if app.myMobileCargoFindAgent.savedSearchCrit.trimBlanks = null then
		return;
	endif;
	
	create xmlDocumentParser transient;
	create xmlDocument transient;

	xmlDocumentParser.parseDocumentString( xmlDocument, app.myMobileCargoFindAgent.savedSearchCrit );	
	
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterTiType, cmbFiltTiType );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterIMEX, cmbFilterIMEX );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterVoyage, cmbFiltVoyage );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterSite, cmbFiltSite );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterSupplier, cmbFiltOperator );
	self.doCurrentColourListActions( true, false, false, 0, nullArray );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterColourList, null ); // objectarray based criteria
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterColour, null );	//Partial string match based criteria
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterTAType, cmbFiltTAType );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterTerminalArea, cmbFiltTermArea );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterYardLocation, cmbFiltYardLocn );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterTrailerType, cmbFiltTrailer );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterISOType, cmbFiltISOType );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterDischargePort, cmbFiltDisPort );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterConsignee, cmbFiltConsignee );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterProduct, cmbFiltProd );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterBols, cmbFiltBol );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterAvaGrade, null );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_Mark, null );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterBookingRef, null );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_FilterCustomsReference, null );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_WeightTare, null );
	self.setSearchLineFromSavedXML( xmlDocument, ETRow_WeightCargo, null );
	
epilog

	delete xmlDocumentParser;
	delete xmlDocument;

end;</source>
        <access>protected</access>
        <Parameter name="xmlStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSearchCriteriaAsXML" id="b54bbe2e-dc57-4593-ae12-48e172e9a112">
        <source>setSearchCriteriaAsXML() protected;
/*

Purpose:			

Parameters:			Saves off the current serch criteria that is in teh search table as an XML string,
					so it can be re-displayed later.

Return Value:		

Date		Who		Reason
08 February 2017	cnwndl1	Initial creation	TFS 3191/2876

*/

vars

	size : Integer;
	index : Integer;
	entRow : EntTableRowTransient;
	attrName : String;
	displayName : String;
	rowIndex : Integer;
	displayValue : String;
	
	xmlString : String;
	subListTable : CM_MobListTable;
	subRowIndex : Integer;
	weightStr : String;
	unitStr : String;
	measureTbl : CMUI_MeasurementTable;

begin

	size := self.tblSearch.allEntRowTransients.size;
	foreach index in 1 to size do
		entRow := self.tblSearch.allEntRowTransients[ index ].EntTableRowTransient;
		attrName := entRow.name;
		displayName := entRow.getHeadingUnaltered();
		if attrName = ETRow_FilterId
		or attrName = ETRow_FilterAlternateId
		then
			//we don't save cargo id or alternate id.
			continue;
		endif;
		rowIndex := self.tblSearch.getRow(attrName);
		if rowIndex &lt; 1 then
			//row not showing
			continue;
		endif;
		displayValue := null;
		if attrName = ETRow_FilterColourList then
			subListTable := self.tblSearch.accessCell(rowIndex,2).cellControl.CM_MobListTable;
			if subListTable.rows &gt;= 1 then
				foreach subRowIndex in 1 to subListTable.rows do
					if subListTable.accessCell(subRowIndex,1).text = "1" then
						if displayValue &lt;&gt; null then
							displayValue := displayValue &amp; ", ";
						endif;
						displayValue := displayValue &amp; subListTable.accessCell(subRowIndex,2).text;
					endif;
				endforeach;
			endif;
			
		elseif ( attrName = ETRow_WeightCargo or attrName = ETRow_WeightTare ) then
			if attrName = ETRow_WeightCargo then
				measureTbl := self.tblMeasurement.getControl(1).CMUI_MeasurementTable;
			elseif attrName = ETRow_WeightTare then
				measureTbl := self.tblMeasurement.getControl(2).CMUI_MeasurementTable;
			endif;
			if measureTbl &lt;&gt; null then
				weightStr := measureTbl.accessCell(1, measureTbl.ColumnValue).text;
				unitStr := measureTbl.accessCell(1, measureTbl.ColumnUnit).text;
				displayValue := weightStr &amp; ", " &amp; unitStr;
			endif;
			
		else
			displayValue := self.tblSearch.getCellText(rowIndex,2);
			
		endif;
		
		if displayValue.trimBlanks = null then
			//no value showing
			continue;
		endif;
		
		xmlString := xmlString &amp; "&lt;" &amp; attrName &amp; "&gt;" &amp; displayValue.asXML &amp; "&lt;/" &amp; attrName &amp; "&gt;";
		
	endforeach;
	
	xmlString := "&lt;" &amp; MOB_MobileCargoFindAgent::savedSearchCrit.name &amp; "&gt;" &amp; xmlString &amp; "&lt;/" &amp; MOB_MobileCargoFindAgent::savedSearchCrit.name &amp; "&gt;";
	
	app.myMobileCargoFindAgent.setSavedSearchCrit( xmlString );
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSearchEntTable" id="a52c3f66-2b3a-4eee-bb0e-371cd569c575">
        <updating/>
        <source>setSearchEntTable( _entTableString : String) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	entTableString : String;
	entTableRow : EntTableRow;
	
begin

	if self.mySearchEntTableView &lt;&gt; null 
	and self.mySearchEntTableView.isTransient
	then
		delete self.mySearchEntTableView;
		self.mySearchEntTableView := null;
	endif;

	if self.myHandHeldConfig = null then
		if _entTableString = null then
			entTableString := ETDef_ContEnqFind;
		else
			entTableString := _entTableString;
		endif;
		
		self.mySearchEntTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[entTableString];
		if self.mySearchEntTableDef = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; entTableString &amp; ') not found');
			return;
		endif;
		
		self.mySearchEntTableView := self.mySearchEntTableDef.allEntTableViews[ETView_HandHeld];
		if self.mySearchEntTableView = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'View (' &amp; ETView_HandHeld &amp; ') within (' &amp; entTableString &amp; ') not found');
			return;
		endif;
	
	else
		entTableString := ETDef_HandHeldFind;
		self.mySearchEntTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[entTableString];
		if self.mySearchEntTableDef = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; entTableString &amp; ') not found');
			return;
		endif;
		if self.mySearchEntTableView &lt;&gt; null 
		and self.mySearchEntTableView.isTransient
		then
			delete self.mySearchEntTableView;
		endif;
		create self.mySearchEntTableView transient;
		self.myHandHeldConfig.populateTransientSearchView( self.mySearchEntTableDef, self.mySearchEntTableView );
	
	endif;
	
	self.tblSearch.setEntTableFromView(self.mySearchEntTableDef, self.mySearchEntTableView, null, null);
	
	self.tblSearch.columnWidth[1] := (self.tblSearch.width / 3).Integer;
	
	loadTblSearch();
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_entTableString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSearchLineFromSavedXML" id="45b007cc-ed6c-4f64-9ab3-965eab88e32d">
        <updating/>
        <source>setSearchLineFromSavedXML(	_xmlDocument : JadeXMLDocument input;
							_attrName : String;
							_combo : ComboBox input
							) protected, updating;
/*

Purpose:			

Parameters:		Find the string value captured for this line in the last search in the XML
				and reset the line in the table for the new search based on the old value if its still there.

Return Value:		

Date		Who		Reason
08 February 2017	cnwndl1	Initial creation	TFS 3191/2876

*/

vars

	rowIndex : Integer;
	xmlElement : JadeXMLElement;
	dataString : String;
	subListTable : Table;
	subTableRowIndex : Integer;
	selectedDataStrings : CnStringArray;
	subTableStr : String;
	selectedText : String;
	measureTbl : CMUI_MeasurementTable;

begin

	if _combo = null then
		// the criteria field doesn't have a combo control in it. (I.e. no control, or a non combo cotrol.)
		rowIndex := self.tblSearch.getRow(_attrName);
		if rowIndex &gt; 0 then
			//the criteria field is still selected for display (Mobile search fields are soft displayed from Hand Held App Config in thin client)
			xmlElement := _xmlDocument.findElementByTagName( _attrName );
			if xmlElement &lt;&gt; null then
				// we have found this criteria in the saved xml
				dataString := xmlElement.text;
				if dataString &lt;&gt; null then
					// And we have a correspond value for the criteria.
					if _attrName = ETRow_FilterColourList
					or  _attrName = ETRow_FilterAvaGrade
					then
						//Its a list control, for either colour list or availability grades
						if _attrName = ETRow_FilterColourList then
							subListTable := self.tblColour;
						elseif _attrName = ETRow_FilterAvaGrade then
							subListTable := self.tblAvail;
						endif;
						selectedDataStrings := dataString.cnGetTokens(", ");
						if subListTable.rows &gt; 0 and not selectedDataStrings.isEmpty then
							foreach subTableRowIndex in 1 to subListTable.rows do
								subTableStr := subListTable.accessCell(subTableRowIndex,2).text;
								if selectedDataStrings.includes( subTableStr.trimBlanks ) then
									selectedText := "1";
								else
									selectedText := "0";
								endif;
								subListTable.accessCell(subTableRowIndex,1).text := selectedText;
							endforeach;
							subListTable.lostFocus(subListTable);
						endif;
						
					elseif _attrName = ETRow_WeightTare then
						//its a weight - using a measuremnet control
						selectedDataStrings := dataString.cnGetTokens(", ");
						measureTbl := self.tblMeasurement.getControl(2).CMUI_MeasurementTable;
						if selectedDataStrings.size = 2 and measureTbl &lt;&gt; null then
							measureTbl.setValues(selectedDataStrings[1] &amp; Space &amp; selectedDataStrings[2]);
							measureTbl.lostFocus( measureTbl );
							self.tblSearch.setValue(rowIndex, dataString);
						endif;
						
					elseif _attrName = ETRow_WeightCargo then
						selectedDataStrings := dataString.cnGetTokens(", ");
						measureTbl := self.tblMeasurement.getControl(1).CMUI_MeasurementTable;
						if selectedDataStrings.size = 2 and measureTbl &lt;&gt; null then
							measureTbl.setValues(selectedDataStrings[1] &amp; Space &amp; selectedDataStrings[2]);
							measureTbl.lostFocus( measureTbl );
							self.tblSearch.setValue(rowIndex, dataString);
						endif;
						
					else
						// Its just an ordinary string value of some sort (or not coded for)
						self.tblSearch.setValue(rowIndex, dataString);
						
					endif;
				endif;
			endif;
		endif;

	else
		// We have a criteria that uses a combo. Just do a text match and select from there
		rowIndex := self.tblSearch.getRow(_attrName);
		if rowIndex &gt; 0 then
			//The criteria is displayed in the table
			xmlElement := _xmlDocument.findElementByTagName( _attrName );
			if xmlElement &lt;&gt; null then
				dataString := xmlElement.text;
				if dataString &lt;&gt; null then
					// And we have a correspond value for the criteria, find the index of the string value.
					_combo.listIndex := _combo.findStringExact(1, dataString);
					_combo.lostFocus( _combo );
				endif;
			endif;
		endif;
	
	endif;

epilog

	delete selectedDataStrings;

end;</source>
        <access>protected</access>
        <Parameter name="_xmlDocument" type="JadeXMLDocument" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setWeightSearchFields" id="ee3ce35e-55c4-4884-acaa-4de1c071ee39">
        <source>setWeightSearchFields();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2016	cnwndl1	Initial creation	TFS 2959 / 2420

*/

vars

	row : Integer;
	rowIndex : Integer;
	measure : CM_MeasurementType;
	measureControl : CMUI_MeasurementTable;
	etRowTrans : EntTableRowTransient;

begin

	measure := app.getDefaultMeasurementForType( Type_Weight );
	
	row := self.tblSearch.getRow(ETRow_WeightCargo);
	if row &gt; 0 then
		etRowTrans := self.tblSearch.allEntRowTransients[row].EntTableRowTransient;
		if etRowTrans &lt;&gt; null then
			etRowTrans.setDisplayNullIfZero( true );
		endif;
		measureControl := self.tblMeasurement.getControl(1).CMUI_MeasurementTable;
		if measureControl = null then
			measureControl := self.tblMeasurement.loadControl(1).CMUI_MeasurementTable;
			measureControl.visible := true;
			measureControl.name := ETRow_WeightCargo;
			measureControl.setEventMapping("lostFocus", "tblMeasurement_lostFocus");
			measureControl.setEventMapping("gotFocus", "tblMeasurement_gotFocus");
			measureControl.setMeasurementType(measure.measurementType);
			measureControl.setHeading(etRowTrans.getHeadingUnaltered);
			measureControl.accessCell(1, measureControl.ColumnSpacer).text := null;
			self.allMeasurementControls.add(measureControl);
		endif;
		measureControl.setRowName(ETRow_WeightCargo);
		self.tblSearch.setControl(row, measureControl);
		self.tblSearch.accessCell(row,2).text := null;
	endif;
	
	row := self.tblSearch.getRow(ETRow_WeightTare);
	if row &gt; 0 then
		etRowTrans := self.tblSearch.allEntRowTransients[row].EntTableRowTransient;
		if etRowTrans &lt;&gt; null then
			etRowTrans.setDisplayNullIfZero( true );
		endif;
		measureControl := self.tblMeasurement.getControl(2).CMUI_MeasurementTable;
		if measureControl = null then
			measureControl := self.tblMeasurement.loadControl(2).CMUI_MeasurementTable;
			measureControl.visible := true;
			measureControl.name := ETRow_WeightTare;
			measureControl.setEventMapping("lostFocus", "tblMeasurement_lostFocus");
			measureControl.setEventMapping("gotFocus", "tblMeasurement_gotFocus");
			measureControl.setMeasurementType(measure.measurementType);
			measureControl.setHeading(etRowTrans.getHeadingUnaltered);
			measureControl.accessCell(1, measureControl.ColumnSpacer).text := null;
			self.allMeasurementControls.add(measureControl);
		endif;
		measureControl.setRowName(ETRow_WeightTare);
		self.tblSearch.setControl(row, measureControl);
		self.tblSearch.accessCell(row,2).text := null;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="f50db672-75cf-47f3-85f4-0882b583411c">
        <updating/>
        <source>setupControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	folderHeight : Real;
	tblWidth : Real;
	tblHeight : Real;
	entTableRow : EntTableRow;
	str : String;
	heading : String;
	tempEntRow : EntTableRow;

begin

	self.myHandHeldConfig := self.myTerminal.getHandHeldConfig( null );

	self.setResizeableMarginAndFontSize();
	folderHeight := self.clientHeight - (self.resizedMargin * 3) - self.getCMDButtonsHeight;

	self.fldCargo.move(	self.resizedMargin,
						self.resizedMargin,
						self.clientWidth - 4,
						folderHeight
						);
						
	tblHeight := self.shtFind.height - self.resizedMargin  - self.resizedMargin;
	tblWidth := self.shtFind.width - self.resizedMargin  - self.resizedMargin;

		// search table
	self.tblSearch.visible := true;
	self.tblSearch.move(	self.resizedMargin,
						self.resizedMargin,
						tblWidth,
						tblHeight );
						
	self.tblSearch.fixedRows := 0;
	self.tblSearch.fixedColumns := 0;
	self.tblSearch.rows := 0;
	self.tblSearch.columns := 2;
	self.tblSearch.parentAspect:=Table.ParentAspect_StretchBoth;
	
	self.setSearchEntTable( null );
	
		// results table
	self.tblResults.visible := true;
	self.tblResults.move(	self.resizedMargin,
						self.resizedMargin,
						tblWidth,
						tblHeight );
						
	
	
	
	self.myResultsEntTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_CargoQuickViewHandHeld];
	if self.myResultsEntTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; ETDef_CargoQuickViewHandHeld &amp; ') not found');
		return;
	endif;
	
	self.myResultsEntTableView := self.myResultsEntTableDef.allEntTableViews[ETView_HandHeld];
	if self.myResultsEntTableView = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'View (' &amp; ETView_HandHeld &amp; ') within (' &amp; ETDef_CargoQuickViewHandHeld &amp; ') not found');
		return;
	endif;
	
	self.doResizeControls(true);
	
	self.myResultsTblEntRows.clear();
	if self.myHandHeldConfig &lt;&gt; null then
		foreach tempEntRow in self.myHandHeldConfig.allVisibleResultsCols do
			entTableRow := self.myResultsEntTableDef.getEntTableRowByHeading( tempEntRow.getRawHeadingValue );
			if entTableRow &lt;&gt; null then
				self.myResultsTblEntRows.add( entTableRow );
			endif;
		endforeach;
	else
		self.myResultsEntTableView.allEntTableRows.copy( self.myResultsTblEntRows );
	endif;
	self.tblResults.columns := self.myResultsTblEntRows.size;
	self.tblResults.fixedRows := 1;
	self.tblResults.fixedColumns := 0;
	self.tblResults.rows := 1;
	self.tblResults.fixed3D := false;
	self.tblResults.parentAspect:=Table.ParentAspect_StretchBoth;
	
	foreach entTableRow in self.myResultsTblEntRows do
		str := entTableRow.getHeading(null, null, app.myCurrentLocale);
		if heading &lt;&gt; null then
			heading := heading &amp; Tab;
		endif;
		heading := heading &amp; str;
	endforeach;
	
	self.tblResults.setCellText(1,1,heading);
						
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cb50c8b3-a73d-483d-96fa-b43e07f6358c">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	operator : CM_Operator;
	nullArray : StringArray;

begin

	app.mousePointer :=	Busy;
	
	self.cmbFiltBol.visible := false;	//16 Nov 2010	NDL Par 26055
	self.cmbFiltTiType.visible := false;
	self.cmbFiltConsignee.visible := false;
	self.cmbFiltDisPort.visible := false;
	self.cmbFiltYardLocn.visible := false;
	self.cmbFiltTermArea.visible := false;
	self.cmbFiltTAType.visible := false;
	self.cmbFiltVoyage.visible := false;
	self.cmbFilterIMEX.visible := false;
	self.cmbFiltAvail.visible := false;
	self.cmbFiltISOType.visible := false;
	self.cmbFiltOperator.visible := false;
	self.cmbFiltProd.visible := false;
	self.cmbFiltSite.visible := false;
	self.cmbFiltTrailer.visible := false;
	self.cmbFiltVoyage.visible := false;
	self.cmbFiltYardLocn.visible := false;

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;

	inheritMethod();
	
	self.setupCmdButtons( 3, app.getErrorString(Select_Item), app.getErrorString(View_item), app.getErrorString(Back), null, null );
	self.btnOne.enabled := false;
	
	self.setupControls();

	if not app.myMobileCargoFindAgent.allSearchResults.isEmpty then
		// returning to the form from a view.
		self.doRePopulateSearchResults();
		//epr par 36908 22/9/15
		if app.myMobileCargoFindAgent.onlyShowResults then
			self.shtFind.visible:=false;
		endif;
	
	//08 Feb 2017	NDL	TFS 3191/2876
	elseif app.myMobileCargoFindAgent.reUseSearchCriteria and app.myMobileCargoFindAgent.savedSearchCrit.trimBlanks &lt;&gt; null then
		app.myMobileCargoFindAgent.clearRePopulateData();
		self.setSearchCritFromSavedXML( app.myMobileCargoFindAgent.savedSearchCrit );
		self.setActionButton(); 
		
	// these ones can be set directly from the calling form, and imply that we want an immediate search performed.
	elseif ( app.myMobileCargoFindAgent.myVoyage &lt;&gt; null
		or app.myMobileCargoFindAgent.myBOL &lt;&gt; null
		or app.myMobileCargoFindAgent.id.trimBlanks &lt;&gt; null
		or app.myMobileCargoFindAgent.bookingRef.trimBlanks &lt;&gt; null
		or app.myMobileCargoFindAgent.myDeliveryRequest &lt;&gt; null//01 Jun 2010	NDL	Par 23903
		or app.myMobileCargoFindAgent.myYardLoc &lt;&gt; null // 22 Mar 2013 Par 31278
		or app.myMobileCargoFindAgent.reefersOnly	//01 May 2013	NDL	Par 31506
		or app.myMobileCargoFindAgent.canSplitOnly	//28 May 2013 NDL	CCMS 2275
		or app.myMobileCargoFindAgent.canMergeOnly	//28 May 2013 NDL	CCMS 2275
		or app.myMobileCargoFindAgent.myCargoType &lt;&gt; null	//01 May 2013	NDL	Par 31506
		or app.myMobileCargoFindAgent.colourString &lt;&gt; null	//25 Oct 2016	NDL TFS 2850 / 2370
		or app.myMobileCargoFindAgent.mark &lt;&gt; null	//25 Oct 2016	NDL TFS 2850 / 2370
		) then
		
		// initial call with additional search criteria.
		app.myMobileCargoFindAgent.clearRePopulateData();	//29 Mar 2010	NDL	Par 23454
		self.doNarrowSerachCriteria();
		
	else
	
		//16 Jul 2014	NDL	Par 34571
		if app.myMobileCargoFindAgent.searchStateSite &gt; 0 then
			self.cmbFiltSite.listIndex := self.cmbFiltSite.findStringExact(1, app.siteEnumToString(app.myMobileCargoFindAgent.searchStateSite));
			self.cmbFiltSite_lostFocus(self.cmbFiltSite);
		endif;
		
		//09 Jun 2015	NDL	Par 36338
		operator := app.myMobileCargoFindAgent.myOperator;
		if operator &lt;&gt; null then
			self.cmbFiltOperator.listIndex := cmbFiltOperator.findObject(operator);
			self.cmbFiltOperator_lostFocus(cmbFiltOperator);
		else
			self.cmbFiltOperator.listIndex := -1;
		endif;
		
		self.setActionButton(); 
		self.doCurrentColourListActions( true, false, false, 0, nullArray );	//08 Dec 2016	TFS 3024  2370
	
	endif;

epilog

	app.mousePointer :=	Idle;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblAvail_gotFocus" id="73f6fa6e-dd38-416e-ac71-67d0ebeb589e">
        <controlMethod name="Table::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAvail_gotFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2013	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	jadeTableRow : JadeTableRow;
	newHeight : Integer;

begin

	self.tblAvail.visible := false;
	
	newHeight := (self.tblSearch.height * .7 ).Integer;
	
	rowIndex := tblSearch.getRow(ETRow_FilterAvaGrade);
	if rowIndex &gt; 0 then
		jadeTableRow := tblSearch.accessRow(rowIndex);
		if jadeTableRow.visible then
			jadeTableRow.height := ( newHeight );
		endif;
	endif;
	
	self.tblSearch.topRow := rowIndex - 1;
	self.tblSearch.accessColumn(1).width := (self.tblSearch.width.Integer * .2).Integer;
	self.tblSearch.columnWidth[1] := (self.tblSearch.width / 5).Integer;
	self.tblSearch.columnWidth[2] := (self.tblSearch.width - self.tblSearch.columnWidth[1]).Integer;

	self.tblAvail.leftColumn := 1;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblAvail_lostFocus" id="30fa12ed-460e-4456-97fe-2690e8f94568">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAvail_lostFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2013	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	jadeTableRow : JadeTableRow;
	baseRowHeight : Integer;
	obj : Object;
	displayString : String;
	avail : CM_MTGrade;

begin

	baseRowHeight := self.tblAvail.accessRow(1).height;
	
	rowIndex := self.tblSearch.getRow(ETRow_FilterAvaGrade);
	if rowIndex &gt; 0 then
		jadeTableRow := self.tblSearch.accessRow(rowIndex);
		if jadeTableRow.visible then
			jadeTableRow.height := ( baseRowHeight  );
		endif;
	endif;
	
	self.allFilterAvailCodes.clear();
	foreach rowIndex in 1 to self.tblAvail.rows do
		if self.tblAvail.accessCell(rowIndex,1).text = "1" then
			obj := self.tblAvail.accessRow(rowIndex).itemObject;
			if obj &lt;&gt; null and obj.isKindOf( CM_MTGrade ) then
				self.allFilterAvailCodes.add( obj.CM_MTGrade );
			endif;
		endif;
	endforeach;
	
	foreach avail in self.allFilterAvailCodes do
		if displayString = null then
			displayString := avail.description.String;
		else
			displayString := displayString &amp; ", " &amp; avail.description.String;
		endif;
	endforeach;
	
	rowIndex := self.tblSearch.getRow(ETRow_FilterAvaGrade);
	if rowIndex &gt; 0 then
		self.tblSearch.setCellText(rowIndex,2,displayString);
	endif;
	
	self.tblSearch.columnWidth[1] := (self.tblSearch.width / 3).Integer;
	self.tblSearch.columnWidth[2] := (self.tblSearch.width - self.tblSearch.columnWidth[1]).Integer;
	self.tblSearch.leftColumn := 1;
	
	self.tblAvail.visible := false;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblColour_gotFocus" id="f253329f-2e96-4b5b-a18c-2af776afb10f">
        <controlMethod name="Table::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblColour_gotFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2016	cnwndl1	Initial creation

*/

vars

	index : Integer;
	rowIndex : Integer;
	nullArray : StringArray;

begin

	foreach index in 1 to self.tblSearch.rows do
		if self.tblSearch.accessCell(index,2).cellControl = self.tblColour then
			rowIndex := index;
			break;
		endif;
	endforeach;
	if rowIndex &gt; 0 then
		self.doCurrentColourListActions( false, true, false, rowIndex, nullArray );
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
