        <source>copyToRealWSObject(_realRequest: IPN1_SendRealisasiPandu input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.biaya := self.biaya;
	_realRequest.gtKapal := self.gtKapal;
	_realRequest.jamMulaiPandu := self.jamMulaiPandu;
	_realRequest.jamNaikPandu := self.jamNaikPandu;
	_realRequest.jamSelesaiPandu := self.jamSelesaiPandu;
	_realRequest.jamTurunPandu := self.jamTurunPandu;
	_realRequest.jenisGerakan := self.jenisGerakan;
	_realRequest.jenisPandu := self.jenisPandu;
	_realRequest.lokasiAkhir := self.lokasiAkhir;
	_realRequest.lokasiAwal := self.lokasiAwal;
	_realRequest.nomorPkk := self.nomorPkk;
	_realRequest.nomorPpkbPandu := self.nomorPpkbPandu;
	_realRequest.nomorSpk := self.nomorSpk;
	_realRequest.prosentase := self.prosentase;
	_realRequest.tanggalMulaiPandu := self.tanggalMulaiPandu;
	_realRequest.tanggalNaikPandu := self.tanggalNaikPandu;
	_realRequest.tanggalSelesaiPandu := self.tanggalSelesaiPandu;
	_realRequest.tanggalTurunPandu := self.tanggalTurunPandu;
	_realRequest.tarifTVariabel := self.tarifTVariabel;
	_realRequest.tarifTetap := self.tarifTetap;

epilog

end;</source>
