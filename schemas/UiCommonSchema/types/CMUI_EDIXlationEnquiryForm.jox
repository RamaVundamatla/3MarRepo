	obj := table.accessCell(table.row, table.column).itemObject.Object;
	
	if obj &lt;&gt; null and obj.isKindOf (CM_Xlation_In) then
		// ***
		write 'coming soon';
	else		
		inheritMethod(table);
	endif;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
