    <JadeMethod name="tblDutyDocItems_contextMenu" id="f144add6-6e43-4144-8428-0d4c777a2c24">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDutyDocItems_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2013	cnwer1	Initial creation HAT 2189

*/

vars
	xLeft, yTop : Real;
	dutyDocItem : CM_DutyDocItem;
begin
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.popupMenu(self.mnuContext, xLeft.Integer, yTop.Integer);
	
	dutyDocItem:= table.accessRow(table.row).itemObject.CM_DutyDocItem;
	mnuInspect.visible:=app.isAllowedToInspect();
	mnuInspect.userObject:=dutyDocItem;
	self.mnuColOrganiser.userObject := table;
	return true;
epilog	

end;</source>
