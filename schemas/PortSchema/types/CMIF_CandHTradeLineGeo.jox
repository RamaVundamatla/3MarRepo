    <JadeMethod name="addToCraneMoves" id="3feea649-34b5-43c1-9cd8-8c23d82f0970">
        <updating/>
        <source>addToCraneMoves(_isDLR, is40: Boolean) updating, protected;
//----------------------------------------------------------------
//	Created:	08 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if _isDLR then
		if is40 then
			self.numCraneMoves40 := self.numCraneMoves40 + 2;
		else
			self.numCraneMoves20 := self.numCraneMoves20 + 2;
		endif;
	else
		if is40 then
			self.numCraneMoves40 := self.numCraneMoves40 + 1;
		else
			self.numCraneMoves20 := self.numCraneMoves20 + 1;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_isDLR" type="Boolean"/>
        <Parameter name="is40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildCode" id="e61ada2a-625f-4d8d-8582-8ae72f993373">
        <source>buildCode(_strArray : StringArray input) : String;
// ---------------------------------------------------------------------------
// Created:     21 August 2007 by cnwrs2
//
// Purpose:     Should be able to remove once 1468 has been fully implemented
// ---------------------------------------------------------------------------
vars
	strCandHCode		: String;
	tmpStrArray			: StringArray;
begin
	create tmpStrArray transient;

	if self.myShippingLine &lt;&gt; null then
		tmpStrArray.add(self.myShippingLine.code.trimBlanks);
	else
		tmpStrArray.add(null);
	endif;
	
	if self.myShipPortGroup &lt;&gt; null then
		tmpStrArray.add(self.myShipPortGroup.code.trimBlanks);
	else
		tmpStrArray.add(null);
	endif;
	
	if self.myDebtor &lt;&gt; null then
		tmpStrArray.add(self.myDebtor.name.trimBlanks);
	else
		tmpStrArray.add(null);
	endif;

	strCandHCode := tmpStrArray[1] &amp; " " &amp; tmpStrArray[3] &amp; " " &amp; tmpStrArray[2];

	if _strArray = null then
		return strCandHCode;
	endif;
	
	_strArray.clear;
	_strArray.add(tmpStrArray[1]);
	_strArray.add(tmpStrArray[3]);
	_strArray.add(tmpStrArray[2]);
	
	return strCandHCode;
epilog
	delete tmpStrArray;	
end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="b9b7fa38-b3be-41fb-9e61-be5486261311">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	05 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	summItem	: CMIF_CandHSummaryItem;
begin

	//imports
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryImportDry20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryImportDry40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryImportDryTShip20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryImportDryTShip40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryImportReefer20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryImportReefer40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryImportReeferTShip20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryImportReeferTShip40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryImportMT20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryImportMT40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryImportMTTShip20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryImportMTTShip40, self);
	
	
	//exports
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryExportDry20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryExportDry40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryExportDryLCL20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryExportDryLCL40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryExportDryTShip20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryExportDryTShip40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryExportReefer20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryExportReefer40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryExportReeferTShip20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryExportReeferTShip40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryExportMT20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryExportMT40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryExportMTTShip20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryExportMTTShip40, self);
	
	//other
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategorySOB20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategorySOB40, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_20, CMIF_CandHRpt.CategoryRehandle20, self);
	create summItem transient;
	summItem.setForCreate(CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_40, CMIF_CandHRpt.CategoryRehandle40, self);
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="findSummaryItem" id="618bb430-39ef-44f8-89b9-b200663a8df2">
        <source>findSummaryItem(_snapShot: CM_TISnapShot): CMIF_CandHSummaryItem;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	snap			: CM_TISnapShot;
	cmifItem		: CMIF_CandHSummaryItem;
	theCategory		: Integer;
begin

	if _snapShot.myUserTISnapShot &lt;&gt; null then
		snap := _snapShot.myUserTISnapShot;
	else
		snap := _snapShot;
	endif;
	
	if snap.cargoType &lt;&gt; TI_CargoType_Container then
		//not interested
		return null;
	endif;

	theCategory := snap.cAndH_category;
	
	cmifItem := self.allSummaryItemsByPrintOrder[theCategory];

epilog
	return cmifItem;
end;</source>
        <Parameter name="_snapShot" type="CM_TISnapShot"/>
        <ReturnType type="CMIF_CandHSummaryItem"/>
    </JadeMethod>
    <JadeMethod name="findSummaryItemOLD" id="857ec578-3b80-4841-9e42-0ee24d3ace64">
        <source>findSummaryItemOLD(_snapShot: CM_TISnapShot): CMIF_CandHSummaryItem;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	snap			: CM_TISnapShot;
	cmifItem		: CMIF_CandHSummaryItem;
	is40Foot		: Boolean;
	isTShip			: Boolean;
	isEmpty			: Boolean;
	isReeferCargo	: Boolean;
	isImport		: Boolean;
	isLCL			: Boolean;
begin

	if _snapShot.myUserTISnapShot &lt;&gt; null then
		snap := _snapShot.myUserTISnapShot;
	else
		snap := _snapShot;
	endif;
	
	isImport 		:= snap.imExStatus = TI_IMEX_STATUS_IMPORT or snap.imExStatus = TI_IMEX_STATUS_STORAGE;
	isTShip			:= snap.isTransship;
	isEmpty			:= snap.isEmpty;
	isReeferCargo	:= snap.requiresTemperature and (snap.contentsStatus = TI_CONTENTS_STATUS_FCL);
	is40Foot		:= snap.is40;
	if snap.contentsStatus = TI_CONTENTS_STATUS_LCL then
		isLCL := true;
	endif;
	
	if snap.cargoType &lt;&gt; TI_CargoType_Container then
		//not interested
		return null;
	endif;

	//find the summaryItem
	if snap.transitStatus = TI_TransitStatusDLR then
		if (is40Foot) then
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_40];
		else
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_20];
		endif;
	elseif snap.transitStatus = TI_TransitStatusSOB then
		if (is40Foot) then
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_40];
		else
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_20];
		endif;
	elseif isImport then
		if (is40Foot) then
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_40];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_40];
				endif;
			else
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_40];
				endif;
			endif;
		else
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_20];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_20];
				endif;
			else
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_20];
				endif;
			endif;
		endif;
	else	//export
		if (is40Foot) then
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_40];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_40];
				endif;
			else
				if (isLCL) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_40];
				elseif (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_40];
				endif;
			endif;
		else
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_20];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_20];
				endif;
			else
				if (isLCL) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_20];
				elseif (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_20];
				endif;
			endif;
		endif;
	endif;

epilog
	return cmifItem;
end;</source>
        <Parameter name="_snapShot" type="CM_TISnapShot"/>
        <ReturnType type="CMIF_CandHSummaryItem"/>
    </JadeMethod>
    <JadeMethod name="getTotalCraneMoves20" id="23af905f-fe0c-44b3-8e63-17c80e9092ab">
        <source>getTotalCraneMoves20(_originalValue: Boolean):Integer;
//----------------------------------------------------------------
//	Created:	08 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	int		: Integer;
	item	: CMIF_CandHSummaryItem;
begin

	foreach item in self.allSummaryItemsByPrintOrder do
		if item.size = CMIF_CandHRpt.Size_20 then
			if item.itemCode = CMIF_CandHRpt.Rehandle then
				int := int + (2*item.getCount(_originalValue));
			else
				int := int + item.getCount(_originalValue);
			endif;
		endif;
	endforeach;

	return int;

end;</source>
        <Parameter name="_originalValue" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalCraneMoves40" id="5d2d1237-8a89-477f-9f14-b532af5451ca">
        <source>getTotalCraneMoves40(_originalValue: Boolean):Integer;
//----------------------------------------------------------------
//	Created:	08 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	int		: Integer;
	item	: CMIF_CandHSummaryItem;
begin

	foreach item in self.allSummaryItemsByPrintOrder do
		if item.size = CMIF_CandHRpt.Size_40 then
			if item.itemCode = CMIF_CandHRpt.Rehandle then
				int := int + (2*item.getCount(_originalValue));
			else
				int := int + item.getCount(_originalValue);
			endif;
		endif;
	endforeach;

	return int;

end;</source>
        <Parameter name="_originalValue" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="fa378489-23e3-42a7-9e39-05ff455d8e1d">
        <updating/>
        <source>setForCreate(_shippingLine : CM_ShippingLine; _debtor : CM_DebtorNode;
				_shipPortGroup : CM_ShipPortGroup; _parent: CMIF_CandHRpt) updating;
// ---------------------------------------------------------------------------
// Created:     21 August 2007 by cnwrs2
//
// Purpose:     CCMS-1468
// ---------------------------------------------------------------------------
vars

begin

	if _shippingLine = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'shipping line', null, null);
		return;
	endif;
	if _debtor = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'debtor', null, null);
		return;
	endif;
	
	// It is ok for _shipPortGroup to be null as port-code may not be
	// in a port group.  Grouped in report as OTHR 

	self.myShippingLine		:= _shippingLine;
	self.myDebtor			:= _debtor;
	self.myShipPortGroup	:= _shipPortGroup;
	
	self.code := self.buildCode(null);
	
	self.myParent := _parent;

end;</source>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="_shipPortGroup" type="CM_ShipPortGroup"/>
        <Parameter name="_parent" type="CMIF_CandHRpt"/>
    </JadeMethod>
    <JadeMethod name="setItemFromSnap" id="b7d8ef7f-b74b-4644-8c9f-96e0d36f8aa2">
        <updating/>
        <source>setItemFromSnap(_snapShot: CM_TISnapShot) updating;
//----------------------------------------------------------------
//	Created:	08 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------
// 07/06/2010	cnwdap1		CCMS 1116 Tranship changes - check voyage for tranships to decide if they shoud
//								be counted as imports or exports
// 14/10/2010	cnwdap1		PAR #26037 Correct tranship checks - CM_Snapshot.myVoyage is not populated, so need to look at the transaction's voyage
//								For Tranships, if the report voyage matches the voyage from the snapshot's transaction, we want to 
//								include this tranship. This primarily affects snapshots for CM_ReceiveShip and CM_ReleaseShip transactions
vars
	snap			: CM_TISnapShot;
	cmifItem		: CMIF_CandHSummaryItem;
	is40Foot		: Boolean;
	isTShip			: Boolean;
	isEmpty			: Boolean;
	isReeferCargo	: Boolean;
	isImport		: Boolean;
	isLCL			: Boolean;
	dispSnap		: CM_TISnapShot;
	theCategory		: Integer;
	
begin

	snap := _snapShot;
	
	isImport 		:= snap.imExStatus = TI_IMEX_STATUS_IMPORT or snap.imExStatus = TI_IMEX_STATUS_STORAGE;
	isTShip			:= snap.isTransship;
	isEmpty			:= snap.isEmpty;
	isReeferCargo	:= snap.requiresTemperature and (snap.contentsStatus = TI_CONTENTS_STATUS_FCL);
	is40Foot		:= snap.is40;
	
	if snap.contentsStatus = TI_CONTENTS_STATUS_LCL then
		isLCL := true;
	endif;
	
	if snap.ignoreMe then
		//slip through
	elseif snap.cargoType = TI_CargoType_Timber then
		self.timberPacksLoaded := self.timberPacksLoaded + 1;
		return;//don't count in cranes
	elseif snap.cargoType = TI_CargoType_BreakBulk then
		if snap.imExStatus = TI_IMEX_STATUS_IMPORT then
			self.bbulkDischarged := self.bbulkDischarged + 1;
		else
			self.bbulkLoaded := self.bbulkLoaded + 1;
		endif;
		return;//don;t count in cranes
	elseif snap.cargoType &lt;&gt; TI_CargoType_Container then
		//not interested
		return;
	endif;

	if snap.ignoreMe then
		//slip through
	elseif snap.isOverDimensions then
		if snap.transitStatus = TI_TransitStatusDLR then
			if (is40Foot) then
				self.rehandleODOH40 := self.rehandleODOH40 + 1;
			else
				self.rehandleODOH20 := self.rehandleODOH20 + 1;
			endif;
		elseif snap.transitStatus = TI_TransitStatusSOB then
			if (is40Foot) then
				self.shiftODOH40 := self.shiftODOH40 + 1;
			else
				self.shiftODOH20 := self.shiftODOH20 + 1;
			endif;
		//elseif snap.imExStatus = TI_IMEX_STATUS_IMPORT then											// PAR #23645 CCMS 1116
		//elseif snap.imExStatus = TI_IMEX_STATUS_IMPORT or snap.myVoyage = self.myParent.myVoyage then	// PAR #23645 CCMS 1116
		elseif snap.imExStatus = TI_IMEX_STATUS_IMPORT or (snap.isTransship and snap.myTransaction.CM_TITransaction.type = TRANS_TYPE_REC_SHIP) then	// PAR #26037
			if (is40Foot) then
				self.importODOH40 := self.importODOH40 + 1;
			else
				self.importODOH20 := self.importODOH20 + 1;
			endif;
		//elseif snap.imExStatus = TI_IMEX_STATUS_EXPORT then											// PAR #23645 CCMS 1116
		//elseif snap.imExStatus = TI_IMEX_STATUS_EXPORT or snap.myVoyage = self.myParent.myVoyage then	// PAR #23645 CCMS 1116
		elseif snap.imExStatus = TI_IMEX_STATUS_EXPORT or (snap.isTransship and snap.myTransaction.CM_TITransaction.type = TRANS_TYPE_REL_SHIP) then	// PAR #26037
			if (is40Foot) then
				self.exportODOH40 := self.exportODOH40 + 1;
			else
				self.exportODOH20 := self.exportODOH20 + 1;
			endif;
		elseif snap.imExStatus = TI_IMEX_STATUS_STORAGE then
			if (is40Foot) then
				self.importODOH40 := self.importODOH40 + 1;
			else
				self.importODOH20 := self.importODOH20 + 1;
			endif;
		endif;
	endif;
	
	theCategory := snap.cAndH_category;
	
	cmifItem := self.allSummaryItemsByPrintOrder[theCategory];
	
	/*
	
	//find the summaryItem
	if snap.transitStatus = TI_TransitStatusDLR then
		if (is40Foot) then
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_40];
		else
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_20];
		endif;
	elseif snap.transitStatus = TI_TransitStatusSOB then
		if (is40Foot) then
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_40];
		else
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_20];
		endif;
	elseif isImport then
		if (is40Foot) then
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_40];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_40];
				endif;
			else
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_40];
				endif;
			endif;
		else
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_20];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_20];
				endif;
			else
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_20];
				endif;
			endif;
		endif;
	else	//export
		if (is40Foot) then
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_40];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_40];
				endif;
			else
				if (isLCL) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_40];
				elseif (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_40];
				endif;
			endif;
		else
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_20];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_20];
				endif;
			else
				if (isLCL) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_20];
				elseif (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_20];
				endif;
			endif;
		endif;
	endif;
	*/

	if cmifItem = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "no cmifItem found");
		return;
	endif;
		
	if not snap.ignoreMe then
		//add to crane moves	
		self.addToCraneMoves(snap.transitStatus = TI_TransitStatusDLR, is40Foot);
		cmifItem.numTIs := cmifItem.numTIs + 1;
	endif;
	
	//add to collection - even the ignored ones
	if CM_UserTISnapShot.hasInstance(snap) then
		if snap.CM_UserTISnapShot.myTISnapShot &lt;&gt; null then
			dispSnap := snap.CM_UserTISnapShot.myTISnapShot;
		endif;
	else
		dispSnap := snap;
	endif;
	
	if not cmifItem.allSnapShots.includes(dispSnap) then
		cmifItem.allSnapShots.add(dispSnap);
	endif;
	
end;</source>
        <Parameter name="_snapShot" type="CM_TISnapShot"/>
    </JadeMethod>
    <JadeMethod name="setItemFromSnapOLD" id="1adafb45-fd8f-4ce3-8394-04c72638ba56">
        <updating/>
        <source>setItemFromSnapOLD(_snapShot: CM_TISnapShot) updating;
//----------------------------------------------------------------
//	Created:	08 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

// pre CCMS 1468

vars
	snap			: CM_TISnapShot;
	cmifItem		: CMIF_CandHSummaryItem;
	is40Foot		: Boolean;
	isTShip			: Boolean;
	isEmpty			: Boolean;
	isReeferCargo	: Boolean;
	isImport		: Boolean;
	isLCL			: Boolean;
	dispSnap		: CM_TISnapShot;
	
begin

	snap := _snapShot;
	
	isImport 		:= snap.imExStatus = TI_IMEX_STATUS_IMPORT or snap.imExStatus = TI_IMEX_STATUS_STORAGE;
	isTShip			:= snap.isTransship;
	isEmpty			:= snap.isEmpty;
	isReeferCargo	:= snap.requiresTemperature and (snap.contentsStatus = TI_CONTENTS_STATUS_FCL);
	is40Foot		:= snap.is40;
	
	if snap.contentsStatus = TI_CONTENTS_STATUS_LCL then
		isLCL := true;
	endif;
	
	if snap.ignoreMe then
		//slip through
	elseif snap.cargoType = TI_CargoType_Timber then
		self.timberPacksLoaded := self.timberPacksLoaded + 1;
		return;//don't count in cranes
	elseif snap.cargoType = TI_CargoType_BreakBulk then
		if snap.imExStatus = TI_IMEX_STATUS_IMPORT then
			self.bbulkDischarged := self.bbulkDischarged + 1;
		else
			self.bbulkLoaded := self.bbulkLoaded + 1;
		endif;
		return;//don;t count in cranes
	elseif snap.cargoType &lt;&gt; TI_CargoType_Container then
		//not interested
		return;
	endif;


	if snap.ignoreMe then
		//slip through
	elseif snap.isOverDimensions then
		if snap.transitStatus = TI_TransitStatusDLR then
			if (is40Foot) then
				self.rehandleODOH40 := self.rehandleODOH40 + 1;
			else
				self.rehandleODOH20 := self.rehandleODOH20 + 1;
			endif;
		elseif snap.transitStatus = TI_TransitStatusSOB then
			if (is40Foot) then
				self.shiftODOH40 := self.shiftODOH40 + 1;
			else
				self.shiftODOH20 := self.shiftODOH20 + 1;
			endif;
		elseif snap.imExStatus = TI_IMEX_STATUS_IMPORT then
			if (is40Foot) then
				self.importODOH40 := self.importODOH40 + 1;
			else
				self.importODOH20 := self.importODOH20 + 1;
			endif;
		elseif snap.imExStatus = TI_IMEX_STATUS_EXPORT then
			if (is40Foot) then
				self.exportODOH40 := self.exportODOH40 + 1;
			else
				self.exportODOH20 := self.exportODOH20 + 1;
			endif;
		elseif snap.imExStatus = TI_IMEX_STATUS_STORAGE then
			if (is40Foot) then
				self.importODOH40 := self.importODOH40 + 1;
			else
				self.importODOH20 := self.importODOH20 + 1;
			endif;
		endif;
	endif;
	
	//find the summaryItem
	if snap.transitStatus = TI_TransitStatusDLR then
		if (is40Foot) then
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_40];
		else
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_20];
		endif;
	elseif snap.transitStatus = TI_TransitStatusSOB then
		if (is40Foot) then
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_40];
		else
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_20];
		endif;
	elseif isImport then
		if (is40Foot) then
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_40];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_40];
				endif;
			else
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_40];
				endif;
			endif;
		else
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_20];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_20];
				endif;
			else
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_20];
				endif;
			endif;
		endif;
	else	//export
		if (is40Foot) then
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_40];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_40];
				endif;
			else
				if (isLCL) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_40];
				elseif (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_40];
				endif;
			endif;
		else
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_20];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_20];
				endif;
			else
				if (isLCL) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_20];
				elseif (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_20];
				endif;
			endif;
		endif;
	endif;

	if cmifItem = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "no cmifItem found");
		return;
	endif;
		
	if not snap.ignoreMe then
		//add to crane moves	
		self.addToCraneMoves(snap.transitStatus = TI_TransitStatusDLR, is40Foot);
		cmifItem.numTIs := cmifItem.numTIs + 1;
	endif;
	
	//add to collection - even the ignored ones
	if CM_UserTISnapShot.hasInstance(snap) then
		if snap.CM_UserTISnapShot.myTISnapShot &lt;&gt; null then
			dispSnap := snap.CM_UserTISnapShot.myTISnapShot;
		endif;
	else
		dispSnap := snap;
	endif;
	
	if not cmifItem.allSnapShots.includes(dispSnap) then
		cmifItem.allSnapShots.add(dispSnap);
	endif;
	
end;</source>
        <Parameter name="_snapShot" type="CM_TISnapShot"/>
    </JadeMethod>
    <JadeMethod name="setItemFromTI" id="ab1c08ea-7094-42bb-a3d8-ca4eab05dd55">
        <updating/>
        <source>setItemFromTI(_ti: CM_TrackedItem) updating;
//----------------------------------------------------------------
//	Created:	08 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------
// 07/06/201	cnwdap1		CCMS 1116 tranship changes - count imports if the voyage here is the tranship's import voyage
// 26/10/2010	cnwdap1		PAR #26146 New parameter for CM_TrackedItem::getCandHCategory method
vars
	ti				: CM_TrackedItem;
	cmifItem		: CMIF_CandHSummaryItem;
	is40Foot		: Boolean;
	isTShip			: Boolean;
	isEmpty			: Boolean;
	isReeferCargo	: Boolean;
	isImport		: Boolean;
	isLCL			: Boolean;
	imexStatus		: Integer;
	theCategory		: Integer;
begin

	ti := _ti;
	imexStatus 		:= ti.getImExStatus;
	
	//isImport 		:= imexStatus = TI_IMEX_STATUS_IMPORT																						// PAR #23645 CCMS 1116
	isImport 		:= imexStatus = TI_IMEX_STATUS_IMPORT or imexStatus = TI_IMEX_STATUS_STORAGE or ti.myImportVoyage = self.myParent.myVoyage;	// PAR #23645 CCMS 1116
	isTShip			:= ti.isTranshipItem;//ti.isInTransitOnShip;
	isEmpty 		:= ti.isAttributeTrue(TI_Attrib_IsEmpty);
	is40Foot 		:= ti.isAttributeTrue(TI_Attrib_IsForty);
	isLCL		 	:= ti.isAttributeTrue(TI_Attrib_IsLCL);
	
	if ti.isAttributeTrue(TI_Attrib_IsFCL)
	and (ti.typeAttributes.bitAnd(ISO_REEFER) &lt;&gt; 0)
	and ti.isAttributeTrue(TI_Attrib_RequiresTemperature) then
		isReeferCargo := true;		//2391: set and use this variable throughout
	endif;
	
	
	if ti.cargoType = TI_CargoType_Timber then
		self.timberPacksLoaded := self.timberPacksLoaded + 1;
		return;//don't count in cranes
	elseif ti.cargoType = TI_CargoType_BreakBulk then
		if imexStatus = TI_IMEX_STATUS_IMPORT then
			self.bbulkDischarged := self.bbulkDischarged + 1;
		else
			self.bbulkLoaded := self.bbulkLoaded + 1;
		endif;
		return;//don;t count in cranes
	elseif ti.cargoType &lt;&gt; TI_CargoType_Container then
		//not interested
		return;
	endif;

	if ti.isOverDimensions then
		if ti.getTransitStatus = TI_TransitStatusDLR then
			if (is40Foot) then
				self.rehandleODOH40 := self.rehandleODOH40 + 1;
			else
				self.rehandleODOH20 := self.rehandleODOH20 + 1;
			endif;
		elseif ti.getTransitStatus = TI_TransitStatusSOB then
			if (is40Foot) then
				self.shiftODOH40 := self.shiftODOH40 + 1;
			else
				self.shiftODOH20 := self.shiftODOH20 + 1;
			endif;
		//elseif imexStatus = TI_IMEX_STATUS_IMPORT then	// PAR #23645 CCMS 1116
		elseif isImport then								// PAR #23645 CCMS 1116
			if (is40Foot) then
				self.importODOH40 := self.importODOH40 + 1;
			else
				self.importODOH20 := self.importODOH20 + 1;
			endif;
		//elseif imexStatus = TI_IMEX_STATUS_EXPORT then												// PAR #23645 CCMS 1116
		elseif imexStatus = TI_IMEX_STATUS_EXPORT or ti.myExportVoyage = self.myParent.myVoyage then	// PAR #23645 CCMS 1116
			if (is40Foot) then
				self.exportODOH40 := self.exportODOH40 + 1;
			else
				self.exportODOH20 := self.exportODOH20 + 1;
			endif;
		elseif imexStatus = TI_IMEX_STATUS_STORAGE then
			if (is40Foot) then
				self.importODOH40 := self.importODOH40 + 1;
			else
				self.importODOH20 := self.importODOH20 + 1;
			endif;
		endif;
	endif;
	
	//theCategory := ti.getCandHCategory();						// PAR #26146
	theCategory := ti.getCandHCategory(self.myParent);			// PAR #26146
	cmifItem := self.allSummaryItemsByPrintOrder[theCategory];
	
	/*
	
	//find the summaryItem
	if ti.getTransitStatus = TI_TransitStatusDLR then
		if (is40Foot) then
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_40];
		else
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_20];
		endif;
	elseif ti.getTransitStatus = TI_TransitStatusSOB then
		if (is40Foot) then
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_40];
		else
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_20];
		endif;
	elseif isImport then
		if (is40Foot) then
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_40];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_40];
				endif;
			else
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_40];
				endif;
			endif;
		else
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_20];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_20];
				endif;
			else
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_20];
				endif;
			endif;
		endif;
	else	//export
		if (is40Foot) then
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_40];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_40];
				endif;
			else
				if (isLCL) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_40];
				elseif (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_40];
				endif;
			endif;
		else
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_20];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_20];
				endif;
			else
				if (isLCL) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_20];
				elseif (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_20];
				endif;
			endif;
		endif;
	endif;
	
	*/

	if cmifItem = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "no cmifItem found");
		return;
	endif;
	
	//add to crane moves	
	self.addToCraneMoves(ti.getTransitStatus = TI_TransitStatusDLR, is40Foot);

	//count 'em
	cmifItem.numTIs := cmifItem.numTIs + 1;
	if not cmifItem.allTrackedItems.includes(ti) then
		cmifItem.allTrackedItems.add(ti);
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setItemFromTIOLD" id="0706bd80-aa94-43e8-b347-54bd4de91dde">
        <updating/>
        <source>setItemFromTIOLD(_ti: CM_TrackedItem) updating;
//----------------------------------------------------------------
//	Created:	08 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

// pre CCMS 1468

vars
	ti				: CM_TrackedItem;
	cmifItem		: CMIF_CandHSummaryItem;
	is40Foot		: Boolean;
	isTShip			: Boolean;
	isEmpty			: Boolean;
	isReeferCargo	: Boolean;
	isImport		: Boolean;
	isLCL			: Boolean;
	imexStatus		: Integer;

begin

	ti := _ti;
	imexStatus 		:= ti.getImExStatus;
	
	isImport 		:= imexStatus = TI_IMEX_STATUS_IMPORT or imexStatus = TI_IMEX_STATUS_STORAGE;
	isTShip			:= ti.isTranshipItem;//ti.isInTransitOnShip;
	isEmpty 		:= ti.isAttributeTrue(TI_Attrib_IsEmpty);
	is40Foot 		:= ti.isAttributeTrue(TI_Attrib_IsForty);
	isLCL		 	:= ti.isAttributeTrue(TI_Attrib_IsLCL);
	
	if ti.isAttributeTrue(TI_Attrib_IsFCL)
	and (ti.typeAttributes.bitAnd(ISO_REEFER) &lt;&gt; 0)
	and ti.isAttributeTrue(TI_Attrib_RequiresTemperature) then
		isReeferCargo := true;		//2391: set and use this variable throughout
	endif;
	
	
	if ti.cargoType = TI_CargoType_Timber then
		self.timberPacksLoaded := self.timberPacksLoaded + 1;
		return;//don't count in cranes
	elseif ti.cargoType = TI_CargoType_BreakBulk then
		if imexStatus = TI_IMEX_STATUS_IMPORT then
			self.bbulkDischarged := self.bbulkDischarged + 1;
		else
			self.bbulkLoaded := self.bbulkLoaded + 1;
		endif;
		return;//don;t count in cranes
	elseif ti.cargoType &lt;&gt; TI_CargoType_Container then
		//not interested
		return;
	endif;

	if ti.isOverDimensions then
		if ti.getTransitStatus = TI_TransitStatusDLR then
			if (is40Foot) then
				self.rehandleODOH40 := self.rehandleODOH40 + 1;
			else
				self.rehandleODOH20 := self.rehandleODOH20 + 1;
			endif;
		elseif ti.getTransitStatus = TI_TransitStatusSOB then
			if (is40Foot) then
				self.shiftODOH40 := self.shiftODOH40 + 1;
			else
				self.shiftODOH20 := self.shiftODOH20 + 1;
			endif;
		elseif imexStatus = TI_IMEX_STATUS_IMPORT then
			if (is40Foot) then
				self.importODOH40 := self.importODOH40 + 1;
			else
				self.importODOH20 := self.importODOH20 + 1;
			endif;
		elseif imexStatus = TI_IMEX_STATUS_EXPORT then
			if (is40Foot) then
				self.exportODOH40 := self.exportODOH40 + 1;
			else
				self.exportODOH20 := self.exportODOH20 + 1;
			endif;
		elseif imexStatus = TI_IMEX_STATUS_STORAGE then
			if (is40Foot) then
				self.importODOH40 := self.importODOH40 + 1;
			else
				self.importODOH20 := self.importODOH20 + 1;
			endif;
		endif;
	endif;
	
	//find the summaryItem
	if ti.getTransitStatus = TI_TransitStatusDLR then
		if (is40Foot) then
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_40];
		else
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.Rehandle, CMIF_CandHRpt.Size_20];
		endif;
	elseif ti.getTransitStatus = TI_TransitStatusSOB then
		if (is40Foot) then
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_40];
		else
			cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ShiftOnBoard, CMIF_CandHRpt.Size_20];
		endif;
	elseif isImport then
		if (is40Foot) then
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_40];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_40];
				endif;
			else
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_40];
				endif;
			endif;
		else
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMTTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportMT, CMIF_CandHRpt.Size_20];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReeferTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportReefer, CMIF_CandHRpt.Size_20];
				endif;
			else
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDryTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ImportDry, CMIF_CandHRpt.Size_20];
				endif;
			endif;
		endif;
	else	//export
		if (is40Foot) then
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_40];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_40];
				endif;
			else
				if (isLCL) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_40];
				elseif (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_40];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_40];
				endif;
			endif;
		else
			if (isEmpty) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMTTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportMT, CMIF_CandHRpt.Size_20];
				endif;
			elseif (isReeferCargo) then
				if (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReeferTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportReefer, CMIF_CandHRpt.Size_20];
				endif;
			else
				if (isLCL) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryLCL, CMIF_CandHRpt.Size_20];
				elseif (isTShip) then
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDryTShip, CMIF_CandHRpt.Size_20];
				else
					cmifItem := self.allSummaryItemsByCode[CMIF_CandHRpt.ExportDry, CMIF_CandHRpt.Size_20];
				endif;
			endif;
		endif;
	endif;
	
	if cmifItem = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "no cmifItem found");
		return;
	endif;
	
	//add to crane moves	
	self.addToCraneMoves(ti.getTransitStatus = TI_TransitStatusDLR, is40Foot);

	//count 'em
	cmifItem.numTIs := cmifItem.numTIs + 1;
	if not cmifItem.allTrackedItems.includes(ti) then
		cmifItem.allTrackedItems.add(ti);
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateForSnapShot" id="10f8a1f9-8519-4f1c-8305-6002f35322e9">
        <source>updateForSnapShot(_snapShot: CM_TISnapShot): Boolean;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	lgd			: CM_LineGroupDebtor;
	updated		: Boolean;
	tmpItem,
	item		: CMIF_CandHSummaryItem;
	tmpDebtor	: CM_DebtorNode;
	tmpShipLine	: CM_ShippingLine;
	tmpSPG		: CM_ShipPortGroup;
	
begin

	tmpDebtor	:= _snapShot.myCandH_Debtor;
	tmpShipLine	:= _snapShot.myCandH_ShippingLine;
	
	if self.myParent.sumariseTo = CMIF_CandHRpt.SumariseTo_Debtor then
		tmpSPG		:= null;
	else
		tmpSPG		:= _snapShot.myCandHShipPortGroup;
	endif;

	updated := false;

	if self.myDebtor = tmpDebtor and
	   self.myShippingLine = tmpShipLine and
	   self.myShipPortGroup = tmpSPG then
	
		//check for add/remove
		updated := false;
		item := self.findSummaryItem(_snapShot);
		foreach tmpItem in self.allSummaryItemsByPrintOrder do
			if tmpItem = item then
				//check for add
				if not tmpItem.allSnapShots.includes(_snapShot) then
					item.addSnapShot(_snapShot);
				else
					//just redo numTIs
					item.redoNumTIs();
				endif;
				updated := true;
			else
				//check for remove
				if tmpItem.allSnapShots.includes(_snapShot) then
					tmpItem.removeSnapShot(_snapShot);
					updated := true;
				endif;
			endif;
		endforeach;
	else
		//check for removal	
		foreach item in self.allSummaryItemsByPrintOrder do
			if item.allSnapShots.includes(_snapShot) then
				item.removeSnapShot(_snapShot);
				updated := true;
				break;
			endif;
		endforeach;
	endif;

	return updated;
	
end;</source>
        <Parameter name="_snapShot" type="CM_TISnapShot"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateForSnapShotOLD" id="91112398-e729-4399-add2-7a9eed48bf35">
        <source>updateForSnapShotOLD(_snapShot: CM_TISnapShot): Boolean;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	lgd			: CM_LineGroupDebtor;
	updated		: Boolean;
	tmpItem,
	item		: CMIF_CandHSummaryItem;
begin

// CCMS-1468 - need to change this to have methods on snapshot to
// return all 3 keys to get to correct summary object.

	lgd := _snapShot.getMyLineGroupDebtor(self.myParent.myVoyage);
	updated := false;
	
	if lgd = self.myLineGroupDebtor then
		//check for add/remove
		updated := false;
		item := self.findSummaryItemOLD(_snapShot);
		foreach tmpItem in self.allSummaryItemsByCode do
			if tmpItem = item then
				//check for add
				if not tmpItem.allSnapShots.includes(_snapShot) then
					item.addSnapShot(_snapShot);
				else
					//just redo numTIs
					item.redoNumTIs();
				endif;
				updated := true;
			else
				//check for remove
				if tmpItem.allSnapShots.includes(_snapShot) then
					tmpItem.removeSnapShot(_snapShot);
					updated := true;
				endif;
			endif;
		endforeach;
	else
		//check for removal	
		foreach item in self.allSummaryItemsByCode do
			if item.allSnapShots.includes(_snapShot) then
				item.removeSnapShot(_snapShot);
				updated := true;
				break;
			endif;
		endforeach;
	endif;

	return updated;
	
end;</source>
        <Parameter name="_snapShot" type="CM_TISnapShot"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
