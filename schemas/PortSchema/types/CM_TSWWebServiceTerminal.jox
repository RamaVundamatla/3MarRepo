    <JadeMethod name="pxyCreateUpdateProxy" id="9feff899-7abb-4f33-a8a8-03043ce2f826">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12 August 2016	cnwdap1		Initial creation PAR #
//
vars
	pxyWebServiceTerminal : CM_TSWWebServiceTerminal;

begin
	pxyWebServiceTerminal := inheritMethod();
	pxyWebServiceTerminal.myTerminal := self.myTerminal;
	
	return pxyWebServiceTerminal;

epilog

end;</source>
