    <JadeMethod name="setupQFCamTransactions" id="8a5372b0-1e9c-471d-9b8c-5872bc5c86e0">
        <updating/>
        <source>setupQFCamTransactions() updating;
/*
	Create or update the Query Filters that are uses by Cam Protocol. 
	These are the persistent objects that belong to the User Def Desc object. They get cloned as transient query by cans background task
	
	For the initial implementation these are system-defined Query Filters only. An interface may be added in the future that lets the users
	build their own.
	
	Inputs : none
	Outputs : create or updates persistent objects  on self.allQFCamTransactions
*/
vars
	qf : CMQF_CamTransactionTemplate;
	queryDesc : String;
	
begin

	// now create the system queries. The method setForCreateSystem knows what the parameters are
	// We call for existing oens too in case we change the query values
	
	queryDesc := QFCam_None;
	qf := allQFCamTransactionTemplates[queryDesc];
	if qf = null then 
		create qf;
	endif;
	qf.setForCreateSystem(self, queryDesc);
	
	queryDesc := QFCam_EmptyContainers;	
	qf := allQFCamTransactionTemplates[queryDesc];
	if qf = null then 
		create qf;
	endif;
	qf.setForCreateSystem(self, queryDesc);
	
	queryDesc := QFCam_EmptyContainers4Release;	
	qf := allQFCamTransactionTemplates[queryDesc];
	if qf = null then 
		create qf;
	endif;
	qf.setForCreateSystem(self, queryDesc);
	
	queryDesc := QFCam_EmptyStorageContainers;
	qf := allQFCamTransactionTemplates[queryDesc];
	if qf = null then 
		create qf;
	endif;
	qf.setForCreateSystem(self, queryDesc);
	
	queryDesc := QFCam_ExportContainerExclEmpty; 
	qf := allQFCamTransactionTemplates[queryDesc];
	if qf = null then 
		create qf;
	endif;
	qf.setForCreateSystem(self, queryDesc);
	
	
	queryDesc := QFCam_ExportContainers; 
	qf := allQFCamTransactionTemplates[queryDesc];
	if qf = null then 
		create qf;
	endif;
	qf.setForCreateSystem (self, queryDesc);
		
	queryDesc := QFCam_GeneralCargo; 
	qf := allQFCamTransactionTemplates[queryDesc];
	if qf = null then 
		create qf;
	endif;
	qf.setForCreateSystem(self, queryDesc);
	
end;
</source>
    </JadeMethod>
