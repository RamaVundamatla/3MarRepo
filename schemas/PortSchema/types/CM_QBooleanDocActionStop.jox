<Class name="CM_QBooleanDocActionStop" id="ddbf7174-075e-4a57-8b47-c466be87860a">
    <superclass name="CM_QBooleanMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <Constant name="PREFIX_NICE_NAME" id="2bbc753a-ad42-4db3-b8f2-63e01299fe14">
        <source>'Stop DA- '</source>
        <type name="String"/>
    </Constant>
    <Constant name="PREFIX_PROPERTY_NAME" id="c3697db3-9946-4e61-b69c-73ca5ddd36ef">
        <source>'stopDA- '</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="stopId" id="82627b39-a464-4238-bff4-95b9719eec9d">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValueForObject" id="4ead2a42-bd49-444b-b4d3-f8e529d3c516">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2016	cnwndl1	Initial creation	TFS 3021 / 2419

*/

vars

begin
	return _obj.CM_TrackedItem.hasIncompleteDocAction( self.stopId, null );

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setup" id="554d1601-4f8c-48db-8b1b-f6018976886e">
        <updating/>
        <source>setup(_stop : CM_StopsTable; _className :String)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2016	cnwndl1	Initial creation	TFS 3021 / 2419

*/

vars
	strDesc	:String;
	intCode	:Integer;
begin
	strDesc := _stop.heading;
	intCode	:= _stop.id;

	if strDesc.length &gt;= 24 then
		strDesc := _stop.heading[1:21] &amp; '...';
	endif;
	
	self.set(self.PREFIX_NICE_NAME &amp; strDesc, self.PREFIX_PROPERTY_NAME &amp; intCode.String, _className);
	
	if self.stopId &lt;&gt; intCode then
		self.stopId := intCode;
	endif;
	
	self.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
			
epilog

end;</source>
        <Parameter name="_stop" type="CM_StopsTable"/>
        <Parameter name="_className" type="String"/>
    </JadeMethod>
</Class>
