    <JadeMethod name="getOperator" id="42d0f7a4-3e3b-4e7a-933e-304462fc60c0">
        <source>getOperator() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	operator : CM_Operator;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		operator := self.myTrackedItem.myOperator;
	elseif self.myBookingRef &lt;&gt; null then
		operator := self.myBookingRef.myOperator;
	elseif self.myBOL &lt;&gt; null then
		operator := self.myBOL.myOperator;
	elseif self.myGateReceival &lt;&gt; null then
		operator := self.myGateReceival.getOperatorObject;
	elseif self.myGateReceivalByType &lt;&gt; null then			// 10/12/2010 cnwmh5 #26556
		operator := self.myGateReceivalByType.getOperatorObject();
	endif;
	
	if operator &lt;&gt; null then
		return app.getErrorString(Operator_GC) &amp; " =  " &amp; operator.displayForXlation(true);
	endif;
	
	return app.getErrorString(Operator_GC) &amp; " =  " &amp; " ";
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPicLogoPort" id="47d58ae8-75d5-4acd-96ec-ae9eb887164e">
        <source>getPicLogoPort():Binary;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2010	cnwndl1	Initial creation	Par 22630

*/

vars

	picBinary : Binary;
	
begin

	if self.myTerminal &lt;&gt; null then
		picBinary := self.myTerminal.getConfig(PortLogoPic).Binary;
		if picBinary &lt;&gt; null then
			return picBinary;
		endif;
	endif;

	return app.getPicLogoPort;
	
epilog

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getReceivedDateTime" id="129883ef-89be-4eb3-bde9-9e16652bb086">
        <source>getReceivedDateTime() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	dateTime : TimeStamp;
	retStr : String;
	
begin

	dateTime := null;

	if self.myTrackedItem &lt;&gt; null then
		dateTime := self.myTrackedItem.receivedDT;
	elseif self.myBookingRef &lt;&gt; null then
		dateTime := null;
	elseif self.myBOL &lt;&gt; null then
		dateTime := null;
	elseif self.myGateReceival &lt;&gt; null then
		dateTime := null;
	elseif self.myGateReceivalByType &lt;&gt; null then	// 10/12/2010 cnwmh5 #26556
		dateTime := null;
	endif;
	
	if dateTime.Date.isValid then
		retStr :=  app.getErrorString(Received) &amp; "  =  " &amp; dateTime.asStringJMT;
		return retStr;
	endif;
	
	return app.getErrorString(Received) &amp; "  =  " &amp; " ";
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShippingLine" id="90052060-0fac-4785-b546-14ebf59f1d27">
        <source>getShippingLine() : String;
// 37594 Steinweg Oman cargo label print
vars
	shippingLine		: String;
	voyage			: CM_Voyage;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		voyage := self.myTrackedItem.myVoyage;
	elseif self.myBookingRef &lt;&gt; null then
		voyage := self.myBookingRef.myVoyage;
	elseif self.myBOL &lt;&gt; null then
		voyage := self.myBOL.getMyVoyage;
	//elseif self.myGateReceival &lt;&gt; null then
	//	voyageCode := self.myGateReceival.voyageCode;
	//elseif self.myGateReceivalByType &lt;&gt; null then
	//	voyageCode := self.myGateReceivalByType.voyageCode;
	endif;
	
	if voyage &lt;&gt; null and
	   voyage.myShippingLine &lt;&gt; null then
		shippingLine := voyage.myShippingLine.description;
	endif;
	
	return shippingLine;
epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalQuantity" id="1b30db60-dd09-40ab-a7ba-8bae6bc59dbd">
        <source>getTotalQuantity() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	quantity : Integer;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		quantity := self.myTrackedItem.totalQuantity;
	elseif self.myBookingRef &lt;&gt; null then
		quantity := self.myBookingRef.getTotalQuantity;
	elseif self.myBOL &lt;&gt; null then
		quantity := self.myBOL.getTotalTIQty;
	elseif self.myGateReceival &lt;&gt; null then
		quantity := self.myGateReceival.quantity;
	elseif self.myGateReceivalByType &lt;&gt; null then		// 10/12/2010 cnwmh5 #26556
		quantity := self.myGateReceivalByType.quantity;
	endif;
	
	if quantity &gt; 0 then
		return app.getErrorString(CM_Total_Quantity) &amp; "  =  " &amp; quantity.asStringJMT;
	endif;
	
	return app.getErrorString(CM_Total_Quantity) &amp; "  =  " &amp;  " ";
	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalVolume" id="39d0d07d-a477-476d-bce2-060ba59c50bc">
        <source>getTotalVolume() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	volume : Decimal [12,4];
	
begin

	if self.myTrackedItem &lt;&gt; null then
		volume := self.myTrackedItem.getMyCargoVolume;
	elseif self.myBookingRef &lt;&gt; null then
		volume := self.myBookingRef.getVolume;
	elseif self.myBOL &lt;&gt; null then
		volume := self.myBOL.getTotalTIVolume;
	elseif self.myGateReceival &lt;&gt; null then
		volume := self.myGateReceival.getMyVolume;
	elseif self.myGateReceivalByType &lt;&gt; null then		// 10/12/2010 cnwmh5 #26556
		volume := self.myGateReceivalByType.getMyVolume;
	endif;
	
	if volume &gt; 0 then
		return app.getErrorString(CM_Cargo_Volume) &amp; " =  " &amp; volume.asStringJMT;
	endif;
	
	return app.getErrorString(CM_Cargo_Volume) &amp; " =  " &amp; " ";
	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
