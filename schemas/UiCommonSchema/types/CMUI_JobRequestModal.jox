    <JadeMethod name="doSave" id="ccf1853f-a041-4be4-951d-e1c1a3e61b57">
        <updating/>
        <source>doSave() : Boolean updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	
	if self.eventRequestType = EventRequestTypeStopsStr then
		return self.doSaveStops();	
	elseif self.eventRequestType = EventRequestTypeNotifyStr then
		return self.doSaveNotify();
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Type ' &amp; self.eventRequestType &amp; ' not handled');
		return false;
	endif;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveNotify" id="b5867906-e78e-4be3-8012-b27951ee4f62">
        <updating/>
        <source>doSaveNotify() : Boolean updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTimeArray : TimeArray;
	tmpUser : CM_User;
	cmifEventReq : CMIF_EventRequestController;
	pxyEmail,
	realEmail : CM_EventRequestEmail;
	pxyRequestNotify : CM_EventRequestNotification;
	result : Integer;
	rtnValue : Boolean;
begin return true;/*
	if self.mode = self.Mode_Update then
		if CM_EventRequestNotification.hasInstance(self.myEventRequest) then
			beginLoad;
			pxyRequestNotify := self.myEventRequest.pxyCreateUpdateProxy().CM_EventRequestNotification;
			tmpUser := self.myEventRequest.myUser;			
			endLoad;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'myEventRequest is null for update');	
			return false;	
		endif;		
	elseif self.mode = self.Mode_Add then
		create pxyRequestNotify transient;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for update');		
		return false;
	endif;
	
	self.setProxyEventRequest(pxyRequestNotify, tmpUser);	
	if tmpUser = null then
		tmpUser := app.getMyUser();
	endif;

	beginLoad;
	
	create tmpTimeArray transient;
	self.getRunTimes(tmpTimeArray);
	
	if not tmpTimeArray.isEmpty() then
		realEmail := tmpUser.allEventRequestEmail[pxyRequestNotify.type];
		if realEmail &lt;&gt; null then
			pxyEmail := realEmail.pxyCreateUpdateProxy();
	
		elseif (not tmpTimeArray.isEmpty) then //&lt;-- only create if they have added time(s)
			create pxyEmail transient;
		endif;
		endLoad;
		
		if pxyEmail &lt;&gt; null then
			pxyEmail.setProxy(app.myRoot, tmpUser, pxyRequestNotify.type, tmpTimeArray);
		endif;
	endif;
	
	create cmifEventReq transient;
	cmifEventReq.myPxyEventRequestEmail := pxyEmail;		
	cmifEventReq.myPxyEventRequestNotify := pxyRequestNotify;
	cmifEventReq.cargoIds := self.txtCargoId.text;
	self.lstTableRequest.getSelectedStrings(cmifEventReq.allEventNames);		
	//self.lstTableRequest.allSelectedObjects.copy(cmifEventReq.allSelectedObjects);		
	self.lstTableRequest.getSelectedObjectsWithDupes(cmifEventReq.allSelectedObjects);		
		
	while true do
		app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);					
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Event Notification Request', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

	if rtnValue then	
		app.msgBox(app.getErrorString4(EventRequestResult, self.eventRequestType, cmifEventReq.numPending.String, cmifEventReq.numActioned.String, cmifEventReq.numMatchFailed.String), self.eventRequestType, MsgBox_OK_Only+ MsgBox_Information_Icon);
	endif;
								
epilog
	endLoad;
	delete tmpTimeArray;
	delete pxyEmail;
	delete pxyRequestNotify;
	delete cmifEventReq;
	return rtnValue;*/
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveStops" id="97eb1ddc-208d-4074-b394-2dd257fcca36">
        <updating/>
        <source>doSaveStops() : Boolean updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	cmifEventReq : CMIF_EventRequestController;
	tmpTimeArray : TimeArray;
	tmpStopTablesCol : CM_StopsTableSet;
	realEmail,
	pxyEmail : CM_EventRequestEmail;
	pxyRequestStops : CM_EventRequestStops;		
	result : Integer;
	rtnValue : Boolean;
	tmpUser : CM_User;
begin return true;
	/*
	if self.mode = self.Mode_Update then
		if CM_EventRequestStops.hasInstance(self.myEventRequest) then
			beginLoad;
			pxyRequestStops := self.myEventRequest.pxyCreateUpdateProxy().CM_EventRequestStops;
			tmpUser := self.myEventRequest.myUser;
			endLoad;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'myEventRequest is null for update');	
			return false;	
		endif;		
	elseif self.mode = self.Mode_Add then
		create pxyRequestStops transient;
		create tmpStopTablesCol transient;
		self.lstTableRequest.allSelectedObjects.copy(tmpStopTablesCol);							
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for update');		
		return false;
	endif;
	
	self.setProxyEventRequest(pxyRequestStops, tmpUser);
	if tmpUser = null then
		tmpUser := app.getMyUser();
	endif;
	
	create tmpTimeArray transient;
	self.getRunTimes(tmpTimeArray);
		
	if not tmpTimeArray.isEmpty() then
		realEmail := tmpUser.allEventRequestEmail[pxyRequestStops.type];
		if realEmail &lt;&gt; null then
			beginLoad;
			pxyEmail := realEmail.pxyCreateUpdateProxy();
			endLoad;
		elseif (not tmpTimeArray.isEmpty) then
			create pxyEmail transient;
		endif;
		
		if pxyEmail &lt;&gt; null then
			pxyEmail.setProxy(app.myRoot, tmpUser, pxyRequestStops.type, tmpTimeArray);
		endif;
	endif;
		
	create cmifEventReq transient;
	cmifEventReq.myPxyEventRequestEmail := pxyEmail;		
	cmifEventReq.myPxyEventRequestStops := pxyRequestStops;
	cmifEventReq.cargoIds := self.txtCargoId.text;
	self.lstTableRequest.allSelectedObjects.copy(cmifEventReq.allStopTables);							

	while true do
		app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Stop Request', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	
	if rtnValue then
		app.msgBox(app.getErrorString4(EventRequestResult, self.eventRequestType, cmifEventReq.numPending.String, cmifEventReq.numActioned.String, cmifEventReq.numMatchFailed.String), self.eventRequestType, MsgBox_OK_Only+ MsgBox_Information_Icon);
	endif;
		
epilog
	endLoad;
	delete tmpTimeArray;
	delete pxyEmail;
	delete tmpStopTablesCol;
	delete pxyRequestStops;
	delete cmifEventReq;			
	return rtnValue;*/
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectRecipients" id="130d80fa-50a2-4ce1-b90c-c6a236a467f6">
        <source>doSelectRecipients();
//--------------------------------------------------
// Created:	18 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	email : CM_EmailEntity;
	origAddresses,
	address,
	str : String;
	result : Integer;
	selected : CM_EmailEntityByTypeNameDict;
	emailController	: CMIF_EmailTemplateController;
	form			: CMUI_RecipientSelector;
	toA,
	ccA,
	bccA	: String;
	
begin
/*	create selected transient;
	self.allSelectedRecipients.copy(selected);	
	result := self.myAssistant.showMultiSelectForm(self.eventRequestType, app.myRoot.allEmailEntities, selected);
	if result &lt;&gt; IDOK then
		return;
	endif;
	origAddresses := self.txtRecipients.text;
	self.allSelectedRecipients.clear();
	selected.copy(self.allSelectedRecipients);
	foreach email in selected do
		address := email.getEmailAddress();
		if address &lt;&gt; null then
			if origAddresses.cnContains(address) then
				continue;
			endif;
			str := str &amp; '; ' &amp; address;
		endif;
	endforeach;*/
	
/*	create form transient;
	create emailController transient;
	
	self.setNavigatorHeading(form.caption);
	form.myEmailController := emailController;
	form.mode := CMUI_RecipientSelector.Mode_To;
	form.centreWindow;
	form.showModal;

	origAddresses := self.txtRecipients.text;
	
	if form.modalResult = IDOK then
		toA 	:= emailController.allToAddresses.getAddresses();
		ccA 	:= emailController.allCcAddresses.getAddresses();
		bccA	:= emailController.allBccAddresses.getAddresses();
		
		if toA &lt;&gt; null then
			str := toA &amp; ';';
		endif;
		
		if ccA &lt;&gt; null then
			str := str &amp; ccA &amp; ';';
		endif;
		
		if bccA &lt;&gt; null then
			str := str &amp; bccA &amp; ';';
		endif;
	endif;

	if str.length &gt; 1 then
		if origAddresses &lt;&gt; null then
			if app.msgBox(app.getErrorString(ConcatenateEmailAddresses), 'Email Recipients', MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
				self.txtRecipients.text := origAddresses &amp; '; ' &amp; str;
			endif;
		else
			self.txtRecipients.text := str;
		endif;
	endif;	
epilog
	delete selected;
	delete emailController;*/
end;</source>
    </JadeMethod>
    <JadeMethod name="getEmailAddresses" id="258c4c86-6cb3-4532-86ea-9b7224aeff19">
        <source>getEmailAddresses(_addressArray : CM_StringArray input);
//--------------------------------------------------
