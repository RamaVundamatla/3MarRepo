    <text>



### CAN BE REMOVED after 792. Was class used for RORO PROTOTYPE</text>
    <DbClassMap file="vesselStructures"/>
    <ExplicitInverseRef name="allShipDecks" id="3a9dcc08-f2f1-4223-a8fd-c967d5de9252">
