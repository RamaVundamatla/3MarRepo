    <JadeMethod name="validate" id="ed862dc1-fbbb-4cd3-8774-734c734790d2">
        <source>validate() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 EPL1 Work Order Changes
// 26 May 2022	navma1		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// 08 Feb 2023  navma1 		ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
vars
	ti : CM_TrackedItem;
begin
	inheritMethod();
	
	foreach ti in self.allSelectedTIs do
		if ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_EXPORT then
			app.raiseCMException(Export_retur_only_export_cargo, null, null);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
