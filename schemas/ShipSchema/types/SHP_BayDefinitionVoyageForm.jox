    <JadeMethod name="printControlData" id="6d48be1c-651e-481c-b8e3-c678a0daf9ce">
        <source>printControlData(_gtpdataTable: CM_GenericTablePrint input; _progress: CMS_Progress input);
//--------------------------------------------------
// Created:	05 January 2006 By: cnwgd1
//--------------------------------------------------
vars
begin

	inheritMethod(_gtpdataTable, _progress);

	if _progress &lt;&gt; null then
		_progress.progress.partsInJob := 26;
	endif;
	
	self.frmReport.left := app.printer.rightMargin;
	self.frmReport.width :=	app.printer.pageWidth - app.printer.leftMargin - app.printer.rightMargin;
	self.lblReport.width := self.frmReport.width - self.lblReport_1.width;
		
	self.lblReport_1.caption := self.lblBayID.caption;
	self.lblReport.caption := self.txtBayID.text;
	app.printer.print(self.frmReport);
	
	self.lblReport_1.caption := self.ckbFortyFootBay.caption;
	self.lblReport.caption := self.ckbFortyFootBay.value.getYesNo;
	app.printer.print(self.frmReport);	

	self.lblReport_1.caption := self.ckbFortyFootOnly.caption;
	self.lblReport.caption := self.ckbFortyFootOnly.value.getYesNo;
	app.printer.print(self.frmReport);		

	self.lblReport_1.caption := self.ckbForty5FootBay.caption;
	self.lblReport.caption := self.ckbForty5FootBay.value.getYesNo;
	app.printer.print(self.frmReport);	

	self.lblReport_1.caption := self.ckbForty5FtOnly.caption;
	self.lblReport.caption := self.ckbForty5FtOnly.value.getYesNo;
	app.printer.print(self.frmReport);		
	
	self.lblReport_1.caption := self.lblIDBay40.caption;
	self.lblReport.caption := self.txt40FootBayID.text;
	app.printer.print(self.frmReport);

	self.lblReport_1.caption := self.lblDirOn20.caption;
	self.lblReport.caption := self.cmbDirOn.text;
	app.printer.print(self.frmReport);						

	self.lblReport_1.caption := self.lblDirUnder20.caption;
	self.lblReport.caption := self.cmbDirUnder.text;
	app.printer.print(self.frmReport);

	self.lblReport_1.caption := self.lblDirOn40.caption;
	self.lblReport.caption := self.cmbDirOn40.text;
	app.printer.print(self.frmReport);																

	self.lblReport_1.caption := self.lblDirUnder40.caption;
	self.lblReport.caption := self.cmbDirUnder40.text;
	app.printer.print(self.frmReport);

	self.lblReport_1.caption := self.lblLashFromTier.caption;
	self.lblReport.caption := self.cmbLashFrom.text;
	app.printer.print(self.frmReport);	

	self.lblReport_1.caption := self.lblUnlashFrom.caption;
	self.lblReport.caption := self.cmbUnlashFrom.text;
	app.printer.print(self.frmReport);															


	self.lblReport_1.caption := self.lblOnDeckCells.caption;
	self.lblReport.caption := self.txtOnDeckCells.text;
	app.printer.print(self.frmReport);	

	self.lblReport_1.caption := self.lblOnDeckTier.caption;
	self.lblReport.caption := self.txtOnDeckTier.text;
	app.printer.print(self.frmReport);						

	self.lblReport_1.caption := self.lblUnderDeckCell.caption;
	self.lblReport.caption := self.txtUnderDeckCell.text;
	app.printer.print(self.frmReport);									

	self.lblReport_1.caption := self.lblUnderDeckTier.caption;
	self.lblReport.caption := self.txtUnderDeckTier.text;
	app.printer.print(self.frmReport);					

	self.lblReport_1.caption := self.lblUDCellHighCub.caption;
	self.lblReport.caption := self.txtUDCellsHiCub.text;
	app.printer.print(self.frmReport);

	self.lblReport_1.caption := self.ckbAftwartships.caption;
	self.lblReport.caption := self.ckbAftwartships.value.getYesNo;
	app.printer.print(self.frmReport);

	self.lblReport_1.caption := self.ckbTwinLiftOD.caption;
	self.lblReport.caption := self.ckbTwinLiftOD.value.getYesNo;
	app.printer.print(self.frmReport);

	self.lblReport_1.caption := self.ckbTwinLiftUD.caption;
	self.lblReport.caption := self.ckbTwinLiftUD.value.getYesNo;
	app.printer.print(self.frmReport);

	self.lblReport_1.caption := self.lblMaxPileWt20IB.caption;
	self.lblReport.caption := self.txtMaxPileWt20IB.text;
	app.printer.print(self.frmReport);										
	
	self.lblReport_1.caption := self.lblMaxPileWt20OB.caption;
	self.lblReport.caption := self.txtMaxPileWt20OB.text;
	app.printer.print(self.frmReport);										
	
	self.lblReport_1.caption := self.lblMaxPileWt40IB.caption;
	self.lblReport.caption := self.txtMaxPileWt40IB.text;
	app.printer.print(self.frmReport);										
	
	self.lblReport_1.caption := self.lblMaxPileWt40OB.caption;
	self.lblReport.caption := self.txtMaxPileWt40OB.text;
	app.printer.print(self.frmReport);														

	self.lblReport_1.caption := self.lblMaxPileWtUD.caption;
