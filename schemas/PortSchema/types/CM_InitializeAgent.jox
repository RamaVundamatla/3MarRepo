    <JadeMethod name="createAllTestData" id="c0467048-46b1-4ee7-8389-3b1010d145b7">
        <source>createAllTestData();

vars

begin

	app.initialize();
	
	self.createTestCarrierData();
	self.createTestCommodityData();
	self.createTestConsigneeConsignData();
	self.createTestCountryPortData();
	self.createTestHazardData();
	self.createTestISOData();
	self.createTestMachineData(app.myPassport.myTerminal);
	self.createTestOperatorData();
	self.createTestToDoTaskDetails();
	self.createTestBatNumbers();
	self.createTestDataHacks();

	// These must be done after operator data
	self.createTestLogSourceData();
	self.createTestLogSpecData();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createOrganisation" id="bf419a2b-02fe-4a09-8c70-4d28317415dd">
        <updating/>
        <source>createOrganisation(_name : String) : Boolean updating;
// -----------------------------------------------------------------------------
// Created:		21 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	daDict : CM_DataAccessControllerSet;

begin
	create daDict transient;
	
	app.myTrxCA.trxCreateInternalOrganisation(_name, null, daDict, myNewOrg, false, false, null, app.myPassport);
	return app.myPassport.trxCompletedOK();

epilog
	delete daDict;
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createRoot" id="62480d23-7a3f-4611-a20a-9760c863376b">
        <updating/>
        <source>createRoot(_companyCode, _companyName, _clientName : String) : Boolean updating ;
// -----------------------------------------------------------------------------
// Created:		18 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	root, proxyRoot : CM_Root;
	menuAgent		: CM_MenuAgent;
begin
	create proxyRoot transient;
	proxyRoot.setProxy(_companyCode, _companyName, _clientName);	
	app.myTrxCA.trxCreateRoot(proxyRoot, root, app.myPassport);
	create menuAgent transient;
	return app.myPassport.trxCompletedOK;
epilog
	delete menuAgent;
	delete proxyRoot;
end;</source>
        <Parameter name="_companyCode" type="String"/>
        <Parameter name="_companyName" type="String"/>
        <Parameter name="_clientName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTerminal" id="16214cab-244b-4d41-8076-468816ed4117">
        <updating/>
        <source>createTerminal(_terminalCode, _terminalName : String) : Boolean updating;
// -----------------------------------------------------------------------------
// Created:		19 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 22/06/2016	cnwns1		TFS 488 - Multi Timezone Support
// 21/06/2023	navdap1		TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
// 01 Aug 2025  navsp1      JIRA-35530 Solution Implementation - COPRAR Trailer Support
// -----------------------------------------------------------------------------
vars
	proxyTerminal,
	createdTerminal : CM_Terminal;
	tmpArray : CM_CargoBOLTypeArray;
begin

	create tmpArray transient;
	app.myRoot.allCargoTypesById.copy(tmpArray);
	app.myRoot.allBOLTypes.copy(tmpArray);

//change to call the trx 

	createdTerminal := app.myRoot.createTerminal(_terminalCode,
												_terminalName,
												app.systemTimeZoneID,	// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
												null,					// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
												tmpArray,
												TI_CargoType_Container,
												TI_CargoType_Null,
												TI_CargoType_Container,
												TI_CargoType_Null,			// TFS 56747
                                                TI_CargoType_Null,          //JIRA-35530
												app.actualTimeServer().date());

	//find superuser and set the userterminal terminal
	//epr par 36624 16/4/15 refactored so done in CM_Terminal create method
epilog
	
	delete tmpArray;
	return app.myPassport.noErrors();
end;</source>
        <Parameter name="_terminalCode" type="String"/>
        <Parameter name="_terminalName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTestBatNumbers" id="8745bccf-ec4d-40a1-9a1c-44e03746e8e0">
        <source>createTestBatNumbers();
// ---------------------------------------------------------------------------
// Created:     14 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	batNo,
	batNo2	: CM_BatNumber;
	term		: CM_Terminal;
begin

//Crap code to setup until we decide exactly on V7 format for bat numbers
	term := app.myPassport.myTerminal;
	if term = null then
		return;
	endif;
	
	beginTransaction;
	term.createBatNumber('1', batNo);
	commitTransaction;

	beginTransaction;
	term.createBatNumber('2', batNo2);
	commitTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="createTestCarrierData" id="6f59d8c0-20d1-4990-9bae-e2414b403c99">
        <source>createTestCarrierData();
// ---------------------------------------------------------------------------
// Created:     10 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	12/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
// ---------------------------------------------------------------------------
vars
	pxyCarrier,
	realCarrier	: CM_Carrier;
	pxyVehicle,
	realVehicle	: CM_Vehicle;
	
begin

	create pxyCarrier transient;
	create pxyVehicle transient;

	//pxyCarrier.setProxy('AZT', 'Aztec', null, false, false, false, null, null, null, null);			//12/05/2022 navhl20 TFS 53430 
	pxyCarrier.setProxy('AZT', 'Aztec', null, false, false, false, false, null, null, null, null);		//12/05/2022 navhl20 TFS 53430 
	app.myTrxCA.trxCreateCarrier(pxyCarrier, realCarrier, app.myPassport);

	pxyVehicle.setProxy('AA1234','01', null, 0, realCarrier, null, false, app.myPassport.myTerminal);	
	app.myTrxCA.trxCreateVehicle(pxyVehicle, realVehicle, app.myPassport);

	//pxyCarrier.setProxy('RR', 'Roadrunners', null, false, false, false, null, null, null, null);		//12/05/2022 navhl20 TFS 53430 
	pxyCarrier.setProxy('RR', 'Roadrunners', null, false, false, false, false, null, null, null, null);	//12/05/2022 navhl20 TFS 53430 
	app.myTrxCA.trxCreateCarrier(pxyCarrier, realCarrier, app.myPassport);

	pxyVehicle.setProxy('RR1111','01', null, 0, realCarrier, null,false, app.myPassport.myTerminal);	
	app.myTrxCA.trxCreateVehicle(pxyVehicle, realVehicle, app.myPassport);

epilog
	delete pxyCarrier;
	delete pxyVehicle;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createTestCommodityData" id="c1f08c60-6622-41f5-a369-a243366a39cc">
        <source>createTestCommodityData();
// ---------------------------------------------------------------------------
// Created:     10 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Added new parameter to commodity setProxy
// ---------------------------------------------------------------------------
vars
	pxyCommodity,
	realCommodity	: CM_Commodity;
	pxyCommodityGroup,
	realCommodityGroup	: CM_CommodityGroup;
	
begin

	create pxyCommodity transient;
	create pxyCommodityGroup transient;

	pxyCommodityGroup.setProxy('LOGS', 'Logs', 0, false, 0, 0, null, false, false);	
	app.myTrxCA.trxCreateCommodityGroup(pxyCommodityGroup, realCommodityGroup,app.myPassport);

	//pxyCommodity.setProxy('SL', 'Saw Logs', 'Saw Logs', 'Saw Logs', false, false, false, false, false, Blue, 0, 0, realCommodityGroup,null, null);			// PAR #35895
	pxyCommodity.setProxy('SL', 'Saw Logs', 'Saw Logs', 'Saw Logs', false, false, false, false, false, Blue, 0, 0, realCommodityGroup, null, false, null,false);		// PAR #35895
	app.myTrxCA.trxCreateCommodity(pxyCommodity, realCommodity,app.myPassport);

	//pxyCommodity.setProxy('PL', 'Pulp Logs', 'Pulp Logs', 'Pulp Logs', false, false, false, false, false, Blue, 0, 0, realCommodityGroup,null, null);			// PAR #35895
	pxyCommodity.setProxy('PL', 'Pulp Logs', 'Pulp Logs', 'Pulp Logs', false, false, false, false, false, Blue, 0, 0, realCommodityGroup, null, false, null,false);	// PAR #35895
	app.myTrxCA.trxCreateCommodity(pxyCommodity, realCommodity,app.myPassport);


	pxyCommodityGroup.setProxy('MEAT', 'Meat', 0, false, 0, 0, null,false, false);	
	app.myTrxCA.trxCreateCommodityGroup(pxyCommodityGroup, realCommodityGroup,app.myPassport);

	//pxyCommodity.setProxy('FZLB', 'Frozen Lamb', 'FZ Lamb', 'FZ Lamb', false, false, false, false, false, Blue, 0, 0, realCommodityGroup,null, null);			// PAR #35895
	pxyCommodity.setProxy('FZLB', 'Frozen Lamb', 'FZ Lamb', 'FZ Lamb', false, false, false, false, false, Blue, 0, 0, realCommodityGroup, null, false, null,false);	// PAR #35895
	app.myTrxCA.trxCreateCommodity(pxyCommodity, realCommodity,app.myPassport);

epilog
	delete pxyCommodity;
	delete pxyCommodityGroup;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createTestConsigneeConsignData" id="6c020d47-4a49-4880-9e28-e267a8cca2ee">
        <source>createTestConsigneeConsignData();
// ---------------------------------------------------------------------------
// Created:     10 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute to CM_ConsigneeConsignor
// 03 Aug 2017	cnwma1		TFS #5209:PEN - Release Request Stop
// ---------------------------------------------------------------------------
vars
	pxyConsigneeConsignor,
	realConsigneeConsignor	: CM_ConsigneeConsignor;
	pxyConsigneeConsignorGroup,
	realConsigneeConsignorGroup	: CM_ConsigneeConsignorGroup;
	
begin

	create pxyConsigneeConsignor transient;
	create pxyConsigneeConsignorGroup transient;

	pxyConsigneeConsignorGroup.setProxy('NA', 'North American',null);	
	app.myTrxCA.trxCreateConsignGroup(pxyConsigneeConsignorGroup, realConsigneeConsignorGroup,app.myPassport);

	pxyConsigneeConsignor.setProxy('ACE', 'Ace Timber', false, false, 'DR123', null, Blue, 0, 
									//realConsigneeConsignorGroup, null,false,false,false,false, null, null, null);		//cnwmc5 - 19/12/2012 - HAT 2198	// PAR #35895
									realConsigneeConsignorGroup, null,false,false,false,false, null, null, null, false,false,false);//cnwmc5 - 19/12/2012 - HAT 2198	// PAR #35895 // 3.8.2017 cnwma1 TFS #5209
	app.myTrxCA.trxCreateConsigneeConsignor(pxyConsigneeConsignor, realConsigneeConsignor,app.myPassport);

	pxyConsigneeConsignor.setProxy('SPULP', 'Seattle Pulp', false, true, 'DR45', null, Green, 0, 
									//realConsigneeConsignorGroup, null,false,false,false,false, null, null, null);		//cnwmc5 - 19/12/2012 - HAT 2198	// PAR #35895
									realConsigneeConsignorGroup, null,false,false,false,false, null, null, null, false,false,false);//cnwmc5 - 19/12/2012 - HAT 2198	// PAR #35895 // 3.8.2017 cnwma1 TFS #5209
	app.myTrxCA.trxCreateConsigneeConsignor(pxyConsigneeConsignor, realConsigneeConsignor,app.myPassport);


	pxyConsigneeConsignorGroup.setProxy('NZ', 'New Zealand', null);	
	app.myTrxCA.trxCreateConsignGroup(pxyConsigneeConsignorGroup, realConsigneeConsignorGroup,app.myPassport);

	pxyConsigneeConsignor.setProxy('WCT', 'West Coast Timber', false, false, null, null, Green, 0, 
									//realConsigneeConsignorGroup, null,false,false,false,false, null, null, null);		//cnwmc5 - 19/12/2012 - HAT 2198	// PAR #35895
									realConsigneeConsignorGroup, null,false,false,false,false, null, null, null, false,false,false);//cnwmc5 - 19/12/2012 - HAT 2198	// PAR #35895 // 3.8.2017 cnwma1 TFS #5209
	app.myTrxCA.trxCreateConsigneeConsignor(pxyConsigneeConsignor, realConsigneeConsignor,app.myPassport);

epilog
	delete pxyConsigneeConsignor;
	delete pxyConsigneeConsignorGroup;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createTestCountryPortData" id="8183bfd6-c0b8-4149-8545-0da4124d12d5">
        <source>createTestCountryPortData();
// ---------------------------------------------------------------------------
// Created:     10 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyCountry,
	realCountry	: CM_Country;
	pxyPort,
	realPort	: CM_Port;
	pxyPortGroup,
	realPortGroup	: CM_PortGroup;
	intCountry : CMIF_Country;
begin

	create pxyCountry transient;
	create pxyPort transient;
	create pxyPortGroup transient;
	create intCountry transient;
	
	pxyCountry.setProxy('NZ', 'New Zealand', 'NZL', '554', false, null);
	intCountry.myProxyCountry := pxyCountry;
	app.myTrxCA.trxCreateCountry(intCountry, realCountry,app.myPassport);

	pxyPortGroup.setProxy('NZ', 'New Zealand', null);
	app.myTrxCA.trxCreatePortGroup(pxyPortGroup, realPortGroup,app.myPassport);

	pxyPort.setProxy('TRG', 'Tauranga', 'T', "TAR", Blue, realCountry, realPortGroup,null, false, true, false, false, false, false, false, false, false);
	app.myTrxCA.trxCreatePort(pxyPort, realPort,app.myPassport);

	pxyPort.setProxy('WLG', 'Wellington', 'T', 'WEL',Black, realCountry, realPortGroup,null, false, true, false, false, false, false, false, false, false);
	app.myTrxCA.trxCreatePort(pxyPort, realPort,app.myPassport);
	
	pxyPort.setProxy('AKL', 'Auckland', 'T', 'AKL', Black, realCountry, realPortGroup,null, false, true, false, false, false, false, false, false, false);
	app.myTrxCA.trxCreatePort(pxyPort, realPort,app.myPassport);


	// Aussie
	pxyCountry.setProxy('AU', 'Australia', 'AUS', '036', false, null);
	intCountry.myProxyCountry := pxyCountry;
	app.myTrxCA.trxCreateCountry(intCountry, realCountry,app.myPassport);

	pxyPortGroup.setProxy('AU', 'Australia', null);
	app.myTrxCA.trxCreatePortGroup(pxyPortGroup, realPortGroup,app.myPassport);

	pxyPort.setProxy('SYD', 'Sydney', 'T', 'SYD', Green, realCountry, realPortGroup,null, false, true, false, false, false, false, false, false, false);
	app.myTrxCA.trxCreatePort(pxyPort, realPort,app.myPassport);



	// USA
	pxyCountry.setProxy('US', 'United States of America', 'USA', '840', false, null);
	intCountry.myProxyCountry := pxyCountry;
	app.myTrxCA.trxCreateCountry(intCountry, realCountry,app.myPassport);

	pxyPortGroup.setProxy('US', 'United States of America',null);
	app.myTrxCA.trxCreatePortGroup(pxyPortGroup, realPortGroup,app.myPassport);

	pxyPort.setProxy('VAN', 'Vancouver', 'V', "VAN", Red, realCountry, realPortGroup,null, false, true, false, false, false, false, false, false, false);
	app.myTrxCA.trxCreatePort(pxyPort, realPort,app.myPassport);



	// Japan
	pxyCountry.setProxy('JP', 'Japan', 'JPN', '392', false, null);
	intCountry.myProxyCountry := pxyCountry;
	app.myTrxCA.trxCreateCountry(intCountry, realCountry,app.myPassport);

	pxyPortGroup.setProxy('JP', 'Japan',null);
	app.myTrxCA.trxCreatePortGroup(pxyPortGroup, realPortGroup,app.myPassport);

	pxyPort.setProxy('UKB', 'Kobe', 'K', 'KBE', Red, realCountry, realPortGroup,null, false, true, false, false, false, false, false, false, false);
	app.myTrxCA.trxCreatePort(pxyPort, realPort,app.myPassport);

	
epilog
	delete pxyCountry;
	delete pxyPort;
	delete pxyPortGroup;
	delete intCountry;
	
end;</source>
    </JadeMethod>
