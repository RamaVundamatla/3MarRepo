    <JadeMethod name="populateStopsTasks" id="ef93bab9-41de-4b15-bb9a-1451324203ad">
        <source>populateStopsTasks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	documentActions : CM_DocumentActions;
	stop : CM_StopsTable;
	task : CM_ToDoTaskDesc;
	str : String;
	
	allStops : ObjectArray;
	allTasks : ObjectArray;
	obj : Object;

begin

	create allStops transient;
	create allTasks transient;

	self.cmbStops.clear();
	self.cmbTasks.clear();
	self.tblCargoStops.rows := 1;
	self.tblCargoTasks.rows := 1;
	
	if self.allDocumentActions.isEmpty then
		return;
	endif;
	
	foreach obj in self.allDocumentActions do
	
		documentActions := obj.CM_DocumentActions;

		foreach stop in documentActions.allStopTablesToAdd do
			if allStops.includes( stop ) then
				continue;
			endif;
			self.cmbStops.itemObject[self.cmbStops.addItem( stop.shortHeading )] := stop;
			allStops.add( stop );
		endforeach;
		
		foreach task in documentActions.allTaskDescsToAdd do
			if allTasks.includes( task ) then
				continue;
			endif;
			str := task.shortDescription;
			if not task.allResourceTypes.isEmpty then
				str := str &amp; " (" &amp; app.getErrorString(Uses_resources) &amp; ")";
			endif;
			self.cmbTasks.itemObject[self.cmbTasks.addItem( str )] := task;
			allTasks.add( task );
		endforeach;
	
	endforeach;
	
	if self.cmbStops.listCount &gt; 0 then
		self.cmbStops.addItemAt( app.getErrorString(AllStops), 1 );
		self.cmbStops.listIndex := 1;
		self.cmbStops.click( self.cmbStops);
	endif;
	
	if self.cmbTasks.listCount &gt; 0 then
		self.cmbTasks.addItemAt( app.getErrorString(AllTasks), 1 );
		self.cmbTasks.listIndex := 1;
		self.cmbTasks.click( self.cmbTasks);
	endif;

epilog

	self.shtStops.enabled := self.cmbStops.listCount &gt; 0;
	self.shtTasks.enabled := self.cmbTasks.listCount &gt; 0;
	
	delete allStops;
	delete allTasks;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="b7e6f72c-6318-41eb-8766-3d686d1b25c4">
        <source>populateTable( _table : Table input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/09/2016	cnwndl1	Initial creation	TFS 2647 / 2001
29/09/2016	cnwdap1	TFS 2653 Bookings and Tasks/Stops
30 Nov 2016	NDL	TFS 2967 - add more doc actions stuff
*/

vars

	documentActions : CM_DocumentActions;
	stop : CM_StopsTable;
	task : CM_ToDoTaskDesc;
	heading : String;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	tiIdArray : StringArray;
	index : Integer;
	requiresResource : Boolean;
	obj : Object;
	doLocCheck : Boolean;
	lc : CM_LocationsController;
	
	user : CM_User;							// TFS 2653
	disableItem : Boolean;					// TFS 2653

begin
	user := app.getMyUser;					// TFS 2653
	
	if self.myMobileGenericAgent.myLocationsController &lt;&gt; null then
		//We have come from "MOB_HHBRLocLoaderAllCargo", we only want to show items on this truck
		if self.getSessionAgent.peekAtPreviousForm.name = "MOB_HHBRLocLoaderAllCargo" then
			doLocCheck := self.myMobileGenericAgent.myLocationsController.isVehicle and self.myMobileGenericAgent.stringField1 = "shtOnTruck";
			if doLocCheck then
				lc := self.myMobileGenericAgent.myLocationsController;
			endif;
		endif;
	endif;

	if self.allDocumentActions.isEmpty then
		_table.columns := 1;
		_table.setCellText(1,1, app.getErrorString(Action_declar_stops_tasks_proc) );
		return;
	endif;

	if _table = self.tblCargoStops then
		self.tblCargoStops.clear;
		if self.cmbStops.listCount &lt; 1 then
			_table.columns := 1;
			_table.setCellText(1,1,app.getErrorString(Stop_selected_process) );
			return;
		endif;
		if self.cmbStops.listIndex &gt; 0 then
			stop := self.cmbStops.itemObject[ self.cmbStops.listIndex ].CM_StopsTable;
		endif;
		
		
	elseif _table = self.tblCargoTasks then
		self.tblCargoTasks.clear;
		if self.cmbTasks.listCount &lt; 1 then
			_table.columns := 1;
			_table.setCellText(1,1,app.getErrorString(Task_selected_process) );
			return;
		endif;
		if self.cmbTasks.listIndex &gt; 0 then
			task := self.cmbTasks.itemObject[ self.cmbTasks.listIndex ].CM_ToDoTaskDesc;
		endif;
		
		
	endif;
	
	//05 Oct 2016	NDL	TFS 2001 / 2792
	if _table = self.tblCargoStops then
		_table.columns := 6;
	elseif _table = self.tblCargoTasks then
		_table.columns := 7;
	endif;
	
	_table.fixedColumns := 1;
	_table.rows := 1;
	_table.fixedRows := 1;
	heading :=  "" &amp; Tab &amp; app.getErrorString(Select) &amp; Tab &amp; app.getErrorString(Cargo_group) &amp; Tab &amp; app.getErrorString(CargoId) &amp; Tab &amp; app.getErrorString(Quantity_complete) &amp; Tab &amp; app.getErrorString(Outstanding_total);
	if _table = self.tblCargoTasks then	//05 Oct 2016	NDL	TFS 2001 / 2792
		heading :=  heading &amp; Tab &amp; app.getErrorString(Remarks);
	endif;
	_table.setCellText(1,1,heading);
	
	create tiArray transient;
	create tiIdArray transient;
	
	if stop &lt;&gt; null or task &lt;&gt; null then
		// list just one stop or just one task
		foreach obj in self.allDocumentActions do
	
			documentActions := obj.CM_DocumentActions;
			
			documentActions.getTIsToBeCompleted( tiArray, stop, task, lc );

			foreach ti in tiArray do
				if self.myTrackedItem &lt;&gt; null then
					if self.myTrackedItem.id &lt;&gt; ti.id then
						//only interested in this one.
						continue;
					endif;
				endif;
				if ti.hasBeenMerged then
					continue;
				endif;
				if not ti.isOnSite then // TFS 4052 make it the same as CMUI_DocumentActionMaint::populateTblCargoIds
					continue; // TFS 4052 attempt to get the completed transaction on the correct cargo item
				endif;
				if doLocCheck then
					if ti.myPrimaryActualLocation &lt;&gt; lc then
						continue;
					endif;
				endif;
				if tiIdArray.includes(ti.id) then
					continue;
				endif;
				tiIdArray.add(ti.id);
				disableItem := false;														// TFS 2653
				if stop &lt;&gt; null then														// TFS 2653
					disableItem := not user.canUpdateStop(self.myTerminal, stop);			// TFS 2653
				elseif task &lt;&gt; null then													// TFS 2653
					disableItem := not user.canCompleteTodoTask(self.myTerminal, task);		// TFS 2653
				endif;																		// TFS 2653
				self.addTableItem( documentActions, _table, stop, task, ti, disableItem );	// TFS 2653
			endforeach;
		
		endforeach;
		
	else
	
		if _table = self.tblCargoStops then
			// listing All stops
			foreach index in 1 to self.cmbStops.listCount do
				tiIdArray.clear();
				stop := self.cmbStops.itemObject[ index ].CM_StopsTable;
				if stop &lt;&gt; null then
				
					foreach obj in self.allDocumentActions do
	
						documentActions := obj.CM_DocumentActions;
				
						documentActions.getTIsToBeCompleted( tiArray, stop, null, lc );
						foreach ti in tiArray do
							if self.myTrackedItem &lt;&gt; null then
								if self.myTrackedItem.id &lt;&gt; ti.id then
									//only interested in this one.
									continue;
								endif;
							endif;
							if ti.hasBeenMerged then
								continue;
							endif;
							if not ti.isOnSite then // TFS 4052 make it the same as CMUI_DocumentActionMaint::populateTblCargoIds
								continue; // TFS 4052 attempt to get the completed transaction on the correct cargo item
							endif;
							if doLocCheck then
								if ti.myPrimaryActualLocation &lt;&gt; lc then
									continue;
								endif;
							endif;
							if tiIdArray.includes(ti.id) then
								continue;
							endif;
							tiIdArray.add(ti.id);
							disableItem := not user.canUpdateStop(self.myTerminal, stop);				// TFS 2653
							self.addTableItem( documentActions, _table, stop, null, ti, disableItem );	// TFS 2653
						endforeach;
					
					endforeach;
					
				endif;
			endforeach;
		
		elseif _table = self.tblCargoTasks then
			// listing All tasks
			foreach index in 1 to self.cmbTasks.listCount do
				tiIdArray.clear();
				task := self.cmbTasks.itemObject[ index ].CM_ToDoTaskDesc;
				if task &lt;&gt; null then
					requiresResource := not task.allResourceTypes.isEmpty;
					
					foreach obj in self.allDocumentActions do
	
						documentActions := obj.CM_DocumentActions;
						
						documentActions.getTIsToBeCompleted( tiArray, null, task, lc );
						foreach ti in tiArray do
							if self.myTrackedItem &lt;&gt; null then
								if self.myTrackedItem.id &lt;&gt; ti.id then
									//only interested in this one.
									continue;
								endif;
							endif;
							if not ti.isOnSite then // TFS 4052 make it the same as CMUI_DocumentActionMaint::populateTblCargoIds
								continue; // TFS 4052 attempt to get the completed transaction on the correct cargo item
							endif;
							if ti.hasBeenMerged then
								continue;
							endif;
							if doLocCheck then
								if ti.myPrimaryActualLocation &lt;&gt; lc then
									continue;
								endif;
							endif;
							if tiIdArray.includes(ti.id) then
								continue;
							endif;
							tiIdArray.add(ti.id);
							disableItem := not user.canCompleteTodoTask(self.myTerminal, task);								// TFS 2653
							self.addTableItem( documentActions, _table, null, task, ti, requiresResource or disableItem );	// TFS 2653
						endforeach;
					
					endforeach;
					
				endif;
			endforeach;
		
		endif;
		
	endif;
	
	if not self.cargoGroupEnabled then
		_table.accessColumn( 3 ).visible := false;
	endif;
	
epilog

	delete tiArray;
	delete tiIdArray;

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="19ebf477-aef8-4b0a-aae2-1b2b6eb8008a">
        <updating/>
        <source>setupControls()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2016	cnwndl1	Initial creation

*/

vars

	parentObj : CM_Object;

begin

	self.doResizeControls(true);
	
	self.btnSelect.caption := app.getErrorString( SHP_UnSelect_Al ); // app.getErrorString(SelectAll)
	
	self.populateStopsTasks();
	
	self.populateTable( self.tblCargoStops );
	self.populateTable( self.tblCargoTasks );
	
	//28 Nov 2016	NDL	TFS 2962
	if self.tblCargoStops.rows = self.tblCargoStops.fixedRows then
		self.fldMain.topSheet := self.shtTasks;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bc68c5a8-9ae6-40a1-908a-5c87002ff066">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	resDetail : CM_ReserveDetail;
	docAction : CM_DocumentActions;
	bookingItem : CM_BookingRefItem;

begin

	foreach resDetail in self.myMobileGenericAgent.allReserveDetails do
		docAction := resDetail.myReserveDetailActions;
		if docAction &lt;&gt; null then
			self.allDocumentActions.add( docAction );
		endif;
	endforeach;
	
	foreach bookingItem in self.myMobileGenericAgent.allBookingRefItems do
		docAction := bookingItem.myBookingRefItemActions;
		if docAction &lt;&gt; null then
			self.allDocumentActions.add( docAction );
		endif;
	endforeach;
	
	self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;
	
	self.cargoGroupEnabled := app.isCargoGroupEnabled;

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Back), null, null, null );
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2409391e-ac77-4feb-8769-309bcbfae66f">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 December 2016 09:01:04.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021331, locale);
	btnSelect.translateCaption(Xlat_0021625, locale);
	shtStops.translateCaption(Xlat_0021332, locale);
	shtTasks.translateCaption(Xlat_0021333, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="unload" id="cdf6dde8-91b7-4e75-8a7a-b1fda51e0283">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

begin

	self.allNewProxyResourceTypeUsages.purge();

epilog

end;</source>
    </JadeMethod>
</GUIClass>
