    <JadeMethod name="setupForm" id="5c9bc2ac-590a-45c1-a059-e92b0d46b627">
        <updating/>
        <source>setupForm() updating;
//27 August 2009	cnwml2
//10 June	2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
//22/06/2023		navkc1	Bug 58784: EUP - Inv Maint Find Items use Debtor for Operators
//24 Jul 2025  		navhn30 MTN-35315: MTN | Pagination - Work Order Maintenance
vars
	entTableDef : EntTableDef;
	emptyPlaceHolder : CM_TIArray;
begin
	inheritMethod();
	self.btnSearchResults.visible := false;
	self.handleMenusForModalDisplay();
	
	if global.isValidObject(self.myParentForm) then 				//+cnwml2 PAR21405
		self.myParentForm.enabled := false;
	endif;
		
	self.initFieldsForEntDefName(ETDef_CargoSearch, true);
	
	self.frmEntTblControl.top := 5;
	
	//26/03/2010 cnwdz2	par23276
	self.frmEntTblControl.width := self.width;
	
	self.jdcMainResults.top:=self.frmEntTblControl.top + self.frmEntTblControl.height + 5;
	self.jdcResults.ignoreSkin:=true;
	self.jdcSelected.ignoreSkin:=true;
	self.frmResults.width:=self.jdcResults.clientWidth;
	self.frmResults.height:=self.jdcResults.clientHeight;
	self.frmSelectedItems.width:=self.jdcSelected.clientWidth;
	self.frmSelectedItems.height:=self.jdcSelected.clientHeight;
	
	self.minimumHeight := self.frmEntTblControl.height.Integer + self.frmResults.height.Integer + self.frmSelectedItems.height.Integer + self.frmButtons.height.Integer;
	self.height := self.minimumHeight.max(650);
	self.jdcMainResults.height:=self.height - self.jdcMainResults.top - self.frmButtons.height;
	self.minimumWidth := 1000;

	
	
	//+cnwml2 PAR21663
//	entTableDef := app.myController.getEntTableDef(ETDef_CargoSearchForm);
	entTableDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);	//11 Jun 2021	NDL	TFS 51338
	self.tblResults.setTblDataEntRowsFromDef(entTableDef);
	self.tblResults.setMyDataClass(CM_TrackedItem);
	self.tblResults.fixedColumns := 0;
	self.tblResults.fixedRows := 1;
	self.tblResults.selectMode := CM_DataTable.SelectMode_FixedRow;
	self.tblResults.selectionType := CM_DataTable.SelectionType_Row;
	self.tblResults.multiSelect := CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(self.tblResults);
	self.tblResults.clearAllData();

	//+cnwml2 PAR21663
//	entTableDef := app.myController.getEntTableDef(ETDef_CargoSearchForm);
	entTableDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);	//11 Jun 2021	NDL	TFS 51338
	self.tblSelectedItems.setTblDataEntRowsFromDef(entTableDef);
	self.tblSelectedItems.setMyDataClass(CM_TrackedItem);
	self.tblSelectedItems.fixedColumns := 0;
	self.tblSelectedItems.fixedRows := 1;
	self.tblSelectedItems.selectMode := CM_DataTable.SelectMode_FixedRow;
	self.tblSelectedItems.selectionType := CM_DataTable.SelectionType_Row;
	self.tblSelectedItems.multiSelect := CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(self.tblSelectedItems);
	self.tblSelectedItems.clearAllData();
	
	if app.myRoot.isPaginated then		// doing this to make results table enabled for pagination by opening form 
		create emptyPlaceHolder transient;
		self.tblResults.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, emptyPlaceHolder, true);	 //24.07.2025	navhn30  MTN-35315
	endif;
		
	// 10/06/2022 navcs2 52351
	cmbBookings.visible := false;
	cmbReleases.visible := false;

	self.loadSelectedTITable();
	
	self.loadCombos();
	
	self.setDetails();
	self.doPopCmbOperatorFromDebtor(self.myDebtor); 			//22/06/2023	navkc1	Bug 58784
	self.btnClear.left := self.btnSearchResults.left;			// Note: only in here until the search Results button is in use.
	self.chkShowAllOperator.left += self.btnSearchResults.width; //22/06/2023	navkc1	Bug 58784
	

	
epilog
	delete emptyPlaceHolder;
end;</source>
    </JadeMethod>
    <JadeMethod name="tblResults_contextMenu" id="162a20e9-1c8b-448d-8218-77a4cb7a3e6f">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//19 February 2010	cnwml2
//+cnwml2 PAR21663

vars
	x1, y1				: Real;

begin
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := conwin;
	
	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.mnuEnquire.userObject := self.tblResults;
	self.popupMenu(self.mnuMainContext, x1.Integer, y1.Integer);
	return false;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
