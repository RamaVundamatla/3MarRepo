    <JadeMethod name="mnuExportCred2File_click" id="6845a064-212a-4621-8c76-68023e775811">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuExportCred2File_click(menuItem: MenuItem input) updating;
// TFS 985
vars
	row : Integer;
	cash : CM_Cash;

begin

	//09 Apr 2018	NDL	TFS 37365 - Allow multi select
	foreach row in 1 to  self.tblCash.rows do
		if self.tblCash.accessRow(row).selected then
			cash :=  self.tblCash.accessRow(row).itemObject.CM_Cash;
			if cash = null or not cash.isKindOf(CM_CashCredit) then
				continue;
			endif;
			self.doExport(cash, true);
			self.doRefreshExportCell(row);
		endif;
	endforeach;

	/*
	row := self.tblCash.row;
	if row &lt;= self.tblCash.fixedRows then
		return;
	endif;
	if row &gt; self.tblCash.rows then
		return;
	endif;

	cash :=  self.tblCash.accessRow(row).itemObject.CM_Cash;
	if cash = null then
		return;
	endif;
	
	self.doExport(cash, true);
		//epr tfs 1754 1/4/16
	self.doRefreshExportCell(row);
	*/

end;
</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuExportCredit_click" id="468b9098-58f9-4f5b-a4e5-44d71a96f0b8">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuExportCredit_click(menuItem: MenuItem input) updating;
// TFS 985
vars
	row : Integer;
	cash : CM_Cash;

begin

	//09 Apr 2018	NDL	TFS 37365 - Allow multi select
	foreach row in 1 to  self.tblCash.rows do
		if self.tblCash.accessRow(row).selected then
			cash :=  self.tblCash.accessRow(row).itemObject.CM_Cash;
			if cash = null or not cash.isKindOf(CM_CashCredit) then
				continue;
			endif;
			self.doExport(cash, false);
			self.doRefreshExportCell(row);
		endif;
	endforeach;
	
	/*
	row := self.tblCash.row;
	if row &lt;= self.tblCash.fixedRows then
		return;
	endif;
	if row &gt; self.tblCash.rows then
		return;
	endif;

	cash :=  self.tblCash.accessRow(row).itemObject.CM_Cash;
	if cash = null then
		return;
	endif;
	
	self.doExport(cash, false);
		//epr tfs 1754 1/4/16
	self.doRefreshExportCell(row);
	
	*/

end;
</source>
