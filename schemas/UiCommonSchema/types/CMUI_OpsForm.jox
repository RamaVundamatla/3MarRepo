    <JadeMethod name="doEdit" id="988e5a30-8b54-434a-9857-5cf96ddeda13">
        <updating/>
        <source>doEdit() updating;
//--------------------------------------------------------------
//Created: 15 May 2002 By: cnwgd1
//--------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	bol 	: CM_BOL;
	job 	: CM_Job;
	request : CM_Request;
	tis : CM_TIArray;
	
begin
	if self.myCurrentWLE = null then
		//app.msgBox($SelectItem,'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		self.myAssistant.showCargoEnquiryForm(null, self.myMasterMenuAction, false, false);
		return;	
	endif;
	
	job := self.myCurrentWLE.job;
	
	request := self.myCurrentWLE.myRequest;
	
	if request &lt;&gt; null then
		if request.isKindOf(CM_BOLYardRequest) then
			bol := request.CM_BOLYardRequest.myBOL;
		elseif request.isKindOf(CM_BOLToDoRequest) then
			bol := request.CM_BOLToDoRequest.myBOL;
		endif;
	endif;

	if bol &lt;&gt; null then
		if job.status = JOB_COMPLETE then
			app.msgBox('Cannot edit as Job ' &amp; job.jobId &amp; ' is complete.','Job Complete', MsgBox_Information_Icon + MsgBox_OK_Only);
			return;	
		endif;
	
		if self.myCurrentWLE.allRTQueueEntries.isEmpty = false then
			app.msgBox('Cannot edit as Job Entry' &amp; job.jobId &amp; ' is queued to move.','Job Queue', MsgBox_Information_Icon + MsgBox_OK_Only);
			return;	
		endif;	
		
		self.myAssistant.showDocketMaintForm(bol, self.myMasterMenuAction, true, true);
	elseif self.myCurrentTrackedItem &lt;&gt; null then
		create tis transient;
		self.getAllTIsInTableSelected(tis);
		if tis.size &lt;=1 then
			self.myAssistant.showCargoEnquiryForm(self.myCurrentTrackedItem, self.myMasterMenuAction, true, true);
		else
			self.myAssistant.showCargoEnquiryForTIs(self.myCurrentTrackedItem, tis, self.myMasterMenuAction,  true);
		endif;
		
	else
		app.msgBox('Job Entry ' &amp; job.jobId &amp; ' does not have an associated Cargo Item.','No Item to Edit.', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;	
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doHideShowTreeView" id="7161ee52-4487-435c-a222-d020880e5fd8">
        <source>doHideShowTreeView();
//--------------------------------------------------------------
