    <JadeMethod name="getMatchingCriteriaAsString" id="165548ee-9bfa-48d9-862b-4ed2c4cae5d3">
        <source>getMatchingCriteriaAsString(_delim : String;_ycCriteriaType :Integer): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2023	navma1 ChangeRequest 60527: EUP | Mobile DD - [BackEnd] Truck Jobs - Receive Jobs
*/

vars
	objSet : ObjectSet;
	str	   : String;
begin
	create objSet transient;
	
	if self.isKindOf(CM_ReserveSelection) then
		self.CM_ReserveSelection.getMatchingCriteriaObjects(objSet, _ycCriteriaType);
	endif;
	
	if objSet.isEmpty then
		return null;
	endif;
	
	if _ycCriteriaType = YACriteriaType_Commodity then 
		str := objSet.listString(_delim,CM_Commodity::code.name);
	elseif _ycCriteriaType = YACriteriaType_ImexStatus then 
		str :=  objSet.listString(_delim,CM_IMEXStatus::abbreviation.name);
	elseif _ycCriteriaType = YACriteriaType_SpecialLift then
		str :=  objSet.listString(_delim,CM_SpecialLift::code.name);
	elseif _ycCriteriaType = YACriteriaType_SpecialStow then 
		str :=  objSet.listString(_delim,CM_SpecialStow::code.name);
	endif;
	return str;
epilog
	delete objSet;
end;</source>
        <Parameter name="_delim" type="String"/>
        <Parameter name="_ycCriteriaType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="8c605797-5eb3-44fc-af56-06cc362b9617">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2019	jlger1	Initial creation
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
*/

vars
	measure	: CM_MeasurementType;

	value	: String;
	volume 	: Decimal [22,10];
begin
	//epr TFS 41398 20/2/19
	if _attrName = ETRow_TotalWeight or  _attrName = ETRow_Weight or _attrName = ETRow_WeightRequested then	//31 May 2016	NDL	TFS 2009
		if (self.getCargoType &lt;&gt; null and self.getCargoType.isTrackByWeight) or (self.weightRequested &gt; 0 and self.byTypeByWeight) then		// 6/12/2023 navcs2 ChangeRequest 57537
			measure := self.getCargoType.myWeightMeasurementType;
			if measure = null then
				measure := app.getDefaultMeasurementForType(Type_Weight);
			endif;
			value := app.convertMeasurementForDisplay(measure.shortName, self.weightRequested);
			return value &amp; Space &amp; measure.shortName;
		else	
			//jlier1 TFS 53678 17/6/22
			if self.myReserveHeader &lt;&gt; null and self.myReserveHeader.context = RelReqContext_CargoGroupReview then
				measure := app.getDefaultMeasurementForType(Type_Weight);
				value := app.convertMeasurementForDisplay(measure.shortName, self.weightRequested);
				return value &amp; Space &amp; measure.shortName;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_TotalVolume or _attrName = ETRow_VolumeRequested then
		if self.getCargoType &lt;&gt; null and self.getDensity &lt;&gt; null  and self.getCargoType.isTrackByVolume then
			measure := self.getCargoType.myVolumeMeasurementType;
			if measure = null then
				measure := app.getDefaultMeasurementForType(Type_Volume);
			endif;
			volume := self.weightRequested / self.getDensity;
			value := app.convertMeasurementForDisplay(measure.shortName, volume);
			return value &amp; Space &amp; measure.shortName;
		endif;
		return null;
	endif;
	
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
