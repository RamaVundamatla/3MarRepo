    <JadeMethod name="getLocationsForSpan" id="a802d868-555f-4d75-84c8-bac3ec2e0d8a">
        <source>getLocationsForSpan(_vertSpan, _horzSpan, depthSpan : Integer; _lcDict : CM_LCSet input);
/*
----------   ----------  --------------------------------------------------
Created:	22 November 2006 By cnwth2

Purpose:	return slots surrounding self that will need to be checked for 
			hazardous segregation rule violation
			
			vertical span = accross rows
			horizontal span = accross columns
			depth span = N/A at this time

Changed On   Changed By  Reason

23 July 2015	NDL	Par 36568	- remove use of LC collection with 'myTerminalArea' as key, replace with LC Set
	
----------   ----------  --------------------------------------------------
*/
vars
	gridArea					: CM_GridArea;
	gridController				: CM_GridController;
	
	heightIdx,
	columnIdx,
	rowIdx,

	probeHorzMin,
	probeVertMin,
	probeHorzMax,
	probeVertMax				: Integer;
	wholeStack					: Boolean;
	segCond						: CM_SegregationCondition;
	doLog						: Boolean;
begin
	gridArea := self.myGridArea;
	
	//get probe perimeter values
	probeHorzMin 	:= (self.myGridColumn.column - _horzSpan).max(1);
	probeHorzMax 	:= (self.myGridColumn.column + _horzSpan).min(gridArea.allGridColumns.size);
	probeVertMin 	:= (self.myGridRow.row - _vertSpan).max(1);
	probeVertMax 	:= (self.myGridRow.row + _vertSpan).min(gridArea.allGridRows.size);
	
	doLog := app.myPassport.myActivityCapture.captureDiagnositcs;
	if doLog then
		app.myPassport.myActivityCapture.logDiagnostic('GetLocationForSpan - from ' &amp; self.getFullId &amp; CrLf &amp;
													'probeHorzMin=' &amp; probeHorzMin.String &amp; ', probeHorzMax=' &amp; probeHorzMax.String &amp; CrLf &amp;
													'probeVertMin=' &amp; probeVertMin.String &amp; ', probeVertMax=' &amp; probeVertMax.String); 
	endif;
	
	foreach columnIdx in probeHorzMin to probeHorzMax do
		foreach rowIdx in probeVertMin to probeVertMax do
			gridController := gridArea.allGridControllersByRowColumn[rowIdx, columnIdx];
			if gridController = null then
				continue;
			endif;
			
			if (not _lcDict.includes(gridController)) then
				if doLog then
					app.myPassport.myActivityCapture.logDiagnostic('Adding gridController for span :' &amp; gridController.getFullId());
				endif;
				
				_lcDict.add(gridController);
			endif;
		endforeach;
	endforeach;
	
end;


</source>
        <Parameter name="_vertSpan" type="Integer"/>
        <Parameter name="_horzSpan" type="Integer"/>
        <Parameter name="depthSpan" type="Integer"/>
        <Parameter name="_lcDict" type="CM_LCSet" usage="input"/>
    </JadeMethod>
