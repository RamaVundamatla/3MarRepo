    <JadeMethod name="calculateRounding" id="15879859-16ba-499e-b122-011416acbecf">
        <updating/>
        <source>calculateRounding() : Decimal updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	decimalAmount,
	tempRoundAmount,
	roundAmount			: Real;
	roundingType		: Integer;
begin
	if not self.shouldRound() then
		return null;
	endif;
	
	self.roundingDifference := 0;

	roundingType := self.myTerminal.getCashRoundingType( self.myPxyCashReceipt.myBank );
	roundAmount  := self.myTerminal.getCashRoundUpAmount( self.myPxyCashReceipt.myBank );
	
	if self.cashRequiredToClearCharges &gt; 0 then
		decimalAmount := self.cashRequiredToClearCharges - self.cashRequiredToClearCharges.Integer;
		if decimalAmount &gt; 0 and
		   roundAmount &lt;&gt; 0 then
			tempRoundAmount := roundAmount;
			while true do
				if roundingType = RoundingType_Up then
					if decimalAmount &gt; tempRoundAmount then
						tempRoundAmount := tempRoundAmount + roundAmount;
						continue;
					endif;
				elseif roundingType = RoundingType_Down then
					if decimalAmount &lt; tempRoundAmount then
						tempRoundAmount := tempRoundAmount - roundAmount;
						continue;
					endif;
				endif;
				break;
			endwhile;
		endif;
		
		self.roundingDifference         := tempRoundAmount - decimalAmount;
		self.cashRequiredToClearCharges := self.cashRequiredToClearCharges + self.roundingDifference;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="delete" id="15349f22-b61b-45aa-ab3e-75b9f6a2a417">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars

begin
	self.allAgents.purge();
	if self.myPxyCashReceipt &lt;&gt; null then
		self.myPxyCashReceipt.allProformaDetails.purge();
	endif;
	delete self.myPxyCashReceipt;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doApplyAgentToCargo" id="fa6960c3-a078-435b-9b9f-858df665c48a">
        <source>doApplyAgentToCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1  CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	allTIsToApply	: CM_TISet;
	tiChildren		: CM_TISet;
	allChildren		: CM_TISet;
	pxyTISet		: CM_TISet;
	child,
	pxyChild,
	pxyTI,
	ti				: CM_TrackedItem;
	agent			: CM_Object;
	logMessage		: String;
	controller	    : CMIF_TiTransactionResync;
	trans			: CM_TITransaction;
	canLogExtra		: Boolean;	//28.02.2025 navah1	#34141
	agentCode : String;
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	create tiChildren transient;
	create allTIsToApply transient;
	create allChildren transient;
	create pxyTISet transient;
	
	foreach ti in self.allTis do
		tiChildren.clear();
		ti.getAllNestedChildren(tiChildren);
		foreach child in tiChildren do
			allChildren.add(child);
		endforeach;
	endforeach;
	
	agent := self.myDebtorAgent;
	
	foreach ti in self.allTis do
		if not self.shouldApplyAgent(ti, agent) then
			continue;
		endif;
		
		if allChildren.includes(ti) then
			continue;
		endif;
		
		if pxyTISet &lt;&gt; null then
			pxyTISet.purge();
		endif;
		pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
		pxyTISet.add(pxyTI);
		if self.myCashDebtorType.code = "SDT2" then
			pxyTI.zSetPxyConsignee(agent.CM_ConsigneeConsignor.code);
			logMessage := "Consignee " &amp; pxyTI.consignee;
		elseif self.myCashDebtorType.code = "SDT3" then
			pxyTI.zSetPxyConsignor(agent.CM_ConsigneeConsignor.code);
			logMessage := "Consignor " &amp; pxyTI.consignor;
		elseif self.myCashDebtorType.code = "SDT4" then
			pxyTI.zSetPxyOperator(agent.CM_Operator);
			logMessage := "Operator " &amp; pxyTI.operatorCode;
		elseif self.myCashDebtorType.code = "SDT6" then
			pxyTI.zSetPxyCustomsAgent(agent.CM_CustomsAgent);
			logMessage := "Customs agent " &amp; pxyTI.myCustomsAgent.code;
		elseif self.myCashDebtorType.code = "SDT7" then
			pxyTI.zSetPxyFreightFowarderCode(agent.CM_ConsigneeConsignor.code);
			logMessage := "Freight forwarder " &amp; pxyTI.freightForwarderCode;
		// ### JIRA 33765 07JAN2025 NAVAB1
		elseif self.myCashDebtorType.code = "SDT1" then
			pxyTI.setOperatorCode(agent.CM_Operator.code, app.myPassport);
			logMessage := "Cargo Operator " &amp; pxyTI.operatorCode;
		endif;
		//  set the child agent as well
		foreach pxyChild in pxyTI.allChildren discreteLock do
			if self.myCashDebtorType.code = "SDT2" then
				pxyChild.zSetPxyConsignee(agent.CM_ConsigneeConsignor.code);
			elseif self.myCashDebtorType.code = "SDT3" then
				pxyChild.zSetPxyConsignor(agent.CM_ConsigneeConsignor.code);
			elseif self.myCashDebtorType.code = "SDT6" then
				pxyChild.zSetPxyCustomsAgent(agent.CM_CustomsAgent);
			elseif self.myCashDebtorType.code = "SDT7" then
				pxyChild.zSetPxyFreightFowarderCode(agent.CM_ConsigneeConsignor.code);
			// ### JIRA 33765 07JAN2025 NAVAB1
			elseif self.myCashDebtorType.code = "SDT1" then
				pxyChild.setOperatorCode(agent.CM_Operator.code, app.myPassport);
			endif;
		endforeach;
		
		//if self.isFromAPI then
			app.myTrxUA.trxUpdateTrackedItems(pxyTISet, TI_UPDMODE_NORMAL, null, app.myPassport);
			
			if app.myPassport.hasErrors() then
				return;
			endif;
		//endif;
	endforeach;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog("** " &amp; logMessage &amp; " applied to selected cargo **", LogTRACE.String);
	endif;
	
	foreach ti in self.allTis do
		create controller transient;
		controller.myTrackedItem := ti;
		controller.force := true;
		if self.myCashDebtorType.code = "SDT2" then
			controller.updateConsignee := true;
			agentCode := agent.CM_ConsigneeConsignor.code;  // ### JIRA 35502 18JUL2025 NAVAB1
		elseif self.myCashDebtorType.code = "SDT3" then
			controller.updateConsignor := true;
			agentCode := agent.CM_ConsigneeConsignor.code;  // ### JIRA 35502 18JUL2025 NAVAB1
		elseif self.myCashDebtorType.code = "SDT6" then
			controller.updateCustomsAgent := true;
			agentCode := agent.CM_CustomsAgent.code;  // ### JIRA 35502 18JUL2025 NAVAB1
		elseif self.myCashDebtorType.code = "SDT7" then
			controller.updateFreightForwarder := true;
			agentCode := agent.CM_ConsigneeConsignor.code;  // ### JIRA 35502 18JUL2025 NAVAB1
		// ### JIRA 33765 07JAN2025 NAVAB1
		elseif self.myCashDebtorType.code = "SDT1" then
			controller.updateOperator := true;
			agentCode := agent.CM_Operator.code;  // ### JIRA 35502 18JUL2025 NAVAB1
		endif;
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Re-evaluate transactions for " &amp; ti.id, LogTRACE.String);
			app.invLog(" ", LogINFO.String);
		endif;
		foreach trans in ti.allTransactions do
			if self.isTransNeedReSync(trans, agentCode, self.myCashDebtorType) then // ### JIRA 35557 24JUL2025 NAVAB1
				controller.allTransactions.add(trans);
			 endif;
		endforeach;
		
		//if self.isFromAPI then
			app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
			
			if app.myPassport.hasErrors() then
				return;
			endif;
		//endif;
		delete controller;
	endforeach;
	
epilog
	delete tiChildren;
	delete allTIsToApply;
	delete allChildren;
	pxyTISet.purge();
	delete pxyTISet;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCalculate" id="86fa5654-a588-43a3-acd5-0fe64c41429c">
        <updating/>
        <source>doCalculate() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	terminal		: CM_Terminal;
	cashReceiptFound,
	realCashReceipt	: CM_CashReceipt;
	tmpController 	: CMIF_ProformaInvLinesForDebtor;
	isSameUser		: Boolean; //30/04/2025	navkc1 JIRA Bug MTN-34734
	allCashReceiptsFound : CM_CashReceiptSet; //30/04/2025	navkc1 JIRA Bug MTN-34734
begin
	
	terminal := self.myTerminal;

	if terminal = null or self.myDebtor = null then
		return;
	endif;
	
	create allCashReceiptsFound transient; //30/04/2025	navkc1 JIRA Bug MTN-34734
	
	//11/07/2024	navkc1 CR 64837 Task 64851 - Already has draft proforma
	// If the draft proforma combination is the same as current request from the same user, current draft to cancelled, detach from BGP, redo draft receipt
	// If the draft proforma combination doesnt match the current request,
	// i.e. from someone else, return the draft proforma and set isPaymentAllowed false.
	if self.createPersistDraftCashReceipt and self.hasDraftProforma(isSameUser, allCashReceiptsFound) then
		//07/01/2025	navkc1 JIRA Bug MTN-33764
		//cashReceiptFound := self.myNewCashReceipt; //30/04/2025	navkc1 JIRA Bug MTN-34734
		
		/*07/01/2025	navkc1 JIRA Bug MTN-33764
		Don't return, because the cash receipt found might already be finalized, and there's further charges to the cargo.
		We still want to allow user to pay for the extra charges
		//return;
		*/
		//30/04/2025	navkc1 JIRA Bug MTN-34734 return if validation failed
		if app.myPassport.hasErrors() then
			return;
		endif;
	endif;
	
	self.doApplyAgentToCargo();
	self.proformaGetProformas();
	self.proformaProxyCashReceipt();
	
	create tmpController transient;
	tmpController.proformaProxyCashPayments(self.myPxyCashReceipt, self.allAgents, true);
	
	self.proformaDisplayCashReceipt();
	
	// Compare the existing draft/hold receit with the Agent //30/04/2025	navkc1 JIRA Bug MTN-34734
	self.doCompareProformaAndExisting(self.myPxyCashReceipt, allCashReceiptsFound);
	
	// If all cash payments are discarded, nothing to be paid //30/04/2025	navkc1 JIRA Bug MTN-34734
	if self.myPxyCashReceipt.allCashPayments.isEmpty() then
		return;
	endif;
	
	//11/07/2024	navkc1 CR 64837 Task 64851 - We want to persist the cash receipt and create a BGP
	if not app.myPassport.hasErrors() and  self.createPersistDraftCashReceipt then
		// ### JIRA 35031 04JUN2025 NAVAB1		self.myPxyCashReceipt.setPaymentType(PaymentType_PrePay); // ### JIRA 35050 10JUN2025 NAVAB1 re issuing this
		// Here we persist the cash receipt. By setting the Status to Draft, it will use OID as the SequenceNumber
		self.doSaveCashPay(CM_CashReceipt.API_RECEIPT_DRAFT);
		
		realCashReceipt := self.myNewCashReceipt;
		
		// Something wrong with creating a persist draft cash receipt, return;
		if app.myPassport.hasErrors() or realCashReceipt = null then
			return;
		endif;
		
		//07/01/2025	navkc1 JIRA Bug MTN-33764 - If the cash receipt we found is not same with the one we currently have, it means that we have created a new one, allow the user to make payment
		//if cashReceiptFound = null or //30/04/2025	navkc1 JIRA Bug MTN-34734
			//cashReceiptFound &lt;&gt; self.myNewCashReceipt then
		if allCashReceiptsFound.isEmpty() or //30/04/2025	navkc1 JIRA Bug MTN-34734 - We didn't find any existing cash receipt, this must be new so allow payment
			not allCashReceiptsFound.includes(self.myNewCashReceipt) //30/04/2025	navkc1 JIRA Bug MTN-34734 - We found some cash receipt, the "new" one is not in the list, must be a new one so allow payment
			then 
			self.isPaymentAllowed := true;
		endif;
	endif;
	
epilog
	delete tmpController;
	delete allCashReceiptsFound; //30/04/2025	navkc1 JIRA Bug MTN-34734
end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeProformaStatusFromAPI" id="20d45ae6-ce20-4c9f-b8a1-d20d4d4f52f7">
        <updating/>
        <source>doChangeProformaStatusFromAPI() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64838 Task 64853: Jade - New Cash API putProformaStatus

*/

vars
	realCashReceipt,
	pxyCashReceipt	: CM_CashReceipt;
	newStatus	: Integer;
begin
	
	realCashReceipt := self.myNewCashReceipt;
	
	if realCashReceipt = null then
		return;
	endif;
	
	newStatus := self.nextStatusValue;
	
	beginLoad;
	pxyCashReceipt := realCashReceipt.pxyCreateUpdateProxy();
	endLoad;
	
	// Update External fields
	pxyCashReceipt.setExternalFields(self.externalReceiptNumber, self.externalFinancialId, self.externalRef1, self.externalTransaction, self.externalUserCode, self.remarks);
	// Update status
	app.myTrxUA.trxCashReceiptAPIUpdateStatus(pxyCashReceipt, newStatus, self.remarks, app.myPassport);
	
epilog
	delete pxyCashReceipt;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCompareProformaAndExisting" id="5d50ed85-7142-4acd-9266-ca44a44d1747">
        <updating/>
        <source>doCompareProformaAndExisting(_pxyCashReceiptFromAgent : CM_CashReceipt input; _allReceiptFound : CM_CashReceiptSet) updating;
/*

Purpose:			This method compares the cash payments calculated from the Agent with the existing cash receipts.
					If the cash payments from Agent are in the existing cash receipt that is on Hold/Draft, we discard them as they should get paid in the existing one.
					If it's not, it will proceed to create a new draft receipt for the cash payment that is not already in the existing cash receipts.
					
					For example
						Existing hold/draft cash receipt has
							Cargo 1
								Storage cash payment
								Release road cash payment
						
						Agent comes back with
							Cargo 1
								Storage cash payment				- This will be discarded
								Release road cash payment			- This will be discarded
								Additional charnges cash payment 	- This will remains
					
					_pxyCashReceiptFromAgent will gets updated
						If all cash payments from the agent are discarded, nothing to be paid.
						If there is cash payment remains, they will be created in new draft cash receipt

Parameters:			

Return Value:		

Date		Who		Reason
30/04/2025	navkc1 JIRA Bug MTN-34734: QTS | UAT - Hard stop for Cancelled Additional charges cash receipt.

*/

vars
	existingCashReceipt 	: CM_CashReceipt;
	cashPaymentAgent,
	cashPaymentExisting 	: CM_CashPayment; 
	allCashPaymentsAgent 	: CM_CashPaymentSet;
	invoiceLineAgent,
	invoiceLineExisting		: CM_InvoiceLine;
	proformaDetailsAgent,
	proformaDetailsExisting	: CM_ProformaDetails;
	allPxyCashPaymentToDelete : CM_CashPaymentSet;
	taxAmountToDeduct,
	cargoAmountToDeduct		: Decimal[23,6];
begin
	
	//InvoiceSchema::INV_CashReceiptList::doCompareProformaAndExisting //06/05/2025	navkc1 JIRA Bug MTN-34734
	// Should do something similar
	
	// Nothing to compare
	if _allReceiptFound.isEmpty() then
		return;
	endif;
	
	create allPxyCashPaymentToDelete transient;
	create allCashPaymentsAgent transient;
	_pxyCashReceiptFromAgent.allCashPayments.copy(allCashPaymentsAgent);
	
	// Go through cash payments from Agent
	foreach cashPaymentAgent in allCashPaymentsAgent do : agent
		invoiceLineAgent := cashPaymentAgent.myInvoiceLine;
		proformaDetailsAgent := cashPaymentAgent.getMyProformaDetails();
		
		// Compare with the existing cash payment
		foreach existingCashReceipt in _allReceiptFound do
			if not global.isValidObject(existingCashReceipt) then
				continue;
			endif;
			
			// If existing cash receipt is in Draft or Hold, we want to discard the cash payment from Agent if it matches
			if existingCashReceipt.paymentStatus &lt;&gt; CM_CashReceipt.API_RECEIPT_HOLD and existingCashReceipt.paymentStatus &lt;&gt; CM_CashReceipt.API_RECEIPT_DRAFT then
				continue;
			endif;
			
			foreach cashPaymentExisting in existingCashReceipt.allCashPayments discreteLock do
				invoiceLineExisting := cashPaymentExisting.myInvoiceLine;
				proformaDetailsExisting := cashPaymentExisting.getMyProformaDetails();
				
				// Check Invoice Line and amount
				if invoiceLineAgent &lt;&gt; null and invoiceLineExisting &lt;&gt; null and invoiceLineAgent.invoiceLineDesc = invoiceLineExisting.invoiceLineDesc then
					// It's the same invoice line type and cash amount, discard this from agent. This should be paid in the existing draft/hold receipt
					if cashPaymentAgent.cashValue &lt;= cashPaymentExisting.cashValue then
						allPxyCashPaymentToDelete.tryAdd(cashPaymentAgent);
						continue agent;
					endif;
				endif;
				
				
				// Check Profoma details and amount
				if proformaDetailsAgent &lt;&gt; null and proformaDetailsExisting &lt;&gt; null and proformaDetailsAgent.myInvoiceLineType = proformaDetailsExisting.myInvoiceLineType then
					// It's the proforma type and cash amount, discard this from agent. This should be paid in the existing draft/hold receipt
					if cashPaymentAgent.cashValue &lt;= cashPaymentExisting.cashValue then
						allPxyCashPaymentToDelete.tryAdd(cashPaymentAgent);
						continue agent;
					endif;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	// Discard the cash payment from agent
	allPxyCashPaymentToDelete.purge();
	// Recalculate the balances
	self.setBalances();
epilog
	delete allCashPaymentsAgent;
	delete allPxyCashPaymentToDelete;
end;</source>
        <Parameter name="_pxyCashReceiptFromAgent" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_allReceiptFound" type="CM_CashReceiptSet"/>
    </JadeMethod>
    <JadeMethod name="doMakeCashPay" id="2da4ceb2-fef1-4292-bb64-ef883a3fa64c">
        <updating/>
        <source>doMakeCashPay(_payment : Decimal; _processFailed : Boolean output) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63405: Jade - REST API putProformaForVoyage

*/

vars

begin
	if not self.doValidateCashPay(_payment) then
		_processFailed := true;
		return;
	endif;
	
	
	if not self.doSaveCashPay(CM_CashReceipt.API_RECEIPT_FINAL) then
		_processFailed := true;
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_payment" type="Decimal"/>
        <Parameter name="_processFailed" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doSaveCashPay" id="55ea8681-b6a6-4512-9ae3-51ba3672a64e">
        <updating/>
        <source>doSaveCashPay(_paymentStatus : Integer) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63405: Jade - REST API putProformaForVoyage

*/

vars
	newCashReceipt 		: CM_CashReceipt;
	pxyCashPayment	    : CM_CashPayment;
	allPxyCashPays 		: ObjectArray;
	allRealCashPays	 	: ObjectArray;
	now 				: TimeStamp;
	tmpController 		: CMIF_ProformaInvLinesForDebtor;

begin
	create allPxyCashPays transient;
	create allRealCashPays transient;
	
	if self.myPxyCashReceipt = null then
		return false;
	endif;
	
	if self.myDebtor = null then
		return false;
	endif;
	
	if self.cashRequiredToClearCharges &lt; 0 then
		return false;
	endif;
	
	now := app.actualTimeServer();
	
	self.myPxyCashReceipt.getAllInvoiceLines().clear();
	
	foreach pxyCashPayment in self.myPxyCashReceipt.allCashPayments	discreteLock do
		if pxyCashPayment.pxyIsProxy() then
			continue;
		endif;
		if pxyCashPayment.status = self.StatusNotSelected then 
			continue;
		endif;
		
		if pxyCashPayment.manual
		and not pxyCashPayment.pxyIsProxy() 
		and pxyCashPayment.myInvoiceLine.isTransient then
		
			if pxyCashPayment.myProformaDetail &lt;&gt; null and pxyCashPayment.myProformaDetail.isTransient then
				
				if pxyCashPayment.myInvoiceLine.remarks &lt;&gt; null then
					pxyCashPayment.myProformaDetail.setPxyRemarks(pxyCashPayment.myInvoiceLine.remarks &amp; " - " &amp; pxyCashPayment.myProformaDetail.remarks);
				else
					pxyCashPayment.myProformaDetail.setPxyRemarks(pxyCashPayment.myProformaDetail.remarks);
				endif;
			endif;
			delete pxyCashPayment.myInvoiceLine;
		endif;
		
		pxyCashPayment.setDateTime(now);
		allPxyCashPays.add(pxyCashPayment);
		
		if pxyCashPayment.myInvoiceLine &lt;&gt; null
		and not pxyCashPayment.myInvoiceLine.isTransient then
			self.myPxyCashReceipt.allInvoiceLines.addNoDuplicates(pxyCashPayment.myInvoiceLine, false);
		endif;
	endforeach;
	
	if allPxyCashPays.isEmpty() then
		return false;
	endif;
	
	self.setProxyCashReceiptAmounts(now);
	
	create tmpController transient;
	tmpController.populateAllTransients(self.myPxyCashReceipt.allCashPayments);
	
	//11/07/2024	navkc1 CR 64837 Task 64851
	if _paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL then
		self.myPxyCashReceipt.setPaymentStatus(CM_CashReceipt.API_RECEIPT_FINAL);
	elseif _paymentStatus = CM_CashReceipt.API_RECEIPT_DRAFT then
		self.myPxyCashReceipt.setPaymentStatus(CM_CashReceipt.API_RECEIPT_DRAFT);
	endif;
	
	app.myTrxCA.trxCreateCashReceipt(self.myPxyCashReceipt, newCashReceipt, allPxyCashPays, allRealCashPays, self.cashComment, app.myPassport);
	
	if app.myPassport.hasErrors() then
		return false;
	endif;
	
	//Payment success, set status to Final //8/07/2024	navkc1 CR 64835 Task 64850
	//app.myTrxUA.trxUpdateRealCashRecPayStatus(newCashReceipt, method.qualifiedName(), CM_CashReceipt.API_RECEIPT_FINAL, app.myPassport);
	
	if app.myPassport.hasErrors() then
		return false;
	endif;
	
	self.myNewCashReceipt := newCashReceipt;
		
	return true;
epilog
	if tmpController &lt;&gt; null then
		tmpController.allTransientsToDelete.purge();
		delete tmpController;
	endif;
	allPxyCashPays.purge();
	delete allPxyCashPays;
	delete allRealCashPays;
end;</source>
        <Parameter name="_paymentStatus" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidateCashCalculate" id="64fdc0e9-ee69-42c6-89cd-a6c8644b6d95">
        <source>doValidateCashCalculate(_message : String output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	errorStr, //10/04/2025	navkc1 JIRA Story MTN-34492
	agent	: String;
	
begin
	
	/* //11/07/2024	navkc1 CR 64837 Task 64851 - No longer mandatory
	if self.myVoyage = null then
		app.raiseCMException(Voyag_found_pleas_enter_valid_, null, null);
		_message &amp;= app.getErrorString(Voyag_found_pleas_enter_valid_);
	endif;
	*/
	
	errorStr &amp;= self.myTerminal.code; //10/04/2025	navkc1 JIRA Story MTN-34492
	
	//10/04/2025	navkc1 JIRA Story MTN-34492
	if self.myVoyage &lt;&gt; null then
		errorStr &amp;= "/" &amp; self.myVoyage.code;
	endif;
	
	//10/04/2025	navkc1 JIRA Story MTN-34492
	if self.customsEntryNumber &lt;&gt; null then
		errorStr &amp;= "/" &amp; self.customsEntryNumber;
	endif;
	
	//10/04/2025	navkc1 JIRA Story MTN-34492
	if self.bolCode &lt;&gt; null then
		errorStr &amp;= "/" &amp; self.bolCode;
	endif;
	
	if self.allTis.isEmpty() then
		app.myPassport.addErrorFull(Cargo_found_cash_payment, app.getErrorString1(Cargo_found_cash_payment, errorStr), null, null, null);
		//app.raiseCMException(Cargo_found_cash_payment, null, null);
		_message &amp;= app.getErrorString1(Cargo_found_cash_payment, errorStr);
	endif;
	
	if self.myDebtor = null then
		if self.myCashDebtorType &lt;&gt; null then
			if self.myCashDebtorType.code = "SDT2" then
				agent := app.getErrorString(Consignee);
			elseif self.myCashDebtorType.code = "SDT3" then
				agent := app.getErrorString(Consignor);
			elseif self.myCashDebtorType.code = "SDT4" then
				agent := app.getErrorString(Voyage_operator);
			elseif self.myCashDebtorType.code = "SDT6" then
				agent := app.getErrorString(CM_Customs_Agent);
			elseif self.myCashDebtorType.code = "SDT7" then
				agent := app.getErrorString(FreightForwarder);
			// ### JIRA 33765 07JAN2025 NAVAB1
			elseif self.myCashDebtorType.code = "SDT1" then
				agent := app.getErrorString(Operator);
			endif;
			
		endif;
		app.myPassport.addErrorFull(Debto_found_cash_payme_calcu_p, app.getErrorString1(Debto_found_cash_payme_calcu_p, agent), null, null, null);
		//app.raiseCMException1(Debto_found_cash_payme_calcu_p, agent, null, null);
		_message &amp;= app.getErrorString1(Debto_found_cash_payme_calcu_p, agent);
	endif;
	
	return app.myPassport.noErrors();
epilog

end;</source>
        <Parameter name="_message" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidateCashPay" id="f6c84995-5627-448c-9968-2ff233248d2e">
        <source>doValidateCashPay(_payAmount : Decimal) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63405: Jade - REST API putProformaForVoyage

*/

vars
	terminal		: CM_Terminal;
	drTerm			: CM_DebtorTerminal;
	payMeth			: CM_PaymentMethod;
	creditAvailable	: Decimal[23,6];
begin
	terminal := self.myTerminal;
	
	if _payAmount &gt; self.cashRequiredToClearCharges + self.cashPaymentSecondary and
		self.cashRequiredToClearCharges &gt; 0 then
		app.raiseCMException( Cannot_pay_more_cash, null, null );
		return false;
	endif;
	
	// Cannot pay less than the amount
	if self.cashRequiredToClearCharges &gt; _payAmount then
		//if not terminal.getConfig(CashCollectAllowUnderpay).Boolean then
			app.raiseCMException( Cash_less_than_owing, null, null );
			return false;
		//endif;
	endif;
	
	drTerm := terminal.allDebtorTerminals.getAtKey(self.myDebtor);
	if drTerm = null or not drTerm.isCashOnly then
		app.raiseCMException(Not_cash_only_no_receipt,null,self);
		return false;
	endif;
	
	payMeth := app.myRoot.allPaymentMethods.first();
	if payMeth = null then
		// need exception
		app.raiseCMException(Payment_method_defined_termina, null, null);
		return false;
	endif;
	
	creditAvailable := drTerm.getCreditAmount();
	if creditAvailable &lt;&gt; self.creditTotal then
		app.raiseCMException(Credit_value_changed, null, self);
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_payAmount" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllTisID" id="ee30a798-9513-491f-a206-998090eae1fa">
        <source>getAllTisID() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	ti		: CM_TrackedItem;
	ids		: String;
begin
	foreach ti in self.allTis do
		if ids &lt;&gt; null then
			ids &amp;= ",";
		endif;
		
		ids &amp;= ti.id;
	endforeach;
	
	return ids;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllTisToProcess" id="43c1fa80-d6f4-45a4-8056-1462a9a8212e">
        <updating/>
        <source>getAllTisToProcess() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage
10/03/2024	navrv30	Jira MTN-12624 MTN | Cash API Needs to Use Generic Agent
*/

vars
	id,
	cen				: String;
	terminal 		: CM_Terminal;
	parentTi,
	ti				: CM_TrackedItem;
	voyage			: CM_Voyage;
	bol				: CM_BOLIn;
	sa				: StringArray;
	oa				: ObjectArray;
	tis				: ObjectArray;
	tiLookupPool	: CM_TISet;
	tiValidateFail	: Boolean;
	iterator		: Iterator;
	tiDictByCEN		: CM_TIByCustomsEntryNumber;
	allActiveVoyage	: CM_VoyageSet;
	cashDebtorObj 	: CM_Object;
begin
	
	//cen := self.customsEntryNumber.toUpper();
	cen := self.customsEntryNumber;				//07/01/2025	navkc1 JIRA Bug MTN-33766
	terminal := self.myTerminal;
	voyage := self.myVoyage;
	bol := self.myBOL;
	
	if terminal = null then
		return;
	endif;
	
	create tiLookupPool transient;
	create sa transient;
	create oa transient;
	create tis transient;
	create tiDictByCEN transient;
	create allActiveVoyage transient;
	
	self.cargoIds.convertToDelimitedArray(",", sa);
	
	if voyage &lt;&gt; null or bol &lt;&gt; null then
		// Search by BOL
		if bol &lt;&gt; null then
			foreach ti in bol.allTrackedItems discreteLock do
				if ti.myTerminal &lt;&gt; terminal then
					continue;
				endif;
				
				//13/02/2025	navkc1 JIRA Story MTN-33879
				if sa.isNotEmpty() and sa.indexOf(ti.id) = null then
					continue;
				endif;
				
				if ti.isOnSite() or ti.isOnShip() then
					if ti.isChild() then
						parentTi := ti.myParent;
						if parentTi &lt;&gt; null then
							tis.addExclusive(ti);
						endif;
					else
						tis.addExclusive(ti);
					endif;
				endif;
			endforeach;
			
		else
			// Search Voyage by Cargo ID
			if sa.isNotEmpty() then
				foreach id in sa do
					ti := voyage.lookupTrackedItemAnyWhere(id, tis);
					if ti &lt;&gt; null and ti.id = id then
						tis.addExclusive(ti);
					endif;
				endforeach;
			else
			// Search Voyage everything
				voyage.lookupTrackedItemAnyWhereBOL(null, false, tis);
			endif;
		endif;
	elseif cen &lt;&gt; null then
		// Always check onsite TI
		terminal.allOnsiteTIsByCargoTypeId.copyNoDuplicates(tiDictByCEN, false);
		
		// Also check all active voyages
		//terminal.getAllCurrentVoyages(allActiveVoyage, true, true, true);
		terminal.getAllCurrentVoyages(allActiveVoyage, true, false, true); //10/04/2025	navkc1 JIRA Story MTN-34492
		
		foreach voyage in allActiveVoyage do
			voyage.allOnshipTIsByCargoTypeId.copyNoDuplicates(tiDictByCEN, false);
		endforeach;
		
		ti := tiDictByCEN[cen];
		
		iterator := tiDictByCEN.createIterator();
		if ti &lt;&gt; null then
			iterator.startAtObject(ti);
		endif;
		
		while iterator.next(ti) do
			if ti.customsEntryNumber &lt;&gt; cen then
				break;
			endif;
			
			if sa.isNotEmpty() and sa.indexOf(ti.id) = null then
				continue;
			endif;
			
			tis.addExclusive(ti);
			
		endwhile;
		
		//10/04/2025	navkc1 JIRA Story MTN-34492
		if allActiveVoyage.isEmpty() and tis.isEmpty() then
			app.myPassport.addErrorFull(Canno_creat_cash_payme_there_a, app.getErrorString1(Canno_creat_cash_payme_there_a, terminal.code), null, null, null);
		endif;
	endif;
	
	foreach ti in tis as CM_TrackedItem do
		tiValidateFail := false;
		
		//13/02/2025	navkc1 JIRA Story MTN-33879 - Making it more generic
		if self.myCashDebtorType &lt;&gt; null and self.myCashDebtorType.isCustomsAgent() then
			if ti.customsEntryNumber = null then
				// raise error
				app.myPassport.addErrorFull(Does_not_have_custo_entry_numb, app.getErrorString1(Does_not_have_custo_entry_numb, ti.id), null, null, null);
				//app.raiseCMException1(Does_not_have_custo_entry_numb, ti.id, null, null);
				tiValidateFail := true;
			endif;
			
			// Must have Customs Agent
			if ti.myCustomsAgent = null then
				// raise error;
				app.myPassport.addErrorFull(Does_not_have_custom_agent, app.getErrorString1(Does_not_have_custom_agent, ti.id), null, null, null);
				//app.raiseCMException1(Does_not_have_custom_agent, ti.id, null, null);
				tiValidateFail := true;
			endif;
		endif;	
		
		if tiValidateFail then
			continue;
		endif;
		
		// Customs Entry number must match with the request if it's entered
		if cen &lt;&gt; null and //13/02/2025	navkc1 JIRA Story MTN-33879
			ti.customsEntryNumber &lt;&gt; cen then
			// raise error;
			app.myPassport.addErrorFull(Custo_entry_numbe_does_not_mat, app.getErrorString2(Custo_entry_numbe_does_not_mat, ti.id, cen), null, null, null);
			//app.raiseCMException3(Custo_entry_numbe_does_not_mat, ti.id, ti.customsEntryNumber, cen, null, null);
			tiValidateFail := true;
		endif;
		
		//10/03/2024	navrv30	Jira MTN-12624
		cashDebtorObj := self.getCashDebForType(ti);
		// Customs Agent must match with the agent;
		if cashDebtorObj &lt;&gt; self.myDebtorAgent then
			// raise error;
			app.myPassport.addErrorFull(Agent_does_not_match_wit, app.getErrorString3(Agent_does_not_match_wit,self.myCashDebtorType.description, ti.id, self.myDebtorAgentId), null, null, null);
			//app.raiseCMException3(Agent_does_not_match_wit, ti.id, ti.myCustomsAgent.code, self.myDebtorAgentId, null, null);
			tiValidateFail := true;
		endif;
		
		//13/02/2025	navkc1 JIRA Story MTN-33879 - Validate BOL code
		if self.bolCode &lt;&gt; null then
			if ti.billOfLading &lt;&gt; self.bolCode then
				app.myPassport.addErrorFull(Code_cargo_does_not_match_with, app.getErrorString2(Code_cargo_does_not_match_with, ti.id, self.bolCode), null, null, null);
				tiValidateFail := true;
			endif;
		endif;
		
		if tiValidateFail then
			continue;
		endif;
		
		if ti.isOnShip() then
			self.hasOnShip := true;
		endif;
		
		self.allTis.addNoDuplicates(ti, false);
	endforeach;
epilog
	delete sa;
	delete oa;
	delete tis;
	delete tiLookupPool;
	delete tiDictByCEN;
	delete allActiveVoyage;
	delete iterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="getBusinessUnitId" id="7d39fdf0-d5d3-46cb-a325-ae6cf7957f32">
        <source>getBusinessUnitId() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	ti : CM_TrackedItem;
	bank : CM_Bank;
begin
	ti := self.allTis.first().CM_TrackedItem;
	
	if ti &lt;&gt; null then
		bank := ti.companyOid;
		
		if bank = null then
			bank := self.myTerminal.getDefaultCompanyBank();
		endif;
	endif;
	
	if bank &lt;&gt; null then
		return bank.code;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCashDebForType" id="8eb8e9e6-6b91-49a2-8369-9aae7a79a009">
        <source>getCashDebForType(_ti : CM_TrackedItem) : CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/03/2024	navrv30	Jira MTN-12624 MTN | Cash API Needs to Use Generic Agent
*/

vars

myCashDebtorTypeCode 	: String;
voyage 					: CM_Voyage;

begin
	// 14/05/2025	NAVKC1	JIRA MTN 34532
	if self.myCashDebtorType = null then
		return null;
	endif;

	myCashDebtorTypeCode := self.myCashDebtorType.code;
	
	if myCashDebtorTypeCode = "SDT2" then
		return  _ti.getConsigneeObject();
	elseif myCashDebtorTypeCode = "SDT3" then
		return _ti.getConsignorObject();
	elseif myCashDebtorTypeCode = "SDT4" then
		//return _ti.myOperator;   //13/02/2025	navkc1 JIRA Story MTN-33879 - Must match with the request
		//13/02/2025	navkc1 JIRA Story MTN-33879 - Must match with the request
		voyage := _ti.myVoyage;
		if voyage &lt;&gt; null then
			return voyage.myOperator;
		endif;
	elseif myCashDebtorTypeCode = "SDT6" then
		return _ti.myCustomsAgent;
	elseif myCashDebtorTypeCode = "SDT7" then
		return _ti.myFreightForwarder;
	// ### JIRA 33765 07JAN2025 NAVAB1
	elseif myCashDebtorTypeCode = "SDT1" then
		return _ti.myOperator;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getMultiplyRate" id="ba8f1a78-a650-416a-b159-672bb6aebe11">
        <source>getMultiplyRate(_typeCode : String) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	currencyType : CM_CurrencyType;
	rate : CM_CurrencyRate;
	now : TimeStamp;
begin
	if _typeCode.trimBlanks = null then
		return 0.0;
	endif;
	
	currencyType := app.myRoot.allCurrencyTypes.getAtKey(_typeCode).CM_CurrencyType;
	if currencyType = null then
		return 0.0;
	endif;
	now := self.systemToLocalTime(app.actualTimeServer);
	
	rate := currencyType.getRate( now );
	if rate = null then
		return 0.0;
	endif;
	
	return rate.rate;
	
epilog

end;</source>
        <Parameter name="_typeCode" type="String"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getProformaPrintDebtor" id="2c240e88-2ffb-45c1-92d3-7d59ade14311">
        <source>getProformaPrintDebtor(pxyCashPayment : CM_CashPayment input; _debtorStr : String output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	ti : CM_TrackedItem;
	proformaPayment : CM_CashPaymentProformaPrint;
	cashPayment : CM_CashPayment;
begin
	ti := pxyCashPayment.myTrackedItem;
	
	if ti = null then
		return false;
	endif;
	
	foreach cashPayment in ti.allCashPaymentProformaPrints	discreteLock do
		proformaPayment := cashPayment.CM_CashPaymentProformaPrint;
		
		if proformaPayment.proformaDesc = pxyCashPayment.myProformaDetail.myInvoiceLineType.narration
		and proformaPayment.cashValue = pxyCashPayment.cashValue then
			_debtorStr :=  proformaPayment.myDebtorTerminal.myDebtor.name;
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="pxyCashPayment" type="CM_CashPayment" usage="input"/>
        <Parameter name="_debtorStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTotalTaxValue" id="f7427a0a-4b4c-4137-b13e-de5aadb8d67e">
        <source>getTotalTaxValue() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars

begin
	return self.taxValue1 + self.taxValue2 + self.taxValue3;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="hasDraftProforma" id="7fbb215f-ae4b-44cd-b386-c79a67281aa9">
        <updating/>
        <source>hasDraftProforma(	_isSameUser : Boolean output; //30/04/2025	navkc1 JIRA Bug MTN-34734
					_allCashReceiptsFound : CM_CashReceiptSet input //30/04/2025	navkc1 JIRA Bug MTN-34734
				) : Boolean updating;
/*

Purpose:	If the draft proforma combination is the same as current request, cancel it and redo
			If some of the cargo found already have cash receipt with status Paid/Hold, skip those and do the calculation for the remaining cargo
			If the draft proforma combination doesnt match the current request,
				i.e. from someone else, return the draft proforma and set isPaymentAllowed false.
	

Parameters:			

Return Value:	True when ALL the cargo found have cash receipt with status paid/hold
				False when one or more of the cargo found -
					a) does not have cash receipt
					b) have cash receipt, but status is in Draft

Date		Who		Reason
//11/07/2024	navkc1 CR 64837 Task 64851: Jade - New API putProformaForExternal
//01/10/2024 	navkc1 JIRA 19366 QTS | FR - 54207 - Partial Payment is made for a Customs Entry Number
*/

vars
	root				: CM_Root;
	ti 					: CM_TrackedItem;
	cashPayment			: CM_CashPayment;
	cashReceipt 		: CM_CashReceipt;
	allTisId,
	cashReceiptAgentId,
	errorMsg			: String;
	hasUnpaidTI,
	hasPaidOrHoldTI,
	foundReceipt		: Boolean;
	cashReceiptAgent	: CM_Object;
	draftReceiptsToDelete,
	cashReceipts		: CM_CashReceiptSet;
	checkedExtUserCode	: Boolean;
	holdTIs,
	paidTIs,
	unpaidTIs			: CM_TISet;
begin
	
	// InvoiceSchema::INV_CashReceiptList::getTIsPendingOrPaidCashReceipt
	// Similar thing, but this method does more validations
	
	create cashReceipts transient;
	
	create holdTIs transient; //01/10/2024 navkc1 JIRA 19366 
	create paidTIs transient; //01/10/2024 navkc1 JIRA 19366 
	create unpaidTIs transient; //01/10/2024 navkc1 JIRA 19366 
	create draftReceiptsToDelete transient; //01/10/2024 navkc1 JIRA 19366
	
	allTisId := self.getAllTisID();
	
	root := app.myRoot;
	
	foreach ti in self.allTis do : tiLoop
		// We want to check all TI's cash receipt whether it matches with the request
		checkedExtUserCode := false;
		
		//01/10/2024 navkc1 JIRA 19366 - TI does not have any cash payments, it's unpaid.
		if ti.allCashPayments.isEmpty() then
			unpaidTIs.tryAdd(ti); 
		endif;
		
		foreach cashPayment in ti.allCashPayments discreteLock do : cashReceiptLoop
			cashReceipt := cashPayment.myCashReceipt;
			if cashReceipt = null then
				continue;
			endif;
			
			//01/10/2024 navkc1 JIRA 19366 - Check the cash receipt payment status, then add the TI to the collection for further validation.
			// Final/Paid
			if cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL or
				cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_PAID then
				paidTIs.tryAdd(ti);
			// Hold
			elseif cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD then
				holdTIs.tryAdd(ti);
			// Cancelled/Expired
			elseif 	cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_CANCELLED or
					cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_EXPIRED then
				unpaidTIs.tryAdd(ti);
				continue;
			endif;

			// Different user, cannot proceed - Do this check for all TI
			//if self.externalUserCode &lt;&gt; cashReceipt.externalUserCode then
			if not (cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL or cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_PAID   //07/01/2025	navkc1 JIRA Bug MTN-33764 - If cash receipt is already paid/finalized, we won't be including it to the new draft receipt. Can skip the check for now
					or cashReceipt.paymentStatus = CM_CashReceipt.PAID)  // ### JIRA 34937 23MAY2025 NAVAB1
				and  self.externalUserCode &lt;&gt; cashReceipt.externalUserCode then
				if not checkedExtUserCode then
					if errorMsg = null then
						errorMsg &amp;= ti.id  &amp; " is being processed by " &amp; cashReceipt.externalUserCode;
					else
						errorMsg &amp;= CrLf &amp; ti.id &amp; " is being processed by " &amp; cashReceipt.externalUserCode;
					endif;
					
					checkedExtUserCode := true;
					_isSameUser := false; //07/01/2025	navkc1 JIRA Bug MTN-33764
				endif;
			else
				_isSameUser := true;
				if cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_DRAFT then
					unpaidTIs.tryAdd(ti);
					draftReceiptsToDelete.tryAdd(cashReceipt);
				endif;
			endif;
			
			// To prevent processing the same cash receipt from different TI
			if cashReceipts.includes(cashReceipt) then
				continue;
			endif;	
			cashReceipts.add(cashReceipt);
			
			foundReceipt := true;
			
			// Customs Entry Number
			if self.customsEntryNumber &lt;&gt; null and self.customsEntryNumber &lt;&gt; cashReceipt.getCustomsEntryNumber() then
				if errorMsg = null then
					errorMsg &amp;= "Request's customs entry number doesn't match with existing cash receipt " &amp; cashReceipt.sequenceNum.String &amp; ", customs entry number - " &amp; cashReceipt.getCustomsEntryNumber();
				else
					errorMsg &amp;= CrLf &amp; "Request's customs entry number doesn't match with existing cash receipt " &amp; cashReceipt.sequenceNum.String &amp; ", customs entry number - " &amp; cashReceipt.getCustomsEntryNumber();
				endif;
			endif;
			
			// Agent Code
			cashReceiptAgent := cashReceipt.myAgent;			
			if self.myDebtorAgentId &lt;&gt; null and cashReceiptAgent &lt;&gt; null then
				if cashReceiptAgent.isKindOf(CM_ConsigneeConsignor) then
					cashReceiptAgentId := cashReceiptAgent.CM_ConsigneeConsignor.code;
				elseif cashReceiptAgent.isKindOf(CM_CustomsAgent) then
					cashReceiptAgentId := cashReceiptAgent.CM_CustomsAgent.code;
				endif;
				
				if self.myDebtorAgent &lt;&gt; cashReceiptAgent then
					if errorMsg = null then
						errorMsg &amp;= "Request's agent code doesn't match with existing cash receipt " &amp; cashReceipt.sequenceNum.String &amp; ", agent code - " &amp; cashReceiptAgentId;
					else
						errorMsg &amp;= CrLf &amp; "Request's agent code doesn't match with existing cash receipt " &amp; cashReceipt.sequenceNum.String &amp; ", agent code - " &amp; cashReceiptAgentId;
					endif;
				endif;
			endif;			
		endforeach;
	endforeach;	
	
	/*01/10/2024 navkc1 JIRA 19366
	============
	Scenario 
	We have 5 cargo found
	Cargo 1 is paid in Cash Receipt 100
	Cargo 2, Cargo 3, Cargo 4, and Cargo 5 not paid
	
	We want to create draft receipt for Cargo 2, 3, 4 and 5
	Then, in the reports, we want to return the draft receipt of Cargo 2, 3, 4, and 5
	=============
	*/
	foreach cashReceipt in cashReceipts do
		if cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_DRAFT then
			self.myNewCashReceipt := cashReceipt;
			break;
		endif;
	endforeach;
	
	cashReceipts.copy(_allCashReceiptsFound); //30/04/2025	navkc1 JIRA Bug MTN-34734
	
	// If we don't have a draft receipt, it means the cargo we found already has cash receipt that is PAID or HOLD
	if self.myNewCashReceipt = null then
		//self.myNewCashReceipt := cashReceipts.first();
		self.myNewCashReceipt := cashReceipts.last(); //30/04/2025	navkc1 JIRA Bug MTN-34734
	endif;
	
	// If same user, we want to delete the existing draft cash receipt/s, then create a new draft
	if _isSameUser then
		if errorMsg = null and self.myNewCashReceipt.isDraftReceipt() then
			foreach cashReceipt in draftReceiptsToDelete do
				app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
			endforeach;
			draftReceiptsToDelete.clear();
			self.myNewCashReceipt := null;
			// Set to false, so it will proceed to create a new one
			foundReceipt := false;
		endif;
		
		//01/10/2024 navkc1 JIRA 19366 
		hasPaidOrHoldTI := paidTIs.isNotEmpty() or holdTIs.isNotEmpty();
		hasUnpaidTI := unpaidTIs.isNotEmpty();
		
		//01/10/2024 navkc1 JIRA 19366 - We have mixture of paid/hold and unpaid, clear the collection and only calculated the amount for unpaid ones.
		if hasPaidOrHoldTI and hasUnpaidTI then
			
			foreach cashReceipt in draftReceiptsToDelete do
				app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
				foundReceipt := false; //30/04/2025	navkc1 JIRA Bug MTN-34734
			endforeach;
			
			/*26/03/2025	navkc1 JIRA Task MTN-34488 - 
				Let's not clear the collection. The Paid Cargo might have additional charges added. We need it to be in the collection so that it gets calculated and display.
				If it doesn't have additional charges, it won't afffect the output anyway.
			*/
			//self.allTis.clear();
			//unpaidTIs.copy(self.allTis);
			
			//foundReceipt := false; //30/04/2025	navkc1 JIRA Bug MTN-34734
		endif;
		
	// If there's an error message, no payment is allowed
	elseif errorMsg &lt;&gt; null then
		self.isPaymentAllowed := false;
		//app.raiseCMException1(Cash_invoice_validat_failed, errorMsg, null, null);
		app.myPassport.addErrorFull(Cash_invoice_validat_failed, app.getErrorString1(Cash_invoice_validat_failed, errorMsg), null, null, null);
	endif;
	
	return foundReceipt;
	
epilog
	delete cashReceipts;
	delete holdTIs; //01/10/2024 navkc1 JIRA 19366 
	delete paidTIs; //01/10/2024 navkc1 JIRA 19366 
	delete unpaidTIs;//01/10/2024 navkc1 JIRA 19366 
	delete draftReceiptsToDelete; //01/10/2024 navkc1 JIRA 19366 
end;</source>
        <Parameter name="_isSameUser" type="Boolean" usage="output"/>
        <Parameter name="_allCashReceiptsFound" type="CM_CashReceiptSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initAllTaxCodes" id="a4bde3aa-ffc9-4c3e-a8da-7c8ba47aa259">
        <updating/>
        <source>initAllTaxCodes() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	terminal 	: CM_Terminal;
	taxCode		: CM_TaxCode;
	sa		    : StringArray;
	defaultBank	: CM_Bank;
	codeList	: String;
	code		: String;
	count		: Integer;
begin
	terminal := self.myTerminal;
	
	if not self.showServiceTax then
		// show configured taxes 
		codeList := terminal.getConfig(CashAllCashTax).String;
		create sa transient;
		codeList.asStringArrayByDelimiter(sa, ",");
		defaultBank := terminal.getDefaultCompanyBank();
		if defaultBank &lt;&gt; null then
			// get the actual current tax code from the saved code string
			foreach code in sa do
				taxCode := defaultBank.allTaxCodes[code];
				if taxCode &lt;&gt; null then
					self.allTaxCodes.add(taxCode);
					count := count + 1;
					if count = 1 then
						self.taxCode1 			  := code; 
					elseif count = 2 then
						self.taxCode2 			  := code; 
					elseif count = 3 then
						self.taxCode3 			  := code; 
						break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
epilog
	delete sa;
end;</source>
    </JadeMethod>
    <JadeMethod name="initMyCashDebtorType" id="1ce1a3de-a108-4337-8a81-5d5170b91029">
        <updating/>
        <source>initMyCashDebtorType() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	terminal : CM_Terminal;
begin
	terminal := self.myTerminal;
	
	if terminal = null then
		return;
	endif;
	
	self.myCashDebtorType := terminal.getConfig(CashDebtorType).CM_DebtorType;
	
	// 14/05/2025	NAVKC1	JIRA MTN 34532
	if self.myCashDebtorType = null then
		app.myPassport.addErrorFull(CashDebtNotDefineCashConfig, app.getErrorString(CashDebtNotDefineCashConfig), null, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initMyDebtor" id="ddc6c5ef-1bbb-4d76-8200-5c8daf24c3f4">
        <updating/>
        <source>initMyDebtor() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	cashDebtorType 	: CM_DebtorType;
	debtor			: CM_Debtor;
	ca				: CM_CustomsAgent;
	cc				: CM_ConsigneeConsignor;
	operator		: CM_Operator;
	root			: CM_Root;
begin
	
	cashDebtorType := self.myCashDebtorType;
	
	if cashDebtorType = null then
		return;
	endif;
	
	self.myCashDebtorType := cashDebtorType;
	
	//11/07/2024	navkc1 CR 64837 Task 64851
	root := app.myRoot;
	
	if root = null then
		return;
	endif;
		
	//11/07/2024	navkc1 CR 64837 Task 64851 - Dont need to get from TI, get directly from Root
	/*foreach ti in self.allTis do
		if ti &lt;&gt; null then
			if cashDebtorType.code = "SDT2" then
				cc := ti.getConsigneeObject();
				if cc &lt;&gt; null then
					self.myDebtorAgent := cc;
					debtor := cc.debtor;
					self.myDebtorAgentId := cc.code;
				endif;
				
				if debtor = null then
					cc := app.myRoot.allConsigneeConsignors[self.myDebtorAgentId];
					if cc &lt;&gt; null and cc.isConsignee then
						self.myDebtorAgent := cc;
						debtor := cc.debtor;
						self.myDebtorAgentId := cc.code;
					endif;
				endif;
			elseif cashDebtorType.code = "SDT3" then
				cc := ti.getConsignorObject();
				if cc &lt;&gt; null then
					self.myDebtorAgent := cc;
					debtor := cc.debtor;
					self.myDebtorAgentId := cc.code;
				endif;
				
				if debtor = null then
					cc := app.myRoot.allConsigneeConsignors[self.myDebtorAgentId];
					if cc &lt;&gt; null and cc.isConsignor then
						self.myDebtorAgent := cc;
						debtor := cc.debtor;
						self.myDebtorAgentId := cc.code;
					endif;
				endif;
			elseif cashDebtorType.code = "SDT4" then
				if self.myVoyage &lt;&gt; null then
					operator := self.myVoyage.myOperator;
					if operator &lt;&gt; null then
						self.myDebtorAgent := operator;
						debtor := operator.debtor;
						self.myDebtorAgentId := operator.code;
					endif;
				endif;
			elseif cashDebtorType.code = "SDT6" then
				ca := ti.myCustomsAgent;
				if ca &lt;&gt; null then
					self.myDebtorAgent := ca;
					debtor := ca.myDebtor;
					self.myDebtorAgentId := ca.code;
				endif;
				
				if debtor = null then
					ca := app.myRoot.allCustomsAgents[self.myDebtorAgentId];
					if ca &lt;&gt; null then
						self.myDebtorAgent := ca;
						debtor := ca.myDebtor;
						self.myDebtorAgentId := ca.code;
					endif;
				endif;
			elseif cashDebtorType.code = "SDT7" then
				cc := ti.myFreightForwarder;
				if cc &lt;&gt; null then
					self.myDebtorAgent := cc;
					debtor := cc.debtor;
					self.myDebtorAgentId := cc.code;
				endif;
				
				if debtor = null then
					cc := app.myRoot.allConsigneeConsignors[self.myDebtorAgentId];
					if cc &lt;&gt; null and cc.isFreightFwdr then
						self.myDebtorAgent := cc;
						debtor := cc.debtor;
						self.myDebtorAgentId := cc.code;
					endif;
				endif;
			endif;
		endif;
		if debtor &lt;&gt; null then
			break;
		endif;
	endforeach;*/
	
	
	//11/07/2024	navkc1 CR 64837 Task 64851
	if cashDebtorType.code = "SDT2" then
		// Consignee
		cc := app.myRoot.allConsigneeConsignors[self.myDebtorAgentId];
		if cc &lt;&gt; null and cc.isConsignee then
			self.myDebtorAgent := cc;
			debtor := cc.debtor;
			self.myDebtorAgentId := cc.code;
		endif;
	elseif cashDebtorType.code = "SDT3" then
		// Consignor
		cc := app.myRoot.allConsigneeConsignors[self.myDebtorAgentId];
		if cc &lt;&gt; null and cc.isConsignor then
			self.myDebtorAgent := cc;
			debtor := cc.debtor;
			self.myDebtorAgentId := cc.code;
		endif;
	elseif cashDebtorType.code = "SDT4" then
		// Votyage operator
		if self.myVoyage &lt;&gt; null then
			operator := self.myVoyage.myOperator;
			if operator &lt;&gt; null and 
				operator.code = self.myDebtorAgentId //13/02/2025	navkc1 JIRA Story MTN-33879 - Must match with the request
				then
				self.myDebtorAgent := operator;
				debtor := operator.debtor;
				self.myDebtorAgentId := operator.code;
			endif;
		endif;
	elseif cashDebtorType.code = "SDT6" then
		// Customs Agent
		ca := app.myRoot.allCustomsAgents[self.myDebtorAgentId];
		if ca &lt;&gt; null then
			self.myDebtorAgent := ca;
			debtor := ca.myDebtor;
			self.myDebtorAgentId := ca.code;
		endif;
	elseif cashDebtorType.code = "SDT7" then
		// Freight Forwarder
		cc := app.myRoot.allConsigneeConsignors[self.myDebtorAgentId];
		if cc &lt;&gt; null and cc.isFreightFwdr then
			self.myDebtorAgent := cc;
			debtor := cc.debtor;
			self.myDebtorAgentId := cc.code;
		endif;
	// ### JIRA 33765 07JAN2025 NAVAB1
	elseif cashDebtorType.code = "SDT1" then
		// Operator
		operator := app.myRoot.allOperators[self.myDebtorAgentId];
		if operator &lt;&gt; null then
			self.myDebtorAgent := operator;
			debtor := operator.debtor;
			self.myDebtorAgentId := operator.code;
		endif;
	endif;
	
	//if debtor.isCashOnlyDebtor(self.myTerminal) then
	if debtor &lt;&gt; null and debtor.isCashOnlyDebtor(self.myTerminal) then //8/07/2024	navkc1 CR 64835 Task 64850
		self.myDebtor := debtor;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initSecondCurrency" id="9c74cbe4-4d20-4ead-ad3a-fbac3fd4c2f6">
        <updating/>
        <source>initSecondCurrency() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars

begin
	self.allowSecondCurrency := self.myTerminal.getConfig(CashAllowSecondCurrency).Boolean;
	
	if self.allowSecondCurrency then
		self.secondCurrencySymbol := self.myTerminal.getCashSecondPayCurrency;
		self.convertMultiplyRate  := self.getMultiplyRate(self.secondCurrencySymbol );
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initShowServiceTax" id="1fd4252f-707c-4d56-99b7-d38dc82f3f8d">
        <updating/>
        <source>initShowServiceTax() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	taxCodeList    : String;
	term 		   : CM_Terminal;
begin
	term := self.myTerminal;
	taxCodeList  := term.getConfig(CashAllCashTax).String ;
	
	self.showServiceTax     := taxCodeList = null and term.getConfig(InvoiceMultiTaxRates).Boolean;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initVoyageAndBOL" id="a1f1bd86-d09f-4bac-a98e-a7e08e5dddf4">
        <updating/>
        <source>initVoyageAndBOL(_voyCode : String; _bolCode : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	allVoyages 	: CM_VoyageSet;
	voyage		: CM_Voyage;
	billOfLading : CM_BOLIn;
	terminal	: CM_Terminal;
begin
	terminal := self.myTerminal;
	
	if _voyCode = null or terminal = null then
		return;
	endif;
	
	create allVoyages transient;
	
	terminal.getAllCurrentVoyagesCashColl(allVoyages);
	
	foreach voyage in allVoyages where voyage.code = _voyCode do
		self.myVoyage := voyage;
		break;
	endforeach;
	
	if voyage &lt;&gt; null and _bolCode &lt;&gt; null then
		billOfLading := voyage.getBOL(_bolCode);
		if billOfLading = null or billOfLading.number &lt;&gt; _bolCode then
			billOfLading := null;
		endif;
		self.myBOL := billOfLading;
	endif;
	
epilog
	delete allVoyages;
end;</source>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_bolCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="5b43d17e-e020-4a7a-954a-2f652869da6a">
        <updating/>
        <source>initialize(	_voyCode : String;
			_bolCode : String;
			_customsEntryNumber : String;
			_cargoIds : String;
			_effectiveDate : Date;
			_shipReleaseDate : Date;
			_terminal : CM_Terminal;
			_agentID : String;
			_isFromAPI : Boolean;
			_createPersistent : Boolean
										) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars

begin
	
	self.cargoIds := _cargoIds.toUpper();
	self.customsEntryNumber := _customsEntryNumber;
	self.effectiveDate := _effectiveDate;
	self.shipReleaseDate := _shipReleaseDate;
	self.myTerminal := _terminal;
	self.isFromAPI := _isFromAPI;
	self.bolCode := _bolCode;
	self.myDebtorAgentId := _agentID;
	self.createPersistDraftCashReceipt := _createPersistent; //11/07/2024	navkc1 CR 64837 Task 64851
	
	self.initSecondCurrency();
	self.initShowServiceTax();
	self.initMyCashDebtorType();
	
	self.initAllTaxCodes();
	
	self.initVoyageAndBOL(_voyCode, _bolCode);	
	self.initMyDebtor();
	self.getAllTisToProcess();
	
epilog

end;</source>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_bolCode" type="String"/>
        <Parameter name="_customsEntryNumber" type="String"/>
        <Parameter name="_cargoIds" type="String"/>
        <Parameter name="_effectiveDate" type="Date"/>
        <Parameter name="_shipReleaseDate" type="Date"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_agentID" type="String"/>
        <Parameter name="_isFromAPI" type="Boolean"/>
        <Parameter name="_createPersistent" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForProformaStatus" id="c5ee0076-9570-4200-84eb-670cbd73d4f6">
        <updating/>
        <source>initializeForProformaStatus(_customsAgentCode : String;
							_customsEntryNumber : String;
							_draftReceiptNumber : Integer;
							_externalFinancialId : String;
							_externalRef1 : String;
							_externalUserCode : String;
							_externalReceiptNumber : String;
							_externalTransaction : String;
							_remarks : String;
							_statusValue : Integer;
							_terminal : CM_Terminal
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64838 Task 64853: Jade - New Cash API putProformaStatus

*/

vars
	cashReceipt 	: CM_CashReceipt;
	debtor			: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
begin
	self.myDebtorAgentId := _customsAgentCode;
	self.customsEntryNumber := _customsEntryNumber;
	self.externalFinancialId := _externalFinancialId;
	self.externalRef1 := _externalRef1;
	self.externalUserCode := _externalUserCode;
	self.externalReceiptNumber := _externalReceiptNumber;
	self.externalTransaction := _externalTransaction;
	self.remarks := _remarks;
	self.myTerminal := _terminal;
	self.nextStatusValue := _statusValue;
	self.draftReceiptNumber := _draftReceiptNumber;
	
	self.initMyCashDebtorType();
	self.initMyDebtor();
	
	// Get Debotr
	debtor := self.myDebtor;
	if debtor &lt;&gt; null then
		// Get Debtor Terminal
		debtorTerminal := debtor.allDebtorTerminals[_terminal];
	endif;
	
	// Get Cash Receipt from debtor terminal
	if debtorTerminal &lt;&gt; null then
		cashReceipt := debtorTerminal.allCashReceipts[_draftReceiptNumber];
		self.myNewCashReceipt := cashReceipt;
	endif;
epilog

end;</source>
        <Parameter name="_customsAgentCode" type="String"/>
        <Parameter name="_customsEntryNumber" type="String"/>
        <Parameter name="_draftReceiptNumber" type="Integer"/>
        <Parameter name="_externalFinancialId" type="String"/>
        <Parameter name="_externalRef1" type="String"/>
        <Parameter name="_externalUserCode" type="String"/>
        <Parameter name="_externalReceiptNumber" type="String"/>
        <Parameter name="_externalTransaction" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_statusValue" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="isTransNeedReSync" id="39d566e9-2ec6-4890-80ac-52d24b20dcf7">
        <source>isTransNeedReSync(_transaction : CM_TITransaction; _agentCode : String; _debtorType : CM_DebtorType):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/
vars
	aSBController : CMIF_ServiceBroker;
	bank : CM_Bank;
begin

	// ### JIRA 35557 24JUL2025 NAVAB1
	if _debtorType.code = "SDT2" then
		if _transaction.consignee = _agentCode then
			return false;
		endif;
	elseif _debtorType.code = "SDT3" then
		if _transaction.consignor = _agentCode then // ### JIRA 35502 18JUL2025 NAVAB1
			return false;
		endif;
	elseif _debtorType.code = "SDT6" then
		if _transaction.customsAgentCode = _agentCode then // ### JIRA 35502 18JUL2025 NAVAB1
			return false;
		endif;
	elseif _debtorType.code = "SDT7" then
		if _transaction.freightForwarderCode = _agentCode then // ### JIRA 35502 18JUL2025 NAVAB1
			return false;
		endif;
	elseif _debtorType.code = "SDT1" then
		if _transaction.operatorCode = _agentCode then // ### JIRA 35502 18JUL2025 NAVAB1
			return false;
		endif;
	endif;

	bank := _transaction.getBusinessUnitObject();
	
	if bank = null then
		return false;
	endif;

	create aSBController transient;
	aSBController.myTransaction := _transaction;
	aSBController.myBank := bank;
	
	if bank.terminal.getConfig(InvUseInvoiceCargoAlloc).Boolean then 
		aSBController.isInvoiceCargoAllocation := true;
		bank.getInvoiceLineDescForTIAlloc(aSBController);
		
		if aSBController.allInvoiceLineTypes.isEmpty() then
			aSBController.isInvoiceCargoAllocation := false;
			bank.getInvoiceLineDescForCargo(aSBController);
		endif;
	else
		bank.getInvoiceLineDescForCargo(aSBController);
	endif;
	
	if aSBController.allInvoiceLineTypes.size &gt;1 then
		return true;
	
	elseif aSBController.allInvoiceLineTypes.size = 1 then
		if aSBController.allInvoiceLineTypes.first.CM_InvoiceLineDesc.isVoid then
			return false;
		else
			return true;
		endif;
	endif;
	
	return false;
	
epilog
	delete aSBController;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_agentCode" type="String"/>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageExempt" id="eeb32e6b-3beb-4ce8-8e53-23b81f6fe184">
        <source>isVoyageExempt() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	voy : CM_Voyage;
begin
	voy := self.myVoyage;
	
	if voy &lt;&gt; null then
		return app.myRoot.getVoyageTaxExempt(voy.myTerminal, voy).Boolean;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="proformaDisplayCashReceipt" id="5ba1416a-5d00-40bd-a92e-83414e64d08d">
        <updating/>
        <source>proformaDisplayCashReceipt() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	pxyCashReceipt			: CM_CashReceipt;
	pxyCashPayment 			: CM_CashPayment;
	childStr, 
	parentStr, 
	sortStr 				: String;
	totalCashValue, 
	totalTaxValue, 
	grandTotalValue, 
	totPayment,
	creditOnPayment,
	creditOnPaymentTax		: Decimal [23,6];
	dynaDict 				: DynaDictionary;
	iter 					: Iterator;
	showPaidDebtor, 
	showProformaDebtor		: Boolean;
	ti						: CM_TrackedItem;
begin
	if self.myPxyCashReceipt = null then
		return;
	endif;
	
	pxyCashReceipt := self.myPxyCashReceipt;
	
	showPaidDebtor 		:= self.myTerminal.getConfig(ShowDebtorForPayment).Boolean;
	showProformaDebtor  := self.myTerminal.getConfig(ShowDebtorForProforma).Boolean;
	
	pxyCashReceipt.applyCreditOnProxy();
	pxyCashReceipt.applyMinChargeByGroupOnProxy(self.isInvoiceProforma);
	
	create dynaDict transient;	
	dynaDict.setMembership(CM_CashPayment);
	dynaDict.addExternalKey(String, 100, false, true	); // TI ID
	dynaDict.addExternalKey(String, 100, false, true	); // NARRATION
	dynaDict.addExternalKey(String, 100, false, true	); // SORT
	dynaDict.endKeys(true);
	
	foreach pxyCashPayment in pxyCashReceipt.allCashPayments discreteLock do
		sortStr := "Z"; // Put any exisitng payment at the bottom
		
		ti := pxyCashPayment.myTrackedItem; //20/08/2025	navkc1 JIRA MTN 35791
		
		//if pxyCashPayment.myTrackedItem &lt;&gt; null then
		if ti &lt;&gt; null then //20/08/2025	navkc1 JIRA MTN 35791
			if ti.isChild then
				parentStr := ti.myParent.id;
				childStr := ti.id;
				if not pxyCashPayment.pxyIsProxy() then
					sortStr := "A"; // Put any new payment at the top
				endif;
			else
				parentStr := ti.id;
				childStr := "";
				if not pxyCashPayment.pxyIsProxy() then
					sortStr := "A"; // Put any new payment at the top
				endif;
			endif;
		else
			parentStr := "ZZZZZZZZZZ";
			childStr := "ZZZZZZZZZ";
		endif;
		dynaDict.putAtKey(parentStr, childStr,sortStr,pxyCashPayment);
	endforeach;
	
	totalCashValue 		:= 0;
	totalTaxValue 		:= 0;
	grandTotalValue 	:= 0;
	totPayment 			:= 0;
	creditOnPayment     := 0;
	creditOnPaymentTax  := 0;
	
	if dynaDict.isEmpty() then
		self.setBalances();
		return;
	endif;
	
	/* //20/08/2025	navkc1 JIRA MTN 35791 Copied from UI, not used at all from API
	iter := dynaDict.createIterator();

	while(iter.next(pxyCashPayment))  do
		taxValue               := 0;
		typeStr 			   := "";
		narrStr                := "";
		totalValue             := 0;
		childStr               := "";
		parentStr              := "";
		debtorStr              := "";
		creditOnPayment        := 0;
		creditOnPaymentTax     := 0;
		isProformaPrintPayment := false;
		
		if pxyCashPayment.myCashPaymentForTax &lt;&gt; null then
			taxValue := pxyCashPayment.myCashPaymentForTax.cashValue;
		endif;
		
		currentTI := pxyCashPayment.myTrackedItem;
		
		if currentTI&lt;&gt; null then
			if lastTI = null or lastTI &lt;&gt; currentTI then
				if lastTI &lt;&gt; null  and lastTI &lt;&gt; currentTI then
					totalCashValue  := 0;
					totalTaxValue   := 0;
					grandTotalValue := 0;
					totPayment      := 0;
				endif;
			
			
				if currentTI.isChild then
					parentStr := "(" &amp; currentTI.myParent.id &amp; ") " &amp; currentTI.id;
				else
					parentStr := currentTI.id &amp; " " &amp; currentTI.totalWeight.Integer.String &amp; " kg";
				endif;
			endif;
		elseif pxyCashPayment.myVoyage &lt;&gt; null then
				if lastTI &lt;&gt; null  then
					
					totalCashValue  := 0;
					totalTaxValue   := 0;
					grandTotalValue := 0;
					totPayment      := 0;
				endif;
			parentStr :=pxyCashPayment.myVoyage.code;
			currentVoyage := pxyCashPayment.myVoyage;
			
			if firstVoyage = null then
				firstVoyage := currentVoyage;
			endif;
			
		endif;
		
		totalCashValue  := totalCashValue + pxyCashPayment.cashValue;
		totalTaxValue   := totalTaxValue  + taxValue;
		grandTotalValue := totalCashValue + totalTaxValue;
		
		
		typeStr 	  := pxyCashPayment.getPaymentType(self.isInvoiceProforma);
		//narrStr 	  := pxyCashPayment.getPaymentNarration(true,true);
		narrStr 	  := pxyCashPayment.getPaymentNarration(false,false); //20/08/2025	navkc1 JIRA MTN 35791
		//checkboxvalue := pxyCashPayment.getPaymentCheckBox(null,self.isInvoiceProforma); //20/08/2025	navkc1 JIRA MTN 35791
		
		// ### EXTRA EXTRA
		if pxyCashPayment.manual then	
		// ### INVOICED INVOICED
		elseif pxyCashPayment.myInvoiceLine &lt;&gt; null then	
		// ### ESTIMATE
		else
			if showProformaDebtor then
				//isProformaPrintPayment := self.getProformaPrintDebtor(pxyCashPayment, debtorStr);
			endif;
		endif;

	
		totalValue := pxyCashPayment.cashValue + taxValue;
		
		if pxyCashPayment.pxyIsProxy  // update proxy = existing cash payment
		//or self.myQueryCashReceipt &lt;&gt; null 
		then
			realCashPayment := pxyCashPayment.pxyGetRealObject().CM_CashPayment;
			paidStr 	    := app.getErrorString(Paid);
			checkboxvalue   := "";

			if showPaidDebtor 
			and realCashPayment &lt;&gt; null then	
					debtorStr :=  realCashPayment.getDebtorName(); 
			endif;

		else
			if self.isInvoiceProforma then
				paidStr := app.getErrorString(Proforma);
			else
				paidStr := app.getErrorString(Outstanding);
			endif;
			
			if pxyCashPayment.status = self.StatusSelected then
				totPayment := totPayment + pxyCashPayment.cashValue;
				if pxyCashPayment.hasTax  then
					totPayment := totPayment + pxyCashPayment.myCashPaymentForTax.cashValue;
				endif;
			endif;
		endif;
		
		lastTI := currentTI;
	endwhile;
	*/
	
	self.setBalances();
epilog
	delete iter;
	delete dynaDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="proformaGetProformas" id="e74f2d56-1441-4349-8c2e-44d52ebee5be">
        <source>proformaGetProformas();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	defaultBank,
	bank			: CM_Bank;
	ti				: CM_TrackedItem;
	terminal		: CM_Terminal;
	proformaAgent	: CM_CashInvoiceProformaAgent;
begin
	terminal := self.myTerminal;
	defaultBank := terminal.getDefaultCompanyBank();
	
	foreach ti in self.allTis do
		bank := ti.companyOid;
		
		if bank = null then
			bank := defaultBank;
		endif;
		
		create proformaAgent transient;
		proformaAgent.init( bank, ti, self.effectiveDate, true);
		proformaAgent.setDebtorFromAgent(self.myDebtor);
		proformaAgent.setReleaseDate(self.shipReleaseDate);
		proformaAgent.createProformaInvLines(null, false, false );
		proformaAgent.getCurrentInvLines();
		
		self.allAgents.add(proformaAgent);
		
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="proformaProxyCashReceipt" id="4e146fef-6363-4b05-950c-ad672a1dda62">
        <updating/>
        <source>proformaProxyCashReceipt() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	realCashRec, //11/07/2024	navkc1 CR 64837 Task 64851
	pxyCashRec 		   	: CM_CashReceipt;
	cashPaymentAmount  	: Decimal [23,6];
	proformaAgent	   	: CM_CashInvoiceProformaAgent;
	now     			: TimeStamp;
	user               	: CM_User;
	drTerm 			   	: CM_DebtorTerminal;
	payMeth 		   	: CM_PaymentMethod;
	voyage 			   	: CM_Voyage;
	voyCode, 
	bolNumber 		   	: String;
	newSeq			   	: Integer;
	invoiceLine		   	: CM_InvoiceLine;
	showProformaDebtor 	: Boolean;
	bank               	: CM_Bank;
	terminal			: CM_Terminal;
	
begin
	if self.allAgents.isEmpty() then
		return;
	endif;
	
	terminal := self.myTerminal;
	now     := app.actualTimeServer;
	user    := app.getMyUser;
	drTerm  := terminal.allDebtorTerminals.getAtKey( self.myDebtor );
	payMeth := app.myRoot.allPaymentMethods.first();
	bank    := self.allAgents.first.CM_CashInvoiceProformaAgent.myBank;
	
	foreach proformaAgent in self.allAgents	discreteLock do
		cashPaymentAmount := cashPaymentAmount + proformaAgent.getProformaCashValue();
	endforeach;
	
	showProformaDebtor := terminal.getConfig(ShowDebtorForProforma).Boolean;
	
	if showProformaDebtor then
		create pxyCashRec as CM_CashReceiptProformaPrint transient; 
	else
		create pxyCashRec transient; 	
	endif;
	
	pxyCashRec.setProxy(cashPaymentAmount,				//_cashValue : Decimal;
						now,							//_dateTime : TimeStamp;
						user,					   		//_myUser : CM_User;
						0,								//_sequenceNum : Integer;
						null,//self.txtChqBank.text,			//_chequeBank : String;
						null,//self.txtChqBranch.text,			//_chequeBranch : String;
						null,//self.txtChqNumber.text,			//_chequeNumber : String;
						null,//self.txtChqDate.getDate(),		//_chequeDate : Date;
						payMeth,						//_myPaymentMethod : CM_PaymentMethod;
						drTerm,							//_myDebtorTerminal : CM_DebtorTerminal;
						0								//_paymentType : Integer
						);
	
	voyage := self.myVoyage;
	
	//11/07/2024	navkc1 CR 64837 Task 64851
	if voyage &lt;&gt; null then
		voyCode := voyage.code;
	endif;
	
	if self.myBOL &lt;&gt; null then
		bolNumber := self.myBOL.number;
	else
		bolNumber := self.bolCode;
	endif;
	
	pxyCashRec.setPxyForBank(bank);
	
	pxyCashRec.setProxy2(voyCode,								// _cashId1
					 bolNumber,									// _cashId2
					 self.customsEntryNumber,//self.txtItemId1.text.trimBlanks(),			// _cashId3 // 14/05/2025	NAVKC1	JIRA MTN-34520
					 null, 										// _cashId4 : String
					 null,//self.txtCashPayment.text.asDecimalJMT,		// _payment1 : Decimal
					 null,//self.txtCashPayment2nd.text.asDecimalJMT,	// _payment2 : Decimal
					 self.effectiveDate,						// _effectiveDate : Date
					 null,
					 null,//self.txtPosReceipt.text.trimBlanks(),		//  _externalInvoiceNumber, _externalReferenceNumber : String
					 0,
					 0,
					 0,
					 0,
					 voyage,									// _myVoyage : CM_Voyage
					 self.myDebtorAgent,						// _agent
					 null,
					 self.myTerminal);
					 
	pxyCashRec.setTaxValues(self.taxValue1, self.taxValue2, self.taxValue3, self.taxCode1, self.taxCode2, self.taxCode3);
	
	if self.hasOnShip then
		pxyCashRec.setShipReleaseDate(self.shipReleaseDate);
	endif;
	
	newSeq := 1;
	
	foreach proformaAgent in self.allAgents do
		foreach invoiceLine in proformaAgent.allProformaInvLines do
			if not invoiceLine.manual then
				if invoiceLine.sequenceNum = Max_Integer then
					invoiceLine.invoice := null;		// to prevent the sequence number change being applied to an invalid .invoice property
					invoiceLine.sequenceNum := newSeq;	// to get unique ids for the CM_CashReceipt allProformaInvoiceLines dictionary
					newSeq := newSeq + 1;
					pxyCashRec.allProformaInvoiceLines.add(invoiceLine);
				endif;
			endif;	
		endforeach;
		
		if proformaAgent.myTrackedItem &lt;&gt; null then
			pxyCashRec.allTrackedItems.add(proformaAgent.myTrackedItem);
		endif;
	endforeach;
	
	//11/07/2024	navkc1 CR 64837 Task 64851
	pxyCashRec.setExternalFields(self.externalReceiptNumber, self.externalFinancialId, self.externalRef1, self.externalTransaction,
								self.externalUserCode, self.remarks); 
	
	self.myPxyCashReceipt := pxyCashRec;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setBalances" id="15d4b183-995e-4bc2-8e10-1d7b8b4ac3e8">
        <updating/>
        <source>setBalances() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	effectiveDate		: TimeStamp;
	taxValue,
	taxTotal,
	creditAvailable,
	creditUsed,
	cashTotal ,
	totalCargoCharges,
	chargeTax			: Decimal[23,6];
	taxCode 			: CM_TaxCode;
	count  				: Integer;
	drTerm				: CM_DebtorTerminal;
	taxRate				: CM_TaxRate;
	obj					: Object;
	cashPayment 		: CM_CashPayment;
	tax1Desc,
	tax2Desc,
	tax3Desc,
	taxCodeStr, 
	taxDescStr 			: String;
begin
	cashTotal 						 := 0;
	taxTotal  						 := 0;
	self.creditTotal 				 := 0;
	self.cashAlreadyPaid 			 := 0;
	self.cashRequiredToClearCharges  := 0;
	self.cashPaymentSecondary  	  	 := 0;
	self.taxValue1					 := null; 
	self.taxValue2					 := null; 
	self.taxValue3					 := null; 
	
	if self.showServiceTax then // Only blank these is using proper tax. If using GHANA tax these are ponly set once, when the screen is opened.
	
		self.taxCode1 := null;
		self.taxCode2 := null;
		self.taxCode3 := null;
	endif;

	foreach cashPayment in self.myPxyCashReceipt.allCashPayments discreteLock do
		if cashPayment.pxyIsProxy then // a real cash payment
			continue;
		endif;
		
		if cashPayment.status = self.StatusNotSelected then
			continue;
		endif;

		cashTotal := cashTotal + cashPayment.cashValue;
		
		totalCargoCharges := totalCargoCharges + cashPayment.cashValue; 
		
		
		
		if self.showServiceTax then
			taxDescStr := cashPayment.getTaxCode(true);
			taxCodeStr := cashPayment.getTaxCode(false);
			
			chargeTax := 0;
			if cashPayment.hasTax() then
				chargeTax    :=  cashPayment.myCashPaymentForTax.cashValue;
			endif;
			if self.taxValue1 = 0 then
				tax1Desc			 := taxDescStr;
				self.taxCode1 		 := taxCodeStr;
				self.taxValue1 	     := chargeTax;
				
			elseif tax1Desc = taxDescStr then
				self.taxValue1	     := self.taxValue1 + chargeTax;
				
			elseif self.taxValue2 = 0 then
				tax2Desc 			 := taxDescStr;
				self.taxCode2 		 := taxCodeStr;
				self.taxValue2 		 := chargeTax;
				
			elseif tax2Desc = taxDescStr then
				self.taxValue2 		 := self.taxValue2 + chargeTax;
				
			elseif self.taxValue3 = 0 then
				tax3Desc 			 := taxDescStr;
				self.taxCode3 		 := taxCodeStr;
				self.taxValue3 		 := chargeTax;
				
			elseif tax3Desc = taxDescStr then
				self.taxValue3 		 := self.taxValue3 + chargeTax;
			endif;
		endif;
		
	endforeach;
	
	if self.myDebtor &lt;&gt; null then
		drTerm := self.myDebtor.allDebtorTerminals[self.myTerminal];
		if drTerm &lt;&gt; null then
			creditAvailable  := drTerm.getCreditAmount();
			self.creditTotal := creditAvailable;
		endif;
	endif;
	
	// do tax unless debtor is zero-rated
	if self.myDebtor &lt;&gt; null 
	and not self.myDebtor.isZeroRatedTax 
	and not self.isVoyageExempt() then 
		effectiveDate := app.actualTimeServer;
		
		if self.showServiceTax then
			taxTotal := self.taxValue1 + self.taxValue2 + self.taxValue3;
		else
			foreach obj in self.allTaxCodes do
				count := count + 1;
				taxCode := obj.CM_TaxCode;
				taxRate := taxCode.getTimeRate(effectiveDate);
				if taxRate &lt;&gt; null then
					taxValue := ((totalCargoCharges * taxRate.rate) / 100);
					taxTotal := taxTotal + taxValue;
					if count = 1 then
						self.taxValue1 := taxValue;
					elseif count = 2 then
						self.taxValue2 := taxValue;				
					elseif count = 3 then
						self.taxValue3 := taxValue;		
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	self.cashRequiredToClearCharges := (totalCargoCharges + taxTotal);//.roundedTo(2); //27/06/2025 NAVKC1 JIRA 35258
	
	if creditAvailable &gt; 0 then
		if self.cashRequiredToClearCharges &gt;= creditAvailable then
			creditUsed := creditAvailable;
			self.cashRequiredToClearCharges := self.cashRequiredToClearCharges - creditAvailable;
		else
			creditUsed := self.cashRequiredToClearCharges;
			self.cashRequiredToClearCharges := 0;
		endif;
		self.cashAlreadyPaid := creditUsed;
		
	endif;
	
	self.cargoTotalCharges := totalCargoCharges; 
	self.calculateRounding();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setExternalFields" id="cc66e2de-af43-4512-ac77-c26fa3dc1ea6">
        <updating/>
        <source>setExternalFields(_externalRecNumber : String;
					_externalFinancialId : String;
					_externalRef1 : String;
					_externalTransaction : String;
					_externalUserCode : String;
					_remarks : String
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/07/2024	navkc1 CR 64837 Task 64851: Jade - New API putProformaForExternal

*/

vars

begin
	self.externalReceiptNumber := _externalRecNumber;
	self.externalFinancialId := _externalFinancialId;
	self.externalRef1 := _externalRef1;
	self.externalTransaction := _externalTransaction;
	self.externalUserCode := _externalUserCode;
	self.remarks := _remarks;
epilog

end;</source>
        <Parameter name="_externalRecNumber" type="String"/>
        <Parameter name="_externalFinancialId" type="String"/>
        <Parameter name="_externalRef1" type="String"/>
        <Parameter name="_externalTransaction" type="String"/>
        <Parameter name="_externalUserCode" type="String"/>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyCashReceiptAmounts" id="f6cfe4ae-8af8-45dc-9022-ab62b41156e0">
        <source>setProxyCashReceiptAmounts(_now : TimeStamp);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63405: Jade - REST API putProformaForVoyage

*/

vars
	requiredCash : Decimal[23,6];
begin
	requiredCash := self.cashRequiredToClearCharges;  // 25/07/2025	navkc1	JIRA MTN-35344
	
	self.myPxyCashReceipt.setPxyForPaymentDetails(	null,// self.txtChqBank.text,
													null,//self.txtChqBranch.text,
													null,//self.txtChqNumber.text,
													null,//self.txtChqDate.getDate(),
													//null//self.txtPosReceipt.text.trimBlanks() //11/07/2024	navkc1 CR 64837 Task 64851
													self.externalReceiptNumber //11/07/2024	navkc1 CR 64837 Task 64851
													);

	self.myPxyCashReceipt.setTaxValues(self.taxValue1, 
										self.taxValue2, 
										self.taxValue3, 
										self.taxCode1, 
										self.taxCode2, 
										self.taxCode3);

	self.myPxyCashReceipt.setRoundingDifference(self.roundingDifference);

	self.myPxyCashReceipt.setProxy2(self.myPxyCashReceipt.cashId1,
										self.myPxyCashReceipt.cashId2,
										self.myPxyCashReceipt.cashId3,	// 14/05/2025	NAVKC1	JIRA MTN-34520
										self.myPxyCashReceipt.cashId4, // 14/05/2025	NAVKC1	JIRA MTN-34520
										requiredCash,
										self.cashPaymentSecondary,
										self.myPxyCashReceipt.effectiveDate,
										null,
										self.myPxyCashReceipt.externalReceiptNumber,
										self.cargoTotalCharges,
										self.cashAlreadyPaid,
										self.cargoTotalCharges,
										requiredCash,
										self.myPxyCashReceipt.myVoyage,
										self.myPxyCashReceipt.myAgent,
										null, 
										self.myTerminal);
	
	self.myPxyCashReceipt.setDateTime(_now);
	
	self.myPxyCashReceipt.setCashValue(requiredCash); // 25/07/2025	navkc1	JIRA MTN-35344 - This set the CM_CashReceipt::cashValue to include all charges &amp; tax amount (to be the same as UI Cash Collection screen)
epilog

end;</source>
        <Parameter name="_now" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="shouldApplyAgent" id="34eab6b7-6420-4602-9ba1-559f5a63f575">
        <source>shouldApplyAgent(_ti : CM_TrackedItem; _agent : CM_Object) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	consignee		: CM_ConsigneeConsignor;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	child 			: CM_TrackedItem;
begin
	if _agent	&lt;&gt; null then	
	
		foreach child in _ti.allChildren do
			if not self.shouldApplyAgent(child, _agent) then
				return false;
			endif;
		endforeach;
	
		if self.myCashDebtorType.code = "SDT2" then
			consignee := _agent.CM_ConsigneeConsignor;
			return _ti.getConsigneeObject() &lt;&gt; consignee;
		elseif self.myCashDebtorType.code = "SDT3" then
			consignee := _agent.CM_ConsigneeConsignor;
			return _ti.getConsignorObject() &lt;&gt; consignee;
		elseif self.myCashDebtorType.code = "SDT4" then
			operator := _agent.CM_Operator;
			return _ti.myOperator &lt;&gt; operator;
		elseif self.myCashDebtorType.code = "SDT6" then
			customsAgent := _agent.CM_CustomsAgent;
			return _ti.myCustomsAgent &lt;&gt; customsAgent;
		elseif self.myCashDebtorType.code = "SDT7" then
			consignee := _agent.CM_ConsigneeConsignor;
			return _ti.myFreightForwarder &lt;&gt; consignee;
		// ### JIRA 33765 07JAN2025 NAVAB1
		elseif self.myCashDebtorType.code = "SDT1" then
			operator := _agent.CM_Operator;
			return _ti.myOperator &lt;&gt; operator;
		endif;
	endif;

	return false;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_agent" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldRound" id="1d7eae7f-fc6a-44c4-9362-ba365c764187">
        <source>shouldRound() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63397  Task 63398: Jade - New REST API getProformaAmountForVoyage

*/

vars
	bank			: CM_Bank;
	roundingType	: Integer;
begin
	if self.myPxyCashReceipt &lt;&gt; null then
		bank := self.myPxyCashReceipt.getBank();
	endif;
	
	roundingType := self.myTerminal.getCashRoundingType(bank);
	return roundingType &gt; 0;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
