end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e887fe8e-efad-4dd4-b7e6-cd5ea3b56a66">
        <updating/>
        <source>setProxy(pCode, pDescription : String; _notAvailableForEntry : Boolean; _debtor : CM_Debtor) updating;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 30/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code 			:= pCode[1:10];
	self.description 	:= pDescription[1:256];
	self.myRoot 		:= app.myRoot;
	self.notAvailableForEntry := _notAvailableForEntry;
	
	self.myDebtor		:= _debtor;				// TFS 44554
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="5a207af5-8dac-4ec6-aeb9-f06b76056a74">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allStevedores[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="32455abe-3698-4af8-82cb-4e736d90c62b">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
// ---------------------------------------------------------------------------
vars

	theStevedore : CM_Stevedore;
	terminal 	 : CM_Terminal;
	whereUsed : String;
	
begin
	
	//epr TFS 2227 its a system object have to check all terminalls
/*	foreach terminal in app.myRoot.allTerminals do
		theStevedore := terminal.getConfig(DefStevedore).CM_Stevedore;
		if theStevedore = self then
			app.raiseCMException3(ERR_USED_IN_CONFIG,"Stevedore", self.code,"Terminal " &amp; terminal.code,null, null);
			return;
		endif;
	endforeach; */

	if not self.allHMSVoyageDataDischarge.isEmpty  or not self.allHMSVoyageDataLoad.isEmpty then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "HMS Voyage Data", null, null);
	endif;
	
	if not self.allBookingRefs.isEmpty then    //02.10.2020 cnwma1 TFS #50112
		app.raiseCMException2(ObjectStillHasEntries, self.code, app.getErrorString(Bookings), null, null);
	endif;
	
	if not self.allVVRS.isEmpty then    //02.10.2020 cnwma1 TFS #50112
		app.raiseCMException2(ObjectStillHasEntries, self.code, app.getErrorString(Vehicle_visit_record), null, null);
	endif;
	
	if not self.allTrainsReceive.isEmpty then    //02.10.2020 cnwma1 TFS #50112
		app.raiseCMException2(ObjectStillHasEntries, self.code, app.getErrorString(Train), null, null);
	endif;
	
	if not self.allTrainsRelease.isEmpty then    //02.10.2020 cnwma1 TFS #50112
		app.raiseCMException2(ObjectStillHasEntries, self.code, app.getErrorString(Train), null, null);
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="7620e214-e77e-4491-9ff0-179a50032e68">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="8e3efb14-4a30-41e0-ab4f-5bd411b155d0">
        <source>validateMe() protected;

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Stevedore Code', null, null);
		app.raiseCMException(Input_required_field_stevCode, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Stevedore Description', null, null);
		app.raiseCMException(Input_required_field_stevDesc, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
