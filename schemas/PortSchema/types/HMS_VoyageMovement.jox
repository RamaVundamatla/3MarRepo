    <JadeMethod name="getInaportnetBerthsStartEnd" id="46ebdff1-6ee1-48f7-badc-23672ef97ba0">
        <source>getInaportnetBerthsStartEnd(_start , _end : String output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2018	jlger1	Initial creation

*/

vars

begin
	if self.myBerthPrevious = null or self.myBerthPrevious.code.toUpper = "SEA"
		or self.myBerthPrevious.code = "LAUT" or self.myBerthPrevious.description = "LAUT" then
		_start:="LAUT";
	else
		_start:=self.myBerthPrevious.externalReference2;
	endif;
	
	if self.myBerth = null or self.myBerth.code.toUpper = "SEA"  
		or self.myBerth.code = "LAUT" or self.myBerth.description = "LAUT" then
		_end:="LAUT"; //sea i think
	else
		_end:=self.myBerth.externalReference2;	
	endif;
	
epilog

end;</source>
        <Parameter name="_start" type="String" usage="output"/>
        <Parameter name="_end" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getInaportnetKegiatan" id="1de2f1eb-051c-41ed-9b68-6316909edc5d">
        <source>getInaportnetKegiatan() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2018	jlger1	Initial creation 39322

*/

vars

begin	
	if self.isArrival then
		return "Masuk";
	elseif self.isMovementTypeShift then
		return "Pindah";
	elseif self.isMovementTypeDeparture then
		return "Keluar";
	endif;
	//Labuh is anchored @ sea don't think we ever return this
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
