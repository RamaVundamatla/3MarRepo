    <JadeMethod name="displayError" id="013ba98a-9f6c-4b7c-938c-544ebc422248">
        <source>displayError(pError : CM_Error) : String;
// ---------------------------------------------------------------------------
// Created:     26 March 2001 by cnwrs2
//
// Purpose:     Put in a seperate function so exception handler can do Ex_REsume_Next
//				if an invalid error object is encountered (ie. has been deleted).
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	errStr	: String;

begin

	if pError.text = null then
		errStr := 'Unknown error ' &amp; pError.errorCode.String;
	else
		errStr := pError.text;
	endif;

epilog
	return errStr;
	
end;</source>
        <Parameter name="pError" type="CM_Error"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayRowExceptionHandler" id="be05935c-cd0d-444e-aaae-91e098397536">
        <source>displayRowExceptionHandler(exObj : Exception) : Integer;
// ---------------------------------------------------------------------------
// Created:     26 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if exObj.errorCode = 4 then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFloating" id="33fa9670-1b04-4e49-864d-ee13b0becf4a">
        <updating/>
        <source>doFloating() updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.lockType	:= LockType_Floating;
	
	self.controlBox	:= true;
	self.maxButton	:= true;
	self.minButton	:= true;
	self.caption	:= 'Errors and Warnings';
	
	mnuFloating.checked		:= true;
	mnuLockBottom.checked 	:= false;
	mnuLockLeft.checked 	:= false;
	mnuLockRight.checked 	:= false;
	
	self.savedTop := self.top;

end;</source>
    </JadeMethod>
    <JadeMethod name="doLockBottom" id="cc95615d-ddb3-4623-80d2-86100923af47">
        <updating/>
        <source>doLockBottom() updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theFrame	: Form;
	frameHeight	: Real;

begin

	self.lockType	:= LockType_Bottom;

	theFrame := self.getMdiFrame();
	if theFrame.isKindOf(CMUI_SuperAppForm2) then
		frameHeight := theFrame.CMUI_SuperAppForm2.clientWindowHeight;
	else
		frameHeight := theFrame.clientHeight;
	endif;

	self.left	:= 0;
	self.height	:= 100;
	self.top	:= frameHeight - self.height;
	self.width	:= theFrame.clientWidth;
	
	mnuFloating.checked		:= false;
	mnuLockBottom.checked 	:= true;
	mnuLockLeft.checked 	:= false;
	mnuLockRight.checked 	:= false;
	
	self.savedTop := self.top;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doLockLeft" id="1741963f-072d-499f-ba16-a0d7a3201092">
        <updating/>
        <source>doLockLeft() updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theFrame	: Form;
	frameHeight	: Real;

begin

	self.lockType	:= LockType_Left;

	theFrame := self.getMdiFrame();
	if theFrame.isKindOf(CMUI_SuperAppForm2) then
		frameHeight := theFrame.CMUI_SuperAppForm2.clientWindowHeight;
	else
		frameHeight := theFrame.clientHeight;
	endif;

//	self.controlBox	:= false;
//	self.maxButton	:= false;
//	self.minButton	:= false;
//	self.caption	:= null;
	
	self.left	:= 0;
	self.height	:= 100;
	self.top	:= frameHeight - self.height;
	self.width	:= 200;
	
	mnuFloating.checked		:= false;
	mnuLockBottom.checked 	:= false;
	mnuLockLeft.checked 	:= true;
	mnuLockRight.checked 	:= false;
	
	self.savedTop := self.top;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doLockRight" id="598012fb-f7bd-4948-baa0-173ca5ec0cf2">
        <updating/>
        <source>doLockRight() updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theFrame	: Form;
	frameHeight	: Real;
	frameWidth : Real;
begin

	self.lockType	:= LockType_Left;

	theFrame := self.getMdiFrame();
	if theFrame.isKindOf(CMUI_SuperAppForm2) then
		frameHeight := theFrame.CMUI_SuperAppForm2.clientWindowHeight;
		frameWidth := theFrame.CMUI_SuperAppForm2.clientWidth;
	else
		frameHeight := theFrame.clientHeight;
		frameWidth := theFrame.clientWidth;
	endif;

//	self.controlBox	:= false;
//	self.maxButton	:= false;
//	self.minButton	:= false;
//	self.caption	:= null;
	self.height	:= 100;
	self.width	:= 200;
	self.top	:= frameHeight - self.height - 25;
	self.left	:=  frameWidth - 200;
	
	mnuFloating.checked		:= false;
	mnuLockBottom.checked 	:= false;
	mnuLockLeft.checked 	:= false;
	mnuLockRight.checked 	:= true;

	self.savedTop := self.top;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="aae2c8a1-987f-40ec-a6e6-4802f4004c83">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	tblData.width := self.clientWidth - 2;
	tblData.accessColumn(1).width := tblData.width.Integer;
	
	tblData.cnEcResizeContents();

end;</source>
    </JadeMethod>
