// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
		
begin

	self.allowMultiSelectEdit := false;	
	self.setTblDataEntRows(ETDef_ProductThumb);
	
	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_Code, false);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initFilterTable" id="e30ff3fb-c847-423a-bda3-57474b09ca5c">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;
	cargoType		: CM_CargoType;
	op				: CM_Operator;
	handlingType	: CM_HandlingType;
begin
	theTable	:=	self.tblSearch;
	entTableDef	:=	app.myController.getEntTableDef(ETDef_FilterProduct);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(200);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef FullReleaseFind not found');
	endif;
	
	cargoType := self.cmbFiltCargoType.listObject.CM_CargoType;
	
	if cargoType &lt;&gt; null then
		theTable.setValueByName(ETRow_CargoType, cargoType.description);
	endif;
	
	op := self.cmbFiltOperator.listObject.CM_Operator;
	
	if op &lt;&gt; null then
		theTable.setValueByName(ETRow_Operator, op.code &amp; '  ' &amp; op.description);
	endif;
	
	handlingType := self.cmbFiltHandling.listObject.CM_HandlingType;
	
	if handlingType &lt;&gt; null then	
		theTable.setValueByName(ETRow_HandlingType, Any_String);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="896d5869-1944-40fc-b59c-d3a6902fc568">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.sptMainRatioSaved = 0 then
		self.sptMainRatioSaved := 60;
	endif;

	self.showFilterOnStartup	:=	true; 	// Show the filter frame
	self.showDataOnStartup		:=	false; 	// Do not populate the data table with data
	self.allowPrint				:=	false;
	self.allowExportCSV			:=	false;
	self.useNumRowsShown		:=	true;
	self.tblData.autoSize		:=	Table.AutoSize_Column;
	self.setMyDataClass();

	self.initTblThumb();
	self.initTblEntDetail();
	self.initTblAttributes();
	self.initTblEntCode();
	self.initTblCodeData();
	
	self.cmbValidation.automaticCellControl	:=	true;
	self.loadCombos();

	self.allowTblDataSearch	:=	true;
end;</source>
    </JadeMethod>
