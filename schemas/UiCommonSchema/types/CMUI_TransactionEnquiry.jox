    <JadeMethod name="doFilterTable" id="2c12fc01-47d1-431c-97f6-2ba8ffb8c7cf">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2022	navvt20	ChangeRequest 54616: MTN - Transaction List Filter

*/

vars
	filterText 	: String;
	rowIdx,
	colIdx,
	start,
	rows		: Integer;
	cell 		: JadeTableCell;
	cellText 	: String;
	tbl			: CM_DataTable;
begin
    /* //23/04/2024	navkc1 CR63736 Task 63770
	rows := 0;
	filterText  := self.txtFilterBox.text.toUpper();
	
	if self.mode = self.Mode_CargoItem_Enquiry then
		tbl := self.tblTrans;
	else
		tbl	:= self.tblTransactions;
	endif;
	
	if filterText = "" then
		self.clearFilter();
		self.doRefresh();
		return;
	else
		self.btnClearFilter.enabled := true;
	endif;

	start := tbl.fixedRows + 1;
	
	foreach rowIdx in start to tbl.rows do : rowLoop
		tbl.accessRow(rowIdx);
		
		foreach colIdx in 1 to tbl.columns do
			cell 	 := tbl.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				tbl.accessedRow.visible := true;
				rows := rows+1;
				continue rowLoop;
			endif;
		endforeach;
		
		tbl.accessedRow.visible := false;
	endforeach;
	*/ //23/04/2024	navkc1 CR63736 Task 63770
	
	rows := self.frmTableFilter.numOfRowVisible; //05/06/2024	navkc1 CR 63736 Task 63770
	
	self.staLine.caption := rows.String &amp; ' rows found.';
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadMergeSplitTransaction" id="a7bc25f9-e596-4857-af45-f76e42a766b8">
        <source>doLoadMergeSplitTransaction(_trans : CM_TITransaction; _listbox : CMUI_ListBox);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/05/2013	cnwdap1		Initial creation CCMS 2274 Split/Merge Break Bulk Cargo
//
vars
	otherTi : CM_TrackedItem;
	trans, otherTxn  : CM_TITransaction;
	listbox : CMUI_ListBox;
	disp : String;
	level : Integer;
	startingTIs : CM_TISet;
	str, deleteStr : String;
	 	
begin

	//26 May 2021	NDL	TFS 51243
	if _trans.isKindOf(CM_Blend) then
		if not _trans.CM_Blend.allChildBlendTrxs.isEmpty then
			foreach otherTxn in _trans.CM_Blend.allChildBlendTrxs do	
				str := otherTxn.getSpecialListBoxString;
				_listbox.addItem(str);
				_listbox.itemLevel[_listbox.newIndex] := 1;
			endforeach;	
		endif;
		return;
	endif;

	if _trans.isKindOf(CM_Split) then
		otherTi := _trans.CM_Split.getOtherTrackedItem;
		otherTxn:=_trans.CM_Split.getOtherSplit;
	elseif _trans.isKindOf(CM_Merge) then
		otherTi := _trans.CM_Merge.getOtherTrackedItem;
		otherTxn:=_trans.CM_Merge.getOtherMerge();
	endif;
	if otherTi = null then
		return;
	endif;
	
	listbox := _listbox;
	level := 1;
	create startingTIs transient;
	startingTIs.add(_trans.myTrackedItem);
	otherTi.getTransForSplitMergeDisplay(level, listbox, startingTIs,otherTxn);
epilog
	delete startingTIs;
end;</source>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_listbox" type="CMUI_ListBox"/>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="cf676365-f4d5-4fc5-bfdb-740f5614ad55">
        <updating/>
        <source>doMnuColumnOrganiserClick(menuItem : MenuItem) protected, updating;
// 25/10/2016    cnwma1 TFS # 2820:PAR38298 STWO-Transaction menu system fault
vars
	rowsTrans,rowTransactions : EntTableRowArray;
	entRow : EntTableRow;
begin
	create rowsTrans transient;													  // 25/10/2016 cnwma1 TFS #2820 PAR #38298
	foreach entRow in self.tblTrans.allTblDataEntRows where  entRow.visible do    // 25/10/2016 cnwma1 TFS #2820 PAR #38298
		rowsTrans.add(entRow);
	endforeach;
	
	if menuItem.userObject = self.tblTrans then	//28 Apr 2016	NDL	TFS 1903 
		//self.tblTrans.showColumnOrganiserFrm(self.myTerminal, self.tblTrans.allTblDataEntRows);   // 25/10/2016 cnwma1 TFS #2820 PAR #38298
		self.tblTrans.disallowColumnSorter := true;													// 25/10/2016 cnwma1 TFS #2820 PAR #38298
		self.tblTrans.showColumnOrganiserFrm(self.myTerminal, rowsTrans);
	else
		self.tblTransactions.showColumnOrganiserFrm(self.myTerminal, self.tblTransactions.allTblDataEntRows);
	endif;
epilog
	delete rowsTrans;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuEditTransferType" id="62ffdd72-7ccd-4f2a-a8a3-798641b2636f">
        <source>doMnuEditTransferType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers
*/

vars
	txn    : CM_TITransaction;
	recTxn : CM_ReceiveShip;
	relTxn : CM_ReleaseShip;
	transferType: Integer;
	allSelectedObjects : ObjectArray;
begin
	
	
	if self.mode = self.Mode_CargoItem_Enquiry then
		allSelectedObjects:=self.tblTrans.allSelectedObjects;
	else
		allSelectedObjects:=self.tblTransactions.allSelectedObjects;
	endif;
	
	if allSelectedObjects.isEmpty then
		return;
	endif;
	
	if allSelectedObjects.size &gt; 1 and not self.canMultiEdit()  then	
		return;
	endif;
	
	txn := allSelectedObjects.first.CM_TITransaction;
	
	if txn.isKindOf(CM_ReceiveShip) then
		recTxn:=txn.CM_ReceiveShip;
		transferType := recTxn.transferType;
	elseif txn.isKindOf(CM_ReleaseShip) then
		relTxn:=txn.CM_ReleaseShip;
		transferType := relTxn.transferType;
	endif;
	
	self.doCmbTransferTypeBuild();
	self.frmTransferType.visible:=true;
	self.frmTransferType.centreWindow();
	self.frmTransferType.zOrder(1);		
	self.cmbTransferType.listIndex := self.cmbTransferType.findObject(app.myRoot.allVoyageJobTransferTypes[transferType]);	
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuEditTransferTypeSave" id="eabff700-2eda-489b-be23-8920bd20ab92">
        <updating/>
        <source>doMnuEditTransferTypeSave()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers

*/

vars
	transferType,
	tranType			: Integer;
	allSelectedObjects 	: ObjectArray;
	txnController 		: CMIF_TITransactionController;
	obj 				: Object;
	result 				: Integer;
begin
	
	
	if self.mode = self.Mode_CargoItem_Enquiry then
		allSelectedObjects:=self.tblTrans.allSelectedObjects;
	else
		allSelectedObjects:=self.tblTransactions.allSelectedObjects;
	endif;
	
	if allSelectedObjects.isEmpty then
		return;
	endif;
	
	tranType 	 := allSelectedObjects.first.CM_TITransaction.type;
	transferType := self.cmbTransferType.listObject.CM_VoyageJobTransferType.id; 
	global.createTxnControllerForType(tranType, txnController);
	
	txnController.myTerminal			:= self.myTerminal;
	txnController.transferType          := transferType;
	txnController.userGenerated 		:= true;
	txnController.hasBeenUpdated		:= true;
	
	foreach obj in allSelectedObjects do
	
	 txnController.myTrackedItem := obj.CM_TITransaction.myTrackedItem;
	 txnController.dateTime      := obj.CM_TITransaction.dateTime;
	 txnController.noCharge      := obj.CM_TITransaction.noCharge;
		while true do
		
			app.myTrxUA.trxUpdateTITransaction(txnController, obj.CM_TITransaction, app.myPassport);
				
			
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog('Transaction Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
	
				self.setAllErrorWarnings(app.myPassport);
			endif;
			return;
		endwhile;
	endforeach;
epilog
	delete txnController;
	self.frmTransferType.visible := false;
end;</source>
    </JadeMethod>
