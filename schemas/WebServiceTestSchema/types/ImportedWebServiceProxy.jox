<Class name="ImportedWebServiceProxy" id="02df9557-7a50-4776-b5ce-293e6e5bc85d">
    <superclass name="Object"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="handleEnumFault" id="f62d36de-958f-4537-b866-8cfab2967267">
        <source>handleEnumFault(_exc : JadeSOAPException) : Integer protected;
/*

Purpose:			Handle a JADE enumb fault during setting a property 

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlgkpd1	Initial creation

*/

vars

begin
	if _exc.errorCode = JADEWS_ENUM_FAULT then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="JadeSOAPException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateSubObjects" id="22639500-d2ee-4e12-801e-a7760c37302e">
        <updating/>
        <source>populateSubObjects( _allPropertyNames : StringArray;
				   _allPropertyValues : StringArray;
				   _createdObjects : ObjectSet input) updating;

/*

Purpose:			Populate the receiver with any public local subobjects, and populate every 
					collection with at least one subobject.
					

Return Value:		Self updated.
					Also add all the transients created to _createdObjects, so they can be tidied up
					by the caller.


Date		Who		Reason
18 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service
08 Nov 2017	jlgkpd1	Handle non JADE Web Services
27 Mar 2019 jlger1	TFS 44093 - changes to allow request params to be set
*/

vars
	props			: PropertyColl;
	property		: Property;
	propName		: String;
	propValue		: Any;
	obj				: ImportedWebServiceProxy;
	memberType		: Type;
	coll			: Collection;
	stringValue		: String;
	binaryValue		: Binary;
	idx 			: Integer;
begin
	on JadeSOAPException do self.handleEnumFault(exception);
	
	props := self.class.allProperties;
	foreach property in props where property.access = null do		// only public properties
		
		propName := property.name;
		if propName[1:1] = "_" then
			continue;
		endif;
		
		if property.type.isKindOf(CollClass) then					// Assume collections are exclusive
			
			memberType := property.type.CollClass.memberType;
			propValue := self.getPropertyValue(propName);
			coll := propValue.Collection;
			
			if memberType.inheritsFrom(ImportedWebServiceProxy) then
				create obj as memberType.Class transient;
				_createdObjects.add(obj);
				
				obj.populateSubObjects(_allPropertyNames,_allPropertyValues,_createdObjects);
				coll.add(obj);
			else
				coll.add(null);										// Not applicable type, just add a null entry
			endif;

		elseif property.type.inheritsFrom(ImportedWebServiceProxy) then

			create obj as property.type.Class transient;
			_createdObjects.add(obj);
			
			obj.populateSubObjects(_allPropertyNames,_allPropertyValues, _createdObjects);
			self.setPropertyValue(propName, obj);
		
		elseif property.type.isKindOf(PrimType) then
			// Set a default value for each string property
			stringValue := " ";
			if _allPropertyNames &lt;&gt; null and 
				_allPropertyNames.includes(property.name) then
				idx:=_allPropertyNames.indexOf(property.name);
				stringValue:=_allPropertyValues[idx];
			endif;
			if property.type = String then			
				self.setPropertyValue(propName, stringValue);
			elseif property.type = Integer then
				self.setPropertyValue(propName, stringValue.Integer);
			elseif property.type = Boolean then
				self.setPropertyValue(propName, stringValue.Boolean);
			elseif property.type = Decimal then
				self.setPropertyValue(propName, stringValue.Decimal);
			elseif property.type = Real then
				self.setPropertyValue(propName, stringValue.Real);
			endif;

		elseif property.type.name = Binary.name then
			
			// Set a default value for each binary property
			binaryValue := " ".Binary;
			
			self.setPropertyValue(propName, binaryValue);
		else
			
			
		endif;
	endforeach;
	
	
epilog
	delete props;
		
end;
</source>
        <Parameter name="_allPropertyNames" type="StringArray"/>
        <Parameter name="_allPropertyValues" type="StringArray"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
</Class>
