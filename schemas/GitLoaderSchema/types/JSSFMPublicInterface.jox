    <JadeMethod name="showBackgroundMonitor" id="9f3a8b4b-48c4-4a97-9cba-68c090bcdb36">
        <source>showBackgroundMonitor(pIsModal:Boolean; pMDIChildFlag:Integer);
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad2
//
// Purpose:		Invokes a Background Copy Monitor form, with which background file/
//				directory copies can be monitored for progress or to stop tasks.
//
// Parameters:	pIsModal - A flag to indicate whether the File Browser should be
//					shown modally.
//				pMDIChildFlag - A numeric flag to indicate whether the File Browser
//					window will be created as an MDI child or not.  Refer to the
//					Online JADE Help for a list of the Form class constants for
//					the "mdiChild" attribute.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myServiceObject.sendMsgWithParams(method.name, pIsModal, pMDIChildFlag);
end;</source>
        <Parameter name="pIsModal" type="Boolean"/>
        <Parameter name="pMDIChildFlag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showFileBrowser" id="3113c085-1990-46f4-950d-ba5ae23b1182">
        <source>showFileBrowser(pIsModal:Boolean; pMDIChildFlag:Integer);
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad2
//
// Purpose:		Invokes a GUI file browser interface, with which files and directories
//				can be manually maintained.
//
// Parameters:	pIsModal - A flag to indicate whether the File Browser should be
//					shown modally.
//				pMDIChildFlag - A numeric flag to indicate whether the File Browser
//					window will be created as an MDI child or not.  Refer to the
//					Online JADE Help for a list of the Form class constants for
//					the "mdiChild" attribute.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myServiceObject.sendMsgWithParams(method.name, pIsModal, pMDIChildFlag);
end;</source>
        <Parameter name="pIsModal" type="Boolean"/>
        <Parameter name="pMDIChildFlag" type="Integer"/>
    </JadeMethod>
</Class>
