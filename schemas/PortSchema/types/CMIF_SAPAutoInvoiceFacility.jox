    <JadeMethod name="copyToRealWSObject" id="1bad77d7-58ce-491e-9d01-cbd922a4f6b4">
        <source>copyToRealWSObject(_realRequest: SAP13_AutocollInvoiceRequest_DT_T_Facility_Item input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.dataSource := self.dataSource;
	_realRequest.facilityID := self.facilityID;
	_realRequest.facilityName := self.facilityName;
	_realRequest.flag1 := self.flag1;
	_realRequest.invoiceID := self.invoiceID;
	_realRequest.itemNo := self.itemNo;
	_realRequest.prodCode := self.prodCode;
	_realRequest.qTYRealization := self.qTYRealization;
	_realRequest.uOM := self.uOM;

epilog

end;</source>
        <Parameter name="_realRequest" type="SAP13_AutocollInvoiceRequest_DT_T_Facility_Item" usage="input"/>
