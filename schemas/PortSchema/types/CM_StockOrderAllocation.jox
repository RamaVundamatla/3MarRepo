        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>
Indicates the allocation type.  One of the class constants

AllocType_Quantity	0	The value is the allocated amount
AllocType_All		1	All of the row is allocated to this
AllocType_Remaining	2	The remainder of the row is allocated to this</text>
    </PrimAttribute>
