<Class name="AtcgCellMate" id="1486c7b5-abfb-4151-98ad-e889c47bf565">
    <superclass name="AtcgCommonEntity"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="JtdCommon"/>
    <PrimAttribute name="column" id="78cf88af-aa18-4a3a-8a85-475d4776a433">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="control" id="0c88eeb3-d1d3-4d39-b440-6183a29f2406">
        <embedded/>
        <type name="Control"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="form" id="b27c09ba-13a3-4010-a8ac-1a6d7a3d8387">
        <embedded/>
        <type name="Form"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="meth" id="e76a936d-842c-42fe-b9bb-5e3b34f57e2c">
        <embedded/>
        <type name="Method"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="receiver" id="bb18a695-40ea-4ca9-97db-e1322f3f284d">
        <embedded/>
        <type name="Object"/>
    </ImplicitInverseRef>
    <PrimAttribute name="row" id="834747ed-3a6a-416e-865e-303af59dffaa">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="table" id="1992d41f-bcbb-4ec0-aed9-b69dd18ed749">
        <embedded/>
        <type name="Table"/>
    </ImplicitInverseRef>
    <PrimAttribute name="text" id="54a6353b-0214-421b-a5ce-6fa107d0077e">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getName" id="59e2fe93-2c8f-40af-8512-ec5bdbddfed1">
        <source>getName():String;

vars
	s,t:String;
begin
	if app.isValidObject(form) then
		s:=s&amp;"form="&amp;form.name;
	else
		s:=s&amp;"form="&amp;form.String;
	endif;
	
	if app.isValidObject(table) then
		s:=s&amp;" table="&amp;table.name&amp;"("&amp;table.String&amp;")";
	else
		s:=s&amp;" table="&amp;table.String;
	endif;
	
	if app.isValidObject(control) then
		s:=s&amp;" control="&amp;control.name&amp;"("&amp;control.String&amp;")";
	else
		s:=s&amp;" control="&amp;control.String;
	endif;
	
	if app.isValidObject(meth) then
		s:=s&amp;" meth="&amp;meth.name;
	else
		s:=s&amp;" meth="&amp;meth.String;
	endif;
	
	s:=s&amp;" receiver="&amp;receiver.String&amp;" row="&amp;row.String&amp;" column="&amp;column.String&amp;" text="&amp;text;
	return s;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
