    <JadeMethod name="getValueForObject" id="fc54f457-fab4-4a0f-bd2a-a12699409bfe">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
// ---------------------------------------------------------------------------
// Created:	28 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
vars
	trackedItem : CM_TrackedItem;
	debtorTypeCode : String;
	debtorType : CM_Debtor;
begin
	if  _obj.isKindOf(CM_TrackedItem ) then
		debtorTypeCode := self.propertyName[6:end]; // Remove "DT - " prefix
		return _obj.CM_TrackedItem.allDebtorsByType[debtorTypeCode];
	else
		return inheritMethod(_obj,_op);
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
