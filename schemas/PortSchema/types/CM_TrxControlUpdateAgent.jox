    <JadeMethod name="trxUpdateYATemplate" id="4a5e5dcb-80fb-41a6-aab4-8261eb695cec">
        <updating/>
        <source>trxUpdateYATemplate(_proxyYATemplate: CM_YATemplate input;
						_proxyCriterias: CMIF_Array;
						_yATemplate: CM_YATemplate io;
						_passport : CM_Passport input) updating;
vars
	yardAllocation: CM_YardAllocation;
	expectedEdition	: Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_proxyYATemplate.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	beginTransaction;

	_proxyYATemplate.pxyGetRealObjectAndEdition(_yATemplate, expectedEdition);
	if _yATemplate = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_YATemplate.name, null, null);
		return;
	endif;
	
	reserveLock(_yATemplate);
	
	if _passport.noErrors() and _yATemplate.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "Yard Allocation Template", null, null);
		return;
	endif;
	
	yardAllocation := _proxyYATemplate.myYardAllocation.pxyGetRealObject();
	app.myUtilityUA.utlUpdateYardAllocation(_proxyYATemplate.myYardAllocation, _proxyCriterias, yardAllocation, _passport);
	if _passport.noErrors() then
		app.myUtilityUA.utlUpdateYATemplate(_proxyYATemplate, _yATemplate, _passport);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyYATemplate" type="CM_YATemplate" usage="input"/>
        <Parameter name="_proxyCriterias" type="CMIF_Array"/>
        <Parameter name="_yATemplate" type="CM_YATemplate" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateYardAllocation" id="0dbedd72-4294-4850-a717-59896480150e">
        <updating/>
        <source>trxUpdateYardAllocation(pProxyObj:CM_YardAllocation;
						pAllTransientCriteriaObj:CMIF_Array;
						_passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		26 April 2005 by cnwdad1
//
// Purpose:		Persists a Yard Allocation, and an array of transient Criteria objects,
//				and their data values.
//
// Parameters:	pProxyObj - A reference to a proxy Yard Allocation object.
//				pAllTransientsObj - A reference to an array of transient objects,
//					each of which represent either a Criteria or a Priority. There
//					should never be a mix of the two.
//				_passport - A reference to the user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 18 July 08	DJW			Refactor to put update code in utlUpdateYardAllocation CCMS 1030
// 20/04/2023	navkc1		Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
// --------------------------------------------------------------------------------
vars
	cmifObject			: CMIF_Object;
	transientObj		: CMIF_YACriteriaPriority;
	proxyObj			: CM_YACriteriaPriority;
	priorityValue		: Real;
	sortValue			: Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
	yardAllocationObj	: CM_YardAllocation;
	expectedEdition		: Integer;
	aTA : CM_TerminalArea;
	tmpTerm : CM_Terminal;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	pProxyObj.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	// Now calculate the Yard Allocation priority values on the proxy objects, working
	// backwards from the least important.
	
	sortValue	:=	0;
	
	foreach cmifObject in pAllTransientCriteriaObj reversed do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		
		if transientObj.isDeleted then
			continue;
		endif;
		
		proxyObj		:=	transientObj.myProxy;
		priorityValue	:=	2 ^ sortValue;
		proxyObj.setPriorityValue(priorityValue);
		sortValue		:=	sortValue + 1;
	endforeach;
	
	beginTransaction;

	pProxyObj.pxyGetRealObjectAndEdition(yardAllocationObj, expectedEdition);
	if yardAllocationObj = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_YardAllocation.name, null, null);
		return;
	endif;
	
	reserveLock(yardAllocationObj);
	
	if _passport.noErrors() and yardAllocationObj.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "Yard Allocation", null, null);
		return;
	endif;

	app.myUtilityUA.utlUpdateYardAllocation(pProxyObj, pAllTransientCriteriaObj, yardAllocationObj, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxyObj" type="CM_YardAllocation"/>
        <Parameter name="pAllTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateYardInternalDeliveryR" id="e6b798bf-2d0b-4cc2-8cd1-0513656ef925">
