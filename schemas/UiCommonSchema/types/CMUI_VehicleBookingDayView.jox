    <JadeMethod name="unload" id="794d047b-7772-4857-8a59-dfeed9491cbd">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jan 2023 navma1	Bug 62011: MTN - Error 1066 while using Vehicle booking Screen
*/

vars
	term 				: CM_Terminal;
	vbsProcess  		: CM_VBSProcess;
	isSlotValidation    : Boolean;
	
begin

	term := self.myTerminal;																	
	if term &lt;&gt; null  then																		//10.01.2023 navma1 #62011
		vbsProcess := self.myTerminal.getMyVBSProcess;
		if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation() then
			isSlotValidation := true;
		endif;
	endif;
	
	if not isSlotValidation then															    //10.01.2023 navma1 #62011
		self.endClassNotification(CM_VehicleBookingTimeSlot, false, Object_Create_Event);
		self.endClassNotification(CM_VehicleBookingTimeSlot, false, Object_Update_Event);
		self.endClassNotification(CM_VehicleBookingTimeSlot, false, Object_Delete_Event);
	endif;
	
	
	if self.timerSet then
		self.endTimer(1);
		self.timerSet := false;
	endif;
	
	if self.myEntTableDef &lt;&gt; null then
		delete self.myEntTableDef;
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
