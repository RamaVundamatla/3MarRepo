<Class name="JadeScriptPWGC" id="591ec3b8-b609-4679-94d2-cece5b4d6bdf">
    <superclass name="JadeScriptPW"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="pwCheckDbFileFreeSpace" id="c8247098-2fe5-47f1-928d-06cdd004414e">
        <source>pwCheckDbFileFreeSpace();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2025	navpw1	Initial creation

*/

constants
	FreeGBThreshold : Integer = 1;
	
vars
	dbFile				: DbFile;
	free				: Decimal[20];
	mapFileNames,
	mapFilesToSkip		: StringArray;
	logFile				: File;
	logFileName			: String;
	freeSpaceGb			: Real;
	
begin
	create mapFileNames transient;
	//mapFileNames.add("audit");
	//mapFileNames.add("edi");
	//mapFileNames.add("information");
	//mapFileNames.add("externdb");
	//mapFileNames.add("infoEDISent");
	
	create mapFilesToSkip transient;
	mapFilesToSkip.add("_jadedef");
	mapFilesToSkip.add("K_Advisory");
	
	logFileName := app.dbPath;
	logFileName := logFileName[4:end];		// get rid of drive stuff
	logFileName := logFileName[1:logFileName.pos("\", 1) - 1];

	create logFile transient;
	logFile.openOutput("c:\temp\" &amp; logFileName &amp; "_free_space.txt");
	
	write "Checking free space for map files " &amp; mapFileNames.concatenate(" ");

	foreach dbFile in DbFile.instances where mapFileNames.isEmpty or mapFileNames.includes(dbFile.name) do
		if mapFilesToSkip.includes(dbFile.name) then
			continue;
		endif;
		
		write "Processing file " &amp; dbFile.name;
		
		dbFile.changeAccessMode(DbFile.Mode_ReadOnly);
        dbFile.getFreeSpace(free);
        dbFile.changeAccessMode(DbFile.Mode_Update);
		
		if free &gt; 0 then
			freeSpaceGb := free / 1000000000;
		endif;
		
		if (freeSpaceGb &gt; 0 and freeSpaceGb &gt; FreeGBThreshold) and free &gt; 0 then
			logFile.writeLine(dbFile.name &amp; Tab &amp; freeSpaceGb.String &amp; Tab &amp; free.String);
		endif;
		
	endforeach;
	
	write "Finished";
	
	
epilog
	delete mapFileNames;
	delete logFile;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="pwCompactDBFiles" id="04a1ac97-9389-4da9-8dab-5f8cb123f059">
        <source>pwCompactDBFiles();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2025	navpw1	Initial creation

*/

vars
	dba				: JadeDatabaseAdmin;
	dbFile			: DbFile;
	dbFiles			: DbFileArray;
	
	files			: StringArray;
	
begin
	// Setup list of files to compact here
	create files transient;
	files.add("audit");
	files.add("unitTest");
	files.add("hmsTrans");
	files.add("jssct_changes");
	files.add("vesselStructures");
	files.add("cams_udr");
	files.add("voyageStructures");
	files.add("jssct_default");
	files.add("_userscm");
	files.add("slotctrl");
	files.add("invoice");
	files.add("location");
	files.add("_rootdef");
	files.add("cmstate");
	files.add("backgroundprocess");
	files.add("voyages");
	files.add("actTrans");
	files.add("transact");
	files.add("eventTrans");
	files.add("vessel");
	files.add("yardAllocations");
	files.add("edi");
	files.add("cmenu");
	files.add("terminal");
	files.add("misc");
	files.add("charge");
	files.add("statistic");
	files.add("receive");
	files.add("_userxrf");
	files.add("externdb");
	files.add("eventRequest");
	files.add("entTable");
	files.add("information");
	files.add("movementLog");
	files.add("bol");
	files.add("edit");
	files.add("move");
	files.add("containr");
	files.add("stkmove");
	files.add("userData_udr");
	files.add("cmgte_data");
	files.add("deferredCharge");
	files.add("create");
	files.add("edi_udr");
	files.add("prenotes");
	files.add("CnEcXML");
	files.add("query");
	files.add("infoEDISent");
	files.add("locationTransactions");
	files.add("release");
	files.add("cams");
	files.add("operatn");
	files.add("stops");
	files.add("trakitem");
	files.add("harbour");
	files.add("cargoGroup");
	files.add("hmsVoyages");
	files.add("cmtrans");
	files.add("workorder");
	files.add("snapshots");
	files.add("cashPayment");
	files.add("activityHistoryExtInterface");
	files.add("camsAudit");
	files.add("CM_TILC");
	files.add("cmsmap");
	files.add("transactbol");
	files.add("InterTermMove");
	files.add("releaseByTypeCriteria");
	files.add("planning");
	files.add("jss");
	files.add("crossref");
	files.add("fixup");
	files.add("tempreading");
	files.add("contacts");
	files.add("logObjs");
	files.add("sealObject");
	files.add("wagonController");
	files.add("_userdev");
	files.add("voyageEvents");
	files.add("cmwarehouse");
	files.add("kpiVoyage");
	files.add("proForma");
	files.add("cashReceipt");
	files.add("_userint");
	files.add("dev");
	files.add("transactST");
	files.add("soh");
	files.add("wagonMaster");
	files.add("resourceTask");
	files.add("wagonVisit");
	files.add("vehicleWeighing");
	files.add("customs");
	files.add("_usergui");
	files.add("vehicleSchedule");
	files.add("baserel");
	files.add("userData");
	files.add("pallet");
	files.add("cmui");
	files.add("discrep");
	files.add("cmextension");
	files.add("docActions");
	files.add("tempread");
	files.add("admin");
	files.add("reeferWalk");
	files.add("finance");
	files.add("HotFixesCommonSchema");
	files.add("uicommon");
	files.add("jsscore_process");
	files.add("invConfig");
	files.add("workTaskCGAssignment");
	files.add("currency");
	files.add("errorPersistent");
	files.add("recipe");
	files.add("remoteDataProcessing");
	files.add("restwebservice");
	files.add("wagons");
	files.add("yardActivity");
	files.add("jsscore_default");
	files.add("storage");
	files.add("translation");
	files.add("jmtinterface");
	files.add("scenario");
	files.add("nodereq");
	files.add("mutex");
	files.add("locationStatistics");
	
	// Run the compact
	create dba transient;
	create dbFiles transient;
	dba.getDbFiles(DbFile.Kind_User_Data, dbFiles);
	
	foreach dbFile in dbFiles do
		if not files.includes(dbFile.name)then
			continue;
		endif;
		
		write "Compacting " &amp; dbFile.name &amp; ".dat (File size=" &amp; dbFile.getFileLength().String &amp; ").  Please wait...";
		dbFile.compactFile();
		write "Finished compacting " &amp; dbFile.name &amp; ".dat (File size=" &amp; dbFile.getFileLength().String &amp; ").";
		
	endforeach;
	
epilog
	delete dba;
	delete dbFiles;
	delete files;
	
end;</source>
    </JadeMethod>
</Class>
