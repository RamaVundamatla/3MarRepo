    <JadeMethod name="addToDoTaskForBulk" id="804912cf-11ac-49dd-8710-e0c0742885b8">
        <updating/>
        <source>addToDoTaskForBulk(_toDoDesc : CM_ToDoTaskDesc; _passport : CM_Passport input) : CM_ToDoTaskDesc updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwrd1	Initial creation
adm 160710 Par 24784 Error instead of warning
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes
28/06/2022 navds20 TFS 53760 MTN - DuplicateItem not Translatable

*/

vars

	task 		: CM_ToDoTaskDesc;
	tiTask 		: CM_ToDoTaskDesc;	

begin

	//Check that we do not already have this task assigned to us
	foreach task in self.allToDoTaskDesc where task.description.trimBlanks = _toDoDesc.description do
		//app.raiseCMException1(ERR_TODOTASK_ADD, app.getErrorString2(DuplicateItem, app.getErrorString(Task) &amp;" "&amp; _toDoDesc.description, self.id), null, self);	// message's text changed to be translatable. #24784 19/10/2010 //28/06/2022 navds20 TFS 53760
		// Add To-Do Task Error: Task %1 already exists for %2 : Todo_task_error_task_alrea_exi
		app.raiseCMException2(Todo_task_error_task_already, _toDoDesc.description, self.id, null, self); //28/06/2022 navds20 TFS 53760
		return task;
	endforeach;
	
	if (not _toDoDesc.isAvailableForCargoType(self.cargoType)) then
		//app.raiseCMException1(ERR_TODOTASK_ADD, app.getErrorString2( ERR_NotAvailableForCargoType, _toDoDesc.description, self.id), null, self);	// message's text changed to be translatable. #24784 19/10/2010 //28/06/2022 navds20 TFS 53760
		// Add To-Do Task Error: %1 is not available for the Cargo type of item %2 : Todo_task_error_not_avail_carg
		app.raiseCMException2(Todo_task_error_not_avail_carg, _toDoDesc.description, self.id, null, self); //28/06/2022 navds20 TFS 53760
		return null;
	endif;
	
	
	//ti could be just a proxy, in which case we want to create
	//proxy toDoTasks - persistent object can't reference transients
	/*
	if self.isTransient then
		create tiTask transient;
	else	
		create tiTask persistent;
		self.causeEvent(Object_Update_Event, false, self);
	endif;
	
	
	tiTask.setForCreateTiMaster(_toDoDesc, _passport); 
	*/
	
	self.allToDoTaskDesc.add( _toDoDesc );
//	self.causeEvent(Object_Update_Event, false, self); // cnwrd1 par #18159 10.10.08
	self.updateObjectEdition(self);
	
	return tiTask;
	
end;</source>
        <Parameter name="_toDoDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
