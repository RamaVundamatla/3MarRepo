    <JadeMethod name="calculateMaxY" id="92f0421d-3e0d-45a3-bfb0-2ce5e7bb6a70">
        <updating/>
        <source>calculateMaxY():Real updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MAX_MULTIPLIER	: Real = 1.50;		// Set a 50% buffer above actual maximum value.
	
vars
	chartValue		: Real;
	maxValue		: Real;
	
begin
	maxValue	:=	self.yMax;
	
	foreach chartValue in self.allValues do
		if chartValue &gt; maxValue then
			maxValue	:=	chartValue * MAX_MULTIPLIER;
		endif;
	endforeach;

	if maxValue &lt; self.minMaxY then
		maxValue	:=	self.minMaxY;
	endif;
	
	self.yMax	:=	maxValue;
	
	return maxValue;
end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="clear" id="d1f060df-b3bf-45dc-86cc-26b7cc47a904">
        <source>clear(pTheControl:Control) protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dcHandle		: Integer;
	windowHandle	: Integer;
	
begin
	windowHandle	:=	pTheControl.hwnd();
	dcHandle		:=	call jssWinGetDC(windowHandle);

	if dcHandle &lt;&gt; 0 then
		call jssWinBitBlt(	dcHandle,
							0,
							0,
							pTheControl.clientWidth(),
							pTheControl.clientHeight(),
							0,
							0,
							0,
							self.BLACKNESS);
	endif;

epilog
	if dcHandle &lt;&gt; 0 then
		call jssWinReleaseDC(windowHandle, dcHandle);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheControl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="copyOffScreenToControl" id="5ee51fad-6701-453f-b8cc-d7572daeb3b1">
        <source>copyOffScreenToControl(pTheControl : Control) protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dcHandle		: Integer;
	dcPicHandle		: Integer;
	windowHandle	: Integer;
	
begin
	dcHandle		:=	self.hOffScreenDC;
	windowHandle	:=	pTheControl.hwnd();
	dcPicHandle		:=	call jssWinGetDC(windowHandle);

	if dcPicHandle &lt;&gt; 0 and dcHandle &lt;&gt; 0 then
		call jssWinBitBlt(	dcPicHandle,
							0,
							0,
							pTheControl.clientWidth(),
							pTheControl.clientHeight(),
							dcHandle,
							0,
							0,
							self.SRCCOPY);
	endif;
epilog
	if dcPicHandle &lt;&gt; 0 then
		call jssWinReleaseDC(windowHandle, dcPicHandle);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheControl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="create" id="1d471fc9-f12d-488e-ae80-3302adf31aff">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.yMax		:=	5;
	self.hPenAxis	:=	call jssWinCreatePen(self.PS_SOLID, 0, self.COLOR_AXIS);
end;</source>
    </JadeMethod>
    <JadeMethod name="createOffScreenResources" id="3831f5ae-13ab-4721-ac48-e0b9e6df4691">
        <updating/>
        <source>createOffScreenResources(pTheControl : Control) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	pictureHandle	: Integer;
	dcPicHandle		: Integer;
	dcOffHandle		: Integer;
	fontHeight		: Integer;
	
begin
	self.freeOffScreenResources();
	
	pictureHandle	:=	pTheControl.hwnd();
	dcPicHandle		:=	call jssWinGetDC(pictureHandle);
	
	if dcPicHandle = 0 then
		return;
	endif;

	self.hOffScreenDC	:=	call jssWinCreateCompatibleDC(dcPicHandle);
	dcOffHandle			:=	self.hOffScreenDC;
	
	if dcOffHandle = 0 then
		return;
	endif;
		
	self.hOffScreenBmp	:=	call jssWinCreateCompatibleBitmap(	dcPicHandle,
																pTheControl.clientWidth(),
																pTheControl.clientHeight());
	
	if self.hOffScreenBmp &lt;&gt; 0 then
		call jssWinSelectObject(dcOffHandle, self.hOffScreenBmp);
	endif;
			
	fontHeight	:=	-(call jssWinMulDiv(	self.TEXT_POINT_SIZE,
											call jssWinGetDeviceCaps(dcOffHandle, self.LOGPIXELSY), 72)
					);

	if app.isUnicode() then
		self.hFont	:=	call jssWinCreateFontW(fontHeight,
												0,
												0,
												0,
												0,
												0,
												0,
												0,
												self.ANSI_CHARSET,
												0,
												0,
												0,
												0,
												self.TEXT_FONT_TYPEFACE);
	else
		self.hFont	:=	call jssWinCreateFontA(fontHeight,
												0,
												0,
												0,
												0,
												0,
												0,
												0,
												self.ANSI_CHARSET,
												0,
												0,
												0,
												0,
												self.TEXT_FONT_TYPEFACE);
	endif;
	
	if self.hFont &lt;&gt; 0 then
		call jssWinSelectObject(dcOffHandle, self.hFont);
	endif;
	
	call jssWinSetBkColor(dcOffHandle, Black);
	call jssWinSetTextColor(dcOffHandle, self.COLOR_TEXT);
epilog
	if dcPicHandle &lt;&gt; 0 then
		call jssWinReleaseDC(pictureHandle, dcPicHandle);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheControl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a70e1d7d-68b1-412f-ba54-06a016b7bdc1">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.freeOffScreenResources();

	if self.hPenValue &lt;&gt; 0 then
		call jssWinDeleteObject(self.hPenValue);
		self.hPenValue	:=	0;
	endif;

	if self.hPenAxis &lt;&gt; 0 then
		call jssWinDeleteObject(self.hPenAxis);
		self.hPenAxis	:=	0;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="dcdaeb43-ec43-48e4-ae7b-a1d7bcc84833">
        <updating/>
        <source>doRefresh() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	axisIncrement		: Integer;
	incrementPosition	: Integer;
	graphBottom			: Integer;
	dcHandle			: Integer;
	maxIncrement		: Real;
	textPosition		: Real;
	topPosition			: Real;
	theControl			: Control;
	
begin
	self.updateCount	:=	0;
	theControl			:=	self.myControl;

	if (not theControl.visible) then
		// The window is not visible so don't bother drawing anything.
		self.freeOffScreenResources();
		return;
	endif;

	self.createOffScreenResources(theControl);
	
	self.clientHeight	:=	theControl.clientHeight();
	self.clientWidth	:=	theControl.clientWidth();

	self.graphHeight	:=	self.clientHeight - (self.TOP_BOTTOM_MARGIN * 2);
	self.graphWidth		:=	self.clientWidth - (self.LEFT_MARGIN + self.RIGHT_MARGIN);
	self.yScale			:=	self.graphHeight / self.calculateMaxY();
	self.maxDisplayableValues := (self.graphWidth div self.AXIS_INCREMENT) + 1;
	
	self.isPictureTooSmall	:=	(self.graphHeight &lt;= 0 or self.graphWidth &lt;= 0);
	
	if self.isPictureTooSmall then
		// The window is too small to draw anything of use.
		self.clear(theControl);
		return;
	endif;

	dcHandle	:=	self.hOffScreenDC;
	
	if dcHandle = 0 then
		// We haven't got an off-screen device context to draw in!
		self.clear(theControl);
		return;
	endif;

	graphBottom := self.clientHeight - self.TOP_BOTTOM_MARGIN;

	call jssWinSelectObject(dcHandle, self.hPenAxis);
	
	foreach incrementPosition in 0 to self.graphWidth step self.AXIS_INCREMENT do
		call jssWinMoveToEx(dcHandle, self.LEFT_MARGIN + incrementPosition, graphBottom, 0);
		call jssWinLineTo(dcHandle, self.LEFT_MARGIN + incrementPosition, self.TOP_BOTTOM_MARGIN);
	endforeach;

	foreach incrementPosition in 0 to self.graphHeight step self.AXIS_INCREMENT do
		call jssWinMoveToEx(dcHandle, self.LEFT_MARGIN, graphBottom - incrementPosition, 0);
		call jssWinLineTo(dcHandle, self.clientWidth - self.RIGHT_MARGIN, graphBottom - incrementPosition);
	endforeach;

	self.drawTextRightAligned(dcHandle, '0', graphBottom - 6, self.LEFT_MARGIN - 3);
	self.drawTextRightAligned(dcHandle, "Rate", self.TOP_BOTTOM_MARGIN - 14, self.LEFT_MARGIN + 11);
	self.drawTextRightAligned(dcHandle, "Time", graphBottom + 2, (self.clientWidth - self.RIGHT_MARGIN) + 1);

	incrementPosition	:=	(self.graphHeight div self.AXIS_INCREMENT) * self.AXIS_INCREMENT;
	
	if (graphBottom - incrementPosition) &lt; (graphBottom - (self.graphHeight - 4)) then
		incrementPosition	:=	incrementPosition - self.AXIS_INCREMENT;
	endif;

	axisIncrement	:=	incrementPosition div self.AXIS_INCREMENT;
	
	if axisIncrement &gt;= 1 then	
		maxIncrement	:=	(incrementPosition / self.yScale).roundedTo(0);
		
		if maxIncrement &gt;= 1 then
			self.drawTextRightAligned(dcHandle, maxIncrement.String, graphBottom - incrementPosition - 6, self.LEFT_MARGIN - 3);
			
			if axisIncrement &gt;= 2 then
				textPosition	:=	(maxIncrement / 2).roundedTo(0);
				topPosition		:=	graphBottom - ((textPosition / maxIncrement) * incrementPosition) - 6;
				self.drawTextRightAligned(dcHandle, textPosition.String, topPosition.Integer, self.LEFT_MARGIN - 3);
			endif;
		endif;
	endif;

	self.refreshValues(self.allValues, dcHandle);

	self.copyOffScreenToControl(theControl);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="74a5ce33-4f86-40e3-a5b0-49a839ca24fa">
        <updating/>
        <source>doUpdate(pNewValue : Real) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	valueArray		: RealArray;
	maxValues		: Real;
	graphBottom		: Integer;
	valueCount		: Integer;
	dcHandle		: Integer;
	yOffset			: Integer;
	updCount		: Integer;
	theControl		: Control;
	priorValue  	: Real;
	scaleDecay		: Real;
	
begin
	updCount			:=	self.updateCount + 1;
	self.updateCount	:=	updCount;
	maxValues			:=	self.maxDisplayableValues;
	valueArray			:=	self.allValues;
	valueCount			:=	valueArray.size();
			
	if valueCount &gt; maxValues then
		// Remove the oldest value.
		valueArray.removeAt(1);
	else
		// We're about to add another value to the array.
		valueCount	:=	valueCount + 1;
	endif;

	priorValue	:=	valueArray.last();
	valueArray.add(pNewValue);

	if pNewValue &gt; self.yMax then
		// We need to adjust the y-scale and refresh the graph.
		self.refresh();
		return;
	endif;
	
	if self.isPictureTooSmall then
		// The window is too small to draw anything of use.
		return;
	endif;

	if updCount &gt; maxValues and valueCount &gt; 2 then
		scaleDecay	:=	self.yMax * 0.5;
		
		if priorValue &lt;= scaleDecay and pNewValue &lt;= scaleDecay then
			// We've had a window's worth of updates and the last two values
			// are both in the bottom half of the graph. Decay the y-scale
			// by 25% so that the graph will slowly adjust to be appropriate
			// for the incoming values.
			self.yMax	:=	self.yMax * 0.75;
			self.refresh();
			return;
		endif;
	endif;

	theControl	:=	self.myControl;
	
	if (not theControl.visible) then
		// The window is not visible so don't bother drawing anything.
		return;
	endif;
	
	dcHandle	:=	self.hOffScreenDC;
	self.scrollOffScreen();
	graphBottom	:=	self.clientHeight - self.TOP_BOTTOM_MARGIN;
	call jssWinSelectObject(dcHandle, self.hPenAxis);

	foreach yOffset in 0 to self.graphHeight step self.AXIS_INCREMENT do
		call jssWinMoveToEx(	dcHandle,
								self.LEFT_MARGIN + self.graphWidth - self.AXIS_INCREMENT,
								graphBottom - yOffset,
								0);
								
		call jssWinLineTo(		dcHandle,
								self.clientWidth - self.RIGHT_MARGIN,
								graphBottom - yOffset);
	endforeach;

	call jssWinMoveToEx(	dcHandle,
							self.LEFT_MARGIN + ((self.graphWidth div self.AXIS_INCREMENT) * self.AXIS_INCREMENT),
							graphBottom,
							0);
		
	call jssWinLineTo(		dcHandle,
							self.LEFT_MARGIN + ((self.graphWidth div self.AXIS_INCREMENT) * self.AXIS_INCREMENT),
							graphBottom - self.graphHeight);

	self.updateValue(valueArray, valueCount, graphBottom, dcHandle);
	self.copyOffScreenToControl(theControl);
end;</source>
        <access>protected</access>
        <Parameter name="pNewValue" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawTextRightAligned" id="0ddae428-b8f9-4bc7-83ad-b3b1f37d3cdc">
        <source>drawTextRightAligned(pDCHandle : Integer; pText : String; pTop : Integer; pRight : Integer) protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rectangle	: Binary;
	
begin
	rectangle[ 1 : 4]	:=	0.Binary;
	rectangle[ 5 : 4]	:=	pTop.Binary;
	rectangle[ 9 : 4]	:=	pRight.Binary;
	rectangle[13 : 4]	:=	self.clientHeight.Binary;
	
	if app.isUnicode() then
		call jssWinDrawTextExW(pDCHandle, pText, pText.length, rectangle, self.DT_RIGHT, 0);
	else
		call jssWinDrawTextExA(pDCHandle, pText, pText.length, rectangle, self.DT_RIGHT, 0);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pDCHandle" type="Integer"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pTop" type="Integer"/>
        <Parameter name="pRight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="freeOffScreenResources" id="b514cae1-4402-4d46-a546-cfe577e73554">
        <updating/>
        <source>freeOffScreenResources() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.hOffScreenDC &lt;&gt; 0 then
		call jssWinDeleteDC(self.hOffScreenDC);
		self.hOffScreenDC := 0;
	endif;
	
	if self.hOffScreenBmp &lt;&gt; 0 then
		call jssWinDeleteObject(self.hOffScreenBmp);
		self.hOffScreenBmp := 0;
	endif;
	
	if self.hFont &lt;&gt; 0 then
		call jssWinDeleteObject(self.hFont);
		self.hFont := 0;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="81aeef8b-7818-4048-a2a6-3ba41949dce2">
        <updating/>
        <source>initializeMe(pThePicture : Picture; pColor : Integer; pMinY : Real) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.freeOffScreenResources();

	if pMinY &lt; 0 then
		self.minMaxY	:=	0;
	else
		self.minMaxY	:=	pMinY;
	endif;
		
	self.yMax	:=	self.minMaxY;
	
	self.myControl				:=	pThePicture;
	self.myControl.autoRedraw	:=	false;
	    
	if self.hPenValue &lt;&gt; 0 then
		call jssWinDeleteObject(self.hPenValue);
		self.hPenValue	:=	0;
	endif;

	self.hPenValue	:=	call jssWinCreatePen(self.PS_SOLID, 0, pColor);

	self.refresh();
end;</source>
        <Parameter name="pThePicture" type="Picture"/>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pMinY" type="Real"/>
    </JadeMethod>
    <JadeMethod name="refresh" id="f4c05fb0-f0f9-4563-9999-88a19a0fb676">
        <updating/>
        <source>refresh() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorNumber	: Integer; // Initialized to zero.
		
begin
	on Exception do self.xHandlerResumeNext(exception, errorNumber);
	
	self.doRefresh();

	// if the refresh encounters an exception, our handler will
	// resume to here and we'll simply abandon the operation
	if errorNumber &lt;&gt; 0 then
		self.freeOffScreenResources();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="refreshValues" id="c326e3b0-b771-40d9-b7c3-b86ec2e0c897">
        <source>refreshValues(pValueArray : RealArray; pDCHandle : Integer) protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xCoordinate	: Real;
	xPrior		: Real;
	yCoordinate	: Real;
	yPrior		: Real;
	realValue	: Real;
	graphBase	: Real;
	graphWide	: Real;
	scaleY		: Real;
	maxValues	: Integer;
	valueCount	: Integer;
	
begin
	scaleY		:=	self.yScale;
	maxValues	:=	self.maxDisplayableValues;
	graphBase	:=	self.clientHeight - self.TOP_BOTTOM_MARGIN;
	graphWide	:=	self.graphWidth;
	xPrior		:=	-1;
	yPrior		:=	-1;
	valueCount	:=	0;
	
	call jssWinSelectObject(pDCHandle, self.hPenValue);

	foreach realValue in pValueArray reversed do
		xCoordinate	:=	self.LEFT_MARGIN + (graphWide - (self.AXIS_INCREMENT * valueCount));
		yCoordinate	:=	graphBase - (realValue * scaleY);

		if xPrior &gt;= 0 and yPrior &gt;= 0 then
			call jssWinMoveToEx(pDCHandle, xPrior.Integer, yPrior.Integer, 0);
			call jssWinLineTo(pDCHandle, xCoordinate.Integer, yCoordinate.Integer);
		endif;

		xPrior	:=	xCoordinate;
		yPrior	:=	yCoordinate;

		valueCount	:=	valueCount + 1;
				
		if valueCount &gt;= maxValues then
			break;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pValueArray" type="RealArray"/>
        <Parameter name="pDCHandle" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="scrollOffScreen" id="43ab661e-c365-4991-97c5-b940c3bea1be">
        <updating/>
        <source>scrollOffScreen() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dcHandle	: Integer;
	
begin
	dcHandle	:=	self.hOffScreenDC;
	
	if dcHandle &lt;&gt; 0 then
		call jssWinBitBlt(	dcHandle,
							self.LEFT_MARGIN,
							self.TOP_BOTTOM_MARGIN,
							self.graphWidth + 1,
							self.graphHeight + 1,
							dcHandle,
							self.LEFT_MARGIN + self.AXIS_INCREMENT,
							self.TOP_BOTTOM_MARGIN,
							self.SRCCOPY);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateMe" id="9a54b6b6-fd83-4c17-9bba-6bb8e65a04bc">
        <updating/>
        <source>updateMe(pNewValue : Real) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorNumber	: Integer; // Initialized to zero.

begin
	on Exception do self.xHandlerResumeNext(exception, errorNumber);

	self.doUpdate(pNewValue);

	// If the update encounters an exception, our handler will
	// resume to here and we'll simply abandon the operation.
end;</source>
        <Parameter name="pNewValue" type="Real"/>
    </JadeMethod>
    <JadeMethod name="updateValue" id="5989ae48-e465-42bc-a76b-e25a23b323b8">
        <source>updateValue(pValueArray : RealArray; pValueCount : Integer; pGraphBottom : Integer; pDCHandle : Integer) protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	realValue	: Real;
	xCoordinate	: Real;
	yCoordinate	: Real;
	yPrior		: Real;
	scaleY		: Real;
	
begin
	scaleY := self.yScale;
	
	if pValueCount &gt; 1 then
		realValue	:=	pValueArray[pValueCount - 1];
	else
		realValue	:=	0;
	endif;
	
	yPrior		:=	pGraphBottom - (realValue * scaleY);
	realValue	:=	pValueArray.last();
	yCoordinate	:=	pGraphBottom - (realValue * scaleY);
	xCoordinate	:=	self.LEFT_MARGIN + self.graphWidth - self.AXIS_INCREMENT;

	call jssWinSelectObject(pDCHandle, self.hPenValue);
	call jssWinMoveToEx(pDCHandle, xCoordinate.Integer, yPrior.Integer, 0);
	call jssWinLineTo(pDCHandle, (xCoordinate + self.AXIS_INCREMENT).Integer, yCoordinate.Integer);
end;</source>
        <access>protected</access>
        <Parameter name="pValueArray" type="RealArray"/>
        <Parameter name="pValueCount" type="Integer"/>
        <Parameter name="pGraphBottom" type="Integer"/>
        <Parameter name="pDCHandle" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerResumeNext" id="5c759d5b-f0e4-4b1a-896b-87ab2d132c02">
        <source>xHandlerResumeNext(pTheException : Exception; pErrorNumber : Integer output) : Integer protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pErrorNumber	:=	pTheException.errorCode;
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="pTheException" type="Exception"/>
        <Parameter name="pErrorNumber" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
