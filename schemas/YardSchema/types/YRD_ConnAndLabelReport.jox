    <JadeMethod name="init" id="fe1b5d16-62a0-40a0-ae7c-e5e51c2dfb2c">
        <updating/>
        <source>init(_useSelected : Boolean; _tisToPrint : Collection) updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.useSelected	:= _useSelected;
	self.allTIsToPrint.clear;

	if _useSelected then
		if _tisToPrint = null then
			app.raiseUnexpectedProgramError(class.name, method.name, '_useSelected = true but _tisToPrint = null');
		else
			_tisToPrint.copy(self.allTIsToPrint);
		endif;
	endif;

end;</source>
        <Parameter name="_useSelected" type="Boolean"/>
        <Parameter name="_tisToPrint" type="Collection"/>
    </JadeMethod>
