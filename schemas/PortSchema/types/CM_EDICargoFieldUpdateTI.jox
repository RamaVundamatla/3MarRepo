        <source>getMyTIDisplayDefName(): String;

vars

begin
	return ETDef_EDITICargoFieldUpdate;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="6d2076d7-8de4-417c-aa3c-46123d0b9ffb">
        <source>getVoyageCode() : String;

/*
Purpose:	Return the appropriate VoyageCode to be used in the EDIConfig allEDITrackedItemsByVoyageCode collection.

Date			Who		Reason
03 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
	
vars
	
begin
	return self.voyageCode;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
