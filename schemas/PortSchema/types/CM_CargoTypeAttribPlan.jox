    <JadeMethod name="validateForUpdate" id="74338247-a9a4-4458-95f9-fa3ba8f45fb0">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
// Purpose:		
// ---------------------------------------------------------------------------
vars
	otherObj,
	realObj	: CM_CargoTypeAttribPlan;
	tmpMoveMap	: CM_MoveMap;
begin
/*	if self.commodityGroup = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Commodity group', ETRow_CommodityGroup, null);
	endif;
	if self.isoTypeGroup = null then
		app.raiseCMException1(REQUIRED_FIELD, 'ISO Type', ETRow_ISOType, null);
	endif;*/
	
	// CCMS 1110
	if self.myCargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Type', ETRow_CargoType, null);
		app.raiseCMException(Input_required_field_cargoType, ETRow_CargoType, null); // cnwdb2	PAR 35364
	endif;
	
	tmpMoveMap := self.myMoveMap;
	if tmpMoveMap = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Move Map', null, null);
		app.raiseCMException(Input_required_field_mveMap, null, null);

	else
		otherObj := tmpMoveMap.allAttributePlans[self.myCargoType, self.imexStatus, self.isoTypeGroup, self.commodityGroup];
		realObj := app.myProxyManager.getRealObject(self).CM_CargoTypeAttribPlan;
		if (realObj &lt;&gt; null and
		   otherObj &lt;&gt; null and
		   realObj &lt;&gt; otherObj) or
		   (realObj = null and otherObj &lt;&gt; null) then
			//app.raiseCMException2(DuplicateItem, 'An attribute plan with this key', 'this move map', null, null); //13.06.2022 navds20 53760
			// An attribute plan with this key already exists for this move map: Attri_plan_with_this_alrea_exi
			app.raiseCMException(Attri_plan_with_this_alrea_exi, null, null); //13.06.2022 navds20 53760
		endif;
	endif;

end;</source>
    </JadeMethod>
</Class>
