        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="printTotals" id="75551981-5b0e-4b3e-ac60-253cb612eaab">
        <source>printTotals(_type : Integer; _heading : String) protected;

vars

	total	: CMIF_ShipStowageTotals;
	iter	: Iterator;
	count,
	pcs		: Integer;
	volume	: Decimal[12,3];

begin

	self.lblPcs1Ttl.caption 	:= null;
	self.lblVol1Ttl.caption		:= null;
	self.lblPcs2Ttl.caption 	:= null;
	self.lblVol2Ttl.caption		:= null;
	self.lblPcs3Ttl.caption 	:= null;
	self.lblVol3Ttl.caption		:= null;
	self.lblPcs4Ttl.caption 	:= null;
	self.lblVol4Ttl.caption		:= null;
	self.lblPcs5Ttl.caption 	:= null;
	self.lblVol5Ttl.caption		:= null;
	
	self.lblTotalHeading.caption := _heading;
	iter := self.allTotals.createIterator;
	while iter.next(total) do
		total.getTotals(_type, pcs, volume);
		count := count + 1;
		if pcs &gt; 0 then
			if count = 1 then
				self.lblPcs1Ttl.caption 	:= pcs.String;
				self.lblVol1Ttl.caption		:= volume.String;
			elseif count = 2 then
				self.lblPcs2Ttl.caption 	:= pcs.String;
				self.lblVol2Ttl.caption		:= volume.String;
			elseif count = 3 then
				self.lblPcs3Ttl.caption 	:= pcs.String;
				self.lblVol3Ttl.caption		:= volume.String;
			elseif count = 4 then
				self.lblPcs4Ttl.caption 	:= pcs.String;
				self.lblVol4Ttl.caption		:= volume.String;
			elseif count = 5 then
				self.lblPcs5Ttl.caption 	:= pcs.String;
				self.lblVol5Ttl.caption		:= volume.String;
			elseif count = 6 then
				self.lblPcs6Ttl.caption 	:= pcs.String;
				self.lblVol6Ttl.caption		:= volume.String;
			endif;
		endif;
	endwhile;
	self.doPrint(self.frmTotals);
//	app.printer.print(self.frmTotals);
	self.doPrint(self.frmSpace);
//	app.printer.print(self.frmSpace);
	self.clearTotals(_type);
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="printVesselTotals" id="12d5bdcd-5a38-40f4-af4c-d1d956fd4285">
        <source>printVesselTotals() protected;

/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

	total	: CMIF_ShipStowageTotals;
	pcs		: Integer;
	iter	: Iterator;
	volume	: Decimal[12,3];

begin
	self.frmHeader.height	:= 61;
	app.printer.newPage();
	iter := self.allTotals.createIterator;
	while iter.next(total) do
		total.getTotals(CMIF_ShipStowageTotals.HoldGrandTotal, pcs, volume);
		self.lblGrandTHeading.caption	:= total.heading;
		self.lblGrLogsDtlHold.caption	:= pcs.String;
		self.lblGrJASDtlHold.caption	:= volume.String;
		
		total.getTotals(CMIF_ShipStowageTotals.DeckGrandTotal, pcs, volume);
		self.lblGrLogsDtlDeck.caption	:= pcs.String;
		self.lblGrJASDtlDeck.caption	:= volume.String;
		self.doPrint(self.frmGrandTotals);
//		app.printer.print(self.frmGrandTotals);
		self.printLine();
	endwhile;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processGroup" id="f6438aa8-1311-4ea1-9104-c7be2b30edda">
        <source>processGroup(_array : ObjectArray) protected;

vars

	sort,	
	lastSort	: CMIF_SOHReporter;
	obj			: Object;
	isFirst		: Boolean;
	array		: ObjectArray;
	isSupplier	: Boolean;
	isPlace		: Boolean;


begin

	self.clearTotals(CMIF_ShipStowageTotals.PlaceTotal);
	self.clearTotals(CMIF_ShipStowageTotals.SupplierTotal);
	create array transient;
	isFirst := true;
	foreach obj in _array do
		sort := obj.CMIF_SOHReporter;
		if isFirst then
			self.printHeading(sort.myLot);
			isFirst := false;
		endif;
		if lastSort = null or
			(lastSort.place = sort.place) then
			if (lastSort = null) or (lastSort.supplier = sort.supplier) then
				if (lastSort = null) or (lastSort.myProduct = sort.myProduct) then
				else
					self.printDetail(array, lastSort.place);
					array.clear;
				endif;
			else
				self.printDetail(array, lastSort.place);
				self.printTotals(CMIF_ShipStowageTotals.SupplierTotal, '          Supplier Total');
				self.printLine();
				self.printSpace();
				isSupplier := true;
				array.clear;
			endif;
		else
			self.printDetail(array, lastSort.place);
			if isSupplier then	// #26143 1/11/2010
				self.printTotals(CMIF_ShipStowageTotals.SupplierTotal, '          Supplier Total');
			endif;
			self.printTotals(CMIF_ShipStowageTotals.PlaceTotal, '          ' &amp; self.getPlaceString(lastSort.place) &amp; ' Total');
			if isSupplier then 	// #26143 1/11/2010
				self.printLine();
			endif;
			isPlace := true;
			array.clear;
		endif;
		array.add(sort.mySOHLocation);
		lastSort := sort;
	endforeach;	
	self.printDetail(array, sort.place);
	if isSupplier then
		self.printTotals(CMIF_ShipStowageTotals.SupplierTotal, '          Supplier Total');
	endif;
	if isPlace then
		self.printTotals(CMIF_ShipStowageTotals.PlaceTotal, '          ' &amp; self.getPlaceString(sort.place) &amp; ' Total');
	endif;
	self.printTotals(CMIF_ShipStowageTotals.LotTotal, 'Lot ' &amp; sort.lot &amp; ' Total');
	self.printLine();

epilog
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_array" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="processReport" id="c17250c4-50af-4f83-9f19-c6c1176dda5b">
        <source>processReport(_array	: ObjectArray) protected;

vars


	sort,
	lastSort: CMIF_SOHReporter;
	iter	: Iterator;
	array	: ObjectArray;
	
begin


	create array transient;
	iter := _array.createIterator;
	while iter.next(sort) do
		if sort.mySOHLocation.allTrackedItems.size = 0 then
			continue;
		endif;
		if	lastSort = null or
			(sort.lot = lastSort.lot)then
		else
			self.processGroup(array);
			array.clear;
		endif;
		array.add(sort);
		lastSort := sort;
	endwhile;
	if array.size &gt; 0 then
		self.processGroup(array);
	endif;
	self.printVesselTotals();
	
epilog

	delete iter;
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_array" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="run" id="aa59dd4a-af1e-44ce-939a-e0e87cb11aa5">
        <updating/>
        <source>run(_isPrintPreview, _isCSV : Boolean; _extraDetail : CM_ExtraDetail) : Binary updating;

constants

	Hatches = 6;
	
vars

	data		: CM_JRWOld;
	dyna		: DynaDictionary;
	soh			: CM_SOHLocation;
	array		: ObjectArray;
	iter		: Iterator;
	sort,
	lastSort	: CMIF_SOHReporter;
	isFirstTime	: Boolean;

begin

	inheritMethod(_isPrintPreview,_isCSV, _extraDetail);
	isFirstTime := true;
	create array transient;
	app.printer.printPreview := _isPrintPreview;
	app.printer.setMargins(Print_Landscape,0,0,10,10);
	data := app.myQAFilter.myRWLogDocket;
	dyna := self.sortData(data.allSOHLocations);
	if dyna.size &gt; 0 then
		iter := dyna.createIterator;
		while iter.next(sort) do
			if	lastSort = null or
				(sort.myVoyage = lastSort.myVoyage) then
			else
				self.doPrinterVoyageReport(array, isFirstTime);
				isFirstTime := false;
				array.clear;
			endif;
			array.add(sort);
			lastSort := sort;	
		endwhile;
	endif;
	if array.size &gt; 0 then
		self.doPrinterVoyageReport(array, isFirstTime);
	endif;
	return null;
	
epilog
	if dyna &lt;&gt; null then
		dyna.purge;
		delete dyna;
	endif;
	delete array;
	delete iter;
	self.allTotals.purge;
	app.printer.close();

end;</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setHeaderAndFooter" id="40fd41c5-377a-4b35-8e34-b599c5a8c992">
        <source>setHeaderAndFooter(_operator : CM_Operator) protected;

vars
	tmpVoyage	: CM_Voyage;

begin

	tmpVoyage := self.myVoyage;

	self.lblHeading1.caption	:= 'Log Marshalling Division';	
	self.lblHeading2.caption	:= ('VESSEL STOWAGE PLAN FOR ' &amp; tmpVoyage.code &amp; ' ' &amp; tmpVoyage.myVoyageGlobalArrival.vesselName).toUpper;
	self.lblFooter1.caption		:= tmpVoyage.myTerminal.name;
	self.lblSupplierDtl.caption	:= app.myRoot.companyName;
	self.lblReportId.caption	:= tmpVoyage.code; 
	self.lblReportExtra.caption := tmpVoyage.statusDescription;
	self.lblLoadPortDtl.caption	:= tmpVoyage.myTerminal.name.toUpper;
	self.frmHeader.height		:= 160;
	self.frmFooter.height		:= 34;
	if _operator &lt;&gt; null then
		self.lblStevedoreDtl.caption	:= tmpVoyage.getStevedoreForOperator(_operator);
	elseif tmpVoyage.allBOLOutByTypeStatusNumDT.first &lt;&gt; null then
		self.lblStevedoreDtl.caption	:= tmpVoyage.allBOLOutByTypeStatusNumDT.first.myStevedore.description;
	else
		self.lblStevedoreDtl.caption	:= null;
	endif;
	app.printer.setHeader(self.frmHeader);
	app.printer.setFooter(self.frmFooter);
	self.printLine();

end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setNoDataDisplay" id="8724e917-237f-47b4-9fe0-ea86716a2836">
        <source>setNoDataDisplay();
// -------------------------------------------
// Created 23 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.lblNoData.caption := 'No Data To Display For Ship Stowage Plan';

end;</source>
    </JadeMethod>
    <JadeMethod name="sortData" id="a20602ae-0312-4bcb-b7e5-26c3405a0231">
        <source>sortData(_set : CM_SOHLocationSet) : DynaDictionary protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	dyna	: DynaDictionary;
	soh		: CM_SOHLocation;
	sort	: CMIF_SOHReporter;

begin

	create dyna transient;
	dyna.setMembership(CMIF_SOHReporter);
	dyna.addMemberKey("myVoyage", false, false);
	dyna.addMemberKey("lot", false, false);
	dyna.addMemberKey("place", true, false);
	dyna.addMemberKey("supplier", false, false);
	dyna.addMemberKey("length", true, false);
	dyna.addMemberKey("myProduct", false, false);
	
	
	dyna.endKeys(true);
	
	foreach soh in _set do
		create sort transient;
//		sort.myVoyage		:= soh.myLocationsController.CM_LogVoyageController.myLogLot.myLogVoyage;
		sort.myVoyage		:= soh.myLocationsController.CM_LogVoyageController.myLogLot.myLogVoyageStructure.myVoyage;
		sort.myLot			:= soh.myLocationsController.CM_LogVoyageController.myLogLot;
		sort.lot 			:= soh.myLocationsController.CM_LogVoyageController.myLogLot.lotNo;
		sort.mySupplier		:= soh.myProduct.myOperator; 
		sort.supplier		:= soh.myProduct.getDisplayStringForAttribute(ETRow_OperatorCode, true);
		sort.hatch			:= soh.myLocationsController.CM_LogVoyageController.hatch;
		sort.place			:= soh.myLocationsController.CM_LogVoyageController.place;
		sort.myProduct		:= soh.myProduct;
		sort.mySOHLocation	:= soh;
		sort.length			:= soh.myProduct.CM_ProductLog.lengthCode.Real;
		dyna.add(sort);
	endforeach;
	return dyna;
	

end;</source>
        <access>protected</access>
        <Parameter name="_set" type="CM_SOHLocationSet"/>
        <ReturnType type="DynaDictionary"/>
    </JadeMethod>
</GUIClass>
