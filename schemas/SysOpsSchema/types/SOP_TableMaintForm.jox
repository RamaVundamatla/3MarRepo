    <JadeMethod name="unload" id="b83e1566-8d34-4a51-a581-53f2cb3c63af">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2020	jlgndl1	Initial creation	50549

*/

vars

begin

	if self.isDelayNotifications then
		self.endTimer( self.CamProtocol_Refresh );
		self.delayNotifications := false;
	endif;

	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="5b3ad0fe-655e-4bb6-9d8c-85521514ec3f">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
----------   ----------  --------------------------------------------------
Created:	05 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.doHandleNotification(eventType, theObject, eventTag, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
