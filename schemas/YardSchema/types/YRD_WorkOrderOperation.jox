    <JadeMethod name="showJobShiftForm" id="eaeece4e-ee04-4826-b6e2-08f7a2005e2f">
        <source>showJobShiftForm(_obj : Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
31 Jul 2023 navma1	Defect 59444: MTN - 1090 Exception when selection Shift Jobs
23 Sep 2024 navhl20	Bug 66211: EUP - Job Sheets should be filtered on Shift and Split Job form based on criteria of WO Operation
*/

vars
	form		: YRD_WorkOrderJobShift;
	jobSet		: CM_JobSet;
	jobSheetSet	: CM_JobSheetSet;
	jobsheet	: CM_WorkPointJobSheet;
	job 		: CM_Job;
	rows,
	n			: Integer;
begin
	
	if _obj = null then		//31.07.2023 navma1 #59444
		return;
	endif;
	
	form := app.loadForm(YRD_WorkOrderJobShift, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderJobShift;
	
	if form = null then
		return;
	endif;
	create jobSet transient;
	
	foreach job in _obj.CM_DataTable.allSelectedObjects as CM_Job do
		jobSet.addNoDuplicates(job,false);
	endforeach;
	
	create jobSheetSet transient;		//23.09.2024 navhl20 #66211
	rows := self.tblJobSheet.rows;		//23.09.2024 navhl20 #66211
	foreach n in 2 to rows do			//23.09.2024 navhl20 #66211
		jobsheet := self.tblJobSheet.accessRow(n).itemObject.CM_WorkPointJobSheet;
		jobSheetSet.addNoDuplicates(jobsheet,false);
	endforeach;
	
	form.setJobSheets(jobSheetSet);		//23.09.2024 navhl20 #66211
	form.setAllJobs(jobSet);
	form.showModal();
epilog
	delete form;
	delete jobSet;
	delete jobSheetSet;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showJobSplitForm" id="5d411c57-4e55-4d4f-9e37-e48e03cd5201">
        <source>showJobSplitForm(_obj : Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2023	navhl20	ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
23 Sep 2024 navhl20	Bug 66211: EUP - Job Sheets should be filtered on Shift and Split Job form based on criteria of WO Operation
*/

vars
	form		: YRD_WorkOrderJobSplit;
	jobSheetSet	: CM_JobSheetSet;
	jobsheet	: CM_WorkPointJobSheet;
	job 		: CM_Job;
	rows,
	n			: Integer;
begin
	form := app.loadForm(YRD_WorkOrderJobSplit, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderJobSplit;
	
	if form = null then
		return;
	endif;
	form.setWorkListEntries(_obj.CM_DataTable.allSelectedObjects.first.CM_Job);
	
	create jobSheetSet transient;		//23.09.2024 navhl20 #66211
	rows := self.tblJobSheet.rows;		//23.09.2024 navhl20 #66211
	foreach n in 2 to rows do			//23.09.2024 navhl20 #66211
		jobsheet := self.tblJobSheet.accessRow(n).itemObject.CM_WorkPointJobSheet;
		jobSheetSet.addNoDuplicates(jobsheet,false);
	endforeach;
	
	form.setJobSheets(jobSheetSet);		//23.09.2024 navhl20 #66211
	
	form.showModal();
epilog
	delete form;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
