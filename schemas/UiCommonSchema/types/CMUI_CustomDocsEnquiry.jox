    <JadeMethod name="includeCustDoc" id="7bcf1bdd-203c-463b-b0f5-5b745f56accb">
        <source>includeCustDoc(_custDoc : CM_CustomDocument; _checkDetails : Boolean): Boolean;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
27 Feb 2024 navrv30	Bug 61880: EUP | FR 53715 - Customs Enquiry screen - Query Issues
15 Aug 2024	navnk30	Bug 65011: FR | 53715 - Customs Enquiry screen - search results
*/

vars
	custDocDetail	: CM_CustomDocumentDetail;
	commodity,
	cargoType,
	subType,
	cargoId			: String;
	isDocDtlMatch	: Boolean;
	ti				: CM_TrackedItem;
	cargoGroup		: CM_CargoGroup;
begin

	if self.filterQueryRefNumber &lt;&gt; "" then
		if _custDoc.itemNumber.String.toUpper().pos(self.filterQueryRefNumber.toUpper(),1) &lt; 1 then
			return false;
		endif;
	endif;

	if self.filterQueryDesc &lt;&gt; "" then
		if _custDoc.description.String.toUpper().pos(self.filterQueryDesc.toUpper(),1) &lt; 1 then
			return false;
		endif;
	endif;

	if self.filterQueryCode &lt;&gt; "" then
		if _custDoc.code.String.toUpper().pos(self.filterQueryCode.toUpper(),1) &lt; 1 then
			return false;
		endif;
	endif;

	if self.filterQueryExtRef1 &lt;&gt; "" then
		if _custDoc.externalRef1.String.toUpper().pos(self.filterQueryExtRef1.toUpper(),1) &lt; 1 then
			return false;
		endif;
	endif;
	
	if self.filterQueryFromDate.isValid() then
		if self.systemToLocalTime(_custDoc.dateTime) &lt; self.filterQueryFromDate then
			return false;
		endif;
	endif;
	
	if self.filterQueryEndDate.isValid() then
		if self.systemToLocalTime(_custDoc.dateTime) &gt; self.filterQueryEndDate then
			return false;
		endif;
	endif;
	
	/*			//15.08.2024 navnk30 #65011
	if self.filterQueryCargoId &lt;&gt;  "" then
		if _custDoc.code.String.toUpper().pos(self.filterQueryCargoId.toUpper(),1) &lt; 1 then
			return false;
		endif;
	endif;
	*/
	
	
	if self.filterQueryAgent &lt;&gt; null then
		if _custDoc.myCustomsAgent &lt;&gt; null then
			if _custDoc.myCustomsAgent &lt;&gt; self.filterQueryAgent then
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	if self.filterQueryDocType &lt;&gt; null then
		if _custDoc.myCustomDocumentType &lt;&gt; null then
			if _custDoc.myCustomDocumentType &lt;&gt; self.filterQueryDocType then
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	if self.filterQueryLicense &lt;&gt; null then
		if _custDoc.myCustomLicense &lt;&gt; null then
			if _custDoc.myCustomLicense &lt;&gt; self.filterQueryLicense then
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	
	if self.filterQueryHSCode &lt;&gt; null then
		if _custDoc.myHSCode &lt;&gt; null then
			if _custDoc.myHSCode &lt;&gt; self.filterQueryHSCode then
				return false;
			endif;
		else
			return false;
		endif;
	endif;
	


	//isMatch := true;			//15.08.2024 navnk30 #65011
	isDocDtlMatch := true;		//15.08.2024 navnk30 #65011
	if _custDoc.allCustomDocumentDetails.isNotEmpty() then
		if self.filterQueryCargoType &lt;&gt; "" 
		or self.filterQueryCargoSubType &lt;&gt; "" 
		or self.filterQueryCommodity &lt;&gt; "" 
		or self.filterQueryCargoId &lt;&gt; ""
		or self.filterQueryCargoGroup &lt;&gt; null then
			foreach custDocDetail in _custDoc.allCustomDocumentDetails do
				isDocDtlMatch := true;		//15.08.2024 navnk30 #65011
				ti := custDocDetail.myTrackedItem;
				 
				if self.filterQueryCargoType &lt;&gt; "" then
					cargoType := ti.cargoTypeCode;
					isDocDtlMatch := isDocDtlMatch and self.filterQueryCargoType.pos(cargoType,1) &gt; 0;	//15.08.2024 navnk30 #65011
					/*if self.filterQueryCargoType.pos(cargoType,1) &lt;= 0 then							//15.08.2024 navnk30 #65011
						isMatch := false;
						break;
					endif;*/
				endif;
				
				if self.filterQueryCargoSubType &lt;&gt; "" then
					subType := ti.cargoTypeCode;
					isDocDtlMatch := isDocDtlMatch and self.filterQueryCargoSubType.pos(subType,1) &gt; 0;	//15.08.2024 navnk30 #65011
					/*if self.filterQueryCargoSubType.pos(subType,1) &lt;= 0 then							//15.08.2024 navnk30 #65011
						isMatch := false;
						break;
					endif;*/
				
				endif;
				if self.filterQueryCommodity &lt;&gt; "" then
					commodity := ti.commodity;
					isDocDtlMatch := isDocDtlMatch and self.filterQueryCommodity.pos(commodity,1) &gt; 0;	//15.08.2024 navnk30 #65011
					/*if self.filterQueryCommodity.pos(commodity,1) &lt;= 0 then							//15.08.2024 navnk30 #65011
						isMatch := false;
						break;
					endif;*/
				
				endif;
				if self.filterQueryCargoId &lt;&gt; "" then
					cargoId := ti.id;
					isDocDtlMatch := isDocDtlMatch and cargoId.pos(self.filterQueryCargoId.toUpper(),1) &gt; 0;	//15.08.2024 navnk30 #65011
					/*if self.filterQueryCargoId.pos(cargoId,1) &lt;= 0 then										//15.08.2024 navnk30 #65011
						isMatch := false;
						break;
					endif;*/
				
				endif;
				if self.filterQueryCargoGroup &lt;&gt; null then					
					if ti.isCargoGroupItem() then
						cargoGroup := ti.CM_CargoGroup;
					else
						cargoGroup := ti.myCargoGroup;
					endif;
					isDocDtlMatch := isDocDtlMatch and self.filterQueryCargoGroup = cargoGroup;			//15.08.2024 navnk30 #65011
					/*if self.filterQueryCargoGroup &lt;&gt; cargoGroup then									//15.08.2024 navnk30 #65011
						isMatch := false;
						break;
					endif;*/
					
				endif;
				if isDocDtlMatch then																	//15.08.2024 navnk30 #65011
					return true;
				endif;
			endforeach;
		endif;
	else 
		return false;
	endif;
	
	//return isMatch;			//15.08.2024 navnk30 #65011
	return isDocDtlMatch;		//15.08.2024 navnk30 #65011

epilog

end;</source>
        <Parameter name="_custDoc" type="CM_CustomDocument"/>
        <Parameter name="_checkDetails" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTblCustDocEnquiry" id="f15dab20-75bb-4c39-879e-c3d566ae9173">
        <source>initTblCustDocEnquiry(_theEntDef :String);
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblData;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CM_OwnershipChange);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		self.setColorsForTable(self.tblData);	
	else
		theTable.rows := 1;	
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
