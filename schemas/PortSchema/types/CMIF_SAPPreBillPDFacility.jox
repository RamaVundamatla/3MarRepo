        <source>copyToRealWSObject(_realRequest: SAP112_PreBillProdDataRequest_DT_T_Facility_item input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

