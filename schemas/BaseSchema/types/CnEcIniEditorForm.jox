    <JadeMethod name="browseForFile" id="d3640437-9e8e-45ce-b32d-567ac1557bde">
        <updating/>
        <source>browseForFile(pSectionListObj:ListBox; pElementListObj:ListBox) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Browser for a new initialization file.
//
// Parameters:	pSectionListObj - The INI section listbox.
//				pElementListObj - The INI section-element listbox.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileOpenObj	: CMDFileOpen;
	fileName	: String;
	csvFileObj	: CnEcCsvFile;

begin
	create fileOpenObj transient;
	fileOpenObj.allowMultiSelect	:=	false;
	fileOpenObj.defaultExt			:=	".ini";
	fileOpenObj.fileMustExist		:=	true;
//	fileOpenObj.filter				:=	"Initialization File (*.ini)|*.ini|Text (*.txt)|*.txt|All files (*.*)|*.*";
//	fileOpenObj.filterIndex			:=	1;
	fileOpenObj.cnEcSetFilters(true, 1, CNEC_FILE_FILTER_INI, CNEC_FILE_FILTER_TEXT);

	if fileOpenObj.open() = 0 then
		fileName	:=	fileOpenObj.fileName;

		pSectionListObj.clear();
		pElementListObj.clear();
		self.enableSetting(false, null);
		self.deleteIniFileReference();

		create csvFileObj transient;
		self.aMyIniFile		:=	csvFileObj.cnEcLoadIniFile(fileName);
		lblFileName.caption	:=	fileName;
		lstSection.listCollection(self.aMyIniFile.allIniSections, false, 0);
		self.enableButtons();
	endif;
epilog
	delete fileOpenObj;
	delete csvFileObj;
end;</source>
        <Parameter name="pSectionListObj" type="ListBox"/>
        <Parameter name="pElementListObj" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="btnAddKey_click" id="f179b6ee-9b03-4ce7-98ca-6bca2c4c2485">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddKey_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniSectionObj	: CnEcIniSection;
	keyName			: String;

begin
	app.mousePointer	:=	Busy;
	iniSectionObj		:=	lstSection.listObject.CnEcIniSection;
	keyName				:=	self.cnEcGetUserInput("Add INI Element", "Please enter the name of the INI Section Key ", null);

	if keyName &lt;&gt; null then
		iniSectionObj.addIniKey(keyName, null);
		lstKey.listCollection(iniSectionObj.allIniKeys, false, 0);
		self.enableSetting(false, null);
		self.enableButtons();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnBrowse_click" id="a4052713-3b96-4edf-98bd-67c3d26b5709">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBrowse_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.browseForFile(lstSection, lstKey);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="7afbb820-6bb2-4039-a903-17d2fccc2a3c">
