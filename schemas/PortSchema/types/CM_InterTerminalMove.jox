    <JadeMethod name="setProxy" id="244ea629-e8f3-46d5-af63-eca7ac93e0e7">
        <updating/>
        <source>setProxy(	_cargoID : String;
			_operator : CM_Operator;
			_sourceTI : CM_TrackedItem;
			_sourceTerminal : CM_Terminal;
			_targetTerminal : CM_Terminal;
			_sourceVehicle : CM_Vehicle;
			_vehicleId : String;
			_status : Integer;
			_myInterTermVehicleJob : CM_InterTermVehicleJob
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 February 2010	conkc1	Initial creation

*/
vars
	
begin
	self.cargoID          := _cargoID;
	self.myOperator       := _operator;
	self.mySourceTI       := _sourceTI;
	self.mySourceVehicle  := _sourceVehicle;
	self.vehicleID        := _vehicleId;
	self.mySourceTerminal := _sourceTerminal;
	self.myTargetTerminal := _targetTerminal;
	self.setStatus( _status );
	self.myInterTermVehicleJob := _myInterTermVehicleJob;

epilog

end;</source>
        <Parameter name="_cargoID" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_sourceTI" type="CM_TrackedItem"/>
        <Parameter name="_sourceTerminal" type="CM_Terminal"/>
        <Parameter name="_targetTerminal" type="CM_Terminal"/>
        <Parameter name="_sourceVehicle" type="CM_Vehicle"/>
        <Parameter name="_vehicleId" type="String"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_myInterTermVehicleJob" type="CM_InterTermVehicleJob"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="c3706977-0394-4dbd-8b5d-43777df482c4">
        <updating/>
        <source>setStatus( _newStatus : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2010	cnwrd1	Initial creation
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	self.status := _newStatus;
	
	if _newStatus = ITT_LOADING then
		vehiclePickupDT := app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _newStatus = ITT_UNLOADED then
		vehicleSetdownDT := app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	
epilog

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
