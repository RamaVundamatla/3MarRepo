    <JadeMethod name="initialise" id="78920e87-c217-4f3c-8117-e6f4448e8c21">
        <updating/>
        <source>initialise(	_trackedItem: CM_TrackedItem; 
			_quantity: Integer; 
			_weight: Decimal; 
			_bulkRelease: CM_BulkRelease; 
			_setParentFromChild : Boolean; 
			_lineNumber: Integer;
			_packTime : TimeStampOffset	) updating;		// MTN-33056
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 September 2024	navcs2	ChangeRequest 65967: CUX | MasterTerminalAPI - Pack and Unpack APIs
09 October 2024		navdap1	MTN-33056 CUX | Pack and Unpack API Issue on Date /Time
*/

vars

begin
	self.trackedItem 		:= _trackedItem;
	self.quantity 			:= _quantity;
	self.weight				:= _weight;
	self.bulkRelease		:= _bulkRelease;
	self.setParentFromChild	:= _setParentFromChild;
	self.lineNumber			:= _lineNumber;
	self.packTime			:= _packTime;		// MTN-33056
epilog

end;</source>
