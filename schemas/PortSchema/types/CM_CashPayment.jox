    <JadeMethod name="getUncreditedAmount" id="b0b9db40-50dd-4b4e-93fa-41a1c8ef1f27">
        <source>getUncreditedAmount() : Decimal;
/*

Purpose:			
		return the payment total less any cash credits, used to determine how much more credit can be applied
		= cashPayment.cashValue - Credit Applied
Parameters:			

Return Value:		

Date		Who		Reason
18 Sep 2019	cnwma1	Bug 46582: Cash Credit are not being accounted for correctly

*/

vars
	creditDetail	: CM_CashCreditDetail;
	amount			: Decimal[23, 6];		//10 May 2018	NDL	TFS 38523
begin
	amount := self.cashValue;
	foreach creditDetail in self.allCashCreditDetails do
		amount := amount - creditDetail.cashValue;
	endforeach;
	
	if amount &lt; 0 then
		amount := 0;
	endif;
	
	return amount;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
