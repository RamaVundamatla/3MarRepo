    </JadeMethod>
    <JadeMethod name="getNumTEU" id="7407cca5-1747-46b3-84fc-21c106947fbf">
        <source>getNumTEU():Real;
// ---------------------------------------------------------------------------
// Created:     08 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	move	:CM_KPIMachineMoveDtl;
	teu		:Real;
begin
	foreach move in self.allKPIMachineMoves do
		teu := teu + move.numTEU;
	endforeach;
	
	return teu;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
