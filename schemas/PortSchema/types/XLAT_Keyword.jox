<Class name="XLAT_Keyword" id="fc1dff4f-9472-4e5b-af89-c89d8e6c3def">
    <superclass name="XLAT_TranslationEnties"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="translation"/>
    <Constant name="MaxKeywordLength" id="2f361ca5-329c-4b4d-976c-cb7d87e9b562">
        <source>20</source>
        <type name="Integer"/>
    </Constant>
    <ExplicitInverseRef name="allTranslations" id="3c09c83a-16c1-433a-934e-235869f8397b">
        <type name="XLAT_TranslationByCatAndNumber"/>
        <access>readonly</access>
        <Inverse name="XLAT_Translation::allKeywords"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myLocale" id="245fd034-edbd-4973-8d7c-a87d0f5d3ab8">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Locale"/>
        <access>readonly</access>
        <Inverse name="CM_Locale::allTranslationKeywords"/>
    </ExplicitInverseRef>
    <PrimAttribute name="text" id="4b3dfa61-6521-412b-8539-2da7157c4dff">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="vTranslationCount" id="b0b5d336-3252-4252-8f72-caeb1f547807">
        <embedded/>
        <virtual/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getTranslationsForCategory" id="ea0020b1-504d-4546-ab93-388d5c5c5e91">
        <source>getTranslationsForCategory(category : XLAT_Category; results : XLAT_TranslationByNumberDict input);

vars
	iter : Iterator;
	translation	: XLAT_Translation;
begin
	iter := allTranslations.createIterator;
	allTranslations.startKeyGeq(category.constantCategoryName, null, iter);
	while iter.next(translation) and translation.myTranslatableText.myConstantCategoryName = category.constantCategoryName do
		results.add(translation);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="category" type="XLAT_Category"/>
        <Parameter name="results" type="XLAT_TranslationByNumberDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeTranslation" id="af530189-e387-4dda-bacf-05b4d3910ee2">
        <source>removeTranslation(_category : XLAT_Category; _translatableText : XLAT_TranslatableText; _translation	: XLAT_Translation);

vars

begin
	if _category = null then
		return;
	endif;
	self.allTranslations.removeKeyEntry(_category.constantCategoryName, _translatableText.number, _translation);//12/Aug/08 cnwdz2 par17718
end;</source>
        <Parameter name="_category" type="XLAT_Category"/>
        <Parameter name="_translatableText" type="XLAT_TranslatableText"/>
        <Parameter name="_translation" type="XLAT_Translation"/>
    </JadeMethod>
    <JadeMethod name="update" id="985be7ea-d852-4443-805f-dc2a437150d0">
        <updating/>
        <source>update(_text : String; _locale : CM_Locale; translation	: XLAT_Translation) updating;

vars

begin
	if text = null then
		text := _text;
	endif;
	myLocale := _locale;
	allTranslations.add(translation);
end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="translation" type="XLAT_Translation"/>
    </JadeMethod>
    <JadeMethod name="vTranslationCount" id="466f01c1-1e58-476d-ad1b-55e89de0ae3b">
        <methodInvocation>mapping</methodInvocation>
        <source>vTranslationCount(set: Boolean; _value: Integer io) mapping;

vars

begin
	if set then
		// read only
	else
		_value := allTranslations.size;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
