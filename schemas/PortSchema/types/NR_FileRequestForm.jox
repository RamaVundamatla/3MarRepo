    <JadeMethod name="tblResults_dblClick" id="1e9c6e93-8893-4219-91bc-ee4ffe606204">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 December 2019	jlgmd1	Initial creation
09 January 2019		jlgmd1	Protect against 1090 if nothing is selected (whoops!)

*/

vars
	class 			: Class;
	selectedText	: String;
	form			: Form;
begin
	
	if self.fldMain.topSheet = self.shtParser then
		if self.tblResults.row &lt; 1 then
			return;
		endif;	
		
		selectedText := self.tblResults.accessRow(self.tblResults.row).itemObject.CM_Association.asString();
		class := rootSchema.getSchema("UiCommonSchema").getClass("CMUI_MessageLogForm");
		
		create form as class transient;
		form.setPropertyValue("myXMLString", selectedText);
		//form.caption := "";		// Set me to what ever process i've just opened ? How do we know which one we're in...?
		form.show();
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblResults_keyDown" id="dbd3c76d-65a5-41f2-9c6e-01651b828119">
        <controlMethod name="CM_Table::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2019	jlgmd1	Initial creation

*/

vars
	row,
	rows : Integer;
	text : String;
begin
	// Ctrl-C
	if shift.bitAnd(2) &lt;&gt; 0 and keyCode = J_key_C then
		rows := self.tblResults.rows;
		foreach row in 1 to rows do
			table.accessCell(row, 1);
			text := text &amp; table.accessedCell.text &amp; CrLf;
		endforeach;
		app.copyStringToClipboard(text);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="dddd3946-88da-4261-95e8-0d5cb2400776">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 June 2006 By cnwth2

Purpose:	Potentially a great number of notifications being received
			So timer event effectively 'caches' output to reduce network traffic
			associated with updating the output textbox for each note

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if eventTag = self.TIMER_SYS_ACTIVITY_REFRESH and self.cachedOutput &lt;&gt; null then
		app.writeLog(self.cachedOutput, LogINFO);
		self.allOutput := self.allOutput &amp; self.cachedOutput;
		self.txtActivityOut.text := self.allOutput;
		self.txtActivityOut.scrollVertPos := #FFFFFF;
	
		self.cachedOutput := null;
	endif;

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
