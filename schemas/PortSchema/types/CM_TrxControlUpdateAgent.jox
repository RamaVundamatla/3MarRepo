    <JadeMethod name="trxUpdateLogRow" id="a6088652-664a-4387-8db1-f4b6be51d7f0">
        <updating/>
        <source>trxUpdateLogRow(_cmifLogRow : CMIF_LogRowRestriction; _passport : CM_Passport input) updating;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	app.myPassport.useTITransactionDeferUpdate := true;		// CCMS 1107 / PAR 20627 - now creating transactions so use deferred update

	beginTransaction;

	app.myUtilityUA.utlUpdateLogRow(_cmifLogRow, _passport); 

	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmifLogRow" type="CMIF_LogRowRestriction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateLogRowDownload" id="1f590f62-8f0f-4de2-b464-3dda138bef0e">
        <updating/>
        <source>trxUpdateLogRowDownload(_logRowDownloadArray : CMIF_LogRowDownloadArray; _logFileName, _shipFileName : String; 
					_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateLogRowDownload(_logRowDownloadArray, _logFileName, _shipFileName, _passport);
	
	if _passport.myCMIFMonitor &lt;&gt; null then
		if _passport.myCMIFMonitor.monitorReturnValue &lt;&gt; null then		
			app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);	
			return;
		endif;
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_logRowDownloadArray" type="CMIF_LogRowDownloadArray"/>
        <Parameter name="_logFileName" type="String"/>
        <Parameter name="_shipFileName" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
