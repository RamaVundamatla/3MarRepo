    <JadeMethod name="addProperty" id="6acfd9bb-3a4a-4f18-bb37-6cd925a047f0">
        <source>addProperty(_etrow : String; _prop : Property;  _value : String);
/*
Purpose:			

Date		Who		Reason
08 May 2024	navab1	CR 64033 TASK 64035
*/

vars
	prop : CMIF_TIBulkUpdateProperty;
begin
	create prop transient;
	prop.id := _etrow;
	prop.myProperty := _prop;
	prop.valueStr := _value;
	
	self.allProperties.addNoDuplicates(prop,false);
epilog

end;</source>
        <Parameter name="_etrow" type="String"/>
        <Parameter name="_prop" type="Property"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
