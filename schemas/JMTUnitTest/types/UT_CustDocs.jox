    <JadeMethod name="createCustDocHeaderForSeqCode" id="f126c86e-3aee-43b9-b169-3e6e44bfa972">
        <updating/>
        <source>createCustDocHeaderForSeqCode(_code : String; _sequence : Integer; _suffix : Integer; _docType : CM_CustomDocumentType; 	cargoGroup1, cargoGroup2 : CM_TrackedItem) : CM_CustomDocument updating;
/*
Purpose - 	
Who - NAVAB1
Date - 03NOV2023
ADO - 60922 TASK 60980
*/

vars

	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode, custDocCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume, clearedWeight, clearedVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr : CM_CustomDocument;
	realCustomDocumentDetail : CM_CustomDocumentDetail;
	term : CM_Terminal;
	cmifCustDocDetail : CMIF_CustomDocumentDetail;
	theReturn        : Integer;
	proxyCustDocDetail		: CM_CustomDocumentDetail;
begin


	term := self.getTerminal();

   custDocCode := _code;

   create pxyCustDocHdr transient;
	pxyCustDocHdr.setProxy(term, custDocCode,custDocCode &amp; " Description",null, null,null,dateTime,null,null,_docType.direction,_suffix, _docType,_docType.allCustomLicenses.first,null,null,_sequence);
	
	
	create cmifCustDocDetail transient;

	create proxyCustDocDetail transient;
	clearedWeight := cargoGroup1.totalWeight;// ### TFS CR 60922 TASK 60980 09NOV2023 NAVAB1
	clearedVolume := cargoGroup1.totalVolume;
	clearedQuantity := cargoGroup1.totalQuantity;
	proxyCustDocDetail.setProxy(clearedQuantity, clearedWeight,clearedVolume, true,cargoGroup1, pxyCustDocHdr, null);
	cmifCustDocDetail.allProxyCustDocDetails.add(proxyCustDocDetail);

	if cargoGroup2&lt;&gt; null then
		create proxyCustDocDetail transient;
		clearedWeight := cargoGroup2.totalWeight;// ### TFS CR 60922 TASK 60980 09NOV2023 NAVAB1
		clearedVolume := cargoGroup2.totalVolume;
		clearedQuantity := cargoGroup2.totalQuantity;
		proxyCustDocDetail.setProxy(clearedQuantity, clearedWeight,clearedVolume, true,cargoGroup2, pxyCustDocHdr, null);
		cmifCustDocDetail.allProxyCustDocDetails.add(proxyCustDocDetail);
	endif;
	
	app.myTrxCA.trxCreateCustDocAndDetails(pxyCustDocHdr,realCustDocHdr, cmifCustDocDetail, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();
	if realCustDocHdr&lt;&gt; null then
		self.assertEqual(realCustDocHdr.code,custDocCode);
	endif;
	
	return realCustDocHdr;

epilog
	delete pxyCustDocHdr;
	cmifCustDocDetail.allProxyCustDocDetails.purge();
	delete cmifCustDocDetail;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_sequence" type="Integer"/>
        <Parameter name="_suffix" type="Integer"/>
        <Parameter name="_docType" type="CM_CustomDocumentType"/>
        <Parameter name="cargoGroup1" type="CM_TrackedItem"/>
        <Parameter name="cargoGroup2" type="CM_TrackedItem"/>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="createCustDocType" id="ab5d136b-40ae-4306-8e50-7490fe68bd5e">
        <source>createCustDocType(_code : String) : CM_CustomDocumentType;
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	CR 56093 TASK 59624
// ### TFS CR 60424 TASK 60549 29SEP2023 NAVAB1 - updated for new doc type validation
*/
constants
vars
	pxyCustDocType, realCustDocType : CM_CustomDocumentType;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
	oArray : ObjectArray; 
	custDocTypes : CM_CustomDocumentTypeByCode;
	code2 : String;
begin
	term := self.getTerminal();

	code2 := _code &amp; "2";
	realCustDocType := term.allCustomDocumentTypes[_code];
	if realCustDocType &lt;&gt; null then
		app.myTrxDA.trxDeleteCustDocType(realCustDocType, app.myPassport);
	
	endif;
	realCustDocType := term.allCustomDocumentTypes[code2];
	if realCustDocType &lt;&gt; null then
		app.myTrxDA.trxDeleteCustDocType(realCustDocType, app.myPassport);
	
	endif;
	
	create pxyCustDocType transient;
	
	create stopsApply transient;
	create stopsClear transient;
	stopTablC := app.myRoot.allStopsTable.first;
	stopsClear.add(stopTablC);
	stopTablA := app.myRoot.allStopsTable.last;
	stopsApply.add(stopTablA);
	
	pxyCustDocType.setProxy(_code,_code &amp; " Description",CM_CustomDocumentType.CustDocTypeDir_Inward,false,false,term,null,stopsApply,null, null, null, null);
	
	app.myTrxCA.trxCreateCustDocType(pxyCustDocType, realCustDocType, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realCustDocType.code,_code);
	self.assertEqual(realCustDocType.description,_code &amp; " Description");
	self.assertEqual(realCustDocType.myTerminal,term);
	self.assertTrueMsg(realCustDocType.allStopsToApply.size = 1,"Stops Apply should be 1, is " &amp; realCustDocType.allStopsToApply.size.String);
	self.assertTrueMsg(realCustDocType.allStopsToClear.size = 0,"Stops Clear should be 0, is " &amp; realCustDocType.allStopsToClear.size.String);
	self.assertTrueMsg(realCustDocType.allNextDocumentTypes.size = 0,"Next cust doc should be 0, is " &amp; realCustDocType.allNextDocumentTypes.size.String);
	
	// ### CREATE SECOND
	create custDocTypes transient;
	custDocTypes.add(realCustDocType);
	pxyCustDocType.setProxy(code2,code2 &amp; " Description",CM_CustomDocumentType.CustDocTypeDir_Outward,false,false,term,custDocTypes,null,stopsClear, null, null, null);
	
	app.myTrxCA.trxCreateCustDocType(pxyCustDocType, realCustDocType, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realCustDocType.code,code2);
	self.assertEqual(realCustDocType.description,code2 &amp; " Description");
	self.assertEqual(realCustDocType.myTerminal,term);
	self.assertTrueMsg(realCustDocType.allStopsToApply.size = 0,"Stops Apply should be 0, is " &amp; realCustDocType.allStopsToApply.size.String);
	self.assertTrueMsg(realCustDocType.allStopsToClear.size = 1,"Stops Clear should be 1, is " &amp; realCustDocType.allStopsToClear.size.String);
	self.assertTrueMsg(realCustDocType.allNextDocumentTypes.size = 1,"Next cust doc should be 1, is " &amp; realCustDocType.allNextDocumentTypes.size.String);
	
	return realCustDocType;
epilog
	delete pxyCustDocType;
	delete stopsApply;
	delete stopsClear;
	delete custDocTypes;
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_CustomDocumentType"/>
    </JadeMethod>
    <JadeMethod name="createCustDocTypeForSeq" id="b22ef86b-d64b-4b66-86f1-b29499a385e5">
        <source>createCustDocTypeForSeq(_code, _desc : String; _nextTypes : CM_CustomDocumentTypeByCode; _direction : Integer; _licenses : CM_CustomLicenseByCode; _autoid : Boolean; _stopsApply, _stopsClear : CM_StopsTableSet; _mandatoryFields : StringArray; _colour : Integer) : CM_CustomDocumentType;
/*
Purpose - 	
Who - NAVAB1
Date - 23AUG2023
ADO - CR 59942 TASK 59943 
*/

constants
vars
	pxyCustDocType, realCustDocType : CM_CustomDocumentType;
	term : CM_Terminal;
	oArray : ObjectArray; 
	realCustDocHdr : CM_CustomDocument;
	realDocDetail : CM_CustomDocumentDetail;
begin
	term := self.getTerminal();
 
 
	self.removeCustDocType(_code);
	
	create pxyCustDocType transient;
	
	
	pxyCustDocType.setProxy(_code,_desc,_direction,_autoid,false,term,_nextTypes,_stopsApply,_stopsClear, _licenses, _mandatoryFields, _colour);
	
	
	if _stopsClear = null then
		app.myPassport.setWarningsIgnored(true);
	endif;
	
	app.myTrxCA.trxCreateCustDocType(pxyCustDocType, realCustDocType, app.myPassport);
		
	self.assertNoTrxErrorsOrWarnings();
	
	if realCustDocType &lt;&gt; null then
		self.assertEqual(realCustDocType.code,_code);
		self.assertEqual(realCustDocType.description,_desc);
		self.assertEqual(realCustDocType.myTerminal,term);
		if _stopsApply &lt;&gt; null then
			self.assertTrueMsg(realCustDocType.allStopsToApply.size = _stopsApply.size,"Stops Apply should be " &amp; _stopsApply.size.String &amp; ", is " &amp; realCustDocType.allStopsToApply.size.String);
		endif;
		if _stopsClear &lt;&gt; null then
			self.assertTrueMsg(realCustDocType.allStopsToClear.size = _stopsClear.size,"Stops Clear should be " &amp; _stopsClear.size.String &amp; ", is " &amp; realCustDocType.allStopsToClear.size.String);
		endif;
		self.assertTrueMsg(realCustDocType.allNextDocumentTypes.size = _nextTypes.size,"Next cust doc should be " &amp; _nextTypes.size.String &amp; ", is " &amp; realCustDocType.allNextDocumentTypes.size.String);
		self.assertTrueMsg(realCustDocType.allCustomLicenses.size = _licenses.size,"Next cust doc should be " &amp; _licenses.size.String &amp; " is " &amp; realCustDocType.allNextDocumentTypes.size.String);
	endif;

	
	return realCustDocType;
epilog
	delete pxyCustDocType;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_nextTypes" type="CM_CustomDocumentTypeByCode"/>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_licenses" type="CM_CustomLicenseByCode"/>
        <Parameter name="_autoid" type="Boolean"/>
        <Parameter name="_stopsApply" type="CM_StopsTableSet"/>
        <Parameter name="_stopsClear" type="CM_StopsTableSet"/>
        <Parameter name="_mandatoryFields" type="StringArray"/>
        <Parameter name="_colour" type="Integer"/>
        <ReturnType type="CM_CustomDocumentType"/>
    </JadeMethod>
    <JadeMethod name="createCustomLicense" id="5e4506ea-46df-43ea-97b4-cedc75f250f2">
        <source>createCustomLicense(_code, _desc : String; _allTerminalArea	: CM_TerminalAreaSet ) : CM_CustomLicense;
/*
Purpose - 	
Who - NAVAB1
Date - 23AUG2023
ADO - CR 59942 TASK 59943 
*/

constants
	TA1 = "BS2";
	TA2 = "UTBOLBS2";
vars
	pxyCustomLicense,
	realCustomLicense	: CM_CustomLicense;
	
	terminal			: CM_Terminal;
	
	allCustDocType		: CM_CustomDocumentTypeByCode;
begin
	terminal := self.getMyTerminal();
	
	realCustomLicense := self.getCustomLicense(_code);
	if realCustomLicense &lt;&gt; null then
		self.deleteCustomLicense(realCustomLicense);
		realCustomLicense := self.getCustomLicense(_code);
		self.assertNullMsg(realCustomLicense, "Custom License not deleted");
	endif;
	
	create pxyCustomLicense transient;
	create allCustDocType transient;
	
	
	pxyCustomLicense.setProxy(_code, _desc, terminal, false, allCustDocType, _allTerminalArea);
	realCustomLicense := self.addCustomLicense(pxyCustomLicense);
	
	return realCustomLicense;

epilog
	delete pxyCustomLicense;
	delete allCustDocType;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_allTerminalArea" type="CM_TerminalAreaSet"/>
        <ReturnType type="CM_CustomLicense"/>
    </JadeMethod>
    <JadeMethod name="createGCOnVoyage" id="55dbfea5-d5dc-4f29-a347-bf4c2c44382b">
        <source>createGCOnVoyage(_delete : Boolean; _contractId,_id : String; _cargoType : CM_CargoType; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port; _weight : Decimal; _volume : Decimal; _quantity : Integer; _cargoGroup : CM_CargoGroup input) : CM_TrackedItem;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59616
*/

vars
	cargo : CM_TrackedItem;
	lc : CM_LocationsController;
	product : CM_Product;
	prevOp : CM_Operator;
begin
	if _delete then
		self.deleteCargo(_id, _cargoType);
	endif;
	
	lc := _voyage.myShipBlockStack;
	
	
	product := _cargoType.allProducts.first;   ////////getProductFromCode("12POUNDER-12");
	if product&lt;&gt; null
	and product.myOperator &lt;&gt; null 
	and product.myOperator &lt;&gt; _operator then
		prevOp := product.myOperator;
		beginTransaction;
		product.setMyOperator(_operator);
		commitTransaction;
	endif;
	//create cargo on ship
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("TotalQuantity",_quantity); 
	cargo := lc.createNewCargoForLCDetailed(_cargoType,product, _id, _port.code, TI_IMEX_STATUS_IMPORT, _voyage,_operator, _quantity, _cargoGroup).CM_Cargo;// ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(cargo);
	self.opts.addAssoc("Commodity", "COM2");
	self.opts.addAssoc("TotalVolume", _volume);
	self.opts.addAssoc("CargoLength", 111.0);
	self.opts.addAssoc("CargoWidth", 222.0);
	self.opts.addAssoc("CargoHeight", 333.0);
	self.opts.addAssoc("Description", "CargoDesc2");
	self.opts.addAssoc("ClientRef", "ClientRef2");
	self.opts.addAssoc("Consignee", "UTDDC");
	self.opts.addAssoc("Consignor", "UTMO1");
	self.opts.addAssoc("ContractId",_contractId);
	self.opts.addAssoc("TotalWeight", _weight.Integer);
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); // ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, _quantity);
	assertEqual(cargo.totalWeight, _weight.Decimal);

	self.assertTrueMsg(cargo.contractId = _contractId, "Cargo Contract Id is wrong");
	
	if prevOp &lt;&gt; null then
		beginTransaction;
		product.setMyOperator(prevOp);
		commitTransaction;
	
	endif;
	
	return cargo;
epilog

end;</source>
        <Parameter name="_delete" type="Boolean"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createStop" id="ff1f980e-f6de-434a-b7c4-5b918a7e28b2">
        <source>createStop(_cargoType : CM_CargoType; _code : String; _id : Integer) : CM_StopsTable;
/*
Purpose:			

Date		Who		Reason
29 August 2023	navab1	CR 59942 TASK 59943 
*/

vars
	stopCheckArray,
	stopProcessArray,
	stopsSetArray			: IntegerArray;
	pxyStopCriteria, criteria			: CM_StopCriteria;
	pxyStopsTableTemplate	: CM_StopTableTemplate;
	pxyStopTable,
	realStop				: CM_StopsTable;
	objSet : ObjectSet;
	term : CM_Terminal;
begin
	term := self.getTerminal();

	self.deleteStopsTable(_id);
	
	create pxyStopTable transient;
	create pxyStopsTableTemplate transient;
	create stopCheckArray transient;
	create stopProcessArray transient;
	create stopsSetArray transient;

	stopCheckArray.add(StopPreventTrainLoad);
//	stopCheckArray.add(StopPreventTruckLoad);
	stopCheckArray.add(StopPreventTruckGateIn);
	stopCheckArray.add(StopPreventVoyageDeparture);
	stopCheckArray.add(StopPreventTrainDeparture);
	stopCheckArray.add(StopPreventRelReqAssign);
	
	pxyStopsTableTemplate.setProxy(stopCheckArray, stopsSetArray, stopProcessArray, null, false, false, false, false, false, false,true, true);
	pxyStopsTableTemplate.setPropertyValue("myStopTable", pxyStopTable);
	pxyStopsTableTemplate.setPropertyValue("myTerminal", term);
	pxyStopTable.setProxy(true, _code, _code,_code, CustomsReference, _id, null, false, true, app.myRoot, null, null,	// ### TFS CR 60424 TASK 60549 12OCT2023 NAVAB1 - CustomsReference
	null	// ### TFS 61382 (61534) 01Dec2023 NAVPW1
	);
	
	create objSet transient;				
	objSet.add(_cargoType);			

	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(objSet, YACriteriaType_CargoType,pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopTable);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopTable, realStop, app.myPassport);
	
	self.assertTrueTrxOKShowPassport("");
	
	return realStop;

epilog
	delete pxyStopCriteria;
	delete pxyStopsTableTemplate;
	delete pxyStopTable;
	delete stopCheckArray;
	delete stopsSetArray;
	delete stopProcessArray;
	delete objSet;
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_id" type="Integer"/>
        <ReturnType type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="createStopForPrevent" id="afe04f09-2f78-47f2-9217-89f95dc99bdc">
        <source>createStopForPrevent(_prevent : Integer; _cargoType : CM_CargoType; _code : String; _id : Integer; _appliesTo : Integer) : CM_StopsTable;
/*
Purpose - 	
Who - NAVAB1
Date - 12OCT2023
ADO - CR 60424 TASK 60549 
*/

vars
	stopCheckArray,
	stopProcessArray,
	stopsSetArray			: IntegerArray;
	pxyStopCriteria, criteria			: CM_StopCriteria;
	pxyStopsTableTemplate	: CM_StopTableTemplate;
	pxyStopTable,
	realStop				: CM_StopsTable;
	objSet : ObjectSet;
	term : CM_Terminal;
begin
	term := self.getTerminal();

	self.deleteStopsTable(_id);
	
	create pxyStopTable transient;
	create pxyStopsTableTemplate transient;
	create stopCheckArray transient;
	create stopProcessArray transient;
	create stopsSetArray transient;

	stopCheckArray.add(_prevent);
	
	stopsSetArray.add(_appliesTo);
	
	pxyStopsTableTemplate.setProxy(stopCheckArray, stopsSetArray, stopProcessArray, null, false, false, false, false, false, false,true, true);
	pxyStopsTableTemplate.setPropertyValue("myStopTable", pxyStopTable);
	pxyStopsTableTemplate.setPropertyValue("myTerminal", term);
	pxyStopTable.setProxy(true, _code, _code,_code, CustomsReference, _id, null, false, true, app.myRoot, null, null,
	null	// ### TFS 61382 (61534) 01Dec2023 NAVPW1
	);
	
	create objSet transient;				
	objSet.add(_cargoType);			

	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(objSet, YACriteriaType_CargoType,pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopTable);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopTable, realStop, app.myPassport);
	
	self.assertTrueTrxOKShowPassport("");
	
	return realStop;

epilog
	delete pxyStopCriteria;
	delete pxyStopsTableTemplate;
	delete pxyStopTable;
	delete stopCheckArray;
	delete stopsSetArray;
	delete stopProcessArray;
	delete objSet;
end;</source>
        <Parameter name="_prevent" type="Integer"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_appliesTo" type="Integer"/>
        <ReturnType type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="createVVRForBulkTI" id="0fd43058-d0da-48f5-aa2c-3a45b00db997">
        <source>createVVRForBulkTI(_truckId : String; _ti : CM_TrackedItem; _weight : Decimal) : CM_VehicleVisitRecord;
/*
Purpose - 	
Who - NAVAB1
Date - 09NOV2023
ADO - 60922 TASK 60980
*/

vars
	vvr : CM_VehicleVisitRecord;
	gateEntity : CMGTE_Entity;
begin
	self.opts.addAssoc("WeightRequested",_weight);
	self.opts.addAssoc("TotalWeight",_weight);
	
	vvr := self.gateOutGC(_truckId, "", "UTDRIVER", _ti,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertNotNull(vvr);
	self.assertNotNull(_ti.getPrimaryLocation(QUEUE_MODE));
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem.id, _ti.id);
	self.workVehicle(vvr);
	
	return vvr;

epilog

end;</source>
