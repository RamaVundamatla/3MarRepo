<Class name="CM_YATypeGrade" id="d5b7d1ed-8d20-4312-9acd-d128895188dd">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaValueForTi" id="2a87131d-36d4-4c2e-a244-1d335bcb822e">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 12 May 2022
TFS#		: 53316
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	if _ti.isKindOf(CM_BreakBulkGeneric) then
		//_criteriaValue := _ti.CM_BreakBulkGeneric.grade;
		_criteriaValue := _ti.CM_BreakBulkGeneric.getGrade(); // ### TFS 54021 29June2022 NAVPW1
	endif;	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="e1196fe7-d0e9-4a20-9799-eea075d495e2">
