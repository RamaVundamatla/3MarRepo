        <source>getDamageProxy(_isNewPxy : Boolean output) : CM_Wagon;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwer1	Initial creation

*/

vars
	pxyWagon : CM_Wagon;
begin
	if self.isTransient then
		return self;
	endif;
	
	pxyWagon:=self.pxyGetProxyObject();
	
	if pxyWagon &lt;&gt; null then	//28 Apr 2010	NDL	Par 23788
		return pxyWagon;
	elseif pxyWagon = null then
		_isNewPxy:=true;
		return app.createUpdateProxy(self).CM_Wagon;
	endif;

