/*
----------   ----------  --------------------------------------------------
Created:	21 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return _remark.code;


end;


</source>
        <Parameter name="_remark" type="CM_PredefinedRemark"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doConfirmContainer" id="a54cb5ff-8f01-4a30-a859-87f673194631">
        <source>doConfirmContainer(_vehicleID 	: String; 
				_containerInfo	: DTO_ContainerInfo input;
				_errorMsgs 		: DTO_HandHeldGateErrorDict input);
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ti			: CM_TrackedItem;
	container : CM_Container;
begin

	//epr 15038 extracted code block into method below
	self.getValidContainer(_vehicleID ,
							_containerInfo,
							_errorMsgs 	);
	if (not _errorMsgs.isEmpty) then
		return;
	endif;						
	
	if (not _containerInfo.hazardousChecked) then
		self.addError(Err_HazCheck_Required, app.getErrorString1(Err_HazCheck_Required, _containerInfo.containerId), _errorMsgs);
		
	endif;
	
	ti:=_containerInfo.myRealTrackedItem;
	if ti.isContainer then
		container := ti.CM_Container;
		//validate id, customs seal, operator seal and shipper seal
		//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustoms' or 'getSealNumCustomsFirst'
		if container.getSealNumCustomsFirst &lt;&gt; _containerInfo.customsSeal then
			self.addError(Err_CustSeal_No_Match, app.getErrorString2(Err_CustSeal_No_Match, _containerInfo.containerId, _containerInfo.customsSeal), _errorMsgs);
		endif;
		//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
		if container.getSealNum &lt;&gt; _containerInfo.operatorSeal then
			self.addError(Err_OpSeal_No_Match,app.getErrorString2(Err_OpSeal_No_Match, _containerInfo.containerId, _containerInfo.operatorSeal), _errorMsgs);
		endif;
		//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
		if container.getSealNumShipper &lt;&gt; _containerInfo.shipperSeal then
			self.addError(Err_ShipSeal_No_Match,app.getErrorString2(Err_ShipSeal_No_Match, _containerInfo.containerId, _containerInfo.shipperSeal), _errorMsgs);
		endif;
	endif;
	
	if (not _errorMsgs.isEmpty) then
		return;
	endif;						
	
	//do confirm damage
	self.doConfirmDamage(_containerInfo,null,null,_errorMsgs);
	
	
	
	
epilog
	if _containerInfo &lt;&gt; null then
		_containerInfo.confirmed := (_containerInfo.myRealTrackedItem &lt;&gt; null and _errorMsgs.isEmpty);
		_containerInfo.hadErrors := not _errorMsgs.isEmpty;
		if _containerInfo.confirmed then
			
		endif;
	endif;
	

end;


</source>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_containerInfo" type="DTO_ContainerInfo" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doConfirmDamage" id="170226f1-fab0-45b9-ad48-7f5ec96ceede">
        <source>doConfirmDamage(_containerInfo	: DTO_ContainerInfo;
				_damageRemarks 	: String; 
				// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
				//_damageDict 	: CM_DamageInstanceByLocDict; 
				_damageDict 	: CM_DamageInstanceByDmgePos;
				_errorMsgs 		: DTO_HandHeldGateErrorDict input);
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	Note that the damageInstanceDict might be empty, but they may still want
			to record the damage free text remarks. In this case, the container should
			be flagged as damaged.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pxyTI : CM_TrackedItem;
	error			: CM_Error;
	theDamageRemarks		: String;
begin
	//inheritMethod(_containerInfo, _damageRemarks, _damageDict, _errorMsgs);
	
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	
	pxyTI:=_containerInfo.myPxyTrackedItem;
	
	pxyTI.setRemarks(_containerInfo.myRealTrackedItem.remarks,false); //epr par 17994 no reason to type cast it just produces an error
	if _containerInfo.damageRemarks &lt;&gt; null then
		pxyTI.setRemarks(_containerInfo.damageRemarks, true);//add to existing remarks
	endif;
	
	
	//might be actually setting damaged to false here
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//pxyTI.setDamaged(_containerInfo.damageRemarks &lt;&gt; null or (not pxyTI.allDamageInstances.isEmpty));
	pxyTI.setDamaged(_containerInfo.damageRemarks &lt;&gt; null or (not pxyTI.allDamageInstancesByPos.isEmpty));
	
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	
	self.createErrorsFromPassport(_errorMsgs);


epilog

end;


</source>
        <Parameter name="_containerInfo" type="DTO_ContainerInfo"/>
        <Parameter name="_damageRemarks" type="String"/>
        <Parameter name="_damageDict" type="CM_DamageInstanceByDmgePos"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doConfirmVehicle" id="82e04f50-254f-432c-983a-87a339bbaea6">
        <source>doConfirmVehicle(_vehicleID : String; _errorMsgs : DTO_HandHeldGateErrorDict input) : CM_Vehicle protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
15 Mar 2010	consw1		PAR #23020 - Allow for vehicle that is defined with a state
*/
vars
	vehicle		: CM_Vehicle;
	error		: DTO_HandHeldGateError;
	roadJob		: CM_RoadJob;
	
begin
	vehicle := self.getVehicle(_vehicleID);
	
	if vehicle = null then
		self.addError(Err_Gate_VehicleId, app.getErrorString(Err_Gate_VehicleId), _errorMsgs);
		return null;
	endif;
	
	if (not vehicle.isInGateLocation(null)) then
		self.addError(Err_Gate_VehiclePos, app.getErrorString(Err_Gate_VehiclePos), _errorMsgs);
		return null;
	endif;
	
	return vehicle;
end;


</source>
        <access>protected</access>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="doGetVehicleDetails" id="ca538cdc-51f4-4110-98df-3a93c391a890">
        <source>doGetVehicleDetails(_vehicleID 		: String; 
					_numRecievals, 
					_numReleases 	: Integer output;
					_inJob			: Boolean output;
					_gateLaneStr	: String output;
					_errorMsgs 		: DTO_HandHeldGateErrorDict input);
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	vehicle		: CM_Vehicle;
//	error		: DTO_HandHeldGateError;
	roadJob		: CM_RoadJob;
	gateLane	: CM_LaneController;
begin
	vehicle := self.doConfirmVehicle(_vehicleID, _errorMsgs);
	if vehicle = null then
		return;
	endif;
	gateLane := vehicle.myPrimaryActualLocation.CM_LaneController;
	_gateLaneStr := gateLane.getID();
	
	roadJob := vehicle.allRoadJobs.first.CM_RoadJob;
	if roadJob = null then
		self.addError(Err_Gate_VehicleNoJob,app.getErrorString(Err_Gate_VehicleNoJob), _errorMsgs);
		return;
	endif;
	
	_inJob := (gateLane.getVehicleDirection = CM_LaneController.Is_In_Lane);  //cnwgb1 23 May 2008 PAR 16483
	_numRecievals := roadJob.allReceiveTrackedItems.size;
	_numReleases := roadJob.allReleaseTrackedItems.size;

end;


</source>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_numRecievals" type="Integer" usage="output"/>
        <Parameter name="_numReleases" type="Integer" usage="output"/>
        <Parameter name="_inJob" type="Boolean" usage="output"/>
        <Parameter name="_gateLaneStr" type="String" usage="output"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doOperateBoom" id="70714ea2-9bd0-4d5e-9468-7418c326b140">
        <source>doOperateBoom(_gateLaneId : Integer; _channel : Integer; _errorMsgs : DTO_HandHeldGateErrorDict input);

vars

	gateLane 			: CM_LaneController;
	boomEventTerminal	: Integer;
	gate 				: CM_Gate;
	gateArea			: CM_AreaWithLanes;
	usage	:CM_GateAreaUsage;
begin
	
	if app.myPassport.myTerminal = null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
	
	//epr par 22695 11/3/09
	gate:=	self.myTerminal.allGates.first;
	if gate = null then
		return;
	endif;

	foreach usage in gate.allGateAreas_IN do
		if usage.isPGate then	
			gateArea:=usage.myGateArea;	
			gateLane:=gateArea.getLaneByNumber(_gateLaneId);
			break;
		endif;
	endforeach;
		
	
	if gateLane = null then
		self.addError(Err_Unexpected_Program_Error, 
					app.getErrorString1(Err_Unexpected_Program_Error, 'The gate lane (' &amp; _gateLaneId.String &amp;') could not be located.'),
					_errorMsgs);
		return;
	endif;
	
	boomEventTerminal := self.myTerminal.getTerminalEvent(Event_Raise_Boom);
	gateLane.causeEvent(boomEventTerminal, true, _channel);
	
end;
</source>
        <Parameter name="_gateLaneId" type="Integer"/>
        <Parameter name="_channel" type="Integer"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doProceedJob" id="69673861-5437-4bf6-8c4b-57444222c941">
        <source>doProceedJob(_vehicleID : String; _errorMsgs : DTO_HandHeldGateErrorDict input);
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants

	BoomGateIn_Open = 3;
	BoomGateOut_Open = 0;
	
vars
	vehicle			: CM_Vehicle;
	roadJob			: CM_RoadJob;
	gateLane		: CM_LaneController;
//	boomGateTcp 	: CM_TcpBoomGateConnection;
//	boomGateResult  : Integer; //0 is success anything else is
//	error		: DTO_HandHeldGateError;
	boomEventTerminal : Integer;
begin
	//th2 - somehow the passport.myTerminal is null coming in here - can't work out why - something to do with packages
	if app.myPassport.myTerminal = null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
	
	vehicle := self.doConfirmVehicle(_vehicleID, _errorMsgs);
	if vehicle = null then
		return;
	endif;
	
	roadJob := vehicle.allRoadJobs.first.CM_RoadJob;
	if roadJob = null then
		self.addError(Err_Gate_VehicleNoJob, app.getErrorString(Err_Gate_VehicleNoJob), _errorMsgs);
		return;
	endif;
	
	
	//safe to cast the vehicles location as gate lane controller because of above validation
	gateLane := vehicle.myPrimaryActualLocation.CM_LaneController;
	
	//Should do the boom gate open before here if this fails the truck can not proceed to the yard;
	
	boomEventTerminal := self.myTerminal.getTerminalEvent(Event_Raise_Boom);
		
	// AT THE MOMENT HAVE NOT DECIDED HOW TO HANDLE FAILURE. PROBABLY WORTH MOVING
	// ALL THE BELOW CODE TO A USERNOTIFICATION METHOD WHICH REACTS TO SUCCESS OR A TIME OUT
	// WHICH EVER COMES FIRST.
	
/*	if self.doOpenCloseBoom(true,gateLane) &lt; 0 then
		create error transient;		
		error.errorNo := 84324;
		error.errorDescr := "Boom Gate failed to open";
		_errorMsgs.add(error);
		return;
	endif;*/
	
	// Lane one for some reason is configured to act like an out lane.
	if gateLane.vehicleDirection = CM_LaneController.Is_In_Lane then	 //cnwgb1 23 May 2008 PAR 16483
		if gateLane.ident = "1" then
			gateLane.causeEvent(boomEventTerminal, true, BoomGateOut_Open);
		else
			gateLane.causeEvent(boomEventTerminal, true, BoomGateIn_Open);
		endif;
		self.doProceedJobIntoYard(vehicle, roadJob, _errorMsgs);
	elseif gateLane.vehicleDirection = CM_LaneController.Is_Out_Lane then   //cnwgb1 23 May 2008 PAR 16483
	//epr 6/9/07 updated after email from micheal peirce gate lanes 7 &amp; 8 share an adam device so lane 7 has 3 for open
		if gateLane.ident = "7" then
			gateLane.causeEvent(boomEventTerminal, true, BoomGateIn_Open);
		else
			gateLane.causeEvent(boomEventTerminal, true, BoomGateOut_Open);
		endif;
		
		self.doProceedJobRoadExit(roadJob, _errorMsgs);
	else
		self.addError(Err_Unexpected_Program_Error, 
					app.getErrorString1(Err_Unexpected_Program_Error, 'The gate lane (' &amp; gateLane.getID &amp;') has no defined direction.' &amp;
									'This may be due to two trucks going different directions being in the same lane.'),
					_errorMsgs);
	endif;
	
	if (not _errorMsgs.isEmpty) then
		return;
	endif;
	//send a msg to raise the boom arm on this gate lane
//	create boomGateTcp transient;
//	boomGateTcp.init(gateLane);
	
	
epilog
//	delete boomGateTcp;
	
end;


</source>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doProceedJobIntoYard" id="82ea7b22-9b54-4f30-9590-100154fd7b39">
        <source>doProceedJobIntoYard(_vehicle : CM_Vehicle input; _roadJob : CM_RoadJob input; _errorMsgs : DTO_HandHeldGateErrorDict input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	wle				: CM_WorkListEntry;
	wleArray		: CM_WLEArray;
	lc				: CM_LocationsController;
	laneController	: CM_LocationsController;
	error			: CM_Error;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636

/*
	CCMS 1061 This is all being done in getNextLocation_IN
	create wleArray transient;
	_roadJob.getAllWLEs(wleArray);
	//loop through work list entries to find a to location for the truck
	foreach wle in wleArray do
		if wle.status = WLE_COMPLETED or (not wle.isReceipt) then
			continue;
		endif;
		
		lc := wle.getLocationForMode(QUEUE_MODE);
	
		if lc = null then
			if wle.myTrackedItem &lt;&gt; null then
				self.addError(Err_Gate_ContainerNotQueued, 
							app.getErrorString1(Err_Gate_ContainerNotQueued, wle.myTrackedItem.id),
							_errorMsgs);
				return;
			else
				self.addError(Err_Gate_ContainerNotQueued, 
							app.getErrorString1(Err_Unexpected_Program_Error, 'No yard location has been resolved for work list entry "' &amp; wle.String &amp; '"'),
							_errorMsgs);
				return;
			endif;
		endif;
		
		if CM_RTGController.hasInstance(lc) then
			laneController := lc.CM_RTGController.getMyLaneController();
			if laneController = null then
				self.addError(Err_Gate_ContainerNotQueued, 
						app.getErrorString1(Err_Unexpected_Program_Error, 'Failed to resolve lane controller from ' &amp; lc.String),
						_errorMsgs);
				lc := null;
				return;
			endif;
			
			lc := laneController;
		endif;
		
		if lc &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	//if we get here and the lc is still null, then must be release containers only
	//so use the job sheet's myInTerminalUnknownLC
	if lc = null then
		lc := _roadJob.myJobSheet.CM_RoadJobSheet.myInTerminalUnknownLC;
	endif;
*/
	lc := _roadJob.myVehicleVisit.myGateIn.getNextLocation_IN(_vehicle);

	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveVehicle(_vehicle, lc.CM_YardController, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		//turn the errors into alert for the controller 
		//AND turn then into errors to be passed back to the hand held
		app.myPassport.createAlertsFromErrors(EVENT_AT_PreGateAlert, _roadJob);
		self.createErrorsFromPassport(_errorMsgs);
	endif;
	

epilog
	delete wleArray;
end;


</source>
        <access>protected</access>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doProceedJobRoadExit" id="a9b1cc00-72c2-4f9d-b193-1f5d6ce0ac37">
        <source>doProceedJobRoadExit(_roadJob : CM_RoadJob input; _errorMsgs : DTO_HandHeldGateErrorDict input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
16 Feb 2024	 navnk30	 ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit	
----------   ----------  --------------------------------------------------
*/
vars
	alertCreated			: Boolean;
	error					: CM_Error;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	
	if _roadJob.status &lt;&gt; JOB_COMPLETE then
		if _roadJob.autoComplete then
			app.msgBox('Cannot process Road Exit as job still has work entries that are not complete and the Job is an auto-complete job.','Road Exit', MsgBox_Information_Icon + MsgBox_OK_Only);
			return;
		else
			app.msgBox('Cannot process Road Exit as job still has work entries that are not complete.','Road Exit', MsgBox_Information_Icon + MsgBox_OK_Only);
			return;	
		endif;	
	endif;
	//app.myPassport.setWarningsIgnored(true);
	if app.myPassport.myTerminal.getConfig(GateInAutoCompleteBkgrnd).Boolean then
		app.myTrxUA.trxRoadJobCompleteReceipt(app.myPassport, alertCreated);
		
		self.createErrorsFromPassport(_errorMsgs);
	
		return;
	endif;
	
	//app.myTrxDA.trxRoadExit(_roadJob, app.myPassport);		//16.02.2024 navnk30 #62414
	app.myTrxDA.trxRoadExit(_roadJob, null, app.myPassport);	//16.02.2024 navnk30 #62414
	
	if (not app.myPassport.trxCompletedOK) then
		//turn the errors into alert for the controller 
		//AND turn then into errors to be passed back to the hand held
		app.myPassport.createAlertsFromErrors(EVENT_AT_PreGateAlert, _roadJob);
		
		self.createErrorsFromPassport(_errorMsgs);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
