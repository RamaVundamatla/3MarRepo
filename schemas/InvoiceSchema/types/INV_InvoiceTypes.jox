    <JadeMethod name="timerEvent" id="4f5072fb-66fe-4145-af4a-0d64713b8fca">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			Filters the table once the user finishes typing

Parameters:			eventTag	Integer	The event tag triggered

Return Value:		NONE

Date				Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

begin
	if eventTag = self.Timer_TableData_Filter then
		self.doFilterTable();
	endif;
	
	inheritMethod(eventTag);
	
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2a5372c3-ad7a-4329-afc6-783ad006c24c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 April 2018 08:00:48.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006208, locale);
	btnSurcharge.translateBubbleHelp(Xlat_0022372, locale);
	btnSurcharge.translateCaption(Xlat_0022373, locale);
	shtEntDetail.translateCaption(Xlat_0002120, locale);
	shtNarration.translateCaption(Xlat_0002121, locale);
end;</source>
    </JadeMethod>
</GUIClass>
