    <JadeMethod name="isRelease" id="54d2dbda-f602-475b-bce6-925a0fb7d938">
        <source>isRelease() : Boolean;
/*
Author:      cnwspg1
Date:        12 January 2000
Description: Simple job to test whether this is a rail release or not.
						Over time this function should be moved further up the class
						Hierarchy to CM_Job. In the meantime I will leave it here.
06 Mar 2025 navma1 		MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
--------------------
Fixes
*/
vars
	wle 		: CM_WorkListEntry;
	wleArr		: CM_WLEArray;
begin
	
	create wleArr transient;
	self.workListEntries.copy(wleArr);						//06.03.2025 navma1 #MTN-34179
	
	foreach wle in wleArr discreteLock do					//06.03.2025 navma1 #MTN-34179
		if wle.myRequest.CM_YardRequest.isReceipt then
			return false;
		endif;
	endforeach;

	return true;
epilog
	delete wleArr;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTransitJob" id="3b18c820-5fab-4a2e-b85f-6e07172fe089">
        <source>isTransitJob(): Boolean;

vars
	inOut : CM_RailJSInOut;
	wagon : CM_Wagon;
begin

	if inOutRakeSheet &lt;&gt; null then
		inOut := inOutRakeSheet.inOut;
		
		if inOut.outwards = Rail_JSIO_Type_Transit then
			return true;
		endif;
	endif;
	
	foreach wagon in self.allWagons discreteLock do
		if wagon.isInTransit() then
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jobId" id="e72b13e3-70f0-45db-9dcf-f49eebe7f889">
        <methodInvocation>mapping</methodInvocation>
        <source>jobId(set: Boolean; value: String io) mapping;
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
11 Nov 2024	navbs1	Bug MTN-33360: EUP - Wrong Start and End Times for Rail Receive

*/

vars
	aStr	:	String;
	aRequest	:	CM_Request;
	delRequest	:	CM_DeliveryRequest;
	tiRequest	:	CM_TIRequest;
	wasDisplayed	:	Boolean;
//	maxLen	:	Integer;
	ti				: CM_TrackedItem;
	invalid 		: Boolean;
	
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	value := null;
	
	if app.myPassport.isVASEnabled() then 							//11.11.2024  navbs1  #33360
		value := self.getJobId();
		return;
	endif;
	
	if self.allRequests.isEmpty then
		if self.id &lt;&gt; null then
			value := self.id;
		else
			value := "Unknown!";		
		endif;
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	
	aStr := railTransAreaId.trimBlanks;
	
	foreach aRequest in self.allRequests discreteLock do				//06.03.2025 navma1 #MTN-34179

		if aRequest.isDeliveryRequest then								//06.03.2025 navma1 #MTN-34179
			delRequest  := aRequest.CM_DeliveryRequest;
			aStr 		:= aStr &amp; " " &amp; delRequest.totalRequested.String;
			
			//GD NFS Xpose 1378 use operator group if there is one
			if delRequest.myOperatorGroup &lt;&gt; null then
				aStr := aStr &amp; " " &amp; delRequest.myOperatorGroup.code;
			else
				aStr := aStr &amp; " " &amp; delRequest.operatorCode.trimRight;
			endif;			
			
			aStr := aStr &amp; " " &amp; delRequest.isoType.trimRight;
			aStr := aStr &amp; " " &amp; delRequest.consignee.trimRight;
			
			if delRequest.clean then
				aStr := aStr &amp; " Cln";
			else
				aStr := aStr &amp; " Drty";
			endif;
			aStr := aStr &amp; " " &amp; self.requestNum.trimBlanks;		//GD Xpose 2697	
			if delRequest.ids &lt;&gt; null and delRequest.ids.size &gt; 0 then
				aStr := aStr &amp; " (!)";
			endif;
		else
			//----------------
			//TI Request
			//----------------
			invalid := false;
			if not wasDisplayed then
				tiRequest := aRequest.CM_TIRequest;

				ti := tiRequest.trackedItem;
				if ti &lt;&gt; null then
					ti.edition;
					
					if invalid then
						continue;
					endif;
					
					if tiRequest.isReceipt then
						aStr := aStr &amp; " Receipt " &amp; ti.wagon; //GD  Xpose 1372
					else
						aStr := aStr &amp; " Release " &amp; ti.id &amp; " " &amp; self.requestNum.trimBlanks;		//GD Xpose 2697;
					endif;
					wasDisplayed := true;
					break;	//Might as well quit here
				endif;
			endif;
		endif;
	endforeach;
	
	//Next call is painful
	//maxLen := CM_Job.getProperty("jobId").getLength;
	
	if aStr.length &gt; JOBID_LEN -1 then
		aStr := aStr[1:JOBID_LEN -1];
	endif;
	
	value := aStr;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jobTypeId" id="877c8755-6c89-4607-a17a-c2d0689b3909">
        <methodInvocation>mapping</methodInvocation>
        <source>jobTypeId(set: Boolean; _value: String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navhl20 Bug 64101: EUP - For the Pack Job the parent and child details are empty on the Complete Job form  
*/

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	if self.isRelease then
		_value := "Load Rail";
	else
		_value := "Unload Rail";
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadToOperations" id="0d1c83db-1a90-4f89-bc45-8dd9d6cd58d1">
        <updating/>
        <source>loadToOperations(ioRake : CM_RailJSInOutRake; doAutoPlan : Boolean) updating;
/*
Method:			loadToOperations();	
Author:     cnwspg1 created on 01 February 2000
Description:

Fixes:
Date        User      Description
--------    --------  ------------------
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/
vars
	request : CM_Request;
	yrequest : CM_YardRequest;
	ta : CM_TerminalArea;
	ti : CM_TrackedItem;
	rta : CM_BlockStack;
	theBR : CM_BulkRelease;
	flags : Integer;
	lMoveControl : CMIF_MoveController;
	rtnValue, ignoreWarnings : Boolean;
begin

	if self.status &lt;&gt; JOB_UNACTIONED and 
	   self.status &lt;&gt; JOB_PART_COMPLETE	then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(VB_JOB_NOT_UNACTIONED, self.jobId, self.statusString, null, null);
		return;
	endif;

	ta := ioRake.myRail;
	sharedLock(ta);
	if ta.CM_Rail.myTransferArea = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_RTA, ta.id, null, null);
		return;
	endif;
	rta := ta.CM_Rail.myTransferArea;
	//status := JOB_WLES_CREATED;
	//self.createWLEs;
//	self.createPlanGhosts;
	/* A release, if specific release, plan it to the appropriate RTA
	else ignore as the enqueueJob methods will handle it.	*/
	/* Lastly put the job in the passed in ioRake */
	self.inOutRakeSheet := ioRake;
	self.railTransAreaId := ioRake.rake;	
//	self.railTransAreaId := ioRake.myRail.id;	

	foreach request in self.allRequests do

 		yrequest := request.CM_YardRequest;
		// ### AKB2004NOV CCMS 1282. Make the requests from the new screen actioned.
		theBR := yrequest.bulkRelease;
		if theBR &lt;&gt; null then
			if theBR.isReserveHeader() then
				yrequest.setBulkRelease(null);
				yrequest.setMyOriginatingBulkRelease(theBR);
			endif;
		endif;
	endforeach;


	if not doAutoPlan then
		return;
	endif;
	
	create lMoveControl transient;
	lMoveControl.isSystemMove := true;
	lMoveControl.setJobForMove(self);
		
	foreach request in self.allRequests do

 		yrequest := request.CM_YardRequest;

		/* Only autoplan those that don't need intervention */
 		if not (yrequest.needCOU or yrequest.needGenerator) then
 			continue;
 		endif;
		
		/* If release of specific TI, queue plan to RTA associated with area */
		ti := yrequest.getTrackedItem;

		if ti &lt;&gt; null then 
			flags := flags.bitOr(MP_RT_IGNORE_WARNINGS);
			flags := flags.bitOr(MP_RT_AUTOPLAN);

			lMoveControl.setMyTrackedItem(ti);
			lMoveControl.setMyToPrimaryLocation(rta.myLocationsController);

			app.myUtilityUA.utlUpdateMoveTrackedItem(lMoveControl, app.myPassport);
			if app.myPassport.hasErrors then
				return;
			endif;
		endif;

	endforeach;

	/* Finally always enqueue that which hast been queue moved. */
	//self.enqueueJob; Already done in the move code now

epilog
	delete lMoveControl;

end;</source>
        <Parameter name="ioRake" type="CM_RailJSInOutRake"/>
        <Parameter name="doAutoPlan" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveToTransit" id="688ce0fd-500d-481c-9533-de9593a39d86">
        <updating/>
        <source>moveToTransit(_newIORake : CM_RailJSInOutRake) updating;
/*
Author:     cnwspg1 created on 01 February 2000
Description:Normally call from a drag-drop on the rail tree or
						via a mouse menu. This will load the job to the nominated rake

Fixes:
Date        User      Description
--------    --------  ------------------
*/
vars

begin

	if _newIORake = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _newIORake passed to method');
		return;
	endif;

	//PAR9568 OK to move unactioned and part complete jobs
	if self.status = JOB_COMPLETE then
		app.raiseCMException2(RakeTransferJobComplete, self.jobId, _newIORake.getDisplayDetails(false), null, null);	
		return;
	endif;				

	if _newIORake.inOut.outwards &lt;&gt; Rail_JSIO_Type_Transit then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Rail Line Type');
		return;
	endif;				
		
	self.inOutRakeSheet := _newIORake; //self.myTerminal.myRailJobSheet.inouts[Rail_JSIO_Type_Transit].inoutRakes[inOutRakeSheet.rake];

end;</source>
        <Parameter name="_newIORake" type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="moveToTransitReturn" id="46d21ecb-5c3b-41b4-8cd7-dcd590c64516">
        <updating/>
        <source>moveToTransitReturn(_newIORake : CM_RailJSInOutRake) updating;
/*
Author:     cnwspg1 created on 28 February 2000
Description:

Fixes:
Date        User      Description
--------    --------  ------------------
12/07/2006	cnwdad1		PAR #11895.
*/
begin
// cnwdad1 12/07/2006 - PAR #11895.
//	if self.status &lt;&gt; JOB_UNACTIONED then
	if self.status = JOB_COMPLETE then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Job has been actioned');	
		return;
	endif;
	
	if _newIORake = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _newIORake passed to method');
		return;
	endif;

	if _newIORake.inOut.outwards &lt;&gt; Rail_JSIO_Type_In then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Rail Line Type');
		return;
	endif;								
	
	self.inOutRakeSheet := _newIORake;
end;</source>
        <Parameter name="_newIORake" type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d43a9251-10a2-442c-ad1b-0061b11ad842">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars
	proxyJob	: CM_RailJob;
	completedOK		: Boolean;
begin

	proxyJob := inheritMethod();

	proxyJob.inOutRakeSheet := self.inOutRakeSheet;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyJob;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyJob;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="rebuildStatus" id="3fa9a1b8-d004-4f2c-97dd-232dbea23e68">
        <updating/>
        <source>rebuildStatus() updating;

vars
//	wle	:	CM_WorkListEntry;
//	delJob: Boolean;
begin

	inheritMethod();
	
//JOB DOES NOT GET ERASED UNTIL RAKE IS CLEARED

/*	if status = JOB_COMPLETE then
		//GD 2/5/03 Can't have, otherwise it's status would not be JOB_COMPLETE
		// rs 3 October 2000 if job is completed and hanging then remove it
		if self.containsIncompleteRailRelease() or self.containsIncompleteReceipt() then
			delJob := false;
		endif;
		
		// GD - All wle's must already be complete for self.status to be JOB_COMPLETE
		foreach wle in self.workListEntries do
			if wle.status = WLE_COMPLETED then
				if wle.myTrackedItem &lt;&gt; null then
					if wle.myTrackedItem.getPrimaryLocation(REAL_MODE) = null then
					else 
						delJob := false;
					endif;
				else
					delJob := false;
				endif;
			else
				delJob := false;
			endif;
			if wle.myRequest &lt;&gt; null and 
			   wle.myRequest.CM_YardRequest.isReceipt then
				delJob := false;
			endif;
		endforeach;
	endif;

	if delJob = true then
		self.erase(NORMAL_ERASE);
	endif;*/

end;</source>
    </JadeMethod>
    <JadeMethod name="removeFromJobSheet" id="8c6ca691-fc26-4c35-9d8e-69110548cf3a">
        <source>removeFromJobSheet();
// ---------------------------------------------------------------------------
// Created:     09 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myJobSheet = null then
		return;
	endif;
	
	self.myJobSheet.removeJob(self);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeTI" id="4fd57ad6-e888-4513-ad30-84fd647b966c">
        <updating/>
        <source>removeTI(_ti : CM_TrackedItem input; _request : CM_Request) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// ---------------------------------------------------------------------------
vars

begin

	exclusiveLock(self);

	if (_ti = null or _request = null ) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_TI_LINK_PARAM, null, null);
		return;		
	endif;
	
	if (not _request.isKindOf(CM_YardRequest)) then
		// if this ever happens then may need to look at reworking this method
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Request is of unhandled type (' &amp; _request.String &amp; ')');
		return;
	endif;

	sharedLock(_request);
	exclusiveLock(_ti);

	//-----------------------
	// Update appropriate instvar on TI
	//-----------------------
	//Check link, if already us, or Null, OK, else error!
	if (_request.CM_YardRequest.isReceipt) then
		if (_ti.jobRailReceive = null) then 
			return; 
		endif;

		if (self = _ti.jobRailReceive) then
			//_ti.doRemoveJob(self, true);
			if self.allReceiveTrackedItems.includes(_ti) then
				self.allReceiveTrackedItems.remove(_ti);
			endif;			
		else
			if _ti.jobRailReceive &lt;&gt; null or
			   _ti.jobRoadReceive &lt;&gt; null then
				app.setContinueCMExceptions(false);
				app.raiseCMException1(ERR_TI_HAS_REC_JOB, _ti.id, null, null);
				return;
			endif;
		endif;
	else
		if (_ti.jobRailRelease = null) then
			return;
		elseif (self = _ti.jobRailRelease ) then
			//_ti.doRemoveJob(self, false);
			if self.allReleaseTrackedItems.includes(_ti) then
				self.allReleaseTrackedItems.remove(_ti);
			endif;
			return;
		elseif _ti.hasBeenMerged() then	//18 Sep 2019	NDL	TFS 42876 - moved code up
			// TFS 42872 DR splitting of WLEs creates new job and the zombie is left
			return;
		elseif _ti.myCargoType.allowDuplicates and _ti.jobRailRelease &lt;&gt; null and self &lt;&gt; _ti.jobRailRelease then	//18 Sep 2019	NDL	TFS 42876
			//last piece split off original wle moved to a different location than the first piece/s that were  split off
			if self.allReleaseTrackedItems.includes(_ti) then
				self.allReleaseTrackedItems.remove(_ti);
			endif;
			return;
		else
			//What is this?
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_TI_HAS_REL_JOB, _ti.id, null, null);
			return;			
		endif;
	endif;

	self.updateObjectEdition(self);	// par 30292

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="removeWagon" id="17d4134c-6f07-4fbd-8b2d-c473e24242e9">
        <updating/>
        <source>removeWagon(_wagon : CM_Wagon) updating;
//--------------------------------------------------------------
//Created: 23 October 2003 By: cnwgd1
//--------------------------------------------------------------
vars
begin

	if _wagon = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name,'Null wagon passed to method.');
	endif;
	
	if (not self.isRelease) then
		return;
	endif;	
	
	if self.allWagons.includes(_wagon) then
		self.allWagons.remove(_wagon);
	endif;
	
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="returnJobToBuildPriority" id="7df60d0e-18a8-46b6-96fd-a4fc3d64bb68">
        <updating/>
        <source>returnJobToBuildPriority(_newIORake : CM_RailJSInOutRake; _passport : CM_Passport input) updating;
/*
Method:			returnJob();	
Author:     cnwspg1 created on 28 January 2000
Description:Return an individual Job back to Build priority entry part of RailOps2


Fixes:
Date        User      Description
--------    --------  ------------------
*/
//Changed: April 2003 By: cnwgd1 - pass in the _newIORake and set it here.
vars
	bp 			: CM_RailJSInOutRake;
	request 	: CM_Request;
	newJob 		: CM_RailJob;
	br			: CM_BulkRelease;
	ti			: CM_TrackedItem;
	
begin
	bp := _newIORake;
	
	if bp = null then
		// Lets try and find it first
		bp := self.getRakeSheet(Rail_JSIO_Type_Build, self.railTransAreaId.trimBlanks);
	elseif bp.inOut.outwards &lt;&gt; Rail_JSIO_Type_Build then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid type of rail line passed to method.');
		return;	
	endif;

	if bp = null then	
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null InOutRakeSheet.');
		return;
	endif;
	//th2 on the 29/06/2007 for PAR#14342 - if it's in an invalid state, why? should not be disguising this.
	//at any rate - when returning a job where the containers are still onship, this completes the job
	//and fails to disassociate the containers from the release and the job casuing problem further on.
	//self.rebuildStatus(); //Do some sef healing first.	
	
	if self.status = JOB_COMPLETE then
		// Cannot transfer complete jobs
		return;
	elseif self.status = JOB_UNACTIONED then
		// Nothing to split, just return the job
		//th2 15/05/2007 PAR14020
		if self.allRequests.first &lt;&gt; null then
			br := self.allRequests.first.myOriginatingBulkRelease;
			if br &lt;&gt; null then
				//releasedItemStrings this is now used to compare number outstanding
				//previously released TIs still associated in the bulk release's allTrackedItemsReleased collection
				
				// Anca FIXUP.  Should clear assigned items, NOT released items.
				//br.releasedItemStrings.clear();
				
				
				//th2 PAR14193 - clear assigned items and delete rails jobs
				foreach ti in br.allTrackedItemsAssigned do
					//PAR 14669 - delete other jobs associated with this release
					if ti.jobRailRelease &lt;&gt; null and ti.jobRailRelease &lt;&gt; self then
						ti.jobRailRelease.erase(NORMAL_ERASE);
					endif;
					
					/*br.removeTIAssigned(ti);
					if self.allReleaseTrackedItems.includes(ti) then
						self.allReleaseTrackedItems.remove(ti);
					endif;
					*/
				endforeach;
				
				br.setStatus(BR_ACTIVE, false, false);
			endif;
		endif;	
		self.erase(NORMAL_ERASE);
		
	elseif self.status = JOB_PART_COMPLETE then
		//th2 PAR#14152 - this is a no go now. There are too many problems relating to the remaining
		//requests being disassociated from their originalBulkRelease and then looked up again when the rail line is cleared.
		//In the event of duplicate release numbers, the system was re-associating the remaining requests withe wrong release.
		app.raiseCMException(Canno_assig_relea_back_relea_r, null, null);
	endif;

end;</source>
        <Parameter name="_newIORake" type="CM_RailJSInOutRake"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDate" id="afa8008b-3adc-4199-82d5-0ab61e594b6e">
        <updating/>
        <source>setDate(_date : TimeStamp) updating;
//--------------------------------------------------
// Created:	22 June 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpDate : Date;
	tmpTime : Time;
begin
	
	tmpDate := _date.date;
	tmpTime := _date.time;

	if (not tmpDate.isValid()) then
		tmpDate := app.actualTimeServer.date;
	endif;
	
	if (not tmpTime.isValid()) then
		tmpTime := app.actualTimeServer.time;
	endif;	
	
	self.date.setDate(tmpDate);
	self.date.setTime(tmpTime);
	
end;</source>
        <Parameter name="_date" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setEntryOverrideFlag" id="b05c784e-ae63-4503-8f5d-15d3defef763">
        <source>setEntryOverrideFlag();
//See CM_Job description...
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle	:	CM_WorkListEntry;
	flags	:	Integer;
	rtqe : CM_RTQueueEntry;
begin
	flags := 0;
	flags := flags.bitOr(MP_RT_AUTOPLAN );
	flags := flags.bitOr(MP_RT_IGNORE_WARNINGS );

	foreach wle in self.workListEntries do
		foreach rtqe in wle.allRTQueueEntries do
			rtqe.overRideFlags := flags;
		endforeach;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="263c45f1-e869-4881-b9da-6c5ae5f33de9">
        <updating/>
        <source>setForCreate(proxyJob : CM_RailJob ;_theTerminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(proxyJob,_theTerminal);
	
	self.date := app.actualTimeServer;
	self.myTerminal.myRailJobSheet.addJob(self, 0);	
	self.retrospectiveDT := proxyJob.retrospectiveDT;// ### TFS 62857 (62858) 18Mar2024 NAVPW1
	
end;</source>
        <Parameter name="proxyJob" type="CM_RailJob"/>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="24f312ed-636e-485e-bd7d-e2fc1fea24dd">
        <updating/>
        <source>setForUpdate(proxyJob: CM_RailJob;_theTerminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(proxyJob,_theTerminal);

	self.railTransAreaId := proxyJob.railTransAreaId;
	self.date := proxyJob.date;
	self.consignorVoyageCode := proxyJob.consignorVoyageCode;
	self.requestNum := proxyJob.requestNum;
	self.voyageCode := proxyJob.voyageCode;

	self.myTerminal := proxyJob.myTerminal;
	if self.myTerminal= null then
		self.myTerminal := _theTerminal;
	endif;
	
	self.inOutRakeSheet := proxyJob.inOutRakeSheet;
end;</source>
        <Parameter name="proxyJob" type="CM_RailJob"/>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setInOutRakeSheet" id="c6e652f2-e832-4292-86b4-9f74671f6ded">
        <updating/>
        <source>setInOutRakeSheet(_inOutRakeSheet : CM_RailJSInOutRake) updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// ---------------------------------------------------------------------------

vars
	br : CM_BulkRelease;
begin
	self.inOutRakeSheet := _inOutRakeSheet;
	
	if _inOutRakeSheet = null then
		self.railTransAreaId := self.myJobSheet.getTrainUsed(); // PAR 25980
	else
		self.railTransAreaId := _inOutRakeSheet.myRail.id;
	endif;
	
	// PAR 25980
	if self.requestNum &lt;&gt; null then
		br := self.getMyBulkRelease();
		
		if br &lt;&gt; null then
			br.updateObjectEdition(br);	// par 30292
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_inOutRakeSheet" type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="setProxyRailJob" id="6b130745-4538-48de-a253-2fb5c8221b19">
        <updating/>
        <source>setProxyRailJob(pRemarks, pConVoy, pReqNum, pVoyCode, _transAreaId : String;
				pWagon: CM_Wagon; pIOType : Integer; _terminal : CM_Terminal; _date : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.consignorVoyageCode := pConVoy;
	self.requestNum := pReqNum;
	self.setDate(_date);
	self.voyageCode := pVoyCode;
	self.myTerminal := _terminal;
	
	if _transAreaId &lt;&gt; null then
		self.inOutRakeSheet := self.getRakeSheet(pIOType, _transAreaId);
		
		// always set self.railTransAreaId to that of the rake
		// as the passed in _transAreaId may have changed or is invalid
		self.railTransAreaId := self.inOutRakeSheet.rake.trimBlanks;
	endif;
end;</source>
        <Parameter name="pRemarks" type="String"/>
        <Parameter name="pConVoy" type="String"/>
        <Parameter name="pReqNum" type="String"/>
        <Parameter name="pVoyCode" type="String"/>
        <Parameter name="_transAreaId" type="String"/>
        <Parameter name="pWagon" type="CM_Wagon"/>
        <Parameter name="pIOType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_date" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setTIForRelease" id="e2a7f6aa-6a5e-4f73-b18e-429caafbed3f">
        <updating/>
        <source>setTIForRelease(_ti : CM_TrackedItem input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 08 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	ti	: CM_TrackedItem;
	doEDIDataOutwardRail : Boolean;
begin

	inheritMethod(_ti, _passport);
	
	doEDIDataOutwardRail := self.myTerminal.getConfig(GenerateOutwardRailManifest).Boolean;

	if (not doEDIDataOutwardRail) then
		return;
	endif;
	
	app.myUtilityCA.utlCreateOutwardRailTIs(_ti);
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="transportMode" id="3dbf2fb2-352e-4c06-a2e9-65ef922ca4be">
        <methodInvocation>mapping</methodInvocation>
        <source>transportMode(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     12 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		inheritMethod(set, _value);
		return;
	endif;
	
	_value := TI_TRANSMODE_RAIL;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateStatus" id="1c8610cc-2f8f-4607-ba56-4962d3937e77">
        <updating/>
        <source>updateStatus() updating;
//Check the contents of the WLE's, and updates the status of this job
//accordingly.
//-----------------------------------
//Rail release jobs are special. The R/T module allows for droppage on 3 
//different locations, the wagon (no problem), the rail rake position (same as wagon)
//or the Rake id only. If its been moved to the rake Id, then in fact it has been
//moved to the RTA for the rail rake. If any jobs have TI's in this position, then
//we set the status of the job to JOB_WLES_PART_COMP
//-----------------------------------
vars

	newStatus	:	Integer;
begin
	exclusiveLock(self);

	// 31890 refactor for job print fixup
	newStatus := self.getNewStatus();
	
	if newStatus &lt;&gt; self.status then
		self.status := newStatus;
		// 31890 prior code mixed the update with the tests now in getNewStatus, and only JOB_PART_COMPLETE made it to this causeEvent
		//   IS THIS INTENDED? or just an accident of coding?  (see the CM_Job updateStatus for comparison)
		if self.status = JOB_PART_COMPLETE then
			self.causeTerminalEvent(self.Event_Mode_Update);
		endif;
	endif;
epilog
	unlock(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateTICollections" id="fccf96e4-9d4c-4e0c-b011-e3f47f0de0a1">
        <updating/>
        <source>updateTICollections(_trackedItem: CM_TrackedItem; _extra :Any) updating;
//--------------------------------------------------------------
//Created: 11 February 2003 By: cnwgd1
//--------------------------------------------------------------
// 01/04/2010	cnwcs5	par 23383 - _extra parameter (not used)
vars
	
	otherRailJob : CM_RailJob;

begin
	inheritMethod(_trackedItem, _extra);// 01/04/2010 cnwcs5 par 23383
	
	if (not app.myPassport.noErrors) then
		return;
	endif;

	if self.isRelease then
		if (not self.allReleaseTrackedItems.includes(_trackedItem)) then
			if _trackedItem.jobRailRelease &lt;&gt; null and _trackedItem.jobRailRelease &lt;&gt; self then
				otherRailJob := _trackedItem.jobRailRelease;
				if _trackedItem.canMergeBreakBulk and otherRailJob &lt;&gt; null then	//16 Sep 2013	NDL	Par 32479 
					otherRailJob.allReleaseTrackedItems.removeIfPresent(_trackedItem);
				else
					//th2 04/06/2007 for PAR14180 - avoid duplicate relationship inverse
					app.raiseCMException1(ERR_TI_HAS_REL_JOB, _trackedItem.id, null, null);
					return;
				endif;
			endif;
			self.allReleaseTrackedItems.add(_trackedItem);
			
		endif;
		if self.allReceiveTrackedItems.includes(_trackedItem) then
			self.allReceiveTrackedItems.remove(_trackedItem);
		endif;		
	else
		if (not self.allReceiveTrackedItems.includes(_trackedItem)) then
			if _trackedItem.jobRailReceive &lt;&gt; null and _trackedItem.jobRailReceive &lt;&gt; self then
				//12 Sep 2013	NDL	Par 32479 - multi pre-note break bulk on train
				otherRailJob := _trackedItem.jobRailReceive;
				if _trackedItem.canMergeBreakBulk and otherRailJob &lt;&gt; null then
					otherRailJob.allReceiveTrackedItems.removeIfPresent(_trackedItem);
				else
					//th2 04/06/2007 for PAR14180 - avoid duplicate relationship inverse
					app.raiseCMException1(ERR_TI_HAS_REC_JOB, _trackedItem.id, null, null);
					return;
				endif;
			endif;
			self.allReceiveTrackedItems.add(_trackedItem);
		endif;
		if self.allReleaseTrackedItems.includes(_trackedItem) then
			self.allReleaseTrackedItems.remove(_trackedItem);
		endif;			
	endif;

	self.addWagon(_trackedItem);

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_extra" type="Any"/>
    </JadeMethod>
    <JadeMethod name="updateTICollectionsUnassign" id="67ac1459-b16e-42f6-bbff-e82e692b8caa">
        <updating/>
        <source>updateTICollectionsUnassign(_trackedItem: CM_TrackedItem) updating;
//--------------------------------------------------
// Created:	23 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_trackedItem);
	if (not app.myPassport.noErrors) then
		return;
	endif;

	if self.isRelease then
		if self.allReleaseTrackedItems.includes(_trackedItem) then
			self.allReleaseTrackedItems.remove(_trackedItem);
		endif;
	else
		if self.allReceiveTrackedItems.includes(_trackedItem) then
			self.allReceiveTrackedItems.remove(_trackedItem);
		endif;
	endif;
	
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="d0d8e108-6478-45eb-a846-a01c4740fab5">
        <source>validateForCreate();
//--------------------------------------------------------------
//Created: 11 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal',  null, null);
		app.raiseCMException(Input_required_field_terminal,  null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForReturnJob" id="f2cdb7c5-27ff-46a5-acc3-91322153b9d8">
        <source>validateForReturnJob();
//--------------------------------------------------------------
//Created: 02 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	request : CM_Request;		
begin
	
	//////////////////////////////////////
	// Start handing the job-&gt;request-&gt;wle hierarchy 
	// recursively
	//////////////////////////////////////

	foreach request in self.allRequests do
		request.validateForReturnJob();
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateRakeTransfer" id="dab23dc4-7d1e-47ab-b8b0-444c92ec6bff">
        <source>validateRakeTransfer(_newIORake : CM_RailJSInOutRake; _passport : CM_Passport input);
//--------------------------------------------------
// Created:	02 December 2004 By: cnwgd1
//--------------------------------------------------
vars
	isRelease : Boolean;
	targetStr : String;
	currentIOType,
	newIOType : Integer;
begin
	
	if _newIORake = self.inOutRakeSheet then
		//already there
		return;
	endif;
	
	if _newIORake = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _newIORake passed to method');
		return;
	endif;			

	if self.status = JOB_COMPLETE then
		app.raiseCMException2(RakeTransferJobComplete, self.jobId, _newIORake.getDisplayDetails(false), null, null);
		return;
	endif;
	
	isRelease := self.isRelease();
	if  self.myJobSheet.isTrainJS() then
		newIOType := Rail_JSIO_Type_Build;
	else
		currentIOType := self.inOutRakeSheet.inOut.outwards;
		newIOType := _newIORake.inOut.outwards;	
	endif;
	if isRelease then
		// if part complete and moving to Build Priority then user has option to split job refer self.validateForReturnJob()
		// else carry on as moves to outward from build priority will always be unactioned (should always be unactioned)
		if newIOType &lt;&gt; Rail_JSIO_Type_Build
		and newIOType &lt;&gt; Rail_JSIO_Type_Out then
			//Tranfers of Release jobs can only be between Build Priority and Outward Rail.
			if currentIOType = Rail_JSIO_Type_Build then
				targetStr := app.getErrorString(Outward_Rail);
			elseif currentIOType = Rail_JSIO_Type_Out then
				targetStr := app.getErrorString(Rail_Release_Request);	
			else
				targetStr := app.getErrorString(Outward_Rail) &amp; ' or ' &amp; app.getErrorString(Rail_Release_Request);	
			endif;
			app.raiseCMException4(RakeTransferNotPermitted, self.jobId, self.inOutRakeSheet.getDisplayDetails(false), _newIORake.getDisplayDetails(false), targetStr, null, null);
		endif;	
	else
		/*PAR9568 OK to move part complete jobs
		if self.status &lt;&gt; JOB_UNACTIONED then
			app.raiseCMException2(VB_JOB_NOT_UNACTIONED, self.getTreeDescription(), self.statusString, null, null);
			return;
		endif;*/
		if newIOType &lt;&gt; Rail_JSIO_Type_In
		and newIOType &lt;&gt; Rail_JSIO_Type_Transit then
			//Tranfers of Receipt jobs can only be between Inward Rail and Transit Rail.
			if currentIOType = Rail_JSIO_Type_Transit then
				targetStr := app.getErrorString(Inward_Rail);
			elseif currentIOType = Rail_JSIO_Type_In then
				targetStr := app.getErrorString(Transit_Rail);	
			else
				targetStr := app.getErrorString(Inward_Rail) &amp; ' or ' &amp; app.getErrorString(Transit_Rail);	
			endif;			
			app.raiseCMException4(RakeTransferNotPermitted, self.jobId, self.inOutRakeSheet.getDisplayDetails(false), _newIORake.getDisplayDetails(false), targetStr, null, null);			
		endif;		

	endif;
	
	if _passport.hasErrors then
		return;
	endif;

	if currentIOType &lt;&gt; Rail_JSIO_Type_Build then
		// PAR 10180 - users do not want confirmation warning when moving from build priority to outward rail						
		if  self.myJobSheet.isTrainJS() then
			app.raiseCMWarning3(RakeTransferJobConfirm, self.getTreeDescription(), self.myJobSheet.getTrain().getCodeDateString(), _newIORake.getDisplayDetails(false), null, null, self);
		else
			app.raiseCMWarning3(RakeTransferJobConfirm, self.getTreeDescription(), self.inOutRakeSheet.getDisplayDetails(false), _newIORake.getDisplayDetails(false), null, null, self);
		endif;
	endif;
end;</source>
        <Parameter name="_newIORake" type="CM_RailJSInOutRake"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
