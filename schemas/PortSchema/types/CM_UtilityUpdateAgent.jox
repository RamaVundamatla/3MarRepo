    <JadeMethod name="utlUpdateSubTerminalDefaults" id="a2245642-f346-4066-bf99-567fa8c97905">
        <source>utlUpdateSubTerminalDefaults(_terminalObj:CM_Terminal;
							_isTurnedOn:Boolean;
							_wasTurnedOn:Boolean;		//cnwdad1 21/07/2009 - PAR #20325.
							_isAreaDefined:Boolean;	//26 Nov 2014	NDL	Par 35295
							_stForExportFullObj:CM_SubTerminal;
							_stForExportMTYObj:CM_SubTerminal;
							_stForImportFullObj:CM_SubTerminal;
							_stForImportMTYObj:CM_SubTerminal;
							_stForStorageFullObj:CM_SubTerminal;
							_stForStorageMTYObj:CM_SubTerminal;
							_stForImportGenObj:CM_SubTerminal;
							_stForExportGenObj:CM_SubTerminal;
							_stForStorageGenObj:CM_SubTerminal;
							_stForCargoOtherObj:CM_SubTerminal;
							_stForSourceBulkRdObj:CM_SubTerminal;		// cnwdad1 PAR 22205.
							_stForSourceBulkRlObj:CM_SubTerminal;		// cnwdad1 PAR 22205.
							_stForSourceBulkShObj:CM_SubTerminal;		// cnwdad1 PAR 22205.
							_stForSourceBulkPkObj:CM_SubTerminal;		// cnwdad1 PAR 22205.
							_stForTargetBulkObj:CM_SubTerminal;
							_stForBOLInwardsObj:CM_SubTerminal;
							_stForDelReq:CM_SubTerminal;			// 31 OCT 2022 NAVSKS20 TFS 52721
							_isAllowChangeInSubTerm:Boolean; 		// 31 OCT 2022 NAVSKS20 TFS 52721
							_passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		07 April 2009 by cnwdad1
//
// Purpose:		Utility method to update the specified Terminal's Sub-Terminal settings.
//
//	NOTE: The first time that Sub-Terminals are turned on, the system needs to take
//	the default Sub-Terminals and update all on-site TI's, all Pre-Notes and all
//	active Voyages.  Suffice to say, it will be a long transaction and should only
//	be done when no other activity is going on in JMT.
//
// Returns:		Nothing
//
//	If any errors occur in here (such as exceptions), then execution will be returned
//	to the calling transaction, which will deal with the mopping up.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 06/10/2009	cnwdad1		PAR #20914 - Changed to create a "receive" transaction
//							whenever a TI's Sub-Terminal is set to a default.
//
// 27/01/2010	cnwdad1		PAR 22205 (CCMS POL 1904).  Added extra Bulk Release
//							Sub-Terminal parameters.
// 21 Oct 2022	navsks20   	ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
// --------------------------------------------------------------------------------
constants
	LOOP_TIME	: Integer = (CNEC_MILLISECONDS_IN_SECOND * CNEC_SECONDS_IN_MINUTE);
	
vars
	voyageObj	: CM_Voyage;
	tiObj		: CM_TrackedItem;
	brObj		: CM_BulkRelease;
	bolObj		: CM_BOL;
	defaultObj	: CM_SubTerminal;
	clockCheck	: Integer;
	clockNot	: Integer;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	app.myValUA.valSubTerminalOptions(	_terminalObj,
										_isTurnedOn,
										_isAreaDefined,	//26 Nov 2014	NDL	Par 35295
										_stForExportFullObj,
										_stForExportMTYObj,
										_stForImportFullObj,
										_stForImportMTYObj,
										_stForStorageFullObj,
										_stForStorageMTYObj,
										_stForImportGenObj,
										_stForExportGenObj,
										_stForStorageGenObj,
										_stForCargoOtherObj,
										_stForSourceBulkRdObj,	// cnwdad1 PAR 22205.
										_stForSourceBulkRlObj,	// cnwdad1 PAR 22205.
										_stForSourceBulkShObj,	// cnwdad1 PAR 22205.
										_stForSourceBulkPkObj,	// cnwdad1 PAR 22205.
										_stForTargetBulkObj,
										_stForBOLInwardsObj,
										_passportObj);
	
	if (not self.checkValidationWithPassport(_passportObj)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_terminalObj);
	
	if _passportObj.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_terminalObj, true);
	endif;
	
	
	// If turning Sub-Terminals on, we need to set the defaults for existing cargo.
	
//	if _isTurnedOn and (not _wasTurnedOn) then
	if _isTurnedOn and (not _wasTurnedOn) and not _isAreaDefined then	//26 Nov 2014	NDL	Par 35295
		
		// First, start with all onsite cargo for the Terminal.
		
		foreach tiObj in _terminalObj.allOnsiteTIsByIdCargoType do
			defaultObj	:=	tiObj.setSubTerminalDefault(_stForExportFullObj,
														_stForExportMTYObj,
														_stForImportFullObj,
														_stForImportMTYObj,
														_stForStorageFullObj,
														_stForStorageMTYObj,
														_stForImportGenObj,
														_stForExportGenObj,
														_stForStorageGenObj,
														_stForCargoOtherObj,
														_stForBOLInwardsObj);
			
// cnwdad1 06/10/2009 - PAR #20914.
			if defaultObj &lt;&gt; null then
				tiObj.createTransForSubTermChange(null, defaultObj, tiObj.receivedDT, null, app.myPassport);
			endif;
		endforeach;
		
		// Next, do all prenoted cargo for the Terminal.
		
		foreach tiObj in _terminalObj.allNotifiedTIsByIdCargoType do
			defaultObj	:=	tiObj.setSubTerminalDefault(_stForExportFullObj,
														_stForExportMTYObj,
														_stForImportFullObj,
														_stForImportMTYObj,
														_stForStorageFullObj,
														_stForStorageMTYObj,
														_stForImportGenObj,
														_stForExportGenObj,
														_stForStorageGenObj,
														_stForCargoOtherObj,
														_stForBOLInwardsObj);
			
// cnwdad1 06/10/2009 - PAR #20914.
			if defaultObj &lt;&gt; null then
				tiObj.createTransForSubTermChange(null, defaultObj, tiObj.receivedDT, null, app.myPassport);
			endif;
		endforeach;
		
		
		// Next, do all Bulk Releases for the Terminal.
		
		foreach brObj in _terminalObj.allBulkReleasesByCodeDate do
// cnwdad1 27/01/2010 - PAR #22205.
//			brObj.setSubTerminalDefault(_stForSourceBulkObj,
//										_stForTargetBulkObj);
			brObj.setSubTerminalDefault(_terminalObj.getDefaultSubTerminalForRel(brObj.type), _stForTargetBulkObj);
		endforeach;
		
		
		// Now we do the same for each active Voyage for the Terminal.
		
		foreach voyageObj in _terminalObj.allVoyagesByCode do
			if not voyageObj.isActiveDisplay(null) then
				continue;
			endif;
			
			if not _isAreaDefined then	//26 Nov 2014	NDL	Par 35295
				// Start with all onsite cargo for the Voyage.
				foreach tiObj in voyageObj.allOnshipTIsByCargoTypeId do
					defaultObj	:=	tiObj.setSubTerminalDefault(_stForExportFullObj,
																_stForExportMTYObj,
																_stForImportFullObj,
																_stForImportMTYObj,
																_stForStorageFullObj,
																_stForStorageMTYObj,
																_stForImportGenObj,
																_stForExportGenObj,
																_stForStorageGenObj,
																_stForCargoOtherObj,
																_stForBOLInwardsObj);
					
	// cnwdad1 06/10/2009 - PAR #20914.
					if defaultObj &lt;&gt; null then
						tiObj.createTransForSubTermChange(null, defaultObj, tiObj.receivedDT, null, app.myPassport);
					endif;
				endforeach;
			endif;
			
			// Next, do all Bulk Releases for the Voyage.
			
			foreach brObj in voyageObj.allBulkReleases do
// cnwdad1 27/01/2010 - PAR #22205.
//				brObj.setSubTerminalDefault(_stForSourceBulkObj,
//											_stForTargetBulkObj);
				brObj.setSubTerminalDefault(_terminalObj.getDefaultSubTerminalForRel(brObj.type), _stForTargetBulkObj);
			endforeach;
			
		endforeach;
		
		foreach bolObj in _terminalObj.allBOLsReceivedByDTType do
			if bolObj.isInward and bolObj.mySubTerminal = null then
				bolObj.setSubTerminal(_stForBOLInwardsObj);
			endif;
		endforeach;

	endif;
	
	_terminalObj.setConfig(DelReqDefaultSubTerm, _stForDelReq);	// 31 OCT 2022 NAVSKS20 TFS 52721
	_terminalObj.setConfig(DelReqChangeSubTerm, _isAllowChangeInSubTerm);	// 31 OCT 2022 NAVSKS20 TFS 52721
	
//cnwdad1 21/07/2009 - PAR #20325.
//	if _passportObj.noErrors() then
//		_terminalObj.setConfig(IsSubTerminalsOn, _isTurnedOn);
//	endif;
	
	if _passportObj.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_terminalObj, false);
	endif;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_isTurnedOn" type="Boolean"/>
        <Parameter name="_wasTurnedOn" type="Boolean"/>
        <Parameter name="_isAreaDefined" type="Boolean"/>
        <Parameter name="_stForExportFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForExportMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForExportGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForCargoOtherObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkRdObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkRlObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkShObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkPkObj" type="CM_SubTerminal"/>
        <Parameter name="_stForTargetBulkObj" type="CM_SubTerminal"/>
        <Parameter name="_stForBOLInwardsObj" type="CM_SubTerminal"/>
        <Parameter name="_stForDelReq" type="CM_SubTerminal"/>
        <Parameter name="_isAllowChangeInSubTerm" type="Boolean"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSubTerminalOptions" id="08bd788f-63e7-4c68-ba4c-fd6f7f87bf92">
        <source>utlUpdateSubTerminalOptions(_terminalObj:CM_Terminal;
							_isTurnedOn:Boolean;
							_isAreaDefined : Boolean;	//26 Nov 2014	NDL	Par 35295
							_stForExportFullObj:CM_SubTerminal;
							_stForExportMTYObj:CM_SubTerminal;
							_stForImportFullObj:CM_SubTerminal;
							_stForImportMTYObj:CM_SubTerminal;
							_stForStorageFullObj:CM_SubTerminal;
							_stForStorageMTYObj:CM_SubTerminal;
							_stForImportGenObj:CM_SubTerminal;
							_stForExportGenObj:CM_SubTerminal;
							_stForStorageGenObj:CM_SubTerminal;
							_stForCargoOtherObj:CM_SubTerminal;
							_stForSourceBulkRdObj:CM_SubTerminal;	// cnwdad1 PAR 22205.
							_stForSourceBulkRlObj:CM_SubTerminal;	// cnwdad1 PAR 22205.
							_stForSourceBulkShObj:CM_SubTerminal;	// cnwdad1 PAR 22205.
							_stForSourceBulkPkObj:CM_SubTerminal;	// cnwdad1 PAR 22205.
							_stForTargetBulkObj:CM_SubTerminal;
							_stForBOLInwardsObj:CM_SubTerminal;
							_passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		07 April 2009 by cnwdad1
//
// Purpose:		Utility method to update the specified Terminal's Sub-Terminal settings.
//
//	NOTE: The first time that Sub-Terminals are turned on, the system needs to take
//	the default Sub-Terminals and update all on-site TI's, all Pre-Notes and all
//	active Voyages.  Suffice to say, it will be a long transaction and should only
//	be done when no other activity is going on in JMT.
//
// Returns:		Nothing
//
//	If any errors occur in here (such as exceptions), then execution will be returned
//	to the calling transaction, which will deal with the mopping up.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/01/2010	cnwdad1		PAR 22205 (CCMS POL 1904).  Added extra Bulk Release
//							Sub-Terminal parameters.
// --------------------------------------------------------------------------------
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	app.myValUA.valSubTerminalOptions(	_terminalObj,
										_isTurnedOn,
										_isAreaDefined,	//26 Nov 2014	NDL	Par 35295
										_stForExportFullObj,
										_stForExportMTYObj,
										_stForImportFullObj,
										_stForImportMTYObj,
										_stForStorageFullObj,
										_stForStorageMTYObj,
										_stForImportGenObj,
										_stForExportGenObj,
										_stForStorageGenObj,
										_stForCargoOtherObj,
										_stForSourceBulkRdObj,	// cnwdad1 PAR 22205.
										_stForSourceBulkRlObj,	// cnwdad1 PAR 22205.
										_stForSourceBulkShObj,	// cnwdad1 PAR 22205.
										_stForSourceBulkPkObj,	// cnwdad1 PAR 22205.
										_stForTargetBulkObj,
										_stForBOLInwardsObj,
										_passportObj);
	
	if (not self.checkValidationWithPassport(_passportObj)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_terminalObj);
	
	if _passportObj.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_terminalObj, true);
	endif;
	
	if _passportObj.noErrors() then
// cnwdad1 21/07/2009 - PAR #20294.
//		if not _terminalObj.getConfig(IsSubTerminalsOn).Boolean then
//			_terminalObj.setConfig(IsSubTerminalsOn, _isTurnedOn);
//		endif;
		
		_terminalObj.setConfig(IsSubTerminalsOn, _isTurnedOn);		// cnwdad1 21/07/2009 - PAR #20294.
		_terminalObj.setConfig(IsSubTerminalAreaDefined, _isAreaDefined and _isTurnedOn );	//26 Nov 2014	NDL	Par 35295
		_terminalObj.setConfig(MySubTerminalForExportFull, _stForExportFullObj);
		_terminalObj.setConfig(MySubTerminalForExportMTY, _stForExportMTYObj);
		_terminalObj.setConfig(MySubTerminalForImportFull, _stForImportFullObj);
		_terminalObj.setConfig(MySubTerminalForImportMTY, _stForImportMTYObj);
		_terminalObj.setConfig(MySubTerminalForStorageFull, _stForStorageFullObj);
		_terminalObj.setConfig(MySubTerminalForStorageMTY, _stForStorageMTYObj);
		_terminalObj.setConfig(MySubTerminalForImportGen, _stForImportGenObj);
		_terminalObj.setConfig(MySubTerminalForExportGen, _stForExportGenObj);
		_terminalObj.setConfig(MySubTerminalForStorageGen, _stForStorageGenObj);
		_terminalObj.setConfig(MySubTerminalForOther, _stForCargoOtherObj);
		_terminalObj.setConfig(MySubTerminalForSourceBulkRoad, _stForSourceBulkRdObj);	// cnwdad1 PAR 22205.
		_terminalObj.setConfig(MySubTerminalForSourceBulkRail, _stForSourceBulkRlObj);	// cnwdad1 PAR 22205.
		_terminalObj.setConfig(MySubTerminalForSourceBulkShip, _stForSourceBulkShObj);	// cnwdad1 PAR 22205.
		_terminalObj.setConfig(MySubTerminalForSourceBulkPack, _stForSourceBulkPkObj);	// cnwdad1 PAR 22205.
		_terminalObj.setConfig(MySubTerminalForTargetBulk, _stForTargetBulkObj);
		_terminalObj.setConfig(MySubTerminalForBOLIn, _stForBOLInwardsObj);
	endif;

	if _passportObj.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_terminalObj, false);
	endif;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_isTurnedOn" type="Boolean"/>
        <Parameter name="_isAreaDefined" type="Boolean"/>
        <Parameter name="_stForExportFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForExportMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForExportGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForCargoOtherObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkRdObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkRlObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkShObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkPkObj" type="CM_SubTerminal"/>
        <Parameter name="_stForTargetBulkObj" type="CM_SubTerminal"/>
        <Parameter name="_stForBOLInwardsObj" type="CM_SubTerminal"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSystemAlertType" id="5cd01f49-5b83-4224-b7ac-ca89e9f7701d">
        <source>utlUpdateSystemAlertType(pProxySysAlertType : CM_SystemAlertType; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwmd1	Initial creation

*/

vars
	realSysAlertType : CM_SystemAlertType;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	pProxySysAlertType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxySysAlertType.pxyGetRealObjectAndEdition(realSysAlertType, expectedEdition);
	
	if realSysAlertType = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SystemAlertType.name, null, null);
		return;
	endif;

	app.myValUA.valSysAlertType(realSysAlertType, pProxySysAlertType);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realSysAlertType);

	if _passport.noErrors and realSysAlertType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'System Alert Type', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSysAlertType, true);
	endif;
	
	if _passport.noErrors then
		realSysAlertType.setForUpdate(pProxySysAlertType);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSysAlertType, false);
	endif;

end;</source>
        <Parameter name="pProxySysAlertType" type="CM_SystemAlertType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTCPConnectionDetails" id="e220464c-c005-44b7-b0e5-5c172804c8da">
        <source>utlUpdateTCPConnectionDetails(_pxyTCPConnectionDetails : CM_DeviceTCPConnectionDetails input;
																 _realTCPConnectionDetails: CM_DeviceTCPConnectionDetails input;
																 _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwrh7	Initial creation

*/

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then
		_realTCPConnectionDetails.setForUpdate(_pxyTCPConnectionDetails);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realTCPConnectionDetails, false);
	endif;

	
	
epilog

end;</source>
        <Parameter name="_pxyTCPConnectionDetails" type="CM_DeviceTCPConnectionDetails" usage="input"/>
