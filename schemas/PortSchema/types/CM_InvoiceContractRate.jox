epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="evaluateRate" id="2c9e3611-1eab-43ba-afe6-ed89d02b0c38">
        <source>evaluateRate(_usingPrimary : Boolean; _newRate : Decimal output; _uomObj : CM_InvoiceUnitOfMeasure; _updateAmount : Boolean; _rangeAmount, _invLineAmount : Real; _dateTime : TimeStamp; _invLine : CM_InvoiceLine input) : Boolean;
/*
Purpose:			

Date				Who		Reason
07 February 2023	navab1	TFS CR 55624 TASK 55700
12 October 2023		navmv20 Bug 60507: FR | 54089 - Invoice Contracts - Contract details on Invoice Items list
03/11/2023			navkc1 	Bug 61061: FR | 54089 - EUP - Contracts - Volume based Invoice line - UOM code is blank
23 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025			navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	iterEntry : Iterator;
	entry : CM_InvoiceContractRateEntry;
	trans : CM_TITransaction;
	contractId : String; //12/10/2023 navmv20 Bug 60507
	invoiceContract : CM_InvoiceContract; //12/10/2023 navmv20 Bug 60507
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	invoiceContract := self.myInvoiceContractDetail.myInvoiceContract; //12/10/2023 navmv20 Bug 60507
	contractId := invoiceContract.contractId; //12/10/2023 navmv20 Bug 60507

	if _usingPrimary then
		// for primary do not check date ranges, so go back wards to get the last set of rate entry
		foreach entry in self.allInvoiceContractRteEntByFrom reversed, discreteLock  do
			if _rangeAmount &gt;= entry.fromAmount 
			and _rangeAmount &lt;= entry.toAmount then
				_newRate := entry.costPerUnit;
				// ### TFS BUG 59807 15AUG2023 NAVAB1
				_invLine.setUsedContractRate(true);
				
				app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_invLine, true); //03/11/2023	navkc1 Bug 61061
				
				//12/10/2023 navmv20 Bug 60507 - start
				_invLine.setContractId(contractId);
				//12/10/2023 navmv20 Bug 60507 - end
				if _updateAmount then
					_invLine.setForUpdateQuantity(_invLineAmount);
					// ### TFS BUG 59807 15AUG2023 NAVAB1
					_invLine.setUsedContractCalcType(true); // set that we have used the contracts calc type to get a new quantity.
					trans := _invLine.myTransactionTI;
					if trans &lt;&gt; null then
						trans.setUsedContractQuantity(true); 
					endif;
				endif;
				//03/11/2023	navkc1 Bug 61061 - Always set the UOM code
				if _uomObj &lt;&gt; null then
					_invLine.setUOMCode(_uomObj.code);
				endif;
				
				_invLine.setContractDetail(self.myInvoiceContractDetail); // ### TFS CR 61911 TASK 62405 08FEB2024 NAVAB1
				
				app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_invLine, false);
				  // ### TFS BUG 61096 21NOV2023 NAVAB1 changed to USED
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("-", LogINFO.String);
					app.invLog("-", LogINFO.String);
					app.invLog("CONT USED - RATE ENTRY = " &amp; _newRate.String &amp; " for range " &amp; entry.fromAmount.String &amp; " to " &amp; entry.toAmount.String &amp; " Date range " &amp; entry.fromTS.asStringJMT() &amp;"-" &amp; entry.toTS.asStringJMT(), LogINFO.String);
				endif;
				return true;
			
			endif;
		
		endforeach;
	
	else
		iterEntry := self.allInvoiceContractRteEntByFrom.createIterator;
		self.allInvoiceContractRteEntByFrom.startKeyLeq(_dateTime, iterEntry);
		while iterEntry.back(entry) do
			if entry.toTS &lt;&gt; null 
			and entry.toTS &lt;= _dateTime then
				continue;
			endif;
			if _rangeAmount &gt;= entry.fromAmount 
			and _rangeAmount &lt;= entry.toAmount then
				_newRate := entry.costPerUnit;
				// ### TFS BUG 59807 15AUG2023 NAVAB1
				_invLine.setUsedContractRate(true);
				
				app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_invLine, true); //03/11/2023	navkc1 Bug 61061
				
				 //08/11/2023 navmv20 Bug 60507 - start
				_invLine.setContractId(contractId);
				//08/11/2023 navmv20 Bug 60507 - end
				if _updateAmount then
					_invLine.setForUpdateQuantity(_invLineAmount);
					// ### TFS BUG 59807 15AUG2023 NAVAB1
					_invLine.setUsedContractCalcType(true); // set that we have used the contracts calc type to get a new quantity.
					trans := _invLine.myTransactionTI;
					if trans &lt;&gt; null then
						trans.setUsedContractQuantity(true);
					endif;
				endif;
				//03/11/2023	navkc1 Bug 61061 - Always set the UOM code;
				if _uomObj &lt;&gt; null then
					_invLine.setUOMCode(_uomObj.code);
				endif;

				_invLine.setContractDetail(self.myInvoiceContractDetail); // ### TFS CR 61911 TASK 62405 08FEB2024 NAVAB1

				app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_invLine, false); //03/11/2023	navkc1 Bug 61061
				// ### TFS BUG 61096 21NOV2023 NAVAB1 changed to USED
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("-", LogINFO.String);
					app.invLog("-", LogINFO.String);
					app.invLog("CONT USED - RATE ENTRY = " &amp; _newRate.String &amp; " for range " &amp; entry.fromAmount.String &amp; " to " &amp; entry.toAmount.String, LogINFO.String);  
				endif;
				return true;
			
			endif;
		endwhile;
	endif;

	return false;
epilog
	delete iterEntry;
end;</source>
        <Parameter name="_usingPrimary" type="Boolean"/>
        <Parameter name="_newRate" type="Decimal" usage="output"/>
        <Parameter name="_uomObj" type="CM_InvoiceUnitOfMeasure"/>
        <Parameter name="_updateAmount" type="Boolean"/>
        <Parameter name="_rangeAmount" type="Real"/>
        <Parameter name="_invLineAmount" type="Real"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_invLine" type="CM_InvoiceLine" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="evaluateRateVolumeBased" id="371089ad-b024-4df2-8acb-3256dc2058ae">
        <updating/>
        <source>evaluateRateVolumeBased(_usingPrimary : Boolean; _newRate : Decimal output; _newTotal : Decimal output; _uomObj : CM_InvoiceUnitOfMeasure; _updateAmount : Boolean; 
						_rangeAmount, _invLineAmount, _origInvAmount : Real; _dateTime : TimeStamp; _invLine : CM_InvoiceLine input; _service : CM_Service input; _calcType : CM_CalculationType)   : Boolean updating;
/*
Purpose: With volume based rates, it may be required to create extra CM_Charges. If the new accumulated amount 	cross 2 or more ranges extra CM_Charges must be created for each range.
				The amount on the new CM_Charges must take into account what has been accumulated previously. 
				The first amount will be for the range end minus the previous accumulated amount and the last amount will be just the amount left within the last range.
				_newRate is used to update the original CM_Charge.

Date			Who		Reason
07 February 2023	navab1	TFS CR 55624 TASK 55700 
 // ### TFS BUG 57505 13APR2023 NAVAB1 - added _origInvAmount
//03/11/2023	navkc1 Bug 61061: FR | 54089 - EUP - Contracts - Volume based Invoice line - UOM code is blank 
//09/11/2023 navmv20 Bug 61114: FR | EUP - 54089 - Invoice Contracts - Contract ID on Invoice lines
23 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/ 
vars
	iterEntry : Iterator;
	entry : CM_InvoiceContractRateEntry;
	rangesTO, rangesFROM, amounts, prevRangeTo, cpus, newrates, rangeUsed, rangeUsedFrom : DecimalArray;
	idx,idy, rangeCount,amountCount, amount : Integer;
	residual, lastRange, prevaccum, amountLeft, amountProcessed, chargeAmount, nextAmount : Decimal[23,4];
	firstCharge,newCharge : CM_Charge;
	fromTS : TimeStamp;
	primSortDict : CM_InvContractRateEntryByAmnt;
	contractId : String; //09/11/2023 navmv20 Bug 61114: FR | EUP - 54089
	trans : CM_TITransaction; //09/11/2023 navmv20 Bug 61114: FR | EUP - 54089
	invoiceContract : CM_InvoiceContract; //09/11/2023 navmv20 Bug 61114: FR | EUP - 54089
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	create rangeUsed transient;
	create newrates transient;
	create cpus transient;
	create rangesTO transient;
	create rangesFROM transient; // ### TFS BUG 57729 28APR2023 NAVAB1
	create rangeUsedFrom transient; // ### TFS BUG 57729 28APR2023 NAVAB1
	create amounts transient;
	create prevRangeTo transient; // ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1

	if _invLine &lt;&gt; null then // ### TFS BUG 57729 28APR2023 NAVAB1
		firstCharge := _invLine.charges.first; // ### TFS BUG 57729 28APR2023 NAVAB1
	
	endif;

	if _usingPrimary then
		// forced primary do not check date ranges, so go back wards to get the last set of rate entry
		create primSortDict transient;
		fromTS := null;
		foreach entry in self.allInvoiceContractRteEntByFrom reversed, discreteLock  do
			if fromTS.isValid()
			and fromTS &lt;&gt; entry.fromTS then
				break;
			endif;
			
			primSortDict.add(entry); // put them in the correct 'amount range' order

			// ## assumming all the rate entries will have the same group of from and to timestamps
			fromTS := entry.fromTS;
		
		endforeach;
		foreach entry in primSortDict discreteLock  do
			rangesFROM.add(entry.fromAmount); // ### TFS BUG 57729 28APR2023 NAVAB1
			rangesTO.add(entry.toAmount);
			cpus.add(entry.costPerUnit);
		endforeach;

	else
		
		// ### get valid rate entries and sort by top of range amount
		foreach entry in self.allInvoiceContractRateEntries discreteLock do
			if _dateTime &lt; entry.fromTS 
			or _dateTime &gt; entry.toTS then
				continue;
			endif;
			
			rangesFROM.add(entry.fromAmount); // ### TFS BUG 57729 28APR2023 NAVAB1
			rangesTO.add(entry.toAmount);
			cpus.add(entry.costPerUnit);
		
		endforeach;
	endif;
	
	rangeCount := rangesTO.size;		
	if rangeCount &gt; 0 then
		// ### chop up the invoice line amount into the different ranges to get a list of amounts and rates for the CM_Charges to be created.
		
		
		// Previous accumulation is the ammount before this TI was included
		prevaccum := _rangeAmount - _origInvAmount; // the _rangeAmount is the accumulated amount that is to be used for getting the correct rate using the ranges. 
													// It includes the current TI's amount that is also the amount (quantity) on the invoice line.
													// these 2 'amounts' are calculated based on a calc type so maybe weight, volume, quantity etc.
		
		idy := 1; // This is the index for the charges, whatever number this gets to is how many charges there shoudl be on the invoice line
		idx := 1; // this is the index used across all the ranges, we may skip some if the accumulation is large enough
		
		lastRange := prevaccum;
		amountLeft := _origInvAmount;
		while true do : outerloop
			if prevaccum &gt; rangesTO[idx] then
				idx := idx + 1;
				
				// NAVAB1 03NOV2023 TFS 61115
				if idx &gt; rangeCount then 
					break outerloop;
				endif;

				continue;
			endif;
			
			while true do : innerloop
				if rangesTO[idx]  &lt;= _rangeAmount then
					// New rate and amount for a charge. rate * amount give the CM_Charge.total, these are accumulated by the CM_InvoiceLine to get a lineTotal
					
					 // ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
					nextAmount := (rangesTO[idx] - lastRange);
					if nextAmount = 0 then // if the last accumulation is the same as the end of a range then skip it
						lastRange := rangesTO[idx];
						idx := idx + 1;

						// NAVAB1 03NOV2023 TFS 61115
						if idx &gt; rangeCount then 
							break outerloop;
						endif;
						continue innerloop;
					endif;
					
					amounts[idy] := nextAmount; // based on the calc type this amount will be the weight, volume etc.
					
					prevRangeTo[idy] := lastRange; // ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
					
					newrates[idy] := cpus[idx];
					
					rangeUsedFrom[idy] := rangesFROM[idx];  // ### TFS BUG 57729 28APR2023 NAVAB1
					rangeUsed[idy] := rangesTO[idx]; // ### TFS BUG 57505 19APR2023 NAVAB1
					amountProcessed := amountProcessed + amounts[idy]; 
					amountLeft := _origInvAmount - amountProcessed;
					lastRange := rangesTO[idx];
					idy := idy + 1;
					idx := idx + 1;
					// NAVAB1 03NOV2023 TFS 61115
					if idx &gt; rangeCount then 
						break outerloop;
					endif;
				else
					// what is left over
					amounts[idy] := amountLeft;
					prevRangeTo[idy] := lastRange; // ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
					newrates[idy] := cpus[idx];
					rangeUsedFrom[idy] := rangesFROM[idx];  // ### TFS BUG 57729 28APR2023 NAVAB1
					rangeUsed[idy] := rangesTO[idx]; // ### TFS BUG 57505 19APR2023 NAVAB1
					break outerloop;
				endif;
			endwhile;
			break;
		endwhile;
	

		
		amountCount := amounts.size;
		
		// ### nothing to do here
		if amountCount = 0 then
			_newRate := 0;
			return false;
		endif;

		// Update the invoice quantity
		_newRate := newrates[1]; // index 1 is Current CM_Charge
		// ### TFS BUG 59807 15AUG2023 NAVAB1
		_invLine.setUsedContractRate(true);
		
		chargeAmount := amounts[1]; // ### TFS BUG 57505 19APR2023 NAVAB1
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("CONT VB range 1 original range amount is " &amp; chargeAmount.String, LogINFO.String); // ### TFS BUG 57505 19APR2023 NAVAB1
		endif;
		self.convertAmountForCalcType(_calcType,chargeAmount); // ### TFS BUG 57505 19APR2023 NAVAB1
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("CONT VB range 1 converted range amount is " &amp; chargeAmount.String &amp; " Used CalcType " &amp; _calcType.description, LogINFO.String); // ### TFS BUG 57505 19APR2023 NAVAB1
		endif;
		_newTotal := chargeAmount * newrates[1]; // ### TFS BUG 57505 19APR2023 NAVAB1
		
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_invLine, true); //03/11/2023	navkc1 Bug 61061
		
		 //09/11/2023 navmv20 Bug 61114: FR | EUP - 54089
		invoiceContract := self.myInvoiceContractDetail.myInvoiceContract;
		contractId := invoiceContract.contractId;
		_invLine.setContractId(contractId);
		
		if _updateAmount then
			_invLine.setForUpdateQuantity(_invLineAmount);
			// ### TFS BUG 59807 15AUG2023 NAVAB1
			_invLine.setUsedContractCalcType(true); // set that we have used the contracts calc type to get a new quantity.
		endif;
		//03/11/2023	navkc1 Bug 61061 - Always set the UOM code.
		if _uomObj &lt;&gt; null then
			_invLine.setUOMCode(_uomObj.code);
		endif;
		
		_invLine.setContractDetail(self.myInvoiceContractDetail); // ### TFS CR 61911 TASK 62405 08FEB2024 NAVAB1
		
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_invLine, false); //03/11/2023	navkc1 Bug 61061
		
		 // ### TFS BUG 61096 21NOV2023 NAVAB1 - changed to USED
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("-", LogINFO.String);
			app.invLog("-", LogINFO.String);
			app.invLog("CONT USED - RATE ENTRY = " &amp; _newRate.String &amp; " for range up to " &amp; rangeUsed[1].String, LogINFO.String);
		endif;
		if firstCharge &lt;&gt; null then // ### TFS BUG 57729 28APR2023 NAVAB1
			if rangeUsedFrom.size &gt;= 1 then // ### TFS BUG 57729 28APR2023 NAVAB1
				firstCharge.setVolumeBasedRange(rangeUsedFrom[1], rangeUsed[1], _uomObj,chargeAmount + prevRangeTo[1] ); // ### TFS BUG 57729 28APR2023 NAVAB1 - set the range of values used
			endif;
		endif;
			
		// ### Only one range covered so use that, the calling method will handle the rate on the original CM_Charge
		if amountCount = 1 then
			return true;
		endif;
		
		// ### create a new CM_Charge for each amount and rate
		foreach idx in 2 to amountCount do
			if amounts[idx] = 0 then
				continue;
			endif;
			
			
			// create extra charges
			newCharge := _service.createCharge(_invLine);
			
			if newCharge &lt;&gt; null then
				chargeAmount := amounts[idx]; // ### TFS BUG 57505 19APR2023 NAVAB1
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("CONT VB range " &amp; idx.String &amp; " original range amount is " &amp; chargeAmount.String, LogINFO.String); // ### TFS BUG 57505 19APR2023 NAVAB1
				endif;
				self.convertAmountForCalcType(_calcType,chargeAmount); // ### TFS BUG 57505 19APR2023 NAVAB1
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("CONT VB range " &amp; idx.String &amp; " converted range amount is " &amp; chargeAmount.String &amp; " Used CalcType " &amp; _calcType.description, LogINFO.String); // ### TFS BUG 57505 19APR2023 NAVAB1
					 // ### TFS BUG 61096 21NOV2023 NAVAB1 - changed to 
					app.invLog("-", LogINFO.String);
					app.invLog("-", LogINFO.String);
					app.invLog("CONT USED - RATE ENTRY = " &amp; newrates[idx].String &amp; " for range  up to " &amp; rangeUsed[idx].String, LogINFO.String); // ### TFS BUG 57505 19APR2023 NAVAB1
				endif;
				newCharge.overrideRate(newrates[idx]);
				newCharge.total := chargeAmount * newrates[idx]; // ### TFS BUG 57505 19APR2023 NAVAB1
				newCharge.isTotalSetExplicitly := true;
				newCharge.setVolumeBasedRange(rangeUsedFrom[idx], rangeUsed[idx], _uomObj,chargeAmount + prevRangeTo[idx]); // ### TFS BUG 57729 28APR2023 NAVAB1 - set the range of values used
			endif;
		endforeach;
		
	
		return true;
	endif;

	return false;
epilog
	delete iterEntry;
	delete rangesTO;
	delete rangesFROM; // ### TFS BUG 57729 28APR2023 NAVAB1
	delete amounts;
	delete cpus;
	delete newrates;
	delete primSortDict;
	delete rangeUsed;
	delete rangeUsedFrom; // ### TFS BUG 57729 28APR2023 NAVAB1
	delete prevRangeTo; // ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
end;</source>
        <Parameter name="_usingPrimary" type="Boolean"/>
        <Parameter name="_newRate" type="Decimal" usage="output"/>
        <Parameter name="_newTotal" type="Decimal" usage="output"/>
        <Parameter name="_uomObj" type="CM_InvoiceUnitOfMeasure"/>
        <Parameter name="_updateAmount" type="Boolean"/>
        <Parameter name="_rangeAmount" type="Real"/>
        <Parameter name="_invLineAmount" type="Real"/>
        <Parameter name="_origInvAmount" type="Real"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_invLine" type="CM_InvoiceLine" usage="input"/>
        <Parameter name="_service" type="CM_Service" usage="input"/>
        <Parameter name="_calcType" type="CM_CalculationType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="2f8247ad-03ca-4a2e-84dd-c1888a3a08de">
        <source>getAuditText(): String;
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
*/

vars

	txt,
	tmpStr	: String;

begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	
	tmpStr := null;
	if self.myService &lt;&gt; null then
		tmpStr :=self.myService.name;
		txt := txt &amp;'Service'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	// ### TFS CR 61579 TASK 62469 13FEB2024 NAVAB1
	tmpStr := null;
	if self.myCalculationType &lt;&gt; null then
		tmpStr :=self.myCalculationType.description;
		txt := txt &amp;'Derive Quantity'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentRateForDisplay" id="200a092e-4de5-413e-a38d-2ec560d21c43">
        <source>getCurrentRateForDisplay() : CM_InvoiceContractRateEntry;
/*
Purpose:		for display get the current 'valid' rate entry. Valid means there is a valid date range in the DB.	

Date		Who		Reason
29 November 2023	navab1	BUG 61268
*/

vars
	now, fromts : TimeStamp;
	iterEntry : Iterator;
	entry, lastOne : CM_InvoiceContractRateEntry;
begin
	now := app.actualTimeAppServer();
	
	// check for range for 'now' incase there are contract rates set for the future
	foreach entry in self.allInvoiceContractRteEntByFrom reversed, discreteLock  do
		if now &gt;= entry.fromTS and now &lt;= entry.toTS then
			lastOne:= entry;
		endif;
	endforeach;
	
	if lastOne &lt;&gt; null then
		return lastOne;
	endif;
	
	// if we are now in the future  and are after the last date range, get the first for that date range.
	lastOne := self.allInvoiceContractRteEntByFrom.last;
	if lastOne &lt;&gt; null then
		fromts	 := lastOne.fromTS;
		foreach entry in self.allInvoiceContractRteEntByFrom reversed, discreteLock  do
			if entry.fromTS = fromts then
				lastOne:= entry;
			endif;
		endforeach;
	endif;
	
	if lastOne &lt;&gt; null then
		return lastOne;
	endif;
	
	// default send first ever
	return self.allInvoiceContractRteEntByFrom.first;

epilog

end;</source>
        <ReturnType type="CM_InvoiceContractRateEntry"/>
    </JadeMethod>
