    <JadeMethod name="addProperty" id="53616720-a6d1-4b2d-a3ca-644f412a235d">
        <source>addProperty(_prop : Property; _class : Class) protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpAuditAttr	: CM_AuditAttribute;

begin
	
	if (not self.shouldAuditProperty(_prop)) then
		return;
	endif;
	
	if self.allAuditedClassProperties.includesKey(_class.name, _prop.name, true) then
		create tmpAuditAttr transient;
		tmpAuditAttr.init(_prop, _class, self);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_prop" type="Property"/>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="create" id="d1891b95-06c0-426c-b4d8-2215516d9a30">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     28 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myAuditAttributesByClsAttrIter := self.allAuditAttributesByClsAttr.createIterator;
	self.myAuditAttributesByAttrClsIter := self.allAuditAttributesByAttrCls.createIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="createAttributesForClass" id="0b3c67be-0c4e-43fe-9023-51f30f22fe41">
        <source>createAttributesForClass(_cls : Class);
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// 30 Oct 2023	navma1 ChangeRequest 60841: MTN - Improve Performance of Cargo Bulk Edit - First Enhancement
// ---------------------------------------------------------------------------
vars
	tmpClass	: Class;
	p 			: Property;
	props 		: PropertyNDict;
	classes		: ClassColl;
	propDict 	: PropertyNDict;
	ti		    : CM_TrackedItem;
	tiClass     : Class;
begin

	/*
	30.10.2023 navma1 #60841
	*/
	ti := self.getTI();
	if ti &lt;&gt; null then
		tiClass := ti.class;
	endif;
	
	// firstly for all the superclasses
	while true do
		if tmpClass = null then
			tmpClass := _cls;
		else
			tmpClass := tmpClass.getPropertyValue(Class::superclass.name).Class;
		endif;
		if tmpClass = null then
			break;
		endif;
		if tmpClass = null or tmpClass = CM_Object or tmpClass = Object then
			break;
		endif;

		props := tmpClass.getPropertyValue(Class::properties.getName).PropertyNDict;
		if props = null or props.size &lt; 1 then
			continue;
		endif;

		foreach p in props do
			self.addProperty(p, tmpClass);
		endforeach;
	endwhile;
	
	// Now do the subclasses
	create classes transient;
	
	/*
	30.10.2023 navma1 #60841
	*/
	if tiClass &lt;&gt; null then
		tiClass.allSuperclassesUpTo(classes,CM_TrackedItem);
	else
		_cls.allSubclasses(classes);
	endif;
	
	_cls.allSubclassesInSubschemas(classes);	// 10/02/2010 cnwar2 CCMS 1849/#22324 [Added for Centre Port]
	
	foreach tmpClass in classes do
		if tmpClass.abstract = true then
			continue;
		endif;
	
		create propDict transient;
		
		tmpClass.getPropertiesAllSuperclass(propDict);
		if propDict = null or propDict.size &lt; 1 then
			continue;
		endif;

		foreach p in propDict do
			self.addProperty(p, tmpClass);
		endforeach;
		delete propDict;

	endforeach;

epilog
	delete classes;
	if propDict &lt;&gt; null then
		delete propDict;
	endif;
end;</source>
        <Parameter name="_cls" type="Class"/>
    </JadeMethod>
    <JadeMethod name="delete" id="f5602ab7-2e86-4360-8932-2401015b23d2">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     28 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	delete self.myAuditAttributesByClsAttrIter;
	delete self.myAuditAttributesByAttrClsIter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getChangedValuesAsStrings" id="d48ec247-b644-49ae-a2e2-f7e6897a18f6">
        <source>getChangedValuesAsStrings(_ti : CM_TrackedItem; _audType : Integer; _values : CM_Strings input; _useSpecialSeparator : Boolean);
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//2/10/2019	JLGNS1	ChangeRequest 45790: JMT - Refactor - Seal Transactions
vars
	displayName	: String;
	cls			: Class;
	auditAttr	: CM_AuditAttribute;
	iter		: Iterator;
	sepChar 	: String;				//45790
begin
	if _useSpecialSeparator then		//45790
		sepChar := AuditStringSeparator;//45790
	else								//45790
		sepChar := " ";					//45790
	endif;								//45790
	
	cls := _ti.class;
	iter := self.myAuditAttributesByClsAttrIter;
	self.allAuditAttributesByClsAttr.startKeyGeq(cls, null, iter);

	while iter.next(auditAttr) and auditAttr.myClass = cls do
		if (not auditAttr.isAudited) then
			continue;
		endif;
		if _audType = AuditCreated or _audType = AuditDeleted then
			displayName := _ti.getCargoTypeDisplayName(auditAttr.attrName);		// 35199 use the cargo type attribute name
			_values.add(displayName &amp; sepChar &amp;
								  CM_Edit.S_EDIT_THING &amp; sepChar &amp; auditAttr.getAfterValue);
		elseif _audType = AuditUpdated then
			if auditAttr.beforeValue &lt;&gt; auditAttr.afterValue then
				displayName := _ti.getCargoTypeDisplayName(auditAttr.attrName);	// 35199 use the cargo type attribute name
				_values.add(displayName &amp; sepChar &amp; auditAttr.getBeforeValue &amp; sepChar &amp;
								  CM_Edit.S_EDIT_THING &amp; sepChar &amp; auditAttr.getAfterValue);
			endif;
		endif;
	endwhile;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_audType" type="Integer"/>
        <Parameter name="_values" type="CM_Strings" usage="input"/>
        <Parameter name="_useSpecialSeparator" type="Boolean"/>
    </JadeMethod>
