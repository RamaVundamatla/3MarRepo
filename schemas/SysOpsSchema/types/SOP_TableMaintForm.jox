// 29/02/2012	cnwcs5	par 29158 - EDI BookingCutoff
vars

begin 
	if table.row &lt;= table.fixedRows then
		return;
	endif;
    if self.mode = self.Mode_View then
    	return;
    endif;  
	
	self.doTblInput1Change(table);
end;</source>
