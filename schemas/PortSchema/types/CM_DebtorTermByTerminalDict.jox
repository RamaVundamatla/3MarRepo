<CollClass name="CM_DebtorTermByTerminalDict" id="e6fc0995-f13a-4624-9380-068b08a892d7">
    <loadFactor>66</loadFactor>
    <memberType name="CM_DebtorTerminal"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="debtorTerm"/>
    <MemberKey>
        <property name="CM_DebtorTerminal::myTerminal"/>
    </MemberKey>
    <JadeMethod name="includesCashOnlyTerminals" id="64d572ff-3374-4c7f-959d-ceb19bec7812">
        <source>includesCashOnlyTerminals():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	drTerm : CM_DebtorTerminal;
	iter : Iterator;

begin

	if self.isEmpty then
		return false;
	endif;
	
	iter := self.createIterator;
	while iter.next( drTerm ) do
		if drTerm.isCashOnly then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
