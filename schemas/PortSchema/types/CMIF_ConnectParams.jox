    <JadeMethod name="createTransaction" id="43e393a3-4567-4e8f-ac78-132894696430">
        <updating/>
        <source>createTransaction(_passport : CM_Passport input) : CM_TITransaction updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	trans	: CM_TITransaction;
	theClass	: Class;

begin
	if (not self.validate) then
		return null;
	endif;
	theClass := global.getTiTxnClassForType(self.type, true);
	if theClass = null then
		return null;
	endif;
	create trans as theClass persistent;
	
	trans.setBaseAttributes(self.ammended, 		self.dateTime,
							self.deleted, 		self.noCharge,
							self.operatorCode, 	self.superseded,
							self.type, 			self.urNumber,
							not self.systemInitiated, self.userId,
							self.myTrackedItem, self.myTerminal);

	if trans.hasOtherTrackedItem then
		if self.type = TRANS_TYPE_CONNECT_POWER then
			//May or may not have other tracked item
			if self.myOtherTrackedItem &lt;&gt; null then
				trans.setOtherTrackedItem(self.myOtherTrackedItem);
			endif;
		elseif self.myOtherTrackedItem = null then
			delete trans;
		//	app.raiseCMException1(REQUIRED_FIELD, 'other tracked item', null, null);
			app.raiseCMException(Input_required_field_otherTrck, null, null); // cnwdb2	PAR 35364
			return null;
		else
			trans.setOtherTrackedItem(self.myOtherTrackedItem);	
		endif;

	endif;

	// XPOSE 1647 AKB2002JAN
	self.myTrackedItem.checkDateConnectDisconnect(self.dateTime, false);
	
	self.setTransactionDetails(trans);
	
	if (not trans.validateForCreate()) then
		// An error occured
		delete trans;
		trans := null;
		return null;
	endif;

	trans.updateTI(_passport);
	_passport.addTITransactionForDeferUpd(trans, self.myTerminal);

	return trans;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="doDisconnect" id="02bc06fe-97b6-4de1-82b4-f3a2fa39a14d">
        <updating/>
        <source>doDisconnect( _realTi : CM_TrackedItem input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2015	cnwndl1	Initial creation	Par 36154
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin

	self.dateTime := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.myTerminal := _realTi.myTerminal;
	self.myTrackedItem := _realTi;
	self.locationsController := _realTi.myPrimaryActualLocation;
	self.userId := app.getMyUserCode();
	self.action := ACTION_DISCONNECT;
	self.radioTelemetryUser := false;
	
	_realTi.setForDisconnect( self, _passport );
			
epilog

end;</source>
        <Parameter name="_realTi" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
