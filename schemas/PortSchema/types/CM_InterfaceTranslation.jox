    <JadeMethod name="pxyCreateUpdateProxy" id="4a652d51-7e86-4375-b189-111e6b9f2758">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method to instantiate and return a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the transient proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj	:=	inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="241ad416-f451-44c2-adf0-36bd170000b8">
        <updating/>
        <source>setForCreate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method that is invoked from a transaction when the receiver
//				is created.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set any non-key properties, and non-inverse references.
	
	// Set any key property values.
	
	// Set any inverse references.
	
	self.setForUpdate(_proxyObj);
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ae9fb0fc-a401-4487-b1a8-cb87b4acd893">
        <updating/>
        <source>setForUpdate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method that is invoked from a transaction when the receiver
//				is created.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set any non-key properties, and non-inverse references.
	
	self.translationString		:=	_proxyObj.translationString;
	
	// Set any key property values.
	
	// Set any inverse references.
	
//	self.myInterfaceDefinition	:=	_proxyObj.myInterfaceDefinition;
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setInterfaceDefinition" id="05ce9530-c747-4aed-98ed-735a6ec874e9">
        <updating/>
        <source>setInterfaceDefinition(_definitionObj:CM_InterfaceDefinition) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Sets a reference to the receiver's Interface Definition object.
//
// Parameters:	_definitionObj - A reference to the Interface Definition object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myInterfaceDefinition	:=	_definitionObj;
end;</source>
        <Parameter name="_definitionObj" type="CM_InterfaceDefinition"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="fd0add88-eaf1-45a9-9aff-e9b2b3e2a02d">
        <source>validateForCreate(_passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Standard method that is invoked from a transaction when the receiver
//				is created.
//
// Parameters:	_passportObj - A reference to the current user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.validateMe(null, _passportObj);
end;</source>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
