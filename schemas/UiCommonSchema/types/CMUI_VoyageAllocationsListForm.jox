    </JadeMethod>
    <JadeMethod name="doQueueRefresh" id="8e9c9b95-e95b-486b-9391-068c06cae7e6">
        <updating/>
        <source>doQueueRefresh() updating, protected;

/*

Purpose:			Queue up a refresh of the form in response to a notification, to prevent
					multiple consecutive notes locking up the process

Parameters:			None

Return Value:		None


Date		Who		Reason
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colou Code performance

*/

vars
	option,
	time			: Integer;
	
begin
	// If we have already queued a refresh, then do nothing
	if self.refreshIsQueued then
		return;
	endif;
	
	// Queue a refresh in 2 seconds
	if not self.getTimerStatus(Timer_Tag_Refresh, option, time) then
		self.beginTimer(2000, Timer_OneShot, Timer_Tag_Refresh);
	endif;
	self.refreshIsQueued := true;
		
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="4ad8d05c-19d8-4e03-9ead-25217d9ea72e">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 January 2010 by cnwab1
//
/*

Date		Who		Reason
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance

*/

vars

begin
	inheritMethod();
	self.displayCCTable();
	
	
epilog
	self.refreshIsQueued := false;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
