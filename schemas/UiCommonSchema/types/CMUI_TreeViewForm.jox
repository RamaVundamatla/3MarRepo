    <JadeMethod name="btnSearch_click" id="b6c008fc-66b3-4f1d-af07-2dcfff95044e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearch_click(btn: Button input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	05 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.mode &lt;&gt; self.Mode_View then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User became able to search in add/edit mode.');
		return;
	endif;
	
	self.doSearch();

end;


</source>
