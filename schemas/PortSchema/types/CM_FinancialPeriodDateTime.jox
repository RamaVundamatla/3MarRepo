end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="5b166278-b888-400e-bd91-8b093bee3506">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	temp_FinancialPeriod	: CM_FinancialPeriodDateTime;
	real_FinancialPeriod	: CM_FinancialPeriodDateTime;
	
begin
	// cnwrl1 06/11/2009 PAR 19278 - start of coding
	if self.dateTime = null then
		app.raiseCMException( ERROR_Null_Date_Time, null, null );
		return;				// no point doing further testing
	endif;
	
	temp_FinancialPeriod	:= self.myFinancialPeriodEnd.allFinancialPeriodEndDates[ self.dateTime ];
	if temp_FinancialPeriod &lt;&gt; null then
		// make sure we are not just updating ourselves.
		real_FinancialPeriod	:= self.pxyGetRealObject.CM_FinancialPeriodDateTime;
		if real_FinancialPeriod = null or temp_FinancialPeriod &lt;&gt; real_FinancialPeriod then
			app.raiseCMException2(	Error_Financial_Period_Date,
									self.dateTime.String,
									self.myFinancialPeriodEnd.description,
									null,
									null );
		endif;
	endif;
	// cnwrl1 06/11/2009 PAR 19278 - end of coding
	
end;</source>
    </JadeMethod>
</Class>
