    <JadeMethod name="getUniqueNumber" id="76252744-78e8-4991-9c57-4d02bc83f4f5">
        <source>getUniqueNumber(_category : XLAT_Category; _constant: GlobalConstant): Integer protected;

// Other global constant categories have a unique range of Integers.
// Menu Items are splt across MenuHdrConstants, MenuHdrSystemConstants and XLAT_Permissions.
vars
begin
	app.raiseUnexpectedProgramError(class.name, method.name, 'Method should not be called for this class');
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_category" type="XLAT_Category"/>
        <Parameter name="_constant" type="GlobalConstant"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
