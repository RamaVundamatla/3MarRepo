    <JadeMethod name="setCustomDocTypeColor" id="9e5e7c2f-c3b0-401b-9c24-ab364b6d3a74">
        <source>setCustomDocTypeColor(_updController : CnEcReleaseController);
/*

Purpose:			
		This script will be all instances in CM_CustomDocumentType.colour to WHITE 
			
Parameters:			

Return Value:		

Date		Who		Reason
05/09/2023	navkc1	CR 60156  Task 60157: UI - Cust Doc Type Colour

*/

vars
	custDocType	: CM_CustomDocumentType;
	allDocTypes	: ObjectArray;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
