    <JadeMethod name="setSourceLocn" id="25b18063-144b-4593-8886-cdd723a95cba">
        <updating/>
        <source>setSourceLocn(_target: CM_Object; _inward: Boolean) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Jun 2009	consw1	Initial creation
05 Dec 2024 navma1	navma1 MTN-33567 MTN - Charges Are Not Created When adding Events
*/

vars
	currentPos   : Integer;
	currentTrain : CM_Train;
	sourceStr    : String;
	wagon		 : CM_Wagon;
	railLine     : CM_RailLine;

begin
	if _target = null then
		self.sourceLocn := null;
		return;
	endif;

	wagon := self.myWagon;
	
	if _target.isKindOf(CM_Train) then
		if _inward then
			currentTrain := wagon.myTrainInwards;
			currentPos 	 := wagon.getMyPositionTrainInwards();
		else
			currentTrain := wagon.myTrainOutwards;
			currentPos   := wagon.getMyPositionTrainOutwards();
		endif;
		if currentTrain &lt;&gt; null then
			sourceStr := currentTrain.code;
		endif;			
	elseif _target.isKindOf(CM_RailLine) then
		
		railLine := wagon.myRailLine;
		
		if railLine &lt;&gt; null then
			sourceStr := railLine.myRailArea.id &amp; " " &amp; railLine.id;
		endif;
		currentPos    := wagon.getMyPosition();
	endif;

	if currentPos &lt;&gt; 0 then
		sourceStr := sourceStr &amp; " " &amp; currentPos.stringWithLeadingZeros(2);
	endif;

	self.sourceLocn := sourceStr[1:30];
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_target" type="CM_Object"/>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
