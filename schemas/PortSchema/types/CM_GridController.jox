    <JadeMethod name="getBackEndController" id="14e3f83c-d541-4e84-a5a8-d868fde7893b">
        <source>getBackEndController(_ti: CM_TrackedItem): CM_GridController;
//25 November 2008	cnwdw1	
// Return the back end controller for this controller with _ti
vars
	control : CMIF_MoveController;
begin
	create control transient;
	control.setMyTrackedItem(_ti);
	control.setMyToPrimaryLocation(self);
	if not self.getSpannedToLCs(control) then
		return null;
	endif;
	return control.myToSecondaryLocations.last.CM_GridController;
epilog
	delete control;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="getColumnLabel" id="39021f71-604b-4104-b1e3-323afbfe4d81">
        <source>getColumnLabel(_short : Boolean) : String;
/*
 ------------------------------------------------------------------------
Created:			15 January 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.myGridColumn = null then
		return null;
	endif;
	
	if _short then
		return self.myGridColumn.label;
	else
		return "Column " &amp; self.myGridColumn.label;
	
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentMaxHeightForPad" id="8f6e8025-ad2f-4385-b8e8-cb1b1a1325c8">
        <source>getCurrentMaxHeightForPad( _reason : String output ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

	firstTi : CM_TrackedItem;
	defaultHeight : Integer;
	griddedStackHeight : CM_GriddedTAStackHeight;

begin

	defaultHeight := self.getFirstUnavailableHeight;
	
	_reason := "Default";
	if self.getMyTerminalArea = null then	
		return defaultHeight;
	endif;
	
	if defaultHeight = 0 then
		defaultHeight := self.getMyTerminalArea.getHeightOfStack();
	endif;
	
	if self.getMyTerminalArea.allGriddedTAStackHeights.isEmpty then	
		return defaultHeight;
	endif;
	
	griddedStackHeight := self.getGriddedStackHeightObj( firstTi );
	
	if griddedStackHeight &lt;&gt; null then
		if griddedStackHeight.maxStackHeight &lt; defaultHeight then
			_reason := "Used " &amp; griddedStackHeight.name &amp; " matched to first ti of " &amp; firstTi.id;
		else
			_reason := "Used default. Checked " &amp; griddedStackHeight.name &amp; " matched to first ti of " &amp; firstTi.id;
		endif;
		defaultHeight := defaultHeight.min( griddedStackHeight.maxStackHeight );
	endif;
	
	return defaultHeight;

epilog

end;</source>
        <Parameter name="_reason" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDeckingSideAccess" id="3e4a33d1-aa0f-425e-a4dd-e4a2a659710c">
        <source>getDefaultDeckingSideAccess(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2009	cnwer1	Initial creation

*/

vars
	ta : CM_GridArea;
	deckingRule : CM_YADeckingRule;
	deckingOption : CM_YADeckingOptionsTA;
begin
	//write method.qualifiedName;
	ta:=self.myGridArea;
	
	if not ta.useSideAccessRules then
		return CM_YABlock.SideAccess_NA;
	endif;
	
	deckingOption:=ta.myYADeckingOptions;
	if deckingOption = null then
		return CM_YABlock.SideAccess_NA;
	endif;
	
	//epr par 24734 25/6/10
	if deckingOption.useReverseOfIn then
		deckingRule:=deckingOption.allDeckingRulesIn.first;
	else
		//when checking overstows check decking rules out
		deckingRule:=deckingOption.allDeckingRulesOut.first;
	endif;
	//write deckingRule;
	if deckingRule = null then
		return CM_YABlock.SideAccess_NA;
	endif;
	
	return deckingRule.getSideAccess(self,ta.allGridRows,ta.allGridColumns,deckingRule.heightFrom,deckingRule.heightTo);

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultInterchangeLocation" id="1dfa6a0f-f317-4a01-8b72-912a8103cff7">
