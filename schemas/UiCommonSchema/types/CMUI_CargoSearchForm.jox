    <JadeMethod name="lstColour_doTabOrder" id="bab4241b-4fd5-4338-8f95-0e8f581fbdd8">
        <controlMethod name="CMUI_FieldGeneric::doTabOrder"/>
        <methodInvocation>event</methodInvocation>
        <source>lstColour_doTabOrder(_startTab: Integer):Integer protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/08/2013	cnwdap1		Initial creation PAR #32331
//
vars
	tabOrder	: Integer;

begin
	tabOrder						:= _startTab;
	tabOrder 						:= tabOrder + 1;
	self.lstColourList.tabIndex 	:= tabOrder;
	tabOrder 						:= tabOrder + 1;
	self.txtColourList.tabIndex 	:= tabOrder;
	return tabOrder;
epilog

