    <JadeMethod name="addDtlToToolBar" id="d219a473-b7a4-48e9-9eb0-124fe9b44aa5">
        <source>addDtlToToolBar() protected;
// ---------------------------------------------------------------------------
// Created:     17 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	menuEntity			: CM_MenuEntity;
	loadStateSet 		: Boolean;
	pxyMenuDtl,
	menuDtl		 		: CM_MenuUserDtl;	
	theUserTerminal 	: CM_UserTerminal;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	//we can safely cast into menuDtl class as this enabling of menu items logic dictates
	menuDtl := self.lstTest.listObject.CM_MenuUserDtl;
	
	theUserTerminal := app.getMyUser.getUserTerminal(self.lstTest.getTeminalOfCurrentEntity);
	
	if theUserTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, ' userTerminal is null');
		return;
	endif;
	
	app.cmsBeginLoad(loadStateSet);
	pxyMenuDtl := menuDtl.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadStateSet);
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateMenuToolbarAdd(theUserTerminal, pxyMenuDtl, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Update Toolbar', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	if pxyMenuDtl &lt;&gt; null then
		delete pxyMenuDtl;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="canDo" id="da31c3b2-bde8-4d13-ba96-a34100a2bf8c">
        <source>canDo(_doWhat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user			: CM_User;
	terminal		: CM_Terminal;
	menuEntity		: CM_MenuEntity;
begin
	menuEntity := self.lstTest.listObject.CM_MenuEntity;
	if menuEntity = null then
		return false;
	endif;

	user := app.getMyUser;
	terminal := menuEntity.getMyTerminal();

	if not user.canDo(terminal, _doWhat) then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_doWhat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkOpenWindows" id="96a24f60-bd62-4d41-9931-90f57af4a61d">
        <source>checkOpenWindows() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     29 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	listCount,
	idx			: Integer;
	lstBox		: CMUI_ListBox;
begin
	lstBox := self.lstTest;
	//PAR 6853 - insist on closing all windows before resetting menu otherwise the occasional menu action (representing an open window)
	//may not be present on closing the app, and thus not have it's user window preferences recorded
	listCount := lstBox.listCount;
	foreach idx in 1 to listCount do
		if CMUI_MenuAction.hasInstance(lstBox.itemObject[idx]) then
			app.msgBox('You must close all JMT windows before organising/resetting your menu','Close all screens first...', MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endforeach;

	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
