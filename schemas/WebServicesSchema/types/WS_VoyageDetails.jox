<Class name="WS_VoyageDetails" id="06d86283-5fa7-4811-8abf-e5691dcb0039">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>pertinent details for a voyage</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="506b8b0e-7bf1-4e90-91bf-05b4cacf3a3a">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="c181d9f8-4ab2-43c9-ac32-0f85e3047809">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="imports" id="73201540-a5c7-4308-ac8e-50b25ef76e4e">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="onShip" id="13bd3981-1978-4143-9ff3-20b3ec1e7ae0">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="onSite" id="2d93e638-278a-4378-b643-ffe6c5470ddf">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="tranship" id="38395883-0a29-473e-9122-3ba4622e5e91">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="f4f9d8a3-d0dd-4954-be00-c8d14a5cb064">
        <updating/>
        <source>setProxyFromObject(_object: CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2017	jlghl1	Initial creation
31 Aug 2017		jlghl1	TFS 6771

*/

vars
	onShipCount, onSiteCount, importsCount, transhipCount : Integer;
	iter : Iterator;
	ti : CM_TrackedItem;
begin
	inheritMethod(_object);
	
	self.code := _object.code;
	self.description := _object.description;
	
	onShipCount := 0;	
	importsCount := 0;
	transhipCount := 0;	
	onSiteCount := 0;
	
	iter := _object.allImportTIs.createIterator;
	
	while iter.next(ti) do
		if ti.isCar() then
					
			if ti.isOnSite and ti.myVoyage.code = _object.code then
				importsCount := importsCount + 1;				
			endif;
			
			if (ti.isOnSite and ti.myVoyage.code &lt;&gt; _object.code)
			  or (ti.myPrimaryActualLocation.isKindOf(CM_VoyageController) and  ti.myPrimaryActualLocation.CM_VoyageController.myVoyage &lt;&gt; _object) then
				transhipCount := transhipCount + 1;
			endif;
			
			if ti.myPrimaryActualLocation.isKindOf(CM_VoyageController) and ti.myPrimaryActualLocation.CM_VoyageController.myVoyage = _object then
				onShipCount := onShipCount + 1;
			endif;
				
		endif;
	endwhile;
	
		
	self.onShip := onShipCount;
	self.imports := importsCount;
	self.tranship := transhipCount;
	self.onSite := importsCount + transhipCount;	

epilog
	delete iter;
end;</source>
        <Parameter name="_object" type="CM_Voyage"/>
    </JadeMethod>
</Class>
