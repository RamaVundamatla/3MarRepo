<Class name="DateFormat">
    <JadeMethod name="jssCopyInfo" id="9ce81164-5cef-4523-ba26-dca8c326a92d">
        <updating/>
        <source>jssCopyInfo(pTheDateFormat : DateFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(pTheDateFormat);
	
	self.activeCalendarType		:=	pTheDateFormat.activeCalendarType;
	self.dayHasLeadingZeros		:=	pTheDateFormat.dayHasLeadingZeros;
	self.firstDayOfWeek			:=	pTheDateFormat.firstDayOfWeek;
	self.firstWeekOfYear		:=	pTheDateFormat.firstWeekOfYear;
	
	self.longDayNames.purge();
	pTheDateFormat.longDayNames.copy(self.longDayNames);
	
	self.longFormat				:=	pTheDateFormat.longFormat;
	self.longFormatOrder		:=	pTheDateFormat.longFormatOrder;
	
	self.longMonthNames.purge();
	pTheDateFormat.longMonthNames.copy(self.longMonthNames);
	
	self.monthHasLeadingZeros	:=	pTheDateFormat.monthHasLeadingZeros;
	self.optionalCalendarType	:=	pTheDateFormat.optionalCalendarType;
	self.separator				:=	pTheDateFormat.separator;
	
	self.shortDayNames.purge();
	pTheDateFormat.shortDayNames.copy(self.shortDayNames);
	
	self.shortFormat			:=	pTheDateFormat.shortFormat;
	self.shortFormatOrder		:=	pTheDateFormat.shortFormatOrder;
	
	self.shortMonthNames.purge();
	pTheDateFormat.shortMonthNames.copy(self.shortMonthNames);
	
	self.showFullCentury		:=	pTheDateFormat.showFullCentury;
end;</source>
        <Parameter name="pTheDateFormat" type="DateFormat"/>
    </JadeMethod>
</Class>
