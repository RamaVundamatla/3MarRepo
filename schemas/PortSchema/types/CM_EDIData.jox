    <JadeMethod name="needToGenerateTransientErrors" id="13c1f3d5-99df-4e5a-9e24-0cf5ea792ab6">
        <source>needToGenerateTransientErrors():Boolean;
/*
Date		Who		Reason
07 Aug 2012	cnwcs5	Initial creation - par 30136
11 Oct 2016	cnwrs1	TFS 2774/2795 PAR38277 EDI Operations Error display can be incorrect
30 Nov 2022 navma1  ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
*/
vars
	status	    :Integer;
	errorState : Boolean;
begin
	
	if self.storePersistentErrors then
		return false;
	endif;
	
	status := self.status;
	
	// if we have errors but the errors are lost then return true
	/*
	//30.11.2022 navma1 #52499
	errorState := status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS or
			status = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS or
			status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
	if errorState and app.myPassport.allErrorWarnings.size = 0 and
	   self.allErrorWarnings.size = 0 then
		return true;
	else
		return false;
	endif;
	*/
	
	//30.11.2022 navma1 #52499
	if status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS   or
	   status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS or
	   status = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS   or
	   status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL  then
		errorState := true;
	endif;
	
	if errorState and app.myPassport.allErrorWarnings.isEmpty and
	   self.allErrorWarnings.isEmpty then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="nodeName" id="b5039df6-5d5f-4bf4-a2b5-d514efebc0db">
