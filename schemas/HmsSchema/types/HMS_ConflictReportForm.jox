    <JadeMethod name="addToolbarControls" id="1f3199c6-21e1-4584-9f13-2cce5411813f">
        <source>addToolbarControls() protected;
//--------------------------------------------------
// Created:	09 February 2004 By: cnwgd1
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnReportOptions, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnRunConflict, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnSaveBase,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnOpenSaved,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.visible := true;
	toolbar.positionToolbarControls();

end;</source>
        <access>protected</access>
    </JadeMethod>
