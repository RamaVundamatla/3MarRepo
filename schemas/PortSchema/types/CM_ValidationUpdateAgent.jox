        <source>valDetach(_realTI: CM_TrackedItem; _theConnectParams : CMIF_ConnectParams input)  ;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
//	aProxyTI, aRealTI : CM_TrackedItem; 
//	expectedEdition:Integer;
begin
/*	done in util
	aProxyTI := _theConnectParams.myTrackedItem;
	self.raiseExceptionIfNull(aProxyTI, 'Detach TI Proxy');
	aProxyTI.pxyGetRealObjectAndEdition(aRealTI, expectedEdition);
	self.raiseExceptionIfNull(aRealTI, 'Detach TI Real');

	if aRealTI = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, aRealTI.id, null, null);
		return;
	endif;
*/	
	_realTI.validateForDetach(_theConnectParams);
	
epilog
	
end;</source>
