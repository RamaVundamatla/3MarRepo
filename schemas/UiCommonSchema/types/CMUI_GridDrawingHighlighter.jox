        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="iteration" id="7f4ba99a-30db-47df-bc30-f4e1991c7d7b">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myDrawingController" id="9d06502a-83ee-4533-b8ae-a1ea3fe5d36e">
        <kind>child</kind>
        <embedded/>
        <type name="CMUI_GridDrawingController"/>
        <Inverse name="CMUI_GridDrawingController::myHighlighter"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="78ab10a1-6a9f-44db-bacd-ad4fb2ed7878">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		25 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	durationInSeconds:=60;
end;</source>
    </JadeMethod>
    <JadeMethod name="doHighlight" id="512bb24a-d8f9-44a3-a8b9-083594d2a125">
        <methodInvocation>mapping</methodInvocation>
        <source>doHighlight(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:		02 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	_value := not self.myDrawingController.allSelectedObjects.isEmpty;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawHighlight" id="f74dae49-166f-4445-9e95-09bb5f011526">
        <updating/>
        <source>drawHighlight() updating;
// ---------------------------------------------------------------------------
// Created:		02 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theFrame : Frame;
	cdc : CMUI_GridDrawingController;
	xys : IntegerArray;
	idx,coord, x1, y1, x2,y2, extra : Integer;
begin
	if self.doHighlight then
		self.iteration := self.iteration + 1;
		
		create xys transient;
		cdc := self.myDrawingController;
		theFrame := cdc.getFrame();
		if theFrame = null then
			self.doHighlight := false;
			return;
		endif;

		cdc.getSelectedObjectsXYs(xys);
		if cdc.scaleFactor &gt;=3 then
			extra := 2;
		elseif cdc.scaleFactor = 2 then
			extra := 1;
		endif;
		theFrame.drawStyle := Frame.DrawStyle_InsideSolid; //Dash;
		theFrame.drawWidth := 1 + extra;
		theFrame.drawMode := Frame.DrawMode_Invert;

		self.drawColour := Black;		
		idx := 0;
		foreach coord in xys do
			idx := idx + 1;
			
			if idx = 1 then
				x1 := coord;
			elseif idx = 2 then
				y1 := coord;
			elseif idx = 3 then
				x2 := coord;
			elseif idx = 4 then
				y2 := coord - 1;
				theFrame.drawRectangle(x1 + extra, y1 + extra, x2 - extra,y2 - extra, self.drawColour);
				idx := 0;
			endif;
		endforeach;
		theFrame.drawMode := Frame.DrawMode_Copy;

		if self.durationInSeconds &gt; 0 then
			if self.iteration &gt;= self.durationInSeconds then // 20 seconds
				self.stopHighlighter();
				self.myDrawingController.clearAllSelectedObjects();
			endif;
		endif;
	else
		self.iteration :=  0;
	endif;
epilog

	delete xys;
end;</source>
    </JadeMethod>
    <JadeMethod name="startHighlighter" id="48c0cf65-f433-464b-a050-0624fead08e5">
        <updating/>
        <source>startHighlighter() updating;
// ---------------------------------------------------------------------------
// Created:		03 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.beginTimer(300, Timer_Continuous, self.Tag_GO);
	self.iteration := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="stopHighlighter" id="a042484a-94de-45ae-8ced-f0fdb33aaa89">
        <executionLocation>client</executionLocation>
        <source>stopHighlighter() clientExecution;
// ---------------------------------------------------------------------------
// Created:		25 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.endTimer(self.Tag_GO);
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="b8ae96ac-dfe8-4924-8b0c-61933518bf11">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		25 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.drawHighlight();
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</Class>
