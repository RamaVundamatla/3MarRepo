    <JadeMethod name="getCommonTrain" id="e009dd38-a019-4c0a-b61b-b280541b3300">
        <source>getCommonTrain():CM_Train;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwndl1	Initial creation

*/

vars
	obj : Object;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	firstTrain : CM_Train;
begin

	// if a train is associated with teh form, use that.
	if self.myCurrentTrain &lt;&gt; null then
		return self.myCurrentTrain;
	endif;
	
	// if we are coming from tblData we need to consider 'assigned train' of teh ti if it is a common one.
	if myContextTable = tblData then
		create tiArray transient;
		foreach obj in self.tblData.allSelectedObjects do
			if CM_TrackedItem.hasInstance(obj) then
				tiArray.add( obj.CM_TrackedItem );
			endif;
		endforeach;
	endif;
	
	// if no train associated with the form, use the one that the ti's are assigned to, providing that
	// there is only one being used.
	if tiArray &lt;&gt; null and not tiArray.isEmpty then
		foreach ti in tiArray do
			if firstTrain = null then
				firstTrain := ti.myTrainAssigned;
				continue;
			else
				if ti.myTrainAssigned &lt;&gt; null and ti.myTrainAssigned &lt;&gt; firstTrain then
					// we have a different train. bail
					firstTrain := null;
					break;
				endif;
			endif;
		endforeach;
	endif;
	
	return firstTrain;
	
epilog

	delete tiArray;
end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getCurrentDataTable" id="49061df1-c504-4e94-adfd-f9d38afea932">
        <source>getCurrentDataTable() : CM_DataTable protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
08 Dec 2011	NDL	Par 28797
*/
vars

begin

	if self.fldMain.topSheet = self.shtPlanned then
		return self.tblPlanned;
	elseif self.fldMain.topSheet = self.shtNonplanned then
		return self.tblData;
	elseif self.fldMain.topSheet = self.shtSummary then
		return self.tblSummary;
	elseif self.fldMain.topSheet = self.shtAll then
		return self.tblAll;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="getExtraExtraInfo" id="4f5b47fb-259d-4eda-9c7b-bec2813345f7">
        <source>getExtraExtraInfo(_dataContainer: CM_DataContainer; _object: CM_Object);
// ---------------------------------------------------------------------------
// Created:     16 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_object.CM_TrackedItem.getExtraInfoRail(false, _dataContainer);

epilog

end;</source>
