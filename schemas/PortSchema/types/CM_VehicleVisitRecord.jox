    <JadeMethod name="getRoadExitTime" id="f66e766a-3eb0-4572-91cd-0d7bfbd8f376">
        <source>getRoadExitTime() : TimeStamp;
//
// Purpose:			Return the time stamp of this visit's Road Exit detail
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	detail : CM_VehicleVisitRecordDetail;
	
begin
	foreach detail in self.allVehicleVisitRecordDetails reversed do
		if detail.recordType = VisitRecord_Complete_OutGate then
			return detail.timeStart;
