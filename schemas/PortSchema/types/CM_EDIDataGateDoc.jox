	_types.add(EDIDataType_Prenote);
	_types.add(EDIDataType_TIHazDets);	//21 Nov 2016	NDL	TFS 2843 / 2604
	_types.add(EDIDataType_TISeal);
	_types.add(EDIDataType_RequestHeader);
	_types.add(EDIDataType_RequestDetail);
