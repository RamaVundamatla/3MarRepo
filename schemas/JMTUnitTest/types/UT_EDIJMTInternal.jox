    <JadeMethod name="tCustomsAgentAction" id="78824f88-99d3-4e78-90d5-4cbd55f009c8">
        <source>tCustomsAgentAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalCustomsAgent";
	CUSTOMSAGENT : String = "CUSAGENT01";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	customsAgent : CM_CustomsAgent;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	self.deleteCustomsAgent(CUSTOMSAGENT);
	customsAgent := self.getCustomsAgent(CUSTOMSAGENT);
	self.assertIsDeleted(customsAgent);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCustomsAgent xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCustomsAgent.xsd"&gt;
	&lt;AllCustomsAgent&gt;
		&lt;CustomsAgent&gt;
			&lt;action&gt;A&lt;/action&gt;
			&lt;cargoTypeDescr&gt;&lt;/cargoTypeDescr&gt;
