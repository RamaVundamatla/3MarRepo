    <JadeMethod name="addItemObject" id="c41faac4-7942-470c-a91c-f46765307edb">
        <updating/>
        <source>addItemObject(_str : String; _obj : Object) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	idx	: Integer;

begin

	idx := self.addItem(Tab &amp; _str);
	if _obj &lt;&gt; null then
		self.accessRow(idx).itemObject := _obj;
	endif;
	return idx;

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSelectedObject" id="f7e974b6-b8cc-4418-bfa0-9e09b4ddb674">
        <updating/>
        <source>addSelectedObject(_obj : Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	idx	: Integer;
begin
	if _obj = null then
		return;
	endif;
	if (not self.allMySelectedObjects.includes(_obj)) then
		self.allMySelectedObjects.add(_obj);
		if self.findObjectInRow(_obj, idx) then
			self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;
		endif;
	endif;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="areAllRowsSelected" id="4fc25b43-a6a0-442e-8a16-f1321ad047f5">
        <updating/>
        <source>areAllRowsSelected(_selected : Boolean) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	idx,
	max			: Integer;
begin
	max := self.rows;
	
	if max &lt; 1 then
		return true;
	endif;
	
	foreach idx in 1 to max do
		if (self.accessCell(idx, self.chkBoxColumn).text =TableCheckBox_Selected) &lt;&gt; _selected then
			return false;
		endif;
	endforeach;

	return true;
end;</source>
        <Parameter name="_selected" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="change" id="bba4b98c-7e1f-493c-80f3-d65aca0d54d3">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>change(table: Table input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	obj	: Object;
	
begin

	inheritMethod(table);

	if table.row &gt; 0 and table.row &lt;= table.rows then
		obj := table.accessRow(table.row).itemObject;
		if self.rowChecked(table.row) then
			if (not self.allMySelectedObjects.includes(obj)) then
				self.allMySelectedObjects.add(obj);
			endif;
		else
			if self.allMySelectedObjects.includes(obj) then
				self.allMySelectedObjects.remove(obj);
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkBoxFirst" id="85d0bae2-eee5-4f13-84c9-e524eec8db43">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>chkBoxFirst(set: Boolean; _value: Boolean io) updating, mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin

	if set then
		if _value then
			self.chkBoxColumn 	:= 1;
		else
			self.chkBoxColumn 	:= self.columns;
		endif;
	else
		_value := (self.chkBoxColumn = 1);
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="clear" id="0ed31e8b-f268-4f06-b85b-f4ce22c41c39">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>clear() updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearSelected" id="4f159cbf-d1c5-4847-ab6c-802d21ec4433">
        <updating/>
        <source>clearSelected() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	maxRows,
	theFirstRow,
	idx,
	chkCol		: Integer;
begin

	self.allMySelectedObjects.clear;
	chkCol := self.chkBoxColumn;
	maxRows := self.rows;
	theFirstRow := self.fixedRows + 1;
	foreach idx in theFirstRow to maxRows do
		self.accessCell(idx, chkCol).text := TableCheckBox_NotSelected;
		self.accessRow(idx).selected := false;
	endforeach;

	if maxRows &gt;= theFirstRow then
		self.row := theFirstRow;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="clearTable" id="eb185b9c-51e5-407b-98a3-5424e43d81f0">
        <updating/>
        <source>clearTable() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin
	self.allMySelectedObjects.clear();
	self.clear();
	self.rows := 0;	
end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="79286c3f-fe89-4dd4-ba8f-e89a3c6c865b">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(table: Table input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	cell	: JadeTableCell;
	theRow : Integer;
begin
	if table.readOnly then
		return;
	endif;
	theRow := table.row;

	if table.userInputEnabled and (theRow &gt; 0 and theRow &lt;= table.rows) then
		self.highlightRow(theRow);
		if self.doManually then
			// the click occured in column 2 so we will need to
			// change the value of the checkbox manually
			cell := table.accessCell(theRow, self.chkBoxColumn);
			if cell.text = TableCheckBox_NotSelected then
				cell.text := TableCheckBox_Selected;
			else
				cell.text := TableCheckBox_NotSelected;
			endif;
			self.doManually := false;
			table.change(table);
		endif;
	endif;
	
	inheritMethod(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="b9df5930-9e87-443a-ac64-ca24cf7a26f6">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin

	self.rows 		:= 0;
	self.columns 	:= 3;
	self.fixedRows 	:= 0;
	self.fixedColumns := 0;
	
	self.selectMode := SelectMode_Row;
	self.gridLines	:= false;
	self.scrollBars	:= ScrollBars_Vertical;
	self.autoSize	:= AutoSize_ColumnMinimum;

	self.chkBoxFirst := true;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="findObject" id="a22f0dfc-914c-4bd8-b728-851e3c6a3d99">
        <updating/>
        <source>findObject(_obj : Object; _rowIdx : Integer io) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	tableRow	: JadeTableRow;
	
begin

	numRows := self.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	startPos := (self.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return found;
	endif;	 
	
	foreach idx in startPos to numRows do
		tableRow := self.accessRow(idx);
		if tableRow.itemObject = _obj then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInRow" id="4f33f48c-c33b-4d95-a1c2-05343715a70e">
        <updating/>
        <source>findObjectInRow(_obj: Object; _rowIdx: Integer io): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	
begin
	if _obj = null then
		return found;
	endif;
	
	numRows := self.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	startPos := (self.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return found;
	endif;	 
	
	foreach idx in startPos to numRows do
		if self.accessRow(idx).itemObject = _obj then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedAsStringArray" id="d0e2b1ce-93ce-4550-96bd-5b402fe1f0b0">
        <updating/>
        <source>getSelectedAsStringArray(_stringArray : StringArray input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903
*/

vars
	col,
	idx,
	max	: Integer;
begin
	if _stringArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null array');
		return;
	endif;

	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;

	if self.chkBoxFirst then
		col := self.chkBoxColumn + 1;
	else
		col := self.chkBoxColumn - 1;
	endif;	
	
	foreach idx in 1 to max do
		if self.accessCell(idx, self.chkBoxColumn).text = TableCheckBox_Selected then
			_stringArray.add(self.accessCell(idx, col).text);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_stringArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedFromDisplay" id="b37d4f68-ca8f-46ad-aedd-457a37f9caf3">
        <source>getSelectedFromDisplay() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

	obj 	: Object;
	str		: String;
	idx,
	max,
	txtRow,
	pos		: Integer;
	lstTbl	: CM_MobListTable;

begin

	max := self.rows;
	pos := 1;
	lstTbl := self;
	if lstTbl.chkBoxFirst then
		txtRow := lstTbl.chkBoxColumn + 1;
	else
		txtRow := lstTbl.chkBoxColumn - 1;
	endif;
	
	foreach idx in 1 to max do
		if self.allMySelectedObjects.includes(lstTbl.accessRow(idx).itemObject) then
			if str &lt;&gt; null then
				str := str &amp; ', ';
			endif;
			str := str &amp; lstTbl.accessCell(idx, txtRow).text; 
		endif;
	endforeach;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedObjectsWithDupes" id="dc6a70c1-478d-4c73-b74c-e87699439293">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>getSelectedObjectsWithDupes(_objectArray : ObjectArray input)updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	col,
	idx,
	max	: Integer;
	obj : Object;
begin
	if _objectArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null array');
		return;
	endif;

	_objectArray.clear();
	
	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;

	if self.chkBoxFirst then
		col := self.chkBoxColumn + 1;
	else
		col := self.chkBoxColumn - 1;
	endif;	
	
	foreach idx in 1 to max do
		if self.accessCell(idx, self.chkBoxColumn).text = TableCheckBox_Selected then
			obj := self.accessRow(idx).itemObject;
			_objectArray.add(obj);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_objectArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedString" id="01dbaf11-01ab-47d9-81ea-75d2fef67976">
        <source>getSelectedString(pAttrName : String) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	obj	: Object;
	str	: String;
	
begin
	if self.allMySelectedObjects.size = 0 then
		if self.useAnyStringWhenNonSelected then
			str := Any_String;
		endif;
	else 
		foreach obj in self.allMySelectedObjects do 
			if obj.isKindOf (CM_StopsTable) then 	// par 17963
				if not app.getMyUser.canViewStop (self.getMyTerminalFromForm, obj.CM_StopsTable) then	// par 17963
					continue;						// par 17963
				endif;								// par 17963
			endif;									// par 17963
			if str &lt;&gt; null then
				str := str &amp; ', ';
			endif;
			str := str &amp; obj.getPropertyValue(pAttrName).String.trimBlanks;
		endforeach;
	endif;

	return str;
			
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedStringXML" id="91ca56b0-db37-4d9d-8fca-f6685639ad58">
        <source>getSelectedStringXML(_attrName, _tag : String) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	obj	: Object;
	tmp,
	str	: String;
	
begin
	if self.allMySelectedObjects.size = 0 then
		str := Any_String;
	else
		foreach obj in self.allMySelectedObjects do
			if str &lt;&gt; null then
				str := str &amp; ', ';
			endif;
			tmp := obj.getPropertyValue(_attrName).String;
			str := str &amp; tmp.cnEcGetTagValueOfName(_tag);
		endforeach;
	endif;
	return str;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_tag" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedStrings" id="a31451dd-c412-4678-b206-004dc4a01ca0">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>getSelectedStrings(_stringArray : CM_StringArray input)updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	col,
	idx,
	max	: Integer;
	obj : Object;
begin
	if _stringArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null array');
		return;
	endif;

	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;

	if self.chkBoxFirst then
		col := self.chkBoxColumn + 1;
	else
		col := self.chkBoxColumn - 1;
	endif;	
	
	foreach idx in 1 to max do
		if self.accessCell(idx, self.chkBoxColumn).text = TableCheckBox_Selected then
			obj := self.accessRow(idx).itemObject;
			if CM_TransactionType.hasInstance(obj) then
				//PAR11768 cnwsh3  Changed as CM_EventNotificationRequest is getting a class name in the event type which is in turn
				//being displayed on web apps and is causing the description on some displays to be cryptic.
				//_stringArray.add(obj.CM_TransactionType.classNameToCreate);
				_stringArray.add(obj.CM_TransactionType.description);
			else
				_stringArray.add(self.accessCell(idx, col).text);
			endif;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_stringArray" type="CM_StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLStringForSelected" id="8e8cc9a7-9dd6-4e7d-896a-a753312e31ed">
        <source>getXMLStringForSelected(_attrNames : StringArray) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

	obj	: Object;
	str,
	tmp,
	attrName	: String;

begin

	if not self.allMySelectedObjects.isEmpty then
		str := self.formatAsXMLPrefix(XMLTag_ListTable &amp; self.name);
		foreach obj in self.allMySelectedObjects do
			tmp := null;
			foreach attrName in _attrNames do
				if tmp &lt;&gt; null then
					tmp := tmp &amp; ',';
				endif;
				tmp := tmp &amp; obj.getPropertyValue(attrName).String;
			endforeach;
			str := str &amp;  global.formatAsXML(XMLTag_SelectedValue, tmp);
		endforeach;
		str := str &amp; self.formatAsXMLSuffix(XMLTag_ListTable &amp; self.name);
	endif;
	return str;

end;</source>
        <Parameter name="_attrNames" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="highlightRow" id="9d64cb69-19a5-49f9-a88f-4190a75b41ec">
        <updating/>
        <source>highlightRow(pRow : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin

	if pRow &gt; 0 and pRow &lt;= self.rows then

		if self.accessCell(pRow, self.chkBoxColumn).text[1] = TableCheckBox_NotSelected then
			self.accessRow(pRow).selected := true;
		else
			self.accessRow(pRow).selected := false;
		endif;

	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
    </JadeMethod>
