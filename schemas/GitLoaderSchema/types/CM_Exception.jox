<ExceptionClass name="CM_Exception" id="356d1b43-3ea1-4447-987a-649bc51574e7">
    <superclass name="NormalException"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="gitloader"/>
    <PrimAttribute name="isWarning" id="f834cc1f-efce-485a-b5be-f9b436a8583e">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myUserObject" id="cbdf25fd-b2f7-4149-872f-9f0a20340ef9">
        <embedded/>
        <type name="Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="userString" id="6ccbc26a-0574-4eac-921a-a15edaf6774a">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="set" id="38f4af43-3c56-45e3-8410-520917441ba8">
        <updating/>
        <source>set(pCode : Integer; pText : String; pWarning : Boolean; pUserString : String; pUserObject : Object; _subject : Object) updating;
// ---------------------------------------------------------------------------
// Created:     17 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
begin

	self.errorCode := pCode;
	if pWarning then
		str := app.name &amp; " warning " &amp; pCode.String;	
	else
		str := app.name &amp; " error " &amp; pCode.String;
	endif;
	self.errorItem 		:= str;
	if app.useShortErrorMsg then
		self.extendedErrorText := pText;
	else
		self.extendedErrorText := 'Code :' &amp; pCode.String &amp; '. ' &amp; pText;
	endif;
	self.isWarning 		:= pWarning;
	
	if pWarning or app.continueCMExceptions then
		self.continuable := true;
	endif;
	
	self.userString 	:= pUserString;
	self.myUserObject 	:= pUserObject;
//	self.mySubject 		:= _subject;

end;</source>
        <Parameter name="pCode" type="Integer"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pWarning" type="Boolean"/>
        <Parameter name="pUserString" type="String"/>
        <Parameter name="pUserObject" type="Object"/>
        <Parameter name="_subject" type="Object"/>
    </JadeMethod>
</ExceptionClass>
