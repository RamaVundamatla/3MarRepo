    <JadeMethod name="addToolbarControls" id="95860b1b-95ff-4dec-9593-3962b01134a1">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		11 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	queryToolbar			: CMUI_Toolbar;

	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	if app.myCurrentUserCan(self.myTerminal, PmHMSInvoiceStatus) then
		frm.addButton(self.btnVoyInvStatus, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	inheritMethod();


	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="amendPxyResourceUsed" id="72ab2b35-e721-45ff-b488-e9e160472985">
        <updating/>
        <source>amendPxyResourceUsed(_pxyResUsed : HMS_ResourceUsed input) updating;
// ---------------------------------------------------------------------------
// Created:		18 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		The marine services need to have their required data shown on the screen, but not updated for real
//				so this populates the dummy proxies for displaying the detail;
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 10/12/2015	cnwdap1		PAR #37295 Delete dummy second resource created if it has no hours
// 30 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars
	resource, mResource, tmpResUsed : HMS_Resource;
	pxyResUsed2 : HMS_ResourceUsed;
	resourceType : HMS_ResourceType;
	aVM,move,thePrevMove : HMS_VoyageMovement;
	tmpBerth : HMS_Berth;
	idx : Integer;
	aTug : HMS_Tug;
	fromTS, toTS : TimeStamp;
	diff, diffMin, numHourBlocks, firstBlockMinutes : Integer;
	prevWharf : HMS_Wharf;
	theVoyage : CM_Voyage;
	aHarbour : HMS_Harbour;
	timeTill2ndResource : Real;
	hmsBerthBlock1, hmsBerthBlock2 : Integer; 
	berthPOC : Boolean;
	hmsResourceUsedProforma : CMIF_HMSResourceUsedProforma;
	pilot : HMS_Pilot;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438
begin

	if _pxyResUsed = null then
		return;
	endif;
	
	create hmsResourceUsedProforma transient;
	
	resource := _pxyResUsed.myResource;
	resourceType := _pxyResUsed.myResourceType;
	move := _pxyResUsed.myVoyageMovement;
	tmpBerth := move.getMyBerth;
	theVoyage := move.myHMSVoyageData.myVoyage;
	aHarbour := move.myHarbour;
	berthPOC := theVoyage.isBerthageOnContract();
	
	if resourceType &lt;&gt; null then
		if resourceType.isMarineService then
			if self.berthageNoShift then
				aVM := move.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeArrival);
//				aVM := move.myHMSVoyageData.getMovementFirstChargeable(move.moveType); 
				if aVM &lt;&gt; null then
					fromTS := aVM.occursOnDTNEW;
				else
					fromTS := tmpBerth.getFromTimeStamp(move);
				endif;
				aVM := move.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeDeparture);
				if aVM &lt;&gt; null then
					toTS := aVM.occursOnDTNEW;
				else
					toTS := tmpBerth.getToTimeStamps(move);
				endif;
			else
				fromTS := tmpBerth.getFromTimeStamp(move);
				toTS := tmpBerth.getToTimeStamps(move);
			endif;
			//### BERTH
			if tmpBerth &lt;&gt; null then
				if self.berthageNoShift then
//					thePrevMove := move.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeArrival);
					thePrevMove := move.myHMSVoyageData.getMovementFirstChargeable(move.moveType); 
				else
//					thePrevMove := move.getMovementPrevious(); 
					if move.moveType = HMSMovementTypeShift then
						thePrevMove := move;
					else // Departure
						thePrevMove := move.getMovementPreviousChargeable(); //getMovementPrevious(); 
					endif;
				endif;
				if thePrevMove &lt;&gt; null then
					prevWharf := thePrevMove.getMyBerth.myWharf;
				else
					prevWharf := tmpBerth.myWharf;
				endif;

				diffMin := (fromTS.cnEcDiff(toTS) / MillisecondsPerMinute).Integer;

				mResource := prevWharf.getResourceForHarbourMovement(move.moveType,HMS_Wharf.First_Resource);
				
				if mResource &lt;&gt; null then
					hmsBerthBlock1 := mResource.getTimeBlockFromResource(move,berthPOC).Integer;// PAR 35469
					if mResource.myResourceType = resourceType then

						numHourBlocks := _pxyResUsed.unitsUsed.Integer;
						if _pxyResUsed.unitsUsed = 0 then
							if self.berthageNoShift then
								// PAR 35469 numHourBlocks := move.myHMSVoyageData.getNumberOfBlocksVisit(HMSBerthBlock1, diffMin, firstBlockMinutes, false); // PAR 35469
								numHourBlocks := move.myHMSVoyageData.getNumberOfBlocksVisit(hmsBerthBlock1, diffMin, firstBlockMinutes, false, hmsBerthBlock1,mResource); // PAR 35469
								fromTS := toTS.addMinutes(diffMin * -1);
							else
								// PAR 35469 numHourBlocks := move.myHMSVoyageData.getNumberOfBlocksMovement(diffMin,HMSBerthBlock1, prevWharf);
								numHourBlocks := move.myHMSVoyageData.getNumberOfBlocksMovement(diffMin,hmsBerthBlock1, prevWharf, true); // PAR 35469/ 36605 extra param
							endif;
						endif;

						_pxyResUsed.setProxy(move.myHarbour,resourceType,mResource,null,fromTS,toTS,
												numHourBlocks,_pxyResUsed.partOfContract,null,null);
						if resource = null then // not set yet so dummy it up
						
	
							mResource := prevWharf.getResourceForHarbourMovement(move.moveType,HMS_Wharf.Second_Resource);
							if mResource &lt;&gt; null then
								hmsBerthBlock2 := mResource.getTimeBlockFromResource(move,berthPOC).Integer;// PAR 35469
								if fromTS.isValid and toTS.isValid then
									diffMin := (fromTS.cnEcDiff(toTS) / MillisecondsPerMinute).Integer; // PAR 10972 AKB2005DEC
									// PAR 35469 diffMin := diffMin - ((HMSBerthBlock1 * MillisecondsPerHour) / MillisecondsPerMinute).Integer; // PAR 12319
									diffMin := diffMin - ((hmsBerthBlock1 * MillisecondsPerHour) / MillisecondsPerMinute).Integer; // PAR 35469
									timeTill2ndResource := (prevWharf.timeTill2ndResource * MillisecondsPerHour) / MillisecondsPerMinute; // PAR 10972 AKB2005DEC
									// ### charge for 2nd berthage resource
									if diffMin &gt;= timeTill2ndResource then
										pxyResUsed2 := _pxyResUsed.cloneMySelf(true);
										self.allResUsed.add(pxyResUsed2);

										if self.berthageNoShift then
											// PAR 35469 numHourBlocks := move.myHMSVoyageData.getNumberOfBlocksVisit(HMSBerthBlock2, diffMin, firstBlockMinutes, true); // PAR 35469
											numHourBlocks := move.myHMSVoyageData.getNumberOfBlocksVisit(hmsBerthBlock2, diffMin, firstBlockMinutes, true,hmsBerthBlock1,mResource); // PAR 35469
											fromTS := toTS.addMinutes(diffMin * -1);
										else
											// PAR 35469 numHourBlocks := move.myHMSVoyageData.getNumberOfBlocksMovement(diffMin,HMSBerthBlock2, prevWharf);
											numHourBlocks := move.myHMSVoyageData.getNumberOfBlocksMovement(diffMin,hmsBerthBlock2, prevWharf, false); // PAR 35469/ 36605 extra param 
										endif;


										if numHourBlocks &gt; 0 then
											pxyResUsed2.setProxy(move.myHarbour,resourceType,mResource,null,fromTS,toTS,
														numHourBlocks,_pxyResUsed.partOfContract,null,null);
											self.doQueryAddItem(null,pxyResUsed2,false);
										else																				// PAR #37295
											self.allResUsed.remove(pxyResUsed2);											// PAR #37295
											delete pxyResUsed2;																// PAR #37295
										endif;
									endif;
								endif;
							endif;
							return; // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
						endif;
					endif;
				endif;
			endif;
			
			//### PILOT
			/*if move.getUnConvertedMyPilotRef &lt;&gt; null then // --&gt; TFS 44438
				mResource := move.getUnConvertedMyPilotRef.getResourceForHarbourMovement(move.myHarbour,move.moveType);
				if mResource &lt;&gt; null then
					if resource = null then // not set yet so dummy it up
						if mResource.myResourceType = resourceType then
							if _pxyResUsed.unitsUsed = 0 then // ### PAR 11913
								_pxyResUsed.setUnitsUsed(1); // ### PAR 11913
							endif;
							_pxyResUsed.setProxy(move.myHarbour,resourceType,mResource,null,fromTS,toTS,
												_pxyResUsed.unitsUsed,_pxyResUsed.partOfContract,null,null);
							return;
						endif;
					endif;
				endif;*/ // &lt;-- TFS 44438
	/*else*/if not move.allMovementPilotDetails/*allPilots*/.isEmpty then // TFS 44438
				foreach movementPilotDetails in move.allMovementPilotDetails do //pilot in move.allPilots do // TFS 44438
					mResource := movementPilotDetails.myPilot/*pilot*/.getResourceForHarbourMovement(move.myHarbour,move.moveType);
					if mResource &lt;&gt; null then
						if resource = null then // not set yet so dummy it up
							if mResource.myResourceType = resourceType then
								if _pxyResUsed.unitsUsed = 0 then 
									_pxyResUsed.setUnitsUsed(1);
								endif;
								_pxyResUsed.setProxy(move.myHarbour,resourceType,mResource,null,fromTS,toTS,
													_pxyResUsed.unitsUsed,_pxyResUsed.partOfContract,null,null);
								return;
							endif;
						endif;
					endif;
					if movementPilotDetails.myPilotLaunch &lt;&gt; null then// --&gt; TFS 44438 - deal with pilot launch also
						mResource := movementPilotDetails.myPilotLaunch.getResourceForHarbourMovement(move.myHarbour,move.moveType);
						if mResource &lt;&gt; null then
							if resource = null then // not set yet so dummy it up
								if mResource.myResourceType = resourceType then
									if _pxyResUsed.unitsUsed = 0 then 
										_pxyResUsed.setUnitsUsed(1);
									endif;
									_pxyResUsed.setProxy(move.myHarbour,resourceType,mResource,null,fromTS,toTS,
														_pxyResUsed.unitsUsed,_pxyResUsed.partOfContract,null,null);
									return;
								endif;
							endif;
						endif;
					endif; // &lt;-- TFS 44438					
				endforeach;
			endif;
			//### LINE COMPANY
			if move.myLineCompany &lt;&gt; null then
				mResource := move.myLineCompany.getResourceForHarbourMovement(move.myHarbour,move.moveType);
				if mResource &lt;&gt; null then
					if mResource.myResourceType = resourceType then // check this is a ship lines resources!!!! PAR 11066 DEC2005
						if resource = null then // not set yet so dummy it up
							if _pxyResUsed.unitsUsed = 0 then // ### PAR 11913
								_pxyResUsed.setUnitsUsed(move.numLineCrewRequired); // ### PAR 11913
							endif;
							_pxyResUsed.setProxy(move.myHarbour,resourceType,mResource,null,fromTS,toTS,
												_pxyResUsed.unitsUsed,_pxyResUsed.partOfContract,null,null);
							return;
						elseif _pxyResUsed.unitsUsed = 0 then // PAR 11053
							_pxyResUsed.setProxy(move.myHarbour,resourceType,mResource,null,_pxyResUsed.fromDateTime,_pxyResUsed.toDateTime,
											move.numLineCrewRequired,_pxyResUsed.partOfContract,null,null);
							return;
						endif;
					endif;
				endif;
			endif;
			//### PILOT LAUNCH
			/*if move.myPilotLaunch &lt;&gt; null then // --&gt; TFS 44438
				mResource := move.myPilotLaunch.getResourceForHarbourMovement(move.myHarbour,move.moveType);
				if mResource &lt;&gt; null then
					if resource = null then // not set yet so dummy it up
						if mResource.myResourceType = resourceType then
							if _pxyResUsed.unitsUsed = 0 then // ### PAR 11913
								_pxyResUsed.setUnitsUsed(1); // ### PAR 11913
							endif;
							_pxyResUsed.setProxy(move.myHarbour,resourceType,mResource,null,fromTS,toTS,
												_pxyResUsed.unitsUsed,_pxyResUsed.partOfContract,null,null);
							return;
						endif;
					endif;
				endif;
			endif;*/ // --&gt; TFS 44438		
		endif;
	endif;

end;</source>
        <Parameter name="_pxyResUsed" type="HMS_ResourceUsed" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnVoyInvStatus_click" id="008399ea-880d-499e-9bf9-a000dc610fda">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnVoyInvStatus_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		21 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.doBtnVoyInvStatus();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkCreateDummy" id="29a3a686-e2da-4da8-8f9a-dff6ab4f8261">
        <source>checkCreateDummy(_move : HMS_VoyageMovement; _res : HMS_Resource) : Boolean;
// ---------------------------------------------------------------------------
// Created:		28 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpResUsed, pxyResUsed : HMS_ResourceUsed;
	anOBj : Object;
begin
	foreach anOBj in self.allResUsed do
		tmpResUsed := anOBj.HMS_ResourceUsed;
		
		// dummy
		if tmpResUsed.myVoyageMovement = _move then
			if tmpResUsed.myResource = _res then
				return false;
			endif;
		endif;
		
	endforeach;
	
	return true;
end;</source>
        <Parameter name="_move" type="HMS_VoyageMovement"/>
        <Parameter name="_res" type="HMS_Resource"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cmbQueryVoyage_displayEntry" id="8706d48f-c488-4763-903e-01280c354a41">
        <controlMethod name="CMUI_ComboVoyage::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbQueryVoyage_displayEntry(combobox: ComboBox input; _voyageObj: CM_Voyage; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
/*
	if _voyageObj.arrivedDT.date &lt; self.queryDateFrom
	or _voyageObj.arrivedDT.date &gt; self.queryDateTo then
		return null;
	endif;
*/	
	if _voyageObj.myHMSVoyageData = null then
		return null;
	endif;
	return self.myAssistant.displayEntryHMSVoyageData(_voyageObj.myHMSVoyageData);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_voyageObj" type="CM_Voyage"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
