	voyCode.add("JBL300N");
	disCode.add("USSAV");
	destCode.add("USSAV");
	comCode.add("NUTS");
	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USSAV");
	destCode.add("USSAV");
	comCode.add("GLAS");
	app.initialize;
	on Exception do handleException(exception);
	app.setPassBackExceptions(true, true);
//	app.setPassBackExceptions(false, false);
//	theUser := CM_Terminal.firstInstance.users["SUPERUSER"];
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	app.myPassport.warningsAcknowledged	:= true;
	app.myPassport.setIsBackgroundWarningsIgnored(true);

	foreach contRange in app.myRoot.allContainerRanges do
		isoType := app.myRoot.allISOTypes[contRange.isoType];
		if isoType = null then
			continue;
		endif;
		if isoType.isIntegral() then
			continue;
		endif;
		if contRangeUsedArray.includes(contRange) then
			continue;
		endif;
		skipCount := skipCount + 1;	
		trackedItem := app.getMyTerminalDO_NOT_USE.allOnsiteTIsByIdCargoType[contRange.lower, TI_CargoType_Container];
		if trackedItem &lt;&gt; null then
			continue;
		endif;
		foreach vehicle in app.getMyTerminalDO_NOT_USE().vehicles do
			vehCount := vehCount + 1;
			if vehCount &lt; skipCount then
				continue;
			endif;
			break;
		endforeach;
		if not isoType.isIntegral() then
			index := index + 1;
			if index &gt; opCode.size then
				break;
			endif;
			contRangeUsedArray.add(contRange);
			self.processGroupOfContainers(contRange, vehicle.regNumber, opCode[index], voyCode[index], disCode[index], destCode[index], comCode[index]);
write class.name&amp;'::'&amp;method.name&amp;' '&amp;(contRange.lower&amp;' '&amp;vehicle.regNumber&amp;' '&amp;opCode[index]&amp;' '&amp;voyCode[index]);
		endif;
	endforeach;
write class.name&amp;'::'&amp;method.name&amp;' '&amp;index.String&amp;' '&amp;skipCount.String;
end;</source>
    </JadeMethod>
    <JadeMethod name="processGeneralToEDI" id="4d03e006-c5b5-4db3-ab0f-9c726f2a0d16">
        <source>processGeneralToEDI();
constants
	FILENAME = "c:\EDI\MTDB\containers";
vars
	prevLength : String;
	currLength : String;
	location : String;
	imexStatus : String;
	contRange: CM_ContRange;
	isoType: CM_ISOType;
	index: Integer;
	theUser: CM_User;
//	vehicle: CM_Vehicle;
	opCode, voyCode, disCode, destCode, comCode: StringArray;
	skipCount, locCount : Integer;
	trackedItem: CM_TrackedItem;
	contRangeUsedArray: ObjectArray;
	intFaceArray : CMIF_TIObjectArray;
	file : File;
	intFaceItem	: CMIF_Receival;
	intFaceItemTI : CMIF_TIObject;
	locPrefix : String;
	lineCount : Integer;
	rowCount : Integer;
	colCount : Integer;
	laneCount : Integer;
	hgtCount : Integer;
	fileCount : Integer;
	teuCount : Integer;
	lineCountTotal : Integer;
begin
	create intFaceArray transient;
	create opCode  transient;
	create voyCode transient;
	create disCode transient;
	create destCode transient;
	create contRangeUsedArray transient;
	create comCode transient;
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("GENL");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("WINE");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("MACH");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("AUTO");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("PAMIT");
	destCode.add("PAMIT");
	comCode.add("FURN");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("PAMIT");
	destCode.add("PAMIT");
	comCode.add("NUTS");
	opCode.add("MSK");
	voyCode.add("JBL100N");
	disCode.add("PAMIT");
	destCode.add("PAMIT");
	comCode.add("GLAS");

	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("GENL");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("WINE");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("NUTS");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("AUTO");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("FURN");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("MACH");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("GLAS");

	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("GENL");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("WINE");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("PAMIT");
	comCode.add("MACH");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("AUTO");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("FURN");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("NUTS");
	opCode.add("MSK");
	voyCode.add("JBL200N");
	disCode.add("COCTG");
	destCode.add("COCTG");
	comCode.add("GLAS");

	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("GENL");
	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("WINE");
	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("MACH");
	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("AUTO");
	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USSAV");
	destCode.add("USSAV");
	comCode.add("FURN");
	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USSAV");
	destCode.add("USSAV");
	comCode.add("NUTS");
	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USSAV");
	destCode.add("USSAV");
	comCode.add("GLAS");
	app.initialize;
	on Exception do handleException(exception);
	app.setPassBackExceptions(true, true);
//	app.setPassBackExceptions(false, false);
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	app.myPassport.warningsAcknowledged	:= true;
	app.myPassport.setIsBackgroundWarningsIgnored(true);
	locPrefix := "X";
	fileCount := 1;
	create file transient;
	file.fileName := FILENAME&amp;locPrefix&amp;fileCount.String&amp;".csv";
	file.mode := File.Mode_Output;
	file.open;
	rowCount := 1;
	colCount := 1;
	laneCount := 1;
	hgtCount := 1;
	foreach contRange in app.myRoot.allContainerRanges do
		isoType := app.myRoot.allISOTypes[contRange.isoType];
		if isoType = null then
			continue;
		endif;
		if isoType.isIntegral() then
			continue;
		endif;
		if contRangeUsedArray.includes(contRange) then
			continue;
		endif;
		skipCount := skipCount + 1;	
		trackedItem := app.getMyTerminalDO_NOT_USE.allOnsiteTIsByIdCargoType[contRange.lower, TI_CargoType_Container];
		if trackedItem &lt;&gt; null then
			continue;
		endif;
		if not isoType.isIntegral() then
			index := index + 1;
			if index &gt; opCode.size then
write class.name&amp;'::'&amp;method.name&amp;' '&amp;"reset index "&amp;index.String;
				index := 1;
//					break;
			endif;
			contRangeUsedArray.add(contRange);
			self.processGroupOfContainersToEDI(contRange, opCode[index], voyCode[index], disCode[index], destCode[index], comCode[index], intFaceArray);
//	write class.name&amp;'::'&amp;method.name&amp;' '&amp;(contRange.lower&amp;' '&amp;opCode[index]&amp;' '&amp;voyCode[index]);
			foreach intFaceItemTI in intFaceArray do
				intFaceItem := intFaceItemTI.CMIF_Receival;
//	write class.name&amp;'::'&amp;method.name&amp;' '&amp;"process "&amp;intFaceItem.id;
				lineCount := lineCount + 1;
				imexStatus := "EXPORT";
				location := locPrefix&amp;rowCount.stringWithLeadingZeros(2)&amp;colCount.stringWithLeadingZeros(2)&amp;laneCount.stringWithLeadingZeros(2);//&amp;' '&amp;hgtCount.stringWithLeadingZeros(1);
				file.writeLine(
								intFaceItem.id&amp;','&amp;
								"ISO Container"&amp;','&amp;
								imexStatus&amp;','&amp;
								intFaceItem.isoType&amp;','&amp;
								intFaceItem.operatorCode&amp;','&amp;
								intFaceItem.voyageCode&amp;','&amp;
								intFaceItem.commodity&amp;','&amp;
								intFaceItem.dischargePort&amp;','&amp;
								intFaceItem.destinationPort&amp;','&amp;
								intFaceItem.carriageTempC.String&amp;','&amp;
								intFaceItem.weight.String&amp;','&amp;
								intFaceItem.weightTotal.String&amp;','&amp;
								intFaceItem.bookingReference.Integer.String&amp;','&amp;
								location
	&amp;','&amp;locPrefix&amp;','&amp;rowCount.stringWithLeadingZeros(2)&amp;','&amp;colCount.stringWithLeadingZeros(2)&amp;','&amp;laneCount.stringWithLeadingZeros(2)&amp;','&amp;hgtCount.stringWithLeadingZeros(1)
								);
				currLength := intFaceItem.isoType[1:1];
				if prevLength &lt;&gt; currLength then
					hgtCount := 10;
				else
					hgtCount := hgtCount + 1;
				endif;
				if hgtCount &gt; 3 then
					if lineCount mod 7 &lt;&gt; 0 and hgtCount &gt; 4 then
						hgtCount := 1;
						colCount := colCount + 2;
						if currLength = '4' then
							colCount := colCount + 2;
						endif;
					endif;
				endif;
				prevLength := currLength;
				if colCount &gt; 70 then
					if prevLength = '4' or colCount &gt; 71 then
						hgtCount := 1;
						colCount := 1;
						laneCount := laneCount + 1;
					endif;
				endif;
				if laneCount &gt; 7 then
					hgtCount := 1;
					colCount := 1;
					laneCount := 1;
					rowCount := rowCount + 1;
				endif;
				if rowCount &gt; 8 then
					hgtCount := 1;
					colCount := 1;
					laneCount := 1;
					rowCount := 1;
					if locPrefix = 'X' then
						locPrefix := 'Y';
					elseif locPrefix = 'Y' then
						locPrefix := 'Z';
					elseif locPrefix = 'Z' then
						locPrefix := 'W';
					elseif locPrefix = 'W' then
						locPrefix := 'U';
					elseif locPrefix = 'U' then
						return;
					endif;
					file.close;
					fileCount := fileCount + 1;
					file.fileName := FILENAME&amp;locPrefix&amp;fileCount.String&amp;".csv";
					file.mode := File.Mode_Output;
					file.open;
					lineCountTotal := lineCountTotal + lineCount;
					lineCount := 0;
				endif;	
				if currLength = '4' then
					teuCount := teuCount + 2;
				else
					teuCount := teuCount + 2;
				endif;
				if lineCount mod 8000 = 0 then
					file.close;
					fileCount := fileCount + 1;
//if lineCount &gt; 5000 then return; endif;
					file.fileName := FILENAME&amp;locPrefix&amp;fileCount.String&amp;".csv";
					file.mode := File.Mode_Output;
					file.open;
					lineCountTotal := lineCountTotal + lineCount;
					lineCount := 0;
				endif;
			endforeach;
			intFaceArray.purge;
		endif;
	endforeach;
epilog
write class.name&amp;'::'&amp;method.name&amp;' index='&amp;index.String&amp;' skipCount='&amp;skipCount.String&amp;' opCode='&amp;opCode.size.String&amp;' contRangeUsedArray='&amp;contRangeUsedArray.size.String&amp;' lineCountTotal='&amp;lineCountTotal.String&amp;' teuCont='&amp;teuCount.String;
	file.close;
	delete file;
	delete opCode;
	delete voyCode;
	delete disCode;
	delete destCode;
	delete contRangeUsedArray;
	delete comCode;
	delete intFaceArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="processGroupOfContainers" id="f958dce0-97cd-4250-a924-fc52586454e7">
        <source>processGroupOfContainers(_contRange:CM_ContRange; _vehCode, _opCode, _voyCode, _disCode, _destCode, _comCode: String) protected;

vars
	intFaceArray : CMIF_TIObjectArray;
	intFaceCommon : CMIF_InOutCommon;
	intFaceItem	: CMIF_Receival;
	index, conNum: Integer;
	error: CM_Error;
	vehicle: CM_Vehicle;
	trackedItem: CM_TrackedItem;
	tiId: String;
begin
	vehicle := app.getMyTerminalDO_NOT_USE().vehicles[_vehCode, null];
	create intFaceCommon transient;
	intFaceCommon.myTerminal := app.getMyTerminalDO_NOT_USE();
	intFaceCommon.carrierCode := vehicle.carrierCode;
	intFaceCommon.regNumber := vehicle.regNumber;
	intFaceCommon.roadTransAreaId := "VTA";
	intFaceCommon.autoComplete := true;

	create intFaceArray transient;
	conNum := _contRange.lower[5:7].Integer;
	foreach index in 1 to 25 do
		create intFaceItem as CMIF_Receival transient;
		intFaceItem.setMyInOutCommon(intFaceCommon);
		intFaceItem.myTerminal := intFaceCommon.myTerminal;
		while true do
			tiId := _contRange.lower[1:4]&amp;conNum.stringWithLeadingZeros(7);
//write "try "&amp;tiId;
			conNum := conNum + 1;
			if conNum &gt; _contRange.upper[5:7].Integer then
				index := 105;
				break;
			endif;
			if app.checkDigitContainerId(tiId) then
//				break;
//			endif;
//			trackedItem := app.getMyTerminal().allOnsiteTIsByIdCargoType[intFaceItem.id, TI_CargoType_Container];
				trackedItem := app.getMyTerminalDO_NOT_USE().lookupTrackedItem(tiId, TI_CargoType_Container, TI_STATE_NORMAL, null, false);	
				if trackedItem = null then
					break;
				else
//write "found "&amp;tiId;
				endif;
			endif;
		endwhile;
		intFaceItem.id := tiId;
//write "process "&amp;intFaceItem.id;
		intFaceItem.cargoType := TI_CargoType_Container;
		intFaceItem.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT].CM_IMEXStatus;
		intFaceItem.isoType	:= _contRange.isoType;
		intFaceItem.operatorCode := _opCode;
		intFaceItem.voyageCode := _voyCode;
		intFaceItem.commodity := _comCode;
		intFaceItem.companyCode := "DFBU";
		intFaceItem.dischargePort := _disCode;
		intFaceItem.destinationPort := _destCode;
		intFaceItem.carriageTempC := NULL_TEMPERATURE; //app.myRoot.allCommodities[_comCode].minTemp;
//		intFaceItem.carriageTempC := app.temperatureConversionLookup(true,app.myRoot.allCommodities[_comCode].minTemp).fahrenheit;
		intFaceItem.weight := (_contRange.maxKilos-_contRange.tareKilos);
		intFaceItem.weightTotal := _contRange.maxKilos;
		intFaceItem.bookingReference := intFaceItem.id;
		intFaceArray.add(intFaceItem);
	endforeach;
	//app.myTrxCA.trxCreateInOutVehicle(intFaceCommon, app.myPassport);		//cnwmc5 - 22 Jan 2015 - PAR 35518
	app.myTrxCA.trxCreateInOut(intFaceCommon, intFaceArray, app.myPassport, null); //TFS 53107, AjitM, navam1
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		write class.name&amp;'::'&amp;method.name&amp;' '&amp;intFaceItem.id&amp;" OK";
	else
		foreach error in app.myPassport.allWarnings do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;intFaceItem.id&amp;" WARNING: "&amp;error.text;
		endforeach;
		foreach error in app.myPassport.allErrors do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;intFaceItem.id&amp;" ERROR: "&amp;error.text;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_contRange" type="CM_ContRange"/>
        <Parameter name="_vehCode" type="String"/>
        <Parameter name="_opCode" type="String"/>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_disCode" type="String"/>
        <Parameter name="_destCode" type="String"/>
        <Parameter name="_comCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="processGroupOfContainersToEDI" id="72bda1b2-6ce5-4294-98a4-27e6bbcdb0a2">
        <source>processGroupOfContainersToEDI(_contRange:CM_ContRange; _opCode, _voyCode, _disCode, _destCode, _comCode: String; intFaceArray : CMIF_TIObjectArray io) protected;

vars
//	intFaceArray : CMIF_TIObjectArray;
//	intFaceCommon : CMIF_InOutCommon;
	intFaceItem	: CMIF_Receival;
//	intFaceItemTI : CMIF_TIObject;
	index, conNum: Integer;
	error: CM_Error;
	ti: CM_Container;
	tiId: String;
begin
//	create intFaceCommon transient;
//	intFaceCommon.myTerminal := app.getMyTerminal();
//	intFaceCommon.roadTransAreaId := "VTA";
//	intFaceCommon.autoComplete := true;

//	create intFaceArray transient;
	conNum := _contRange.lower[5:7].Integer;
	foreach index in 1 to 3000 do
//		create intFaceItem as CMIF_Receival transient;
//		intFaceItem.setMyInOutCommon(intFaceCommon);
//		intFaceItem.myTerminal := intFaceCommon.myTerminal;
		while true do
			tiId := _contRange.lower[1:4]&amp;conNum.stringWithLeadingZeros(7);
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;"try "&amp;tiId;
			conNum := conNum + 1;
			if conNum &gt; _contRange.upper[5:7].Integer then
write class.name&amp;'::'&amp;method.name&amp;' '&amp;"index="&amp;index.String;
				index := 10005;
				break;
			endif;
			if app.checkDigitContainerId(tiId) then
//				break;
//			endif;
//			trackedItem := app.getMyTerminal().allOnsiteTIsByIdCargoType[intFaceItem.id, TI_CargoType_Container];
				ti := app.getMyTerminalDO_NOT_USE().lookupTrackedItem(tiId, TI_CargoType_Container, TI_STATE_NORMAL, null, false).CM_Container;	
				if ti = null then
					break;
				else
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;"found "&amp;tiId;
				endif;
			endif;
		endwhile;
		create intFaceItem transient;
		intFaceItem.id := tiId;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;"process "&amp;intFaceItem.id;
		intFaceItem.cargoType := TI_CargoType_Container;
		intFaceItem.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT].CM_IMEXStatus;
		intFaceItem.isoType	:= _contRange.isoType;
		intFaceItem.operatorCode := _opCode;
		intFaceItem.voyageCode := _voyCode;
		intFaceItem.commodity := _comCode;
		intFaceItem.companyCode := "DFBU";
		intFaceItem.dischargePort := _disCode;
		intFaceItem.destinationPort := _destCode;
		intFaceItem.carriageTempC := NULL_TEMPERATURE; //app.myRoot.allCommodities[_comCode].minTemp;
//		intFaceItem.carriageTempC := app.temperatureConversionLookup(true,app.myRoot.allCommodities[_comCode].minTemp).fahrenheit;
		intFaceItem.weight := (_contRange.maxKilos-_contRange.tareKilos);
		intFaceItem.weightTotal := _contRange.maxKilos;
		intFaceItem.bookingReference := intFaceItem.id;
		intFaceArray.add(intFaceItem);
	endforeach;
//	app.myTrxCA.trxCreateInOut(intFaceCommon, intFaceArray, app.myPassport);
//	if app.myPassport.trxCompletedOK and
//	   app.myPassport.allErrorWarnings.size = 0 then
//		write class.name&amp;'::'&amp;method.name&amp;' '&amp;intFaceItem.id&amp;" OK";
//	else
//		foreach error in app.myPassport.allWarnings do
//			write class.name&amp;'::'&amp;method.name&amp;' '&amp;intFaceItem.id&amp;" WARNING: "&amp;error.text;
//		endforeach;
//		foreach error in app.myPassport.allErrors do
//			write class.name&amp;'::'&amp;method.name&amp;' '&amp;intFaceItem.id&amp;" ERROR: "&amp;error.text;
//		endforeach;
//	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_contRange" type="CM_ContRange"/>
        <Parameter name="_opCode" type="String"/>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_disCode" type="String"/>
        <Parameter name="_destCode" type="String"/>
        <Parameter name="_comCode" type="String"/>
        <Parameter name="intFaceArray" type="CMIF_TIObjectArray" usage="io"/>
