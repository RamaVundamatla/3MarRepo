    <JadeMethod name="doDelete" id="45ad3c5f-57b2-4f08-9f28-20fb596d2c32">
        <updating/>
        <source>doDelete(pObj : Object io) updating;
// ---------------------------------------------------------------------------
// Created:     26 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	mthName	: String;
	
begin
	//epr par 36958 30/9/15 generic delete method
	if self.canDoDelete then
		app.myTrxDA.trxDeleteCMObject(pObj.CM_Object,app.myPassport);
	endif;
	

end;</source>
        <Parameter name="pObj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doImport" id="426d2544-a0db-423c-a50f-9db13f7ac8e6">
        <source>doImport(_impFile : File): Boolean;		//cnwmc5 - 15 May 2014 - PAR 34156
// MES 1010 jmn - moved up so can be reimplemented
// PAR20723 JMH 23/0/09 Exit if user cancels on open dialog
vars
	//impFile		: File;				//cnwmc5 - 15 May 2014 - PAR 34156
	cmifMonitor	: CMIF_Monitor;
	theForm		: SOP_TableMaintForm;	
begin

	theForm := self.myForm;
	
	//create impFile transient;			//cnwmc5 - 15 May 2014 - PAR 34156
	//self.getImportFile(impFile);		//cnwmc5 - 15 May 2014 - PAR 34156
	//if impFile.fileName = null then	//cnwmc5 - 15 May 2014 - PAR 34156
	//	return true;					//cnwmc5 - 15 May 2014 - PAR 34156
	//endif;							//cnwmc5 - 15 May 2014 - PAR 34156
	
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := theForm;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;

	self.initModalDialog();
	theForm.lblModalMessage.caption := Cr &amp; (app.getErrorString(Importing) &amp; ' ' &amp; name);
	theForm.frmModalDialog.visible := true;

	app.doWindowEvents(0);

	
	if _impFile.fileName = null then
		return true;
	else
		doImportTrx(_impFile);
	endif;
		
	return app.myPassport.trxCompletedOK;
	
epilog
	theForm.frmModalDialog.visible := false;
	delete cmifMonitor;
	//delete impFile;					//cnwmc5 - 15 May 2014 - PAR 34156
end;</source>
        <Parameter name="_impFile" type="File"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doImportTrx" id="35380000-01eb-4519-803e-5490816b1be4">
        <source>doImportTrx(_impFile: File) protected;

/*

Purpose:		Import File	
Parameters:		Import File	

Date		Who		Reason
11 August 2009	cnwjmn1	Initial creation

*/

vars

begin
	
end;</source>
        <access>protected</access>
        <Parameter name="_impFile" type="File"/>
    </JadeMethod>
    <JadeMethod name="doLoadCmbResources" id="eb698ed3-7d9c-464a-af82-77bed2364e46">
        <source>doLoadCmbResources(_cmb: CMUI_ComboBox input; _harbour: HMS_Harbour; _resource: HMS_Resource; _column: Integer);
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	resource		: HMS_Resource;
	combo				: CMUI_ComboBox;
begin
	if _cmb = null or _harbour = null then
		return;
	endif;
	
	combo := _cmb;
	combo.clear();
	combo.addItem(null);
		
		
	combo.listCollection(_harbour.allResources, true, 0);
	
	
//	foreach resource in _harbour.allResources discreteLock
//		where resource.isNotAvailableForEntry = false do // CCMS 1350
//		_cmb.itemObject[_cmb.addItem(resource.description)] := resource;
//	endforeach;
	
	if _resource &lt;&gt; null then
		combo.listIndex := combo.findObject(_resource);
	endif;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_resource" type="HMS_Resource"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
