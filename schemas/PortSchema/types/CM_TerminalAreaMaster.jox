    <JadeMethod name="isPackArea" id="ec0bcd14-0831-4272-9b70-8e586e61cc58">
        <source>isPackArea():Boolean;
// ---------------------------------------------------------------------------
// Created:     09 February 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	taType	:CM_TerminalAreaType;
	type	:Integer;
begin
	taType := self.myType;
	
	if taType = null then
		return false;
	endif;
	
	type := taType.type;
	
	return type =  TA_TYPE_IRREGULAR_BLOCK_AREA or 
			type = TA_TYPE_DEPOT_LCL;
epilog

end;</source>
