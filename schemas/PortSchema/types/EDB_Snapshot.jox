    <JadeMethod name="edb_LastChangeReason" id="83103519-76f6-4387-98a3-8aded434d016">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>edb_LastChangeReason(set:Boolean; value:String io) mapping, updating, subschemaHidden;
begin
	if set then
		_setVirtualString( 'lastChangeReason',56, value );
	else
		value := _getVirtualString( 'lastChangeReason',56);
	endif;
end;</source>
        <subAccess>hidden</subAccess>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
