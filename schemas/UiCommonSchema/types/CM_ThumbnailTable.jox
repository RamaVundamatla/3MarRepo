    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="create" id="b5ddad8f-ab6d-4f84-bdc2-8b893540381c">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.rows := 0;
	self.fixedRows := 1;
	
	self.columns := 2;
	self.fixedColumns := 1;
	
	self.fixed3D := false;
	self.tabStop := false;
	
	self.readOnly := false;
	self.userInputEnabled := false;
	self.scrollBars := self.ScrollBar_Vertical;
	
	self.gridLines := true;
	self.backColor := -2147483633;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getRowFromHeading" id="7bdff375-7d18-4162-beaa-3bb495c6f1c5">
        <updating/>
        <source>getRowFromHeading(_heading : String) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx, numRows  : Integer;
begin
	if _heading = null then
		return -1;
	endif;
	
	numRows := self.rows;
	
	foreach idx in 1 to numRows do
		if self.accessCell(idx,1).text = _heading then
			return idx;
		endif;
	endforeach;
	
	return -1;
end;</source>
        <Parameter name="_heading" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideRowFromHeading" id="66f934e3-58f3-4c6c-a215-0eebef47f272">
        <updating/>
        <source>hideRowFromHeading(_heading : String) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	idx, numRows  : Integer;
begin
	if _heading = null then
		return;
	endif;
	
	idx := self.getRowFromHeading(_heading);
	
	if idx  &lt;= 0 then
		return;
	endif;
	
	self.accessRow(idx).visible := false;
	
	
end;</source>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="hideRowsFromHeading" id="6ba0ebeb-431f-489c-942d-ccddc57af15e">
        <updating/>
        <source>hideRowsFromHeading(_heading : String) updating;
/*

Date		Who		Reason
03 March 2017	cnwer1	Initial creation TFS

*/

vars
	idx  : Integer;
	foundRow : Boolean;
begin
	if _heading = null then
		return;
	endif;
	
	foreach idx in 1 to self.rows do
		if self.accessCell(idx,1).text = _heading then
			foundRow:=true;
			self.accessRow(idx).visible := false;
		else
			if foundRow then
				break;
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="optimiseHeadingColumn" id="d818980f-c9ce-4eb5-98b9-7b6b7b8f21b6">
        <updating/>
        <source>optimiseHeadingColumn(_sheet : JadeTableSheet input) updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	xWidth		: Integer;
	numRows,
	maxWidth	: Integer;

begin

	if _sheet.columns &lt; 1 then
		return;
	endif;
	
	_sheet.column := 1;

	numRows := _sheet.rows;
	// First do fixed header rows
	foreach idx in 1 to numRows do

		xWidth := self.getTextExtent(_sheet.accessCell(idx, 1).text);
		if fontItalic then
			xWidth := xWidth + 4;
		endif;
		if fontBold then
			xWidth := (xWidth * 1.2).rounded;
		endif;
		if self.fixed3D then
			xWidth := xWidth + 1;
		endif;
		maxWidth := maxWidth.max(xWidth);

	endforeach;
	
	_sheet.accessColumn(1).width := maxWidth + 4;
	
end;</source>
        <Parameter name="_sheet" type="JadeTableSheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHeadingByHeading" id="20b17300-f0ec-40f3-bc87-63ad36be3c1b">
        <updating/>
        <source>setHeadingByHeading(_heading : String; _newLabel : String) updating;
// ---------------------------------------------------------------------------
// Created:		October 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	idx, numRows  : Integer;
begin
	if _heading = null then
		return;
	endif;
	
	idx := self.getRowFromHeading(_heading);
	
	if idx  &lt;= 0 then
		return;
	endif;
	
	self.accessCell(idx,1).text := _newLabel;
	
	
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_newLabel" type="String"/>
    </JadeMethod>
    <JadeMethod name="sheetChg" id="b6612261-b41c-4339-94b8-2699c1481485">
        <updating/>
        <source>sheetChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
// Do not call as inheritMethod calls cnEcResizeContents which for then calls setLastColumnMaxWidth
// which has undesirable consequences (refer CM_ContainerEnt - Log Data sheet)

//	inheritMethod(table);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showRowFromHeading" id="7f77e2dd-e96e-43ae-86a5-46612f406f3d">
        <updating/>
        <source>showRowFromHeading(_heading : String) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	idx, numRows  : Integer;
begin
	if _heading = null then
		return;
	endif;
	

	idx := self.getRowFromHeading(_heading);
	
	if idx  &lt;= 0 then
		return;
	endif;
	
	self.accessRow(idx).visible := true;
	
	
end;</source>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="dea1cbd4-73f8-4043-9cf6-13582971abee">
        <controlMethod name="CM_BaseTable::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	self.setMargins();
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
