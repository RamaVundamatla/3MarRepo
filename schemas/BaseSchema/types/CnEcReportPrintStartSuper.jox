    <JadeMethod name="isReportParamIncluded" id="0a6cb23c-28b6-449d-a392-3bbf671bbee3">
        <source>isReportParamIncluded(pReportParameter:CnEcReportParameter; pParameterValueColl: CnEcReportParameterValueDict):Boolean protected;
//
// Returns true if pReportParameter is referenced by parameterValue.myReportParameter.
//
vars
 	parameterValue	: CnEcReportParameterValue;

begin
	foreach parameterValue in pParameterValueColl do
		if parameterValue.myReportParameter &lt;&gt; pReportParameter then
			continue;
		endif;
		
		return true;
	endforeach;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pReportParameter" type="CnEcReportParameter"/>
        <Parameter name="pParameterValueColl" type="CnEcReportParameterValueDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="registerNotifications" id="f13b49a9-503b-4b4c-8a7f-1a6980cf1e0f">
        <source>registerNotifications() protected;
// rmm 23/3/1999

begin
	if self.aMyReportQueueEntry &lt;&gt; null then
		self.beginNotification(self.aMyReportQueueEntry, Any_System_Event, Response_Continuous, null);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
