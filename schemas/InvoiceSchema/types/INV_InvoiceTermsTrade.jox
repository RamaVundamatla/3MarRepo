    <JadeMethod name="setControlsForAddEdit" id="ce094e5c-b053-469c-9876-5fbdc328eb4b">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.populateEntDetailTable();
	self.tblEntDetail.setFocus;
	if self.mode = self.Mode_Add then
		self.tblEntDetail.goToRowByName(ETRow_Code3);
		self.tblEntDetail.enableRowByName(ETRow_Code3);
		self.tblEntDetail.enableRowByName(ETRow_DueDays);	//15/01/2023	navkc1 ChangeRequest 59145 Task 61328
		self.tblEntDetail.enableRowByName(ETRow_DueRule);	//15/01/2023	navkc1 ChangeRequest 59145 Task 61328
	else
		self.tblEntDetail.goToRowByName(ETRow_Description30);
		self.tblEntDetail.disableRowByName(ETRow_Code3);
		self.tblEntDetail.enableRowByName(ETRow_DueDays);	//15/01/2023	navkc1 ChangeRequest 59145 Task 61328
		self.tblEntDetail.enableRowByName(ETRow_DueRule);	//15/01/2023	navkc1 ChangeRequest 59145 Task 61328
	endif;
end;</source>
    </JadeMethod>
