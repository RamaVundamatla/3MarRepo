    <JadeMethod name="edb_Remarks" id="1c6554c1-d671-4bf5-b531-fc4b54eb4405">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>edb_Remarks(set:Boolean; value:String io) mapping, updating, subschemaHidden;
begin
	if set then
		_setVirtualString( 'remarks',41, value );
	else
		value := _getVirtualString( 'remarks',41);
	endif;
end;</source>
