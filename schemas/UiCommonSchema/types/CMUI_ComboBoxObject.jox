    <JadeMethod name="clear" id="c135f150-4dc1-4cb7-b62d-29f917c2aa59">
        <updating/>
        <source>clear() updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.amInitialised := false;
	self.myObject := null;
	self.hasDirtyObject := false;
	
	inheritMethod();

end;</source>
