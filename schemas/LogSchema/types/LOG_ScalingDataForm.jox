    <JadeMethod name="translateForm" id="600d4f33-ede7-45de-9b40-59ee8134f1b7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006339, locale);
	grpHeader.translateCaption(Xlat_0002442, locale);
	lblRemaining.translateCaption(Xlat_0002441, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateItem" id="4a7a2b1f-b6f5-4a4f-b3f3-538947363b3d">
        <updating/>
        <source>updateItem() : Boolean updating;
//--------------------------------------------------------------
//Created: 17 April 2002 By: cnwgd1
//--------------------------------------------------------------
/*
Date		      Who		Reason
17 June 2008	cnwdz2	    Par16941 related to Par16801 - Use app.handleDeletedObject() to handle invalid object reference instead of isValidObject().
*/

vars
	oldLogID           : String;	
	roundMin, roundMax : Integer;	
	invalidScalingDtl  : Boolean; 
	lockedDtl		   : CM_LogScalingDtl;
	tmpDtl			   : CM_LogScalingDtl;  //cnwrd1 15.7.2008 par 17456 
	
begin
	if self.selectedRow &lt;= 1 then
		return false;
	endif;
	
	if self.mySelectedScalingDtl = null then	// or not app.isValidObject(self.mySelectedScalingDtl) then//par16801
		return false;
	endif;
	
	if self.mySelectedScalingDtl.logID &lt;&gt; oldLogID then  // cnwrd1 3.11.08  par  17456
		self.checkForDuplicateScalingDtl(self.mySelectedScalingDtl, tblItem.getValueByName(ETRow_LogId).String );
	endif;
	
	//To correct Par16941 related to Par16801
	//Use handleDeletedObject() to handle invalid object reference instead of isValidObject() 
	on Exception do app.handleDeletedObject(exception, self.mySelectedScalingDtl, invalidScalingDtl);	
	//If the self.mySelectedScalingDtl object is not valide then return false.
	if invalidScalingDtl then
		self.mySelectedScalingDtl := null;
		return false;
	endif;
	
	self.mySelectedScalingDtl.checkFieldsNotNull();
//	if self.mySelectedScalingDtl.logID &lt;&gt; oldLogID then //-- cnwrd1 3.11.08  par  17456
//		self.checkForDuplicateScalingDtl(self.mySelectedScalingDtl, tblItem.getValueByName(ETRow_LogId).String );
//	endif;

	sharedLock(self.mySelectedScalingDtl); //Prevent others updating mySelectedScalingDtl

	lockedDtl := self.mySelectedScalingDtl;
	tmpDtl :=  lockedDtl.cloneSelf(true);   //cnwrd1 15.7.2008 par 17456  - making changes to the only copy of the data we have ( not on the table) so make a copy for rollback
	
	oldLogID := self.mySelectedScalingDtl.logID;
	
	self.setFieldSEDs(roundMin, roundMax);
	self.mySelectedScalingDtl.setForUpdateProxy(tblItem.getValueByName(ETRow_LogId).String,
							  	  				tblItem.getValueByName(ETRow_LogCondition).String,
												roundMin, roundMax, tblItem.getValueByName(ETRow_ScalerCode).String);
	
    on CM_Exception do addExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings(); // added as was causing error warnings from previous actions HJG 1/04/05
	/*						  
	self.mySelectedScalingDtl.checkFieldsNotNull();
	if self.mySelectedScalingDtl.logID &lt;&gt; oldLogID then
		self.checkForDuplicateScalingDtl(self.mySelectedScalingDtl);
	endif;
	*/
	if app.myPassport.hasErrors then
		app.showErrorWarningDialog('Scaling Data', app.myPassport, ErrWarnMode_Update);
		self.mySelectedScalingDtl.setForUpdateProxy(tmpDtl.logID,									//cnwrd1 15.7.2008 par 17456 - reset the scalingdtl back to what it should be after failed update
													tmpDtl.conditionCode,
													tmpDtl.minSED, tmpDtl.maxSED, tmpDtl.scalerCode);
		return false;
	endif;
	
	if tmpDtl.logID &lt;&gt; self.mySelectedScalingDtl.logID then //cnwrd1 15.7.2008 par 17456  - key updated , remove the old add in the new
		self.allScalingDtls.removeKey(tmpDtl.logID );
		self.allScalingDtls.add(self.mySelectedScalingDtl);
	endif;
		 
	
	self.mySelectedScalingDtl.setHdrForProxy(self.myCurrentTicket);	
	self.tblAll_ShowScalingDtl(self.mySelectedScalingDtl, self.selectedRow);
	
	self.setEnableObjects();
	return true;
	
epilog	
    //unlock the locked object.
	if lockedDtl &lt;&gt; null then
		unlock(lockedDtl);
	endif;
	
	//cnwrd1 15.7.2008 par 17456  - delete the tmp transient
	if tmpDtl &lt;&gt; null then
		delete tmpDtl; 
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="0997e86d-d6f3-44d7-ad6a-bb947ea25eca">
        <updating/>
        <source>validate() updating, protected;
//--------------------------------------------------------------
//Created: 29 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpStr,
	operCode,
	docketNum : String;
	realHeader,
	existingHdr : CM_LogScalingHdr;
begin
	operCode := self.tblHeader.getValueByName(ETRow_Supplier).String;
	docketNum := self.tblHeader.getValueByName(ETRow_DocketNumber).String;
	if operCode = null then
		tmpStr := app.getTerminologyAlternate(null, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, "Supplier");
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr , ETRow_Supplier, self);
		app.raiseCMException1(Input_required_field_Required, tmpStr , ETRow_Supplier, self); // cnwdb2	PAR 35364
	endif;
	if docketNum = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Docket Number", ETRow_DocketNumber, self);
		app.raiseCMException(Input_required_field_dockNum, ETRow_DocketNumber, self); // cnwdb2	PAR 35364
		
	endif;
	
	
	//RJS2 12/11/02 this check is no longer required
	/*if operCode &lt;&gt; null and docketNum &lt;&gt; null then
		existingHdr := self.myTerminal.allLogScalingHdrsUnmatched.getAtKeyGeq(operCode, docketNum, null);
		if existingHdr &lt;&gt; null and
		   existingHdr.operatorCode = operCode and
		   existingHdr.bolNumber = docketNum then
			if self.mode = UPDATE_MODE then
				if self.myCurrentTicket &lt;&gt; null and self.myCurrentTicket.isTransient then
					realHeader := self.myCurrentTicket.pxyGetRealObject();
					if existingHdr &lt;&gt; realHeader then
						app.raiseCMException1(ERR_DUPLICATE_KEY, 'Unscaled Docket number ' &amp;
											  docketNum &amp; ' for supplier ' &amp; operCode, null, null);
					endif;
				endif;
			else
				app.raiseCMException1(ERR_DUPLICATE_KEY, 'Unscaled Docket number ' &amp;
									  docketNum &amp; ' for supplier ' &amp; operCode, null, null);			
			endif;
		endif;	
	endif;*/

	if self.mode = ADD_MODE then
		if self.allScalingDtls.isEmpty then
		//	app.raiseCMException1(REQUIRED_FIELD, "Scaling Detail", ETRow_LogId, self);
			app.raiseCMException(Input_required_field_scailDets, ETRow_LogId, self); // cnwdb2	PAR 35364
		endif;
	elseif self.mode = UPDATE_MODE and self.myCurrentTicket &lt;&gt; null then
		if self.myCurrentTicket.allLogScalingDtls.isEmpty then
		//	app.raiseCMException1(REQUIRED_FIELD, "Scaling Detail", ETRow_LogId, self);
			app.raiseCMException(Input_required_field_scailDets, ETRow_LogId, self); // cnwdb2	PAR 35364
		endif;
	endif;
	
	self.validatePieceCount();
	self.tblHeader.setFocus();	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validatePieceCount" id="317e1b98-5812-4006-aefc-c22efe5e96e8">
        <source>validatePieceCount()protected;
//--------------------------------------------------------------
//Created: 29 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	reqPieceCount,
	actualPieceCount : Integer;
begin
	reqPieceCount := self.tblHeader.getValueByName(ETRow_NumItems).Integer;
	if self.mode = ADD_MODE then
		actualPieceCount := self.allScalingDtls.size;
	elseif self.mode = UPDATE_MODE  and self.myCurrentTicket &lt;&gt; null then
		actualPieceCount := self.myCurrentTicket.allLogScalingDtls.size;
	endif;
	if actualPieceCount &lt;&gt; reqPieceCount then
		app.raiseCMWarning2(VB_COUNT_MISMATCH, 'items in the list', 'Piece Count', ETRow_NumItems, null,self.myTerminal);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
