<Class name="CM_QReferenceMethod" id="5dcd07ed-214d-4b70-8e60-edf905e672cd">
    <superclass name="CM_QueryMethod"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="824620a3-4ca3-49bd-bb2c-216dee5c79e0">
        <updating/>
        <source>create() updating;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QReferenceLookup persistent;
	self.allAllowedOperators.add(oper);


end;</source>
    </JadeMethod>
    <JadeMethod name="getBanksInPlay" id="7678dd9d-2082-428b-939e-4f64cbedc68b">
        <source>getBanksInPlay( _params: CM_QueryCriteriaLineHolder; objSet : ObjectSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	termObjSet : ObjectSet;
	crit : CM_SelectorCriteriaLine;
	obj : Object;
	term : CM_Terminal;
	bank : CM_Bank;

begin

	//try to establish the 'Bank(s)' in play directly from the criteria.
	foreach crit in _params.allCriteriaLines do
		if crit.myQueryProperty.propertyName = 'bank' or
			crit.myQueryProperty.propertyName = 'myBank' or
			crit.myQueryProperty.propertyName = 'getBank' then
			crit.myQueryOperator.getSearchValueAsObjectSet( objSet );
			return;
		endif;
	endforeach;
	
	
	//OK, then try to use the banks based on the terminals in play
	create termObjSet transient;
	self.getTerminalsInPlay( _params, termObjSet );
	
	if termObjSet.isEmpty then
		return;
	endif;
	
	//now use the terminals to find the banks
	foreach obj in termObjSet do
		term := obj.CM_Terminal;
		foreach bank in term.companies discreteLock where bank.isBusinessUnit do
			objSet.addNoDuplicates( bank, false );
		endforeach;
	endforeach;
	

epilog

	delete termObjSet;

end;</source>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="objSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="a6e53f77-82ba-4803-9f25-22e4dc4483a2">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars

begin

	if _op.isKindOf(CM_QReferenceLookup) then
		return QueryControl_ComboBox;
	elseif _op.isKindOf(CM_QReferenceIsOneOf) then
		return QueryControl_MultiSelect;
	endif;

	return inheritMethod(_op);

end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryOperatorForYADataConv" id="7d618248-5873-4ecf-9e12-66fc22056fa7">
        <source>getQueryOperatorForYADataConv(): Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	iter : Iterator;
	queryOper : CM_QueryOperator;
	class : Class;
	className : String;

begin
	
	//first choice
	iter := self.allAllowedOperators.createIterator;
	while iter.next( queryOper ) do
		class := queryOper.class;
		if class = CM_QReferenceIsOneOf then
			return class;
		endif;
	endwhile;
	delete iter;
	
	//second choice
	iter := self.allAllowedOperators.createIterator;
	while iter.next( queryOper ) do
		class := queryOper.class;
		if class = CM_QReferenceLookup then
			return class;
		endif;
	endwhile;
	
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getTerminalsInPlay" id="dc0a28ec-9c50-4477-ac62-d408f4e174ae">
        <source>getTerminalsInPlay( _params: CM_QueryCriteriaLineHolder; objSet : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	crit : CM_SelectorCriteriaLine;

begin

	foreach crit in _params.allCriteriaLines do
		if crit.myQueryProperty.propertyName = 'myTerminal' or
			crit.myQueryProperty.propertyName = 'getTerminal' then
			crit.myQueryOperator.getSearchValueAsObjectSet( objSet );
			break;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="objSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="56bea3c5-8124-45a4-a4d6-639335f85ef6">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
09 February 2010		cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
23/03/2018 	Jlgns1	Bug 37765: SNO - Event Transaction Error
*/

vars
	edition : Integer;													//Bug 37765
	invalid : Boolean;													//Bug 37765
begin
	on Exception do app.handleDeletedObject(exception,_obj,invalid);	//Bug 37765
	edition := _obj.edition;											//Bug 37765
	if invalid then														//Bug 37765
		return null;													//Bug 37765
	endif;																//Bug 37765
	return _obj.sendMsg(self.propertyName);
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
