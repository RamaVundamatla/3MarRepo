    <JadeMethod name="cargoOperator" id="02fa2548-8211-45c6-96f3-f063b3255cb0">
        <source>cargoOperator() : CM_Operator;
//
// 08 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
//
vars

begin
	if self.myCargoOperator &lt;&gt; null then
		return self.myCargoOperator;
	elseif self.mySenderOperator &lt;&gt; null then
		return self.mySenderOperator;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="cargoOperatorCode" id="2ab735b3-08d4-4541-bfa4-0f1dca880dd0">
        <source>cargoOperatorCode() : String;
//
// 30 May 2018	jlgrs1	TFS 38357 SNO Fix Xlations from TFS 6797
//
vars

begin
	if self.myCargoOperator &lt;&gt; null then
		return self.myCargoOperator.code;
	elseif self.mySenderOperator &lt;&gt; null then
		return self.mySenderOperator.code;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearAll" id="23eef061-ab8d-47ba-99bd-451f773fcc28">
        <updating/>
        <source>clearAll() updating;
/*
Purpose:	Sets all attributes to default values

Date				Who		Reason
30 November 2011	cnwgb1	Initial creation - CCMS POL 2122 PAR 28696		
15/02/2012			cnwcs5	CCMS POL 2151 - default release request date
23 Feb 2012			cnwrs1	Par 29181 Fix up Coparn reprocess
24/04/2012			cnwcs5	par 29480 - changes for updating request date
16/04/2014          cnwgb1  PAR 33795 - CUSCAR Manifest
14 Jun 2016 		cnwma1	TFS #2048 POL - HSD EDI Empty Release Request
29/08/2016			cnwdap1	TFS #2566 AAT EDI IFCSUM
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 30 May 2018	jlgrs1	TFS 38357 SNO Fix Xlations from TFS 6797
// 03 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
// 14/10/2024	navcs2	MTN-33034 NSW | FR - IFCSUM - Issues with HS Code to Cargo Type and Sub-Type Mappings
*/
vars

begin
    self.callsign 				:= null;
    self.commodityCodeHeader 	:= null;
    self.commodityDescHeader 	:= null;
    self.currentBrID 			:= null;
    self.defCmdty 				:= null;
    self.destination 			:= null;
    self.dischargePort 			:= null;
    self.ediFileIssueDateTime 	:= null;
    self.hazCmdty 				:= null;
    self.hazCommodityCodeHeader := null;
    self.hazundg 				:= null;
    self.loadPort 				:= null;
    self.lloydsNumber 			:= null;
    self.mtCmdty 				:= null;
    self.mySenderOperator 		:= null;
    self.myVoyageOperator 		:= null;
 	self.myEDIBookingHeaderTI := null;
	self.myEDIBookingItemTI	:= null;
	self.myEDIHdr 				:= null;
    self.myEDIItem 				:= null;
	self.myEDIPrenoteTI := null;
	self.myEDIRequestHeaderTI := null;
	self.myEDIRequestItemTI	:= null;
	self.rawEDIData 			:= null;
    self.refCmdty 				:= null;
    self.requestDT 				:= self.creationTime;	// par 29137 - time file was loaded
	self.requestDTDoUpdate		:= false;				// par 29480 April 2012
    self.requiredDT 			:= null;
    self.senderOperatorCode 	:= null;
    self.transVoyageCode 		:= null;
    self.vesselName 			:= null;
    self.voyageCode 			:= null;
    self.voyageOperatorCode 	:= null;
	self.skipTillNextBGM := null;	// 23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
    self.gidCount := 0;
    self.bulkId := null;
    self.thisPort := null;
    self.skipTillNextGID := false;
    self.bolNumber := null;
	self.availabilityGrades := null;  //cnwma1 TFS #2048 14/06/2016 
	self.totalVolume 			:= null;								// TFS #2566
	self.totalWeight			:= null;								// TFS #2566
	self.model					:= null;								// TFS #2566
    self.specialStowage 		:= null;	//07 Jun 2017	NDL	TFS 4454
	self.allEDICargoForGID.clear; //jlier1 TFS 57426 18/4/23
	if self.allEDIItems &lt;&gt; null then
        self.allEDIItems.clear();
        delete self.allEDIItems;
    endif;
	
	self.weightCertifiedName := null;
	self.weightCertifiedReference := null;
	self.myCargoOperator := null;
	self.releaseRequestNumber := null;
	self.customsAgent := null;
	self.releaseCarrier := null;
	self.clientRef := null;
	self.cargoSubType := null;	// 14/10/2024	navcs2	MTN-33034
	self.hsCode	:= null;		// 14/10/2024	navcs2	MTN-33034
end;</source>
    </JadeMethod>
    <JadeMethod name="clearGID" id="bf9de046-991c-4e38-ada6-f84a46dc4f4e">
        <updating/>
        <source>clearGID(_ediPartyRules : CM_EDIPartyIFCSUMRules) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2023	jlier1	Initial creation 57426

*/

vars
	gidCount : Integer;
	ediTI : CM_EDITrackedItem;
	ediCargoTI : CM_EDICargoTI;
	
begin
	self.remarks:=null;
	self.cargoWeight:=null;
	self.totalVolume:=null;
	self.totalWeight:=null;
	self.hsCode:=null;
	self.cargoSubType:=null;
	
	if _ediPartyRules&lt;&gt; null and _ediPartyRules.divideWeightVolumeByGIDCount then
		gidCount:=self.allEDICargoForGID.size;
		if gidCount &gt; 1 then
			foreach ediTI in self.allEDICargoForGID do
				if ediTI.isKindOf(CM_EDICargoTI) then
					ediCargoTI:=ediTI.CM_EDICargoTI;
					if _ediPartyRules.meaIsCargoWeight then
						if ediCargoTI.cargoWeight &gt; 0 then
							ediCargoTI.cargoWeight:=(ediCargoTI.cargoWeight/gidCount).rounded;
						endif;
						ediCargoTI.weight:=ediCargoTI.cargoWeight + ediCargoTI.tareWeight;
					else
						if ediCargoTI.weight &gt; 0 then
							ediCargoTI.weight:=ediCargoTI.weight/gidCount;
						endif;
					endif;
					if ediCargoTI.volume &gt; 0 then
						ediCargoTI.volume:=ediCargoTI.volume/gidCount;
					endif;		
				endif;	
			endforeach;
		endif;
	endif;
	
	
	self.allEDICargoForGID.clear;
epilog

end;</source>
