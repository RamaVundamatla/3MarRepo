    <JadeMethod name="getBerthingDT" id="d6413525-b184-4f2b-a926-c018a344efab">
        <source>getBerthingDT():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		27 November 2006 by cnwdad1
//
// Purpose:		Gets the Berthing Date/Time, as occurence Date/Time of the first
//				movement whose region is a terminal.
//
// Parameters:	None
//
// Returns:		The date/time of the next Berthing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	voyageDataObj	: HMS_VoyageData;
	movementObj		: HMS_VoyageMovement;
	berthObj		: HMS_Berth;
	regionObj		: HMS_HarbourRegion;
	
begin
	voyageDataObj	:=	self.myHMSVoyageData;
	
	if voyageDataObj &lt;&gt; null then
		foreach movementObj in voyageDataObj.allVoyageMovements do
			berthObj	:=	movementObj.getMyBerth;
			
			if berthObj &lt;&gt; null then
				regionObj	:=	berthObj.myHarbourRegion;
				
				if regionObj &lt;&gt; null and regionObj.getTerminal() &lt;&gt; null then
					return movementObj.occursOnDT;
				endif;
			endif;
		endforeach;
	endif;
	
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getBerthingDTLocalTZ" id="8a7be47b-0c62-4976-9ee6-a48dff7fd517">
        <source>getBerthingDTLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2016	cnwns1	Initial creation
// 01 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	voyageDataObj	: HMS_VoyageData;
	movementObj		: HMS_VoyageMovement;
	berthObj		: HMS_Berth;
	regionObj		: HMS_HarbourRegion;
	
begin
	voyageDataObj	:=	self.myHMSVoyageData;
	
	if voyageDataObj &lt;&gt; null then
		foreach movementObj in voyageDataObj.allVoyageMovements do
			berthObj	:=	movementObj.getMyBerth;
			
			if berthObj &lt;&gt; null then
				regionObj	:=	berthObj.myHarbourRegion;
				
				if regionObj &lt;&gt; null and regionObj.getTerminal() &lt;&gt; null then
					return self.systemToLocalTime(movementObj.occursOnDT);
				endif;
			endif;
		endforeach;
	endif;
	
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getBerthingDateForPriority" id="80716956-1fad-4c5f-b182-3e5b440d599b">
        <source>getBerthingDateForPriority() : Date;
/*
Purpose:			Find the berthing date for the voyage movement AFTER passing through a 
					priority startpoint

Parameters:			

Return Value:		Berthing Date or null if no berth found

Date		Who		Reason
23/08/2012	cnwdap1	Initial creation PAR #30223
07/09/2012	cnwdap1	PAR #30312 At the end point of a high-priority voyage, use arrival date to sort by 
					- this priority sorting only applies to Rio Tinto Voyage Commodity Planning, and the
					end-point harbours (QAL and Yarwun) have only one berth each, so no point in prioritising on berthing date
*/
vars
	voyageData		: HMS_VoyageData;
	movement		: HMS_VoyageMovement;
	lastMovement	: HMS_VoyageMovement;

begin
	voyageData := self.myHMSVoyageData;
	foreach movement in voyageData.allVoyageMovements do
		if lastMovement &lt;&gt; null and lastMovement.getMyBerth.myHarbourRegion.isPriorityStartPoint then
			return movement.arrivalTimeAtToRegion.Date;
		elseif movement.getMyBerth.myHarbourRegion.isHighPriority then		// PAR #30312
			return movement.arrivalTimeAtFromRegion.Date;					// PAR #30312
		elseif not movement.getMyBerth.myWharf.isLogicalWharf then
			return movement.arrivalTimeAtToRegion.Date;
		endif;
		
		lastMovement := movement;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getCandHStats" id="72d9094e-3410-4e5d-b63b-55bfe8c350a0">
        <source>getCandHStats(_aCandHRpt : CMIF_CandHRpt input; _progress : CMS_Progress io);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------


vars
	jobSheet : CM_JobSheet;
	spg : CM_ShipPortGroup;
	lgd : CM_LineGroupDebtor;
	ia : IntegerArray;
	cmifTradeLineGeo: CMIF_CandHTradeLineGeo;
begin

	if _aCandHRpt = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "There is no hatch summary object.");
		return;		
	endif;
	
	if not CM_LineGroupDebtor.hasInstance(self.myDefaultLineGroupDebtor) then
		app.setContinueCMExceptions(true);
		app.raiseCMException2(ERR_INVALID_VALUE, "Voyage Default Line Group Debtor",  self.code &amp; " does not have a Default Line Group Debtor. Use Voyage definition to specify one.", null, null);
		return;
	endif;
	
	_progress.setAction("Setting up Line Group Debtors");

	foreach spg in self.myShippingLine.shipPortGroups do
		foreach lgd in spg.lineGroupDebtors do
			//create ia transient;
			//ia[48] := 0;
			//_ha.putAtKey(lgd.code, ia);
			create cmifTradeLineGeo transient;
			cmifTradeLineGeo.setForCreate(lgd.shipPortGroup.shippingLine,
				lgd.debtor, lgd.shipPortGroup, _aCandHRpt);
		endforeach;
	endforeach;
	
	foreach jobSheet in self.allJobSheets do
		jobSheet.getCandHStats(_aCandHRpt, _progress);
	endforeach;

end;</source>
        <Parameter name="_aCandHRpt" type="CMIF_CandHRpt" usage="input"/>
        <Parameter name="_progress" type="CMS_Progress" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCandHStatsFromSnapShots" id="e68497d2-b8dd-4b90-be59-ce7204e3dc48">
        <source>getCandHStatsFromSnapShots(_aCandHRpt : CMIF_CandHRpt input; _progress : CMS_Progress io);
//----------------------------------------------------------------
//	Created:	21 July 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	jobSheet 			: CM_JobSheet;
	spg 				: CM_ShipPortGroup;
	lgd 				: CM_LineGroupDebtor;
	exchangeTxns		: CM_TITransactionByTypeDateDict;
	txn					: CM_TITransaction;
	cmifTradeLineGeo	: CMIF_CandHTradeLineGeo;
	ss					: CM_SnapShot;
	tiSnapShot			: CM_TISnapShot;
begin

	if _aCandHRpt = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "There is no hatch summary object.");
		return;		
	endif;

	if not CM_LineGroupDebtor.hasInstance(self.myDefaultLineGroupDebtor) then
		app.setContinueCMExceptions(true);
		app.raiseCMException2(ERR_INVALID_VALUE, "Voyage Default Line Group Debtor",  self.code &amp; " does not have a Default Line Group Debtor. Use Voyage definition to specify one.", null, null);
		return;
	endif;
	
	_progress.setAction("Setting up Line Group Debtors");

	foreach spg in self.myShippingLine.shipPortGroups do
		foreach lgd in spg.lineGroupDebtors do
			create cmifTradeLineGeo transient;
			cmifTradeLineGeo.setForCreate(lgd.shipPortGroup.shippingLine,
				lgd.debtor, lgd.shipPortGroup, _aCandHRpt);
		endforeach;
	endforeach;


	create exchangeTxns transient;
	self.getExchangeTxns(exchangeTxns);

	//always run this code - new code
	foreach jobSheet in self.allJobSheets do
		jobSheet.getHatchLashStats(_aCandHRpt);
	endforeach;
	
	foreach txn in exchangeTxns where (not txn.deleted) do
		txn.getExchangeStats(_aCandHRpt);
	endforeach;

	foreach ss in self.allNonTrxSnapShots do
		tiSnapShot := ss.CM_TISnapShot;
		//if tiSnapShot.myUserTISnapShot &lt;&gt; null then
		//	tiSnapShot.myUserTISnapShot.getExchangeStats(_aCandHRpt);	
		//else
			tiSnapShot.getExchangeStats(_aCandHRpt);
		//endif;
	endforeach;

epilog
	delete exchangeTxns;
end;</source>
        <Parameter name="_aCandHRpt" type="CMIF_CandHRpt" usage="input"/>
        <Parameter name="_progress" type="CMS_Progress" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCargoDescription" id="be3d3d31-37cd-41f3-a7ed-dd8b9675e18b">
        <source>getCargoDescription() : String;
/*






FOR THE WEB PORTAL, limited to 30 characters.







Purpose:			// TFS 40747 

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlgab1	Initial creation

*/

vars
	commodity : CM_Commodity;
	cargodesc : String;
	ti : CM_TrackedItem;
	cargotypes : CM_CargoTypeSet;
	cargotype : CM_CargoType;
	cargoForecast : CM_CargoForecast;
	
begin
	/*if self.myHMSVoyageData &lt;&gt; null then
		commodity:= self.myHMSVoyageData.allCommodityDischarge.first;
		if commodity = null then
			commodity:=self.myHMSVoyageData.allCommodityLoad.first;
		endif;
		if commodity &lt;&gt; null then
			cargodesc :=commodity.description;
		endif;	
	endif;*/ // ### TFS 53132 11Apr2022 NAVPW1 - Commented out
	
	// ### TFS 53132 19Apr2022 NAVPW1
	foreach cargoForecast in self.allCargoForecasts do
		if cargoForecast.myCargoType &lt;&gt; null then
			cargodesc := cargoForecast.myCargoType.description;
			
		elseif cargoForecast.myCommodity &lt;&gt; null then
			cargodesc := cargoForecast.myCommodity.description;
			
		endif;
		
	endforeach;
	// ### TFS 53132 19Apr2022 NAVPW1
	
	if cargodesc = "" then
		create cargotypes transient;
		foreach ti in self.allOnshipTIsByCargoTypeId	discreteLock do
			if not cargotypes.includes(ti.myCargoType) then
				cargotypes.add(ti.myCargoType);
			endif;
		endforeach;
		foreach ti in self.allOnsiteTIsByCargoTypeId	discreteLock do
			if not cargotypes.includes(ti.myCargoType) then
				cargotypes.add(ti.myCargoType);
			endif;
		endforeach;
		foreach ti in self.allNotifiedTIsByCargoTypeId	discreteLock do
			if not cargotypes.includes(ti.myCargoType) then
				cargotypes.add(ti.myCargoType);
			endif;
		endforeach;
		
		// TFS 41026
		foreach ti in self.allOffsiteTIsByIdCargoType	discreteLock do
			if not cargotypes.includes(ti.myCargoType) then
				cargotypes.add(ti.myCargoType);
			endif;
		endforeach;
		
		foreach cargotype in cargotypes 	discreteLock do
			if cargodesc = "" then
				cargodesc := cargotype.description;
			else
				cargodesc := cargodesc &amp; ", " &amp; cargotype.description;
			endif;
		endforeach;
	
	
	endif;

	if cargodesc.length &gt; 30 then
		cargodesc := cargodesc[1:30];
	endif;
	return cargodesc;
epilog
	delete cargotypes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoDischargeTime" id="071ff5f6-a4f0-4c57-8d17-a5c05d2b86a1">
        <source>getCargoDischargeTime():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		12 March 2007 by cnwdad1
//
// Purpose:		Returns the timestamp when the Voyage's cargo is deemed to have been
//				discharged.
//
// Parameters:	None
//
// Returns:		The timestamp when the cargo has been discharged, or the departure
//				timestamp, whichever is the earliest.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	globalVoyObj	: CM_VoyageGlobal;
	vesselObj		: CM_Vessel;
	arrivalTime		: TimeStamp;
	dischargeTime	: TimeStamp;
	timeDeparting	: TimeStamp;
	dischargeHours	: Decimal[12,2];		// The number of hours it takes to discharge the Vessel.
	dischargeMins	: Integer;
	
begin
	globalVoyObj	:=	self.getGlobalVoyage();
	
	if globalVoyObj = null then
		return null;
	else
		vesselObj	:=	globalVoyObj.getMyVessel();
	endif;
	
	if vesselObj = null then
		if self.myTerminal = null then
			return null;
		else
			dischargeHours	:=	self.myTerminal.getConfig(GrossDischargeTime).Decimal;
		endif;
	else
		dischargeHours	:=	vesselObj.getGrossDischargeTime(self.myTerminal);
	endif;
	
	arrivalTime		:=	self.arrivedDT;
	timeDeparting	:=	self.departedDT;
	dischargeMins	:=	(dischargeHours * 60) div 2;
	dischargeTime	:=	arrivalTime.cnEcAddMinutes(dischargeMins);
	
	if dischargeTime &gt; timeDeparting then
		return timeDeparting;
	else
		return dischargeTime;
	endif;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCargoDischargeTimeLocalTZ" id="93e15460-c96d-43cc-a99e-9b4ab142bee3">
        <source>getCargoDischargeTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2016	cnwns1	Initial creation
// 01 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	globalVoyObj	: CM_VoyageGlobal;
	vesselObj		: CM_Vessel;
	arrivalTime		: TimeStamp;
	dischargeTime	: TimeStamp;
	timeDeparting	: TimeStamp;
	dischargeHours	: Decimal[12,2];		// The number of hours it takes to discharge the Vessel.
	dischargeMins	: Integer;
	
begin
	globalVoyObj	:=	self.getGlobalVoyage();
	
	if globalVoyObj = null then
		return null;
	else
		vesselObj	:=	globalVoyObj.getMyVessel();
	endif;
	
	if vesselObj = null then
		if self.myTerminal = null then
			return null;
		else
			dischargeHours	:=	self.myTerminal.getConfig(GrossDischargeTime).Decimal;
		endif;
	else
		dischargeHours	:=	vesselObj.getGrossDischargeTime(self.myTerminal);
	endif;
	
	arrivalTime		:=	self.arrivedDT;
	timeDeparting	:=	self.departedDT;
	dischargeMins	:=	(dischargeHours * 60) div 2;
	dischargeTime	:=	arrivalTime.cnEcAddMinutes(dischargeMins);
	
	if dischargeTime &gt; timeDeparting then
		return self.systemToLocalTime(timeDeparting);
	else
		return self.systemToLocalTime(dischargeTime);
	endif;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCargoForecastStr" id="2ae5b816-8c8e-4c19-97d3-c9aaf1e8cb08">
