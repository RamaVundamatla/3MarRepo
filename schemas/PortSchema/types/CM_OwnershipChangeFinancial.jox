    <JadeMethod name="auditId" id="00472667-e439-4977-96c3-f4fd2ee0ab9e">
        <source>auditId(): String;
/*
Purpose:			

Date		Who		Reason
21 July 2023	navab1	 // ### TFS CR 58246 TASK 58249 21JUL2023 NAVAB1
*/

vars
	audittext : String;
begin
	if self.myOwnershipChange &lt;&gt; null then
		audittext := self.myOwnershipChange.auditId();
	endif;
	
	if self.myInvoiceLine &lt;&gt; null then
		audittext := audittext &amp; "/" &amp; self.myInvoiceLine.sequenceNum.String;
	endif;
	
	return audittext;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
