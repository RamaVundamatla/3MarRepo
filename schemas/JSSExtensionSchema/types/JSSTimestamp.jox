    <JadeMethod name="create" id="afd029e3-87c5-410f-9787-c71c3218319f">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		19 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setTimestampClient();
	self.setTimestampServer();
end;</source>
    </JadeMethod>
    <JadeMethod name="getGMTBiasClient" id="f620ea27-36bf-4968-9a76-ef508572eea4">
        <executionLocation>client</executionLocation>
        <source>getGMTBiasClient():Integer clientExecution;
// --------------------------------------------------------------------------------
// Created:		17 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	gmtBias			: Integer;

begin
	self.timestampClient.cnGetGMTBias(gmtBias);
epilog
	return gmtBias;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGMTBiasServer" id="2a301fe7-5358-4489-8549-2a8c2f4f677f">
