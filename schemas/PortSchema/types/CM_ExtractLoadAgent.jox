        <source>handleVesselLoadException(_ex : Exception; _hadException : Boolean io; _exCode, _exMsg : String output) : Integer protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/04/2017	cnwdap1		Initial creation TFS 3930 LNX Vessel Extract and Load
//
vars

begin
	_exCode := _ex.errorCode.String;
	_exMsg := _ex.extendedErrorText;
	_hadException := true;
	return Ex_Resume_Next;
epilog

end;</source>
