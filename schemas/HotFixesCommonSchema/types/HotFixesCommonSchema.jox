    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myRootHotFix" id="40f89002-7974-4e42-9d1a-a6c932ba15f4">
        <embedded/>
