<Class name="CMIF_EDIReleaseRequest" id="69eeba18-040f-4da7-9ab6-fd35343dd493">
    <superclass name="CMIF_EDI"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <ImplicitInverseRef name="allEDITIs" id="5014ebfa-1cab-40f1-9a99-71dfc81ec724">
        <memberTypeInverse/>
        <type name="CM_EDITISet"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allReserveDetailDel" id="94c4b4bb-6915-4349-88d0-0abbebb3116c">
        <memberTypeInverse/>
        <type name="ObjectSet"/>
        <text>Used my EDIDataRequestMultiLine which has one ediTIRecord per ReleaseRequest and one for each ReserverDetails</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myBulkRelease" id="c8cfc24e-4c11-4866-b29e-adefddcdcb3e">
        <embedded/>
        <type name="CM_BulkRelease"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myReserveDetailDel" id="b45ca095-36b6-42f8-ad6a-64205df515da">
        <embedded/>
        <type name="CM_ReserveDetail"/>
        <text>Used my EDIDataReleaseRequest which has one ediTIRecord per ReleaseRequest/ReserverDetails</text>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="f163c680-5956-4662-b862-d961b199b211">
        <updating/>
        <source>delete() updating;
//
// CCMS POL 2122 Par 28696 
//
// 06/09/2013	cnwcs5	par 32321 - only delete transient releases
//04 Mar 2015	cnwrs1	Par35791	- need to check the release is not null
vars
	release			:CM_BulkRelease;
	gotException	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, release, gotException);
	
	release := self.myBulkRelease;
	
	if release &lt;&gt; null and
	   release.isTransient then
		delete release;
	endif;
end;
</source>
    </JadeMethod>
</Class>
