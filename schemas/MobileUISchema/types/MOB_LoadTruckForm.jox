    <JadeMethod name="handleOK" id="8913f0c9-c88d-44d9-a3b1-65360e653e84">
        <updating/>
        <source>handleOK()updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars	
	truckID 	: String;
	truck 		: CM_Vehicle;
	bulkReleaseSet 	: CM_BulkReleaseSet;
	form 		: MOB_CEScanForLoadRequestForm;
	parentTA,
	transferTA	: CM_TerminalArea;
	req : CM_Request;
begin
	truck := null;
	create bulkReleaseSet transient;
	truckID := self.txt_TextBox1.text;
	
	modalResult := ModalResultOK;
	myRoadJob := self.myMobileDataAgent.findOrCreateRoadJob(truckID);
	if myRoadJob = null then
		modalResult := ModalResultError;
		return;
	else
		self.myMobileDataAgent.setupRoadJob(myRoadJob, app.myMobileGUIAgent.strDevice);
		foreach req in myRoadJob.allRequests do
			if req.myOriginatingBulkRelease &lt;&gt; null and (not bulkReleaseSet.includes(req.myOriginatingBulkRelease))then
				bulkReleaseSet.add(req.myOriginatingBulkRelease.CM_BulkRelease);
			endif;
		endforeach;
	endif;
	create form transient;
	form.setMyRoadJob(myRoadJob);
	form.setAllReleases(bulkReleaseSet);
	form.show();
epilog
	delete bulkReleaseSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="12590bf4-506d-4dc7-8661-2a099043252c">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.lbl_Label1.caption := app.getErrorString(Enter_truck);
	self.btn_ButtonLeft.caption := app.getErrorString(Start_scan);
	self.btn_ButtonLeft.default  := true;
	self.btn_ButtonRight.caption := app.getErrorString(Cancel);
	self.btn_ButtonRight.cancel := true;
	self.caption:= '';
	self.lbl_Title.caption :=  app.getErrorString(Load_truck);
	self.txt_TextBox1.case := txt_TextBox1.Case_Upper;
	modalResult := ModalResultCancel;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4219d3c4-5850-4ea8-89b3-caaad51b1774">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018498, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
