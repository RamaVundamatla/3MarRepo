    <JadeMethod name="populate" id="854531cc-eb7b-4e1e-a4b2-71b9f9a834a9">
        <source>populate(listbox: ListBox; level: Integer; at : Integer);
// 35386
vars
	tmc : CMIF_TranMapController;
	pic : Picture;
	str : String;
	int : Integer;
	index	: Integer;
	count	: Integer;
begin
	count := at;
	foreach tmc in self.allGroupMembers do
		int := 1;
		if tmc.itemName &lt;&gt; null then
			str := tmc.itemName.scanUntil(Tab, int);
		endif;
		str := str.trimRight;
	
		listbox.addItemAt(str, count);
		index := listbox.newIndex;
		listbox.itemLevel[index] := level+1;
		listbox.itemObject[index] := tmc;
		listbox.itemData[index] := tmc.getType();
		pic := getPicture(listbox.form.INV_TransactionMap);
		if pic &lt;&gt; null then
			listbox.itemPicture[index] := pic.picture;
		endif;
		count := count + 1;
	endforeach;

end;</source>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="at" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateAll" id="8e501e33-a778-4c64-a7f7-c75bf27b680e">
        <source>populateAll(listbox: ListBox; level: Integer; at: Integer);
// recursively load all children
vars
	tmc : CMIF_TranMapController;
	i :Integer;
begin

	i := at;
	foreach tmc in self.allGroupMembers do
		i := i + 1;
		tmc.loadListaAt(listbox, level + 1, i);
	endforeach;

end;</source>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="at" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="fb2de820-c188-43d7-8b56-a8c162c83b68">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin
	myTMCController.myCurrentMapTMVoyage := null;
	myTMCController.myCurrentMapTM := null;
	myTMCController.myCurrentMapServiceBroker := null;

	myTMCController.myCurrentMapDebtor := null;
	myTMCController.myCurrentMapCommodity := null;
	myTMCController.myCurrentMapContents := null;
	myTMCController.myCurrentMapIMEX := null;
	myTMCController.myCurrentMapTIService := null;
	myTMCController.myCurrentMapTM := null;
	myTMCController.myCurrentMapProduct:= null;
	myTMCController.myCurrentMapProdGrp:= null;
	myTMCController.myCurrentMapQuantity := null;
	myTMCController.myCurrentMapQuantityRange := null;
	
	myTMCController.isContractIn := false;
	myTMCController.isContractOut := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="833245cd-0c54-4a97-94d0-de29279f6414">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------
vars
begin
	form.myCurrentMapTMVoyage := null;
	form.myCurrentMapTM := null;
	form.myCurrentMapTMEvent := null;
	form.myCurrentMapTMWorkOrder := null; // TFS 39236
	form.myCurrentMapTMSS := null;
	form.myCurrentMapServiceBroker := null;
	form.myCurrentMapTMCargoAllocation := null; // PAR 35833
	form.myCurrentMapTMInventory := null;  // ### TFS 51219 25MAY2021 NAVAB1

	form.myCurrentMapDebtor := null;
	form.myCurrentMapCommodity := null;
	form.myCurrentMapContents := null;
	form.myCurrentMapIMEX := null;
	form.myCurrentMapTIService := null;
	form.myCurrentMapTM := null;
	form.myCurrentMapProduct:= null;
	form.myCurrentMapProdGrp:= null;
	form.myCurrentMapQuantity := null;
	form.myCurrentMapQuantityRange := null;
	
	form.myTMCCargoType := null;
	form.myTMCCommodity := null;
	form.myTMCContent := null;
	form.myTMCContractIN := null;
	form.myTMCContractOUT := null;
	form.myTMCDebtor := null;
	form.myTMCIMEX := null;
	form.myTMCInvoice := null;
	form.myTMCResource := null;
	form.myTMCSB := null;
	form.myTMCProduct := null;
	form.myTMCProdGrp := null;
	form.myTMCTrans := null;
	form.myTMCQuantity := null;
	form.myTMCQuantityRange := null;
	
	form.myTMCEG := null; // 15/05/2023	navkc1	CR 57927 Task 54268
	form.myTMCWO := null; // 15/05/2023	navkc1	CR 57927 Task 54268

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="testGetAllMembers" id="d1888bed-26e3-4857-b6c6-b7aae86b722f">
        <source>testGetAllMembers( _objArray : ObjectArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2019	jlgndl1	Initial creation	TFS 48039

*/

vars

	mem : CMIF_TranMapController;

begin

	_objArray.addExclusive( self );
	
	foreach mem in self.allGroupMembers do
		if mem.isKindOf(CMIF_TMCGroup) then
			mem.CMIF_TMCGroup.testGetAllMembers( _objArray );
		else
			_objArray.addExclusive( mem );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
</Class>
