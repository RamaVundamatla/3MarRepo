    <JadeMethod name="addBrokenLink" id="20c4740b-5548-4d8f-8ba4-3507a135b476">
        <source>addBrokenLink(_objectKey: String; _propertyName: String; _referencedKey: String; _errorMessage: String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
	brokenLink: CM_BrokenLink;
begin
    create brokenLink transient;
    brokenLink.objectKey := _objectKey;
    brokenLink.propertyName := _propertyName;
    brokenLink.referencedKey := _referencedKey;
    brokenLink.errorMessage := _errorMessage;
    brokenLink.className := self.myExportImportClass.className;
    
    self.brokenLinkRecords.add(brokenLink);
    
    app.writeLog("BROKEN LINK: " &amp; _objectKey &amp; " -&gt; " &amp; _propertyName &amp; " = " &amp; _referencedKey,LogINFO);
end;</source>
        <access>protected</access>
        <Parameter name="_objectKey" type="String"/>
        <Parameter name="_propertyName" type="String"/>
        <Parameter name="_referencedKey" type="String"/>
        <Parameter name="_errorMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="addFailedRecord" id="2baf5d8b-c1e4-4318-acd5-0545d4c4289a">
        <source>addFailedRecord(_objectKey: String; _rowNumber: Integer; _errorMessage: String) protected;
/*

Purpose:			
	* Records a failed import record with error details
	 * 
	 * @param _objectKey Business key of failed object
	 * @param _rowNumber Row number in import file
	 * @param _errorMessage Error description
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    failedRecord: CM_FailedRecord;
begin
    create failedRecord transient;
    failedRecord.objectKey := _objectKey;
    failedRecord.rowNumber := _rowNumber;
    failedRecord.errorMessage := _errorMessage;
    failedRecord.className := self.myExportImportClass.className;
    
    self.failedRecords.add(failedRecord);
end;</source>
        <access>protected</access>
        <Parameter name="_objectKey" type="String"/>
        <Parameter name="_rowNumber" type="Integer"/>
        <Parameter name="_errorMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="addFailedRecordWithPassportErrors" id="6408dca8-4c3a-4fbf-8c7e-7b3171917642">
        <source>addFailedRecordWithPassportErrors(_objectKey: String; _rowNumber: Integer; _methodName: String) protected;
/*

Purpose:			
	* Records a failed import with all passport errors and warnings
	 * 
	 * @param _objectKey Business key of failed object
	 * @param _rowNumber Row number in import file
	 * @param _methodName Name of load method that failed
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/
vars
    failedRecord: CM_FailedRecord;
    error: CM_Error;
    errorText: String;
begin
    errorText := "Load method '" &amp; _methodName &amp; "' failed. ";
    
    // Collect all errors
    if app.myPassport.allErrors.size &gt; 0 then
        errorText := errorText &amp; "Errors: ";
        foreach error in app.myPassport.allErrors do
            errorText := errorText &amp; error.text &amp; "; ";
        endforeach;
    endif;
    
    // Collect all warnings
    if app.myPassport.allWarnings.size &gt; 0 then
        errorText := errorText &amp; "Warnings: ";
        foreach error in app.myPassport.allWarnings do
            errorText := errorText &amp; error.text &amp; "; ";
        endforeach;
    endif;
    
    create failedRecord transient;
    failedRecord.objectKey := _objectKey;
    failedRecord.rowNumber := _rowNumber;
    failedRecord.errorMessage := errorText;
    failedRecord.className := self.myExportImportClass.className;
    
    self.failedRecords.add(failedRecord);
    
    app.writeLog("FAILED: " &amp; _objectKey &amp; " - " &amp; errorText,LogERROR);
end;</source>
        <access>protected</access>
        <Parameter name="_objectKey" type="String"/>
        <Parameter name="_rowNumber" type="Integer"/>
        <Parameter name="_methodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="buildJsonResponse" id="df1e4eb5-71eb-4648-8751-4edf727823dd">
        <source>buildJsonResponse(): String protected;
/*

Purpose:			
	* Builds final JSON response with import statistics
 * Constructs JSON from failedRecords and brokenLinkRecords collections
 * 
 * @return JSON string with complete import results
 * 
 * Response format:
 * {
 *   "recordsProcessed": 150,
 *   "successCount": 145,
 *   "failedRecords": [
 *     {
 *       "objectKey": "STEEL",
 *       "rowNumber": 12,
 *       "className": "CM_Commodity",
 *       "errorMessage": "Commodity code already exists"
 *     }
 *   ],
 *   "brokenLinkRecords": [
 *     {
 *       "objectKey": "NEWCOM",
 *       "rowNumber": 15,
 *       "propertyName": "myCommodityGroup",
 *       "referencedKey": "INVALID_GRP",
 *       "errorMessage": "Referenced Commodity Group 'INVALID_GRP' not found"
 *     }
 *   ]
 * }
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    jsonResult: String;
    failedRecord: CM_FailedRecord;
    brokenLink: CM_BrokenLink;
    separator: String;
begin
    // Start JSON object
    jsonResult := '{';
    
    // Add summary statistics
    jsonResult := jsonResult &amp; '"recordsProcessed":' &amp; self.recordsProcessed.String &amp; ',';
    jsonResult := jsonResult &amp; '"successCount":' &amp; self.successCount.String &amp; ',';
    
    // Build failedRecords array
    jsonResult := jsonResult &amp; '"failedRecords":[';
    
    separator := '';
    
    if self.failedRecords &lt;&gt; null then
        foreach failedRecord in self.failedRecords do
            jsonResult := jsonResult &amp; separator;
            jsonResult := jsonResult &amp; '{';
            
            // Add objectKey
            jsonResult := jsonResult &amp; '"objectKey":"' &amp; 
                self.escapeJsonString(failedRecord.objectKey) &amp; '",';
            
            // Add rowNumber
            jsonResult := jsonResult &amp; '"rowNumber":' &amp; failedRecord.rowNumber.String &amp; ',';
            
            // Add className
            jsonResult := jsonResult &amp; '"className":"' &amp; 
                self.escapeJsonString(failedRecord.className) &amp; '",';
            
            // Add errorMessage
            jsonResult := jsonResult &amp; '"errorMessage":"' &amp; 
                self.escapeJsonString(failedRecord.errorMessage) &amp; '"';
            
            jsonResult := jsonResult &amp; '}';
            
            separator := ',';
        endforeach;
    endif;
    
    jsonResult := jsonResult &amp; '],';
    
    // Build brokenLinkRecords array
    jsonResult := jsonResult &amp; '"brokenLinkRecords":[';
    
    separator := '';
    
    if self.brokenLinkRecords &lt;&gt; null then
        foreach brokenLink in self.brokenLinkRecords do
            jsonResult := jsonResult &amp; separator;
            jsonResult := jsonResult &amp; '{';
            
            // Add objectKey
            jsonResult := jsonResult &amp; '"objectKey":"' &amp; 
                self.escapeJsonString(brokenLink.objectKey) &amp; '",';
            
            // Add rowNumber (if available)
            if brokenLink.rowNumber &gt; 0 then
                jsonResult := jsonResult &amp; '"rowNumber":' &amp; brokenLink.rowNumber.String &amp; ',';
            endif;
            
            // Add propertyName
            jsonResult := jsonResult &amp; '"propertyName":"' &amp; 
                self.escapeJsonString(brokenLink.propertyName) &amp; '",';
            
            // Add referencedKey
            jsonResult := jsonResult &amp; '"referencedKey":"' &amp; 
                self.escapeJsonString(brokenLink.referencedKey) &amp; '",';
            
            // Add errorMessage
            jsonResult := jsonResult &amp; '"errorMessage":"' &amp; 
                self.escapeJsonString(brokenLink.errorMessage) &amp; '"';
            
            jsonResult := jsonResult &amp; '}';
            
            separator := ',';
        endforeach;
    endif;
    
    jsonResult := jsonResult &amp; ']';
    
    // Close JSON object
    jsonResult := jsonResult &amp; '}';
    
    return jsonResult;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findObjectByKey" id="1f1e0cb7-627d-45f8-a8fd-afda3137ce9c">
        <updating/>
        <source>findObjectByKey(_exportClass: CM_ExportImportClass; _key: String): Object protected, updating;
/*

Purpose:			
	* Finds an existing persistent object by its business key
	 * 
	 * @param _exportClass Class configuration containing key metadata
	 * @param _key Business key value to search for
	 * @return Found object or null if not found
	 * 
	 * Uses CM_DataLookupAgent for efficient key-based lookup
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    obj: Object;
    keyProp: Property;
    expProp: CM_ExportImportProperty;
    expClass: CM_ExportImportClass;
begin
    // Validate parameters
    if _exportClass = null or _key = null or _key = "" then
        return null;
    endif;
    
    if _exportClass.myClass = null then
        app.writeLog("WARNING: No class found for " &amp; _exportClass.className,LogWARN);
        return null;
    endif;
    
    if _exportClass.myKeyName = null or _exportClass.myKeyName = "" then
        app.writeLog("WARNING: No key name defined for " &amp; _exportClass.className,LogWARN);
        return null;
    endif;
    
    // Get key property metadata
    keyProp := _exportClass.myClass.getPropertyInHTree(_exportClass.myKeyName);
    expProp := _exportClass.allProperties[keyProp.name];
    
    if keyProp = null then
        app.writeLog("WARNING: Key property not found: " &amp; _exportClass.myKeyName,LogWARN);
        return null;
    endif;
    
    // If key property is a reference, use referenced class for lookup
    expClass := _exportClass;
    if expProp.isReference then
        expClass := app.myRoot.allExportImportClasses[keyProp.type.name];
    endif;
    
    // Use lookup agent to resolve reference

    obj := self.lookupAgent.resolveReference(
        _exportClass.className,
        _exportClass.myKeyName,
        _key
    );
    
    return obj;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exportClass" type="CM_ExportImportClass"/>
        <Parameter name="_key" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="findOrCreateObject" id="bc385d86-1669-41bb-b624-ad834de53b75">
        <updating/>
        <source>findOrCreateObject(_exportClass: CM_ExportImportClass; _key: String; _isNew: Boolean io): Object updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    keyProperty: Property;
    targetClass: Class;
begin
    _isNew := false;
    
    if _exportClass = null  then
        return null;
    endif;
    
    targetClass := _exportClass.myClass;
    if targetClass = null then
        app.writeLog("ERROR: Class not found for " &amp; _exportClass.className,LogERROR);
        return null;
    endif;
    
    keyProperty := targetClass.getProperty(_exportClass.myKeyName);
    if keyProperty = null then
        app.writeLog("ERROR: Key property " &amp; _exportClass.myKeyName &amp; " not found in " &amp; _exportClass.className,LogERROR);
        return null;
    endif;
    
    // Look up existing object in database
    self.proxyObject := self.findObjectByKey(_exportClass, _key);
    
    if  self.proxyObject &lt;&gt; null then
        // Existing object found
        _isNew := false;
        return  self.proxyObject;
    endif;
    
    // Object doesn't exist - create new transient object
  
        create  self.proxyObject as targetClass transient;
        
        // Set the key property
         self.proxyObject.setPropertyValue(_exportClass.myKeyName, _key);
        
        _isNew := true;
        
        app.writeLog("Created new transient " &amp; _exportClass.className &amp; " with key: " &amp; _key,LogINFO);
        
        return  self.proxyObject;
   
end;</source>
        <Parameter name="_exportClass" type="CM_ExportImportClass"/>
        <Parameter name="_key" type="String"/>
        <Parameter name="_isNew" type="Boolean" usage="io"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getKeyTagName" id="e6d4ab00-c061-4910-95d5-e10f2c19c960">
        <source>getKeyTagName(_exportClass: CM_ExportImportClass): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    keyProp: CM_ExportImportProperty;
begin
  
	if _exportClass.myKeyName.length &gt; 0 then
		keyProp := _exportClass.allProperties.getAtKey(_exportClass.myKeyName);
		if keyProp &lt;&gt; null then
			return self.removeSpaces(keyProp.displayName);
		endif;
	endif;
   
	return "";
end;</source>
        <access>protected</access>
        <Parameter name="_exportClass" type="CM_ExportImportClass"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importAttribute" id="6d6c817e-8769-4541-ad6c-f685bf3f075c">
        <updating/>
        <source>importAttribute(_obj: Object io; _property: CM_ExportImportProperty; _objectBlock: String) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    tagName: String;
    value: String;
begin
    if _property.myProperty = null then
        return;
    endif;
    
    tagName := self.removeSpaces(_property.displayName);
    value := _objectBlock.cnEcGetTagValueOfName(tagName);
    
    if value = null then
        return;
    endif;

     _obj.setPropertyValue(_property.myProperty.name, value);
   
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object" usage="io"/>
        <Parameter name="_property" type="CM_ExportImportProperty"/>
        <Parameter name="_objectBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importAttributes" id="e741269b-6905-4cfc-bc81-40edf2d602e5">
        <updating/>
        <source>importAttributes(_objectBlock: String) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    exportProp: CM_ExportImportProperty;
    tagName: String;
    tagValue: String;
    propName: String;
begin
    foreach exportProp in self.attributes do
        // Skip if property metadata is missing
        if exportProp.myProperty = null then
            continue;
        endif;
        
        propName := exportProp.myProperty.name;
        
        // Build XML tag name by removing spaces from display name
        tagName := self.removeSpaces(exportProp.displayName);
        
        // Extract value from XML
        tagValue := self.extractXmlTag(_objectBlock, tagName);
        
        if tagValue &lt;&gt; null and tagValue &lt;&gt; "" then
            // Set the attribute value on proxy object
            self.setAttributeValue(self.proxyObject, exportProp.myProperty, tagValue);
        endif;
    endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_objectBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importClassInstances" id="dddf36fb-4c51-407d-a73c-2ce3adcbbd9c">
        <updating/>
        <source>importClassInstances(_objectBlock: String; _objectKey: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/
vars

begin
    // Create lookup agent for resolving references
    create self.lookupAgent transient;
    
    // Import simple attributes
    self.importAttributes(_objectBlock);
    
    // Import references as inline keys
    self.importReferenceKeys(_objectBlock);
    
    // Import references as expanded nested objects
    self.importReferencesExpanded(_objectBlock, _objectKey);
    
    // Import collections (both key-based and expanded)
    self.importCollections(_objectBlock, _objectKey);
    
epilog
    delete self.lookupAgent;
   
end;</source>
        <Parameter name="_objectBlock" type="String"/>
        <Parameter name="_objectKey" type="String"/>
    </JadeMethod>
    <JadeMethod name="importClassSheet" id="a56e9e7b-6216-479d-b6c3-041b1be34acd">
        <updating/>
        <source>importClassSheet(_exportClass: CM_ExportImportClass; _sheetBlock: String) updating, protected;
/*

Purpose:			
	* Imports all objects from a class sheet XML block
	 * 
	 * @param _exportClass Export configuration for the class being imported
	 * @param _sheetBlock XML block containing all objects (e.g., &lt;Commoditys&gt;...&lt;/Commoditys&gt;)
	 * 
	 * Process:
	 * 1. Categorizes properties for import
	 * 2. Extracts individual object blocks
	 * 3. Imports each object sequentially
	 * 4. Logs progress every 100 records
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    objectBlock: String;
    startPos: Integer;
    rowNumber: Integer;
    objectTagName: String;
begin
    // Categorize properties into attributes/references/collections
    self.categorizeClassProperties();
    
    // Get object tag name (e.g., "Commodity")
    objectTagName := self.removeSpaces(_exportClass.displayName);
    
    // Initialize iteration variables
    startPos := 1;
    rowNumber := 0;
    
    // Iterate through all object blocks in the sheet
    while startPos &gt; 0 and startPos &lt; _sheetBlock.length do
        // Extract next object block
        objectBlock := _sheetBlock.cnEcGetNextTagValueOfName(objectTagName, startPos);
        
        // Check if extraction completed (startPos = 0 means no more blocks found)
        if startPos = 0 and objectBlock = null then
            break;
        endif;
        
        rowNumber := rowNumber + 1;
        
        // Import the object if block is valid
        if objectBlock &lt;&gt; "" and objectBlock &lt;&gt; null then
            self.importObject(_exportClass, objectBlock, rowNumber);
            
            // Log progress every 100 records
            if rowNumber mod 100 = 0 then
                app.writeLog("  Imported " &amp; rowNumber.String &amp; " objects...",LogINFO);
            endif;
        endif;
    endwhile;
    
    app.writeLog("  Completed: " &amp; rowNumber.String &amp; " objects processed",LogINFO);
end;</source>
        <access>protected</access>
        <Parameter name="_exportClass" type="CM_ExportImportClass"/>
        <Parameter name="_sheetBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importCollectionExpanded" id="d07cbf2f-ce25-4fea-a041-956676ae77c1">
        <updating/>
        <source>importCollectionExpanded(_property: CM_ExportImportProperty; _objectBlock: String; _objectKey: String) updating, protected;
/*

Purpose:			
	* Imports collection members as fully expanded objects
 * 
 * @param _property Collection property configuration
 * @param _objectBlock XML block containing parent object and collections
 * @param _objectKey Parent object's business key (for error reporting)
 * 
 * Example XML:
 * &lt;TerminalAreaViewPositions&gt;
 *   &lt;TerminalAreaViewPosition&gt;
 *     &lt;SatelliteViewDefinition_Key&gt;DDDD&lt;/SatelliteViewDefinition_Key&gt;
 *     &lt;Height&gt;148&lt;/Height&gt;
 *     &lt;Width&gt;264&lt;/Width&gt;
 *     &lt;TerminalArea&gt;TESTD&lt;/TerminalArea&gt;
 *   &lt;/TerminalAreaViewPosition&gt;
 * &lt;/TerminalAreaViewPositions&gt;
 * 
 * Process:
 * 1. Gets parent object's collection property
 * 2. For each member block:
 *    a. Extracts member key (if exists)
 *    b. Finds or creates member object
 *    c. Uses sub-agent to import member's full content
 *    d. Establishes parent-child relationship
 *    e. Adds to collection
Parameters:			
	
Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    memberBlock: String;
    memberClassName: String;
    memberTagName: String;
    memberKey: String;
    memberObj: Object;
    coll: Collection;
    startPos: Integer;
    rowNumber: Integer;
    subAgent: CM_DataImportAgent;
    memberExportClass: CM_ExportImportClass;
    memKeyProp: CM_ExportImportProperty;
    ownerKeyProp: CM_ExportImportProperty;
    ownerKeyTag: String;
    collectionBlock: String;
begin
    // Get collection from parent object
    coll := self.proxyObject.getPropertyValue(_property.propertyName).Collection;
    if coll = null then
        app.writeLog("WARNING: Collection property " &amp; _property.propertyName &amp; " is null",LogWARN);
        return;
    endif;
    
    // Get member class configuration
    memberClassName := coll.cnEcGetMemberType.name;
    memberExportClass := app.myRoot.allExportImportClasses[memberClassName];
    
    if memberExportClass = null then
        app.writeLog("WARNING: Member class " &amp; memberClassName &amp; " not configured for import",LogWARN);
        return;
    endif;
    
    memberTagName := self.removeSpaces(memberExportClass.displayName);
    memKeyProp := memberExportClass.allProperties[memberExportClass.myKeyName];
    
    // Get owner key property for establishing relationship
    ownerKeyTag := self.getKeyTagName(self.myExportImportClass);
    ownerKeyProp := self.getExportImportProperty(memberExportClass, ownerKeyTag);
    
    // Extract collection block
    collectionBlock := self.extractXmlBlock(_objectBlock, self.removeSpaces(_property.displayName));
    if collectionBlock = null or collectionBlock = "" then
        return;
    endif;
    
    // Create sub-agent for importing member objects
    create subAgent transient;
    subAgent.setExportImportClass(memberExportClass);
    subAgent.categorizeClassProperties();
    subAgent.parentObject := self.proxyObject;
    
    // Iterate through member blocks
    startPos := 1;
    rowNumber := 0;
    
    while startPos &gt; 0 and startPos &lt; collectionBlock.length do
        // Extract next member block
        memberBlock := collectionBlock.cnEcGetNextTagValueOfName(memberTagName, startPos);
        
        if startPos = 0 then
            break;
        endif;
        
        rowNumber := rowNumber + 1;
        
        if memberBlock = null or memberBlock = "" then
            break;
        endif;
        
        // Extract member key (if it exists)
        memberKey := "";
        if memKeyProp &lt;&gt; null then
            memberKey := self.extractXmlTag(memberBlock, self.getKeyTagName(memberExportClass));
        endif;
        
        // Find or create member object
        if memberKey = null or memberKey = "" then
            // No key specified - create new transient object
            create memberObj as memberExportClass.myClass transient;
        else
            // Look up existing object by key
            memberObj := self.findObjectByKey(memberExportClass, memberKey);
            
            // If not found, create new transient object
            if memberObj = null then
                create memberObj as memberExportClass.myClass transient;
            endif;
        endif;
        
        if memberObj &lt;&gt; null then
            // Import member's content using sub-agent
            subAgent.proxyObject := memberObj;
            subAgent.importClassInstances(memberBlock, memberKey);
            
            // Establish parent-child relationship
            if _property.myProperty.isA(ExplicitInverseRef) and 
               _property.myProperty.ExplicitInverseRef.updateMode &lt;&gt; ExplicitInverseRef.UpdateMode_Automatic then
                // Manual inverse reference - add to collection directly
                if not coll.includes(memberObj) then
                    coll.add(memberObj);
                endif;
            else
                // Automatic inverse reference - set parent on child
                if ownerKeyProp &lt;&gt; null then
                    memberObj.setPropertyValue(ownerKeyProp.propertyName, self.proxyObject);
                endif;
            endif;
        else
            self.addBrokenLink(_objectKey, _property.displayName, memberKey,
                "Failed to create collection member " &amp; memberExportClass.displayName);
        endif;
    endwhile;
    
epilog
    delete subAgent;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="CM_ExportImportProperty"/>
        <Parameter name="_objectBlock" type="String"/>
        <Parameter name="_objectKey" type="String"/>
    </JadeMethod>
    <JadeMethod name="importCollectionKeys" id="f6982c90-84c8-4eb7-8bc9-efb34ec1fe84">
        <updating/>
        <source>importCollectionKeys(_property: CM_ExportImportProperty; _collectionBlock: String; _objectKey: String) updating, protected;
/*

Purpose:			
	* Imports collection members using key references
	 * 
	 * @param _property Collection property configuration
	 * @param _collectionBlock XML block containing collection mappings
	 * @param _objectKey Parent object's business key (for error reporting)
	 * 
	 * Example XML:
	 * &lt;CargoTypes&gt;
	 *   &lt;CargoType&gt;
	 *     &lt;CommodityCode_Key&gt;STEEL&lt;/CommodityCode_Key&gt;
	 *     &lt;Description&gt;ISO Container&lt;/Description&gt;
	 *   &lt;/CargoType&gt;
	 * &lt;/CargoTypes&gt;
	 * 
	 * Process:
	 * 1. Gets parent object's collection property
	 * 2. Extracts member key from each mapping block
	 * 3. Looks up member object by key
	 * 4. Adds to collection if found
	 * 5. Records broken link if not found
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    mappingBlock: String;
    memberKey: String;
    memberObj: Object;
    coll: Collection;
    startPos: Integer;
    rowNumber: Integer;
    memExportClass: CM_ExportImportClass;
    memKeyProp: CM_ExportImportProperty;
    memberClassName: String;
    memberTagName: String;
begin
    // Get collection from parent object
    coll := self.proxyObject.getPropertyValue(_property.propertyName).Collection;
	
    if coll = null then
        app.writeLog("WARNING: Collection property " &amp; _property.propertyName &amp; " is null",LogWARN);
        return;
    endif;
    
    // Get member class configuration
    memberClassName := coll.cnEcGetMemberType.name;
    memExportClass := app.myRoot.allExportImportClasses[memberClassName];
    
    if memExportClass = null then
        app.writeLog("WARNING: Member class " &amp; memberClassName &amp; " not configured for import",LogWARN);
        return;
    endif;
    
    memKeyProp := memExportClass.allProperties[memExportClass.myKeyName];
    memberTagName := self.removeSpaces(memExportClass.displayName);
    self.lookupAgent.proxyObject := self.proxyObject;
    // Iterate through mapping blocks
    startPos := 1;
    rowNumber := 0;
    
    while startPos &gt; 0 and startPos &lt; _collectionBlock.length do
        // Extract next mapping block
        mappingBlock := _collectionBlock.cnEcGetNextTagValueOfName(memberTagName, startPos);
        
        if startPos = 0 then
            break;
        endif;
        
        rowNumber := rowNumber + 1;
        
        if mappingBlock = null or mappingBlock = "" then
            break;
        endif;
        
        // Extract member key
        memberKey := self.extractXmlTag(mappingBlock, self.removeSpaces(memKeyProp.displayName));
        
        if memberKey &lt;&gt; null and memberKey &lt;&gt; "" then
            // Look up member object
            memberObj := self.findObjectByKey(memExportClass, memberKey);
            
            if memberObj &lt;&gt; null then
                // Add to collection if not already present
                if not coll.includes(memberObj) then
                    coll.add(memberObj);
                endif;
            else
                // Record broken link
                self.addBrokenLink(_objectKey, _property.displayName, memberKey,
                    "Collection member " &amp; memExportClass.displayName &amp; " '" &amp; memberKey &amp; "' not found");
            endif;
        endif;
    endwhile;
end;
</source>
        <access>protected</access>
        <Parameter name="_property" type="CM_ExportImportProperty"/>
        <Parameter name="_collectionBlock" type="String"/>
        <Parameter name="_objectKey" type="String"/>
    </JadeMethod>
    <JadeMethod name="importCollections" id="5e43c324-aec1-4126-8b4d-3ade29921a8b">
        <updating/>
        <source>importCollections(_objectBlock: String; _objectKey: String) updating, protected;
/*

Purpose:			
	* Imports all collection properties for an object
	 * 
	 * @param _objectBlock XML block containing collection blocks
	 * @param _objectKey Parent object's business key (for error reporting)
	 * 
	 * Two import modes:
	 * 1. Key-based: Links existing objects via their keys
	 * 2. Expanded: Creates/updates member objects with full data
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    property: CM_ExportImportProperty;
    collectionBlock: String;
    collectionName: String;
begin
    // Import collections with key-based references
    foreach property in self.collections do
        collectionName := self.removeSpaces(property.displayName);
        collectionBlock := self.extractXmlBlock(_objectBlock, collectionName);
        
        if collectionBlock &lt;&gt; null and collectionBlock &lt;&gt; "" then
            self.importCollectionKeys(property, collectionBlock, _objectKey);
        endif;
    endforeach;
    
    // Import collections with expanded member objects
    foreach property in self.collectionsToExpand do
        self.importCollectionExpanded(property, _objectBlock, _objectKey);
    endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_objectBlock" type="String"/>
        <Parameter name="_objectKey" type="String"/>
    </JadeMethod>
    <JadeMethod name="importFromXml" id="44713e4b-052d-499a-92e5-01250af955f3">
        <updating/>
        <source>importFromXml(_xmlFilePath: String): CM_ImportResult updating;
/*

Purpose:			
	* Imports data from XML file and returns JSON with results
 * 
 * @param _xmlFilePath Path to XML file to import
 * @return JSON string with import statistics and error details
 * 
 * Process:
 * 1. Reads entire XML file into memory
 * 2. Delegates to importFromXmlString for processing
 * 3. Returns JSON result with success/failure counts
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    file: File;
    xmlData: String;
    result: CM_ImportResult;
begin
    // Initialize file reader
    create file;
    file.fileName := _xmlFilePath;
    file.kind := File.Kind_Unknown_Text;
    file.maxRecordSize := 64000;
    
    // Validate file exists
    if not file.isAvailable() then
        write "ERROR: File not found: " &amp; _xmlFilePath;
      //  return '{"recordsProcessed":0,"successCount":0,"failedRecords":[],"brokenLinkRecords":[]}';
    endif;
    
    // Read entire file content
    file.openInput(_xmlFilePath);
    xmlData := "";
    while not file.endOfFile do
        xmlData := xmlData &amp; file.readLine() &amp; CrLf;
    endwhile;
    file.close();
    
    // Process XML data
    result := self.importFromXmlString(xmlData);
    
    return result;
    
epilog
    delete file;
end;</source>
        <Parameter name="_xmlFilePath" type="String"/>
        <ReturnType type="CM_ImportResult"/>
    </JadeMethod>
    <JadeMethod name="importFromXmlString" id="863f200d-ffa3-4de7-a2e3-15a28dd97d88">
        <updating/>
        <source>importFromXmlString(_xmlData: String): CM_ImportResult updating;
/*

Purpose:			
	* Main import orchestrator - processes XML string and coordinates import
	 * 
	 * @param _xmlData Complete XML document as string
	 * @return JSON string with import results
	 * 
	 * Process:
	 * 1. Initializes import counters
	 * 2. Extracts the class sheet block (e.g., &lt;Commoditys&gt;...&lt;/Commoditys&gt;)
	 * 3. Imports all objects from the sheet
	 * 4. Builds JSON response with statistics and errors
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    sheetBlock: String;
    sheetName: String;
	result : CM_ImportResult;
begin
    // Initialize import statistics
    self.recordsProcessed := 0;
    self.successCount := 0;
    create self.failedRecords transient;
    create self.brokenLinkRecords transient;
    
    // Build sheet name from display name (e.g., "Commoditys")
    sheetName := self.removeSpaces(self.myExportImportClass.displayName) &amp; "s";
    
    // Extract the class sheet XML block
    sheetBlock := self.extractXmlBlock(_xmlData, sheetName);
    
    if sheetBlock &lt;&gt; null and sheetBlock &lt;&gt; "" then
       // app.writeLog("Importing " &amp; self.myExportImportClass.displayName &amp; " objects...",LogINFO);
        self.importClassSheet(self.myExportImportClass, sheetBlock);
    else
        app.writeLog("WARNING: No data found for " &amp; sheetName,LogWARN);
    endif;
    
    // Build and return JSON response
    //return self.buildJsonResponse();
	create result transient;
	result.allFailedRecords := self.failedRecords;
	result.allBrokenLinks := self.brokenLinkRecords;
	result.recordsProcessed := self.recordsProcessed;
	result.successCount := self.successCount;
	
	return result;
end;</source>
        <Parameter name="_xmlData" type="String"/>
        <ReturnType type="CM_ImportResult"/>
    </JadeMethod>
    <JadeMethod name="importObject" id="bc74753b-ee5d-46f8-9475-28369e2d3402">
        <updating/>
        <source>importObject(_exportClass: CM_ExportImportClass; _objectBlock: String; _rowNumber: Integer) updating, protected;
/*

Purpose:			
	* Imports a single object from XML and validates/persists it
	 * 
	 * @param _exportClass Export configuration for the class
	 * @param _objectBlock XML block for single object (e.g., &lt;Commodity&gt;...&lt;/Commodity&gt;)
	 * @param _rowNumber Row number for error reporting
	 * 
	 * Process:
	 * 1. Extracts business key from XML
	 * 2. Creates transient proxy object
	 * 3. Imports attributes, references, and collections
	 * 4. Validates and persists via load agent
	 * 5. Records success or failure
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    objectKey: String;
    keyTagName: String;
begin
    // Extract business key value
    keyTagName := self.getKeyTagName(_exportClass);
    objectKey := self.extractXmlTag(_objectBlock, keyTagName);
    
    // Validate key exists
    if objectKey = null or objectKey = "" then
        self.addFailedRecord("", _rowNumber, "Missing business key value for " &amp; keyTagName);
        self.recordsProcessed := self.recordsProcessed + 1;
        return;
    endif;
    
    // Create transient proxy object
    create self.proxyObject as _exportClass.myClass transient;
    
    if self.proxyObject = null then
        self.addFailedRecord(objectKey, _rowNumber, "Failed to create transient object of type " &amp; _exportClass.className);
        self.recordsProcessed := self.recordsProcessed + 1;
        return;
    endif;
    
    // Import all data into proxy object
    self.importClassInstances(_objectBlock, objectKey);
    
    // Validate and persist the object
    if self.validateAndLoadObject(objectKey, _rowNumber) then
        self.successCount := self.successCount + 1;
    endif;
    
    // Always increment processed count
    self.recordsProcessed := self.recordsProcessed + 1;
    
epilog
    // Clean up transient proxy object
    delete self.proxyObject;
    self.proxyObject := null;
end;</source>
        <access>protected</access>
        <Parameter name="_exportClass" type="CM_ExportImportClass"/>
        <Parameter name="_objectBlock" type="String"/>
        <Parameter name="_rowNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="importReferenceKeys" id="0990d2b9-28a0-4ca5-95ee-9c4c580b95b2">
        <updating/>
        <source>importReferenceKeys(_objectBlock: String) updating, protected;
/*

Purpose:			
	 * Imports reference properties using inline key values
	 * 
	 * @param _objectBlock XML block containing reference key tags
	 * 
	 * Example XML:
	 * &lt;CommodityGroup&gt;HAZ1&lt;/CommodityGroup&gt;
	 * 
	 * Process:
	 * 1. Extracts key value from XML
	 * 2. Looks up referenced object by key
	 * 3. Sets reference property on proxy object
	 * 4. Records broken link if referenced object not found
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    property: CM_ExportImportProperty;
    keyTagName: String;
    keyValue: String;
    referencedObj: Object;
    exportClass: CM_ExportImportClass;
begin
    foreach property in self.references do
        // Build key tag name (display name without spaces)
        keyTagName := self.removeSpaces(property.displayName);
        
        // Extract key value from XML
        keyValue := self.extractXmlTag(_objectBlock, keyTagName);
        
        if keyValue &lt;&gt; null and keyValue &lt;&gt; "" then
            // Get export configuration for referenced class
            exportClass := app.myRoot.allExportImportClasses[property.myProperty.type.name];
            
            // Look up referenced object by key
			self.lookupAgent.proxyObject := self.proxyObject;
            referencedObj := self.findObjectByKey(exportClass, keyValue);
            
            // Check if parent object can be used (for circular references)
            if referencedObj = null and self.parentObject &lt;&gt; null then
                if self.parentObject.isKindOf(exportClass.myClass) then
                    referencedObj := self.parentObject;
                endif;
            endif;
            
            if referencedObj &lt;&gt; null then
                // Set the reference property
                self.proxyObject.setPropertyValue(property.propertyName, referencedObj);
            else
                // Record broken link
                self.addBrokenLink(
                    self.proxyObject.getPropertyValue(self.myExportImportClass.myKeyName).String,
                    property.displayName,
                    keyValue,
                    "Referenced " &amp; property.displayName &amp; " '" &amp; keyValue &amp; "' not found"
                );
            endif;
        endif;
    endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_objectBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importReferencesExpanded" id="4f3aa88b-fec2-4734-8311-aa6196205a3f">
        <updating/>
        <source>importReferencesExpanded(_objectBlock: String; _objectKey: String) updating, protected;
/*

Purpose:			
 * Imports reference properties as expanded nested objects
 * 
 * @param _objectBlock XML block containing nested reference blocks
 * @param _objectKey Parent object's business key (for error reporting)
 * 
 * Example XML:
 * &lt;CommodityGroup&gt;
 *   &lt;CommodityGroupCode&gt;HAZ1&lt;/CommodityGroupCode&gt;
 *   &lt;Description&gt;Hazardous Class 1&lt;/Description&gt;
 * &lt;/CommodityGroup&gt;
 * 
 * Process:
 * 1. Extracts nested reference block from XML
 * 2. Extracts key from nested block
 * 3. Finds or creates referenced object
 * 4. Uses sub-agent to import nested object's content
 * 5. Sets reference on parent object
 * 6. Validates/persists if new object created
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    property: CM_ExportImportProperty;
    refBlockName: String;
    refBlock: String;
    refObj: Object;
    refKey: String;
    isNew: Boolean;
    subAgent: CM_DataImportAgent;
    refExportClass: CM_ExportImportClass;
begin
    foreach property in self.referencesToExpand do
        // Build reference block name (e.g., "CommodityGroup")
        refBlockName := self.removeSpaces(property.displayName);
        
        // Extract nested reference block
        refBlock := self.extractXmlBlock(_objectBlock, refBlockName);
        
        if refBlock &lt;&gt; null and refBlock &lt;&gt; "" then
            // Get export configuration for referenced class
            refExportClass := app.myRoot.allExportImportClasses[property.myProperty.type.name];
            
            if refExportClass = null then
                self.addBrokenLink(_objectKey, property.displayName, "", 
                    "Referenced class " &amp; property.myProperty.type.name &amp; " not configured for import");
                continue;
            endif;
            
            // Extract key from nested block
            refKey := self.extractXmlTag(refBlock, self.getKeyTagName(refExportClass));
            
            if refKey &lt;&gt; null and refKey &lt;&gt; "" then
                // Find or create referenced object
                refObj := self.findOrCreateObject(refExportClass, refKey, isNew);
                
                if refObj &lt;&gt; null then
                    // Create sub-agent to import nested object content
                    create subAgent transient;
                    subAgent.setExportImportClass(refExportClass);
                    subAgent.proxyObject := refObj;
                    subAgent.importClassInstances(refBlock, refKey);
                    
                    // Set the reference property on parent object
                    self.proxyObject.setPropertyValue(property.propertyName, refObj);
                    
                    // If new object, validate and persist before continuing
                    if isNew then
                        if not subAgent.validateAndLoadObject(refKey, 0) then
                            self.addBrokenLink(_objectKey, property.displayName, refKey,
                                "Failed to persist referenced " &amp; property.displayName &amp; " '" &amp; refKey &amp; "'");
                            // Clear reference if validation failed
                            self.proxyObject.setPropertyValue(property.propertyName, null);
                        endif;
                    endif;
                    
                    delete subAgent;
                else
                    self.addBrokenLink(_objectKey, property.displayName, refKey,
                        "Failed to create referenced " &amp; property.displayName &amp; " '" &amp; refKey &amp; "'");
                endif;
            else
                self.addBrokenLink(_objectKey, property.displayName, "",
                    "Missing key in expanded " &amp; property.displayName);
            endif;
        endif;
    endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_objectBlock" type="String"/>
        <Parameter name="_objectKey" type="String"/>
    </JadeMethod>
    <JadeMethod name="setAttributeValue" id="224ee87b-54b7-4bdd-a45d-3013e973830b">
        <updating/>
        <source>setAttributeValue(_obj: Object io; _property: Property; _value: String io) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    propType: Type;
	strLength, pos: Integer;
	tempStrArray: StringArray;
	tempIntArray: IntegerArray;
	tempCMIntArray: CM_IntegerArray;
	tempTimeArray: TimeArray;
	tempDecimalArray: DecimalArray;
	tempBooleanArray: BooleanArray;
	tempBinaryArray: BinaryArray;
	attributeValue: Any;
	propName: String;
begin
    propType := _property.type;
	propName := _property.name;
	
	if propType = StringArray then
		pos := 1;
		strLength := attributeValue.String.length;
		tempStrArray := _obj.getPropertyValue(propName).StringArray;
		while pos &lt;= strLength do
			tempStrArray.add(attributeValue.String.getNextToken(pos).replace('&amp;amp;','&amp;'));
		endwhile;
	elseif propType = CM_IntegerArray then
		pos := 1;
		strLength := attributeValue.String.length;
		tempCMIntArray := _obj.getPropertyValue(propName).CM_IntegerArray;
		while pos &lt;= strLength do
			tempCMIntArray.add(attributeValue.String.getNextToken(pos).Integer);
		endwhile;
	elseif propType = IntegerArray then
		pos := 1;
		strLength := attributeValue.String.length;
		tempIntArray := _obj.getPropertyValue(propName).IntegerArray;
		while pos &lt;= strLength do
			tempIntArray.add(attributeValue.String.getNextToken(pos).Integer);
		endwhile;
	elseif propType = TimeArray then
		pos := 1;
		strLength := attributeValue.String.length;
		tempTimeArray := _obj.getPropertyValue(propName).TimeArray;
		while pos &lt;= strLength do
			tempTimeArray.add(attributeValue.String.getNextToken(pos).Time);
		endwhile;
	elseif propType = DecimalArray then
		pos := 1;
		strLength := attributeValue.String.length;
		tempDecimalArray := _obj.getPropertyValue(propName).DecimalArray;
		while pos &lt;= strLength do
			tempDecimalArray.add(attributeValue.String.getNextToken(pos).Decimal);
		endwhile;
	elseif propType = BooleanArray then
		pos := 1;
		strLength := attributeValue.String.length;
		tempBooleanArray := _obj.getPropertyValue(propName).BooleanArray;
		while pos &lt;= strLength do
			tempBooleanArray.add(attributeValue.String.getNextToken(pos).Boolean);
		endwhile;
	elseif propType = BinaryArray then
		pos := 1;
		strLength := attributeValue.String.length;
		tempBinaryArray := _obj.getPropertyValue(propName).BinaryArray;
		while pos &lt;= strLength do
			tempBinaryArray.add(attributeValue.String.getNextToken(pos).Binary);
		endwhile;
    elseif propType = Boolean then
        _obj.setPropertyValue(propName, _value.Boolean);
    elseif propType = Integer then
        _obj.setPropertyValue(propName, _value.Integer);
    elseif propType = Decimal then
        _obj.setPropertyValue(propName, _value.Decimal);
    elseif propType = Real then
        _obj.setPropertyValue(propName, _value.Real);
    elseif propType = Date then
        _obj.setPropertyValue(propName, _value.Date);
    elseif propType = Time then
        _obj.setPropertyValue(propName, _value.Time);
    elseif propType = TimeStamp then
        _obj.setPropertyValue(propName, _value.TimeStamp);
    elseif propType = Character then
        _obj.setPropertyValue(propName, _value.Character);
    elseif propType = Binary then
        _obj.setPropertyValue(propName, _value.Binary);
	elseif propType = Point then
		_obj.setPropertyValue(propName, _value.Point);
    else
        // String or other types
        _obj.setPropertyValue(propName, _value.replace('&amp;amp;', '&amp;'));
    endif;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateAndLoadObject" id="8fbf73e1-9235-4e8c-bbae-0be4b1b9ed70">
        <updating/>
        <source>validateAndLoadObject(_objectKey: String; _rowNumber: Integer): Boolean updating, protected;
/*

Purpose:			
	 * Validates and persists an object using the appropriate load method
	 * 
	 * @param _objectKey Business key value (for error reporting)
	 * @param _rowNumber Row number (for error reporting)
	 * @return true if validation and persistence succeeded, false otherwise
	 * 
	 * Process:
	 * 1. Determines appropriate load method name based on class prefix
	 * 2. Creates CM_DataLoadAgent
	 * 3. Calls load method via sendMsgWithParams
	 * 4. Checks passport for errors/warnings
	 * 5. Records failure details if validation failed
	 * 
	 * Standard load method naming:
	 * - CM_Commodity -&gt; loadCommodity
	 * - HMS_Equipment -&gt; loadEquipment
	 * - CMIF_Terminal -&gt; loadTerminal
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars
    loadAgent: CM_DataLoadAgent;
    loadMethodName: String;
    result: Boolean;
begin
    result := false;
	loadMethodName := self.myExportImportClass.loadMethodName;
    
    // Create load agent
    create loadAgent transient;
    
    // Call validation/persistence method
    result := loadAgent.sendMsgWithParams(loadMethodName, self.proxyObject).Boolean;
    
    // Check if validation/persistence succeeded
    if result and app.myPassport.trxCompletedOK and app.myPassport.allErrorWarnings.size = 0 then
        // Success - no errors or warnings
        result := true;
    else
        // Failure - collect error details
        self.addFailedRecordWithPassportErrors(_objectKey, _rowNumber, loadMethodName);
        result := false;
    endif;
    
    delete loadAgent;
    return result;
end;</source>
        <access>protected</access>
        <Parameter name="_objectKey" type="String"/>
        <Parameter name="_rowNumber" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
