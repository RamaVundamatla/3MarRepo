    <JadeMethod name="getPropertyDisplay" id="fbec6efc-638a-4d2f-ae66-5021b0fd7e6d">
        <executionLocation>client</executionLocation>
        <source>getPropertyDisplay(property: String; str: String io): Boolean clientExecution;
// --------------------------------------------------------------------------------
// Created:		14 April 2006 by cnwdad1
//
// Purpose:		Returns a display value for the receiver's feature reference.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(property, str);
	
	if property = CnEcExperimentalTB::myFeature.name then
		if self.myFeature = null then
			str	:=	"None";
		else
			if self.myFeature.type = null then
				str	:=	self.myFeature.class().name &amp; " " &amp;
						self.myFeature.getType().name &amp; "::" &amp;
						self.myFeature.name;
			else
				str	:=	self.myFeature.class().name &amp; " " &amp;
						self.myFeature.type.name &amp; "::" &amp;
						self.myFeature.name;
			endif;
		endif;
		
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="property" type="String"/>
        <Parameter name="str" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasPropertyPage" id="2f695edd-1aea-4c63-9319-7d12ea7c56dd">
        <source>hasPropertyPage(nam: String): Boolean;
// --------------------------------------------------------------------------------
// Created:		19 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if nam = CnEcExperimentalTB::myFeature.name then
		return true;
	else
		return inheritMethod(nam);
	endif;
end;</source>
        <Parameter name="nam" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveProperties" id="2797e909-0732-4957-b3b2-62fef42efb4c">
        <updating/>
        <source>saveProperties(persistCtl: Control input) updating;
// --------------------------------------------------------------------------------
// Created:		19 April 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(persistCtl);
	persistCtl.CnEcExperimentalTB.myFeature	:=	self.myFeature;
end;</source>
        <Parameter name="persistCtl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showPropertyPage" id="6cdb3083-de9e-4a9d-9dca-8ea9b35124c5">
        <updating/>
        <source>showPropertyPage(nam: String): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		19 April 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	featureFormObj	: CnEcObjectFeatureForm;
	featureObj		: Feature;
	
begin
	if nam = CnEcExperimentalTB::myFeature.name then
		create featureFormObj;
		featureFormObj.setSchema(self.form.class.schema);
		
		if featureFormObj.showModal() = Form.CNEC_MODAL_SELECT then
			self.myFeature	:=	featureFormObj.aMyFeature;
		endif;
	else
		return inheritMethod(nam);
	endif;
end;</source>
        <Parameter name="nam" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
