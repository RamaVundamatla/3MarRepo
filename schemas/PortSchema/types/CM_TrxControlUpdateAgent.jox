    <JadeMethod name="trxUpdateFiles" id="e23c77f2-68b3-44a4-9dfa-dc0660773c86">
        <updating/>
        <source>trxUpdateFiles(_masterObject	: CM_Object input;
				_allDocuments	: ObjectArray input;
				_passport		: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2024	navpw1	Initial creation TFS: 62849 (62927)

*/

vars
	documentsToCreate	: ObjectArray;
	documentsToUpdate	: CM_FileDataSet;
	documentsToDelete	: CM_FileDataSet;
	obj					: Object;
	realFile			: CM_FileData;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if _masterObject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Parent object was not specified/was null");
		
	endif;
	
	if _allDocuments = null then
		return;
	endif;
	
	create documentsToCreate transient;
	create documentsToUpdate transient;
	create documentsToDelete transient;
	
	if _masterObject.isKindOf(CM_Voyage) then
		_masterObject.CM_Voyage.allFiles.copy(documentsToDelete);
	
	elseif _masterObject.isKindOf(CM_VoyageGlobal) then
		_masterObject.CM_VoyageGlobal.allFiles.copy(documentsToDelete);
		
	elseif _masterObject.isKindOf(CM_CargoBOLType) then
		_masterObject.CM_CargoBOLType.allFiles.copy(documentsToDelete);
		
	elseif _masterObject.isKindOf(CM_WorkOrder) then
		_masterObject.CM_WorkOrder.allFiles.copy(documentsToDelete);
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "Parent is an invalid object type. You will also need to update app.myUtilityCA.utlCreateFiles");
		
	endif;
		
	foreach obj in _allDocuments do
		if obj.isKindOf(CM_FileData) and obj.CM_FileData.pxyIsProxy then
			// document is for update
			documentsToUpdate.add(obj.CM_FileData);
			realFile := obj.CM_FileData.pxyGetRealObject();
			if documentsToDelete.includes(realFile) then
				documentsToDelete.remove(realFile);
			endif;
		else
			// document is to be created
			documentsToCreate.add(obj);
		endif;
	endforeach;
	
	// Start the transaction
	beginTransaction;
	
	//if filesToCreate then
	if documentsToCreate.isNotEmpty then
		app.myUtilityCA.utlCreateFiles(_masterObject, documentsToCreate, _passport);
	endif;
	
	//if filesToUpdate then
	if documentsToUpdate.isNotEmpty then
		app.myUtilityUA.utlUpdateFiles(documentsToUpdate, _passport);
	endif;
	
	//if documentsToDelete.size() &gt; 0 then
	if documentsToDelete.isNotEmpty then
		// any documents that are on the exisitng voyage request, 
		// but aren't in the list to update, will get deletetd
		app.myUtilityDA.utlDeleteFiles(documentsToDelete, _passport);
	endif;
	
epilog
	delete documentsToCreate;
	delete documentsToUpdate;
	delete documentsToDelete;
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_masterObject" type="CM_Object" usage="input"/>
        <Parameter name="_allDocuments" type="ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
