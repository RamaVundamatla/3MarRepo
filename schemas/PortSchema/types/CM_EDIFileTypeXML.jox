    <JadeMethod name="handleXMLException" id="8c6f0062-cdaa-487a-ac30-ef3dd883be8d">
        <source>handleXMLException(_exc : JadeXMLException; _parsingError : Boolean io) : Integer protected;

/*

Purpose:			Handle any error during parsing of the incomingFile

Parameters:			Exception object

Return Value:		_parsingError set to true when an exception occurs


Date		Who		Reason
18 Apr 2018	cnwma1	Bug 46410: AAT - 8901 when parsing OneStop message

*/

vars
	errStr : String;
begin
	app.writeLog(method.qualifiedName &amp; 
							 " " &amp; _exc.class.name &amp; 
							 " " &amp; _exc.errorCode.String &amp; 
							 " " &amp; _exc.text &amp; 
							 " " &amp; _exc.extendedErrorText, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	errStr := app.getErrorString1(ERR_Parsing_XML, _exc.errorItem)&amp;' ('&amp;_exc.errorCode.String&amp;'). '&amp;_exc.extendedErrorText;
			
	_parsingError := true;
	self.addFileErrors(errStr, 1, null);
	return Ex_Resume_Next;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="JadeXMLException"/>
        <Parameter name="_parsingError" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
