    <JadeMethod name="doCmbAccuralTypeBuild" id="f3cd3a57-7f6c-4bdd-b973-a1436c7676ec">
        <source>doCmbAccuralTypeBuild();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anFPE: 	CM_FinancialPeriodEnd;
	idx : Integer;
begin
	self.cmbAccuralType.clear;

	self.cmbAccuralType.addItemAt("Until Closed", 1);
	self.cmbAccuralType.itemObject[1] := null;
	self.cmbAccuralType.itemData[1] := CM_InvoiceDesc.Accrue_Until_Manually_Closed;

	idx  := 1;
	foreach anFPE in app.myRoot.myRootCompany.allFinancialPeriods do
		idx := idx + 1;
		self.cmbAccuralType.addItemAt(anFPE.description, idx);
		self.cmbAccuralType.itemObject[idx] := anFPE;
		self.cmbAccuralType.itemData[idx] := CM_InvoiceDesc.Accrue_For_Financial_Period;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBankBuild" id="5404d881-a914-4935-99ad-b67bcaa34ec0">
        <source>doCmbBankBuild();
//	35874 build combo for business unit query
vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCmbFieldBuild" id="02fbeefa-62cf-443b-8d3a-0cd37c63522a">
        <source>doCmbFieldBuild(_theCombo : ComboBox input);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 04/01/2013	cnwdap1		PAR #30860 CCMS QNS 2236 New narrative field types
vars
begin
	
	_theCombo.clear;
	_theCombo.sorted := false;
	_theCombo.addItem('"None"');
	_theCombo.itemData[1] := CM_InvoiceDesc.Field_None;
	
	_theCombo.addItem('"Debtor name"');
	_theCombo.itemData[2] := CM_InvoiceDesc.Field_Debtor_Name;

	_theCombo.addItem('"Voyage code"');
	_theCombo.itemData[3] := CM_InvoiceDesc.Field_Voyage_Code;

	_theCombo.addItem('"Vessel name"');
	_theCombo.itemData[4] := CM_InvoiceDesc.Field_Vessel_Name;

	_theCombo.addItem('"Business unit name"');
	_theCombo.itemData[5] := CM_InvoiceDesc.Field_Business_Unit;

	_theCombo.addItem('"End date"');
	_theCombo.itemData[6] := CM_InvoiceDesc.Field_Closing_Date;

	_theCombo.addItem('"End date and time"');
	_theCombo.itemData[7] := CM_InvoiceDesc.Field_Closing_Date_And_Time;

	_theCombo.addItem('"Voyage Operator Code"');							// PAR #30860
	_theCombo.itemData[8] := CM_InvoiceDesc.Field_Voyage_Operator_Code;		// PAR #30860
																			// PAR #30860
	_theCombo.addItem('"Voyage Operator Description"');						// PAR #30860
	_theCombo.itemData[9] := CM_InvoiceDesc.Field_Voyage_Operator_Desc;		// PAR #30860
																			// PAR #30860
	_theCombo.addItem('"Voyage Arrival Date (no time)"');					// PAR #30860
	_theCombo.itemData[10] := CM_InvoiceDesc.Field_Voyage_Arrival_Date;		// PAR #30860
																			// PAR #30860
	_theCombo.addItem('"Voyage Departure Date (no time)"');					// PAR #30860
	_theCombo.itemData[11] := CM_InvoiceDesc.Field_Voyage_Departure_Date;	// PAR #30860

end;</source>
        <Parameter name="_theCombo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbSepInvoicesBuild" id="2dc61dba-70f0-4efa-b6ec-4fc06ed50082">
        <source>doCmbSepInvoicesBuild();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 15/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 New BOL Invoice type
vars

begin
	self.cmbSepInvoices.clear;

	self.cmbSepInvoices.addItemAt( app.getErrorString(None), 1);
	self.cmbSepInvoices.itemData[1] := CM_InvoiceDesc.Key_None;
	self.cmbSepInvoices.addItemAt( app.getErrorString(CargoItem_Name), 2);	//Par17895. September 2008
	self.cmbSepInvoices.itemData[2] := CM_InvoiceDesc.Key_CargoItem;
	self.cmbSepInvoices.addItemAt( app.getErrorString(Voyage), 3);
	self.cmbSepInvoices.itemData[3] := CM_InvoiceDesc.Key_Voyage;
	
	self.cmbSepInvoices.addItemAt( app.getErrorString(BillOfLading), 4);	// PAR #36909
	self.cmbSepInvoices.itemData[4] := CM_InvoiceDesc.Key_BOL;				// PAR #36909
	
	self.cmbSepInvoices.addItemAt( app.getErrorString(Voyage_group), 5); // ### TFS 51219 25MAY2021 NAVAB1
	self.cmbSepInvoices.itemData[5] := CM_InvoiceDesc.Key_VoyageGroup;	 // ### TFS 51219 25MAY2021 NAVAB1			// PAR #36909

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbTermsTradeBuild" id="ecd1c1cf-8bfc-458c-88ac-17082f01397f">
        <source>doCmbTermsTradeBuild();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	invTerm : CM_InvoiceTermsOfTrade;

begin

	self.cmbTermsTrade.clear;
	self.cmbTermsTrade.addItem("");
	foreach invTerm in app.myRoot.myRootCompany.allInvoiceTermsOfTrade do
		self.cmbTermsTrade.addItem(invTerm.description);
		self.cmbTermsTrade.itemObject[self.cmbTermsTrade.newIndex] := invTerm;
	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbTriggerOnActionBuild" id="ff69b4d1-9624-4fc7-ae4a-94182ae430ff">
        <source>doCmbTriggerOnActionBuild();
/* ---------------------------------------------------------------------------
Created:	08 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.cmbTriggerAction.clear();

	self.cmbTriggerAction.addItemAt("Trigger On Release", 1);
	self.cmbTriggerAction.itemData[1] := InvTypeTrigger_Release;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="4c82386f-27d7-4272-8f78-a2fd73883867">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theReturn : Integer;
begin
 
	while true do
 
 	 	app.myTrxDA.trxDeleteInvoiceDesc(self.myCurrentObject.CM_InvoiceDesc, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Invoice Type", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="269dac2c-2555-4d20-b903-de7e008efe94">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			Filters the tree

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

vars
	filterText		: String;
	rowIdx,
	colIdx,
	start			: Integer;
	cell			: JadeTableCell;
	cellText		: String;
	
begin
	//filterText := self.txtFilterBox.text.toUpper();
	filterText := self.frmTableFilter.txtFilterBox.text.toUpper(); //25/06/2024	navkc1 CR 64823 Task 64824
	
	if (filterText = "") then
		self.clearFilter();
		return;
	else
		//self.btnClearFilter.enabled := true;
		self.frmTableFilter.btnClearFilter.enabled := true;
	endif;
	/*
	start := self.tblData.fixedRows + 1;
	foreach rowIdx in start to self.tblData.rows do	: rowLoop
		self.tblData.accessRow(rowIdx); // ### TFS 51912 17Sep2021 NAVPW1 Needed as we use accessedRow below. Plus needed for columns of current row
		foreach colIdx in 1 to self.tblData.columns do
			cell := self.tblData.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblData.accessedRow.visible := true;
				continue rowLoop;
			endif;
		endforeach;
		self.tblData.accessedRow.visible := false;
	endforeach;
*/
	self.tblData.topRow := 1;
	
end;</source>
    </JadeMethod>
