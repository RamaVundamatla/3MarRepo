    <JadeMethod name="checkForDuplicates" id="feec1442-cb3f-46a3-94dd-2cc466d144cd">
        <source>checkForDuplicates(_craneType : Integer; _jobType : Integer) : Boolean;
//////////////////////////////////////////
//
//	cnwyl1 for par12216
//	reason: check if there is same job 
//          in the same crane type 
//
//////////////////////////////////////////
vars
	jobPriority : CM_JobPriority;
begin
	foreach jobPriority in self.allJobPriorities do
		if jobPriority.craneType = _craneType and jobPriority.jobType = _jobType then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <Parameter name="_craneType" type="Integer"/>
        <Parameter name="_jobType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="1327e4c0-8c84-4e32-ac32-a0421977d6f1">
        <updating/>
        <source>init(_purge : Boolean; _obj : CM_Object; _class : Class) updating;
// ---------------------------------------------------------------------------
// Created:		06 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
begin
	self.myObject := _obj;
	self.myClass := _class;
	if _purge then
		self.allJobPriorities.purge;
	else
		self.allJobPriorities.clear;
	endif;
end;</source>
        <Parameter name="_purge" type="Boolean"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="populateControllerWithMissing" id="638e6fb5-6288-4d66-a7ed-8b0a8bbf2ef2">
        <source>populateControllerWithMissing(_craneType : Integer);
// ---------------------------------------------------------------------------
// Created:		06 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	iter : Iterator;
	pxyJP : CM_JobPriority;
	craneType, priority,jobType : Integer;
	priYN : BooleanArray;
begin
	iter := self.allJobPriorities.createIterator();
	craneType := _craneType; 
	
	create priYN transient;
	priYN[JobTypePriority_MAX] := false; // initialise
	
	while iter.next(pxyJP) do
		if  pxyJP.craneType = craneType then
			priYN[pxyJP.jobType] := true;
			priority := priority.max(pxyJP.priority);
		endif;
	endwhile;

	if priority &lt; 1 then
		priority := 1;
	endif;
	foreach jobType in 1 to JobTypePriority_MAX do
		if priYN[jobType] = false then
			// ### Create proxy for create
			create pxyJP  as self.myClass transient;
			
			pxyJP.setProxy(craneType,jobType,priority,self.myObject);
			self.allJobPriorities.add(pxyJP);
		
		endif;
	endforeach;
	
epilog
	delete priYN;
	delete iter;			// PAR #26678
	
end;</source>
        <Parameter name="_craneType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateDefaults" id="0b0e4286-46a9-46e0-a292-484a192a17be">
        <source>populateDefaults();
// ---------------------------------------------------------------------------
// Created:		06 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyJP, aJP : CM_JobPriority;
	aVessel : CM_Vessel;
begin
	if self.myObject.isKindOf(CM_Root) then
		self.populateControllerWithMissing(JobTypePriority_Crane1);
		self.populateControllerWithMissing(JobTypePriority_Crane2);
	elseif self.myObject.isKindOf(CM_Vessel) then
		
		foreach aJP in app.myRoot.allJobPriorities do
			create pxyJP  as self.myClass transient;
			pxyJP.setProxy(aJP.craneType, aJP.jobType, aJP.priority,self.myObject);
			self.allJobPriorities.add(pxyJP);
			
		endforeach;
		
	elseif self.myObject.isKindOf(CM_Voyage) then
		aVessel := self.myObject.CM_Voyage.getMyVessel();
		//changed by cnwyl1 for Par 12455
		//it was..
		//if aVessel &lt;&gt; null then
		if aVessel &lt;&gt; null and not aVessel.allJobPriorities.isEmpty() then
			foreach aJP in aVessel.allJobPriorities do
				create pxyJP as self.myClass transient;
				pxyJP.setProxy(aJP.craneType, aJP.jobType, aJP.priority,self.myObject);
				self.allJobPriorities.add(pxyJP);
				
			endforeach;
		else
			foreach aJP in app.myRoot.allJobPriorities do
				create pxyJP  as self.myClass transient;
				pxyJP.setProxy(aJP.craneType, aJP.jobType, aJP.priority,self.myObject);
				self.allJobPriorities.add(pxyJP);
				
			endforeach;
		
		endif;

	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="populatePriorities" id="06829500-25c9-474e-8cbb-c7dfe8f86ab9">
        <updating/>
        <source>populatePriorities() updating;
// ---------------------------------------------------------------------------
// Created:		06 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	root : CM_Root;
	vess : CM_Vessel;
begin
	//When Voyage Enquiry form is opening this JobPriorities form, the value of 
	//isResetToSystem would be FALSE, so we copy their own Job Priorities.
	//When JobPriroritis form is being refreshed, if the isResetToSystem is true, 
	//the default job priorities would be used.

	if self.myObject.isKindOf(CM_Root) then
		self.myObject.CM_Root.allJobPriorities.copy(self.allJobPriorities);
		self.tempLabel := app.getErrorString(System_wide_settings); // PAR 34655 "(System Wide Settings)";
	elseif self.myObject.isKindOf(CM_Vessel) then
		if self.isResetToSystem or self.myObject.CM_Vessel.allJobPriorities.isEmpty then//added by cnwyl1
			app.myRoot.allJobPriorities.copy(self.allJobPriorities);
			self.tempLabel := app.getErrorString(System_wide_settings); // PAR 34655  "(System Wide Settings)";
		else
			self.myObject.CM_Vessel.allJobPriorities.copy(self.allJobPriorities);
			self.tempLabel := app.getErrorString(Vessel_settings); // PAR 34655  "(Vessel Settings)";
		endif;	
	elseif self.myObject.isKindOf(CM_Voyage) then
		if not self.isResetToVessel
		and (self.isResetToSystem or self.myObject.CM_Voyage.allJobPriorities.isEmpty) then//added by cnwyl1
			app.myRoot.allJobPriorities.copy(self.allJobPriorities);
			self.tempLabel := app.getErrorString(System_wide_settings); // PAR 34655  "(System Wide Settings)";
		elseif self.isResetToVessel or self.myObject.CM_Voyage.allJobPriorities.isEmpty then // PAR 34655
			vess := self.myObject.CM_Voyage.getMyVessel();
			if vess.allJobPriorities.isEmpty then // PAR 34655
				app.myRoot.allJobPriorities.copy(self.allJobPriorities);
				self.tempLabel := app.getErrorString(System_wide_settings); // PAR 34655  "(System Wide Settings)";
			else
				vess.allJobPriorities.copy(self.allJobPriorities);
			self.tempLabel := app.getErrorString(Vessel_settings); // PAR 34655  "(Vessel Settings)";
			endif;
		else
			self.myObject.CM_Voyage.allJobPriorities.copy(self.allJobPriorities);
			self.tempLabel := app.getErrorString(Voyage_settings); // PAR 34655  "(Voyage Settings)";
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="purgePriorities" id="c28e95be-af67-460e-88b3-3e7685e84957">
        <source>purgePriorities();
// ---------------------------------------------------------------------------
// Created:		06 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
begin

	if self.myObject.isKindOf(CM_Root) then
		self.myObject.CM_Root.allJobPriorities.purge();
	elseif self.myObject.isKindOf(CM_Voyage) then
		self.myObject.CM_Voyage.allJobPriorities.purge();
	elseif self.myObject.isKindOf(CM_Vessel) then
		self.myObject.CM_Vessel.allJobPriorities.purge();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="12f357e0-c017-4b3e-9060-152bff5454c8">
        <source>setForCreate();
// ---------------------------------------------------------------------------
// Created:		06 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyJP, realJP : CM_JobPriority;
begin
	
	foreach pxyJP in self.allJobPriorities do
		create realJP as self.myClass;
		
		realJP.setForCreate(pxyJP);
	endforeach;
end;</source>
    </JadeMethod>
</Class>
