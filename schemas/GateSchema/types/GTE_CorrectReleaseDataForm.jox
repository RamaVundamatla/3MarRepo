    <JadeMethod name="resetForm" id="bbf45367-f488-451b-92c4-a876640bfab9">
        <updating/>
        <source>resetForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
20/09/2025		navcs2	MTN-35847
13.10.25	Navcs2	MTN-36202	MTN | Invoice Form displaying empty rows when rows are added from Selector form

*/

vars

begin
	create releasedCMIFs transient;		// 13.10.25	Navcs2	MTN-36202
	create onsiteCMIFs transient;		// 13.10.25	Navcs2	MTN-36202
	
	self.onsiteCMIFs.clear();			// 13.10.25	Navcs2	MTN-36202
	self.releasedCMIFs.clear();			// 13.10.25	Navcs2	MTN-36202
	self.loadVehicleVisitDetails();
	self.buildTblOnsiteCargo(true);		// 13.10.25	Navcs2	MTN-36202
	self.buildTblReleasedCargo();
	self.loadCurrentCargoDetails();
	self.myMoveControllers.clear;			// 20/09/2025		navcs2	MTN-35847
	//self.txtNewCargo.text := null;
epilog

end;</source>
