    <JadeMethod name="trxProcessEDIBOLConsist" id="ee60f149-8018-427b-95fd-e9643100b53d">
        <updating/>
        <source>trxProcessEDIBOLConsist(_ediData :CM_EDIDataBOL input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
//
// cnwrs1 Jan 2010 CCMS 1008 1006 Messina Ship Mainfest
//
// 20/06/2012	cnwcs5	par 29747 - refactor utl
// 26/06/2012	cnwcs5	par 29747:1 - fix problem with errors
// 26/06/2012	cnwcs5	par 29747:2 - make setting status simpler
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
vars
	status 				: Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	beginTransaction;

	_passport.useTIDictDeferUpdate 			:= true;
	_passport.useTITransactionDeferUpdate 	:= true;

	app.myUtilityUA.utlProcessEDIBOLConsist (_ediData, _validateOnly, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataBOL" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDICargoFieldUpdate" id="3af3034e-d2d2-46c0-a7f1-9792a0048745">
        <updating/>
        <source>trxProcessEDICargoFieldUpdate(_ediData : CM_EDIDataCargoFieldUpdate input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		14 December 2009 by cnwdad1
//
// Purpose:		Process the EDI Cargo Field Update objects.
//
// Parameters:	_allCargoTIsObj - An array of Tracked Item objects to update.
//				_isValidateOnly - True if we are only validating the EDI data.
//				_passportObj - The user's passport.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 3
// --------------------------------------------------------------------------------
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
vars
	status : Integer;
begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers.
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);
	
	beginTransaction;
	
	app.myUtilityUA.utlCargoFieldUpdate(_ediData, _validateOnly, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataCargoFieldUpdate" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDICommodity" id="d5c85c4c-4ee1-4900-91c3-8b88201645c2">
        <updating/>
        <source>trxProcessEDICommodity(_ediData : CM_EDIData input; _allAddCommoditys, _allUpdCommoditys, _allDelCommoditys : CM_CommodityArray;
								_validateOnly : Boolean; _passport : CM_Passport input) updating;

//
// 18 Jul 2018	jlgrs1	TFS PLI01
//
vars
	commodityObj : CM_Commodity;
	realCommodityObj : CM_Commodity;
	status : Integer;
begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	foreach commodityObj in _allAddCommoditys do
		app.myUtilityCA.utlCreateCommodity(commodityObj, realCommodityObj, _passport);
	endforeach;
	
	foreach commodityObj in _allUpdCommoditys do
		app.myUtilityUA.utlUpdateCommodity(commodityObj, _passport);
	endforeach;
	
	foreach commodityObj in _allDelCommoditys do
		app.myUtilityDA.utlDeleteCommodity(commodityObj, _passport);
	endforeach;
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
	_passport.allCurrentCellularVoyages.clear;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_allAddCommoditys" type="CM_CommodityArray"/>
        <Parameter name="_allUpdCommoditys" type="CM_CommodityArray"/>
        <Parameter name="_allDelCommoditys" type="CM_CommodityArray"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
