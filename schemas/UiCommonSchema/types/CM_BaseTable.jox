    <JadeMethod name="timerEvent" id="9afbdbe5-c266-4509-bfc5-06fcd1f713e9">
        <updating/>
        <source>timerEvent(_eventTag: Integer) updating;
/*

Purpose:			Rather than executing methods that add delay to scrolling at the beginning of the scroll, batch them into a timer request instead

Parameters:			

Return Value:		

Date				Who		Reason
18 November 2022	navmd1	Initial creation TFS 55379 Give the thinclient / JADE a second or so to finish scrolling

*/

vars

begin
	if _eventTag = CM_BaseTable.Timer_UpdateCurrentViewObjects then
		self.setCurrentViewObjects();
	// 10 Sept 2024	navab1	CR 66065 : MTN - Generate quick list of selected column data
	elseif _eventTag = CM_BaseTable.Timer_CTRL_SHFT_G then
		self.doClearCtrlShftG();
	endif;
epilog

end;</source>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toggleGroup" id="8efb64f6-cf13-42c8-9aa0-14e3e8d0718d">
        <updating/>
        <source>toggleGroup() updating;
//15 June 2009	cnwdw1	
// PAR 19910
vars
	cell: JadeTableCell;
	row: JadeTableRow;
	rowIndex: Integer;
begin
	//cnwjo3, little tidy up here
	if self.row &lt; 1 then
		return;
	endif;
	
	cell := self.accessCell(self.row, CM_EntryTable.ColumnHeading);
	if cell.backColor = LightGray then
		cell := self.accessCell(self.row, CM_EntryTable.ColumnValue);
		cell.fontName := "Webdings";		// is webdings always avialable?
		cell.alignment := Table.Alignment_Right;
		cell.fontSize := 12;
		if cell.text = "5" then
			cell.text := "6";
		else
			cell.text := "5";
		endif;

		foreach rowIndex in self.row + 1 to self.rows do
			cell := self.accessCell(rowIndex, CM_EntryTable.ColumnHeading);
			if cell.backColor = LightGray then
				break;
			endif;
			row := self.accessRow(cell.row);
			if row.visible then
				row.visible := false;
			else
				row.visible := true;
			endif;
		endforeach;
	endif;			
end;</source>
    </JadeMethod>
    <JadeMethod name="updateViewObject" id="514b3898-8edd-4fcc-9972-cd4efb0b8b79">
        <updating/>
        <source>updateViewObject( _obj : CM_Object; _str : String )updating;
/*

Purpose:			

Parameters:			Called when 'updating' an existing object during notification processing,
					decides whether to update the line or not
					based on whether or not the line is actually visible to the user.
					Used to improve form performance.

Return Value:		

Date		Who		Reason
15 March 2021	navndl1	Initial creation	TFS 50935

*/

vars
	
	rowIndex : Integer;

begin

	if self.allCurrentViewObjects.includes( _obj ) then
		//Its one that is in our current view, update it
		self.findObjectInRow( _obj, rowIndex );
		if rowIndex &gt; 0 then
			self.setCellText( rowIndex, 1, _str);
		endif;
	else
		//nothing to do, it may be in the table BUT, its not currently in sight.
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="c9afbfc0-5ad3-413a-8b45-4691107407d1">
