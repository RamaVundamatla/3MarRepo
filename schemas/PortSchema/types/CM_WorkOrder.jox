	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="966bf4da-46d1-441c-9b91-7082231ff256">
        <source>getDisplayDetails(_short: Boolean): String;
/*

Purpose:			

