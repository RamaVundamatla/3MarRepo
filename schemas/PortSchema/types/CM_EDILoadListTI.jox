    <JadeMethod name="setDefaultsForFileFormat" id="3425ce10-cbd9-4634-b755-5c174f40a7f3">
        <updating/>
        <source>setDefaultsForFileFormat(_ediData: CM_EDIData) updating;
//----------------------------------------------------------------
//	Created:	26 January 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	terminal : CM_Terminal;
begin
	inheritMethod(_ediData);

	terminal := self.getMyTerminal();

	if terminal &lt;&gt; null then
		self.loadPort := terminal.getConfig(PortDestCode).String;
	endif;

	self.operatorCode := _ediData.operatorCode;
	
	self.temperature := NULL_TEMPERATURE;
	self.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	self.setOxygen( NULL_OXYGEN );
	self.setHumidity( NULL_HUMIDITY );
	self.vent := NULL_VENTILATION; //par19252 cnwrs1 may 2009
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
