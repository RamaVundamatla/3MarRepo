// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		By passing in the class of the controller - Stack, Gap Tower etc this will check the previous 2 controllers in the 
//				chain. If one of them is of the passed in type  then pass it back else pass null
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myPreviousController = null then
		return null;
	endif;
	if pControllerType &lt;&gt; CM_StackController 
	and self.testMyPreviousController(CM_StackController) then // is the controller next to me a Stack Controller? If so then stop
		return null;
	endif;
	
	if self.testMyPreviousController(pControllerType) then
		return self.myPreviousController;
	elseif self.myPreviousController.testMyPreviousController(pControllerType) then 
		return self.myPreviousController.myPreviousController;
	else
		return null;
	endif;


end;</source>
        <Parameter name="pControllerType" type="Class"/>
        <ReturnType type="CM_GridController"/>
