    <JadeMethod name="addServiceRateToTable" id="d7bf439f-a064-4167-b2fb-418cde5a9214">
        <source>addServiceRateToTable(service: CM_Service; rate: Real; overridden: Boolean; chargeCount: Integer);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str:     String;
	row:     Integer;
	theTable : Table;
begin
	theTable := self.tblRatesOR;
	str := service.name &amp; Tab;
	str := str &amp; rate.asStringJMTWithPrecision($CM_RateNumber.decimalPlaces, false) &amp; "  " &amp; Tab;
	if overridden then
		str := str &amp; "Yes" &amp; Tab;
	else
		str := str &amp; "No" &amp; Tab;
	endif;

	str := str &amp; chargeCount.String &amp; "  " &amp; Tab;
	if overridden then
		str := str &amp; rate.asStringJMTWithPrecision($CM_RateNumber.decimalPlaces, false) &amp; "  ";
	endif;

	row := theTable.addItem(str);
	theTable.accessRow(row).itemObject := service;
//	theTable.row := row;
//	theTable.column := 1;
//	theTable.itemObject := service;


end;</source>
        <Parameter name="service" type="CM_Service"/>
        <Parameter name="rate" type="Real"/>
        <Parameter name="overridden" type="Boolean"/>
        <Parameter name="chargeCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="c51a1011-c50e-412e-b183-9210f2a001f7">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 29/03/2018	jlgdap1		TFS 37560 PEL1 Prepend Invoice Status
// 26 Nov 2022  navvt20		Task 55527: Invoice List Attachments
// 13 Dec 2022  navmv20     TFS CR 55301 Task 55554: UI - Invoice List changes for Selector
// 11 Sep 2023 	navhl20 	ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
vars
	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrintInvoice, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrintConsol, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrintOneLine, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSelector, CMUI_Toolbar.Control_Alignment_Left);	//13/12/2022 navmv20 TFS CR 55301 TASK 55554
	
	//jlier1 MTN-34725 28/5/25
	frm.addButton(self.btnNotifications, CMUI_Toolbar.Control_Alignment_Right);
	self.btnNotifications.visible := true;
	
	inheritMethod();

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnUpdate, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	//frm.addButton(self.btnStatusPrepend, CMUI_Toolbar.Control_Alignment_Left);		// TFS 37560 // TFS 39618
	//frm.addButton(self.btnStatusDispute, CMUI_Toolbar.Control_Alignment_Left);		// TFS 37560 // TFS 39618
	//frm.addButton(self.btnStatusClose, CMUI_Toolbar.Control_Alignment_Left); // TFS 39618
	//frm.addButton(self.btnStatusPost, CMUI_Toolbar.Control_Alignment_Left); // TFS 39618
	//frm.addButton(self.btnStatusReturn, CMUI_Toolbar.Control_Alignment_Left);	//31 Aug 2017	NDL	TFS 6759 // TFS 39618
	frm.addButton(self.btnStatusVoid, CMUI_Toolbar.Control_Alignment_Left); // TFS 39618 861.010
	//frm.addButton(self.btnStatusSuspens, CMUI_Toolbar.Control_Alignment_Left); // TFS 39618
	frm.addFrame(self.frmStatus, CMUI_Toolbar.Control_Alignment_Left); // TFS 39618
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left); // TFS 39618
	frm.addButton(self.btnInvoiceLines, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnOverRide, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnAudits, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExport2File, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnReeval, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnOpenSchedule, CMUI_Toolbar.Control_Alignment_Left);	// CCMS 2120 Nov 2011
	frm.addButton(self.btnAttachments, CMUI_Toolbar.Control_Alignment_Left);	// 26 Nov 2022 navvt20 TFS 55527
	btnReeval.visible := true;
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnIncludeArchive, CMUI_Toolbar.Control_Alignment_Left);	//11.9.2023 navhl20 #59376
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);

/*	//05/06/2024	navkc1 CR 63736 Task 63770 Replaced with new filter control
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left); 						// ### TFS 51912 14Sep2021 NAVPW1
	frm.addFrame(self.frmFilterBox, CMUI_Toolbar.Control_Alignment_Left);		// ### TFS 51912 14Sep2021 NAVPW1
	frm.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);	// ### TFS 51912 14Sep2021 NAVPW1
*/
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					//05/06/2024	navkc1 CR 63736 Task 63770
	frm.addFrame(self.frmTblFilter, CMUI_Toolbar.Control_Alignment_Left); 	//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmTblFilter.visible := true;										//05/06/2024	navkc1 CR 63736 Task 63770
	
	frm := self.frmInvToolbar;
	frm.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnInvPropCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmRatesToolbar;
	frm.addButton(self.btnRateSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRateSet, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRateRemove, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addFrame(self.frmRateTBFrame, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRateCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="77c27016-c65c-413b-8a0d-f2b099f6f87c">
        <source>addToolbarControlsQuery() protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 08/06/2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// ---------------------------------------------------------------------------

vars
	queryToolbar			: CMUI_Toolbar;
begin

	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery,              CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnQueryVoyage,        CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnQueryDebtor,        CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnQueryCargo_,        CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnQueryBOL,     	   CMUI_Toolbar.Control_Alignment_Left); // 30931
	queryToolbar.addButton(self.btnQueryInvoice, 	   CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnQueryVoyageGrpCode, CMUI_Toolbar.Control_Alignment_Left); //03/06/2020 cnwma1 Tfs #49400
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnResetSearch, 	   CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher,       CMUI_Toolbar.Control_Alignment_Left);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="78f18f2e-143f-4e23-9b87-59b997a1bd7a">
        <source>allowsTableFilters(_table: Table) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2013	cnwjre1	Initial creation

*/

vars

begin
	return _table = self.tblData;
epilog

