    <JadeMethod name="railRakeTypeEnumToString" id="12064093-5f35-49f0-aa70-20d0531a676f">
        <source>railRakeTypeEnumToString(_ioType : Integer) : String;
//--------------------------------------------------------------
//Created: December 2004 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _ioType = Rail_JSIO_Type_Out then
		return app.getErrorString(Outward_Rail);
	elseif _ioType = Rail_JSIO_Type_In then
		return app.getErrorString(Inward_Rail);
	elseif _ioType = Rail_JSIO_Type_Transit then
		return app.getErrorString(Transit_Rail);
	elseif _ioType = Rail_JSIO_Type_Build then
		//return $Build_Priority;					
		return app.getErrorString(Rail_Release_Request);							
	endif;
	
	return null;					
	
end;</source>
        <Parameter name="_ioType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="raiseCMException" id="b33d898e-3352-4bcc-8b2b-084f7b8f847e">
        <updating/>
        <source>raiseCMException(errNo : Integer;
				  pAttrNameString : String; pGuiObject : Object) updating;

vars
	exObj	: CM_Exception;

begin

	create exObj transient;
	exObj.set(errNo, self.getErrorString(errNo), false, pAttrNameString, pGuiObject, null);
	
	raise exObj;

end;</source>
        <Parameter name="errNo" type="Integer"/>
        <Parameter name="pAttrNameString" type="String"/>
        <Parameter name="pGuiObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="raiseCMException1" id="ea9dca0a-db1d-45d6-8a40-f6e310a4e6e6">
        <updating/>
        <source>raiseCMException1(errNo : Integer; param1 : String; 
				  pAttrNameString : String; pGuiObject : Object) updating;
vars
	exObj	: CM_Exception;
	translation : XLAT_Translation;
	sa  		: HugeStringArray;
begin
	create exObj transient;

	exObj.set(errNo, self.getErrorString1(errNo, param1), false, pAttrNameString, pGuiObject, null);
	//jlier1 TFS 59732 28/9/23
	if self.mySecondaryLocale &lt;&gt; null and self.mySecondaryLocale &lt;&gt; self.myCurrentLocale then
		translation := self.mySecondaryLocale.getTranslatedText(XLAT_Exceptions, errNo);
		if translation &lt;&gt; null then
			create sa transient;
			sa.addTruncated(param1);	
			exObj.secondaryText:= translation.getTextWithSubstitutedParams(sa);	
		endif;	
	endif;
	
	
	raise exObj;
epilog
	delete sa;
end;</source>
        <Parameter name="errNo" type="Integer"/>
        <Parameter name="param1" type="String"/>
        <Parameter name="pAttrNameString" type="String"/>
        <Parameter name="pGuiObject" type="Object"/>
    </JadeMethod>
