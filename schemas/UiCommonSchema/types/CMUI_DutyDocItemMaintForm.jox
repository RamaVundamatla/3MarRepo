    <JadeMethod name="clearAllFields" id="b8d2413c-751c-4b61-8eed-c7c08bbd412d">
        <updating/>
        <source>clearAllFields() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	billType : CM_DutyDocType; 

begin

	self.myTrackedItem := null;
	self.txtID.text := null;
	self.txtCargoDetail.text := null;
	self.txtVoyage.text:=null;
	self.txtOperator.text:=null;
	self.txtAgent.text:=null;
	self.btnAsCar.visible := false;	//07 Aug 2013	NDL	Par 31804
	
	if not self.isSaveNext then
		self.myDutyDocHSCode := null;
		self.cmbHSCodeCode.listIndex:=-1;
		self.cmbConsignee.listIndex:=-1;
		self.cmbBOL.listIndex:=-1;
		self.cmbBOL.text := null;
		self.cmbPOD.listIndex:=-1;
		self.cmbPOL.listIndex:=-1;
		self.txtDO.text:=null;
		self.txtDOExp.text:=null;
		self.cmbPacking.listIndex := -1;
		//self.txtOrigin.text := null;
		self.cmbOrigin.listIndex := -1;	//08 Aug 2013	NDL	Par 32305
		self.txtQuantity.text := null;
		self.txtVolume.text := null;
		self.txtGrossWeight.text := null;
		self.txtNetWeight.text := null;
		self.cmbCurrency.listIndex := -1;
		self.txtForeignValue.text := null;
		self.txtLocalValue.text := (0.0).Decimal.asCurrencyJMT;
		self.txtLocalFreight.text := null;
		self.txtLocalIns.text := (0.0).Decimal.asCurrencyJMT;
		self.txtNetValue.text := (0.0).Decimal.asCurrencyJMT;
		self.txtRatePercent.text := null;
		self.txtDutyCode.text := null;
		self.txtDuty.text := (0.0).Decimal.asCurrencyJMT;
	
		self.grpCar.visible := false;
		self.txtVCCNum.text := null;
		self.txtVccDate.setDate( null );
		self.cmbVehMake.listIndex := -1;
		self.cmbVehModel.listIndex := -1;
		self.cmbVehType.listIndex := -1;
		self.txtChassis.text := null;
		self.txtEngine.text := null;
		self.cmbVehColour.listIndex := -1;
		self.txtNumPlate.text := null;
		
		self.chkDutyExempt.value := false;
		if self.myDutyDoc &lt;&gt; null and self.myDutyDoc.type &lt;&gt; null then
			billType := app.myDutyDocRoot.allDutyDocTypes[self.myDutyDoc.type];
			if billType &lt;&gt; null then
				self.chkDutyExempt.value := ( not billType.dutyCharged );
			endif;
		endif;
		self.txtDutyExempt.text := null;
		self.txtExemptSource.text := null;
		self.txtExemptBenefit.text := null;
		
		self.doClickDutyExempt();
	endif;

epilog

end;</source>
    </JadeMethod>
