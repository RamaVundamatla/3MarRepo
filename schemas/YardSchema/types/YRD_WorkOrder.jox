    <JadeMethod name="doSaveToDoWorkOrderProxy" id="15ead02f-cbdc-469d-9ae6-46e7c885fdc0">
        <updating/>
        <source>doSaveToDoWorkOrderProxy(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Dec 2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
14 Mar 2023 navma1  ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Screen
24 Mar 2023 navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars
	wodtl 			: CM_WorkOrderDtl;
	invalidWodDtl 	: Boolean; 

begin 

	wodtl := self.myPxyTask;
	
	if wodtl = null then
		return true; //No task selected - Form just loaded
	endif;
	
	on Exception do app.handleDeletedObject(exception, wodtl, invalidWodDtl); 

	if invalidWodDtl then
		return true;
	endif;
	
	self.doSaveReqByDT(wodtl);																//24.3.2023 navhl20	#57301[57303]
	self.doSaveToDoSpecialRate(wodtl.CM_WorkOrderToDoDtl);									//14.03.2023 navma1  #56840:[54265]
	self.doSaveToDoTaskDetails(wodtl.CM_WorkOrderToDoDtl);									//14.03.2023 navhl20 #56840:[54265]
	
	// Saving To Do WorkOrder	
	if wodtl.isKindOf(CM_WodToDoNonOperational) then					
		return self.doSaveToDoNonOperational(wodtl.CM_WodToDoNonOperational);
	elseif wodtl.isKindOf(CM_WodToDoTrain) then					
		return self.doSaveToDoTrain(wodtl.CM_WodToDoTrain);
	elseif wodtl.isKindOf(CM_WodToDoVBS) then					
		return self.doSaveToDoVbs(wodtl.CM_WodToDoVBS);
	elseif wodtl.isKindOf(CM_WodToDoVehicleVisit) then					
		return self.doSaveToDoVehicleVisit(wodtl.CM_WodToDoVehicleVisit);
	elseif wodtl.isKindOf(CM_WodToDoVoyage) then					
		return self.doSaveToDoVoyage(wodtl.CM_WodToDoVoyage);
	elseif wodtl.isKindOf(CM_WodToDoWagon) then					
		return self.doSaveToDoWagon(wodtl.CM_WodToDoWagon);
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveVoyageProxy" id="c0044179-98fa-401c-9942-31aeb98a5409">
        <updating/>
        <source>doSaveVoyageProxy(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
24 Mar 2023 navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars
	wodtl 			: CM_WorkOrderDtl;
	invalidWodDtl 	: Boolean; 
begin 

	wodtl := self.myPxyTask;
	
	if wodtl = null then
		return true; //No task selected - Form just loaded
	endif;
	
	on Exception do app.handleDeletedObject(exception, wodtl, invalidWodDtl); 

	if invalidWodDtl then
		return true;
	endif;
	
	self.doSaveReqByDT(wodtl);													//24.3.2023 navhl20	#57301[57303]
	
	// saving Voyage WorkOrder	
	if wodtl.isKindOf(CM_WodShiftMovement) then					
		 return self.doSaveShiftMovement(wodtl.CM_WodShiftMovement);
	elseif wodtl.isKindOf(CM_WodCargoRequest) then
		 return self.doSaveCargoRequest(wodtl.CM_WodCargoRequest);		
	elseif wodtl.isKindOf(CM_WodTimeChange) then						
		return self.doSaveTimeChange(wodtl.CM_WodTimeChange);
	elseif wodtl.isKindOf(CM_WodExtension) then
		 return self.doSaveExtension(wodtl.CM_WodExtension);
	elseif wodtl.isKindOf(CM_WodWaterRequest) then			
		return self.doSaveWaterRequest(wodtl.CM_WodWaterRequest);
	elseif wodtl.isKindOf(CM_WodHMSRequestCancel) then
		return self.doSaveHMSRequestCancel(wodtl.CM_WodHMSRequestCancel);
	elseif wodtl.isKindOf(CM_WodMarineServicesInitial) then
		 return self.doSaveMarineInitial(wodtl.CM_WodMarineServicesInitial);
	elseif wodtl.isKindOf(CM_WodMarineServicesDepart) then
		 return self.doSaveMarineDepart(wodtl.CM_WodMarineServicesDepart);
	elseif wodtl.isKindOf(CM_WodVoyageRequest) then
		 return self.doSaveVoyageRequest(wodtl.CM_WodVoyageRequest);			
	elseif wodtl.isKindOf(CM_WodPermitRequest) then
		 return self.doSavePermitRequest(wodtl.CM_WodPermitRequest);
	elseif wodtl.isKindOf(CM_WodBillingAdjustment) then
		 return self.doSaveBillingAdjustment(wodtl.CM_WodBillingAdjustment);
	endif;

	return true;	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveVoyageRequest" id="838218d1-8193-4a5b-b93b-effd70f212e5">
        <source>doSaveVoyageRequest(_wodtl : CM_WodVoyageRequest input):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	
	estimatedArrivalTS 	 	   : TimeStamp;
	estimatedDepartureTS	   : TimeStamp;
	cargoOperatorCodeDischarge : String;
	cargoOperatorCodeLoad 	   : String;
	commodityCode			   : String;
	externalCode			   : String;
	portCode1 				   : String;
	portCode2 				   : String;
	portCode4				   : String;
	portCode5				   : String;
	remarks 				   : String;
	vesselCategoryCode 		   : String;
	vesselCode				   : String;
	visitTypeCode			   : String;
	voyageCode 				   : String;
	voyageCodeIn 			   : String;
	voyageCodeOut			   : String;
	voyageOperatorCode 		   : String;
	tmpOp 					   : CM_Operator;
	tmpTS 					   : TimeStamp;
	tmpPort 				   : CM_Port;
	tmpVC 					   : HMS_VesselCategory;
	tmpVT					   : HMS_VisitType;
begin

	tmpOp := self.cmbOpCargoDischVR.listObject.CM_Operator;
	if tmpOp &lt;&gt; null then
		cargoOperatorCodeDischarge := tmpOp.code;
	endif;

	tmpOp := self.cmbOpCargoLoadVR.listObject.CM_Operator;
	if tmpOp &lt;&gt; null then
		cargoOperatorCodeLoad := tmpOp.code;
	endif;

	commodityCode := _wodtl.commodityCode;

	tmpTS.setDate(self.txtEstArrVR.getDate());	
	tmpTS.setTime(self.txtEstArrTimeVR.getTime());
	tmpTS			   := self.localToSystemTime(tmpTS);	
	estimatedArrivalTS := tmpTS;

	tmpTS.setDate(self.txtEstDepVR.getDate());	
	tmpTS.setTime(self.txtEstDepTimeVR.getTime());
	tmpTS 				 := self.localToSystemTime(tmpTS);	
	estimatedDepartureTS := tmpTS;
	
	externalCode := _wodtl.externalCode;
	
	tmpPort := self.cmbPortOriginVR.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		portCode1 := tmpPort.code;
	endif;
	
	tmpPort := self.cmbPortLastCallVR.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		portCode2 := tmpPort.code;
	endif;
	
	
	tmpPort := self.cmbPortNextPortVR.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		portCode4 := tmpPort.code;
	endif;
	
	tmpPort := self.cmbPortLastVR.listObject.CM_Port;
	if tmpPort &lt;&gt; null then
		portCode5 := tmpPort.code;
	endif;

	tmpVC := self.cmbVesselCatVR.listObject.HMS_VesselCategory;
	if tmpVC &lt;&gt; null then
		vesselCategoryCode :=  tmpVC.code;
	endif;
	
	vesselCode := _wodtl.vesselCode;
	
	tmpVT := self.cmbVisitTypeVR.listObject.HMS_VisitType;
	if tmpVT &lt;&gt; null then
		visitTypeCode := tmpVT.code;
	endif;
	
	voyageCode := _wodtl.voyageCode;
	
	voyageCodeIn  := self.txtCodeVoyageInVR.text.trimBlankCharacters;
	voyageCodeOut := self.txtCodeVoyageOutVR.text.trimBlankCharacters;
	
	tmpOp := self.cmbOpVoyageVR.listObject.CM_Operator;
	if tmpOp &lt;&gt; null then
		voyageOperatorCode := tmpOp.code;
	endif;
	
	remarks := self.txtGeneralRemarksVR.text; // TFS 51963
	
	_wodtl.setProxyVoyageRequest(	cargoOperatorCodeDischarge,
									cargoOperatorCodeLoad,
									commodityCode,
									estimatedArrivalTS,
									estimatedDepartureTS,
									externalCode,
									portCode1,
									portCode2,
									portCode4,
									portCode5,
									vesselCategoryCode,
									vesselCode,
									visitTypeCode,
									voyageCode,
									voyageCodeIn,
									voyageCodeOut,
									voyageOperatorCode,
									remarks,
									self.chkHasCargoVR.value);
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodVoyageRequest" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveWaterRequest" id="763388f9-8c4d-4955-9a1e-bd50e29813d3">
        <source>doSaveWaterRequest(_wodtl : CM_WodWaterRequest input):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	fromDateTime, 
	toDateTime   : TimeStamp;
	resourceType : HMS_ResourceType;
	resource     : HMS_Resource;
	transferType : Integer;

begin
	resourceType := self.cmbResourceType.listObject.HMS_ResourceType;
	resource     := self.cmbResource.listObject.HMS_Resource;
	
	fromDateTime.setDate(self.txtFromDate.getDate);
	fromDateTime.setTime(self.txtFromTime.getTime);
	toDateTime.setDate(self.txtToDate.getDate);
	toDateTime.setTime(self.txtToTime.getTime);
	
	if self.cmbWTransferType.listIndex &gt; 0 then
		transferType := self.cmbWTransferType.listObject.CM_VoyageJobTransferType.id;
	endif;
	
	_wodtl.setProxyWodWaterRequest(	fromDateTime,
									toDateTime,
									self.txtUnitsUsed.text.asRealJMT,
									transferType,
									resource,
									resourceType);
									
		return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodWaterRequest" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectItem" id="95ed72b2-715b-4e63-a899-53d5194385cb">
        <source>doSelectItem(_obj : CM_Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jun 2023 navhl20 ChangeRequest 57745: EUP - Delivery Dispatch – Allocation List - Road
11 Jul 2023 navhl20 Defect 59092: EUP - On the Add Cargo form the Cargo SubType list is empty
*/

vars
	row,idx : Integer;
	tbl 	: CM_DataTable;
begin
	tbl := self.tblItems;
	foreach idx in 1 to tbl.rows do
		tbl.accessRow(idx).backColor := White;
	endforeach;
	if _obj = null then									//11.7.2023 navhl20 #59092
		return;
	endif;
	if tbl.findObjectInRow(_obj, row) then
		tbl.accessedRow.backColor := LightGreen;
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doSortTask" id="9e747bdc-723a-4833-86c1-f7c0c33bb588">
        <updating/>
        <source>doSortTask(_direction : Integer; _task : CM_WorkOrderDtl input) protected, updating;


/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	currentPos,
	maxPos     : Integer;
	workOrder  : CM_WorkOrder;
begin
	if _task = null then
		return;
	endif;
	
	workOrder  := self.myPxyWorkOrder;
	maxPos     := workOrder.allWoDtls.size;
	currentPos := workOrder.allWoDtls.indexOf(_task);
	
	if _direction = self.MoveDirection_Up then //decreasing the pos
		if currentPos &gt; 1 then
			workOrder.allWoDtls.remove(_task);
			workOrder.allWoDtls.insert(currentPos - 1, _task);
			_task.setParent(workOrder);
			self.displayTasks(_task);									//17.03.2022 navma1 #52351
		endif;
	elseif _direction = MoveDirection_Down then //increasing the pos
		if currentPos &lt; maxPos then
			workOrder.allWoDtls.remove(_task);
			workOrder.allWoDtls.insert(currentPos + 1, _task);
			_task.setParent(workOrder);		
			self.displayTasks(_task);									//17.03.2022 navma1 #52351
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_task" type="CM_WorkOrderDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblCargoContextMenu" id="500558a3-1a00-4cad-a354-91b536860582">
        <updating/>
        <source>doTblCargoContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
04 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
25 Jan 2022 navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars
	xLeft 	: Real;
	yTop	: Real;
	
begin
	xLeft := x;
	yTop := y;
	
	self.mnuRemoveTi.visible := true;					//7.2.2023 navhl20 #55443[54991]
	self.mnuColumnOrganiser.userObject := cntrl;		//7.2.2023 navhl20 #55443[54991]
	
	if self.tblSelectedCargo.allSelectedObjects.size = 0 then	
		self.mnuRemoveTi.enabled := false;
	else	
		self.mnuRemoveTi.enabled := true;
	endif;
	
	if self.myPxyWorkOrder.taskStatus &lt;&gt; WO_STATUS_PENDING and 			//06.03.2023 navma1 #56457:[56458]
	   self.myPxyWorkOrder.taskStatus &lt;&gt; WO_STATUS_USERENTRY then
	   self.mnuRemoveTi.enabled := false;
	endif;
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	self.popupMenu(self.mnuWorkOrder, xLeft.Integer, yTop.Integer);

	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doWorkOrderNew" id="abae0c81-0f49-411c-85b2-3316c3c31c74">
        <updating/>
        <source>doWorkOrderNew() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
11 April 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin
	self.workOrderMode := self.MODE_ADD;
	
	self.myWorkOrder := null;
	
	self.clearControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableControlsForMode" id="ea7ac217-74ab-4bb6-a6ea-a111d0f0eac9">
        <source>enableControlsForMode();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin
	
	if self.workOrderMode = MODE_ADD then
		self.txtWorkOrderId.enabled := true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="enableSelectCargoBtn" id="dbf68509-51e5-499c-85b7-b0f846db3077">
        <source>enableSelectCargoBtn();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
14 Sep 2023 navhl20 Bug 60510: MTN - Work Order Enquiry Release Cargo Rail not populating release request details
*/

vars
	isNull		: Boolean;
begin
	
	if self.myPxyTask = null then
		self.btnSelectCargo.enabled := false;
		return;
	endif;
	
	self.btnSelectCargo.enabled 		 := true;	
	
	if self.isApproved then
		self.btnSelectCargo.enabled 	 := false;
		self.btnCreateCargo.enabled 	 := false;	
		self.btnSelectChildCargo.enabled := false;
		return;
	endif;
	
	if self.myPxyTask.isKindOf(CM_WodRelease) then
		if self.optBtnRelease.value = true then
			if self.cmbReleaseRequest.listObject = null then	
				self.btnCreateCargo.enabled := false;			//14.9.2023 navhl20 #60510
			endif;
		elseif self.optBtnBooking.value = true then
			if self.cmbBooking.listObject = null then			//04.07.2023 navma1 #58952
				self.btnCreateCargo.enabled := false;			//14.9.2023 navhl20 #60510
			endif;
		endif;
		
	elseif self.myPxyTask.isKindOf(CM_WodReceive) then
		if self.cmbTransMode.text = TI_TRANSMODE_SHIP_STR then	//06.7.2023 navhl20 #58952
			if self.cmbBol.listObject = null then
				isNull := true;
			endif;
		else
			if self.cmbBooking.listObject = null then
				isNull := true;
			endif;
		endif;
		if isNull then
			//self.btnSelectCargo.enabled := false;				//14.9.2023 navhl20 #60510
			self.btnCreateCargo.enabled := false;
		endif;
	endif;

	self.btnSelectChildCargo.enabled := self.btnSelectCargo.enabled;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="enableTaskActions" id="ab2b432b-dde7-4769-b3d4-fa09d14c4db6">
        <source>enableTaskActions();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 March 2022		navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin
	
	self.btnTaskAdd.enabled 	 := true;
	
	
	if not self.isUseYardJobs then
		self.btnTaskUp.enabled       := false;
		self.btnTaskDown.enabled     := false;
		self.btnTaskDelete.enabled   := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="filterBookingCombo" id="cc3e6d10-d50f-4407-93ee-5ea73e7ea6dc">
        <updating/>
        <source>filterBookingCombo(_voyage: CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/03/2023	navcs2	ChangeRequest 55443:[54991]: Receive Cargo Work Order - Enhancements
29 Mar 2023 navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
*/

vars
	iter 	: Iterator;
	booking	: CM_BookingRef; 
begin
	self.cmbBooking.clear();
	
	iter := self.myTerminal.allBookingRefsByStatusRef.createIterator;
	self.myTerminal.allBookingRefsByStatusRef.startKeyGeq(BOOKING_REF_PENDING, null, iter);
	self.cmbBooking.addItem("");																//29.3.2023 navhl20	#55443[54991]
	while iter.next(booking) do
		if booking.myVoyage = _voyage then
			self.cmbBooking.addItemObject(booking.bookingReference, booking);
		endif;
	endwhile;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="filterDischargePort" id="50ded5ec-eec7-4641-962d-6b18a1040353">
        <updating/>
        <source>filterDischargePort(_imexStatus : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	port : CM_Port;

begin
	if _imexStatus &lt;&gt; TI_IMEX_STATUS_IMPORT then
		self.cmbDischargePort.enabled := true;
		return;
	endif;
	port						    := self.myTerminal.getDefaultPort;
	self.cmbDischargePort.listIndex := self.cmbDischargePort.findObject(port);
	self.cmbDischargePort.enabled   := false;
epilog

end;</source>
        <Parameter name="_imexStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fldCargo_click" id="049bfc4f-d520-4a6e-8a7c-6650fd912934">
        <controlMethod name="Folder::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldCargo_click(folder: Folder input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2024 navhl20 Bug 64258: MTN - Cargo work order takes significant time to click between tasks
30 May 2024 navhl20 Bug 64101: EUP - For the Pack Job the parent and child details are empty on the Complete Job form
04 Nov 2024 navbs1 	Bug MTN-19888: MTN - Work Order Pack to mirror Receive Cargo Work Order
*/

vars

begin
	if folder.topSheet = self.shtSelectedTis then 			//30.05.2024 navhl20 #64101
		if self.tblSelectedCargo.rows = 1 then
			self.loadTabCargoTis();
		elseif  self.tblSelectedCargo.accessRow(2).itemObject = null then
			self.loadTabCargoTis();
		endif;
		
		if self.myPxyTask.isKindOf(CM_WodPack) and self.tblChildItems.rows = 1 then 		//04.11.2024 navbs1 #19888
			self.buildTblChildItems();
		endif;
	endif;
epilog

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="fldCargo_querySheetChg" id="0c384a73-d2fe-4aab-8a9c-3861b6413b0f">
        <controlMethod name="Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldCargo_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jun 2024	navhl20	Defect 64433: Selected Cargo Items tab is disabled with using the arrow keys when creating ToDo Task work orders
04 Nov 2024 navbs1  Bug MTN-19888: MTN - Work Order Pack to mirror Receive Cargo Work Order

*/

vars

begin
	if newSheet = self.shtSelectedTis then
		if self.tblSelectedCargo.rows = 1 then
			self.loadTabCargoTis();
		elseif  self.tblSelectedCargo.accessRow(2).itemObject = null then
			self.loadTabCargoTis();
		endif;
		
		if self.myPxyTask.isKindOf(CM_WodPack) and self.tblChildItems.rows = 1 then 		//04.11.2024 navbs1 #19888
			self.buildTblChildItems();
		endif;
	endif;
	return true;
epilog

end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getActivePorts" id="f4e7c178-1a9c-4d63-8322-b3d8a4dbdccd">
        <source>getActivePorts (_wod : CM_WorkOrderVoyageDtl ; _allPorts : CM_PortByCodeDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	voyage  : CM_Voyage;
	port	: CM_Port;
begin
	
	if _wod.isKindOf(CM_WodVoyageRequest) then
		voyage := _wod.CM_WodVoyageRequest.getMyVoyageObject();
		
		foreach port in voyage.allPorts discreteLock do 
			_allPorts.addNoDuplicates(port,false);
		endforeach;
	else
		app.myRoot.allActivePorts.copy(_allPorts);
	endif;
	
	
epilog

end;</source>
        <Parameter name="_wod" type="CM_WorkOrderVoyageDtl"/>
        <Parameter name="_allPorts" type="CM_PortByCodeDict" usage="input"/>
    </JadeMethod>
