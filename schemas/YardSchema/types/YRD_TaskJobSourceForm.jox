    <JadeMethod name="delete" id="ac4b41c7-d550-418d-a431-27c21dc81009">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwrd1	Initial creation

*/

vars
	pxyWorkOrder : CM_WorkOrder;
begin

	if self.deleteProxy then
		pxyWorkOrder := self.myProxySource.myParent.CM_WorkOrder;
		delete pxyWorkOrder;
	endif;

epilog

end;</source>
