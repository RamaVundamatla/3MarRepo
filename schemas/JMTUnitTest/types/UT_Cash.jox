    <JadeMethod name="uClearCashConfig" id="b4f38c3d-ffd1-4853-8e3c-51c6f868e7a8">
        <source>uClearCashConfig();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 December 2012	cnwjre1	Initial creation

*/

vars
	terminal	: CM_Terminal;
	bank		: CM_Bank;
begin
	terminal := CM_Root.firstInstance.allTerminals["JT1"];			// "JBL"
	
	beginTransaction;

	foreach bank in terminal.companies do
		bank.allProformaCriteria.purge();
		bank.allSelectedProformaQueryProps.clear();
	endforeach;
	
	commitTransaction;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateCashCargo" id="f56e659f-5f56-4bfc-b9b0-b117eb9d8ade">
        <updating/>
        <source>uCreateCashCargo() updating;

/*	NOTE: For this to work with a different terminal, debtor Cash Debtor 1 to 4 as a cash-only debtors, 
			the user used to run this (typically UnitTest) needs security to create BOLs (set all access is simplest).
			Also needs block stacks BS2 and BS3.
		To get useful invoice lines from this also needs the transaction map set up for Import Release - Ship, Move and Storage at a minimum.
		USE THIS ONE rather than uCreateCargoForCash
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2012	cnwjre1	Initial creation

*/

vars
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
	allDebtors	: CM_DebtorSet;
begin
	// clear the cash debtor values
	create allDebtors transient;
	
	terminal := CM_Root.firstInstance.allTerminals["JT1"];
	debtor := CM_Root.firstInstance.myRootCompany.debtors["Cash Debtor 1"];
	allDebtors.add(debtor);
	debtor := CM_Root.firstInstance.myRootCompany.debtors["Cash Debtor 2"];
	allDebtors.add(debtor);
	debtor := CM_Root.firstInstance.myRootCompany.debtors["Cash Debtor 3"];
	allDebtors.add(debtor);
	debtor := CM_Root.firstInstance.myRootCompany.debtors["Cash Debtor 4"];
	allDebtors.add(debtor);

	foreach debtor in allDebtors do
		debtorTerminal := debtor.allDebtorTerminals[terminal];
	
		beginTransaction;

		debtorTerminal.allCashPayments.purge();
		debtorTerminal.allCashReceipts.purge();
		debtorTerminal.allConsolidatedCashTrx.purge();
		debtorTerminal.setConsolidatedBalance();

		commitTransaction;
	endforeach;
	
	// create import cargo for John's Terminal cash usage
	self.createMoreCargoForCash(true, true);		// 1st param = create invoice lines for extra moves, 2nd param = connect reefers for reefer daily charge
epilog
	delete allDebtors;
end;</source>
    </JadeMethod>
    <JadeMethod name="uPayBreakBulkSplitMerge" id="0c96427b-3f9f-4a7c-a14d-f439ff53b4bc">
        <updating/>
        <source>uPayBreakBulkSplitMerge() updating;
// cnwma1
/*

Purpose:		cnwjre1 test cash for break bulk split merge TFS 1990 where cargo is paid for then split and merged before
				release and the weight/volume-based charges and payments are split and merged along with the cargo so it can be released at any point
				with the appropriate charges and payents kept.  Charges and payments are also copied off when the cargo is zombied.
				This test covers paying for the all the cargo first then splitting it into 2 lots, merging back and releasing.  The invoice lines
				and payments should be split and merged back again so are all still there so the cargo can be released without an "insufficient cash" error.
Parameters:			


*/
constants
	Cargo_Type			: String = "UTREBAR";
vars
	date		: Date;
	tranTS		: TimeStamp;
	cargoTypeObj : CM_CargoType;
	bs1,bs2 	: CM_BlockStack;
	cargo , splitCargo	: CM_TrackedItem;
	moveController		: CMIF_MoveController;
	wle 		: CM_WorkListEntry;
	job : CM_Job;
	gateOut	: CM_GateArea;
	vvr		: CM_VehicleVisitRecord;
	customsAgent	: CM_CustomsAgent;
	debtor1		: CM_Debtor;
	drTerm		: CM_DebtorTerminal;
	services	: CM_ServiceByNameDict;
	service1,
	service2	: CM_Service;
	calcType	: CM_CalculationType;
	cashInvType,
	invType		: CM_InvoiceDesc;
	invLineType1	: CM_InvoiceLineDesc;
	terminal	: CM_Terminal;

begin

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );

	self.deleteInvoiceTransactionMap(1, 'UT_SplitMerge');
	self.deleteInvoiceType("UT_InvTypeWeight");
	self.deleteInvoiceService("UT_ServiceWeight1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight1", FORCED_ERASE);

	create services transient;
	invType := self.createInvoiceType("UT_InvTypeWeight", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeWeight not created");

	calcType := app.myRoot.allCalculationTypesByCode['CCT04'];		// cargo weight kilos
	self.assertNotNullMsg(calcType, "Calculation type CCT04 not found");
	
	service1 := self.createInvoiceService("UT_ServiceWeight1","weight1", calcType, null);
	self.assertNotNullMsg(service1, "UT_ServiceWeight1 not created");
 	services.add(service1);
	
	// charges customs agent
	invLineType1 := self.createInvoiceLineType("UT_LineTypeWeight1", calcType, invType, services, "SDT6");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeWeight1 not created");
	// agent and debtor, set rates
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor1 := customsAgent.myDebtor;
	self.setServiceRate(service1, debtor1, "01/01/2013".Date, 0.10);
	service2 := self.myBank.services["UT_ServiceX9"];
	self.setServiceRate(service2, debtor1, "01/01/2013".Date, 100.00);

	// Transaction map to charge receive as fixed charge and per-weight charge, and storage as per-weight
	self.tranMapLoadSplitMerge();

	//create bbk cargo type with allow duplicates
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	terminal := self.getTerminal();
	cashInvType := self.getInvoiceType("UT_CashInvType");		// cash receipt invoice type
	
	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(50000);
	cargo.setImExStatus(TI_IMEX_STATUS_IMPORT);
	cargo.setCustomsAgent(customsAgent);

	//terminal.setConfig(CashInvoiceType, cashInvType);
	commitTransaction;
	self.setDefaultBankCashInvoiceType(cashInvType);
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);

	// create a receive ship transaction to get the associated charges
	tranTS := app.actualTimeServer;
	date := tranTS.date;
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_REC_SHIP, true);
	// back-date the transactions 3 days to get storage now
	date := date - 3;
	self.setTransactionDate2(cargo, date);

	// pay for the cargo before split/merge
	drTerm := debtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm &lt;&gt; null, "Debtor/Terminal not found");
	self.cashTestSplitMerge(cargo, drTerm);
	
	//create block stack 2
	deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	
	
	create moveController transient;
	moveController.setMyTrackedItem(cargo);	
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	
	//queue the entire 50 to bs2
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setQuantity(50);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.myPrimaryQueuedLocation,bs2.myLocationsController);
	self.assertNotNull(cargo.allQueuedFutureMoves.first);
	wle:=cargo.allQueuedFutureMoves.first.myWorkListEntry;
	self.assertNotNull(wle);
	self.assertEqual(wle.quantity,50);
	job:=wle.job;
	self.assertNotNull(job);
	
	// actual move 20 to bs2 
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setQuantity(20);  //split move 20 to bs2
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.totalQuantity,30);
	self.assertEqual(cargo.totalWeight.Decimal,30000.Decimal);
	self.assertEqual(cargo.totalVolume.Real,30000.Real);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	self.assertEqual(bs2.myLocationsController.allTrackedItems.size,1);
	splitCargo:=bs2.myLocationsController.allTrackedItems.first;
	
	self.assertEqual(splitCargo.myCargoType,cargoTypeObj);
	self.assertEqual(splitCargo.id,cargo.id);
	self.assertEqual(splitCargo.totalQuantity,20);
	self.assertEqual(splitCargo.totalWeight.Decimal,20000.Decimal);
	self.assertEqual(splitCargo.totalVolume.Real,20000.Real);
	// check the original and split invoice lines and payments
	self.validateSplitMergeA(cargo, splitCargo);
	
	//test the merge
	//move another 10 from bs1 to bs2, will merge
	moveController.setMyTrackedItem(cargo);
	moveController.setMyWorkListEntry(wle);
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	moveController.setQuantity(10);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(cargo.totalQuantity,20);
	self.assertEqual(cargo.totalWeight.Decimal,20000.Decimal);
	self.assertEqual(cargo.totalVolume.Real,20000.Real);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);

	self.assertEqual(splitCargo.totalQuantity,30);
	self.assertEqual(splitCargo.totalWeight.Decimal,30000.Decimal);
	self.assertEqual(splitCargo.totalVolume.Real,30000.Real);
	// check the original and split invoice lines and payments
	self.validateSplitMergeB(cargo, splitCargo);

	//move the remaining 20 will null out all terminal coll so can't be found
	moveController.setMyTrackedItem(cargo);
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	moveController.setMyWorkListEntry(wle);
	moveController.setQuantity(20);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(cargo.totalQuantity,0);
	self.assertEqual(cargo.totalWeight.Decimal,0.Decimal);
	self.assertEqual(cargo.totalVolume.Real,0.Real);
	self.assertEqual(cargo.myPrimaryActualLocation,null);
	self.assertEqual(cargo.locationId,null);
	self.assertEqual(cargo.myTerminal,splitCargo.myTerminal);
	
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOffsiteTerminal.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnsiteTerminal.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnsiteOperatorTerminal.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnshipVoyage.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnsiteVoyage.name),null);
	self.assertEqual(cargo.allWorklistEntries.size,0);
	self.assertEqual(cargo.state,TI_STATE_MERGED);
	
	
	self.assertEqual(splitCargo.totalQuantity,50);
	self.assertEqual(splitCargo.totalWeight.Decimal,50000.Decimal);
	self.assertEqual(splitCargo.totalVolume.Real,50000.Real);
	
	//check original cargo and split cargo have now wles or queued future moves
	self.assertEqual(cargo.allWorklistEntries.size,0);
	self.assertEqual(cargo.allQueuedFutureMoves.size,0);
	self.assertEqual(cargo.allQueues.size,0);
	self.assertEqual(splitCargo.allWorklistEntries.size,0);
	self.assertEqual(splitCargo.allQueuedFutureMoves.size,0);
	self.assertEqual(splitCargo.allQueues.size,0);
	// check the original and split invoice lines and payments
	self.validateSplitMergeC(cargo, splitCargo);
	
	//move splitCargo offsite
	gateOut := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	assertNotNull(gateOut);
	self.deleteVehicle(VehicleNumOut);
	
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 50);
	vvr := self.gateOutGC(VehicleNumOut, "", "UTFRED", splitCargo, gateOut.getFirstExitGate, null);
	assertNotNull(splitCargo.getPrimaryLocation(QUEUE_MODE));
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, splitCargo);
	self.workVehicle( vvr );
	self.roadExit(vvr);
	// check the released invoice lines and payments
	self.validateSplitMergeD(cargo, splitCargo);
	
epilog
	app.isGarbageCollectionProcess:=false;
	self.resetDefaultTranMap();
	delete moveController;
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="uPayBreakBulkSplitMerge2" id="e13cd0b8-fa90-420e-9294-3222765a0576">
        <updating/>
        <source>uPayBreakBulkSplitMerge2() updating;
// cnwma1
/*

Purpose:		cnwjre1 test cash for break bulk split merge TFS 1990 where cargo is paid for then split and merged before
				release and the weight/volume-based charges and payments are split and merged along with the cargo so it can be released at any point
				with the appropriate charges and payents kept.  Charges and payments are also copied off when the cargo is zombied.
				Cargo is moved to BS2 and BS3 and released from there.
				Split cargo is released in multiple steps after it is all paid for.
Parameters:			


*/
constants
	Cargo_Type			: String = "UTREBAR";
vars
	date		: Date;
	tranTS		: TimeStamp;
	cargoTypeObj : CM_CargoType;
	bs1,bs2,bs3 	: CM_BlockStack;
	cargo , splitCargo	: CM_TrackedItem;
	moveController		: CMIF_MoveController;
	wle 		: CM_WorkListEntry;
	job : CM_Job;
	gateOut	: CM_GateArea;
	vvr		: CM_VehicleVisitRecord;
	customsAgent	: CM_CustomsAgent;
	debtor1		: CM_Debtor;
	drTerm		: CM_DebtorTerminal;
	services	: CM_ServiceByNameDict;
	service1,
	service2	: CM_Service;
	calcType	: CM_CalculationType;
	cashInvType,
	invType		: CM_InvoiceDesc;
	invLineType1	: CM_InvoiceLineDesc;
	terminal	: CM_Terminal;
begin

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );

	self.deleteInvoiceTransactionMap(1, 'UT_SplitMerge');
	self.deleteInvoiceType("UT_InvTypeWeight");
	self.deleteInvoiceService("UT_ServiceWeight1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight1", FORCED_ERASE);

	create services transient;
	invType := self.createInvoiceType("UT_InvTypeWeight", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeWeight not created");

	calcType := app.myRoot.allCalculationTypesByCode['CCT04'];		// cargo weight kilos
	self.assertNotNullMsg(calcType, "Calculation type CCT04 not found");
	
	service1 := self.createInvoiceService("UT_ServiceWeight1","weight1", calcType, null);
	self.assertNotNullMsg(service1, "UT_ServiceWeight1 not created");
 	services.add(service1);
	
	// charges customs agent
	invLineType1 := self.createInvoiceLineType("UT_LineTypeWeight1", calcType, invType, services, "SDT6");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeWeight1 not created");
	// agent and debtor, set rates
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor1 := customsAgent.myDebtor;
	self.setServiceRate(service1, debtor1, "01/01/2013".Date, 0.10);
	service2 := self.myBank.services["UT_ServiceX9"];
	self.setServiceRate(service2, debtor1, "01/01/2013".Date, 100.00);

	// Transaction map to charge receive as fixed charge and per-weight charge, and storage as per-weight
	self.tranMapLoadSplitMerge();

	//create bbk cargo type with allow duplicates
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);

	gateOut := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	assertNotNull(gateOut);
	self.deleteVehicle(VehicleNumOut);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	terminal := self.getTerminal();
	cashInvType := self.getInvoiceType("UT_CashInvType");		// cash receipt invoice type
	
	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(50000);
	cargo.setImExStatus(TI_IMEX_STATUS_IMPORT);
	cargo.setCustomsAgent(customsAgent);
	
	///terminal.setConfig(CashInvoiceType, cashInvType);
	commitTransaction;
	self.setDefaultBankCashInvoiceType(cashInvType);
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);

	// create a receive ship transaction to get the associated charges
	tranTS := app.actualTimeServer;
	date := tranTS.date;
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_REC_SHIP, true);
	// back-date the transactions 3 days to get storage now
	date := date - 3;
	self.setTransactionDate2(cargo, date);

	// pay for the cargo before split/merge
	drTerm := debtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm &lt;&gt; null, "Debtor/Terminal not found");
	self.cashTestSplitMerge(cargo, drTerm);
	
	//create block stacks 2 and 3
	deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	deleteTerminalArea("UTBS3");
	bs3:=self.addBlockStack("UTBS3",200,null);
	self.assertNotNull(bs3);
	
	create moveController transient;
	moveController.setMyTrackedItem(cargo);	
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	
	//queue 20 to bs2
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setQuantity(20);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.myPrimaryQueuedLocation,bs2.myLocationsController);
	self.assertNotNull(cargo.allQueuedFutureMoves.first);
	wle:=cargo.allQueuedFutureMoves.first.myWorkListEntry;
	self.assertNotNull(wle);
	self.assertEqual(wle.quantity,20);
	job:=wle.job;
	self.assertNotNull(job);
	
	//move 20 to bs2 set move wle to 
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setQuantity(20);  //split move 20 to bs2
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.totalQuantity,30);
	self.assertEqual(cargo.totalWeight.Decimal,30000.Decimal);
	self.assertEqual(cargo.totalVolume.Real,30000.Real);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	self.assertEqual(bs2.myLocationsController.allTrackedItems.size,1);
	splitCargo:=bs2.myLocationsController.allTrackedItems.first;
	
	self.assertEqual(splitCargo.myCargoType,cargoTypeObj);
	self.assertEqual(splitCargo.id,cargo.id);
	self.assertEqual(splitCargo.totalQuantity,20);
	self.assertEqual(splitCargo.totalWeight.Decimal,20000.Decimal);
	self.assertEqual(splitCargo.totalVolume.Real,20000.Real);
	self.validateSplitMergeA(cargo, splitCargo);
	
	//move this first lot of 20 offsite
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 20);
	vvr := self.gateOutGC(VehicleNumOut, "", "UTFRED", splitCargo, gateOut.getFirstExitGate, null);
	assertNotNull(splitCargo.getPrimaryLocation(QUEUE_MODE));
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, splitCargo);
	self.workVehicle( vvr );
	self.roadExit(vvr);
	self.validateSplitMerge2A(cargo, splitCargo);
	
	//move another 20 in bs1 to bs3
	//queue it first
	delete moveController;
	create moveController transient;
	moveController.setMyTrackedItem(cargo);	
	moveController.setMyToPrimaryLocation(bs3.myLocationsController);
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setQuantity(20);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.myPrimaryQueuedLocation,bs3.myLocationsController);
	self.assertNotNull(cargo.allQueuedFutureMoves.first);
	wle:=cargo.allQueuedFutureMoves.first.myWorkListEntry;
	self.assertNotNull(wle);
	self.assertEqual(wle.quantity,20);
	job:=wle.job;
	self.assertNotNull(job);

	moveController.setMyTrackedItem(cargo);
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyToPrimaryLocation(bs3.myLocationsController);
	moveController.setQuantity(20);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(cargo.totalQuantity,10);
	self.assertEqual(cargo.totalWeight.Decimal,10000.Decimal);
	self.assertEqual(cargo.totalVolume.Real,10000.Real);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	splitCargo:=bs3.myLocationsController.allTrackedItems.first;

	self.assertEqual(splitCargo.myCargoType,cargoTypeObj);
	self.assertEqual(splitCargo.id,cargo.id);
	self.assertEqual(splitCargo.totalQuantity,20);
	self.assertEqual(splitCargo.totalWeight.Decimal,20000.Decimal);
	self.assertEqual(splitCargo.totalVolume.Real,20000.Real);
	// check the original and split invoice lines and payments
	//self.validateSplitMergeB(cargo, splitCargo);
	
	//move this second lot of 20 offsite
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 20);
	vvr := self.gateOutGC(VehicleNumOut, "", "UTFRED", splitCargo, gateOut.getFirstExitGate, null);
	assertNotNull(splitCargo.getPrimaryLocation(QUEUE_MODE));
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, splitCargo);
	self.workVehicle( vvr );
	self.roadExit(vvr);
	// check the original and split invoice lines and payments
	self.validateSplitMerge2B(cargo, splitCargo);
	
	
	//move remaining cargo offsite
	
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 10);
	vvr := self.gateOutGC(VehicleNumOut, "", "UTFRED", cargo, gateOut.getFirstExitGate, null);
	assertNotNull(cargo.getPrimaryLocation(QUEUE_MODE));
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cargo);
	self.workVehicle( vvr );
	self.roadExit(vvr);
	
epilog
	app.isGarbageCollectionProcess:=false;
	delete moveController;
	delete services;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="uPayBreakBulkSplitMergeVol" id="6e374782-c2c2-44e7-9639-366c751a0895">
        <updating/>
        <source>uPayBreakBulkSplitMergeVol() updating;
// cnwma1
/*

Purpose:		cnwjre1 test cash for break bulk split merge TFS 1990 where cargo is paid for then split and merged before
				release and the weight/volume-based charges and payments are split and merged along with the cargo so it can be released at any point
				with the appropriate charges and payents kept.  Charges and payments are also copied off when the cargo is zombied.
				This test covers paying for the all the cargo first then splitting it into 2 lots, merging back and releasing.  The invoice lines
				and payments should be split and merged back again so are all still there so the cargo can be released without an "insufficient cash" error.
				Copy of tPayBreakBulkSplitMerge with charges by volume (original charges by weight)
Parameters:			


*/
constants
	Cargo_Type			: String = "UTREBAR";
vars
	date		: Date;
	tranTS		: TimeStamp;
	cargoTypeObj : CM_CargoType;
	bs1,bs2 	: CM_BlockStack;
	cargo , splitCargo	: CM_TrackedItem;
	moveController		: CMIF_MoveController;
	wle 		: CM_WorkListEntry;
	job : CM_Job;
	gateOut	: CM_GateArea;
	vvr		: CM_VehicleVisitRecord;
	customsAgent	: CM_CustomsAgent;
	debtor1		: CM_Debtor;
	drTerm		: CM_DebtorTerminal;
	services	: CM_ServiceByNameDict;
	service1,
	service2	: CM_Service;
	calcType	: CM_CalculationType;
	cashInvType,
	invType		: CM_InvoiceDesc;
	invLineType1	: CM_InvoiceLineDesc;
	terminal	: CM_Terminal;

begin

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );

	self.deleteInvoiceTransactionMap(1, 'UT_SplitMerge');
	self.deleteInvoiceType("UT_InvTypeVolume");
	self.deleteInvoiceService("UT_ServiceVolume1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeVolume1", FORCED_ERASE);

	create services transient;
	invType := self.createInvoiceType("UT_InvTypeVolume", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeVolume not created");

	calcType := app.myRoot.allCalculationTypesByCode['CCT03'];		// cargo volume
	self.assertNotNullMsg(calcType, "Calculation type CCT03 not found");
	
	service1 := self.createInvoiceService("UT_ServiceVolume1","Volume1", calcType, null);
	self.assertNotNullMsg(service1, "UT_ServiceVolume1 not created");
 	services.add(service1);
	
	// charges customs agent
	invLineType1 := self.createInvoiceLineType("UT_LineTypeVolume1", calcType, invType, services, "SDT6");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeVolume1 not created");
	// agent and debtor, set rates
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor1 := customsAgent.myDebtor;
	self.setServiceRate(service1, debtor1, "01/01/2013".Date, 0.10);
	service2 := self.myBank.services["UT_ServiceX9"];
	self.setServiceRate(service2, debtor1, "01/01/2013".Date, 100.00);

	// Transaction map to charge receive as fixed charge and per-Volume charge, and storage as per-Volume
	self.tranMapLoadSplitMergeVolume();

	//create bbk cargo type with allow duplicates
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	terminal := self.getTerminal();
	cashInvType := self.getInvoiceType("UT_CashInvType");		// cash receipt invoice type
	
	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(25000);
	cargo.setImExStatus(TI_IMEX_STATUS_IMPORT);
	cargo.setCustomsAgent(customsAgent);

	///terminal.setConfig(CashInvoiceType, cashInvType);
	commitTransaction;
	self.setDefaultBankCashInvoiceType(cashInvType);
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,25000.Decimal);

	// create a receive ship transaction to get the associated charges
	tranTS := app.actualTimeServer;
	date := tranTS.date;
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_REC_SHIP, true);
	// back-date the transactions 3 days to get storage now
	date := date - 3;
	self.setTransactionDate2(cargo, date);

	// pay for the cargo before split/merge
	drTerm := debtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm &lt;&gt; null, "Debtor/Terminal not found");
	self.cashTestSplitMergeVolume(cargo, drTerm);
	
	//create block stack 2
	deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	
	
	create moveController transient;
	moveController.setMyTrackedItem(cargo);	
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	
	//queue the entire 50 to bs2
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setQuantity(50);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.myPrimaryQueuedLocation,bs2.myLocationsController);
	self.assertNotNull(cargo.allQueuedFutureMoves.first);
	wle:=cargo.allQueuedFutureMoves.first.myWorkListEntry;
	self.assertNotNull(wle);
	self.assertEqual(wle.quantity,50);
	job:=wle.job;
	self.assertNotNull(job);
	
	// actual move 20 to bs2 
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setQuantity(20);  //split move 20 to bs2
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.totalQuantity,30);
	self.assertEqual(cargo.totalWeight.Decimal,15000.Decimal);
	self.assertEqual(cargo.totalVolume.Real,30000.Real);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	self.assertEqual(bs2.myLocationsController.allTrackedItems.size,1);
	splitCargo:=bs2.myLocationsController.allTrackedItems.first;
	
	self.assertEqual(splitCargo.myCargoType,cargoTypeObj);
	self.assertEqual(splitCargo.id,cargo.id);
	self.assertEqual(splitCargo.totalQuantity,20);
	self.assertEqual(splitCargo.totalWeight.Decimal,10000.Decimal);
	self.assertEqual(splitCargo.totalVolume.Real,20000.Real);
	// check the original and split invoice lines and payments
	self.validateSplitMergeA(cargo, splitCargo);
	
	//test the merge
	//move another 10 from bs1 to bs2, will merge
	moveController.setMyTrackedItem(cargo);
	moveController.setMyWorkListEntry(wle);
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	moveController.setQuantity(10);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(cargo.totalQuantity,20);
	self.assertEqual(cargo.totalWeight.Decimal,10000.Decimal);
	self.assertEqual(cargo.totalVolume.Real,20000.Real);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);

	self.assertEqual(splitCargo.totalQuantity,30);
	self.assertEqual(splitCargo.totalWeight.Decimal,15000.Decimal);
	self.assertEqual(splitCargo.totalVolume.Real,30000.Real);
	// check the original and split invoice lines and payments
	self.validateSplitMergeB(cargo, splitCargo);

	//move the remaining 20 will null out all terminal coll so can't be found
	moveController.setMyTrackedItem(cargo);
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	moveController.setMyWorkListEntry(wle);
	moveController.setQuantity(20);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(cargo.totalQuantity,0);
	self.assertEqual(cargo.totalWeight.Decimal,0.Decimal);
	self.assertEqual(cargo.totalVolume.Real,0.Real);
	self.assertEqual(cargo.myPrimaryActualLocation,null);
	self.assertEqual(cargo.locationId,null);
	self.assertEqual(cargo.myTerminal,splitCargo.myTerminal);
	
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOffsiteTerminal.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnsiteTerminal.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnsiteOperatorTerminal.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnshipVoyage.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnsiteVoyage.name),null);
	self.assertEqual(cargo.allWorklistEntries.size,0);
	self.assertEqual(cargo.state,TI_STATE_MERGED);
	
	
	self.assertEqual(splitCargo.totalQuantity,50);
	self.assertEqual(splitCargo.totalWeight.Decimal,25000.Decimal);
	self.assertEqual(splitCargo.totalVolume.Real,50000.Real);
	
	//check original cargo and split cargo have now wles or queued future moves
	self.assertEqual(cargo.allWorklistEntries.size,0);
	self.assertEqual(cargo.allQueuedFutureMoves.size,0);
	self.assertEqual(cargo.allQueues.size,0);
	self.assertEqual(splitCargo.allWorklistEntries.size,0);
	self.assertEqual(splitCargo.allQueuedFutureMoves.size,0);
	self.assertEqual(splitCargo.allQueues.size,0);
	// check the original and split invoice lines and payments
	self.validateSplitMergeC(cargo, splitCargo);
	
	//move splitCargo offsite
	gateOut := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	assertNotNull(gateOut);
	self.deleteVehicle(VehicleNumOut);
	
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 50);
	vvr := self.gateOutGC(VehicleNumOut, "", "UTFRED", splitCargo, gateOut.getFirstExitGate, null);
	assertNotNull(splitCargo.getPrimaryLocation(QUEUE_MODE));
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, splitCargo);
	self.workVehicle( vvr );
	self.roadExit(vvr);
	// check the released invoice lines and payments
	self.validateSplitMergeD(cargo, splitCargo);
	
epilog
	app.isGarbageCollectionProcess:=false;
	delete moveController;
	delete services;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="uPurgeCashDebtor" id="12c68b99-1ff9-47cb-8c0a-6a49b4e58cd5">
        <source>uPurgeCashDebtor();

/*

Purpose:			Delete all invoice and cash data for the given debtor

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2012	cnwjre1	Initial creation

*/

vars
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
	invoice	: CM_Invoice;
begin
	//terminal := CM_Root.firstInstance.allTerminals["DP1"];
//	debtor := CM_Root.firstInstance.myRootCompany.debtors["Douglas WOODS Esquire"];
	//debtor := CM_Root.firstInstance.myRootCompany.debtors["OLDCON"];
	//debtor := CM_Root.firstInstance.myRootCompany.debtors["RDT"];
	
	//terminal := CM_Root.firstInstance.allTerminals["MA"];
	//debtor := CM_Root.firstInstance.myRootCompany.debtors["MA"];
	//terminal := CM_Root.firstInstance.allTerminals["JT1"];
	//debtor := CM_Root.firstInstance.myRootCompany.debtors["Deb Debtor 2"];
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	
	self.zPurgeCashDebtor(debtorTerminal);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uReleaseFromTransferArea" id="1e8d0a8f-253f-4403-828d-6d19d0bafbfd">
        <updating/>
        <source>uReleaseFromTransferArea() updating;
// cnwma1
/*

Purpose:		Test cash owing on release from transfer area

Date			Who		Reason
9/09/2015		cnwjre1 Par 36361 tesing
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

vars

	releaseArea						: CM_BlockStack;
	consignee						: CM_ConsigneeConsignor;
	
	objSet							: ObjectSet;
	ti								: CM_TrackedItem;
	tiArray							: CM_TIArray;
	tiSet							: CM_TISet;
	
	deliveryReason					: Integer;
	count							: Integer;

	debtorType	: CM_DebtorType;
	invType			: CM_InvoiceDesc;
	invLineType1	: CM_InvoiceLineDesc;
	operator		: CM_Operator;
	debtor : CM_DebtorNode;
	service : CM_Service;
	drTerm	 : CM_DebtorTerminal;

	cashToPay,
	cashTotal	: Decimal[23,6];// [16,4]; // TFS 47529
	cashInvType	: CM_InvoiceDesc; // this doesn't seem to be run anymore;

	cashReceipt : CM_CashReceipt; // changed to 23,6 for consistency with other UTs
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	now			: TimeStamp;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;

	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
begin
	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type
	self.setDefaultBankCashInvoiceType(cashInvType);

	consignee := self.addConsigneeConsignor("UTCE3", "UTCE3", true, false, false);
	self.assertNotNull(consignee);
	debtor := consignee.debtor;
	if debtor = null then
		debtor := app.myRoot.myRootCompany.debtors["UT_Cash3"];
		beginTransaction;
		consignee.setDebtor(debtor.CM_Debtor);
		commitTransaction;
		drTerm := debtor.CM_Debtor.allDebtorTerminals[self.myTerminal];
	endif;
	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );

	// Voyage invoice type, ILT8 invoice line type, used in ship receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", "UT_ILT8", null, invType);
	// set service rate
	service := self.myBank.services["UT_ServiceX8"];		// for receive ship
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT8"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	// Yard invoice type, ILT19 invoice line type, used in yard and road release, charged to consignee, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", "UT_ILT19", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT19"];
	debtorType := app.myRoot.allDebtorTypes["SDT2"];	// consignee
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		// for move and road release
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	
	// Yard invoice type, ILT20 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT20", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT20"];
	debtorType := app.myRoot.allDebtorTypes["SDT2"];	// consignee
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 10.00);
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	self.tranMapLoadCashRelease();
	
	create tiArray transient;

	releaseArea := self.addReleaseTransArea("UTMHRELT1", 50, null);
	self.assertNotNull(releaseArea);
	self.opts.purge();
	self.opts.addAssoc("ReturnTIs", true);
	self.addQuickCargo(releaseArea, null, 2, tiArray);
	
	create tiSet transient;
	self.assertFalse(tiArray.isEmpty);
	
	tiSet.add(tiArray[1]);
	
	deliveryReason := DEL_SNT;
	app.myTrxDA.trxReleaseFromTransArea(tiSet, 0, consignee.code, "Deliv101", deliveryReason, app.myPassport);
	self.assertTrueMsg( not app.myPassport.allErrorWarnings.isEmpty, "Should be an insuffient funds warning/error..."); //error 87607
	self.assertTrueMsg( app.myPassport.allErrorWarnings.includesErrorCode(Cash_cargo_not_paid),"Errors should include " &amp; Cash_cargo_not_paid.String );
	// cargo should still be onsite
	foreach ti in tiSet do
		self.assertTrueMsg( ti.isOnSite, ti.id &amp; " should still be onsite");
	endforeach;
	
	// pay the bill
	create allAgents transient;
	agent := self.createProformaAgent(now, ti);
	allAgents.add(agent);
	
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;		// should be 20

	paymentMeth := app.myRoot.allPaymentMethods['UTCASH'];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");
	
	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					drTerm,				// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	self.assertTrueMsg(cashReceipt &lt;&gt; null, " Cash Receipt for on site cargo not created...");

	foreach cashPayment in cashReceipt.allCashPayments do
		if cashPayment.isProformaPayment then
			cashPaymentProForma := cashPayment;
		endif;
	endforeach;
	self.assertTrueMsg(cashPaymentProForma &lt;&gt; null, " Cash Payment Pro Forma for on site cargo not created...");
	self.assertTrueMsg(not ti.allCashPayments.isEmpty, " Pro Forma not on On Site Cargo...");

	deliveryReason := DEL_SNT;
	app.myTrxDA.trxReleaseFromTransArea(tiSet, 0, consignee.code, "Deliv101", deliveryReason, app.myPassport);
	// cargo should be offsite
	foreach ti in tiSet do
		self.assertTrueMsg( ti.isOffSite, ti.id &amp; " should be offsite");
	endforeach;
	// payments should be all for real charges now
	count := 0;
	foreach cashPayment in cashReceipt.allCashPayments do
		count := count + 1;
		self.assertNullMsg(cashPayment.myProformaDetail, "Released cargo is proforma");
		self.assertNotNullMsg(cashPayment.myInvoiceLine, "Released cargo no invoice line");
	endforeach;
	self.assertTrueMsg(count=1, " Cash Payment for released cargo");
	
epilog

	self.resetDefaultTranMap();							// 14/09/2015 cnwmh5
	if allAgents &lt;&gt; null then
		allAgents.purge;
		delete allAgents;
	endif;
	delete tiArray;
	delete objSet;
	delete tiSet;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="uTest1" id="763b6293-ab6f-44f2-87c2-414e30a2a507">
        <updating/>
        <source>uTest1() updating;
// test for creation of cargo onship then moved onsite getting the correct receive ship transactions etc for invoicing/cash
constants
	VOYAGECODE = 'VOY27419';
	VOYAGECODETSHIP = 'VOY27419_2';
	VESSELNAME = 'SHIP27419';
	VESSELNAMETSHIP = 'SHIP27419_2';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27419';
	TIID = 'MSKU27419';
	BlockStackName	= 'BS26729';
vars
	tempStr	: String;
	id	: String;
	container : CM_Container;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	voyageTShip : CM_Voyage;
	terminal : CM_Terminal;
	bs : CM_BlockStack;
	operator : CM_Operator;

begin
	//operator := self.getOperator(OPERATORCODE);
	
	terminal := self.getTerminal;
	operator := self.getOperator("PON");
	
	voyage := self.createTargetVesselVoyage(terminal, "JMT CASH", "JCASH003", operator);
	self.assertNotNullMsg(voyage, 'Add voyage failed');

	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	self.deleteContainer(TIID);
	container := self.getTrackedItem(TIID).CM_Container;
	self.assertIsDeleted(container);

	bs := self.addBlockStack(BlockStackName, 5, null);
	self.assertNotNull(bs);
	
	// and add the container
	container := createContainerFromVoyage(voyage,
											TIID,
											bs,
											'22G1',
											operator,
											'GENL', 
											"NZPOE",
											"NZPOE",
											2500,
											3500).CM_Container;

	id := container.id;			// debug point
epilog

end;
</source>
    </JadeMethod>
