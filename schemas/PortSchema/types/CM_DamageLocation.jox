    <JadeMethod name="getDisplayStringForAttribute" id="7b44505a-1ec2-4317-9fa9-8de8e3ca7524">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2016	cnwndl1	Initial creation	TFS 1593
02 Oct 2019	jlgsl4	TFS 46657 - STWO - Damage Location not created when Damage updated
*/

vars
	damageDetails : String; // TFS 46657
begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			damageDetails := self.damageDescription; // --&gt; TFS 46657
			if self.isNewDamage then
				damageDetails := damageDetails &amp; ", New Damage";
			endif;
			if self.remarks &lt;&gt; null then
				damageDetails := damageDetails &amp; ", " &amp; self.remarks;
			endif;
			return /*self.damageDescription*/damageDetails &amp; " @ " &amp; self.damagedInLocation; // &lt;-- TFS 46657
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationStr" id="2678c576-5c79-4f26-99f1-827cac21e01b">
