    <JadeMethod name="removeInsertJobWithNewId" id="80ef8d2e-5823-4f05-b001-52a136f26ce1">
        <source>removeInsertJobWithNewId(_job : CM_Job);
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		If they re number a job this re inserts it into the correct sequence in the array
//
// ---------------------------------------------------------------------------

vars
	aJob,lJob : CM_Job;
	idx : Integer;
begin
	if _job = null then
		return;
	endif;
	
	exclusiveLock(self.allJobsByOrder);

	idx := 0;
	foreach aJob in self.allJobsByOrder do
		if aJob = _job then
			continue;
		endif;
		
		if _job.id &gt; aJob.id then
			lJob := aJob;
		else
			break;
		endif;
	endforeach;

	self.removeJob(_job);
	if lJob &lt;&gt; null then
		idx := self.allJobsByOrder.indexOf(lJob) + 1 ;
	endif;
	self.addJob(_job,idx);
end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="removeJob" id="d76c2694-22b2-4d52-a58b-dbcb53ad0553">
        <source>removeJob(_job : CM_Job);
/*
 ------------------------------------------------------------------------
Created:			22 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	exclusiveLock(self);
	if self.allJobsByOrder.includes(_job) then
		self.allJobsByOrder.remove(_job);
	endif;

end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
