/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlger1	Initial creation

*/

vars

begin
	if _property.virtual then
		return true;
	endif;
	
	if _property.name[1] = "_" then
		return true;
	endif;
	
	return false;
epilog

end;</source>
