    <JadeMethod name="qryTrains" id="b05be960-ce28-4225-909b-db42c760be13">
        <source>qryTrains(_filter : CMQF_Train input; _passport : CM_Passport) : Integer;
// -----------------------------------------------------------------------------
// Created:		13 July 2009 by consw1
//
// Purpose:		5
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 13/07/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// -----------------------------------------------------------------------------

vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWTrain;

begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	jrwTrans := self.createJRWTransient(CM_JRWTrain).CM_JRWTrain;
	jrwTrans.allTrains.clear();
	_filter.filterObjects(jrwTrans.allTrains, _passport);

	jrwTrans.setAllTerminals(_filter.allTerminals);

	jrwTrans.myTrain := _filter.getMyTrain;
	
	numSelected := jrwTrans.allTrains.size;

epilog
	return numSelected;
end;</source>
