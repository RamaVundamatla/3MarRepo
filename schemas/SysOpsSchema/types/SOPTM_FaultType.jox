    <JadeMethod name="doSave" id="95440e12-8599-4afe-a4fc-25bc3ca8e019">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	rtnValue,notAvailable,
	default : Boolean;
	proxyFaultType		: CM_FaultType;
	description,
	code,
	emailTo,emailToCC,emailToBCC,
	emailSubject,
	emailBody : String;
	theForm				: SOP_TableMaintForm;
	theTable : CM_EntryTable;
begin
	theForm := self.myForm; 
	theTable:=theForm.tblInput1;
	description	:=	theTable.getValueByName(ETRow_Description).String;
	code			:=	theTable.getValueByName(ETRow_Code).String;
	emailTo:=	theTable.getValueByName(ETRow_EmailRecipient).String;	
	emailToCC:=theTable.getValueByName(ETRow_EmailToCC).String;
	emailToBCC:=theTable.getValueByName(ETRow_EmailToBCC).String;
	emailSubject:=theTable.getValueByName(ETRow_EmailSubject).String;	
	emailBody :=theTable.getValueByName(ETRow_EmailBody).String;	

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_FaultType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyFaultType := theForm.myProxyObject.CM_FaultType;
	

	proxyFaultType.setProxy(code,description,emailTo,emailToCC,emailToBCC, emailSubject,emailBody);
		
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateFaultType(proxyFaultType, theForm.myCurrentObject, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
		
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateFaultType(proxyFaultType, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	
	return rtnValue;


epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowEmailRecipientSelector" id="563e49f5-c4b0-4b01-90ff-350a88deb28c">
        <source>doShowEmailRecipientSelector();
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	recipientMode : Integer;
	rowInTable	: Integer;
	modalResult : Real;
	table : CM_EntryTable;
begin
	table:=self.myForm.tblInput1;
	rowInTable:=table.getRow(ETRow_EmailRecipient);
	if table.row = rowInTable and rowInTable &gt; 0 then
		recipientMode:=CMUI_RecipientSelector.Mode_To;
	else
		rowInTable:=table.getRow(ETRow_EmailToCC);
		if table.row = rowInTable and rowInTable &gt; 0 then
			recipientMode:=	CMUI_RecipientSelector.Mode_CC;
		else
			rowInTable:=table.getRow(ETRow_EmailToBCC);
			if table.row = rowInTable and rowInTable &gt; 0 then
				recipientMode:=	CMUI_RecipientSelector.Mode_BCC;
			endif;	
		endif;
	endif;
	
	if recipientMode = null then
		return;
	else
		
		modalResult:=self.myForm.myAssistant.showRecipientSelector(self.myEmailController,recipientMode,false);
		if modalResult = IDOK then
			table.setValueByName(ETRow_EmailRecipient, self.myEmailController.allToAddresses.getAddresses);	
			table.setValueByName(ETRow_EmailToCC,self.myEmailController.allCcAddresses.getAddresses);
			table.setValueByName(ETRow_EmailToBCC,self.myEmailController.allBccAddresses.getAddresses);
		endif;
	endif;


epilog

end;</source>
    </JadeMethod>
