    <JadeMethod name="addItem" id="be87bae4-33d9-4f58-94cb-9aec93ed9829">
        <source>addItem();
//----------------------------------------------------------------
//	Created:	05 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 18/10/2012	cnwcs5	par 30501 - refactored code into getIndexForEDIDataSheet
vars	
	index : Integer;
begin

	if self.fldDetail.topSheet = self.shtEDIFile then
		self.insertFileLine();
	else
		index := self.getIndexForEDIDataSheet;
		
		if index &gt;= 0 then
			self.insertEDITI(index);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="050ef65e-0203-4d70-9c51-98dd26f53bcf">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
25 Mar 2010	cnwkpd1	PAR #22819 - Rework to ensure keys are used correctly
10 Nov 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar - dont add CrLf when doing writline
18 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
04 May 2023	navsp1	TFS Bug 57864: AAT - EDI Operation - Users with Stevedore role should see only Voyage assigned to their Data access group
04 Sep 2023	jlika1	TFS 59168 - 55715.060 Display of Voyage EDI data in the EDI Operations Screen
06 Oct 2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types 
*/
constants
	TypeDict 			: Integer = 1;
	StatusDict 			: Integer = 2;
	DateDict 			: Integer = 3;
vars
	ediData 			: CM_EDIData;
	dict 				: CM_MemberKeyDictionary;// CM_EDIDataByTypeNumberDict;
	iter 				: Iterator;
	breakOut 			: Boolean;
	ls					: Boolean;
	ediDataType 		: Integer;
	typesToShow			: IntegerArray;
	index 				: Integer;
	tble 				: CM_DataTable;
	dictType 			: Integer;
	exOccurred 			: Boolean;
	failedDAC  			: CM_DataAccessController;
	filterInclEmptyItem : Boolean;		
	ediTypeIndex		: Integer;
begin 
	on Exception do self.handle14051Error(exception, self.tblData, exOccurred);	//25 Nov 2014	NDL	Par 35248
	on Exception do app.handleDeletedObject(exception, ediData, exOccurred);
	if self.amInitialisingWithObject then 
		self.fldDetail.topSheet := self.shtEDIDetails;
		self.myDisplayedEDIData := null;
		
		self.addObjectToTable(self.myCurrentObject.CM_EDIData, _numItems, breakOut);
		return;
	endif;
	
	self.filterFromDate := self.tblSearch.getValueByName(ETRow_FilterFromDate).Date; 	//ccms1906
	self.filterToDate 	:= self.tblSearch.getValueByName(ETRow_FilterToDate).Date; 		//ccms1906	
	filterInclEmptyItem := self.tblSearch.getValueByName(ETRow_FilterInclEmptyItem).Boolean;	
	
	create typesToShow transient;
	
	self.fldDetail.topSheet := self.shtEDIDetails;
	
	index := 0;
	
	while (true) do
		tble := self.tblEDITI.getControl(index);
		
		if tble &lt;&gt; null and tble.visible then
			tble.rows := 1;
		else
			break;
		endif;
		
		index := index+1;
	endwhile;
	
	self.myDisplayedEDIData := null;
	
	//we don't want to be in load state while we go through the collection
	//Jade will lock the dict and we'll be open to dead locks if members are deleted
	ls := process.isInLoadState;
	app.cmsEndLoad(ls);
	
	self.myEDIConfig.getDataTypeFromClass(self.myDataClass, typesToShow);
	
	// The order here is important.  If the filter status is specified, then we will use the status dict,
	// because we can then use both status and date as keys in the dictionary
	
	if self.filterStatus &lt;&gt; 999 then
		// If filter status is specified, then use status dict
		dict 		:= self.myTerminal.myEdiConfig.allEDIDatasByStatusDate;
		dictType 	:= StatusDict;
		
	elseif self.filterFromDate &lt;&gt; null or self.filterToDate &lt;&gt; null then //ccms1906 cnwrs1 Jan 2009 
		// If from or to date is specified, and not status, then use date dict
		dict 		:= self.myTerminal.myEdiConfig.allEDIDatasByDateStatus;
		dictType 	:= DateDict;
	
	else
		dict 		:= self.myTerminal.myEdiConfig.allEDIDatasByTypeNumber;
		dictType 	:= TypeDict;
	endif;
	
	iter := dict.createIterator;
	
	// PAR #22819 - Rework assumes there is at least one typesToShow
	foreach ediDataType in typesToShow do : typeLoop
	
		// First start with available keys
		if dictType = StatusDict then
			dict.startKeyGeq(ediDataType, self.filterStatus, self.filterFromDate, iter);	
			
		elseif dictType = DateDict then
			if self.filterStatus = 999 then
				dict.startKeyGeq(ediDataType, self.filterFromDate, null, iter);
			else
				dict.startKeyGeq(ediDataType, self.filterFromDate, self.filterStatus, iter);
			endif;
		
		elseif dictType = TypeDict then
			dict.startKeyGeq(ediDataType, null, iter);
			
		endif;

		while iter.next(ediData) do
	
			//04.May.2023 navsp1 TFS 57864
			if not ediData.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
				continue;
			endif;
			
			// Hide invidivudal items that are part of a combined Transport Manifest
			if ediData.isTransportManifestRelated then		//06.Jun.2023 navsp1 TFS 58054
				continue;
			endif;
			
			// Check for break conditions - ediDataType is the primary key for all dictionary types
			if ediData.ediDataType &lt;&gt; ediDataType then
				break;
			endif;
						
			if dictType = DateDict then
				// If we are using a DateDict, then can break if we have passed the filterToDate
				if self.filterToDate &lt;&gt; null then
					if ediData.processDate &gt; self.filterToDate then
						break;
					endif;
				endif;
			elseif dictType = StatusDict then
				// If we are using a StatusDict, then we can break if we have passed the filterStatus
				if ediData.status &lt;&gt; self.filterStatus then
					break;
				endif;
				// If using status and ToDate, then can break if we have passed the date
				if self.filterToDate &lt;&gt; null then
					if ediData.processDate &gt; self.filterToDate then
						break;
					endif;
				endif;
			endif;
			
			ediTypeIndex := self.cmbFiltEdiType.listIndex; //jlika1 TFS 60232
			
			if ediTypeIndex &gt; 0 and self.cmbFiltEdiType.itemData[ediTypeIndex] = EDIDataType_Voyage and filterInclEmptyItem = false and ediData.items = 0 then //jlika1 TFS 60232
				continue;
			endif;
						
			if ediTypeIndex &gt; 0 and self.cmbFiltEdiType.itemData[ediTypeIndex] = EDIDataType_TransportManifest then //jlika1 TFS 60232
				if transportManifestFilter(ediData) then
					continue;
				endif;
			endif;
			
			if ediTypeIndex &gt; 0 and self.cmbFiltEdiType.itemData[ediTypeIndex] = EDIDataType_CallOff then //jlika1 TFS 60232
				if callOffFilter(ediData) then
					continue;
				endif;
			endif;
			
			if self.includeObjectEDI(ediData, _numItems, breakOut) then
				self.addObjectToTable(ediData, _numItems, breakOut);
			endif;
			if exOccurred then
				break;
			endif;
			if breakOut then
				break typeLoop;
			endif;
			
		endwhile;
	
	endforeach;
			
	
epilog
	delete iter;
	delete typesToShow;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="ef90816a-4aae-4caa-baa1-05ba13920d74">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// ---------------------------------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;
begin
	inheritMethod();

	toolbar 		:= self.frmToolbar;
	showCaptions	:= toolbar.showCaptions;
	
	if not self.btnEditTV.isAddedToToolbar then	//29 Aug 2014	NDL	Par 34737
		toolbar.addButton(self.btnEditTV, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	if not self.btnSaveBase.isAddedToToolbar then	//29 Aug 2014	NDL	Par 34737
		toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addButton(self.btnSaveVerify, CMUI_Toolbar.Control_Alignment_Left);
	if not self.btnCancelBase.isAddedToToolbar then	//29 Aug 2014	NDL	Par 34737
		toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	endif;
	toolbar.addButton(self.btnDeleteTV, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnShowFindRepl, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowLoadFile, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExtractNew, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	if app.myRoot.canDoEDIFileType(EDIFileType_UserDefined) then
		toolbar.addButton(self.btnUserTypes, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	toolbar.addButton(self.btnHideWarnings, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrintTV, CMUI_Toolbar.Control_Alignment_Left);

	self.btnPrintTV.caption		:= 'Print Error/Warnings';	
	self.btnExportCSVTV.caption	:= 'Export Error/Warnings';
	self.btnPrintTV.bubbleHelp	:= 'Print Error/Warnings';	
	self.btnDeleteTV.bubbleHelp	:= 'Delete File';	
	
	toolbar.addButton(self.btnDeleteEDITi, CMUI_Toolbar.Control_Alignment_Left);		// RJS - move to left side

	self.btnExportCSVTV.bubbleHelp	:= 'Export as CSV';
	//================================================
	//	Load new file toolbar
	//================================================
	toolbar 				:= self.frmLoadFileTool;
	toolbar.showCaptions 	:= showCaptions;	
		
	toolbar.addButton(self.btnHideFileLoad, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnLoadFile, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	//================================================
	//	Find Replace toolbar
	//================================================
	
	toolbar := self.frmFindRToolBar;
	
	toolbar.showCaptions := showCaptions;	
		
	toolbar.addButton(self.btnFRFind, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFRFindNext, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnFRReplace, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnFRHide, CMUI_Toolbar.Control_Alignment_Right);
		
	toolbar.positionToolbarControls();
	toolbar.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
