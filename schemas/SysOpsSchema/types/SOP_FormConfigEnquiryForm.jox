    <JadeMethod name="doDelete" id="34388be8-84dc-4eb5-a2f5-b21657037295">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myCurrentObject = null then
		return false;
	endif;
	
	beginTransaction;
	delete self.myCurrentObject;
	commitTransaction;
	
	self.myCurrentObject := null ;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
