    <JadeMethod name="transDateTime" id="ac70c683-bb80-4614-9aac-07029f3d12c7">
        <source>transDateTime(_transaction : CM_TITransaction; _activity : Integer; _camProtocol : CM_CamProtocol) : TimeStamp;
//this exists so the protocols that want to create more than one message per transaction can
// manipulate the datetime for subsequant messages.
//12 Sep 2012	cnwrs1	Par 30360 the gatein should always be after the gateout
// 09/08/2013	cnwcs5	par 32148 - fix changes made for 31281
// 08/09/2016   cnwma1  TFS #2596*:PNL- Delay on CODECO messages not working
// 09 Dec 2016	cnwrs1	TFS #3086 Only add the sub terminal xtra minute for a subterminal internal
vars
	dateTime: TimeStamp;

begin
	dateTime := _transaction.dateTime;
	
	if _transaction.isCamsShipReceiveType() then
		if _activity = CODECO_GATEOUT then
			dateTime := dateTime.addMinutes(1);		// 12/03/2013 cnwar2 #31281
		elseif _activity = CODECO_GATEIN then
			dateTime := dateTime.addMinutes(2);		// 12/03/2013 cnwar2 #31281
		endif;
	endif;
	
	if _transaction.isCamsShipReleaseType() then //ccms 1670 Apr 2008
		if _activity = CODECO_GATEIN then
			dateTime := dateTime.addMinutes(1);		// 12/03/2013 cnwar2 #31281
		elseif _activity = CODECO_GATEOUT then
			dateTime := dateTime.addMinutes(2);		// 12/03/2013 cnwar2 #31281
		endif;
	endif;
	
	if (_transaction.isCamsPackType() and  _activity = CODECO_GATEIN) or  
		(_transaction.isCamsUnpackType() and _activity = CODECO_GATEIN) then
		
		dateTime := dateTime.addMinutes(1);		// 12/03/2013 cnwar2 #31281

	elseif (_transaction.isCamsPackType() and _activity = CODECO_GATEOUT) or
		(_transaction.isCamsUnpackType() and _activity = CODECO_GATEOUT) then
		
		dateTime := dateTime.addMinutes(-1);		// 12/03/2013 cnwar2 #31281
	endif;
	
	if _transaction.isInternalReceive then  //08/09/2016 cnwma1 TFS #2596 cmwrs1 TFS3086
		dateTime := dateTime.addMinutes(1);	
	elseif _transaction.isInternalRelease then //08/09/2016 cnwma1 TFS #2596  cmwrs1 TFS3086
		dateTime := dateTime.addMinutes(0);	
	endif;
	//08 Sep 2015	NDL	Par 36876
	if _camProtocol &lt;&gt; null then
		if self.useDelayMinutes and _camProtocol.delayMinutes &gt; 0 then
			dateTime := dateTime.addMinutes( _camProtocol.delayMinutes );
		endif;
	endif;
	
	return dateTime;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
