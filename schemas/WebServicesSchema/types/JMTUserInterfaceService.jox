    <JadeWebServicesMethod name="getDimensionsForCargoType" id="7e1dc3b0-c5f6-4e5e-8e56-8dc8cea2beae">
        <source>getDimensionsForCargoType(_request : WS_CargoTypeDimensionsRequest) :  WS_CargoTypeDimensionsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2018	jlger1	Initial creation - webportal prenotes

*/

vars
	response : WS_CargoTypeDimensionsResponse;
	completedOK : Boolean;
	cargoSubType  : CM_Product;
	cargoType : CM_CargoType;
	allProductAttrs : ObjectSet;
	prodAttr : Object;
	wsDimension : WS_Dimension;
	entRow : EntTableRow;
	entDef 	: EntTableDef;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelayType for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if _request.cargoSubType &lt;&gt; null then
		cargoSubType :=app.myPassport.getObjectOfTypeFromOid(_request.cargoSubType,CM_Product).CM_Product;	
	endif;
	
	if cargoSubType &lt;&gt; null then
		cargoType:=cargoSubType.myCargoType;
	else
		cargoType:=app.myRoot.allCargoTypesById[_request.cargoType.Integer];
	endif;
	//lets try the oid
	if cargoType = null then
		cargoType:=app.myPassport.getObjectOfTypeFromOid(_request.cargoType,CM_CargoType).CM_CargoType;	
	endif;
	
	if cargoType = null then
		completedOK:=true;
		return response;	
	endif;
	
	if not cargoType.allTerminals.includes(app.myPassport.myTerminal) then
		//must be for the current terminal of the user 
		completedOK:=true;
		return response;
	endif;
	if cargoType.isTrailer then
		entDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_GeneralCargo];
		
		// have length width and height with no product
		create wsDimension transient;
		wsDimension.type :=ETRow_MyWidth;		
		wsDimension.description:= entDef.getEntTableRow(wsDimension.type).getHeading(null,app.myPassport.myTerminal,app.myCurrentLocale);
		wsDimension.measurementType:=app.getDefaultMeasurementForType(Type_Width).shortName;
		response.allDimensions.add(wsDimension);
		
		create wsDimension transient;
		wsDimension.type :=ETRow_MyHeight;		
		wsDimension.description:= entDef.getEntTableRow(wsDimension.type).getHeading(null,app.myPassport.myTerminal,app.myCurrentLocale);
		wsDimension.measurementType:=app.getDefaultMeasurementForType(Type_Height).shortName;
		response.allDimensions.add(wsDimension);
		
			
		create wsDimension transient;
		wsDimension.type :=ETRow_MyLength;		
		wsDimension.description:= entDef.getEntTableRow(wsDimension.type).getHeading(null,app.myPassport.myTerminal,app.myCurrentLocale);
	
		wsDimension.measurementType:=app.getDefaultMeasurementForType(Type_Length).shortName;
		response.allDimensions.add(wsDimension);
		completedOK:=true;
		return response;
	endif;
	
	
	if cargoSubType = null and cargoType.isSubCargoTypeRequired then
		if _request.cargoSubType &lt;&gt; null then
			cargoSubType:=cargoType.allProducts.findProductByCode(_request.cargoSubType);
		endif;	
	else
		cargoSubType:=cargoType.mySystemProductType;
	endif;
	
	
	if cargoSubType = null then
	
		
		completedOK:=true;
		return response;
	endif;
	
	create allProductAttrs transient;
	cargoSubType.getAllProductAttributes(allProductAttrs);
	
	foreach prodAttr in allProductAttrs discreteLock do
			//these 2 fields are only stored on break bulk generic objects so 
			// no point displaying if not one of those
			if ( prodAttr.CM_ProductAttr.name = ETRow_MyWeight) and 
					not cargoType.isBreakBulk then
					continue;
			endif;
			
			if prodAttr.CM_ProductAttr.name = ETRow_MyStowageFactor then
				//can't actually store this on cargo just skip
				continue;
			endif;				
			
			create wsDimension transient;
			wsDimension.setProxyFromObject(prodAttr.CM_ProductAttr);
			
			response.allDimensions.add(wsDimension);
	endforeach;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up transients
	delete allProductAttrs;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_CargoTypeDimensionsRequest"/>
        <ReturnType type="WS_CargoTypeDimensionsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getDriversForCarrier" id="e961588f-ecc4-4bda-88ec-48816a1cbbde">
        <source>getDriversForCarrier(carrierCode : String) : WS_DriversResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2013	cnwmc5	Initial creation
10 Feb 2015 cnwmc5	Now correctly accepts the carrier code (and also the OID to support the RIA) - PAR 35658
*/

vars
	response 		: WS_DriversResponse;
	realCarrier		: CM_Carrier;
	wsDriver		: WS_Driver;
	driver			: CM_DriverDetails;
	completedOK 	: Boolean;
	obj				: Object;
	terminal        : CM_Terminal;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	
	if carrierCode &lt;&gt; null then
		realCarrier := app.myRoot.allCarriers[carrierCode];
	endif;
	
	if realCarrier = null then
		//epr TFS 5535 4/8/17 
		realCarrier := app.myPassport.getObjectOfTypeFromOid(carrierCode,CM_Carrier).CM_Carrier;	
	endif;
	
	if realCarrier = null then
		app.raiseCMException2(ERR_Carrier_Unknown, carrierCode, null, null, null);
		completedOK := true;
		return response;
	endif;
	
	foreach driver in realCarrier.allDrivers discreteLock do
		if driver.myTerminal &lt;&gt; terminal then
			continue;
		endif;
		create wsDriver transient;
		wsDriver.setProxyFromObject( driver);
		response.allDrivers.add( wsDriver );
	endforeach;
	
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
		delete wsDriver;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="carrierCode" type="String"/>
        <ReturnType type="WS_DriversResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getDriversOnlyForCarrier" id="2582f05a-32a4-4611-a7e6-5a5657d8e7a5">
