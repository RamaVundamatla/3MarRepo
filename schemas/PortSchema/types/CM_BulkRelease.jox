    <JadeMethod name="setProxyBasic" id="ec2197f4-7719-422e-9db0-4b539600e2bf">
        <updating/>
        <source>setProxyBasic(	_releaseNumber			: String;
				_type					: Integer;
				_releaseByType			: Boolean;
				_status					: Integer;
				_terminal				: CM_Terminal;
				_operator				: CM_Operator;
				_voyage 				: CM_Voyage;
				_dateRequested,
				_expiryTimeStamp 		: TimeStamp  ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2018	jlger1	Initial creation 39642

*/

vars

begin
	if _releaseNumber = null then
		self.code:=_terminal.generateNextNumber(CM_AutoReleaseIdGen);
	else
		self.code:= _releaseNumber.trimBlanks.toUpper;
	endif;
	
	self.releaseByType			:= _releaseByType;
	self.type					:= _type;
	self.status 				:= _status;
	self.myVoyage 				:= _voyage;
	self.myOperator				:=	_operator;
	self.myTerminal				:=	_terminal;
	self.dateRequested 			:= _dateRequested;
	self.expiryTimeStamp		:= _expiryTimeStamp;	//13 Feb 2017	NDL	TFS 3368
	self.allowCargoOnMultipleReleases :=true;
	self.canBeHiLoCube			:= true;
	if self.myOperator &lt;&gt; null then
		//now PAR16612 cnwsh3 Was causing a 1048 exception when using a newly created operator.  
		self.myOperatorTerminal := self.myOperator.getOperatorTerminal(self.myTerminal, false);
	endif;
epilog

end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_releaseByType" type="Boolean"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dateRequested" type="TimeStamp"/>
        <Parameter name="_expiryTimeStamp" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromComparison" id="a2ee2493-5215-47ac-9441-156c7cc1012a">
        <updating/>
        <source>setProxyFromComparison(_attribute ,_value : String)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2017 cnwma1	TFs #4596 POL - Cannot ignore fields during EDI Release Request Update

*/

vars
	status : Integer;
	destinationPort,
	dischargePort,
	loadPort		: CM_Port;
	operator : CM_Operator;
	destinationTerm : CM_Terminal;
	releaseType : Integer;
	voyage : CM_Voyage;
	subTerminal : CM_SubTerminal;
	bu : CM_Bank;
begin
	if _attribute ="Request Date" then
		if _value &lt;&gt; null then
			self.setRequestDate( _value.asTimeStampJMT);
		endif;
	endif;
	
	if _attribute = "Release Type" then
		if _value &lt;&gt; null then		
			if  _value = BR_TYPE_PACKING_STR then
				releaseType := BR_TYPE_PACKING;
			elseif   _value = BR_TYPE_ROAD_STR then 
				releaseType :=BR_TYPE_ROAD;
			elseif   _value = BR_TYPE_RAIL_STR then 
				releaseType :=BR_TYPE_RAIL;
			elseif   _value = BR_TYPE_SHIP_STR then 
				releaseType :=BR_TYPE_SHIP;
			endif;
			self.setType(releaseType);
		endif;
	endif;
	
	if _attribute = "Estimated Required By" then
		self.dateEstimatedRequired := _value.asTimeStampJMT;
	endif;
	
	if _attribute ="Operator" then
		operator := app.myRoot.allOperators[_value];
		
		if operator &lt;&gt; null then
		self.myOperator := operator;
		endif;
	
	endif;
	if _attribute = "Booking Confirmation Number" then
		self.bookingConfirmation := _value;
	endif;	
	
    
	if _attribute = "Destination" then
		destinationPort :=app.myRoot.allPorts[_value];
		if destinationPort &lt;&gt; null then
			self.myDestinationPort := destinationPort;
		endif;
	endif;
	
	if _attribute = "Discharge Port" then
		dischargePort :=app.myRoot.allPorts[_value];
		if dischargePort &lt;&gt; null then
			self.myDischargePort := dischargePort;
		endif;
	endif;
	
	if _attribute = "Load Port" then
		loadPort :=app.myRoot.allPorts[_value];
		if loadPort &lt;&gt; null then
			self.myLoadPort := loadPort;
		endif;
	endif;
	
	if _attribute = "Voyage" then
		voyage	:= self.myTerminal.allVoyagesByCode.getAtKeyGeq(_value, null);
		if voyage &lt;&gt; null then
			self.myVoyage := voyage;
		endif;
	endif;
	
		// Updating Bulk Release Header
	if _attribute = "Status (Bulk Release)" then
		if  _value = BR_PENDING_STRING then
			status := BR_PENDING;
		elseif   _value = BR_ACTIVE_STRING then 
			status :=BR_ACTIVE;
		else
			status := BR_COMPLETE;
		endif;
		self.setStatus(status,true,false);
	endif;
	
	if _attribute = "Carrier Code" then
		self.carrierId := _value;
	endif;
	
	if _attribute ="Consignee" then
		self.consigneeCode := _value[1:5] ;
	endif;
	
	if _attribute ="Consignor" then
		self.consigneeCode := _value[1:5]; 
	endif;
	
	if _attribute ="Customs Agent" then
		self.customsAgent := _value ;
	endif;
	
	if _attribute = "Destination Terminal" then
		destinationTerm := app.myRoot.allTerminals[_value];
		if destinationTerm &lt;&gt; null  then
			self.myTransferToTerminal := destinationTerm;
		endif;
	endif;
	if _attribute = "Sub-Terminal" then
		subTerminal := self.myTerminal.allSubTerminals[_value];
		if subTerminal &lt;&gt; null then
			self.mySubTerminal := subTerminal;
		endif;
	endif;
	
	if _attribute = "Business Unit" then
		bu := self.myTerminal.companies[_value];
		if bu &lt;&gt; null then
			self.myBusinessUnit := bu;
		endif;
	endif;
	if _attribute = "Can be Hi or Low Cube" then
		self.canBeHiLoCube := _value.asBooleanJMT;
	endif;
	
epilog

end;</source>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
