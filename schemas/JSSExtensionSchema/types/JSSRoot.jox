    <DbClassMap file="jssxs_root"/>
    <ExplicitInverseRef name="allDictionaries" id="fe873072-e425-43de-97bc-76b2ba270879">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="JSSWordDictionaryByNameDict"/>
        <access>readonly</access>
        <Inverse name="JSSWordDictionary::myRoot"/>
    </ExplicitInverseRef>
    <JadeMethod name="createWordDictionary" id="8b305360-c598-413c-a0d2-cc1dda76580d">
        <source>createWordDictionary(pDictionaryName:String; pTheDictionary:JSSWordDictionary output):String;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDictionary	: JSSWordDictionary;

begin
	create theDictionary;

	theDictionary.updateMe(pDictionaryName, self);
	
	pTheDictionary	:=	theDictionary;
	
	return null;
end;</source>
        <Parameter name="pDictionaryName" type="String"/>
        <Parameter name="pTheDictionary" type="JSSWordDictionary" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWordDictionary" id="3ba039d4-44bd-4186-8b89-3642dec8b2dc">
        <source>getWordDictionary(pDictionaryName:String):JSSWordDictionary;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return allDictionaries[pDictionaryName];
end;</source>
        <Parameter name="pDictionaryName" type="String"/>
        <ReturnType type="JSSWordDictionary"/>
    </JadeMethod>
</Class>
