    <JadeMethod name="click" id="12cfe060-f3e3-4825-918a-76d84eb5564b">
        <updating/>
        <source>click(table: Table input) updating;

begin
	self.myDisplayPanel.click(self.myDisplayPanel);
	inheritMethod(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
