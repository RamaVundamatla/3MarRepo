    <JadeMethod name="doUserNotifyStructuralTables" id="090db2d6-6e17-4907-ae3e-a9a04413dea5">
        <source>doUserNotifyStructuralTables(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin


	if eventType = EVENT_DECK_ITEM_CREATE or  eventType = EVENT_DECK_ITEM_UPDATE then
		self.tblExtRamps.updateItemObject(userInfo.CM_Object, null	, null, app.myPassport);	
	elseif eventType = EVENT_DECK_ITEM_DELETE then
		self.tblExtRamps.removeItemObject(userInfo.CM_Object);
	elseif eventType = EVENT_TANK_CREATE or eventType = EVENT_TANK_UPDATE then
		self.tblTanks.updateItemObject(userInfo.CM_Object, null	, null, app.myPassport);	
	elseif eventType = EVENT_TANK_DELETE then
		self.tblTanks.removeItemObject(userInfo.CM_Object);
	elseif  eventType = EVENT_SECTION_CREATE or eventType = EVENT_SECTION_UPDATE then
		self.tblSections.updateItemObject(userInfo.CM_Object, null	, null, app.myPassport);	
	elseif eventType = EVENT_SECTION_DELETE then	
		self.tblSections.removeItemObject(userInfo.CM_Object);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="enableAllControls" id="096fb22e-2399-4802-be48-b0fc1edec22d">
        <source>enableAllControls(_enable: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2018	jlgndl1	Initial creation	TFS 39216

*/

vars
	
	allowAllStatusView : Boolean;

begin

	inheritMethod(_enable);
	
	// ### TFS 54485 22AUG2022 NAVAB1
	if not _enable then 
		if self.myCurrentVoyage = null or self.myCurrentVoyage.myVoyageProcess = null then
			self.frmAllStatuses.visible := false; 
		else
			if self.myCurrentVoyage.myVoyageProcess.isDefaultProcessJMT then
				self.frmAllStatuses.visible := false;
			else
				self.frmAllStatuses.visible := true;
				self.frmAllStatuses.enabled := false;
			endif;
		endif;
	else
		allowAllStatusView := app.getMyUser.canDo( self.myTerminal, PmShipVoyageStatusALL );
		
		self.frmAllStatuses.visible := false;
		if self.myCurrentVoyage = null or self.myCurrentVoyage.myVoyageProcess = null then
			self.chkAllStatus.value := false;
		elseif not self.myCurrentVoyage.myVoyageProcess.isDefaultProcessJMT then
			if not allowAllStatusView then
				self.chkAllStatus.value := false;
			endif;
			self.frmAllStatuses.visible := true;
			self.frmAllStatuses.enabled := true;
			self.chkAllStatus.enabled := true;
			self.chkAllStatus.readOnly := not allowAllStatusView;
		endif;
	
	endif;
	self.cmbVoyage.enabled := self.mode = self.Mode_View;
epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="endVesselStructureNotes" id="4b3105dc-5677-40be-94c2-f6348ac8d76d">
        <source>endVesselStructureNotes() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	roroStructure : CM_ROROVoyageStructure;
	structElements : CM_VoyageStructuralElements;
begin
//	return;
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	structElements:=self.myCurrentVoyage.myStructuralElements;
	if structElements &lt;&gt; null then
		self.endNotification(structElements,EVENT_TANK_CREATE);
		self.endNotification(structElements,EVENT_TANK_UPDATE);
		self.endNotification(structElements,EVENT_TANK_DELETE);	
		
		self.endNotification(structElements,EVENT_SECTION_CREATE);
		self.endNotification(structElements,EVENT_SECTION_UPDATE);
		self.endNotification(structElements,EVENT_SECTION_DELETE);	
		
		self.endNotification(structElements,EVENT_DECK_ITEM_CREATE);
		self.endNotification(structElements,EVENT_DECK_ITEM_UPDATE);
		self.endNotification(structElements,EVENT_DECK_ITEM_DELETE);	

	endif;
	
	roroStructure:=self.myCurrentVoyage.myROROStructure ;
	if roroStructure &lt;&gt; null then
		self.endNotification(roroStructure,EVENT_DECK_ITEM_CREATE);
		self.endNotification(roroStructure,EVENT_DECK_ITEM_UPDATE);
		self.endNotification(roroStructure,EVENT_DECK_ITEM_DELETE);	
		
		self.endNotification(roroStructure,EVENT_TANK_CREATE);
		self.endNotification(roroStructure,EVENT_TANK_UPDATE);
		self.endNotification(roroStructure,EVENT_TANK_DELETE);	
		
		self.endNotification(roroStructure,EVENT_SECTION_CREATE);
		self.endNotification(roroStructure,EVENT_SECTION_UPDATE);
		self.endNotification(roroStructure,EVENT_SECTION_DELETE);	
		
	endif;
epilog

end;</source>
