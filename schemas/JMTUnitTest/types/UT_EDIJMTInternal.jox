    <JadeMethod name="tOperatorStopAction" id="4d7b2161-97ca-47dc-81ba-360b68b3d4b8">
        <source>tOperatorStopAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalOperatorStop";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalOperatorStop xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalOperatorStop.xsd"&gt;
	&lt;AllOperatorStops&gt;
		&lt;OperatorStops&gt;
			&lt;expiryDate/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;description/&gt;
			&lt;entryNumber&gt;567890&lt;/entryNumber&gt;
			&lt;freightForwarder/&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;vesselName/&gt;
			&lt;voyageCode/&gt;
		&lt;/OperatorStops&gt;
	&lt;/AllOperatorStops&gt;
&lt;/JMTInternalOperatorStop&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.remarks.trimBlanks, "Created by unit test UT_EDIJMTInternal::tOperatorStopAction"&amp;CrLf, "wrong remarks");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tOutwardRailAction" id="f64e6a43-8860-4211-8a2a-b97c8452391d">
        <source>tOutwardRailAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalOutwardRail";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalOutwardRail xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalOutwardRail.xsd"&gt;
	&lt;AllOutwardRail&gt;
		&lt;OutwardRail&gt;
			&lt;weight/&gt;
			&lt;bookingReleaseNo/&gt;
			&lt;cargoTypeDescr/&gt;
			&lt;description/&gt;
			&lt;destination/&gt;
			&lt;equipmentCode/&gt;
			&lt;freightPayerCode/&gt;
			&lt;fullOrMT/&gt;
			&lt;id/&gt;
			&lt;imex/&gt;
			&lt;isoType/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operator/&gt;
			&lt;operatorDesc/&gt;
			&lt;remarks/&gt;
			&lt;voyage/&gt;
			&lt;wagon/&gt;
			&lt;wagonClassCode/&gt;
			&lt;weightQualifier/&gt;
			&lt;loadDT/&gt;
		&lt;/OutwardRail&gt;
	&lt;/AllOutwardRail&gt;
&lt;/JMTInternalOutwardRail&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);

end;
</source>
    </JadeMethod>
    <JadeMethod name="tPackAction" id="03e7c442-b007-4db1-998c-cdf991518e1a">
        <source>tPackAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalPack";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "MT", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalPack xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalPack.xsd"&gt;
	&lt;AllPack&gt;
		&lt;Pack&gt;
			&lt;isWeightCertified/&gt;
			&lt;vent/&gt;
			&lt;weight/&gt;
			&lt;weightNet/&gt;
			&lt;weightTare/&gt;
			&lt;carbonDioxide/&gt;
			&lt;humidity/&gt;
			&lt;oxygen/&gt;
			&lt;ventilationUnits/&gt;
			&lt;temperature/&gt;
			&lt;alternativeId/&gt;
			&lt;bookingRef/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;clientRef/&gt;
			&lt;clientRefEx/&gt;
			&lt;commodity&gt;GEN&lt;/commodity&gt;
			&lt;commodityDescription&gt;GENERAL&lt;/commodityDescription&gt;
			&lt;consignee/&gt;
			&lt;consignor/&gt;
			&lt;description/&gt;
			&lt;destinationPort/&gt;
			&lt;destinationTerminal/&gt;
			&lt;dischargePort/&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
			&lt;loadPort/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;remarks/&gt;
			&lt;sealShipper/&gt;
			&lt;sender/&gt;
			&lt;vesselName&gt;'&amp;VESSELNAME&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
			&lt;weightCertifiedName/&gt;
			&lt;weightCertifiedReference/&gt;
		&lt;/Pack&gt;
	&lt;/AllPack&gt;
&lt;/JMTInternalPack&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.commodity, "GENL", "wrong commodity");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPrenote" id="3e9f7996-9bca-4356-b31f-6a228a42b193">
        <source>tPrenote();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//10 Jun 2016	cnwrs1	TFS 2150 - If you process an operatorCode and there is not xlation operator then start using that operator
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
constants
	USER_DEF_NAME : String = "JMTInternalPrenote";
	VESSEL_CODE	: String = "UTXVES1";
	VOYAGE_CODE	: String = "UTXVOY1";
	CONTAINER_ID01 : String = "TESTA000001";
	CONTAINER_ID02 : String = "TESTA000002";
	CONTAINER_ID03 : String = "TESTA000003";
vars
	containerObj : CM_TrackedItem;
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	operator : CM_Operator;
begin
	// turn off CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, false);
	passportObj	:=	app.myPassport;
	self.deleteContainer(CONTAINER_ID01);
	containerObj := self.getTrackedItem(CONTAINER_ID01);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID02);
	containerObj := self.getTrackedItem(CONTAINER_ID02);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID03);
	containerObj := self.getTrackedItem(CONTAINER_ID03);
	self.assertIsDeleted(containerObj);
	// Create the Vessel and the Voyage.
	self.deleteVessel(VESSEL_CODE);
	vesselObj	:=	self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vesselObj);
	self.deleteVoyage(VOYAGE_CODE);
	voyageObj	:=	self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyageObj);
	self.createVoyageVessel(VOYAGE_CODE, VESSEL_CODE, voyageObj, vesselObj);
	self.assertNotNullMsg(vesselObj, "Add vessel failed!");
	operator := self.getOperator("MSK");
	self.deleteEDIInwardXlation("22ZZ", XLATION_TYPE_ISOTYPE_BYOP, operator, null);	
	self.createEDIXlation("22ZZ", "22G1", XLATION_TYPE_ISOTYPE_BYOP, false, operator, null);
	self.deleteEDIInwardXlation("MAERSK SEALAND", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAERSK SEALAND", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
	self.deleteEDIInwardXlation("MAEU", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAEU", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
//&lt;xlateOperatorCode&gt;MAEU&lt;/xlateOperatorCode&gt;

	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;SystemXMLPrenote&gt;
	&lt;AllPrenote&gt;
		&lt;Prenote&gt;
			&lt;weight&gt;2001&lt;/weight&gt;
			&lt;commodity&gt;GENL&lt;/commodity&gt;
			&lt;id&gt;'&amp;CONTAINER_ID01&amp;'&lt;/id&gt;
			&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
			&lt;isoType&gt;22ZZ&lt;/isoType&gt;
			&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
			&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
			&lt;operatorCode&gt;MAERSK SEALAND&lt;/operatorCode&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
			&lt;orderNumber&gt;111111OrderNum&lt;/orderNumber&gt;
			&lt;invoiceNumber&gt;111111InvoiceNum&lt;/invoiceNumber&gt;
		&lt;/Prenote&gt;
		&lt;Prenote&gt;
			&lt;weight&gt;2001&lt;/weight&gt;
			&lt;commodity&gt;GENL&lt;/commodity&gt;
			&lt;id&gt;'&amp;CONTAINER_ID02&amp;'&lt;/id&gt;
			&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
			&lt;isoType&gt;22ZZ&lt;/isoType&gt;
			&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
			&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
			&lt;orderNumber&gt;222222OrderNum&lt;/orderNumber&gt;
			&lt;invoiceNumber&gt;222222InvoiceNum&lt;/invoiceNumber&gt;
		&lt;/Prenote&gt;
		&lt;Prenote&gt;
			&lt;weight&gt;2001&lt;/weight&gt;
			&lt;commodity&gt;GENL&lt;/commodity&gt;
			&lt;id&gt;'&amp;CONTAINER_ID03&amp;'&lt;/id&gt;
			&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
			&lt;isoType&gt;2200&lt;/isoType&gt;
			&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
			&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
			&lt;orderNumber&gt;333333OrderNum&lt;/orderNumber&gt;
			&lt;invoiceNumber&gt;333333InvoiceNum&lt;/invoiceNumber&gt;
			&lt;AllHazardousDetails&gt;
				&lt;HazardousDetails&gt;
					&lt;id&gt;'&amp;CONTAINER_ID03&amp;'&lt;/id&gt;
					&lt;code&gt;3.1&lt;/code&gt;
					&lt;isMarinePollutant&gt;12&lt;/isMarinePollutant&gt;
				&lt;/HazardousDetails&gt;
			&lt;/AllHazardousDetails&gt;
			&lt;AllSealDetails&gt;
				&lt;SealDetails&gt;
					&lt;sealEDIType&gt;SHIP&lt;/sealEDIType&gt;
					&lt;sealEDINum&gt;SH0031&lt;/sealEDINum&gt;
				&lt;/SealDetails&gt;
				&lt;SealDetails&gt;
					&lt;sealEDIType&gt;SH&lt;/sealEDIType&gt;
					&lt;sealEDINum&gt;SH0032&lt;/sealEDINum&gt;
				&lt;/SealDetails&gt;
			&lt;/AllSealDetails&gt;
		&lt;/Prenote&gt;
	&lt;/AllPrenote&gt;
&lt;/SystemXMLPrenote&gt;
';
//&lt;id&gt;'&amp;CONTAINER_ID03&amp;'&lt;/id&gt;

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 6, "incorrect number of EDI trackedItems");
	containerObj := self.getTrackedItem(CONTAINER_ID03);
	self.assertNotNull(containerObj);
	self.assertEqualMsg(containerObj.getSealNumShipper(), "SH0031,SH0032", "Incorrect Shipper Seal");
	containerObj := self.getTrackedItem(CONTAINER_ID01);
	self.assertEqualMsg(containerObj.totalWeight.String, "2001.0000", "incorrect weight of "&amp;containerObj.totalWeight.String);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPrenote1" id="ba72a5ba-9c4c-4431-aafc-675090de6357">
        <source>tPrenote1();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//10 Jun 2016	cnwrs1	TFS 2150 - If you process an operatorCode and there is not xlation operator then start using that operator
//
constants
	USER_DEF_NAME : String = "JMTInternalPrenote";
	VESSEL_CODE	: String = "UTXVES1";
	VOYAGE_CODE	: String = "UTXVOY1";
	CONTAINER_ID01 : String = "TEST0000001";
	CONTAINER_ID02 : String = "TEST0000002";
	CONTAINER_ID03 : String = "TEST0000003";
vars
	containerObj : CM_TrackedItem;
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	operator : CM_Operator;
begin
	passportObj	:=	app.myPassport;
	self.deleteContainer(CONTAINER_ID01);
	containerObj := self.getTrackedItem(CONTAINER_ID01);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID02);
	containerObj := self.getTrackedItem(CONTAINER_ID02);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID03);
	containerObj := self.getTrackedItem(CONTAINER_ID03);
	self.assertIsDeleted(containerObj);
	// Create the Vessel and the Voyage.
	self.deleteVessel(VESSEL_CODE);
	vesselObj	:=	self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vesselObj);
	self.deleteVoyage(VOYAGE_CODE);
	voyageObj	:=	self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyageObj);
	self.createVoyageVessel(VOYAGE_CODE, VESSEL_CODE, voyageObj, vesselObj);
	self.assertNotNullMsg(vesselObj, "Add vessel failed!");
	operator := self.getOperator("MSK");
	self.deleteEDIInwardXlation("22ZZ", XLATION_TYPE_ISOTYPE_BYOP, operator, null);	
	self.createEDIXlation("22ZZ", "22G1", XLATION_TYPE_ISOTYPE_BYOP, false, operator, null);
	self.deleteEDIInwardXlation("MAERSK SEALAND", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAERSK SEALAND", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
	self.deleteEDIInwardXlation("MAEU", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAEU", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
//&lt;xlateOperatorCode&gt;MAEU&lt;/xlateOperatorCode&gt;
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalPrenote&gt;
&lt;AllPrenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID01&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;22ZZ&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MAERSK SEALAND&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;111111OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;111111InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID02&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;222222OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;222222InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID03&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;333333OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;333333InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;/AllPrenote&gt;
&lt;/JMTInternalPrenote&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 3, "incorrect number of EDI trackedItems");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPrenote2" id="4986b883-4106-4335-9241-6a603bbbba8e">
        <source>tPrenote2();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//10 Jun 2016	cnwrs1	TFS 2150 - If you process an operatorCode and there is not xlation operator then start using that operator
//
constants
	USER_DEF_NAME : String = "JMTInternalPrenote";
	VESSEL_CODE	: String = "UTXVES1";
	VOYAGE_CODE	: String = "UTXVOY1";
	CONTAINER_ID01 : String = "TEST0000001";
	CONTAINER_ID02 : String = "TEST0000002";
	CONTAINER_ID03 : String = "TEST0000003";
vars
	containerObj : CM_TrackedItem;
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	operator : CM_Operator;
begin
	passportObj	:=	app.myPassport;
	self.deleteContainer(CONTAINER_ID01);
	containerObj := self.getTrackedItem(CONTAINER_ID01);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID02);
	containerObj := self.getTrackedItem(CONTAINER_ID02);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID03);
	containerObj := self.getTrackedItem(CONTAINER_ID03);
	self.assertIsDeleted(containerObj);
	// Create the Vessel and the Voyage.
	self.deleteVessel(VESSEL_CODE);
	vesselObj	:=	self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vesselObj);
	self.deleteVoyage(VOYAGE_CODE);
	voyageObj	:=	self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyageObj);
	self.createVoyageVessel(VOYAGE_CODE, VESSEL_CODE, voyageObj, vesselObj);
	self.assertNotNullMsg(vesselObj, "Add vessel failed!");
	operator := self.getOperator("MSK");
	self.deleteEDIInwardXlation("22ZZ", XLATION_TYPE_ISOTYPE_BYOP, operator, null);	
	self.createEDIXlation("22ZZ", "22G1", XLATION_TYPE_ISOTYPE_BYOP, false, operator, null);
	self.deleteEDIInwardXlation("MAERSK SEALAND", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAERSK SEALAND", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
	self.deleteEDIInwardXlation("MAEU", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAEU", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;SystemXMLPrenote&gt;
&lt;xlateOperatorCode&gt;MAEU&lt;/xlateOperatorCode&gt;
&lt;AllPrenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID01&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;22ZZ&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MAERSK SEALAND&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;111111OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;111111InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID02&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;222222OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;222222InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID03&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;333333OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;333333InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;/AllPrenote&gt;
&lt;/SystemXMLPrenote&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 3, "incorrect number of EDI trackedItems");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPrenote3" id="33f3e788-bc3e-487f-94d9-046af3b7cb41">
        <source>tPrenote3();
//
// 17 Aug 2016 - cnwrs1 - TFS 2562 test string too long
//
constants
	USER_DEF_NAME : String = "JMTInternalPrenote";
	VESSEL_CODE	: String = "UTXVES1";
	VOYAGE_CODE	: String = "UTXVOY1";
	CONTAINER_ID01 : String = "TEST0000001";
	CONTAINER_ID02 : String = "TEST0000002";
	CONTAINER_ID03 : String = "TEST0000003";
vars
	containerObj : CM_TrackedItem;
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	operator : CM_Operator;
begin
	passportObj	:=	app.myPassport;
	self.deleteContainer(CONTAINER_ID01);
	containerObj := self.getTrackedItem(CONTAINER_ID01);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID02);
	containerObj := self.getTrackedItem(CONTAINER_ID02);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID03);
	containerObj := self.getTrackedItem(CONTAINER_ID03);
	self.assertIsDeleted(containerObj);
	// Create the Vessel and the Voyage.
	self.deleteVessel(VESSEL_CODE);
	vesselObj	:=	self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vesselObj);
	self.deleteVoyage(VOYAGE_CODE);
	voyageObj	:=	self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyageObj);
	self.createVoyageVessel(VOYAGE_CODE, VESSEL_CODE, voyageObj, vesselObj);
	self.assertNotNullMsg(vesselObj, "Add vessel failed!");
	operator := self.getOperator("MSK");
	self.deleteEDIInwardXlation("22ZZ", XLATION_TYPE_ISOTYPE_BYOP, operator, null);	
	self.createEDIXlation("22ZZ", "22G1", XLATION_TYPE_ISOTYPE_BYOP, false, operator, null);
	self.deleteEDIInwardXlation("MAERSK SEALAND", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAERSK SEALAND", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
	self.deleteEDIInwardXlation("MAEU", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAEU", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;SystemXMLPrenote&gt;
&lt;xlateOperatorCode&gt;MAEU&lt;/xlateOperatorCode&gt;
&lt;AllPrenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;FURITURE&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID01&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;22ZZ&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MAERSK SEALAND&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;111111OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;111111InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;SPOTTED PAINT&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID02&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;222222OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;222222InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;GLASS TACKS&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID03&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;333333OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;333333InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;/AllPrenote&gt;
&lt;/SystemXMLPrenote&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 3, "incorrect number of EDI trackedItems");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPrenote4" id="b29e06b9-8d54-4473-8486-61f149d25848">
        <source>tPrenote4();
//
//01 Dec 2016	cnwrs1	TFS 2987 if no cooling type check with container Range
//
constants
	USER_DEF_NAME : String = "JMTInternalPrenote";
	VESSEL_CODE	: String = "UTXVES1";
	VOYAGE_CODE	: String = "UTXVOY1";
	CONTAINER_ID01 : String = "AALU4308196";
vars
	containerObj : CM_TrackedItem;
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	operator : CM_Operator;
	ti : CM_TrackedItem;
begin
	passportObj	:=	app.myPassport;
	self.deleteContainer(CONTAINER_ID01);
	containerObj := self.getTrackedItem(CONTAINER_ID01);
	self.assertIsDeleted(containerObj);
	// Create the Vessel and the Voyage.
	self.deleteVessel(VESSEL_CODE);
	vesselObj	:=	self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vesselObj);
	self.deleteVoyage(VOYAGE_CODE);
	voyageObj	:=	self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyageObj);
	self.createVoyageVessel(VOYAGE_CODE, VESSEL_CODE, voyageObj, vesselObj);
	self.assertNotNullMsg(vesselObj, "Add vessel failed!");
	operator := self.getOperator("MSK");
	self.deleteEDIInwardXlation("22ZZ", XLATION_TYPE_ISOTYPE_BYOP, operator, null);	
	self.createEDIXlation("22ZZ", "22G1", XLATION_TYPE_ISOTYPE_BYOP, false, operator, null);
	self.deleteEDIInwardXlation("MAERSK SEALAND", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAERSK SEALAND", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
	self.deleteEDIInwardXlation("MAEU", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAEU", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;SystemXMLPrenote&gt;
&lt;xlateOperatorCode&gt;MAEU&lt;/xlateOperatorCode&gt;
&lt;AllPrenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;15001&lt;/weight&gt;
&lt;commodity&gt;FZBF&lt;/commodity&gt;
&lt;temperature&gt;-18&lt;/temperature&gt;
&lt;id&gt;'&amp;CONTAINER_ID01&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MAERSK SEALAND&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;111111OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;111111InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;/AllPrenote&gt;
&lt;/SystemXMLPrenote&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS,
//						CM_EDIFile.EDI_STATUS_DBLOADED);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	ti := self.getTrackedItem(CONTAINER_ID01);
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.getISOType, "2031".String, "wrong isotype");
	self.assertEqualMsg(ti.getCoolingType.String, "2".String, "wrong cooling type");
end;</source>
    </JadeMethod>
    <JadeMethod name="tPrenoteAction" id="f45148c0-ee4f-4575-9fa7-ea2a00540965">
        <source>tPrenoteAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalPrenote";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
//	BookingId1 = 'BK27418';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalPrenote xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalPrenote.xsd"&gt;
	&lt;AllPrenote&gt;
