    <JadeMethod name="cmbValidated_displayEntry" id="77b9d2fc-a1d5-4cb0-9f13-0900fdf7828b">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbValidated_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation

*/

vars

	pilot : HMS_Pilot;

begin

	if obj = null or not obj.isKindOf( HMS_Pilot )then
		return null;
	endif;
	
	pilot := obj.HMS_Pilot;
	
	return pilot.description &amp; ' ('&amp; pilot.code &amp; ')';

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbVessel_change" id="12b99535-e046-4007-8744-0dfd09ccdb9e">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVessel_change(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	obj : Object;
	vessel : CM_Vessel;
	tmpStr : String;

begin

	obj := combobox.listObject;
	if obj = null or not obj.isKindOf( CM_Vessel ) then
		self.lblLoaGrt.caption := null;
	else
		vessel := obj.CM_Vessel;
		tmpStr := "LOA: " &amp; vessel.getDisplayStringForAttribute(ETRow_LengthOverall,false);
		tmpStr := tmpStr &amp; "    GRT: " &amp; vessel.getDisplayStringForAttribute(ETRow_GrossRegTonnes,false);
		self.lblLoaGrt.caption := tmpStr;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
