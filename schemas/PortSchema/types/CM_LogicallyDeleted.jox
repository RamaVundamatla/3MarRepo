<Class name="CM_LogicallyDeleted" id="e1f57451-9e44-4de1-9207-e9934b018da5">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <ImplicitInverseRef name="myLogicalDelArea" id="7e429e1d-970a-4899-aef1-af80c28cfe72">
        <embedded/>
        <type name="CM_BlockController"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getDisplayStringForAttribute" id="959e7a46-3333-4909-867d-576cccd979dc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2017	jlgndl1	Initial creation	TFS 5679

*/

vars

	lDetail : String;

begin

	if _attrName = ETRow_Details  then
	
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := self.typeString;
			return lDetail;
			
		endif;

	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyDelArea" id="50c2ed89-2d37-4e8f-88a9-63339c3f4962">
        <updating/>
        <source>setMyDelArea( _delArea : CM_BlockController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2017	jlgndl1	Initial creation	TFS 5679

*/

vars

begin

	self.myLogicalDelArea := _delArea;

epilog

end;</source>
        <Parameter name="_delArea" type="CM_BlockController"/>
    </JadeMethod>
</Class>
