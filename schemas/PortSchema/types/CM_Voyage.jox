    <JadeMethod name="getAllWLEs" id="1347dee0-21d8-4148-b6ce-d8aace6a0e41">
        <source>getAllWLEs(_wleArray: CM_WLEArray input);
//--------------------------------------------------------------
//Created: 16 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	job : CM_Job;
	jobSht : CM_JobSheet;
begin
	inheritMethod(_wleArray);
	
	// Use the job on the jobSheets as they are loaded to operations
/*	foreach jobSht in self.allJobSheets do
		jobSht.getAllWLEs(_wleArray);
	endforeach;*/
	
	foreach job in self.allVoyageJobs do
		if job.CM_VoyageJob.isLoadedToOperations then
			job.getAllWLEs(_wleArray);
		endif;
	endforeach;	
	
end;</source>
