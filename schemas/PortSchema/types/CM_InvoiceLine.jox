    <JadeMethod name="getLineTotalConverted" id="4cb5fa7f-7809-4904-ae6b-3f12aa9b92c1">
        <source>getLineTotalConverted( _rate : CM_CurrencyRate ) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2018	jlgndl1	Initial creation	TFS 41684

*/

vars

	charge: CM_Charge;
	rateTotal: Real;
	// TFS 42431 	tot: Decimal[23,6];
	// TFS 43253 tot: Decimal[23,2]; // TFS 42431 
	tot: Decimal[23,6]; // TFS 43253
begin

	if self.invoiceLineDesc &lt;&gt; null and self.invoiceLineDesc.currencyConversionNotRequired then
		return self.lineTotal;
	endif;
	
	if _rate &lt;&gt; null and _rate.rate &lt;&gt; 0 then
	//	return _rate.rate * self.lineTotal;
	
		//27 Nov 2018	NDL	TFS 42218
		// New rule is to apply the exchagre rate to the charge rate
		// before multiplying by the quantity of the line
		foreach charge in self.charges discreteLock do
			rateTotal := rateTotal + charge.getConvertedRate( _rate.rate );
		endforeach;
		tot := rateTotal * self.quantity;
		return tot;
		
	else
		return self.lineTotal;
	endif;

epilog

end;</source>
        <Parameter name="_rate" type="CM_CurrencyRate"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getLineTotalTen" id="718b35b6-bbc6-42ed-9ecf-9fc782f5b36c">
        <source>getLineTotalTen() : Decimal;
/*

Purpose:			Return total amount in 10 decimal

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2025	navkc1 JIRA EPIC-34131 STORY-34815 GPHA | XML Invoice Export 10DC - Ten Decimal Place Methods

*/

vars
	charge		: CM_Charge;
	total		: Decimal[23,10];
begin
	
	total := 0; // Set this so it display 10 decimal 
	
	foreach charge in self.charges discreteLock do
		total += charge.getChargeTotalTen();
	endforeach;
	
	return total;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getLineTotalTenString" id="eb43a3e7-3148-4a93-963c-2aa4a7576d2b">
