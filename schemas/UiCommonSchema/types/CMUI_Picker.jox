    <JadeMethod name="tblList_contextMenu" id="78ff11c5-004f-45a6-928a-a299cec051c1">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblList_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2017	cnwndl1	Initial creation	TFS 3758

*/

vars

	xLeft : Real;
	yTop : Real;
	

begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	
	self.mnuInspect.visible := app.isAllowedToInspect();	
	self.mnuInspect.userObject := table.accessRow( table.row ).itemObject;

	self.popupMenu(mnuContext, xLeft.Integer, yTop.Integer);
	self.mnuColumnOrganiser.userObject := table;

	return false;


epilog

end;</source>
