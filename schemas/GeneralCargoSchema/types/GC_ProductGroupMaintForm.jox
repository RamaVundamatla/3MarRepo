        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
begin
	inheritMethod();
	
// cnwdad1 14/07/2006 - PAR #12098.
// First of all, the "Is available for entry" should not be hidden,
// secondly, this is not the right place for error messages, as "return"
// doesn't stop the add/edit from continuing.
//	if self.mode = Mode_Add then
//		if self.aMyCurrentCargoType = null then
//			app.msgBox("Please select a cargo type", "Query Error", MsgBox_Exclamation_Mark_Icon);
//			return;
//		endif;
//		
//		self.tblEntDetail.hideRowByName(ETRow_IsAvailableForEntry, false);
//	else
//	
//	endif;
	
	self.fldEntDetail.visible := true;
	self.populateEntDetailTable();
	self.enableDisableControls();	//Par 18269 April 2009
	self.setProductsAvailable();

	self.tblEntDetail.setFocus;
//elf.tblEntDetail.goToRowByName(ETRow_Narration);
	self.fldEntDetail.initSheetBackColors();
end;</source>
