    <JadeMethod name="getNumOnsiteItemsUnpacked" id="3338b621-c293-43a0-8ec3-c4a4b58e6a5b">
        <source>getNumOnsiteItemsUnpacked():Integer;
/*
	Created on 30 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	ti : CM_TrackedItem;
	i : Integer;
begin
	foreach ti in self.allTIs 
	where (ti.state &lt;&gt; TI_STATE_NOTIFIED
	and ti.myParent = null) do
		i := i + 1;
	endforeach;
	return i;
end;</source>
