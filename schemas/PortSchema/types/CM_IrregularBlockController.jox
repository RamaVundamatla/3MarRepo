    <JadeMethod name="getTIs" id="3545e32b-1127-4458-ae17-922a21ae4fa9">
        <source>getTIs(array: CM_TIArray input; mode: Integer; _clear: Boolean);
/*
Purpose:			
Date		Who		Reason
06 Sep 2013	cnwab1	Initial creation
02 Apr 2024 navma1	ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
*/

vars

	ti	  : CM_TrackedItem;
	shelf : CM_RackShelfController;
begin
	if _clear then
		array.clear();
	endif;
	if self.isRack then
		foreach shelf in self.allSubLocations discreteLock do
			if mode = REAL_MODE then
				/*
				//02.04.2024 navma1 #63302
				foreach ti in shelf.allTrackedItems discreteLock do
					array.add(ti);
				endforeach;
				*/
				shelf.allTrackedItems.tryCopy(array);						//02.04.2024 navma1 #63302
			elseif mode = PLANNING_MODE then
				shelf.getAllPlannedTrackedItems(array, _clear, false);
			elseif mode = QUEUE_MODE then
				shelf.getAllQueuedTrackedItems(array, _clear);
			endif;
		endforeach;

	else
		inheritMethod(array, mode, _clear);
	endif;
epilog

end;</source>
        <Parameter name="array" type="CM_TIArray" usage="input"/>
        <Parameter name="mode" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTotalsByMode" id="b6441888-56a8-435d-94de-a33848f09950">
        <source>getTotalsByMode(_mode : Integer; _vol, _weight : Decimal io; _qty : Integer io);
/*
Purpose:			
Date		Who		Reason
05 September 2013	cnwab1	Initial creation
*/

vars
	array : CM_TIArray;
	ti : CM_TrackedItem;
begin
	create array transient;
	self.getTIs(array, _mode, true);
	
	foreach ti in array discreteLock do
		_vol := _vol + ti.totalVolume;
		_weight := _weight + ti.totalWeight;
		_qty := _qty + ti.totalQuantity;
	endforeach;
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_vol" type="Decimal" usage="io"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
        <Parameter name="_qty" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getYACapacity" id="62f06031-b769-431b-baa6-cef68da92939">
        <source>getYACapacity():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2020	jlgndl1	Initial creation	TFS 49775

*/

vars

	yaCapacity : Integer;
	subLoc : CM_RackShelfController;
	
begin

	if self.allSubLocations.isEmpty then
		yaCapacity := self.maxCapacity;
	
	else
		foreach subLoc in self.allSubLocations do
			yaCapacity := yaCapacity + subLoc.getYACapacity;
		endforeach;
	
	endif;
	
	return yaCapacity;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getYACapacityStr" id="d0eb101c-b171-4653-837b-b911f54bb754">
