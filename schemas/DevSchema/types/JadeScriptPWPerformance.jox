	str : String;
	
begin
	app.initialize();
	create arr transient;
	
	i := 1;
	foreach i in 1 to 10000 do
		arr.add("Prefixed string in array 1");
	endforeach;
	
	
	clock  := app.clock.String;
	folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
	prof   := process.profiler;	
	prof.methodCount := 50;
	prof.fileName := folder &amp;"\PW\" &amp; "myFile_" &amp; clock &amp; ".txt";
	prof.clearMethodCache();
	
	prof.start;
	
	foreach str in arr do
		str.replaceAll_regex("String", "StringMine", false);
		
	endforeach;
	
	if prof &lt;&gt; null then
		prof.report;
	endif;
	
epilog
	arr.clear;
	delete arr;
	
end;</source>
