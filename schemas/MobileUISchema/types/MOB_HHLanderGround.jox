    <JadeMethod name="doClickInTransit" id="97f1063f-8490-4c82-ab19-90a61a7d3653">
        <updating/>
        <source>doClickInTransit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2012	cnwndl1	Initial creation	Par 29961

*/

vars

	errMess : String;

begin

	if not self.myMobileGenericAgent.hhLanderGroundingOpt = BothOpts 
	and not self.myMobileGenericAgent.hhLanderGroundingOpt = GroundInTransit 
	then
		errMess := "Invalid Ground option to be here!";
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return;
	endif;
	
	if self.doComplete( GroundInTransit ) then
		self.myMobileGenericAgent.setMyNextTiToAction(null);
		self.doBackButtonClick();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doComplete" id="1cd4624a-edd9-4262-9f26-49602d8e6c36">
        <source>doComplete( _groundOption : Integer ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwndl1	Initial creation	Par 23603

*/

vars

	errMess : String;
	tmpFoundLC : CM_LocationsController;
	
	currentLocation : CM_LocationsController;
	voyage : CM_Voyage;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	rtQueTask : CM_RTQueueTask;
	rtQueTaskToUpdate : CM_RTQueueTask;
	result	: Integer;
	nwnp : Boolean;
begin

	if self.myTrackedItem = null then
		errMess := app.getErrorString(No_Cargo_identified);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;
	
	if not self.findLocationToMoveTo( tmpFoundLC ) then
		return false;
	endif;

	if self.myTrackedItem.myPrimaryActualLocation = tmpFoundLC then
		errMess := app.getErrorString2(Cargo_already_located, self.myTrackedItem.id, self.cmbTerminalArea.text);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;
	
	//20 May 2010	NDL	Par23603
	currentLocation := self.myTrackedItem.myPrimaryActualLocation;
	if self.myTrackedItem.getFirstAvailableDischargeJob() = null then
		voyage := self.myMobileGenericAgent.myVoyage;
		if currentLocation &lt;&gt; null and voyage &lt;&gt; null then
			if currentLocation = voyage.myShipBlockStack then
				// it is unplanned unworked cargo, on the ship, try autoplaning and queuing it
				self.myMobileGenericAgent.doQueueUnplannedUnworkedCargo(self.myTrackedItem, job, wle,0,0,null);
				nwnp := true;
			elseif currentLocation = voyage.myNotNotifiedStack then	//12 Sep 2011	NDL	Par 28173
				//14 June 2012	NDL	Par 29745
				if _groundOption = GroundInTransit then	//10 Jul 2012	NDL	Par 29961
					self.myMobileGenericAgent.doQueueUnplannedUnworkedCargo(self.myTrackedItem, job, wle,0,0,null);
				endif;
				//epr par 35862 13/3/15
				return self.doDischargeToGroundTrx(_groundOption,self.myTrackedItem,tmpFoundLC,job, wle,  0, 0);
			endif;
		endif;
	endif;
	
	//epr PAR 25038 15/7/10
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then
	
		if not self.doImportGetJobWLE(self.myTrackedItem, job, wle, errMess) then
			if not nwnp then
				errMess := Work_list_entry_found.String &amp; " - " &amp; app.getErrorString(Work_list_entry_found) &amp; CrLf &amp; errMess;
				self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
				return false;
			endif;
		endif;
		if _groundOption = GroundInTransit and not self.myTrackedItem.isQueued then	//11 Jul 2012	NDL	Par 29961
			if self.myTrackedItem.isPlanned(PLANNING_MODE) then	//13 Aug 2012	NDL	Par 29961
				self.myMobileGenericAgent.doPromotePlannedToQueued( self.myTrackedItem, wle );
			else
				self.myMobileGenericAgent.rePlanTi( self.myTrackedItem, job, 0 );
			endif;
		endif;
		
		return self.doDischargeToGroundTrx(_groundOption,self.myTrackedItem,tmpFoundLC,job, wle,  0, 0);	//14 June 2012	NDL	Par 29745
	
	endif;
	
	
	if wle = null then
	//	wle := self.myTrackedItem.getVoyageWLEUnactioned( false );
		wle := self.myTrackedItem.getVoyageWLEForLCUnactioned( false, tmpFoundLC );	//23 Jun 2016	NDL	TFS 2172
	endif;
	
	//20 May 2010	NDL	Par 23603 - Pass a null wle when going to ground, so that we don't lose the rtq entry...
	//								Unles it was actaully auto planned to the user selected ground location.
	if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; tmpFoundLC then
		wle := null;
	endif;
	
	if not self.myMobileGenericAgent.moveTI( self.myTrackedItem, null, tmpFoundLC, wle, false, 0, 0, null ) then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_groundOption" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doImportGetJobWLE" id="c7d5e708-c032-4927-8ecc-cf59b32ec863">
        <source>doImportGetJobWLE(_ti : CM_TrackedItem input; _job : CM_VoyageJob output; _wle : CM_WorkListEntry output; msgStr : String output) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 March 2010	cnwndl1	Initial creation //epr PAR 25038 15/7/10
29 May 2017		cnwma1  TFS #4310 75664 error when using Lander App
*/

vars
	voyage : CM_Voyage;
	currentLocation : CM_LocationsController;
	
begin

	_job := _ti.getFirstAvailableDischargeJob();
	
	//20 May 2010	NDL	Par23603
	if _job = null then
	//	_wle := _ti.getVoyageWLEUnactioned( false );
		_wle := _ti.getVoyageWLEForLCUnactioned( false, null );	//23 Jun 2016	NDL	TFS 2172
		if _wle &lt;&gt; null then
			_job := _wle.job.CM_VoyageJob;
		endif;
	endif;
	if _job = null then
		currentLocation := _ti.myPrimaryActualLocation;
		voyage := self.myMobileGenericAgent.myVoyage;
		if currentLocation &lt;&gt; null and voyage &lt;&gt; null then
			if currentLocation = voyage.myShipBlockStack then
				// it is unplanned unworked cargo, on the ship, try autoplaning and queuing it
				self.myMobileGenericAgent.doQueueUnplannedUnworkedCargo(_ti, _job, _wle,0,0,null);
			endif;
		endif;
	endif;
	
	if _job = null then
		//Error! Not a voyage Job
		msgStr := ERR_TINOT_MACH_TYPE.String &amp; " - " &amp; app.getErrorString2(ERR_TINOT_MACH_TYPE, _ti.id.trimBlanks,app.getErrorString(NoCompatibleJobFound)); //29/05/2017 cnwma1 TFS #4310
		return false;					
	endif;
	
	if _wle = null then
		_wle := _job.getWLEForTI(_ti);
	endif;

	return (_wle &lt;&gt; null);
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="msgStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="77e21a2f-b0ac-42ad-8006-e5147f007d0e">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation

*/

vars

	top : Real;
	stdWidth : Real;
	width : Real;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	top := self.resizedMargin;
	width := stdWidth - self.getSearchButtonSpace();
	if _initialSetup then
		self.txtCargoId.visible := true;
		self.txtCargoId.enabled := false;
	endif;
	self.txtCargoId.move( self.resizedMargin,
						 top,
						 width,
						 stdHeight );
						 
	top := top + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.lblGroundCargo.visible := true;
	endif;
	self.lblGroundCargo.move( self.resizedMargin,
							 top,
							 width,
							 stdHeight );
						 
	top := top + self.lblGroundCargo.height + self.resizedMargin;
	if _initialSetup then
		self.cmbTerminalArea.visible := true;
	endif;
	self.cmbTerminalArea.move( self.resizedMargin,
							 top,
							 width,
							 stdHeight ); 
							 
	top := top + self.cmbTerminalArea.height + self.resizedMargin;
	if _initialSetup then
		self.cmbLane.visible := true;
	endif;
	self.cmbLane.move( self.resizedMargin,
							 top,
							 width,
							 stdHeight ); 
							 
	self.txtCargoId.text := myTrackedItem.id;
	self.populateTerminalAreas();
	
	
	//10 Jul 2012	NDL	Par 29961
	self.btnInTransit.visible := false;
	if self.myMobileGenericAgent.hhLanderGroundingOpt = BothOpts or self.myMobileGenericAgent.hhLanderGroundingOpt = GroundInTransit then
	
		if self.myMobileGenericAgent.hhLanderGroundingOpt = GroundInTransit then
			top := btnOne.top;
			btnOne.visible := false;
		else
			top := btnOne.top - btnOne.height - (self.resizedMargin * 2);
		endif;
		
		if _initialSetup then
			btnInTransit.visible := true;
		endif;
		self.btnInTransit.move( btnOne.left,
								top,
								btnOne.width,
								stdHeight );
	endif;


	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocationToMoveTo" id="20ec662f-e427-4a13-b4ff-ae480a86dd56">
        <source>findLocationToMoveTo( tmpFoundLC : CM_LocationsController output ):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwndl1	Initial creation	Par 23603

*/

vars

	errMess : String;
	
begin

	if self.cmbTerminalArea.listObject = null then
		errMess := self.lblTerminalArea.caption.toUpper;
		self.cmbTerminalArea.setFocus();
	elseif self.cmbLane.listObject = null then
		errMess := self.lblLane.caption.toUpper;
		self.cmbLane.setFocus();
	else
		tmpFoundLC := self.cmbLane.listObject.CM_LocationsController;
	endif;
	
	if tmpFoundLC = null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		self.cmbLane.setFocus();
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="tmpFoundLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
