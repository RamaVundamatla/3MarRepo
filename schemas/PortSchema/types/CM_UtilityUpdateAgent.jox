    <JadeMethod name="utlUpdateEWSforBGPRequest" id="d66d6027-c8b4-4cca-af91-bb800e9e8871">
        <updating/>
        <source>utlUpdateEWSforBGPRequest(_bgpObject : BGP_ExternalWSController input; 
		_status : String; 
		_passport : CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
18AUG2021	NAVAB1	TFS 50669
*/

vars
	realObject		: CM_TrxTestObject;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_bgpObject, 'BGP_ExternalWSController Object');

	app.setContinueCMExceptions(true);

	/*
	app.myValUA.aValSample(_pxyObject, _controller);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'Test Object', _passport).CM_TrxTestObject;
*/
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		if _bgpObject.myExternalWSDef.isOpsView() then
			if _status = EWS_STATUS_STARTING then
				// setting the BGP status to STARTING will stop bgp request from being created.
				_bgpObject.setStatus(EWS_STATUS_STARTING);
				if _bgpObject.myExternalWSDef.CM_OpsViewServiceDef.lastSuccessfullSequence &gt; 0 then // last sequence number
					_bgpObject.myExternalWSDef.createBGPRequestsForSEQUENCE();
				else
					_bgpObject.myExternalWSDef.createBGPRequestsForSTARTING();
				endif;
				
			elseif _status = EWS_STATUS_RUNNING then
				// 'process any activity created during starting and stopped producer statuses
				_bgpObject.myExternalWSDef.createBGPRequestsForRUNNING();
				
				// setting to RUNNING will mean that new BGP requests will be created when the activity is created
				_bgpObject.setStatus(EWS_STATUS_RUNNING);
			elseif _status = EWS_STATUS_STOPPED then
				// 'process any activity created during starting and stopped producer statuses
				_bgpObject.myExternalWSDef.createBGPRequestsForSTOPPING();
				
				// setting to STOPPED will mean that new BGP requests will NOT be created when the activity is created
				_bgpObject.setStatus(EWS_STATUS_STOPPED);

			elseif _status = EWS_ACTION_SNAPSHOT then
				// logically delete all paused EWS activity
				// the producer API will be responding with isSnapShotRequired= true this will make producer call API for snap shot data.
				// whilst its doing that STOP the BGP conroller.
				_bgpObject.setStatus(EWS_STATUS_STOPPED);
				_bgpObject.myExternalWSDef.updateActivityForSNAPSHOT();
				
				// setting to STOPPED will mean that new BGP requests will NOT be created when the activity is created
			endif;
			
			

		endif;
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;

end;</source>
        <Parameter name="_bgpObject" type="BGP_ExternalWSController" usage="input"/>
        <Parameter name="_status" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEasyGateIn" id="80e84496-d6c4-476c-a8c2-158b4faf4d49">
        <updating/>
        <source>utlUpdateEasyGateIn( _ifEasyGateOut : CMIF_EasyGateController io; _passport : CM_Passport input) updating;
/*

Purpose:	called at end of trxCreateEasyGatein			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2010	cnwrd1	Initial creation

*/

vars
	easyGateOut : CMIF_EasyGateController;
	itm		: CM_InterTerminalMove;
begin

	self.initialiseActivity();
	easyGateOut := _ifEasyGateOut;

	foreach itm in easyGateOut.allMovesForOffloading do
	//	if itm.myTargetTerminal = easyGateOut.myTerminal then
			exclusiveLock(itm);
			itm.setMyTargetVVR(easyGateOut.myVehicleVisit); //should set the vehicle too			
			itm.setStatus(ITT_UNLOADED);
			itm.removeFromJob();
	//	endif;
	endforeach;
		
	
epilog

end;</source>
        <Parameter name="_ifEasyGateOut" type="CMIF_EasyGateController" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEasyGateOut" id="07a54a99-bae7-4406-bf8d-b55f13fae948">
        <updating/>
        <source>utlUpdateEasyGateOut( _ifEasyGateOut : CMIF_EasyGateController io; _itm : CM_InterTerminalMove; _passport : CM_Passport input) updating;

/*

Purpose:	called at end of trxCreateEasyGateOut		

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2010	cnwrd1	Initial creation

*/

vars
	realVVR : CM_VehicleVisitRecord;
	tmpTerminal		: CM_Terminal; 
	easyGateOut : CMIF_EasyGateController;
	itm		: CM_InterTerminalMove;
begin

	self.initialiseActivity();
	easyGateOut := _ifEasyGateOut;

	itm := _itm;
	exclusiveLock(itm);
	itm.setMySourceVVR(easyGateOut.myVehicleVisit); //should set the vehicle too		
	
	if  itm.myTargetTerminal &lt;&gt; null then
		itm.mySourceTI.interTerminalRelease(itm.myTargetTerminal);
		itm.setMyTargetTI( itm.mySourceTI.myMoveCloneToTI  );
		//itm.mySourceTI.setMyInTransitTerminalTo( itm.myTargetTerminal );
		//itm.setMyTargetTI( itm.mySourceTI.cloneForInterTerminalPreNote( itm.myTargetTerminal ) );
	endif;
	itm.setStatus(ITT_LOADED);		
	//easyGateOut.allMovesForLoading.clear();  //now we have done clear this
epilog

end;</source>
        <Parameter name="_ifEasyGateOut" type="CMIF_EasyGateController" usage="io"/>
        <Parameter name="_itm" type="CM_InterTerminalMove"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEmailAddress2" id="40d7afc9-1412-4f86-a667-8689015dcb67">
        <source>utlUpdateEmailAddress2(_proxyEmailAddress	:CM_EmailAddress2; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realEmailAddress	: CM_EmailAddress2;
	expectedEdition		: Integer;
	
begin

	self.initialiseActivity();

	_proxyEmailAddress.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	app.myValUA.valEmailAddress2(_proxyEmailAddress);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;
	
	_proxyEmailAddress.pxyGetRealObjectAndEdition(realEmailAddress, expectedEdition);
	
	if realEmailAddress = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_EmailAddress2.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realEmailAddress);

	if _passport.noErrors and realEmailAddress.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'EmailAddress', null, null);
		return;
	endif;
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEmailAddress, true);
	endif;
	if _passport.noErrors then
		realEmailAddress.setForUpdate(_proxyEmailAddress);
	endif;
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEmailAddress, false);
	endif;

end;</source>
        <Parameter name="_proxyEmailAddress" type="CM_EmailAddress2"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEmailGroup" id="8778bd15-5b65-4089-8fc8-d97f04d69514">
        <source>utlUpdateEmailGroup(_proxyGroup : CM_EmailGroup; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
