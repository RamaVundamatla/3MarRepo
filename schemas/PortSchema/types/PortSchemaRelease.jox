    <JadeMethod name="addScriptRun" id="09b651bc-4156-4630-9bfc-614105a704a6">
        <source>addScriptRun(_scriptName : String);
/*

Date		Who		Reason
27 May 2015	cnwer1	Initial creation TFS 336 - Monthly Releases

*/

vars
	scriptRun : CM_String;
begin
	if _scriptName = null then
		return;
	endif;
	
	if self.allScriptsRun[_scriptName] &lt;&gt; null then
		return;
	endif;
	
	beginTransaction;
	create scriptRun persistent;
	scriptRun.string:=_scriptName;
	self.allScriptsRun.add(scriptRun);
	commitTransaction;

epilog

end;</source>
        <Parameter name="_scriptName" type="String"/>
    </JadeMethod>
    <JadeMethod name="buildStorageConfigTypes" id="0ad7ee7b-9b40-4a5d-a5a2-93c0f6233e48">
        <source>buildStorageConfigTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 November 2017	jlgndl1	Initial creation	TFS 7032

*/

vars

	storageConfigType : CM_StorageConfigType;
	subs : ClassColl;
	subClass : Class;

begin
	
	//ensure we have one instance of 'CM_StorageConfigType', this is the default one.
	if CM_StorageConfigType.firstInstance = null then
		beginTransaction;
		create storageConfigType persistent;
		commitTransaction;
	endif;
	
	create subs transient;
	CM_StorageConfigType.allSubclasses(subs);
	
	//ensure we have one instance of every sub class of 'CM_StorageConfigType'.
	foreach subClass in subs do
		if subClass.firstInstance = null then
			beginTransaction;
			create storageConfigType as subClass persistent;
			commitTransaction;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
