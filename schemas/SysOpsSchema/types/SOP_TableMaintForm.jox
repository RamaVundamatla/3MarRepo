    <JadeMethod name="setTableItemSingle" id="55e8e843-3c2f-4ac7-8fb9-49b0926f5879">
        <updating/>
        <source>setTableItemSingle(_sopTableItemClass : Class) updating;
/*
Purpose:			
Date		Who		Reason
07 May 2014	cnwab1	Initial creation
1/10/2018 	JLGNS1	Bug 40711: CIG - Object Null Reference on UAT after deploy 851.220
*/

vars
	item		: SOP_TableMaintItem;
	tmpUser			: CM_User;

	tmpTerminal	: CM_Terminal;
begin
	
	self.setCurrentTableItem(null);							
	tmpUser := app.getMyUser();

	self.allTableItems.purge;

	create item as _sopTableItemClass transient;
	
	if item.isSystemItem then
		tmpTerminal := null;
	else
		tmpTerminal := self.myTerminal;
	endif;

			
	if (item.permissionGroup &lt;&gt; 0 and 
	   (not tmpUser.canDo(tmpTerminal, item.permissionGroup))) or 
	   (not tmpUser.canDo(tmpTerminal, item.permissionView))
	then			
		delete item;

	endif;		
	
	if item &lt;&gt; null then			 //Bug 40711
		self.allTableItems.add(item);//Bug 40711
	endif;							 //Bug 40711
	
	self.setCurrentTableItem(item);
	
	
	
	if self.allTableItems.isEmpty then
		self.permissionMaint	:= 0;
		self.permissionView		:= 0;
	else
		item := self.allTableItems.first;
		self.permissionMaint	:= item.permissionMaint;
		self.permissionView		:= item.permissionView;
	endif;
epilog

end;</source>
        <Parameter name="_sopTableItemClass" type="Class"/>
    </JadeMethod>
