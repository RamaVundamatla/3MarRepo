    <JadeMethod name="setProxyBaseData" id="3c198577-7447-42bd-b767-12e57c650bf3">
        <updating/>
        <source>setProxyBaseData( _terminal : CM_Terminal; _shipLineStatus : CM_ShippingLineStatus) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX

