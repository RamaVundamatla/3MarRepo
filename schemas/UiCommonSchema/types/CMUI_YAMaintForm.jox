    <JadeMethod name="txtGroupName_lostFocus" id="c1ce1357-dd82-4e71-b253-d2109ae1c69c">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtGroupName_lostFocus(textbox: TextBox input) updating;
// adm 080609 Par 19637 defaultYACodeChanged 
vars
	yaTemplate : CM_YATemplate;
begin
	if not defaultYACodeChanged then
		yaTemplate := cmbYATemplate.listObject.CM_YATemplate;	
		if yaTemplate = null then
			txtYACode.text := txtGroupName.text;
		else
			txtYACode.text := txtGroupName.text &amp; " - " &amp; yaTemplate.code;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
