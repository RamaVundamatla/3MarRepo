    <JadeMethod name="isSameCriteria" id="c415e202-b9e1-41e8-86e9-60e19fc014f8">
        <source>isSameCriteria(_compareData: SelfType): Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	idx,
	obj				: Object;
begin
	if self.allObjects.size &lt;&gt; _compareData.allObjects.size then
		return false;
	endif;
	foreach obj in self.allObjects do
		if (not _compareData.allObjects.includes(obj)) then
			return false;
		endif;
	endforeach;
	
	return true;

end;





</source>
        <Parameter name="_compareData" type="SelfType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValueUsed" id="d825e370-ea9b-4203-ae6e-b359ddfc9c50">
        <source>isValueUsed(pAllValues: Any): Boolean;
// --------------------------------------------------------------------------------
// Created:		13 June 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	paramValueObj	: Object;
	
begin
	foreach paramValueObj in pAllValues.ObjectArray do
		if self.allObjects.includes(paramValueObj) then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="pAllValues" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
