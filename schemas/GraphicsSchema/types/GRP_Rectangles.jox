    <JadeMethod name="button1_click" id="c0f3a2be-fdc7-4b55-91ce-d96fed17fa06">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>button1_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		22 July 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants
	RectSize = 100;
vars
	x,y,
	x1,y1, idx : Integer;
begin

	frameOne.autoRedraw := true;
	self.drawRectangles();
	
	return;
	
	x := 200;
	y := 200;

	x1 := x.Integer - RectSize;
	y1 := y.Integer - RectSize;
	self.point1.set(x1,y1);
	
	x1 := x.Integer + RectSize;
	y1 := y.Integer + RectSize;
	self.point2.set(x1,y1);


	
	foreach idx in 1 to 6 do
		self.frameOne.clearGraphics;
	
		self.frameOne.drawFillColor := Red;
		self.frameOne.drawFillStyle := idx;
		self.frameOne.drawFilledRectangle(self.point1.x,self.point1.y,self.point2.x,self.point2.y,self.frameOne.drawFillColor);
		self.frameOne.drawTextAt("Fill " &amp; idx.String, self.point1.x,self.point1.y,Black);
		process.sleep(1000);
		self.frameOne.refreshNow();
	endforeach;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawRectangles" id="12b82de7-0767-4b2c-99ce-b911d6e1206f">
        <source>drawRectangles();
// ---------------------------------------------------------------------------
// Created:		14 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	chars : StringArray;
	thex, they,idx, tmpX, tmpY, block, bay : Integer;
	label : String;
begin
	frame2.clearGraphics();
	frame2.autoRedraw := true;
	frame2.scaleMode := 0;
	frame2.drawWidth := 1;
	frame2.drawWindow := 0;
	frame2.caption := null;
	frame2.transparent := true;
	frame2.drawGrid(Frame.DrawGrid_Dots,10,10,Red);
	
	create chars transient;
	chars.add("A");
	chars.add("B");
	chars.add("C");
	chars.add("D");
	chars.add("E");
	chars.add("F");
	chars.add("G");
	chars.add("G");
	chars.add("G");
	frameOne.clearGraphics;
	frameOne.drawFillColor := White;
	block := 1;
	bay := 1;
	foreach thex in 1 to 16 do
//		block := (thex / 5).roundedUp();
		if block = 2 or block = 3 then
			if bay &gt;= 20 then 
				bay := 1;
				block := block + 1;
			endif;
		else
			if bay &gt; 20 then 
				bay := 1;
				block := block + 1;
			endif;
		endif;
		foreach they in 1 to 8 do
			
			label := chars[block] &amp; they.String &amp; bay.padLeadingWith("0",2);
			tmpX := (thex * 35);
			tmpY := (they * 17);
		
			frameOne.drawFilledRectangle(tmpX,tmpY, tmpX + 32, tmpY + 14,Blue);
			frameOne.drawTextAt(label,tmpX + 3,tmpY + 1,Blue);
		endforeach;
		bay := bay + 5;
	endforeach;
	
	frame2.refreshNow();
epilog delete chars;	
end;</source>
    </JadeMethod>
