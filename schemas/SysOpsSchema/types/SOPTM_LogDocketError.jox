    <JadeMethod name="includeObject" id="d35056d1-0399-4686-ba80-b910f42c0564">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2010	cnwas3	Initial creation

*/

vars

begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_DocketErrorType.notAvailableForEntry;
	endif;
end;</source>
