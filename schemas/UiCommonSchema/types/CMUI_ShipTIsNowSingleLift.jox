    <JadeMethod name="doLocate" id="3ad5fcc2-e80a-47f4-9743-abfed006b93a">
        <source>doLocate();
// ---------------------------------------------------------------------------
// Created:		16 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aTI : CM_TrackedItem;
	aJob : CM_VoyageJob;
	bayOne, bayTwo: CM_Bay ;
	mode : Integer;
begin
	aTI := self.tblData.accessRow(self.tblData.row).itemObject.CM_TrackedItem;
	if aTI = null then
		return;
	endif;

	aJob := aTI.getFirstAvailableDischargeJob();
	if aJob = null then
		aJob := aTI.getFirstAvailableLoadJob();
		mode := ShpDisplayMode_ColCodeLoad;
	else
		mode := ShpDisplayMode_ColCodeDisch;
	endif;
	if aJob = null then
		return;
	endif;

	aJob.getBays(bayOne, bayTwo);
	if bayOne = null then
		return;
	endif;
	
	

	self.myAssistant.showVoyagePlanningForm(self.myCurrentVoyage, bayOne, mode, self.myMasterMenuAction);

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="c1d5aa14-6ef6-4442-908d-5d91c8e97813">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin	
