<JadeWebServiceProviderClass name="JadeWebServiceProvider">
    <JadeMethod name="isLoggedOn" id="41f993b2-9dc6-432c-930f-46b03cb5b9e5">
        <source>isLoggedOn():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		12 October 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the current session has
//				a user.  If not, then we assume that the user has not logged on.
//
// Parameters:	None
//
// Returns:		True if the current session has a user, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (currentSession.myUser &lt;&gt; null);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidMessage" id="a55da64f-1ada-403c-924c-de32c60a309b">
        <source>isValidMessage(_isLoggingOn:Boolean; _errorMsg:String output):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		12 October 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the message is valid.
//
// Parameters:	_isLoggingOn - True if the client is logging on to a session.
//				_errorMsg - Output parameter containing error details if the message
//					is not valid.
//
// Returns:		True if the message is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _isLoggingOn then
		if self.isLoggedOn() then
			if _errorMsg = null then
				_errorMsg	:=	app.getErrorString(ERR_MS_ALREADY_LOGGED_ON);
			else
				_errorMsg	:=	_errorMsg &amp; CrLf &amp; app.getErrorString(ERR_MS_ALREADY_LOGGED_ON);
			endif;
			
			return false;
		else
			return true;
		endif;
	endif;
		
	if not self.isLoggedOn() then
		if _errorMsg = null then
			_errorMsg	:=	app.getErrorString(ERR_MS_NOT_LOGGED_ON);
		else
			_errorMsg	:=	_errorMsg &amp; CrLf &amp; app.getErrorString(ERR_MS_NOT_LOGGED_ON);
		endif;
		
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_isLoggingOn" type="Boolean"/>
        <Parameter name="_errorMsg" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xHandlerInterface" id="462c73c3-c2e5-4525-a99c-c87c0f4f870d">
        <source>xHandlerInterface(pExceptionObj:Exception; pErrorMsg:String output):Integer protected;
// --------------------------------------------------------------------------------
// Created:		11 October 2005 by cnwdad1
//
// Purpose:		General exception handler which allows the Service Provider to respond
//				(in the event of an exception) with the details of what went wrong.
//
// Parameters:	pExceptionObj - A Reference to the exception object.
//				pErrorMsg - The error message which the Service Provider will
//					return to the calling Service Consumer.
//
// Returns:		The exception 'resume next" flag, and an error message (output parameter).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	LOCKING_ERROR	: Integer = 1027;
	
vars
	errorCode		: Integer;
	errorMessage	: String;
	
begin
	abortTransaction;
	errorCode		:=	pExceptionObj.errorCode;
	errorMessage	:=	process.getErrorText(errorCode);
	
	if pExceptionObj.isSoapException() then
	
	else
		if pExceptionObj.extendedErrorText &lt;&gt; null then
			errorMessage	:=	errorMessage &amp; CrLf &amp; pExceptionObj.extendedErrorText;
		endif;
	endif;
	
	if errorCode = LOCKING_ERROR then
		pErrorMsg	:=	"The Mobile Server cannot complete you request due to locking errors. Contact your system administrator.";
	else
		pErrorMsg	:=	"The Mobile Server failed with error '" &amp; errorCode.String &amp; 
						"': " &amp; CrLf &amp; CrLf &amp; errorMessage;
	endif;
	
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <Parameter name="pErrorMsg" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</JadeWebServiceProviderClass>
