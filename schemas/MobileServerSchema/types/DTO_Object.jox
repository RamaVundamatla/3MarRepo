    <JadeMethod name="setFromPersistent" id="db829b69-53e2-4b59-b227-3bbd38e51011">
        <updating/>
        <source>setFromPersistent(_obj : Object) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.masterEdition	:= _obj.edition;
	self.masterOid		:= _obj.getOidString();
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
