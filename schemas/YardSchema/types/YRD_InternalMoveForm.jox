    <JadeMethod name="doOpenCloseSection" id="841ae6fb-3f3d-4381-a7a6-19c75eb1b29a">
        <updating/>
        <source>doOpenCloseSection(_sectionFrame: CMUI_FieldFrame; _nextSectionFrame: CMUI_FieldFrame; _button: CMUI_Button input; _opening: Boolean io) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation

*/

vars

begin

	// are we opening or closing
	if _sectionFrame = self.lblQueueInfo then
		_opening := self.closedQueueInfo;		
		self.closedQueueInfo := not _opening;			
	elseif _sectionFrame = self.lblSourceInfo then
			_opening := self.closedSourceInfo;
		self.closedSourceInfo := not _opening;
	elseif _sectionFrame = self.lblStatusInfo then
			_opening := self.closedStatusInfo;
		self.closedStatusInfo := not _opening;
	elseif _sectionFrame = self.lblTargetInfo then	
		_opening := self.closedTargetInfo;
		self.closedTargetInfo := not _opening;
	endif;
	
	inheritMethod(_sectionFrame, _nextSectionFrame, _button, _opening);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sectionFrame" type="CMUI_FieldFrame"/>
        <Parameter name="_nextSectionFrame" type="CMUI_FieldFrame"/>
        <Parameter name="_button" type="CMUI_Button" usage="input"/>
        <Parameter name="_opening" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doReleaseChange" id="6cd1359e-b50f-4236-af9f-0aa745e7c73a">
        <updating/>
        <source>doReleaseChange() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation

*/

vars

bulkRel : CM_BulkRelease;
begin

	
	bulkRel := self.cmbRelease.getObject().CM_BulkRelease;
	
	if bulkRel = null then
		// set fields to editable
		self.myInitialisingRelease := null;
		self.cmbOperator.enabled  := true; 
		self.cmbISOGroup.enabled  := true; //cnwrd1 par 23804 28.5.2010
		self.cmbISOType.enabled  := true;
		//self.cmbAvGrade.enabled  := true;
		self.lstMTGrades.enabled := true; //cnwrd1 par 26633 17.12.2010	// 30123 Aug 2012 changed from visible to enabled
	else
		
		self.myInitialisingRelease := bulkRel;
		self.doBuildComboReleaseItem();
		
		//populate 
		// job ID if blank = BR id
		if self.txtJobID.text = '' then
			//self.tblMain.setValueByName(ETRow_JobId, bulkRel.code);
			self.txtJobID.text := bulkRel.code;
		endif;
		
		/*
		self.tblMain.disableRowByName( ETRow_Operator);
		self.tblMain.setValueByName( ETRow_Operator , bulkRel.myOperator.code);		
		self.cmbOperator.listObject := bulkRel.myOperator;
		*/
		self.cmbOperator.setForObject(bulkRel.myOperator);
		
		self.cmbOperator.enabled  := false;
		self.cmbISOGroup.enabled  := false; //cnwrd1 par 23804 28.5.2010
		self.cmbISOType.enabled  := false;
		//self.cmbAvGrade.enabled  := false;
	//	self.lstMTGrades.enabled := false; // cnwrd1 par  31418 - removed, alwasy allow av changes.
		self.cmbSubTerminal.enabled  := false;
		self.cmbTargetSubTerm.enabled := false; //cnwrd1 par 27754 28.6.2011
		
		self.cmbSubTerminal.setForObject( bulkRel.mySubTerminal );
		self.cmbTargetSubTerm.setForObject( bulkRel.mySubTerminalTarget );
		self.doReleaseItemLostFocus(); //cnwrd1 par 22331 17.2.2010
		//self.tblMain.disableRowByName( ETRow_IsoType);				
		// self.tblMain.disableRowByName( ETRow_AvGrade); // for now
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doReleaseItemLostFocus" id="c9a4b360-dc78-444b-a978-2980cf4139f0">
        <updating/>
        <source>doReleaseItemLostFocus() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation

*/

vars
	releaseItem : CM_ReserveSelection;
	isoType : CM_ISOType;
	isoGroup : CM_ISOTypeGroup; //cnwrd1 par 23804 28.5.2010
	mtg		: CM_MTGrade;
	index 	: Integer;
	str		: String;
begin


	releaseItem := self.cmbReleaseItem.getObject().CM_ReserveSelection;
	
	if releaseItem &lt;&gt; null then
	
		isoGroup := releaseItem.myISOGroup; //cnwrd1 par 23804 28.5.2010
		if isoGroup &lt;&gt; null then
			self.cmbISOGroup.setForObject(isoGroup);
		else
			self.cmbISOGroup.setIndex( CNEC_NULL_INDEX);
		endif;
	
		isoType := releaseItem.myISOType;
		if isoType &lt;&gt; null then

			//self.tblMain.setValueByName( ETRow_IsoType , releaseItem.myISOType.code);
			//self.cmbISOType.listObject :=  releaseItem.myISOType;
			self.cmbISOType.setForObject(releaseItem.myISOType);
		else
			//self.tblMain.setValueByName( ETRow_IsoType , '');
			self.cmbISOType.setIndex( CNEC_NULL_INDEX);
		endif;
		
		//if releaseItem.totalRequested &gt; 0  then
		if self.txtNumRequested.getString.Integer &gt;= releaseItem.totalRequested or self.txtNumRequested.getString = null then		//+cnwml2 PAR25730
			//self.txtNumRequested.setValue(releaseItem.totalRequested ); 
			self.txtNumRequested.setValue(releaseItem.getTotalOutstanding());		// 21/01/2011 cnwmh5 #26777
		endif;
		
		
		
		self.myAssistant.setListTableMTGrade(self.lstMTGrade, releaseItem.allAvailabilityGrades);
		str := self.lstMTGrade.getSelectedString(CM_MTGrade::description.name);
		str := self.truncateDisplayString(str, -1);
		self.txtMTGrades.text := str;
		
		/*
		if releaseItem.allAvailabilityGrades.first &lt;&gt; null then
			//self.cmbAVGradecmb.enabled := true;
			self.lstMTGrades.enabled := true; //cnwrd1 par 26633 17.12.2010
			mtg := app.myRoot.allAvailabilityGrades[releaseItem.allAvailabilityGrades.first];
			index :=  self.cmbAVGradecmb.findObject(mtg);

			self.cmbAVGradecmb.listIndex := index;
			self.cmbAVGradecmb.setObjectAndOperator(mtg, self.cmbOperator.getObject().CM_Operator, null);
		endif;
		*/
		
	else
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemoveListTI" id="e1ac9450-dedf-43a9-b751-31bf8c375740">
