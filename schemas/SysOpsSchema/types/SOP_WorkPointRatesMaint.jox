    <JadeMethod name="getXMLSettingsForSave" id="7cf67150-a4f4-460f-ae8b-5fbd1b06960b">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation

*/

vars

	xmlStr : String;

begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; global.formatAsXML( self.tblRates.name, self.xmlStrTblRate );
	 
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="3c3dfb10-dbaf-475b-b2b4-5afde60867ca">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

	theXML : String;

begin

	inheritMethod(_userWindow);
	
	theXML:= _userWindow.xmlInfo;
	self.xmlStrTblRate := theXML.cnEcGetTagValueOfName(self.tblRates.XMLTag_Table &amp; self.tblRates.name);


epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
