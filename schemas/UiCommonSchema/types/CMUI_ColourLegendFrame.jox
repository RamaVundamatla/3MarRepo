    <JadeMethod name="displayStackHeights" id="3f457241-86a9-4a9e-8e3d-c90e6d436b93">
        <source>displayStackHeights();
// ---------------------------------------------------------------------------
// Created:		02 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theLabels : StringArray;
	theColours : IntegerArray;
	aColour,
	idx,
	numLabels,
	numColours	: Integer;
	theRoot		: CM_Root;
begin
	create theLabels transient;
	create theColours transient;
	theRoot := app.myRoot;
	
//	theLabels.add("Unavailable");		theColours.add(theRoot.coloursForTALevels[1]);
//	theLabels.add("SubBlock");		theColours.add(theRoot.coloursForTALevels[2]);
	theLabels.add("Light");			theColours.add(theRoot.coloursForTALevels[3]);
	theLabels.add("Building");		theColours.add(theRoot.coloursForTALevels[4]);
//	theLabels.add("Empty");			theColours.add(theRoot.coloursForTALevels[5]);
//	theLabels.add("˝");				theColours.add(theRoot.coloursForTALevels[6]);
	theLabels.add("1");				theColours.add(theRoot.coloursForTALevels[7]);
//	theLabels.add("1 ˝");			theColours.add(theRoot.coloursForTALevels[8]);
	theLabels.add("2");				theColours.add(theRoot.coloursForTALevels[9]);
//	theLabels.add("2 ˝");			theColours.add(theRoot.coloursForTALevels[10]);
	theLabels.add("3");				theColours.add(theRoot.coloursForTALevels[11]);
//	theLabels.add("3 ˝");			theColours.add(theRoot.coloursForTALevels[12]);
	theLabels.add("4");				theColours.add(theRoot.coloursForTALevels[13]);
//	theLabels.add("4 ˝");			theColours.add(theRoot.coloursForTALevels[14]);
	theLabels.add("5");				theColours.add(theRoot.coloursForTALevels[15]);
//	theLabels.add("5 ˝");			theColours.add(theRoot.coloursForTALevels[16]);
	theLabels.add("6");				theColours.add(theRoot.coloursForTALevels[17]);
//	theLabels.add("6 ˝");			theColours.add(theRoot.coloursForTALevels[18]);
	theLabels.add("7");				theColours.add(theRoot.coloursForTALevels[19]);
//	theLabels.add("7 ˝");			theColours.add(theRoot.coloursForTALevels[20]);
	theLabels.add("8");				theColours.add(theRoot.coloursForTALevels[21]);

	self.myLegendTable.rows := 0;
	self.myLegendTable.sortColumn[1] := 0;
	self.myLegendTable.sortAsc[1] := false;
	
	self.addRow("Heights",Red, null,true);
	numLabels := theLabels.size;
	numColours := theColours.size;
	foreach idx in 1 to numLabels do
		if idx &lt;= numColours then
			aColour := theColours[idx];
		else
			aColour := Black; // Just incase this is the first Time ever run and colours are not set on root
		endif;
		self.addRow(theLabels[idx], aColour, null,true);
	endforeach;

epilog
	delete theLabels;
	delete theColours;


end;</source>
    </JadeMethod>
    <JadeMethod name="displayStatus" id="6844b159-9f68-4f6e-be30-772addb7d970">
        <source>displayStatus() protected;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lStatus : CM_ContentsStatus;
	iter01 : Iterator;
begin
	self.myLegendTable.rows := 0;
	self.addRow("Status",Red,null,true);
	self.myLegendTable.fixedRows := 1;
	
	iter01 := app.myRoot.allContentsStatuses.createIterator;
	
	while iter01.next(lStatus) do
		self.addRow(lStatus.abbreviation.trimBlanks,lStatus.colour,lStatus,false);
	endwhile;
epilog
	delete iter01;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayStockBookRef" id="69ce5089-c8e3-4cbe-a045-995f1d8f4357">
        <updating/>
        <source>displayStockBookRef(controller : CMIF_DrawingAttrController) protected, updating;
// Add a list of Stock Booking References to the legend table
vars
	bookRef : CM_BookingRef;
	viewObjectColour : CM_ViewObjectColour;
	iter : Iterator;
begin
	self.viewMode := VIEW_BOOKREF_STOCK;
	self.myLegendTable.rows := 0;
	self.addRow("Stock Booking", Red, null,true);
	self.myLegendTable.fixedRows := 1;
	
	iter := controller.allStockBookRefs.createIterator;
	while iter.next(viewObjectColour) do
		bookRef := viewObjectColour.myObject.CM_BookingRef;
		if bookRef.isStockBookingRef then
			self.addRow(bookRef.bookingReference.trimBlanks, viewObjectColour.colour, bookRef,false);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="controller" type="CMIF_DrawingAttrController"/>
    </JadeMethod>
    <JadeMethod name="displayTemperature" id="93832055-9e4f-443b-865a-98ba355926c6">
        <source>displayTemperature() protected;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/10/2012	cnwdap1		PAR #30480 use global constant for heading
// 09/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// ---------------------------------------------------------------------------
vars
	lTemperature : CM_TempRange;
	iter01 : Iterator;
	showFahr : Boolean;												// PAR #31155
	terminal : CM_Terminal;											// PAR #31155
	
begin
	terminal := self.form.CM_BaseForm.myTerminal;					// PAR #31155
	showFahr := terminal.getConfig(TempFahForFahOperator).Boolean;	// PAR #31155
	self.myLegendTable.rows := 0;
	//self.addRow("Temp",Red,null,true);							// PAR #30480
	self.addRow(app.getErrorString(Temperature), Red, null, true);	// PAR #30480
	self.myLegendTable.fixedRows := 1;
	
	iter01 := app.myRoot.allTempRanges.createIterator;
	
	while iter01.next(lTemperature) do
		if showFahr then																												// PAR #31155
			self.addRow(app.temperatureConversion(true, lTemperature.value).String &amp; Degrees_F,lTemperature.colour,lTemperature,false);	// PAR #31155
		else																															// PAR #31155
			self.addRow(lTemperature.value.String &amp; Degrees_C,lTemperature.colour,lTemperature,false);
		endif;																															// PAR #31155
	endwhile;
epilog
	delete iter01;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayTrain" id="4f165d91-4254-47d1-af3b-60af91c89460">
        <source>displayTrain();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jun 2009	consw1	PAR 19913 - SFW1067 Rail Simplifications
01 Jun 2010	cnwkpd1	PAR #21914 - Found 1310 exception during testing when two trains with the
					same code and colour were on the terminal.  Reworked code to prevent exception.
					
*/

vars
	terminal : CM_Terminal;
	train : CM_Train;
//	trainColl : CM_TrainByCodeColourDict;
	
begin
	self.myLegendTable.rows := 0;
	self.addRow(app.getErrorString(Trains), Red, null,true);
	self.myLegendTable.fixedRows :=	1;

	terminal := self.form.CM_BaseForm.myTerminal;
	if terminal = null then
		return;
	endif;
	
//	create trainColl transient;
//	terminal.allTrainsOnTerminal.copy(trainColl);
	
	foreach train in terminal.allTrainsOnTerminal discreteLock do
		self.addRow(train.code.trimBlanks, train.colour, train, false);
	endforeach;

epilog
//	delete trainColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayViewModeCodes" id="1fcecd7a-6e42-4338-ad00-71ecc7511580">
        <updating/>
        <source>displayViewModeCodes(_theViewMode : Integer; _theDrawingAttrController : CMIF_DrawingAttrController input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		March  2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 01 Jun 2010	cnwkpd1		PAR #21914 - Improve legend load performance when loading entire table
//	06-06-2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
vars
	tmpCommodityGroup	: CM_CommodityGroup;
	tmpConsignee		: CM_ConsigneeConsignor;
	lCommodity : CM_Commodity;
	anOperator : CM_Operator;
	productObj			: CM_Product;
	aPort : CM_Port;
	aVoyage : CM_Voyage;
	aTrain : CM_Train;
	invalidObject : Boolean;
	idx, theViewMode : Integer;
	theCode, theTitle : String;
	term			: CM_Terminal;
	tmpRange : CM_TempRange;
	tmpISOGroup : CM_ISOTypeGroup;
	tmpWeight : CM_WeightRange;
	newMode : Boolean;
	theColour : Integer;
	tmpWeightRange		: CM_WeightRange; // (11836) 27/09/2006 cnwmo1
	tmpDwellDayRange : CM_DwellDayRange;	//20 Jul 2011	NDL	Par 27890
	tmpMTGrade : CM_MTGrade;	//29 Jul 2011	NDL	Par 27890
	carrier: CM_Carrier;		// 9/6/17 MAP TFS4209
	tmpShppingLine	: CM_ShippingLine;//navtnr20	53204
begin
	newMode := false;
	if self.myLegendTable.rows &gt; 0 then
		self.myLegendTable.removeItem(1);
	else
		newMode := true;
	endif;

	if self.viewMode &lt;&gt; _theViewMode then
		self.myLegendTable.rows := 0;
		newMode := true;
	endif;
	
	term := self.form.CM_BaseForm.myTerminal;
	if term = null then
		return false;
	endif;
	
	theViewMode := _theViewMode;
	self.viewMode := theViewMode;

	if theViewMode = VIEW_COMMODITY then
		theTitle := "Commd";
		foreach tmpCommodityGroup in _theDrawingAttrController.allCommodityGroups do
			self.addRow(tmpCommodityGroup.code, tmpCommodityGroup.colour, tmpCommodityGroup, not newMode);
		endforeach;

	elseif theViewMode = VIEW_TEMPERATURE then
		theTitle := "Temp.";
		foreach tmpRange in _theDrawingAttrController.allTempRanges do
			self.addRow(tmpRange.value.String, tmpRange.colour, tmpRange, not newMode);
		endforeach;
	elseif theViewMode = VIEW_WEIGHT then
		theTitle := "Weight";
		foreach tmpWeightRange in _theDrawingAttrController.allWeightRanges do
			self.addRow(tmpWeightRange.value.String, tmpWeightRange.colour, tmpWeightRange, not newMode);
		endforeach;
		
	//20 Jul 2011	NDL	Par 27890
	elseif theViewMode = VIEW_DWELL_DAYS then
		theTitle := "Dwell Days";
		foreach tmpDwellDayRange in _theDrawingAttrController.allDwellRanges do
			self.addRow(tmpDwellDayRange.getDisplayValue, tmpDwellDayRange.colour, tmpDwellDayRange, not newMode);
		endforeach;
		
	//29 Jul 2011	NDL	Par 27890
	elseif theViewMode = VIEW_MTGRADE then
		theTitle := "Availability Grade";
		foreach tmpMTGrade in _theDrawingAttrController.allAvailGrades do
			self.addRow(tmpMTGrade.description, tmpMTGrade.colour, tmpMTGrade, not newMode);
		endforeach;

	elseif theViewMode = VIEW_CONSIGNEE then
		theTitle := "Consign";
		foreach tmpConsignee in _theDrawingAttrController.allConsignees do
			self.addRow(tmpConsignee.code, tmpConsignee.colour, tmpConsignee, not newMode);
		endforeach;
	
	elseif theViewMode = VIEW_OPERATOR then
		theTitle := "Operator";
		foreach anOperator in _theDrawingAttrController.allOperators do
			self.addRow(anOperator.code.trimBlanks,anOperator.colour,anOperator, not newMode);
		endforeach;
		
	elseif theViewMode = VIEW_PRODUCT then
		theTitle := app.getErrorString(Product);
		
		foreach productObj in _theDrawingAttrController.allProducts do
			self.addRow(productObj.code.trimBlanks(), productObj.colour, productObj, not newMode);
		endforeach;
		
	elseif theViewMode = VIEW_ISOGROUP then
		theTitle := "ISO Grp";
		foreach tmpISOGroup in _theDrawingAttrController.allISOTypeGroups do
			self.addRow(tmpISOGroup.code.trimBlanks,tmpISOGroup.colour,tmpISOGroup, not newMode);
		endforeach;
	elseif theViewMode = VIEW_VOYAGE then
		theTitle := "Voyages";
		foreach aVoyage in _theDrawingAttrController.allVoyages do
			self.addRow(aVoyage.code.trimBlanks,aVoyage.colour,aVoyage, not newMode);
		endforeach;

	elseif theViewMode = VIEW_TRAIN then
		on Exception do app.handleDeletedObject(exception, aTrain, invalidObject);
		theTitle := "Trains";
		foreach aTrain in _theDrawingAttrController.allTrains do
			invalidObject := false;
			theColour := aTrain.colour;
			if not invalidObject then
				self.addRow(aTrain.code.trimBlanks,theColour,aTrain, not newMode);
			endif;
		endforeach;

	elseif theViewMode = VIEW_LOADPORT then
		theTitle := "Load Port";
		foreach aPort in _theDrawingAttrController.allLoadPorts do
			if aPort.myCountry = null then
				self.addRow(aPort.code.trimBlanks,aPort.colour,aPort, not newMode);
			else
				self.addRow(aPort.portCode &amp; " " &amp; aPort.myCountry.code.trimBlanks,aPort.colour,aPort, not newMode);
			endif;
		endforeach;

	elseif theViewMode = VIEW_DISPORT then
		theTitle := "Disch Port";
		foreach aPort in _theDrawingAttrController.allDischargePorts do
			if aPort.myCountry = null then
				self.addRow(aPort.code.trimBlanks,aPort.colour,aPort, not newMode);
			else
				self.addRow(aPort.portCode &amp; " " &amp; aPort.myCountry.code.trimBlanks,aPort.colour,aPort, not newMode);
			endif;
		endforeach;
		
	elseif theViewMode = VIEW_DESTPORT then
		//par 13964
		theTitle := " Destination";
		foreach aPort in _theDrawingAttrController.allDestinationPorts do
			if aPort.myCountry = null then
				self.addRow(aPort.code.trimBlanks,aPort.colour,aPort, not newMode);
			else
				self.addRow(aPort.portCode &amp; " " &amp; aPort.myCountry.code.trimBlanks,aPort.colour,aPort, not newMode);
			endif;
		endforeach;

	elseif theViewMode = VIEW_CARRIERIN then		// 9/6/17 MAP TFS4209
		theTitle := (app.getErrorString(Receive) &amp; " " &amp; app.getErrorString(Carrier)).trimBlanks();
		foreach carrier in _theDrawingAttrController.allCarriersIn do
			self.addRow(carrier.code.trimBlanks, carrier.colour, carrier, not newMode);
		endforeach;
	elseif theViewMode = VIEW_CARRIEROUT then		// 9/6/17 MAP TFS4209
		theTitle := app.getErrorString(Release_carrier);
		foreach carrier in _theDrawingAttrController.allCarriersOut do
			self.addRow(carrier.code.trimBlanks, carrier.colour, carrier, not newMode);
		endforeach;
		//Start  06-06-2022	navtnr20 53204
	elseif theViewMode = VIEW_SHIPPINGLINE then
		theTitle := app.getErrorString(ShippingLine);
		foreach tmpShppingLine in _theDrawingAttrController.allShippingLines do
			self.addRow(tmpShppingLine.code.trimBlanks,tmpShppingLine.colour,tmpShppingLine, not newMode);
		endforeach;
		//end 06-06-2022	navtnr20 53204

	else
		return false;
	endif;
	
	if self.myLegendTable.rows = 1 and not newMode then
		return false;
	elseif self.myLegendTable.rows = 0 then
		return false;
	else
		self.myLegendTable.sortColumn[1] := 1;
		self.myLegendTable.sortAsc[1] := true;
		self.addRowAt(theTitle,Red,null,1);
		self.myLegendTable.fixedRows := 1;
		
		self.doResize;
		return true;
	endif;
end;</source>
        <Parameter name="_theViewMode" type="Integer"/>
        <Parameter name="_theDrawingAttrController" type="CMIF_DrawingAttrController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayVoyage" id="ade36c46-0b53-4285-8b21-6897ea4ee1b7">
        <source>displayVoyage() protected;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01 Jun 2010	cnwkpd1		PAR #21914 - Improve legend load performance when loading entire table
// 29 Oct 2012	cnwdap1		PAR #30480 - use global constant for heading
// ---------------------------------------------------------------------------
vars
	voy				: CM_Voyage;
	voySet			: CM_VoyageSet;
	ls				: Boolean;
	term			: CM_Terminal;
begin
	self.myLegendTable.rows := 0;
	//self.addRow("Voyage",Red,null,true);						// PAR #30480
	self.addRow(app.getErrorString(Voyage), Red, null, true);	// PAR #30480
	self.myLegendTable.fixedRows := 1;

	app.cmsBeginLoad(ls);
	term := self.form.CM_BaseForm.myTerminal;
	if term = null then
		return;
	endif;
	
	create voySet transient;
	term.getAllCurrentCellularVoyages(voySet, true, true);
	
	foreach voy in voySet do
		self.addRow(voy.code.trimBlanks, voy.colour, voy,false);
	endforeach;

epilog
	delete voySet;
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayWeight" id="0efef113-3a67-47bd-a0b9-5aabc9104772">
        <source>displayWeight() protected;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// ---------------------------------------------------------------------------
vars
	lWeight 	: CM_WeightRange;
	iter01 		: Iterator;
	ls			: Boolean;
	theWeights 	: CM_WeightRangeByValueDict;
	measure		: CM_MeasurementType;							// PAR #31155
	
begin
	measure := app.getDefaultMeasurementForType(Type_Weight);												// PAR #31155
	self.myLegendTable.rows := 0;
	//self.addRow("Weight",Red,null,true);																	// PAR #31155
	self.addRow("Weight " &amp; Left_Round_Bracket &amp; measure.shortName &amp; Right_Round_Bracket,Red,null,true);	// PAR #31155
	self.myLegendTable.fixedRows := 1;
	self.myLegendTable.fixedRows := 1;
	
	app.cmsBeginLoad(ls);
	create theWeights transient;
	//app.myRoot.allWeightRanges.copy(theWeights);															// PAR #31155
	measure.allWeightRanges.copy(theWeights);																// PAR #31155
	theWeights.removeInvalidObjects();
//	beginTransaction;
//	app.myRoot.allWeightRanges.rebuild;
//	commitTransaction;

//	iter01 := app.myRoot.allWeightRanges.createIterator;
	iter01 := theWeights.createIterator;
	
	while iter01.next(lWeight) do
//		if global.isValidObject(lWeight) then
			//self.addRow(iter01.getCurrentKey(1).String.trimBlanks, lWeight.colour, lWeight,false);		// PAR #31155
			self.addRow(iter01.getCurrentKey(2).String.trimBlanks, lWeight.colour, lWeight,false);			// PAR #31155
//		endif;
	endwhile;

epilog
	delete theWeights;
	delete iter01;
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChangeViewMode" id="5e55afbf-e155-4123-a143-244f7ff4a452">
        <updating/>
        <source>doChangeViewMode(pMode : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
20 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
16 Jun 2009	consw1	PAR #19913 - SFW1067 Rail Simplifications
29 Oct 2012	cnwdap1	PAR #30480 - VIEW_COMMODITY mode is actually commodity groups, not commodities
12/05/2017	cnwdap1	TFS 4416 SNO Dwell Days Legend
19/05/2022 navtnr20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
*/

begin
	self.viewMode := pMode;
	
	if self.viewMode = VIEW_COMMODITY then
		//self.displayCommodity();				// PAR #30480
		self.displayCommodityGroup();			// PAR #30480
	elseif self.viewMode = VIEW_LOG_GRADE then
		self.displayLogGrade();
	elseif self.viewMode = VIEW_CONSIGNEE then
		self.displayConsignee();
	elseif self.viewMode = VIEW_DISPORT then
		self.displayDischargePort();
	elseif self.viewMode = VIEW_LOADPORT then
		self.displayLoadPort();
	elseif self.viewMode = VIEW_ISOGROUP then
		self.displayISOGroup();
	elseif self.viewMode = VIEW_JOB then
		self.displayJob();
	elseif self.viewMode = VIEW_OPERATOR then
		self.displayOperator();
	elseif self.viewMode = VIEW_PRODUCT then
		self.displayProduct();
	elseif self.viewMode = VIEW_STATUS then
		self.displayStatus();
	elseif self.viewMode = VIEW_TEMPERATURE then
		self.displayTemperature();
	elseif self.viewMode = VIEW_VOYAGE then
		self.displayVoyage();
	elseif self.viewMode = VIEW_TRAIN then
		self.displayTrain();
	elseif self.viewMode = VIEW_WEIGHT then
		self.displayWeight();
	elseif self.viewMode = VIEW_DESTPORT then
		self.displayDestinationPort();
	elseif self.viewMode = VIEW_CARGO_TYPE then		// PAR #16753
		self.displayCargoType();
	elseif self.viewMode = VIEW_DWELL_DAYS then				// TFS 4416
		self.displayDwellDay();								// TFS 4416
	elseif self.viewMode = VIEW_MTGRADE then				// TFS 4416
		self.displayMTGrade();								// TFS 4416
	elseif self.viewMode = VIEW_CARRIERIN then		// 9/6/17 MAP TFS4209
		self.displayCarrier();
	elseif self.viewMode = VIEW_CARRIEROUT then		// 9/6/17 MAP TFS4209
		self.displayCarrier();
	elseif self.viewMode = VIEW_SHIPPINGLINE then	//19-may-2022 navtnr20 53204
		self.displayShippingLine();
	else
		self.myLegendTable.rows := 0;
		return false;
	endif;	
	
	return true;
end;</source>
        <Parameter name="pMode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeViewModeEx" id="16a60eed-168e-4b90-9f51-330c21f23c14">
        <updating/>
        <source>doChangeViewModeEx(viewMode : Integer; controller : CMIF_DrawingAttrController) updating;
// Display the legend for view mdoes that need the drawing controller. (The drawing controller
// has the collection of items to add to the legend)
vars
begin
	if viewMode = VIEW_PRODUCT then
		self.doChangeViewMode(viewMode);
	elseif viewMode = VIEW_BOOKREF_EXPORT then
		self.displayExportBookRef(controller);
	elseif viewMode = VIEW_BOOKREF_STOCK then
		self.displayStockBookRef(controller);
	elseif viewMode = VIEW_RELEASE_REQUEST then
		self.displayRelease(controller);
	elseif viewMode = VIEW_CARGO_TYPE then
		self.displayCargoTypeEx(controller);
	else
		self.displayCodesForMode(viewMode, controller);
	endif;			
end;</source>
        <Parameter name="viewMode" type="Integer"/>
        <Parameter name="controller" type="CMIF_DrawingAttrController"/>
    </JadeMethod>
    <JadeMethod name="doIHaveScrollBar" id="95d3bd37-0cb8-400d-9d97-f76a82a18478">
        <source>doIHaveScrollBar() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aOK : Boolean;
	idx : Integer;
	
begin
	if self.myLegendTable.rows &gt;= 2 then
		idx := self.myLegendTable.rows * self.myLegendTable.accessRow(2).height;
	endif;
	
	if idx &gt; self.myLegendTable.height then
		return true;
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegend" id="74dd1887-03be-4a79-b27a-39ed4ade9f6c">
        <source>doNotesForLegend(_startNote : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	idx, numRows : Integer;
	theTable : Table;
	theForm : CM_BaseForm;
	
begin
	theTable := self.myLegendTable;
	numRows := theTable.rows;
	theForm := self.form.CM_BaseForm;
	
	foreach idx in 2 to numRows do
		anObject := theTable.accessRow(idx).itemObject;
		if anObject &lt;&gt; null then
			if _startNote then
				theForm.beginNotification(anObject, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			else
				theForm.endNotification(anObject, EVENT_CODE_COLOUR_CHANGE);
			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_startNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="f06de1cd-1d4b-4616-a60a-58bf2aa7cfd8">
        <source>doResize();
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.myLegendTable.top := 0;
	self.myLegendTable.left := 0;
	self.myLegendTable.width := self.width;
	self.myLegendTable.height := self.height;
	self.myLegendTable.accessColumn(1).width := self.width.Integer;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTableClick" id="4ff52c2b-c747-46fb-b264-a4397cc6ba01">
        <updating/>
        <source>doTableClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
begin
	if self.form.name = "GC_BlockAreaForm" then
		self.form.sendMsgWithParams("doTableClick", table);
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="6ce097b8-ad04-48e2-ba2f-a7867d23defc">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	frame : CMUI_ColourLegendFrame;
	anObject : CM_Object;
	assistant : CMUI_Assistant;
begin
	

	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	anObject := table.accessRow(table.row).itemObject.CM_Object ;
	if anObject &lt;&gt; null then
		
	//if frame.viewMode = 
	endif;
	
	self.form.sendMsgWithParams("doTableDblClick", table);
//	self.form.sendMsgWithParams(method.name, table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getViewModeFromObject" id="f42836cb-49d1-42b0-b284-9de1045f430f">
        <source>getViewModeFromObject(_anObject : Object) : Integer protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//06-06-2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
begin
	if _anObject.isKindOf(CM_CommodityGroup) then
		return TI_ColourMode_CommodityGroup;
	elseif _anObject.isKindOf(CM_Voyage) then
		return TI_ColourMode_Voyage;
	elseif _anObject.isKindOf(CM_Operator) then
		return TI_ColourMode_Operator;
	elseif _anObject.isKindOf(CM_Product) then
		return TI_ColourMode_Product;
	elseif _anObject.isKindOf(CM_Port) then
		return TI_ColourMode_DischargePort;
	elseif _anObject.isKindOf(CM_ConsigneeConsignor) then
		return TI_ColourMode_Consignee;
	elseif _anObject.isKindOf(CM_ISOTypeGroup) then
		return TI_ColourMode_ISOTypeGroup;
	elseif _anObject.isKindOf(CM_ContentsStatus) then
		return TI_ColourMode_Status;
	elseif _anObject.isKindOf(CM_TempRange) then
		return TI_ColourMode_Temperature;
	elseif _anObject.isKindOf(CM_WeightRange) then
		return TI_ColourMode_Weight;
	elseif _anObject.isKindOf(CM_DwellDayRange) then	//20 Jul 2011	NDL	Par 27890
		return TI_ColourMode_DwellDays;
	elseif _anObject.isKindOf(CM_MTGrade) then	//29 Jul 2011	NDL	Par 27890
		return TI_ColourMode_MTGrade;
	elseif _anObject.isKindOf(CM_ShippingLine) then		//07-06-2022 navtnr20 53204
		return TI_ColourMode_ShippingLine;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_anObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="redisplayViewModeCodes" id="b0916da9-eb1a-4dc8-a96c-ab9d11e0c756">
        <updating/>
        <source>redisplayViewModeCodes()  updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 10/03/2011	cnwmh5		PAR 27142 - Change the where the voyage handler is armed
//09 May 2016	cnwma1		  TFS #1961 PAR #37474 Changing colour of ISO type only updates selected instance
//06-06-2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
vars
	tmpCommodityGroup	: CM_CommodityGroup;
	tmpConsignee		: CM_ConsigneeConsignor;
//	lCommodity : CM_Commodity;
	anOperator : CM_Operator;
	aPort : CM_Port;
	aVoyage : CM_Voyage;
	aTrain : CM_Train;
	invalidObject : Boolean;
	theColour : Integer;
	theViewMode : Integer;
//	theCode, theTitle : String;
//	term			: CM_Terminal;
//	newMode : Boolean;
	idx : Integer;
	anISOType : CM_ISOType;
	anISOTypeGroup : CM_ISOTypeGroup;
	aCStatus : CM_ContentsStatus;
	aTemp : CM_TempRange;
	aWait : CM_WeightRange;
	inValidVoy : Boolean;
	aDwell : CM_DwellDayRange;
	aMTGrade : CM_MTGrade;
	carrier: CM_Carrier;
	shippingLine	: CM_ShippingLine;	//53204
begin

	theViewMode := self.viewMode;
		
	if theViewMode = VIEW_COMMODITY then
		foreach idx in 2 to self.myLegendTable.rows do
			tmpCommodityGroup :=  self.myLegendTable.accessRow(idx).itemObject.CM_CommodityGroup;
			self.myLegendTable.accessedRow.backColor := tmpCommodityGroup.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;

	elseif theViewMode = VIEW_HEIGHT then
		self.displayStackHeights();
	elseif theViewMode = VIEW_CONSIGNEE then
		foreach idx in 2 to self.myLegendTable.rows do
			tmpConsignee :=  self.myLegendTable.accessRow(idx).itemObject.CM_ConsigneeConsignor;
			self.myLegendTable.accessedRow.backColor := tmpConsignee.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;
	
	elseif theViewMode = VIEW_OPERATOR then
		foreach idx in 2 to self.myLegendTable.rows do
			anOperator :=  self.myLegendTable.accessRow(idx).itemObject.CM_Operator;
			self.myLegendTable.accessedRow.backColor := anOperator.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;
		
	elseif theViewMode = VIEW_VOYAGE then
		on Exception do app.handleDeletedObject(exception, aVoyage, inValidVoy);
		foreach idx in 2 to self.myLegendTable.rows do
			inValidVoy := false; //20 Oct. 2008 cnwdz2	Par15319
			aVoyage :=  self.myLegendTable.accessRow(idx).itemObject.CM_Voyage;
			self.myLegendTable.accessedRow.backColor := aVoyage.colour;
			
			//20 Oct. 2008 cnwdz2	Par15319
			if inValidVoy then
				continue;
			endif;
			
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;

	elseif theViewMode = VIEW_TRAIN then
		on Exception do app.handleDeletedObject(exception, aTrain, invalidObject);
		foreach idx in 2 to self.myLegendTable.rows do
			aTrain :=  self.myLegendTable.accessRow(idx).itemObject.CM_Train;
			invalidObject := false;
			theColour := aTrain.colour;
			if not invalidObject then
				self.myLegendTable.accessedRow.backColor := theColour;
				self.myLegendTable.accessedRow.foreColor := theColour.getInverseColour;
			endif;
		endforeach;

	elseif theViewMode = VIEW_LOADPORT then
		foreach idx in 2 to self.myLegendTable.rows do
			aPort :=  self.myLegendTable.accessRow(idx).itemObject.CM_Port;
			self.myLegendTable.accessedRow.backColor := aPort.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;

	elseif theViewMode = VIEW_DISPORT then
		foreach idx in 2 to self.myLegendTable.rows do
			aPort :=  self.myLegendTable.accessRow(idx).itemObject.CM_Port;
			self.myLegendTable.accessedRow.backColor := aPort.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;
	elseif theViewMode = TI_ColourMode_ISOTypeGroup then
		foreach idx in 2 to self.myLegendTable.rows do
			/*
			anISOTypeGroup :=  self.myLegendTable.accessRow(idx).itemObject.CM_ISOTypeGroup;  //09/05/2016 cnwma1 PAR #37474 TFS #1961
			self.myLegendTable.accessedRow.backColor := anISOTypeGroup.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
			*/
		
			if self.myLegendTable.accessRow(idx).itemObject.isKindOf(CM_ISOType) then   //09/05/2016 cnwma1 PAR #37474 TFS #1961
				anISOType :=  self.myLegendTable.accessRow(idx).itemObject.CM_ISOType;
				self.myLegendTable.accessedRow.backColor := anISOType.colour;
			elseif self.myLegendTable.accessRow(idx).itemObject.isKindOf(CM_ISOTypeGroup) then
				anISOTypeGroup :=  self.myLegendTable.accessRow(idx).itemObject.CM_ISOTypeGroup;
				self.myLegendTable.accessedRow.backColor := anISOTypeGroup.colour;
			endif;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;
		
	elseif theViewMode = TI_ColourMode_Status then
		foreach idx in 2 to self.myLegendTable.rows do
			aCStatus :=  self.myLegendTable.accessRow(idx).itemObject.CM_ContentsStatus;
			self.myLegendTable.accessedRow.backColor := aCStatus.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;

	elseif theViewMode = TI_ColourMode_Temperature then
		foreach idx in 2 to self.myLegendTable.rows do
			aTemp :=  self.myLegendTable.accessRow(idx).itemObject.CM_TempRange;
			self.myLegendTable.accessedRow.backColor := aTemp.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;
	elseif theViewMode = TI_ColourMode_Weight then
		foreach idx in 2 to self.myLegendTable.rows do
			aWait :=  self.myLegendTable.accessRow(idx).itemObject.CM_WeightRange;
			self.myLegendTable.accessedRow.backColor := aWait.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;
	elseif theViewMode = TI_ColourMode_DwellDays then	//20 Jul 2011	NDL	Par 27890
		foreach idx in 2 to self.myLegendTable.rows do
			aDwell :=  self.myLegendTable.accessRow(idx).itemObject.CM_DwellDayRange;
			self.myLegendTable.accessedRow.backColor := aDwell.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;
	elseif theViewMode = TI_ColourMode_MTGrade then	//29 Jul 2011	NDL	Par 27890
		foreach idx in 2 to self.myLegendTable.rows do
			aMTGrade :=  self.myLegendTable.accessRow(idx).itemObject.CM_MTGrade;
			self.myLegendTable.accessedRow.backColor := aMTGrade.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;
	elseif theViewMode = VIEW_CARRIERIN then		// 9/6/17 MAP TFS4209
		foreach idx in 2 to self.myLegendTable.rows do
			carrier :=  self.myLegendTable.accessRow(idx).itemObject.CM_Carrier;
			self.myLegendTable.accessedRow.backColor := carrier.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;
	elseif theViewMode = VIEW_CARRIEROUT then		// 9/6/17 MAP TFS4209
		foreach idx in 2 to self.myLegendTable.rows do
			carrier :=  self.myLegendTable.accessRow(idx).itemObject.CM_Carrier;
			self.myLegendTable.accessedRow.backColor := carrier.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;
		
		//Start	06-06-2022 navtnr20 53204
		elseif theViewMode = VIEW_SHIPPINGLINE then	
		foreach idx in 2 to self.myLegendTable.rows do
			shippingLine :=  self.myLegendTable.accessRow(idx).itemObject.CM_ShippingLine;
			self.myLegendTable.accessedRow.backColor := shippingLine.colour;
			self.myLegendTable.accessedRow.foreColor := self.myLegendTable.accessedRow.backColor.getInverseColour;
		endforeach;
		//END 06-06-2022 navtnr20 53204
	endif;

	self.doResize;
end;</source>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="6d24e672-9b77-4900-a593-66b1d6577dd7">
        <updating/>
        <source>repositionAfterResize() updating;
begin
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="saveAllUsedProducts" id="34b89851-3e7d-490e-bb7c-0192f9bb21bb">
        <source>saveAllUsedProducts(pAllProductsObj:CM_ProductByCodeCargoTypeDict);
// --------------------------------------------------------------------------------
// Created:		01 December 2005 by cnwdad1
//
// Purpose:		Updates a collection of Products that are currently "in use" within
//				a Grid Area.  This collection will be refreshed whenever a new area
//				is selected.
//
// Parameters:	pAllProductsObj - A reference to a collection of Products.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 10 Jun 2015	NDL	Par 36392
// --------------------------------------------------------------------------------
begin
	self.allUsedProducts.clear();
	pAllProductsObj.copy(self.allUsedProducts);
end;</source>
        <Parameter name="pAllProductsObj" type="CM_ProductByCodeCargoTypeDict"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="24450151-8d66-41e1-885c-1601d8635df4">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);

	self.alignChildren := self.AlignChildren_All;

	self.width := 50;
	self.height := 200;
	self.visible := true;
	self.borderStyle := BorderStyle_None;
	self.boundaryWidth := 0;
	self.bevelInnerWidth := 0;
	self.bevelOuterWidth := 0;
	self.backColor := White;
	self.caption := null;
	self.enabled := true;
	self.createLegendTable();
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
