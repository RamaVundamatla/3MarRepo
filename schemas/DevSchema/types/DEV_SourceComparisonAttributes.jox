    </JadeMethod>
    <JadeMethod name="loadAttribute" id="7e8c9514-1e3b-4070-802f-4534cb440c35">
        <updating/>
        <source>loadAttribute(_devAttribute : DEV_Attribute) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	schema 				: Schema;
	currentClass 		: Class;
	currentAttribute 	: Property;
	outputFile 			: File;
	
begin
	schema := rootSchema.getSchema(_devAttribute.myClass.mySchema.name);
	currentClass := schema.getClass(_devAttribute.myClass.name);
	currentAttribute := currentClass.getProperty(_devAttribute.name);
	
	self.caption := "Source Comparison Attribute" &amp; " - " &amp; _devAttribute.name;
	
	if currentAttribute = null then
		self.slStatus.caption := "Attribute Missing";
	elseif _devAttribute.type &lt;&gt; currentAttribute.type.name then
		self.slStatus.caption := "Difference: Type";
	elseif _devAttribute.documentationTextData &lt;&gt; currentAttribute.text then
		self.slStatus.caption := "Difference: Text";
	endif;
	
	self.tblLoaded.rows := 0;
	self.tblLoaded.clearAllSelected();
	self.tblLoaded.addItemAt("Loaded", 1);
	self.tblLoaded.accessRow(1).fontBold := true;
	self.tblLoaded.fixedRows := 1;
	
	self.tblLoaded.addItemObject(_devAttribute, "Name");
	self.tblLoaded.addItemObject(_devAttribute, "Modified TimeStamp");
	self.tblLoaded.addItemObject(_devAttribute, "Modified by");
	self.tblLoaded.addItemObject(_devAttribute, "Modified version");
	self.tblLoaded.addItemObject(_devAttribute, "Documentation Text");
	self.tblLoaded.addItemObject(_devAttribute, "Type");
	
	self.tblLoaded.setCellText(2, 2, _devAttribute.name);
	self.tblLoaded.setCellText(3, 2, _devAttribute.modifiedTimeStamp.String);
	self.tblLoaded.setCellText(4, 2, _devAttribute.modifiedBy);
	self.tblLoaded.setCellText(5, 2, _devAttribute.modifiedVersion);
	self.tblLoaded.setCellText(6, 2, self.cleanText(_devAttribute.documentationTextData));
	self.tblLoaded.setCellText(7, 2, _devAttribute.type);
	
	self.tblCurrent.rows := 0;
	self.tblCurrent.clearAllSelected();
	self.tblCurrent.addItemAt("Current", 1);
	self.tblCurrent.accessRow(1).fontBold := true;
	self.tblCurrent.fixedRows := 1;
	
	self.tblCurrent.addItemObject(currentAttribute, "Name");
	self.tblCurrent.addItemObject(currentAttribute, "Modified TimeStamp");
	self.tblCurrent.addItemObject(currentAttribute, "Modified by");
	self.tblCurrent.addItemObject(currentAttribute, "Modified version");
	self.tblCurrent.addItemObject(currentAttribute, "Documentation Text");
	self.tblCurrent.addItemObject(currentAttribute, "Type");
	
	if currentAttribute = null then
		return;
	endif;
	
	self.tblCurrent.setCellText(2, 2, currentAttribute.name);
	self.tblCurrent.setCellText(3, 2, currentAttribute.getModifiedTimestamp().String);
	self.tblCurrent.setCellText(4, 2, currentAttribute.getModifiedBy());
	self.tblCurrent.setCellText(5, 2, currentAttribute.version.asStringJMT());
	self.tblCurrent.setCellText(6, 2, self.cleanText(currentAttribute.text));
	self.tblCurrent.setCellText(7, 2, currentAttribute.type.name);

end;</source>
        <Parameter name="_devAttribute" type="DEV_Attribute"/>
    </JadeMethod>
