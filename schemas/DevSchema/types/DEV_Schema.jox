    <JadeMethod name="create" id="285ea9f9-d314-47f0-9dc2-34a5930caa3f">
        <updating/>
        <source>create(_name,
		_subSchema,
		_otherData,
		_documentationTextData : String) 
		::super(_name) updating;
/*

Purpose:			Constructor for CM_Schema class

Parameters:			_name:					String	The name of the schema
					_subSchema:				String	The subschema the schema belongs to
					_otherData:				String	The data we are not interested in but needs to be written out
					_documentationTextData:	String	The documentation text on the schema

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set Attributes
	self.name 					:= _name;
	self.subSchema				:= _subSchema;
	self.otherData 				:= _otherData;
	self.documentationTextData 	:= _documentationTextData;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_subSchema" type="String"/>
        <Parameter name="_otherData" type="String"/>
        <Parameter name="_documentationTextData" type="String"/>
    </JadeMethod>
    <JadeMethod name="extractDocumentationTextStr" id="c1e7c13b-a8af-4287-b5c8-4ba620c07cca">
        <source>extractDocumentationTextStr() : String protected;
/*

Purpose:			Extracts the documentation text data

Parameters:			

Return Value:		A string in the documentation text format

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	if (self.documentationTextData &lt;&gt; null) then
		return self.getDelimiter &amp; "documentationText" &amp; CrLf &amp; "`" &amp; self.documentationTextData &amp; "`";
	else
		return "";
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractModifiedTimeStamp" id="d0978bdf-d40a-4b39-b255-0cbf33538dd0">
        <source>extractModifiedTimeStamp() : String protected;
/*

Purpose:			Extracts the modified timestamp

Parameters:			A string in the modified timestamp format

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	return CrLf &amp; self.getDelimiter &amp; self.getDelimiter &amp; "setModifiedTimeStamp " &amp; self.getLastModifiedTimeStamp();

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractSchemaDefinition" id="83e1f04c-7692-42a1-b879-4d79e32d6a76">
        <source>extractSchemaDefinition() : String protected;
/*

Purpose:			Extracts the schema definition

Parameters:			A string in the schema definition format

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	return self.name &amp; " " &amp; "subschemaOf" &amp; " " &amp; self.subSchema &amp; " " &amp; self.otherData &amp; CrLf;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractSchemaHeader" id="32ddd230-c655-4444-8295-2c9395c117fb">
        <source>extractSchemaHeader() : String protected;
/*

Purpose:			Extracts the schema header

Parameters:			A string in the schema header format

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	return "schemaDefinition" &amp; CrLf;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractSectionsToFile" id="dccab3da-5e2b-4e50-9951-c460b00efbea">
        <source>extractSectionsToFile(_outputFile: File io);
/*

Purpose:			Extracts all the schema file sections

Parameters:			_outputFile: The file to write the sections to

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devSchemaSection : DEV_SchemaGenericSection;
	
begin
	//Look into making the below work
	//foreach devSchemaSection in allSections do
	//	devSchemaSection.extractSection(_outputFile);
	//endforeach;

	/*
	* importedPackageDefinitions
	*/
	devSchemaSection := allSections["importedPackageDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* constantDefinitions
	*/
	devSchemaSection := allSections["constantDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* localeDefinitions
	*/
	devSchemaSection := allSections["localeDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* translatableStringDefinitions
	*/
	devSchemaSection := allSections["translatableStringDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* localeFormatDefinitions
	*/
	devSchemaSection := allSections["localeFormatDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* libraryDefinitions
	*/
	devSchemaSection := allSections["libraryDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* interfaceDefs
	*/
	devSchemaSection := allSections["interfaceDefs"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* membershipDefinitions
	*/
	devSchemaSection := allSections["membershipDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* typeDefinitions
	*/
	devSchemaSection := allSections["typeDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.DEV_SchemaClassesSection.extractTypeDefinitionSection(_outputFile);
	endif;
	
	/*
	* externalKeyDefinitions
	*/
	
	devSchemaSection := allSections["externalKeyDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* memberKeyDefinitions
	*/
	
	devSchemaSection := allSections["memberKeyDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* inverseDefinitions
	*/
	devSchemaSection := allSections["inverseDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* databaseDefinitions
	*/
	devSchemaSection := allSections["databaseDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* schemaViewDefinitions
	*/
	devSchemaSection := allSections["schemaViewDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* exportedPackageDefinitions
	*/
	devSchemaSection := allSections["exportedPackageDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* externalFunctionSources
	*/
	devSchemaSection := allSections["externalFunctionSources"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.extractSection(_outputFile);
	endif;
	
	/*
	* typeSources
	*/
	devSchemaSection := allSections["typeDefinitions"];
	if (devSchemaSection &lt;&gt; null) then
		devSchemaSection.DEV_SchemaClassesSection.extractSection(_outputFile);
	endif;

end;</source>
        <Parameter name="_outputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="extractToFile" id="51d0782b-1d0e-4053-ae88-faaa1ddfe2e4">
        <source>extractToFile(_outputFile: File io);
/*

Purpose:			Extracts all the schema data to file

Parameters:			_outputFile: The file to write the schema data to

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	_outputFile.writeLine(self.extractSchemaHeader() &amp; self.extractSchemaDefinition() &amp; self.extractDocumentationTextStr() &amp; self.extractModifiedTimeStamp());

end;</source>
        <Parameter name="_outputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setReport" id="9a497980-362c-403e-ae4e-f9df99951b01">
        <updating/>
        <source>setReport(_report : DEV_SourceCompareReport) updating;
/*

Purpose:			Sets our report for the CM_Schema class

Parameters:			_report:	CM_SourceCompareReport	Our report the schema is associated with

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.myReport := _report;

end;</source>
        <Parameter name="_report" type="DEV_SourceCompareReport"/>
    </JadeMethod>
</Class>
