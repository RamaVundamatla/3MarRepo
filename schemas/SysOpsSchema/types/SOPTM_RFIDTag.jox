    <JadeMethod name="setControlsForAddEdit" id="32aa9380-efe4-4b25-989a-dae5f60145e7">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	theForm : SOP_TableMaintForm;
	machineName			: String;
begin
  
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	theForm.tblInput1.enableRowByName(ETRow_Code);
	theForm.tblInput1.enableRowByName(ETRow_Description);
	theForm.tblInput1.enableRowByName(ETRow_SerialNumber);
	theForm.tblInput1.enableRowByName(ETRow_IsAvailableForEntry);
	theForm.tblInput1.enableRowByName(ETRow_Remarks);
							
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
	else
		self.showThumbnail(theForm.myCurrentObject.CM_RFIDTag);
	endif;
    theForm.tblInput1.cnEcResizeContents;
	//listen for tag reads
	if not app.beginRFIDTagNoteWindowsPC(Event_RFIDSerialOnly, theForm, theForm.myTerminal) then
		// Raise error
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="7f16b454-6eac-4749-93e1-32e05aeaa98f">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	theForm 			: SOP_TableMaintForm;
	defMenu,tmpMenu,
	mnuChild,mnuMaster	: MenuItem;
	
	tagReader			: CM_RFIDTagReader;
	tagReaderDict		: CM_RFIDTagReaderByCodeDict;
	
begin
	inheritMethod(conwin);
	theForm := self.myForm;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		return;
	endif;

	mnuMaster := theForm.cloneMenu(theForm.mnuTblVCloneDataTbl, theForm.mnuSwipe, false); 
	
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Swipe me ";
	theForm.mnuSwipeSub.visible := true;
	theForm.mnuSwipeSub.caption := app.getErrorString(Stops_NOOO); //"No Stops";
	
	defMenu := theForm.cloneMenu(mnuMaster, theForm.mnuSwipeSub, true); 
	tmpMenu := defMenu;
	
	tagReaderDict := theForm.myTerminal.allRFIDTagReadersByCode;
	
	foreach tagReader in tagReaderDict do
		defMenu.visible := false;
		
		mnuChild := theForm.cloneMenu(mnuMaster, tmpMenu, true); 
		mnuChild.caption := 'on reader ' &amp; tagReader.code;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := tagReader.code;
		mnuChild.userObject := tagReader;
		
		tmpMenu := mnuChild;
	endforeach; 

	mnuMaster := theForm.cloneMenu(theForm.mnuTblVCloneDataTbl, theForm.mnuContext2, false); 

	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Set road job to null";
	mnuMaster.userObject := self;
	
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="90f3a4f9-9b07-4b57-885d-767270debb62">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			


Return Value:		


Date			Who		Reason
17 August 2006	cnwer1	Initial creation - PAR#xxxx
22 October 2008	consw1	Par 18241 - RFID Tag location field disappeared
*/
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_RFIDTag);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_RFIDTag);
	theForm.shtTblInput1.visible := true;

	theForm.tblInput1.hideRowByName(ETRow_LocationOnTerminal,false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="6a67973a-a04b-40a2-8391-2703fb761f07">
        <updating/>
        <source>showThumbnail(pRFIDTag: CM_RFIDTag) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.hideRowByName(ETRow_LocationOnTerminal,false);
	theForm.tblInput1.setValueByName(ETRow_Code, pRFIDTag.code);
	theForm.tblInput1.setValueByName(ETRow_Description, pRFIDTag.description);
	theForm.tblInput1.setValueByName(ETRow_SerialNumber, pRFIDTag.serialNumber);
	theForm.tblInput1.setValueByName(ETRow_IsAvailableForEntry,pRFIDTag.isAvailableForEntry);
	theForm.tblInput1.setValueByName(ETRow_Remarks,pRFIDTag.remarks);
epilog

end;</source>
        <Parameter name="pRFIDTag" type="CM_RFIDTag"/>
    </JadeMethod>
</Class>
