        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;

begin

	inheritMethod();
	self.frmToolbar.alignContainer := Frame.AlignContainer_Top;
	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.width:=700;
	self.height:=460;
	self.dkbGridAreasSide.parentAspect := Control.ParentAspect_StretchBoth;
	self.dkbGridAreasTop.parentAspect := Control.ParentAspect_StretchBottom;
	

	
end;</source>
