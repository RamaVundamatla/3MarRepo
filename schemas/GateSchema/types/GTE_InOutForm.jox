    <JadeMethod name="tblMain_cellInputReady" id="38881b60-c44f-47b6-9afc-bbb0a655a190">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_cellInputReady(table: CM_EntryTable; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tableObj	: CM_EntryTable;
	topSheetObj		: GTE_Sheet;

begin
	self.myAssistant.GTE_Assistant.mainExtraCellInputReady(table, inputControl, cleft, ctop, cwidth, cheight, saveRowHeight, GTE_InOutForm::getTopSheetControl.name);

	topSheetObj		:=	self.topSheet;
	
	if inputControl.name = cmbSubTerminal.name then
		if app.isSubTerminalsOn(self.myTerminal) then
			tableObj	:=	table;
			self.setSubTerminalDefault(topSheetObj.isReceival, false, tableObj);
		endif;
	endif;
end;</source>
        <Parameter name="table" type="CM_EntryTable"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
