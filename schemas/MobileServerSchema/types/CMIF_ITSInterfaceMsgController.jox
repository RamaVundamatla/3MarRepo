<Class name="CMIF_ITSInterfaceMsgController" id="97a73f1f-aa60-485b-8580-38647783d0f2">
    <superclass name="CMIF_ITSInterfaceMsg"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This class is used to parse messages from the ITS Interface.</text>
    <DbClassMap file="mobileServer"/>
    <ImplicitInverseRef name="myMediator" id="0f46efa8-296d-4c77-a6e1-97a273da3542">
        <embedded/>
        <type name="CM_RadioTelemetryMediator"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myRTQueueEntry" id="ad51702e-c36a-4de8-b771-f94845203ca7">
        <embedded/>
        <type name="CM_RTQueueEntry"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="errorQueueEntryNotAvailable" id="49ac45f1-fe6b-4ffe-828b-8d1424ccfa86">
        <source>errorQueueEntryNotAvailable();

/*

Purpose:			Generate Queue Entry not available exception

Parameters:			None

Return Value:		None


Date		Who		Reason
18 Feb 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	idString	: String;

begin
	idString := self.containerId;
	
	if self.queueEntryId &lt;&gt; null then
		if idString &lt;&gt; null then
			idString := idString  &amp; " ";
		endif;
		idString := idString &amp; "(" &amp; self.queueEntryId.String &amp; ")";
	endif;
	
	app.raiseCMException1(ERR_ITS_QE_NotAvailable, idString, null, null);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="errorQueueEntryNotFound" id="0d50fb5c-d2dc-4377-891f-63d8eadb666c">
        <source>errorQueueEntryNotFound();

/*

Purpose:			Generate Queue Entry not found exception

Parameters:			None

Return Value:		None


Date		Who		Reason
03 Feb 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	idString	: String;

begin
	idString := self.containerId;
	
	if self.queueEntryId &lt;&gt; null then
		if idString &lt;&gt; null then
			idString := idString  &amp; " ";
		endif;
		idString := idString &amp; "(" &amp; self.queueEntryId.String &amp; ")";
	endif;
	
	app.raiseCMException1(Err_QueueEntryNotFound, idString, null, null);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getContainerId" id="daac94ea-f689-45cc-bd48-d919a71cabab">
        <source>getContainerId() : String;

/*

Purpose:			Gets the container (cargo) id specified in the request.  If a container was not specified in 
					the request then gets the container id for the queue entry that was specified in the request.

Parameters:			None

Return Value:		Container Id


Date		Who		Reason
20 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	ti : CM_TrackedItem;

begin
	if self.containerId &lt;&gt; null then
		return self.containerId;
	endif;
	
	ti := self.myRTQueueEntry.getTrackedItem();
	
	if ti = null then
		return null;
	endif;
	
	return ti.id;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTask" id="512c2b1a-c1a5-41a0-bdb5-43a56892361e">
        <source>getTask() : CM_RTQueueTask;

/*

Purpose:			Get current task for machine

Parameters:			None

Return Value:		Current task


Date		Who		Reason
17 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
					
*/

vars
	
begin
	return self.myMachine.currentQueueTask;
	
end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getTaskForQueueEntry" id="98e23201-1ee6-420a-9312-ed89240b6151">
        <source>getTaskForQueueEntry(): CM_RTQueueTask;

/*

Purpose:			Get the task for the queue entry that was specified in the request.

Parameters:			None

Return Value:		Task to be actioned.


Date		Who		Reason
11 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	task : CM_RTQueueTask;

begin
	task := app.myUtlRT.getTaskForMachineFromQEntry(self.myMachine, self.myRTQueueEntry, false, true);
	
	if task &lt;&gt; null then
		return task;
	endif;
	
	task := self.myMachine.allAllocatedQueueTasks.first;
	
	if task &lt;&gt; null and
	   task.status = TASK_ALLOCATED and
	   task.myEntry = self.myRTQueueEntry then
		return task;
	endif;
	
	return task;
	
epilog

end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="postLogoff" id="df001291-f51c-484b-ad37-b28f46bd5dcd">
        <updating/>
        <source>postLogoff(_passport : CM_Passport input) updating;

/*

Purpose:			Invoked at the end of a successful Logoff transaction to do wrap up processing for ITS Interface.

Parameters:			Passport.

Return Value:		None


Date		Who		Reason
03 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	logoffRequest	: CM_ITSInterfaceRequestMessage;
	proxyResponse	: CM_ITSInterfaceResponse;
	realResponse	: CM_ITSInterfaceResponse;
	
begin
	logoffRequest	:= self.myMessage.CM_ITSInterfaceRequestMessage;

	self.myInterfaceDefinition.resetInterfaceForMachine(self.myMachine, logoffRequest.createdTS);
		
	// Create the delete all queue entries response
	create proxyResponse transient;
	proxyResponse.setProxyForDeleteAllQueueEntry(self.myMachine, self.myInterfaceDefinition);
	app.myUtilityCA.utlCreateITSInterfaceResponse(proxyResponse, realResponse, logoffRequest, _passport);
	
epilog
	delete proxyResponse;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="postLogon" id="d801f0db-e52b-4b2d-9d12-c3e38e521208">
        <updating/>
        <source>postLogon(_passport : CM_Passport input) updating;

/*

Purpose:			Invoked at the end of a successful Logon transaction to do wrap up processing for ITS Interface.

Parameters:			Passport.

Return Value:		None


Date		Who		Reason
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
01 Apr 2011	cnwkpd1	PAR #27107 - Prevent 1210 exception when logging a machine on in a test
					environment that has been refreshed from production
					
*/

vars
	logonRequest	: CM_ITSInterfaceRequestMessage;
	proxyResponse	: CM_ITSInterfaceResponse;
	realResponse	: CM_ITSInterfaceResponse;
	otherInterface	: CM_ITSInterfaceDefinition;
	
begin
	logonRequest := self.myMessage.CM_ITSInterfaceRequestMessage;

	self.myInterfaceDefinition.resetInterfaceForMachine(self.myMachine, logonRequest.createdTS);
	
	// PAR #27107 - If the machine is already "logged on" to another interface, this is because
	// we are in a database that has been refreshed from another source that was backed up when
	// the machine was currently logged on.  Because only one ITS interface can be running per 
	// terminal, it is safe to remove it from that other interface before connecting it to this one
	otherInterface := self.myMachine.myITSInterfaceLoggedOn;
	if otherInterface &lt;&gt; null then
		otherInterface.allMachinesLoggedOn.remove(self.myMachine);
	endif;
	
	// Add machine to list of active machines
	self.myInterfaceDefinition.allMachinesLoggedOn.add(self.myMachine);

	// Create the Logon Complete response
	create proxyResponse transient;
	proxyResponse.setProxyForLogonComplete(logonRequest);
	app.myUtilityCA.utlCreateITSInterfaceResponse(proxyResponse, realResponse, logonRequest, _passport);

epilog
	delete proxyResponse;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="postReject" id="4d6a8cae-c15d-40ec-9f05-e412d742d0be">
        <updating/>
        <source>postReject(_passport : CM_Passport input) updating;

/*

Purpose:			Invoked at the end of a successful reject to remove queue entry from active list.

Parameters:			Passport.

Return Value:		None


Date		Who		Reason
09 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	activeResponse	: CM_ITSInterfaceResponse;
	queueEntryID	: Integer;
	proxyResponse	: CM_ITSInterfaceResponse;
	realResponse	: CM_ITSInterfaceResponse;
	rejectRequest	: CM_ITSInterfaceRequestMessage;

begin
	queueEntryID	:= self.getInstanceIdForObject(self.myRTQueueEntry).Integer;
	activeResponse	:= self.myMachine.allITSInterfaceResponsesActive[queueEntryID];
	
	if activeResponse = null then
		self.postTransactionComplete(_passport);
		return;
	endif;
	
	rejectRequest	:= self.myMessage.CM_ITSInterfaceRequestMessage;
		
	// Create the delete response
	create proxyResponse transient;
	proxyResponse.setProxyForDeleteQueueEntry(activeResponse);
	app.myUtilityCA.utlCreateITSInterfaceResponse(proxyResponse, realResponse, rejectRequest, _passport);

epilog
	delete proxyResponse;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="postSetDown" id="020908cd-532a-4082-a818-698f93a3e1bd">
        <updating/>
        <source>postSetDown(_passport : CM_Passport input) updating;

/*

Purpose:			Invoked at the end of a successful set down to remove queue entry from active list.

Parameters:			Passport.

Return Value:		None


Date		Who		Reason
09 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	activeResponse	: CM_ITSInterfaceResponse;
	queueEntryID	: Integer;
	proxyResponse	: CM_ITSInterfaceResponse;
	realResponse	: CM_ITSInterfaceResponse;
	setdownRequest	: CM_ITSInterfaceRequestMessage;

begin
	queueEntryID	:= self.getInstanceIdForObject(self.myRTQueueEntry).Integer;
	activeResponse	:= self.myMachine.allITSInterfaceResponsesActive[queueEntryID];
	
	if activeResponse = null then
		self.postTransactionComplete(_passport);
		return;
	endif;
	
	setdownRequest	:= self.myMessage.CM_ITSInterfaceRequestMessage;
		
	// Create the delete response
	create proxyResponse transient;
	proxyResponse.setProxyForDeleteQueueEntry(activeResponse);
	app.myUtilityCA.utlCreateITSInterfaceResponse(proxyResponse, realResponse, setdownRequest, _passport);

epilog
	delete proxyResponse;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="postTransactionComplete" id="8b0162a1-8c21-4176-a8c4-5c775b034d8c">
        <updating/>
        <source>postTransactionComplete(_passport : CM_Passport input) updating;

/*

Purpose:			Invoked at the end of a successful transaction to do wrap up processing for ITS Interface.

Parameters:			Passport.

Return Value:		None


Date		Who		Reason
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.myMessage.CM_ITSInterfaceRequest.setProcessed(app.actualTimeServer());
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="postUpdateQueueEntry" id="ef609840-af2b-4bc8-b0bd-f83c11bcfc2b">
        <updating/>
        <source>postUpdateQueueEntry(_passport : CM_Passport input) updating;

/*

Purpose:			Invoked at the end of a successful transaction for ITS Interface which requires an updated Queue Entry to be sent.

Parameters:			Passport.

Return Value:		None


Date		Who		Reason
02 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	proxyResponse	: CM_ITSInterfaceResponse;
	realResponse	: CM_ITSInterfaceResponse;
	request			: CM_ITSInterfaceRequestMessage;
	task			: CM_RTQueueTask;
	
begin
	request	:= self.myMessage.CM_ITSInterfaceRequestMessage;
	task 	:= self.getTask();
	
	if task = null then
		self.myMessage.CM_ITSInterfaceRequest.setProcessed(app.actualTimeServer());
		return;
	endif;
	
	// Create the current Queue Entry response
	create proxyResponse transient;
	proxyResponse.setProxyForQueueEntry(task, true, self.messageNumber, self.myMachine, self.myInterfaceDefinition);
	app.myUtilityCA.utlCreateITSInterfaceResponse(proxyResponse, realResponse, request, _passport);
	
epilog
	delete proxyResponse;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setQueueEntry" id="5cc8d2aa-4c1d-4207-92fa-9ecbdadaefc0">
        <updating/>
        <source>setQueueEntry(_entry : CM_RTQueueEntry) updating;

/*

Purpose:			Set the Queue Entry reference on the receiver to the
					passed in value.  To be used when a message finds a Queue
					Entry other than one in the currently active list

Parameters:			RT Queue Entry

Return Value:		None


Date		Who		Reason
16 Sep 2010	cnwkpd1	PAR #24294 - CCMS MES 1080 - ITS Driver Initiated Move 

*/

vars

begin
	self.myRTQueueEntry := _entry;
	
	
epilog

end;</source>
        <Parameter name="_entry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="validateContainer" id="6a0b33bb-02a4-4fd7-80f2-9789e2312b4b">
        <source>validateContainer(_containerId : String);

/*

Purpose:			Validate that the input container matches the container of the current task

Parameters:			Input container id

Return Value:		None


Date		Who		Reason
17 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	currentTiId		: String;
	task			: CM_RTQueueTask;

begin
	if _containerId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, CM_ITSInterfaceMessage.XMLTag_CargoId, null, null);
		app.raiseCMException1(Input_required_field_Required, CM_ITSInterfaceMessage.XMLTag_CargoId, null, null); // cnwdb2	PAR 35364
	endif;
	
	task := self.getTask();
	if task &lt;&gt; null and 
	   task.ti &lt;&gt; null then
		currentTiId := task.ti.id;
	endif;
	
	if currentTiId &lt;&gt; _containerId then
		app.raiseCMException3(ERR_RT_CONTAINER_MISMATCH, _containerId, self.messageType, currentTiId, null, null);
	endif;
	
epilog
	
end;</source>
        <Parameter name="_containerId" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMachine" id="686d0c96-35f1-4376-b4e7-8088c6e976e2">
        <updating/>
        <source>validateMachine() updating;

/*

Purpose:			Validate the Machine ID of the input request and do set up for machine.

Parameters:			None

Return Value:		None


Date		Who		Reason
17 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	machineId		: String;
	terminal		: CM_Terminal;
	rtDevice		: CM_RTDeviceVehicleMount;
	
begin
	// Terminal is set for the interface
	terminal := app.getMyTerminalDO_NOT_USE();

	machineId := self.machineId;
	
	// Validate incoming machine Id
	if machineId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, CM_ITSInterfaceMessage.XMLTag_MachineId, null, null);
		app.raiseCMException1(Input_required_field_Required, CM_ITSInterfaceMessage.XMLTag_MachineId, null, null); // cnwdb2	PAR 35364
	endif;
	if self.myMachine = null then
		app.raiseCMException2(ERR_MACH_NOTFOUND, machineId, terminal.code, null, null);
		return;
	endif;

	// Check machine is RT enabled
	rtDevice := self.myMachine.myRTDevice;
	if rtDevice = null then
		app.raiseCMException1(ERR_MACH_NO_RT, machineId, null, null);
		return;
	endif;
	
	// Check device id is numeric - required to use mediator framework
	if not rtDevice.id.isInteger then
		app.raiseCMException1(ERR_MACH_NON_NUM_RT, machineId, null, null);
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMachineAndMediator" id="a03647ee-f363-4931-b95e-34d45a9dba3e">
        <updating/>
        <source>validateMachineAndMediator() updating;

/*

Purpose:			Validate the machine and mediator.

Parameters:			None

Return Value:		Set up references myMachine and myMediator.
					Set user in passport from machine.


Date		Who		Reason
17 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	mediator		: CM_RTConnectMediator;
	terminal		: CM_Terminal;
	timeout			: Integer;
	user			: CM_User;
	
begin
	// Terminal is set for the interface
	terminal := app.getMyTerminalDO_NOT_USE();
	
	// Validate machine id first, and set up myMachine reference
	self.validateMachine();
	
	user := self.myMachine.user;
	
	// Check machine is logged on
	if self.messageType &lt;&gt; ITS_MESSAGETYPE_LOGOFF then
		if user = null or 
		   not self.myMachine.loggedOn or
		   self.myMachine.myITSInterfaceLoggedOn &lt;&gt; self.myInterfaceDefinition then
			app.raiseCMException(ERR_MS_NOT_LOGGED_ON, null, null);
			return;
		endif;
	endif;
	
	if user &lt;&gt; null then
		// Set user from machine
		app.myPassport.setMyUser(user);
		// Set local from User if there is one set
		if user.myLocale &lt;&gt; null then
			app.setLocale(user.myLocale );
		endif;
	endif;
	
	// Validate and set mediator
	mediator := terminal.allActiveMediators[self.myMachine.myRTDevice.id.Integer];

	if self.messageType &lt;&gt; ITS_MESSAGETYPE_LOGOFF then
		if mediator = null or 
		   not mediator.isKindOf(CM_RadioTelemetryMediator) then
			app.raiseCMException(ERR_MS_NOT_LOGGED_ON, null, null);
			return;
		endif;
	endif;

	if mediator &lt;&gt; null then 
		self.myMediator := mediator.CM_RadioTelemetryMediator;
	endif;
	
	// Check for session timeout
	if self.messageType &lt;&gt; ITS_MESSAGETYPE_LOGOFF then
		timeout := self.myInterfaceDefinition.sessionTimeout;
		if timeout &lt;&gt; null then
			if self.myMediator.lastUpdateTs.addMinutes(timeout) &lt; app.actualTimeServer then
				app.raiseCMException(ERR_MS_SESSION_TIMEOUT, null, null);
				return;
			endif;	
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateQueueEntry" id="1dafc5bf-417a-44d4-bc70-24cf14ec016c">
        <updating/>
        <source>validateQueueEntry() updating;

/*

Purpose:			Validate Queue Entry.  

Parameters:			None

Return Value:		Set up reference myRTQueueEntry.


Date		Who		Reason
18 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	activeResponse	: CM_ITSInterfaceResponse;
	response		: CM_ITSInterfaceResponse;
	task			: CM_RTQueueTask;
	ti				: CM_TrackedItem;
	invalidObject	: Boolean;
	
begin
	// Require a Queue Entry ID or Container ID to identify active queue entry
	if self.queueEntryId = 0 then
		if self.containerId = null then
			app.raiseCMException(ERR_ITS_ID_required, null, null);
		endif;
		// Match the given Container Id with the machine's list of queue entries sent to ITS
		foreach activeResponse in self.myMachine.allITSInterfaceResponsesActive discreteLock do
			if activeResponse.myRTQueueEntry &lt;&gt; null then
				ti := activeResponse.myRTQueueEntry.getTrackedItem();
				if ti &lt;&gt; null and
				   ti.id = self.containerId then
					response := activeResponse;
					break;
				endif;
			endif;
		endforeach;
	else
		// Check the Queue Entry is in the machine's list of queue entries sent to ITS
		response := self.myMachine.allITSInterfaceResponsesActive[self.queueEntryId];
	endif;
	
	if response = null or
	   response.myRTQueueEntry = null then
		self.errorQueueEntryNotFound();
	endif;
	
	// Set up reference Queue Entry	
	self.myRTQueueEntry := response.myRTQueueEntry;

	// Check machine not working on a different queue entry
	task := self.getTask();
	if task &lt;&gt; null and
	   task.myEntry &lt;&gt; response.myRTQueueEntry then
		app.raiseCMException2(ERR_MACH_BUSY, self.machineId, task.myEntry.id, null, null);
	endif;

	// Check input container matches Queue Entry
	if self.containerId &lt;&gt; null then
		
		on Exception do app.handleDeletedObject(exception, self.myRTQueueEntry, invalidObject);	//06 Apr 2011	NDL	Par 27242
		ti := self.myRTQueueEntry.getTrackedItem();
		
		if invalidObject then	//06 Apr 2011	NDL	Par 27242
			self.errorQueueEntryNotFound();
			return;
		endif;
		
		if ti &lt;&gt; null and
		   self.containerId &lt;&gt; ti.id then
			app.raiseCMException3(ERR_RT_CONTAINER_MISMATCH, self.containerId, self.messageType, ti.id, null, null);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateTask" id="c2683309-7e19-4a5f-9657-57699ff00708">
        <source>validateTask(_expectedTaskType : Integer);

/*

Purpose:			Validate the state of the current task

Parameters:			Expected type of current task

Return Value:		None, exception raised if there are any issues


Date		Who		Reason
17 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	task	: CM_RTQueueTask;
	
begin
	task := self.getTask();
	
	if task = null then
		if _expectedTaskType &lt;&gt; TASK_UNKNOWN then
			app.raiseCMException1(ERR_RT_PHASE_STARTUP, self.messageType , null, null);
		endif;
	elseif task.machine &lt;&gt; self.myMachine then
		if _expectedTaskType &lt;&gt; TASK_UNKNOWN then
			app.raiseCMException(TaskAllocated, null, null);
		endif;
	elseif task.taskType &lt;&gt; _expectedTaskType then
		if task.status = TASK_OFFERED or 
		   task.status = TASK_ACCEPTED or 
		   task.status = TASK_WORKING then
			if task.taskType = TASK_DIRECTOR then
				app.raiseCMException1(ERR_RT_PHASE_DIRECTEDMOVE, self.messageType , null, null);
			elseif task.taskType = TASK_PICKUP then
				app.raiseCMException1(ERR_RT_PHASE_QUEUEDMOVE, self.messageType , null, null);
			elseif task.taskType = TASK_SETDOWN then
				app.raiseCMException1(ERR_RT_PHASE_SETDOWN, self.messageType , null, null);
			elseif task.taskType = TASK_MOVE then
				app.raiseCMException1(ERR_RT_PHASE_QUEUEDMOVE, self.messageType , null, null);
			endif;
		else
			if _expectedTaskType &lt;&gt; TASK_UNKNOWN then
				app.raiseCMException1(ERR_RT_PHASE_STARTUP, self.messageType , null, null);
			endif;
		endif;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_expectedTaskType" type="Integer"/>
    </JadeMethod>
</Class>
