    <JadeMethod name="getDisplayStringForAttribute" id="847ac25e-6935-4bbf-a14e-09bf211fa767">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
//19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	debtor	: CM_Debtor;
	voyage	: CM_Voyage;
	ts		: TimeStamp;
begin
	if _attrName = ETRow_EventType then
		if self.myEventType &lt;&gt; null then
			return self.myEventType.name;
		else
			return null;
		endif;
	 // ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1 - start
	elseif _attrName = ETRow_ResourcesUsed then	
		return self.getResourceUsageQuantStringJRW();
	elseif _attrName = ETRow_Category then
		return self.myEventType.getCategoryString();
	elseif _attrName = ETRow_UsesResources  then
		return self.hasTaskThatAllowsResources.getYes();
	elseif _attrName = ETRow_HasResources then
		return self.allResourceUsages.isNotEmpty.getYes();
	 // ### TFS CR 54345 TASK 58281 16JUN2023 NAVAB1 - end
	elseif _attrName = ETRow_NumMoves then
		return self.getAmountDisplay();
	elseif _attrName = ETRow_Charged then
		return app.getYesBlank(not self.allInvoiceLines.isEmpty());
	elseif _attrName = ETRow_NoCharge then	//05 Nov 2009	NDL Par 21519
		return app.getYesBlank(self.noCharge);
		
	elseif _attrName = ETRow_Date then
		return self.systemToLocalTime(self.dateTime).date.asStringJMT();
		
	elseif _attrName = ETRow_Time then
		return self.systemToLocalTime(self.dateTime).time.asStringJMT();
	
	// Feb 2012 CCMS 1262 Transaction Enquiry extra attributes
	elseif _attrName = ETRow_TransactionDT then
		return self.systemToLocalTime(self.dateTime).shortCurrentLocaleFormat;
	elseif _attrName = ETRow_TypeString then
		return self.getEventTypeName();
	elseif _attrName = ETRow_MyHMSVoyageData then	// used because it has a heading of just 'Voyage'
		voyage := self.getVoyage();
		if voyage = null then	
			return null;
		else
			return voyage.code;
		endif;
	elseif _attrName = ETRow_Debtor then
		debtor := self.myDebtor;
		if debtor = null then
			debtor := self.getDebtor();
		endif;
		if debtor = null then
			return null;
		else
			return debtor.name;
		endif;
	elseif _attrName = ETRow_StartDT then
		ts := self.getStartTS();
		if ts = null then
			return null;
		else
			return self.systemToLocalTime(ts).shortCurrentLocaleFormat;
		endif;
	elseif _attrName = ETRow_EndDT then
		ts := self.getEndTS();
		if ts = null then
			return null;
		else
			return self.systemToLocalTime(ts).shortCurrentLocaleFormat;
		endif;
	
	elseif _attrName = ETRow_User or
		   _attrName = ETRow_UserName then
		return self.userCode;
	elseif 	 _attrName = ETRow_ErrorText or
		   _attrName = ETRow_AppName then 	
		  return self.getExtraData(TrnsExtraDataContext).asStringJMT;

	elseif _attrName = ETRow_ErrorCode or 
	   _attrName = ETRow_ComputerName  or
	   _attrName = ETRow_ErrorField or
	   _attrName = ETRow_Entity  or
	   _attrName = ETRow_OsDescription or
	   _attrName = ETRow_TimeLoggedOnMinutes or
	   _attrName = ETRow_LogoutTime then
		return null;
	
	elseif _attrName = ETRow_MyTerminal or 
	   _attrName = ETRow_Terminal then
		if self.myTerminal &lt;&gt; null then
			return self.myTerminal.name;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_Description then
		return self.getDescription();

	elseif _attrName = ETRow_GenLanding then	//14 Mar 2016	NDL	TFS 1407
		return null;
		
	elseif _attrName = ETRow_PrevGenLanding then	//14 Mar 2016	NDL	TFS 1407
		return null;
	elseif _attrName = ETRow_EndDateTime then	
		return null;
	elseif _attrName = ETRow_WorkPoint then	//05 May 2017	NDL	TFS 4329
		return null;
	elseif _attrName = ETRow_MyVoyageDelay then	//24 Aug 2018	NDL	TFS 40309
		return null;
	elseif _attrName = ETRow_Remarks then	//09 Mar 2020	NDL	TFS 48784
		if self.class.getPropertyInHTree( ETRow_Remarks ) &lt;&gt; null then	//20 May 2020	NDL	TFS 49418
			return inheritMethod(_attrName, _short);
		endif;
		return null;
	elseif _attrName = ETRow_Weight then	// 09/07/2022 jlizm1 TFS 54165
		return null;
	endif;
	
	return inheritMethod(_attrName, _short);


end;


</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
