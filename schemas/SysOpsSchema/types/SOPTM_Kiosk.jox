begin
	self.doMovePPEQuestion(false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSingle1Edit" id="922a05a5-c691-4962-ba83-5925a563771f">
        <source>doBtnSingle1Edit();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions
28 August 2023		jlizm1	TFS 59551 Kiosk Additional Question

*/

vars
	theForm	: SOP_TableMaintForm;
	ppeQuestionForm : SOP_PPEQuestionForm;
	ppeQuestion : CM_KioskPPEQuestion;
	modalResult : Integer;
	
begin
	theForm := self.myForm;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	
	if (theForm.myCurrentObject.isKindOf(CM_Kiosk) = false) then
		return;
	endif;
	
	if(theForm.lstSingleSelect1.listObject = null) then
		return;
	else
		ppeQuestion := theForm.lstSingleSelect1.listObject.CM_KioskPPEQuestion;
	endif;
	
	ppeQuestionForm := app.loadForm(SOP_PPEQuestionForm, theForm.myAssistant.class, false, false ,true ,self.myForm.myTerminal, null).SOP_PPEQuestionForm;
	if ppeQuestionForm = null then
		return;
	endif;
	
	ppeQuestionForm.init(theForm.myCurrentObject.CM_Kiosk, ppeQuestion, SOP_PPEQuestionForm.MODE_PPE);
	modalResult:=ppeQuestionForm.showModal;
	if modalResult = IDOK then
		theForm.lstSingleSelect1.listCollection(theForm.myCurrentObject.CM_Kiosk.allPPEQuestions, true, 0);
		theForm.lstSingleSelect1.listObject := ppeQuestionForm.myKioskObject;
	endif;

epilog

end;</source>
    </JadeMethod>
