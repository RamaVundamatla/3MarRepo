        <source>createDrawingAttribute() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/05/2015	cnwdap1		Initial creation PAR #36206 TFS 324/334 Graphical Representation of Hazard Class
