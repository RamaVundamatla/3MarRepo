    <JadeMethod name="analyseTranLog" id="fb80c397-5db2-4e62-994d-0c3df6bfea15">
        <updating/>
        <source>analyseTranLog():String updating;

begin
	outFile.usePresentationFileSystem:=inFile.usePresentationFileSystem;
	readTransFile;
	if allTransactions.size &lt;&gt; 0 then
		doAnalysis;
		writeStatsFile;
		if app.name &lt;&gt; "CreatorCreator" then
			doCopyOutFile;
		endif;
	else
		return "no transactions in file";
	endif;
	return outFile.fileName;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="compareStatsFiles" id="70199087-0a9a-474e-8af8-dbea2205a774">
        <updating/>
        <source>compareStatsFiles(file1,file2:String):String updating;

begin
	readStatsFile(file1, allTranStats1);
	readStatsFile(file2, allTranStats2);
	outFile.usePresentationFileSystem:=inFile.usePresentationFileSystem;
	outFile.fileName:=inFile.fileName.replace("_stats",null).replace(".csv","_comparison.csv");
	outFile.writeLine("Comparing,"&amp;file1);
	outFile.writeLine("with,"&amp;file2);
	outFile.writeLine(null);
	doCompare;
	doCopyOutFile;
	return outFile.fileName;
end;</source>
        <Parameter name="file1" type="String"/>
        <Parameter name="file2" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="c8993471-e769-4663-a078-7971d3a31163">
        <updating/>
        <source>create() updating;

begin
	allTranStats1.setMembership(TranStat);
	allTranStats1.addMemberKey("key", false, false);
	allTranStats1.endKeys(true);
	
	allTranStats2.setMembership(TranStat);
	allTranStats2.addMemberKey("key", false, false);
	allTranStats2.endKeys(true);
	
	create inFile;
	inFile.mode:=File.Mode_Input;
	//inFile.shareMode:=File.Share_Read;  // "optimisation" for static files
	inFile.shareMode:=File.Share_ReadWrite;  // read it whether someone has it open output or not
	inFile.kind:=File.Kind_ANSI;
	create outFile;
	outFile.mode:=File.Mode_Output;
	outFile.kind:=File.Kind_ANSI;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="b5478ab9-4812-48bd-9bf0-012dbd878a5b">
        <updating/>
        <source>delete() updating;

begin
	delete inFile;
	delete outFile;
	if allTranStats1.isEmpty=false then
		allTranStats1.purge;
	endif;
	if allTranStats2.isEmpty=false then
		allTranStats2.purge;
	endif;
	if allTransactions.isEmpty=false then
		allTransactions.purge;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAnalysis" id="d42a5306-f82a-44b8-80ad-a301d788cb06">
        <updating/>
        <source>doAnalysis() updating;

vars
	iter:Iterator;
	tran:Transaction;
	tranStat:TranStat;
	totalCount,totalElapsed,totalMaxElapsed,totalMinElapsed:Integer;
	key1,prevKey1:String;
begin
	iter:=allTransactions.createIterator;
	while iter.next(tran) do
		if process.getUserCode = "cnwjhp1" and tran.tranid = "CMITimeZoneTA::updateEntity" then  // supress this, as it is only done at driver boj, and is artificially long due to lock contention with large numbers of users
			continue;
		endif;
		totalElapsed:=totalElapsed+tran.elapsed;
		totalCount:=totalCount+1;
		key1:=iter.getCurrentKey(1).String;
		if key1 &lt;&gt; prevKey1 then
			if tranStat &lt;&gt; null then
				totalMaxElapsed:=totalMaxElapsed+tranStat.maxElapsed;
				totalMinElapsed:=totalMinElapsed+tranStat.minElapsed;
				tranStat.avgElapsed:=(tranStat.totalElapsed / tranStat.count).rounded;
				allTranStats1.add(tranStat);
			endif;
			create tranStat;
			tranStat.minElapsed:=99999;
			tranStat.key:=key1;
			prevKey1:=key1;
		endif;
		tranStat.totalElapsed:=tranStat.totalElapsed+tran.elapsed;
		tranStat.count:=tranStat.count+1;
		tranStat.errors:=tranStat.errors+(tran.error&lt;&gt;null).Integer;
		if tran.elapsed &lt; tranStat.minElapsed then
			tranStat.minElapsed:=tran.elapsed;
		endif;
		if tran.elapsed &gt; tranStat.maxElapsed then
			tranStat.maxElapsed:=tran.elapsed;
		endif;
	endwhile;
	totalMaxElapsed:=totalMaxElapsed+tranStat.maxElapsed;
	totalMinElapsed:=totalMinElapsed+tranStat.minElapsed;
	tranStat.avgElapsed:=(tranStat.totalElapsed / tranStat.count).rounded;
	allTranStats1.add(tranStat);

	// add totals line
	create tranStat;
	tranStat.key:="All Transactions";
	tranStat.totalElapsed:=totalElapsed;
	tranStat.count:=totalCount;
	tranStat.avgElapsed:=(totalElapsed / totalCount).rounded;
	tranStat.maxElapsed:=totalMaxElapsed;
	tranStat.minElapsed:=totalMinElapsed;
	allTranStats1.add(tranStat);
end;</source>
    </JadeMethod>
    <JadeMethod name="doCompare" id="78586f90-75c4-4d79-90c9-12b9501baabd">
        <updating/>
        <source>doCompare() updating;

vars
	iter1:Iterator;
	tranStat1,tranStat2:TranStat;
	s,avgElapsedDiff,totalsLine:String;
	o:Object;
begin
	outFile.writeLine("Transaction Id,Count 1,Count 2,Count Diff %,Avg Time 1,Avg Time 2,Avg Time Diff Secs,Avg Time Diff %,Total Time 1,Total Time 2,Total Time Diff Secs");
	iter1:=allTranStats1.createIterator;
	
	while iter1.next(tranStat1) do
		tranStat2:=allTranStats2[iter1.getCurrentKey(1)].TranStat;
		if tranStat2 = null then  // transaction is in file 1 but not file 2
			outFile.writeLine(tranStat1.key
							&amp;","&amp;tranStat1.count.String
							&amp;",,,"&amp;(tranStat1.avgElapsed / 1000).String&amp;",,");
			continue;
		endif;
		while tranStat2 &lt;&gt; allTranStats2.first do  // transactions in file 2 but not file 1
			//if not (process.getUserCode = "cnwjhp1" and allTranStats2.first.TranStat.key = "CMITimeZoneTA::updateEntity") then
				outFile.writeLine(allTranStats2.first.TranStat.key
								&amp;",,"&amp;allTranStats2.first.TranStat.count.String
								&amp;",,,"&amp;(allTranStats2.first.TranStat.avgElapsed / 1000).String&amp;",");
			//endif;
			allTranStats2.remove(allTranStats2.first);
		endwhile;
		if tranStat1.avgElapsed = 0 then
			avgElapsedDiff:="0";
		else
			avgElapsedDiff:=((tranStat2.avgElapsed - tranStat1.avgElapsed) / tranStat1.avgElapsed *100).roundedTo(1).String;
		endif;
		s:=tranStat1.key  // transaction in both files
				&amp;","&amp;tranStat1.count.String
				&amp;","&amp;tranStat2.count.String
				&amp;","&amp;((tranStat2.count - tranStat1.count) / tranStat1.count *100).roundedTo(1).String
				&amp;","&amp;(tranStat1.avgElapsed / 1000).String
				&amp;","&amp;(tranStat2.avgElapsed / 1000).String
				&amp;","&amp;((tranStat2.avgElapsed - tranStat1.avgElapsed) / 1000).String
				&amp;","&amp;avgElapsedDiff
				&amp;","&amp;(tranStat1.totalElapsed / 1000).String
				&amp;","&amp;(tranStat2.totalElapsed / 1000).String
				&amp;","&amp;((tranStat2.totalElapsed - tranStat1.totalElapsed) / 1000).String;
		if tranStat1.key = "All Transactions" then
			totalsLine:=s;
		else
			outFile.writeLine(s);
		endif;
		allTranStats2.remove(tranStat2);
	endwhile;
	foreach o in allTranStats2 do  // transactions in file 2 but not file 1
		tranStat2:=o.TranStat;
		outFile.writeLine(tranStat2.key
						&amp;",,"&amp;tranStat2.count.String
						&amp;",,,"&amp;(tranStat2.avgElapsed / 1000).String&amp;",");
		allTranStats2.remove(tranStat2);
	endforeach;
	outFile.writeLine(totalsLine);
	outFile.close;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCopyOutFile" id="59bfaa27-beb3-4cc6-bf47-b555b8f8c5a7">
        <updating/>
        <source>doCopyOutFile() updating;

begin
	on FileException do fileExceptionHandler(exception);  // handle file in use and bad directory exceptions copying output file
	inFile.close;
	outFile.close;
	outFile.usePresentationFileSystem:=true;  // can't reach m24 with jblpcre usercode
	if inFile.fileName.toLower.cnContains("benchmarkresults") and inFile.fileName[1:2] &lt;&gt; "\\" then
		inFile.fileName:=outFile.fileName;
		outFile.fileName:=OtherResultsFolder&amp;inFile.fileName[3:end];
		outFile.writeString(inFile.readString(inFile.fileLength));
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="fileExceptionHandler" id="58e0c4cd-9a3b-487f-b3ff-1c2e0810c6e0">
        <source>fileExceptionHandler(exc:FileException):Integer;

begin
	if exc.errorCode = 5030  // File is in use by another process
	or exc.errorCode = 5028  // Requested file directory not found
	then
		if exc.errorObject.isKindOf(FileNode) then
			app.logMessage("FileException "&amp;exc.errorCode.String&amp;" ignored for "&amp;exc.errorObject.FileNode.fileName);
		else
			app.logMessage("FileException "&amp;exc.errorCode.String&amp;" ignored");
		endif;
		return Ex_Resume_Next;
	endif;
	return Ex_Pass_Back;
end;</source>
        <Parameter name="exc" type="FileException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="profAddThis" id="cc957d72-1a81-4c70-9b86-fb01cb2d0fbe">
        <source>profAddThis(key,s:String);

vars
	stat:TranStat;
	i,j,count,min,max,total:Integer;
	t,u,v:String;
begin
	i:=1;		total		:=s.scanUntil(Tab, i).Integer;
	i:=11;	count	:=s.scanUntil(Tab, i).Integer;
	i:=21;	min		:=s.scanUntil(Tab, i).Integer;
	i:=31;	max		:=s.scanUntil(Tab, i).Integer;
	
	stat:=allTranStats1[key].TranStat;
	if stat = null then
		create stat;
		stat.key:=key;
		stat.minElapsed:=99999;
		allTranStats1.add(stat);
	endif;
	stat.totalElapsed:=stat.totalElapsed + total;
	stat.count:=stat.count + count;
	if min &lt; stat.minElapsed then
		stat.minElapsed:=min;
	endif;
	if max &gt; stat.maxElapsed then
		stat.maxElapsed:=max;
	endif;
end;
</source>
        <Parameter name="key" type="String"/>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="profDoTotals" id="a1b357fe-9147-4b88-a84c-c29683230621">
        <source>profDoTotals();
//	used with addThis
vars
	o:Object; stat:TranStat;
	totalCount,totalElapsed,totalMaxElapsed,totalMinElapsed:Integer;
begin
	foreach o in allTranStats1 do
		stat:=o.TranStat;
		if stat.count &gt; 0 then
			stat.avgElapsed:=(stat.totalElapsed / stat.count).rounded;
		endif;
		
		totalElapsed:=totalElapsed + stat.totalElapsed;
		totalCount:=totalCount+stat.count;
		totalMaxElapsed:=totalMaxElapsed+stat.maxElapsed;
		totalMinElapsed:=totalMinElapsed+stat.minElapsed;
	endforeach;
	create stat;
	stat.key:="All Transactions";
	stat.totalElapsed:=totalElapsed;
	stat.count:=totalCount;
	stat.avgElapsed:=(totalElapsed / totalCount).rounded;
	stat.maxElapsed:=totalMaxElapsed;
	stat.minElapsed:=totalMinElapsed;
	allTranStats1.add(stat);
end;
</source>
    </JadeMethod>
    <JadeMethod name="readStatsFile" id="5aba7811-c915-49fe-ae2b-851070fa0fd9">
        <updating/>
        <source>readStatsFile(fileName:String; dyna:DynaDictionary input) updating;

vars
	tranStat:TranStat;
	i,j:Integer;
	s,t,s2:String;
begin
	inFile.fileName:=fileName;

	while not inFile.endOfFile do
		s:=inFile.readLine;
		if s[1:15] = "Transaction Id," or s = null then
			continue;
		endif;
	
		create tranStat;
		i:=1;
		tranStat.key			:= s.scanUntil(",",i);  i:=i+1;
		if process.getUserCode = "cnwjhp1" then
			if tranStat.key.contains("CMIEdit") and tranStat.key.contains("Form::btnSave_click") then
				tranStat.key:=tranStat.key.replace("btnSave_click", "doSave");  // instrumentation was changed
			endif;
		endif;
		tranStat.count			:= s.scanUntil(",",i).Integer;  i:=i+1;
		//write tranStat.count;
								   s.scanUntil(",",i);  i:=i+1;  // ignore percent
		tranStat.errors			:= s.scanUntil(",",i).Integer;  i:=i+1;
		tranStat.avgElapsed		:= (s.scanUntil(",",i).Decimal*1000).Integer;  i:=i+1;
		tranStat.maxElapsed		:= (s.scanUntil(",",i).Decimal*1000).Integer;  i:=i+1;
		tranStat.minElapsed		:= (s.scanUntil(",",i).Decimal*1000).Integer;  i:=i+1;
		tranStat.totalElapsed	:= (s.scanUntil(",",i).Decimal*1000).Integer;  i:=i+1;
		if tranStat.count = 0 then
			tranStat.count:=1;
		endif;
		dyna.add(tranStat);
	endwhile;
	inFile.close;
end;</source>
        <Parameter name="fileName" type="String"/>
        <Parameter name="dyna" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="readTransFile" id="8a30d7bd-e072-405d-869e-0efedfa3bfad">
        <updating/>
        <source>readTransFile() updating;

vars
	i,j,k,l:Integer;
	s,t,u,v,s2:String;
	tran:Transaction;
	levelformat,ipFormat:Boolean;
begin
	on Exception do resumeNextExceptionHandler(exception);
	allTransactions.setMembership(Transaction);
	allTransactions.addMemberKey("tranid", false, false);
	allTransactions.addMemberKey("computer", false, false);
	allTransactions.addMemberKey("user", false, false);
	allTransactions.endKeys(true);
	
	// Deal with the change to cntranlog with level as a column
	s:=inFile.readLine;
	if s.cnContains("Tran Id,Level,Elapsed") then 
		levelformat := true;
	endif;
	if s.cnContains(",IP Address,") then 
		ipFormat := true;
	endif;
	
	inFile.readLine;
	//inFile.readLine;
	while not inFile.endOfFile do
		s:=inFile.readLine;
		if s.trimBlanks = null then continue; endif;
		create tran;
		i:=1;
		t:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		if t.length &lt; 8 or t[1:21] = "previous log saved as" or s[1:11] = "Date,Time,C" then continue; endif;
		
		tran.timeStamp.setDate((t[7:2]&amp;"/"&amp;t[5:2]&amp;"/"&amp;t[1:4]).Date);
		t:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		tran.timeStamp.setTime((t[1:2]&amp;":"&amp;t[3:2]&amp;":"&amp;t[5:2]).Time);
		tran.computer		:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		//if ipFormat then
		if ipFormat and s[i:19] &lt;&gt; "jblstdruncnlogmaker" then
			s.scanUntil(",",i).trimBlanks;  i:=i+1;   // skip ip field if present
		endif;
		tran.application		:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		tran.user			:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		/*tran.tranid		:=s.scanUntil(",",i).trimBlanks.replace('"','');  i:=i+1;
		if tran.tranid[1:3] = "CMI" then  // their tranids take the form of 'class,name', or '"class,name"' for CardSchema 3.1.09
			tran.tranid		:=tran.tranid&amp;"::"&amp;s.scanUntil(",",i).trimBlanks.replace('"','');  i:=i+1;
		endif;*/
		if s[i] = '"' then  // tranid is quoted
			i:=i+1;
			tran.tranid		:=s.scanUntil('"',i).trimBlanks.replace(',','::');  i:=i+2;
		else
			tran.tranid		:=s.scanUntil(',',i).trimBlanks;  i:=i+1;
			if tran.tranid[1:3] = "CMI" then  // their tranids take the form of 'class,name', or '"class,name"' for CardSchema 3.1.09
				tran.tranid	:=tran.tranid&amp;"::"&amp;s.scanUntil(",",i).trimBlanks.replace('"','');  i:=i+1;
			endif;
		endif;
		
		v:=inFile.fileName.toLower;
		if v.cnContains("jadestar") or v.cnContains("jblvtx") or v.cnContains("jvtx6")
		and tran.tranid.cnContains("/") then  // special for JadeStar - remove org codes
			j:=1;
			u:=tran.tranid;
			while true do
				tran.tranid:=u.scanUntil("/",j).trimBlanks; j:=j+1;
				if j = 1 then break; endif;
			endwhile;
		endif;
		if statsByClient then
			//tran.tranid		:=tran.tranid&amp;" "&amp;tran.computer;  // by client
			//tran.tranid		:=t[1:2]&amp;":"&amp;t[3:2]&amp;" "&amp;tran.tranid;  // by time by client
			//tran.tranid		:=tran.tranid&amp;" "&amp;t[1:2]&amp;":"&amp;t[3:2];  // by client by time
			tran.tranid		:=t[1:2]&amp;":"&amp;t[3:2];  // by time (per minute)
			//tran.tranid		:=t[1:2]&amp;":"&amp;t[3:3];  // by time (per 10 seconds)
		endif;
		if tran.tranid = null then
			tran.tranid:="&lt;none&gt;";
		endif;
		
		if levelformat then 
			i:= i + 2;
		endif;	
		tran.elapsed		:=s.scanUntil(",",i).Integer;  i:=i+1;
		if tran.elapsed = Max_Integer or tran.tranid = 'bogus' then  // CardSchema bug?
			delete tran;
			continue;
		endif;
		if tran.elapsed &gt; 3600000 then
			tran.tranid:=tran.tranid&amp;"_bogus";
			//delete tran; continue;
		endif;
		if i &lt;= s.length then
			tran.cpu			:=s.scanUntil(",",i).Integer;  i:=i+1;
		endif;
//		tran.error			:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		allTransactions.add(tran);
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="readTransFileOrig" id="dae506cf-a8f3-403a-8d06-251e1b15d6a7">
        <updating/>
        <source>readTransFileOrig() updating;

vars
	i,j,k,l:Integer;
	s,t,u,v:String;
	tran:Transaction;
begin
	allTransactions.setMembership(Transaction);
	allTransactions.addMemberKey("tranid", false, false);
	allTransactions.addMemberKey("computer", false, false);
	allTransactions.addMemberKey("user", false, false);
	allTransactions.endKeys(true);
	
	inFile.readLine;
	inFile.readLine;
	inFile.readLine;
	while not inFile.endOfFile do
		create tran;
		s:=inFile.readLine;
		i:=1;
		t:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		if t = null or t[1:21] = "previous log saved as" or s[1:11] = "Date,Time,C" then continue; endif;
		tran.timeStamp.setDate((t[7:2]&amp;"/"&amp;t[5:2]&amp;"/"&amp;t[1:4]).Date);
		t:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		tran.timeStamp.setTime((t[1:2]&amp;":"&amp;t[3:2]&amp;":"&amp;t[5:2]).Time);
		tran.computer		:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		tran.application	:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		tran.user			:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		tran.tranid			:=s.scanUntil(",",i).trimBlanks.replace('"','');  i:=i+1;
		if tran.tranid[1:3] = "CMI" then  // their tranids take the form of 'class,name', or '"class,name"' for CardSchema 3.1.09
			tran.tranid		:=tran.tranid&amp;"::"&amp;s.scanUntil(",",i).trimBlanks.replace('"','');  i:=i+1;
		endif;
		v:=inFile.fileName.toLower;
		if v.cnContains("jadestar") or v.cnContains("jblvtx") or v.cnContains("jvtx6")
		and tran.tranid.cnContains("/") then  // special for JadeStar - remove org codes
			j:=1;
			u:=tran.tranid;
			while true do
				tran.tranid:=u.scanUntil("/",j).trimBlanks; j:=j+1;
				if j = 1 then break; endif;
			endwhile;
		endif;
		if statsByClient then
//			tran.tranid		:=tran.tranid&amp;" "&amp;tran.computer;
//			tran.tranid		:=t[1:2]&amp;":"&amp;t[3:2]&amp;" "&amp;tran.tranid;  // by time by client
//			tran.tranid		:=tran.tranid&amp;" "&amp;t[1:2]&amp;":"&amp;t[3:2];  // by client by time
			tran.tranid		:=t[1:2]&amp;":"&amp;t[3:2];  // by time (per minute)
		endif;
		if tran.tranid = null then
			tran.tranid:="&lt;none&gt;";
		endif;
		tran.elapsed		:=s.scanUntil(",",i).Integer;  i:=i+1;
		if tran.elapsed = Max_Integer then  // CardSchema bug?
			delete tran;
			continue;
		endif;
		tran.cpu			:=s.scanUntil(",",i).Integer;  i:=i+1;
		tran.error			:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		allTransactions.add(tran);
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="readTransFileOrig2" id="f8acc4cc-f913-4d00-9dc3-97925fdda5c9">
        <updating/>
        <source>readTransFileOrig2() updating;

vars
	i,j,k,l:Integer;
	s,t,u,v:String;
	tran:Transaction;
begin
	allTransactions.setMembership(Transaction);
	allTransactions.addMemberKey("tranid", false, false);
	allTransactions.addMemberKey("computer", false, false);
	allTransactions.addMemberKey("user", false, false);
	allTransactions.endKeys(true);
	
	inFile.readLine;
	inFile.readLine;
	//inFile.readLine;
	while not inFile.endOfFile do
		s:=inFile.readLine;
		if s.trimBlanks = null then continue; endif;
		create tran;
		i:=1;
		t:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		if t = null or t[1:21] = "previous log saved as" or s[1:11] = "Date,Time,C" then continue; endif;
		tran.timeStamp.setDate((t[7:2]&amp;"/"&amp;t[5:2]&amp;"/"&amp;t[1:4]).Date);
		t:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		tran.timeStamp.setTime((t[1:2]&amp;":"&amp;t[3:2]&amp;":"&amp;t[5:2]).Time);
		tran.computer		:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		tran.application		:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		tran.user			:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		/*tran.tranid		:=s.scanUntil(",",i).trimBlanks.replace('"','');  i:=i+1;
		if tran.tranid[1:3] = "CMI" then  // their tranids take the form of 'class,name', or '"class,name"' for CardSchema 3.1.09
			tran.tranid		:=tran.tranid&amp;"::"&amp;s.scanUntil(",",i).trimBlanks.replace('"','');  i:=i+1;
		endif;*/
		if s[i] = '"' then  // tranid is quoted
			i:=i+1;
			tran.tranid		:=s.scanUntil('"',i).trimBlanks.replace(',','::');  i:=i+2;
		else
			tran.tranid		:=s.scanUntil(',',i).trimBlanks;  i:=i+1;
			if tran.tranid[1:3] = "CMI" then  // their tranids take the form of 'class,name', or '"class,name"' for CardSchema 3.1.09
				tran.tranid	:=tran.tranid&amp;"::"&amp;s.scanUntil(",",i).trimBlanks.replace('"','');  i:=i+1;
			endif;
		endif;
		v:=inFile.fileName.toLower;
		if v.cnContains("jadestar") or v.cnContains("jblvtx") or v.cnContains("jvtx6")
		and tran.tranid.cnContains("/") then  // special for JadeStar - remove org codes
			j:=1;
			u:=tran.tranid;
			while true do
				tran.tranid:=u.scanUntil("/",j).trimBlanks; j:=j+1;
				if j = 1 then break; endif;
			endwhile;
		endif;
		if statsByClient then
//			tran.tranid		:=tran.tranid&amp;" "&amp;tran.computer;  // by client
//			tran.tranid		:=t[1:2]&amp;":"&amp;t[3:2]&amp;" "&amp;tran.tranid;  // by time by client
//			tran.tranid		:=tran.tranid&amp;" "&amp;t[1:2]&amp;":"&amp;t[3:2];  // by client by time
			tran.tranid		:=t[1:2]&amp;":"&amp;t[3:2];  // by time (per minute)
		endif;
		if tran.tranid = null then
			tran.tranid:="&lt;none&gt;";
		endif;
		tran.elapsed		:=s.scanUntil(",",i).Integer;  i:=i+1;
		if tran.elapsed = Max_Integer or tran.tranid = 'bogus' then  // CardSchema bug?
			delete tran;
			continue;
		endif;
		tran.cpu			:=s.scanUntil(",",i).Integer;  i:=i+1;
//		tran.error			:=s.scanUntil(",",i).trimBlanks;  i:=i+1;
		allTransactions.add(tran);
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="resumeNextExceptionHandler" id="1024c9d7-0f27-4e4b-860c-494e5e4efd72">
        <source>resumeNextExceptionHandler(ex:Exception):Integer;

begin
	if ex.errorCode = 1413 
	or ex.errorCode = 1035 then
		app.logMessage("Resuming next");
		ex.logSelf(app.msgLog.fileName);
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;
</source>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="versionInfoRead" id="892c90b8-20a4-4257-8bb0-dc22fa647745">
        <updating/>
        <source>versionInfoRead(path:String) updating;

vars
	s,t,baseRelease,lowest,highest:String; sa:StringArray256;
	i,j:Integer;
	f:File;
begin
	create sa transient;
	sa.clear;
	create f;
	f.usePresentationFileSystem:=true;
	f.mode:=File.Mode_Input;
	f.fileName:=path&amp;"versioninfo.txt";
	if not f.isAvailable then
		global.causeEvent(Bmk_Result, true, "File not found - wrong env name?");
		return;
	endif;
	lowest:="999999999";

	// find base release level
	while not f.endOfFile do
		s:=f.readLine;
		if s[1:8]="jade.exe" then
			i:=12;
			s.scanWhile(" ",i);
			baseRelease:=s.scanUntil(" ",i)[1:6];
//			app.logMessage("base release="&amp;baseRelease.display);
			sa.add(s[1:68]);
			if s.length &gt; 68 then
				sa.add(s[69:end]);
			endif;
			f.seek(0);
			break;
		endif;
	endwhile;

	// find lowest patch level
	while not f.endOfFile do
		s:=f.readLine;
		i:=s.pos(" "&amp;baseRelease,1)+1;
		if i=1 then continue; endif;
		s.scanWhile(" ",i);
		t:=s.scanUntil(" ",i);
		if t[1:6]=baseRelease and t[8:3] &lt;&gt; "911" and s[1:9].toLower &lt;&gt; "jadeadmin" and s[1:8].toLower &lt;&gt; "autodist" then
			if t&lt;lowest then
				lowest:=t;
				//app.logMessage("new lowest=" &amp; s);
			elseif t&gt;highest then
				highest:=t;
			endif;
		endif;
	endwhile;
	f.seek(0);
	//app.logMessage("base release=".padBlanks(25)&amp;lowest);

	// find those not on lowest patch level
	while not f.endOfFile do
		s:=f.readLine;
		if s[1:9]="karma.dll" then
			sa.add(s[1:62]);
			continue;
		endif;
		i:=s.pos(" "&amp;baseRelease,1)+1;
		if i=1 then continue; endif;
		s.scanWhile(" ",i);
		t:=s.scanUntil(" ",i);
		if i&lt;&gt;0 and (t&lt;&gt;lowest or s[1:9]="karma.dll") then
			sa.add(s[1:i-1]);
		endif;
	endwhile;
	sa.add(" ");
	sa.add("base release".padBlanks(25)&amp;lowest);
	sa.add("highest patch".padBlanks(25)&amp;highest);
	foreach s in sa do
		global.causeEvent(Bmk_Result, true, s);
	endforeach;
epilog
	delete f;
	delete sa;
end;</source>
        <Parameter name="path" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeStatsFile" id="7fbb85fb-4ab3-4377-8c7f-933e291b592e">
        <updating/>
        <source>writeStatsFile() updating;

vars
	oo:Object;
	tranStat,tranStatTotals:TranStat;
	totalCount:Integer;
	s,totalsLine:String;
begin
	if statsByClient then
		outFile.fileName:=inFile.fileName.replace(".csv","_stats_by_minute_"&amp;app.actualTimeAppServer.time.format("HHmmss")&amp;".csv");
	else
		outFile.fileName:=inFile.fileName.replace(".csv","_stats.csv");
	endif;
	
	outFile.writeLine("Transaction Id,Count,% of Tot,Errors,Avg Time,Max Time,Min Time,Tot Time");

	tranStatTotals:=allTranStats1["All Transactions"].TranStat;
	totalCount:=tranStatTotals.count;	
	foreach oo in allTranStats1 do
		tranStat:=oo.TranStat;
		s:=tranStat.key &amp;","&amp;tranStat.count.String
						&amp;","&amp;(tranStat.count / totalCount *100).roundedTo(1).String
						&amp;","&amp;tranStat.errors.String
						&amp;","&amp;(tranStat.avgElapsed / 1000).String
						&amp;","&amp;(tranStat.maxElapsed / 1000).String
						&amp;","&amp;(tranStat.minElapsed / 1000).String
						&amp;","&amp;(tranStat.totalElapsed / 1000).String;
		if tranStat = tranStatTotals then
			totalsLine:=s;
		else
			outFile.writeLine(s);
		endif;
	endforeach;
	outFile.writeLine(totalsLine);
end;</source>
    </JadeMethod>
</Class>
