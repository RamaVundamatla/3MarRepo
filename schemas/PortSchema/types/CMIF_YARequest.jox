    <JadeMethod name="isISO_Match" id="e145603b-2d1d-4ff3-8484-2132d3dfaa92">
        <source>isISO_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars
	iso		: String;
begin
	iso	:= self.isoType.trimBlanks();
	
	// Only priorities will be empty.
	if iso &lt;&gt; null and _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YARequest::isISO_Compare, iso);

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isImexStatus_Compare" id="17e92a1b-7c9c-4d20-957f-7dff42e67c30">
        <source>isImexStatus_Compare(imexStatus: Object; status: Integer): Boolean;
begin
	return imexStatus.CM_IMEXStatus.code = status;
end;</source>
