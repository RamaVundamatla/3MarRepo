    <JadeMethod name="create" id="24b06def-59b6-464b-8dd3-e966c57b2ab6">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		04 May 2010 by cnwjo3
//
// Purpose:		
//
// Parameters:	
//
// Returns:		Nothing
//
vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;

	create oper as CM_QStringContains persistent;
	self.allAllowedOperators.add(oper);	
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="57aef82f-36df-430a-8caf-85f0f8faa145">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
// --------------------------------------------------------------------------------
// Created:		04 May 2010 by cnwjo3
//
// Purpose:		
//
// Parameters:	
//
// Returns:		Nothing
//
vars

begin
	if _op.isKindOf(CM_QStringIsOneOf) then
		return QueryControl_MultiSelect;
	else
		return QueryControl_ComboBox;
	endif;
	
end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
