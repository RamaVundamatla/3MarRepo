    <JadeMethod name="cmbDestPort_excludeRow" id="e0a49f02-b52a-4ea0-aae2-ff6e7c3c694c">
        <controlMethod name="CMUI_ComboPorts::excludeRow"/>
        <methodInvocation>event</methodInvocation>
        <source>cmbDestPort_excludeRow(_comboboxObj: ComboBox input; _port :CM_Port; _lstIndex: Integer):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     02 June 2009 by concms1
// Purpose:     Par 19013
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin 
	// always allow destination for existing train
	if self.mySelectedTrain &lt;&gt; null and
		_port = self.mySelectedTrain.myDestinationPort then
		return false;	// include it
	endif;
	// don't show ports that are not rail ports
	if not _port.bIsRail then 
		return true;	// exclude it
	endif;
	
	return false;		// include it
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_comboboxObj" type="ComboBox" usage="input"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_lstIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
