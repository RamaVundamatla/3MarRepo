    <JadeMethod name="create" id="b63e4b61-ec48-4e4b-b6c2-123e67b19963">
        <updating/>
        <source>create() updating;
//-----------------------------------------------------------------------
//	Created:	28 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	self.name := SOP_TableMaintForm.Table_Master;
	self.permissionView	 := PmHMSMasterView;
	self.permissionMaint := PmHMSMasterMaint;
	self.myDataClass := HMS_Master;
end;</source>
