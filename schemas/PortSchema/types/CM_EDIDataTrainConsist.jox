    <JadeMethod name="getRealTrackedItem" id="ccc11485-4807-4394-9b55-cbc327f20824">
        <source>getRealTrackedItem(editTI: CM_EDITrackedItem): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 February 2024	navcs2	ChangeRequest 62250: EUP | FR 53824 - Transport Manifest - Multiple Manifests For a Single Wagon Need to be Possible. 

*/

vars
	terminal 	: CM_Terminal;
	trackedItem	: CM_TrackedItem;
begin
	terminal := app.myPassport.myTerminal;
	
	if terminal &lt;&gt; null then
		if editTI.isEDIPrenote then
			trackedItem := terminal.findPrenoteCargo(editTI.id, editTI.cargoType, null, editTI.getCargoGroupId());
		elseif editTI.isEDICargo then
			trackedItem := terminal.allOnsiteTIsByCargoTypeId[editTI.cargoType, editTI.id];
		endif;
	endif;
	
	return trackedItem;
epilog

end;</source>
        <Parameter name="editTI" type="CM_EDITrackedItem"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getReceiptTransportMode" id="142e1415-2553-44ce-b164-8dd13780b040">
