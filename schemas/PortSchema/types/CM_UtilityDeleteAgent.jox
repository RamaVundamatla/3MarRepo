        <source>utlDeleteInstructionIssued(_instructionType : CM_InstructionsIssued io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars

begin
	if not self.exclusiveLockObjectToDelete(_instructionType) then
	    return;
	endif;
	_instructionType.validateForDelete();
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_instructionType);
	endif;
	
	_instructionType.erase(NORMAL_ERASE);
epilog

end;</source>
