    <JadeMethod name="create" id="a1030533-b5bb-41ec-99ee-d7b679a93c35">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/

vars

