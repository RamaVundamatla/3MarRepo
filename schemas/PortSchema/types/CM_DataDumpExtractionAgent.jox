    <JadeMethod name="localExtDbaseInTransHandler" id="6c619a4c-41a6-4e65-883b-6a08bb38c38d">
        <updating/>
        <source>localExtDbaseInTransHandler(_exObj: Exception; _inTrxStateException: Boolean output) : Integer updating, protected;

	//24 Jan 2013	NDL	Par 31070
vars
	alertStr,
	errStr : String;
	
begin

	if _exObj.errorCode = 8004 then
		_inTrxStateException := true;
		
		errStr := "'beginExternalTransaction' failed" &amp; CrLf &amp;
		"Error Code: " &amp; _exObj.errorCode.String &amp; CrLf &amp;
		"Extended Error Text: " &amp; _exObj.extendedErrorText &amp; CrLf &amp;
		"Method Desc: " &amp; _exObj.currentMethodDesc.display;
		self.log(errStr);
		
		// 33033 Feb 2014 raise an alert from here as after connection failure, the exceptions are only from beginExternalTransaction and abortExternalTransaction
		//	and not the other exception handlers that do alerts
		alertStr := "'beginExternalTransaction' failed , Error Code: " &amp; _exObj.errorCode.String &amp; " Extended Error Text: " &amp; _exObj.extendedErrorText;
		self.raiseAlert(alertStr);

		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;

end;
</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_inTrxStateException" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="localExtractClassExHandler" id="d5b9de38-066f-422a-81ab-63c27ab71b9f">
        <updating/>
        <source>localExtractClassExHandler(_exObj: Exception; _transClass: CM_DataDumpTransSpecClass;
		_gotException: Boolean output) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 July 2003 by cnwsb1
//
// Purpose:		We want to abandon classes that get extract exceptions, but
//				continue with other classes (for now), so that we get as many
//				feed-back exception logging per run as possible.  This logic
//				may change when this code gets into production
// ---------------------------------------------------------------------------
vars
	errStr : String;
	transClassStr : String;
	sqlParams : String; //cnwrd1 36135 log sqlparams
begin
	if _exObj.isKindOf(LockException) then
		if self.dataDumpLockExceptionHandler(_exObj.LockException) then
			return Ex_Continue;
		endif;
	endif;
			
	_gotException := true;
	
	abortTransaction;
	
	if _transClass &lt;&gt; null then
		transClassStr := "Extract exception - abandoned extract of class " &amp;
			_transClass.myClass.getName;
	else
		transClassStr := "Bulk load error - abandoned operation ";
	endif;
	
	//cnwrd1 36135 log sqlparams
	if self.isSQLNative  then
		if self.myExternalDatabaseAgent &lt;&gt; null then
			sqlParams := CrLf &amp; " SQL Parameters : " &amp; self.myExternalDatabaseAgent.myExtractionAgent.sqlCallInfo;
		endif;
	endif;
	
	errStr := transClassStr &amp; CrLf &amp;
			"Error Code: " &amp; _exObj.errorCode.String &amp; CrLf &amp;
			"Extended Error Text: " &amp; _exObj.extendedErrorText &amp; CrLf &amp;
			"Method Desc: " &amp; _exObj.currentMethodDesc.display &amp; 
			 sqlParams; //cnwrd1 36135 log sqlparams
	self.log(errStr);
	
	if self.isExternalDatabaseExtract then
		self.myExternalDatabaseAgent.abortTrans("EDB");
	elseif self.isSQLNative  then
		if self.myExternalDatabaseAgent &lt;&gt; null then
			self.myExternalDatabaseAgent.abortTrans("SQL Native");
		endif;
	endif;
	
	self.raiseAlert(self.extractClassId);

	// Resume to the next statement in the method that armed the handler.
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass"/>
        <Parameter name="_gotException" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="localInvalidObjExHandler" id="7d3c5e98-6ef4-4ed4-992c-e146e12a9d36">
        <updating/>
        <source>localInvalidObjExHandler(_exObj: Exception; _obj: Object;
		_exceptionStr: String output; _gotException: Boolean output) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2003 by cnwsb1
//
// Purpose:		The object being extracted, or any one of the references
//				on the object, can be invalid.  In this case we want to log
//				the invalid object and move on, rather than abandoning the
//				entire class.
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
08 Nov 2012	cnwkpd1	PAR #30706 - Remove code which dereferences _obj to prevent 1239 exceptions// 11 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
// 11 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
*/

constants
	ObjectNotFound = 4;
	ObjectDeleted = 1072;
	OdbcError = 8000;	// 09 July 2014	NDL Par 33362
	StringTooLong = 1035;	//03 Sep 2015	NDL	Par 36724
vars
	oidStr : String;
	errStr : String;
	msg : String;
begin
	if _exObj.errorCode = 1228 or 
	   _exObj.errorCode = 1295 or 
	   _exObj.errorCode = 3015 or 
	   _exObj.errorCode = 3037 then
		abortTransaction;
		abortTransientTransaction;
		msg := class.name&amp;'::'&amp;method.name&amp;' SDS Exception, cant continue,'&amp;_exObj.errorCode.String&amp;' '&amp;_exObj.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		terminate;
	endif;

	_gotException := true;
	
	//03 Sep 2015	NDL	Par 36724
	if _obj &lt;&gt; null then
		oidStr := self.getOidStringForObject(_obj);
	endif;
	
	if not self.loadMode and _exObj.errorCode = StringTooLong then	//03 Sep 2015	NDL	Par 36724
		//We are in change mode and got a string too long
		_exceptionStr := "String Too long retreiving SQL data object matching " &amp; oidStr.oidStringId &amp;
				"  " &amp; _exObj.currentMethodDesc.getName;
				
		//03.May.2023 navsp1 TFS 57822
		//Additional log information is needed to investigate why the 1035 error occurs during the data extract.
		app.doDumpStack(_exObj);
		
		// Resume to the next statement in the method that armed the handler.
		return Ex_Resume_Next;
	endif;
	
	if _exObj.errorCode = ObjectNotFound or _exObj.errorCode = ObjectDeleted then
		_exceptionStr := "Invalid object, couldn't extract: " &amp; oidStr.oidStringId &amp;
				"  " &amp; _exObj.currentMethodDesc.getName;		// PAR #30706

		// Resume to the next statement in the method that armed the handler.
		return Ex_Resume_Next;
	endif;
	
	// Abort transaction only if we're not resuming to the caller
	abortTransaction;
	
	if _exObj.errorCode = OdbcError then	// 09 July 2014	NDL Par 33362
		self.doProcessOdbcErrorAlert( _exObj );	// 09 July 2014	NDL Par 33362
	else
		app.doDumpStack(_exObj);
	endif;
	
	errStr := "Exception with this object, couldn't extract: " &amp; oidStr.oidStringId &amp;
			"  " &amp; _exObj.currentMethodDesc.getName;			// PAR #30706
			
	self.log(errStr);

	// Pass the exception back to the next handler in the stack
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_exceptionStr" type="String" usage="output"/>
        <Parameter name="_gotException" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="localProtectedFeatureExHandler" id="f44223d0-a977-4a77-b1cb-3cde6283a430">
        <updating/>
        <source>localProtectedFeatureExHandler(_exObj: Exception; _transClass: CM_DataDumpTransSpecClass;
		_gotProtectedFeatureError: Boolean output) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	errStr : String;

begin
	if _exObj.errorCode = DataDumpProtectedFeature then
		// Resume_Next so that we can check for the same problem
		// on the other attributes of this class.
		_gotProtectedFeatureError := true;
		
		errStr := "Protected Feature exception - abandoned extract of class " &amp;
				_transClass.myClass.getName &amp; CrLf &amp;
				"Error Code: " &amp; _exObj.errorCode.String &amp; CrLf &amp;
				"Extended Error Text: " &amp; _exObj.extendedErrorText;
		self.log(errStr);

		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass"/>
        <Parameter name="_gotProtectedFeatureError" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="raiseAlert" id="61e858a8-371f-4c7f-a9f0-59c4a9d767a6">
        <updating/>
        <source>raiseAlert(_extractClassId : String)updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	#cnwdz2	 

*/

vars
	
begin
	if self.isSQLNative then
		if self.alertCounter &gt; self.alertLimit then
			return;
		endif;
		
		if self.alertCounter = self.alertLimit then
		    self.log(app.getErrorString1(ERR_AlertLimitReached,self.alertLimit.String)); 
		endif;
		self.alertCounter := self.alertCounter + 1;
	endif;
	inheritMethod(_extractClassId);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_extractClassId" type="String"/>
    </JadeMethod>
