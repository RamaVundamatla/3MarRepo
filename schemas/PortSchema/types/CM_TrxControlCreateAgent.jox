    <JadeMethod name="trxCreateLoggingOrganisation" id="161c90c6-5433-4420-84b4-2e4a86bdc254">
        <updating/>
        <source>trxCreateLoggingOrganisation(pProxyLogOrg:CM_LoggingOrganisation input; 
				pNewLogOrg:CM_LoggingOrganisation output;
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	self.raiseExceptionIfNull(pProxyLogOrg, 'Log Condition Code Proxy');
	pProxyLogOrg.raiseExceptionIfNotTransient(method);

	pProxyLogOrg.validateForCreate();

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create pNewLogOrg persistent;
	pNewLogOrg.setForCreate(pProxyLogOrg);
	
	if _passport.noErrors then
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(pNewLogOrg);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
