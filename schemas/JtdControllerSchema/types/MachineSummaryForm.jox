    <JadeMethod name="btnClose_click" id="5c4a173b-3471-478e-af1e-d7cd77a14581">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;

begin
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTableAsString" id="a011bc5c-4ad9-451f-b790-a585f8a325bc">
        <updating/>
        <source>getTableAsString(colGap : Integer) : String updating;

vars
	s : String;
	
begin
	// load the table contents
	self.loadTheLot;
	
	// change the CPU heading and remove the space before '(MB)' and '(%)'
	self.tblSummary.accessCell(2, 2).text := "CPU" &amp; Tab &amp; "Total(MB)" &amp;
		Tab &amp; "Free(MB)" &amp; Tab &amp; "Free(%)";
	
	// get the table contents as a string
	s := self.tblSummary.asString(2, colGap, null);
	
	// refresh the table before returning to undo any changes made
	// by this method (in case this is called when the form has been
	// shown and is visible to the user)
	self.loadTheLot;
	
	return s;
end;</source>
        <Parameter name="colGap" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="218fc8d7-c6ce-40bd-8f8c-9d1f374ddd5c">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

begin
	if keyCode = 116 then // F5
		self.loadTheLot;
		keyCode := 0;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="bc7a0b28-f2f8-4dca-a4bd-9fe1139050b4">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	self.width := 660;
	self.height := 520;
	self.loadTheLot;
	self.resizeTheLot;
	self.centreWindow;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTheLot" id="2704ec96-7e14-4470-93f2-81a6f784de78">
        <updating/>
        <source>loadTheLot() updating, protected;

vars
	tm, ta, tn, tp : Integer;
	md : MachineDescriptor;
	tbl : Table;
	tf : Real;
	
begin
	if app.mySession.myDbServerMachineDescriptor = null then
		self.lblDbServer.caption := "*** unknown ***";
	else
		self.lblDbServer.caption := app.mySession.myDbServerMachineDescriptor.name;
	endif;

	self.lblDbPath.caption := app.dbPath;

	self.lblFreeDisk.caption := app.mySession.dbServerFreeDisk.asMegabytes.roundedTo(2).String &amp; " MB";
	
	tbl := self.tblSummary;
	
	tbl.rows := tbl.fixedRows;
	tbl.accessCell(1, 6).text := ' '; // to stop merge cells
	tbl.accessCell(1, 3).text := "Memory Summary";
	tbl.accessedCell.mergeCells := Table.MergeCells_Merge;
	tbl.accessCell(2, 1).text := "Machine" &amp; Tab &amp; "CPU Type / MHz" &amp; Tab &amp; "Total (MB)" &amp; Tab &amp;
		"Free (MB)" &amp; Tab &amp; "Free (%)" &amp; Tab &amp; "Nodes" &amp; Tab &amp; "Processes";
	tbl.alignment := Table.Alignment_Center;
	tbl.accessColumn(1).alignment := Table.Alignment_Left;

	foreach md in app.mySession.allMachineDescriptors do
		tbl.addItem(md.getTableString);
		tm := tm + md.totalMemory;
		ta := ta + md.availableMemory;
		tn := tn + md.allNodeDescriptors.size;
		tp := tp + md.allProcessDescriptors.size;
	endforeach;
	
	if ta &lt; 1 or tm &lt; 1 then
		tf := 0;
	else
		tf := (ta / tm) * 100;
	endif;

	tbl.addItem("Totals" &amp; Tab &amp; Tab &amp; tm.asMegabytes.roundedTo(2).String &amp; Tab &amp;
		ta.asMegabytes.roundedTo(2).String &amp; Tab &amp; tf.roundedTo(2).String &amp; '%' &amp;
		Tab &amp; tn.String &amp; Tab &amp; tp.String);
	tbl.accessRow(tbl.rows).fontBold := true;
	tbl.accessedRow.backColor := 13103609; // pale yellow
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="49660672-7ed0-4909-abe5-496cb815b97b">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

begin
	self.resizeTheLot;
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeTheLot" id="d18fb57d-3a73-41f1-ae10-3f33dd2dfa94">
        <source>resizeTheLot() protected;

vars
	tbl : Table;
	n : Integer;
	r : Real;
	
begin
	tbl := self.tblSummary;
	
	self.btnClose.top := self.clientHeight - self.btnClose.height - 4;
	self.btnClose.left := self.clientWidth - self.btnClose.width - 4;

	r := self.lblFreeDisk.top + self.lblFreeDisk.height + 6;	
	tbl.move(4, r, self.clientWidth - 8, self.btnClose.top - r - 8);

	n := (tbl.clientWidth * 0.12).Integer;

	tbl.columnWidth[2] := (tbl.clientWidth * 0.17).Integer;
	tbl.columnWidth[1] := tbl.clientWidth - (n * 5) - tbl.columnWidth[2];
	tbl.columnWidth[3] := n;
	tbl.columnWidth[4] := n;
	tbl.columnWidth[5] := n;
	tbl.columnWidth[6] := n;
	tbl.columnWidth[7] := n;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
