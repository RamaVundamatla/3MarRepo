    <JadeMethod name="setKPIQueryParams" id="4d7c183a-ed64-499d-a7b2-35ef9a897add">
        <source>setKPIQueryParams(_kpi : CM_KPITerminalArea input);
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin

	if self.doChkCargoType then
		self.allQryCargoTypes.copy(_kpi.allQryCargoTypes);
	endif;
	
	if self.doChkContents then
		self.allQryContents.copy(_kpi.allQryContents);
	endif;
	
	if self.doChkIMEX then
		self.allQryIMEX.copy(_kpi.allQryIMEX);
	endif;
	
	if self.doChkISO then
		self.allQryISOGroups.copy(_kpi.allQryISOGroups);
	endif;
	
	if self.doChkOperator then
		self.allQryOperator.copy(_kpi.allQryOperator);
	endif;

	if self.doChkPorts then
		self.allQryPorts.copy(_kpi.allQryPorts);
	endif;
	
	if self.doChkVoyages then
		self.allQryVoyages.copy(_kpi.allQryVoyages);
	endif;
end;</source>
        <Parameter name="_kpi" type="CM_KPITerminalArea" usage="input"/>
    </JadeMethod>
</Class>
