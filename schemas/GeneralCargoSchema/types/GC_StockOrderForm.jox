    <JadeMethod name="cmbLineType_click" id="4fd48b94-043e-4b4d-a8cb-2c4ae90a01e8">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLineType_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     05 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_DataTable;
	tmpControl		: Control;
	theRow 			: Integer;
	tmpCell 		: JadeTableCell;
	lineType		: Integer;
begin

	tbl	:= self.tblDataDetail;
	theRow  := tbl.row;

	lineType := combobox.itemData[combobox.listIndex];

	//find out what table text is to see if combo has changed.  
	tmpCell := tbl.accessCell(theRow, self.colQuantityId);
	tmpControl := tmpCell.cellControl;

	if tmpControl = null then
		self.setupColumnQtyIdForLineType(lineType, theRow);
	elseif (lineType = StockOrderLine_Product and tmpControl.isKindOf(ComboBox)) or
		   (lineType = StockOrderLine_TI and tmpControl.isKindOf(TextBox)) then
		self.setupColumnQtyIdForLineType(lineType, theRow);
	endif;	

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
