    <JadeMethod name="getTableColumFilters" id="d1d13d80-3efb-4adb-92bd-b7b9b2b86b5e">
        <updating/>
        <source>getTableColumFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	self.allColumnFilters.cloneFiltersForTable( _table, _allFilterColumns );
	
	

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="61dee710-5215-40e2-9347-87602536df16">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 16/03/2015	cnwmh5	Transient Leaks
vars
	xmlString	: String;

	totalWidth,
	usedWidth,
	qInWidth,
	qOutWidth,
	freeWidth,
	projectedWidth,
	planInWidth,
	planOutWidth,
	priorityWidth,
	deckingWidth,
	seqWidth,
	ifNoLocFoundWidth,
	overstowRuleWidth,
	allowOthersWidth : Integer;
	attrNameArray : StringArray;
	attrName : String;
	column : Integer;
	colWidth : Integer;
begin
	xmlString	:=	inheritMethod() &amp;
					self.tblData.getXmlStrForColumns(true) &amp;
					global.formatAsXML(self.XML_DATA_HEIGHT, self.dkbData.height.String);
	
	self.calculateTitleWidths(self.tblData,totalWidth,usedWidth,qInWidth,qOutWidth,freeWidth,projectedWidth,planInWidth,planOutWidth,priorityWidth,deckingWidth,seqWidth,ifNoLocFoundWidth,overstowRuleWidth,allowOthersWidth);

	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_totalWidth,totalWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_usedWidth,usedWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_qInWidth,qInWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_qOutWidth,qOutWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_freeWidth,freeWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_projectedWidth,projectedWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_planInWidth,planInWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_planOutWidth,planOutWidth.String);
	
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_priorityWidth,priorityWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_deckingWidth,deckingWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_seqWidth,seqWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_ifNoLocFoundWidth,ifNoLocFoundWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_overstowRuleWidth,overstowRuleWidth.String);
	xmlString := xmlString &amp; global.formatAsXML(XML_YAMTable_allowOthersWidth,allowOthersWidth.String);
	
	//05 Jan 2012	NDL	Par 28889
	create attrNameArray transient;
	self.tblData.getGenFilterableColumns(attrNameArray);
	foreach attrName in attrNameArray do	
		column := self.tblData.getColumnByRowName(attrName);
		if column &gt; 0 then
			colWidth := self.tblData.accessColumn(column).width;
			if colWidth &gt; 0 then
				xmlString := xmlString &amp; global.formatAsXML("YAMTable_" &amp; attrName &amp; "Width", colWidth.String);
			endif;
		endif;	
	endforeach;
	
	return xmlString;
	
epilog
	delete attrNameArray;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="a20c745b-cdd1-42e3-81d3-f60175362ee6">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// --------------------------------------------------------------------------------
// Created:		02 April 2009 by cnwdad1
//
// Purpose:		Standard method to restore window settings when the receiver is opened.
//
// Parameters:	_userWindow - A reference to the User's Window settings object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xmlString	: String;
	dataHeight	: Integer;
	
begin
	inheritMethod(_userWindow);
	
	xmlString	:=	_userWindow.xmlInfo;
	dataHeight	:=	xmlString.cnEcGetTagValueOfName(self.XML_DATA_HEIGHT).Integer;
	
	if dataHeight = 0 then
		dataHeight	:=	(self.height * 0.75).Integer;
	endif;
	
	dkbData.height	:=	dataHeight;
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="0f6fa07c-40e8-473d-aa80-2bf9d9b457f5">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
09 September 2008	consw1	Initial creation
10 June 2013		cnwdap1	PAR #31721 Imperial Measurements in What Ifs
*/

vars

begin

	if keyCode = CMUI_Key_F3 then
		self.doShowSearch( true );
		return;
	endif;
	
	inheritMethod(keyCode, shift);
	
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
