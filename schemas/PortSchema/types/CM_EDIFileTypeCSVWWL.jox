<Class name="CM_EDIFileTypeCSVWWL" id="ad65a1fb-5ef9-416c-8f0b-b93a5428ca1f">
    <superclass name="CM_EDIFileTypeCSV"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="b7608b5b-509c-4f6e-bd87-5e75f1de7ac9">
        <updating/>
        <source>create() updating;

vars

begin
	self.name := "WWL CSV Tranship";
	self.type := EDIFileType_CSVWWL;
end;</source>
    </JadeMethod>
    <JadeMethod name="createEDIData" id="ea45f9f5-e98d-4d05-b8b2-9ccfd70edecd">
        <source>createEDIData(_transient: Boolean): CM_EDIData;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
vars
	bayPlan	: CM_EDIDataTranship;
begin

	if _transient then
		create bayPlan transient;
	else
		create bayPlan persistent;
	endif;

	return bayPlan;
end;
</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="extractFile" id="208a7d04-0e44-45dc-a2f5-e3142cbe566c">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile input; _number: Integer; _recipient: CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars
	operator	: CM_Operator;
	ediData		: CM_EDIDataTranship;
	ediTI		: CM_EDITrackedItem;
	i			: Integer;
	str : String;
begin
	ediData := _ediFile.ediData.CM_EDIDataTranship;
	
	operator := self.getMyOperator();

	str := str &amp; "Feeder Vsl name,"&amp;str&amp;"," &amp; CrLf;
	str := str &amp; "ETA,"&amp;str&amp;"," &amp; CrLf;

	foreach ediTI in ediData.allEDITrackedItems do
		i := i + 1;
		str := str &amp; self.extractTI(ediTI, i, operator); 
	endforeach;
	_ediFile.setRawDataString(str);
	_ediFile.writeFile();
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="extractTI" id="81c63514-054e-4f97-b7c2-750bb137a2c6">
        <updating/>
        <source>extractTI(_ediTI : CM_EDITrackedItem input; _number : Integer; _operator : CM_Operator) : String updating, protected;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars
	tmpStr	: String;
	str		: String;
	ediTI	: CM_EDITranshipTI;
begin
//,Car Vin #
//,APMU2701271
	if _ediTI.isKindOf(CM_EDITranshipTI) then
		ediTI := _ediTI.CM_EDITranshipTI;
	else
		return null;
	endif;
	if _number = 1 then
		tmpStr := 'Cargo ID';
	endif;
	str :=	tmpStr&amp;","&amp;ediTI.id &amp; CrLf;
	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="0a821afc-d125-40ea-b446-23ab15e2be67">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010

vars

begin
	_ediDataClass := CM_EDIDataTranship;
	_dataType := EDIDataType_Tranship;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getBOLDetails" id="e110c6d6-82f2-4a0c-99f0-8d014525aca6">
        <source>getBOLDetails(_ediTI : CM_EDIBayPlanTI; _carNum, _bolWeight : Integer) : String protected;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------

vars
	str : String;
begin
	str := _ediTI.rawEDIData;
	return str;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDIBayPlanTI"/>
        <Parameter name="_carNum" type="Integer"/>
        <Parameter name="_bolWeight" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
