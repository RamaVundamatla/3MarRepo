Purpose:		To avoid the reimplementation message.
Parameters:		
Return Value:	

Date				Who		Reason
24 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	// Without this empty method stub a warning message is produced in CM_ListViewForm::initForm
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initFilterTable" id="8b5bf3ef-a657-4cad-854c-5494b469afd1">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef	: EntTableDef;
	
begin

	if self.filterTableDefName = null then
		self.btnShowSearchTV.visible := false;	//cnwvu1
		self.btnShowSearchTV.enabled := false;	//cnwvu1
		return;
	endif;
	
//	entTableDef := app.myCmuiRoot.allEntTableDefs[self.filterTableDefName];
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[self.filterTableDefName];
	
	if entTableDef &lt;&gt; null then
		
		tblSearch.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		tblSearch.adjustHeight(200);
				self.btnShowSearchTV.visible := true;
		self.btnShowSearchTV.enabled := true;	//cnwvu1
		self.myCurrentTableItem.initFilterTableControls();
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef not found (' &amp; self.filterTableDefName &amp; ')');
		self.btnShowSearchTV.visible := false;	//cnwvu1
		self.btnShowSearchTV.enabled := false;	//cnwvu1
	endif;

epilog
	cmbTable.setFocus();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="c34af455-5faa-4fce-9456-ef86f6d4b3f9">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01 Sep 2009	cnwkpd1		PAR #20398 - Add Booking Reference cross reference functionality
//							Changed positioning of Advanced button
// 19 Apr 2012	cnwrs1	par 29516
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
// 13/05/2015	cnwdap1	PAR #36206 Graphical Representation of Hazard Class and Special Stow
// 03/06/2016	cnwdap1	TFS #1949 VGM Process Requirements - Allocations
// 04/08/2016   cnwma1  TFS #2365 Error on selecting Hazard Classes or Special Stow from the drop-down
// 05/12/2016	cnwdap1	TFS 3039 SNO Empty Container Pool Management
// 19/12/2017	cnwer1	TFS 8211 removed old drawing code
// 25/09/2018	cnwma1	ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
// 04/06/2021	navmd1	TFS 51320 - Add filter to Sys/Terminal Admin forms
// ---------------------------------------------------------------------------
vars
	
begin
	//epr was annoyed with the opening of another form before this one now clicking terminal config in navigator only opens
	//this form
	if self.modeSystemOrTerminal = Mode_TerminalConfig and self.myTerminal &lt;&gt; null then
		self.amInitialisingWithObject:=true;
		self.myCurrentObject:=self.myTerminal;
		//self.modeSystemOrTerminal := Mode_System;
		self.useTblData					:= false;
		self.useThumbArea				:= true;
		self.isThumbnailVisible			:= true;
		if self.myCurrentObject &lt;&gt; null  then	
			self.armNotesForObject(self.myCurrentObject);
		endif;
	endif;
	
	if self.amInitialisingWithObject then
		if self.myCurrentObject.isKindOf(CM_Terminal) then
			self.setTableItemSingle(SOPTM_Terminal);
		else
			self.setAllTblItems(Mode_All);	// need to call again to get all items for all modes
			self.setCurrentTableItem(self.getTableItemForClass(self.myCurrentObject.class));
			if self.myCurrentTableItem = null then
				//could be one of two problems, either no permission to access table item
				app.raiseCMException1(NoPermission, 'access this option (' &amp; self.myCurrentObject.class.name &amp; ')', null, null);
				return;
			endif;
	
			if self.myCurrentTableItem.isSystemItem then
				self.modeSystemOrTerminal := Mode_System;  
				self.setAllTblItems(Mode_System); // 04/08/2016 cnwma1 TFS #2365
			else
				self.modeSystemOrTerminal := Mode_Terminal;
				self.setAllTblItems(Mode_Terminal); // 04/08/2016 cnwma1 TFS #2365
			endif;
			// need to redo this as setting modeSystemOrTerminal purges collection
			self.setCurrentTableItem(self.getTableItemForClass(self.myCurrentObject.class));
		endif;
		self.allowAdd	 := false;
		self.allowDelete := false;
		
	elseif self.amInitialisingWithMaintItem and self.myInitSOPMaintItemClass &lt;&gt; null then
	
		self.setTableItemSingle(self.myInitSOPMaintItemClass);	
		self.allowAdd	 := true;
		self.allowDelete := true;

	else	
		self.setAllTblItems(self.modeSystemOrTerminal);
		self.allowTblDataSearch	:= true;		
	endif;

	// reset this here as if showWithObject this gets set to false earlier

	if self.allTableItems.isEmpty then
		//no permission to access any table item
		app.raiseCMException1(NoPermission, 'access any Terminal Admin tables', null, null);
		return;
	endif;
	
	self.useTblThumb := false;
	self.frmDetailsBottom.visible := false;
	self.allowPrint  := true;									
	self.btnPrintTV.caption := 'Print current list';			
	self.btnPrintTV.bubbleHelp := self.btnPrintTV.caption;		
	//self.btnExportCSVTV.bubbleHelp	:= self.btnExportCSVTV.caption;
	self.btnExportCSVTV.bubbleHelp	:= 'Export as CSV';
	self.btnExportCSVTV.caption		:= 'Export current list';
	
	self.allowExportCSV	:= true;
	self.btnExportCSVTV.bubbleHelp	:= 'Export as CSV';
	self.btnExportCSVTV.caption		:= 'Export current list';
	self.useNumRowsShown	:= true;

	txtName.readOnly	:= true;
	optAllow.enabled	:= false;
	optAllow.transparent := true;
	optDisallow.transparent := true;
	optDisallow.enabled	:= false;
	self.mulSelect1.setSelected(null);
	self.mulSelect2.setSelected(null);	
	self.mulSelect1.userInputEnabled := false;
	self.mulSelect2.userInputEnabled := false;	
	self.mulSelect3.userInputEnabled := false;
	self.mulSelect6.userInputEnabled := false;
	self.mulSelect7.userInputEnabled := false;	// PAR 21905 CCMS MES 1008 - PHB
	self.mulSelect8.userInputEnabled := false;
	self.mulSelect41.userInputEnabled := false;		
	self.mulSelect42.userInputEnabled := false;
	self.mulSelIn21.userInputEnabled := false;
    self.mulAlign1.userInputEnabled	:= false;
	// setup opt buttons
	optAllow.width		:= 200;
	optDisallow.width	:= 200;
	
	self.btnTimeAdd.enabled		:=	false;
	self.btnTimeRemove.enabled	:=	false;
	self.txtTimeBox1.enabled	:=	false;
	self.txtTimeInterval.enabled := false;	//19 Apr 2012	cnwrs1	Par 29516
	self.txtTimeIntStart.enabled := false;
	self.txtTimeIntEnd.enabled := false;

	self.cmbDummy.automaticCellControl			:=	true;
	self.cmbToDoTaskPTI.automaticCellControl	:=	true;
	self.cmbToDoTaskRep.automaticCellControl	:=	true;
	self.cmbToDoTaskWash.automaticCellControl	:=	true;	
	self.cmbCraneOpSR.automaticCellControl	:=	true;	 //25.09.2018 cnwma1 TFS #41080
	self.cmbToDoTask.automaticCellControl	:=	true;	//28 Jun 2011	NDL	Par 27003
	self.cmbGridAreaSel.automaticCellControl	:=	true;	//20 Jul 2011	NDL	Par 27890
	self.cmbRailToDo.automaticCellControl	:=	true;
	self.cmbTraceLevel.automaticCellControl		:=	true;
	self.cmbStopCharging.automaticCellControl	:=	true;
	self.cmbConsignee.automaticCellControl		:=	true;
	self.cmbSelectorQuery.automaticCellControl	:=	true;	// ccms 1593 21 May 2008	cnwvu1
	self.cmb30ForReports.automaticCellControl	:=	true;	// ccms 1029 21 May 2008	cnwvu1
	self.cmb45ForReports.automaticCellControl	:=	true;	// ccms 1029 21 May 2008	cnwvu1
	self.cmb53ForReports.automaticCellControl	:=	true;	// ccms 1029 21 May 2008	cnwvu1
	self.cmbQFCamTrans.automaticCellControl		:=	true;	// PAR 20994 Oct 2009	cnwvu1
	self.cmbDelayTypeGrp.automaticCellControl	:= true;	// par 27755 June 2011	cnwjre1
	self.cmbSnapshotDefin.automaticCellControl	:= true;	// CCMS HAT 2205 Feb 2013
	self.cmbStopsTable.automaticCellControl	:=	true;		// cnwmc5 - 18 July 2014 - CCMS 2353 PEN
	self.cmbToDoTaskRem.automaticCellControl := true;		// TFS #1949
	self.cmbMTPoolParty.automaticCellControl := true;			// TFS 3039
	self.cmbToDoTaskLashing.automaticCellControl:=true;  //jlier1 TFS 54700 2/9/22
	
	self.initTblData(tblData1);

	// setup mulSelect
	self.mulSelect1.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.mulSelect2.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.mulSelect3.multiSelect 	:= ListBox.MultiSelect_Extended; // CCMS 1051 AKB2002JUNE
	self.mulSelect41.multiSelect 	:= ListBox.MultiSelect_Extended; // CCMS 1051 AKB2002JUNE
	self.mulSelect42.multiSelect 	:= ListBox.MultiSelect_Extended; // CCMS 1051 AKB2002JUNE
	self.mulSelect8.multiSelect := ListBox.MultiSelect_Extended;
	self.mulAlign1.multiSelect 		:= ListBox.MultiSelect_Extended; // CCMS 1051 AKB2002JUNE
	self.mulSelIn21.multiSelect 	:= ListBox.MultiSelect_Extended; // CCMS 1535 AER2007MAY
	self.timelistBox1.multiSelect := ListBox.MultiSelect_Extended;	// 19 Apr 2012	cnwrs1 par xxxx
	self.timelistBox1.stretchHeight := true; // CCMS 1051 AKB2002JUNE
	self.timelistBox1.stretchWidth 	:= true; // CCMS 1051 AKB2002JUNE

	self.initComboTable();
	if self.myCurrentTableItem = null then
		self.initShtMultiSelect();
	endif;
	self.initShtFolder1();						//+cnwml2 PAR23715 SFW CCMS1131

	// setup fldInput
	self.fldInput.stretchToParent := true;
	self.fldInput.useSheetBackColors := true;
	self.fldInput.setDefaultSheetBackColors();
	self.fldInput.initSheetBackColors(); 	
//-----------------------------------------------
// Commented combos loaded in their respective showThumbNail method
//-----------------------------------------------

	if self.modeSystemOrTerminal = Mode_System then		
		self.setCaption(app.getErrorString(System_Administration));		
	elseif self.modeSystemOrTerminal = Mode_TerminalConfig then
		self.setCaption(app.getErrorString(Terminal_Configuration));
	elseif self.modeSystemOrTerminal = Mode_Terminal then
		self.setCaption(app.getErrorString(Terminal_Administration));
	endif;
	

//	self.txtCamFirstTime.text := time.time.String;
//	self.txtCamLastTime.text := time.time.String;
	//must set this
	self.cmbCamGroup.myTerminal := self.myTerminal;
	
	// setup tblInput1
	tblInput1.warningMethod := 'entTableWarning';
	tblInput2.warningMethod := 'entTableWarning';
	
	if self.useTblData then
		btnSubTerms.visible			:=	false;
		btnITTC.visible  			:=	false;
		btnAutoId.visible := false;//	29 July 2014	NDL	Par 34660
		btnAutoVoyageConfig.visible := false; // ### TFS BUG 65730 22AUG2024 NAVAB1
	else
		lblTable.visible			:=	false;
		cmbTable.visible			:=	false;
		//lblFilterBox.visible		:=	false;	//25/06/2024	navkc1 CR 64823 Task 64824
		//txtFilterBox.visible		:=	false;	//25/06/2024	navkc1 CR 64823 Task 64824
		chkShowNotAvail.visible		:=	false;
		self.allowPrint				:=	false;
		self.allowExportCSV			:=	false;
		self.allowAdd				:=	false;
		self.allowDelete			:=	false;		
		self.allowSearch 			:=	false;
		self.btnShowSearchTV.visible:=	false;
	endif;
	
	self.cmbChkRep1.automaticCellControl		:=	true;
	self.cmbChkRep2.automaticCellControl		:=	true;
	self.cmbSubTermType.automaticCellControl	:=	true;
	self.btnAdvanced.move((self.clientWidth - btnAdvanced.width - 6), cmbTable.top, btnAdvanced.width, btnAdvanced.height); // PAR #20398
	
	if self.modeSystemOrTerminal = Mode_System then	
		self.loadFonts();								// PAR #36206
		self.loadChars(self.cmbFont.text);				// PAR #36206
	endif;
	
	self.tblData.userInputEnabled := false;	// 27/04/2010 cnwar2 #23911
	
	if self.myCurrentTableItem = null then
		self.doResize();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="1ae327d1-a48f-4c26-a086-cf60db7a8bbd">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2006 by cnwdad1
//
// Purpose:		Initializes any window/control features that have to be restored to
//				their former state when the window was last closed.
//
// Parameters:	_userWindow - A reference to the User Window object on which the
//					previours settings were stored (in XML format).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlTag		: String;
	controlValue	: String;
	
begin
	inheritMethod(_userWindow);

	controlTag	:=	_userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_NotAvailCheckBox &amp; ' name="' &amp; self.XMLTag_NotAvailCheckBox &amp; '"');
	
	if controlTag &lt;&gt; null then
		controlValue	:=	controlTag.cnEcGetTagValueOfName(self.XMLTab_Boolean);
		
		if controlValue &lt;&gt; null then
			chkShowNotAvail.cnEcSet(controlValue.Boolean);
		endif;
	endif;
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initShtFolder1" id="b8b8be8b-ad2e-48d2-84c1-9ace3da34481">
        <source>initShtFolder1();
//26 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
constants
	LeftMargin		: Integer = 10;
	TopMargin		: Integer = 10;
	VerticalSpacing	: Integer = 5;
vars
	currentTop : Integer;
begin
	currentTop := TopMargin;
	self.lblTitleSht1.visible := false;
	if self.shtFolder1.visible then
	
		/*if self.lblTitleSht1.visible then
			self.lblTitleSht1.top		:= currentTop;
			self.lblTitleSht1.left		:= LeftMargin;
			
			//self.lblTitleSht1.top		:= TopMargin;
			//self.lblTitleSht1.left		:= self.lblTitleSht1.left + self.lblTitleSht1.width + 5;
			
			currentTop := currentTop + self.lblTitleSht1.height.Integer + VerticalSpacing;
			
			self.tblFldSheet1.top := currentTop;
			self.tblFldSheet1.left := LeftMargin;
		endif;*/

		self.tblFldSheet1.move(LeftMargin, currentTop, self.tblFldSheet1.parent.width - 10, self.tblFldSheet1.parent.height - currentTop - 10);
		self.tblFldSheet1.cnEcResizeContents();	
		

	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="c58c10c1-b937-403b-aeef-eda2208953cf">
        <updating/>
        <source>initShtMultiSelect() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
/* Changes

Date		Name	TFS#			Description
============================================================================
18/05/2011	cnwcs5	CCMS SCT 2058 
					/ par 27460 	user defined special charac	ters
19 Apr 2012	cnwrs1	par 29516
16/07/2012	cnwcs5	par 29601 		log excluded transactions
12 Nov 2018	jlgsl4	TFS 39345 		SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
15 Mar 2019	jlgka1  TFS 41641		SSL - X12 322 Equipment ID Check.
19 Mar 2019	jlgsl4	TFS 41786 		SNO - output DAM segment for Standard Coarri/Codeco
24 Apr 2019 jlgka1	TFS 43785		STWR - Add Produce Codeco for Non Structured Voyage Flag.
28 May 2019	jlgsl4	TFS 43706		PEN - output Enhanced Genset segment details
26 Jun 2019	jlgka1	TFS 44737 		PNL Hapag CODECO on Weighing.
11 mar 2020	jlgdap1	TFS 48785		SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726		GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181		GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142 		AAT - Add NAD+MS to Standard COARRI SMDG213
07 Jul 2023	jlika1	TFS 58636		EUP - Goods Receipt - Move Transaction area triggers
27 Aug 2023	jlizm1	TFS 59551 		Kiosk Additional Question
01 Aug 2025 navsp1  JIRA-35530 Solution Implementation - COPRAR Trailer Support
============================================================================*/
constants
	LeftMargin		: Integer = 10;
	TopMargin		: Integer = 10;
	VerticalSpacing	: Integer = 5;
vars
	currentTop			: Real;
	date				: Date;	
	stdCheckboxWidth,
	stdCheckboxHeight	: Real;				// par 27460 cnwcs5
	control				: Control;			// cnwcs5 July 2012
	parent				: Window;			// cnwcs5 July 2012
	lblControl : Control;	//31 Jan 2018	NDL	TFS 36466
	txtControl : Control;	//31 Jan 2018	NDL	TFS 36466
	chkControl : CheckBox;
begin
	if self.myCurrentTableItem = null then
		self.shtMultiSelect1.visible 	:= false;
		self.shtMultiSelect2.visible 	:= false;
		self.shtMultiSelect3.visible 	:= false; 	// CCMS 1051 AKB2002JUNE
		self.shtMultiAlign.visible 		:= false;
		self.shtMultiSelect4.visible 	:= false; 
		self.shtMultiSelect5.visible 	:= false; 
		self.shtSingleSelect1.visible 	:= false;
		self.shtSingleSelect3.visible 	:= false;
		self.sheetAddress.visible 		:= false;
		return;
	endif;

	self.myCurrentTableItem.initShtMultiSelect();
	
	if (self.shtMultiSelect1.visible = false) and
	   (self.shtMultiSelect2.visible = false) and 
	   (self.shtMultiSelect3.visible = false) and
	   (self.shtMultiSelect4.visible = false) and
	   (self.shtMultiSelect5.visible = false) and
	   (self.shtMultiAlign.visible 	= false) and
	   (self.shtSingleSelect1.visible = false) and
	   (self.shtSingleSelect3.visible = false) and
	   (self.sheetAddress.visible = false) then
		return;
	endif;

	currentTop := TopMargin;
	
	if (self.shtMultiSelect1.visible = true) then
		if self.lblName.visible then
			if self.lblEmailAddress.visible then
				//controls dealt with in the tableItem method
				currentTop := self.lblEmailAddress.top + self.lblEmailAddress.height + VerticalSpacing;
			else
				self.lblName.top	:= currentTop;
				self.lblName.left	:= LeftMargin;
				
				self.txtName.top	:= TopMargin;
				self.txtName.left	:= self.lblName.left + self.lblName.width + 5;
				
				currentTop := currentTop + self.lblName.height + VerticalSpacing;
			endif;
		endif;
	
		if self.optAllow.visible then
			self.optAllow.top	:= currentTop;
			self.optAllow.left	:= LeftMargin;
			currentTop 			:= currentTop + self.optAllow.height + VerticalSpacing;
		
			self.optDisallow.top	:= currentTop;
			self.optDisallow.left	:= LeftMargin;
			
			currentTop := currentTop + self.optDisallow.height + VerticalSpacing;
		endif;
		//========
		control := self.btnSetDefault1;
		
		if control.visible then
			control.move (LeftMargin, currentTop, 170, 30);
			
			currentTop := currentTop + 30 + VerticalSpacing;
		endif;
		//=========
		control := self.mulSelect1;
		parent 	:= control.parent;
		
		control.move(LeftMargin, currentTop, parent.width - 10, parent.height - currentTop - 10);
		
		self.mulSelect1.cnEcResizeContents();	
	endif;
	
	currentTop := TopMargin;
	
	// TRANSACTIONS Sheet
	if (self.shtMultiSelect2.visible = true) then
		control := self.lblName2;
		
		if control.visible then
			control.move (LeftMargin + 5, currentTop, 120, control.height);		
		endif;
		
		if self.cmbCargoBOLType.visible then
			self.cmbCargoBOLType.top	:= currentTop;
			self.cmbCargoBOLType.left	:= lblName2.left + lblName2.width + 5;
			self.cmbCargoBOLType.width 	:= 190;
			
			currentTop := currentTop + self.cmbCargoBOLType.height + VerticalSpacing;
			
		elseif self.lblName2.visible then
			currentTop := currentTop + self.lblName2.height + VerticalSpacing;
		endif;
		
		if self.lblName3.visible then
			self.lblName3.top := currentTop;
			self.lblName3.left := LeftMargin + 5;
			self.lblName3.width := 120;		
		endif;
		
		if self.btnTransactionFilter.visible then
			self.btnTransactionFilter.top	:= currentTop;			
			if self.cmbCargoBOLType.visible then
				self.btnTransactionFilter.left := self.cmbCargoBOLType.left;
			else
				btnTransactionFilter.left	:= self.lblName3.left + self.lblName3.width + 5;
			endif;
			self.btnTransactionFilter.width := 190;
			
			currentTop := currentTop + self.btnTransactionFilter.height + VerticalSpacing;
		endif;
		
		if self.cmbCargoType2.visible then
			self.cmbCargoType2.top	:= currentTop;
			//Align cargo type combo boxes on the cargo/BOL Type sheet - 7.4.2 changes 19/04/2006
			if self.cmbCargoBOLType.visible then
				self.cmbCargoType2.left := self.cmbCargoBOLType.left;
			else
				cmbCargoType2.left	:= self.lblName3.left + self.lblName3.width + 5;
			endif;
			self.cmbCargoType2.width := 190;
			
			currentTop := currentTop + self.cmbCargoType2.height + VerticalSpacing;
		elseif self.lblName3.visible then
			currentTop := currentTop + self.lblName3.height + VerticalSpacing;
		endif;

		if self.lblName4.visible then
			self.lblName4.top 	:= currentTop;
			self.lblName4.left 	:= LeftMargin + 5;
			self.lblName4.width := 120;		
		endif;
		
		if self.cmbBOLType.visible then
			self.cmbBOLType.top	:= currentTop;
			//Align cargo type combo boxes on the cargo/BOL Type sheet - 7.4.2 changes 19/04/2006
			if self.cmbCargoBOLType.visible then
				self.cmbBOLType.left 	:= self.cmbCargoBOLType.left;
			else
				self.cmbBOLType.left	:= self.lblName4.left + self.lblName4.width + 5;
			endif;
			
			self.cmbBOLType.width := 190;
			
			currentTop := currentTop + self.cmbBOLType.height + VerticalSpacing;
		elseif self.lblName4.visible then
			currentTop := currentTop + self.lblName4.height + VerticalSpacing;
		endif;
		
		// TFS 56747 start - default cargo group combo and label
		if self.lblName5.visible then
			self.lblName5.top 	:= currentTop;
			self.lblName5.left 	:= LeftMargin + 5;
			self.lblName5.width := 120;		
		endif;
		
		if self.cmbCargoGroup.visible then
			self.cmbCargoGroup.top	:= currentTop;
			//Align cargo type combo boxes on the cargo/BOL Type sheet - 7.4.2 changes 19/04/2006
			if self.cmbCargoBOLType.visible then
				self.cmbCargoGroup.left := self.cmbCargoBOLType.left;
			else
				self.cmbCargoGroup.left	:= self.lblName5.left + self.lblName5.width + 5;
			endif;
			
			self.cmbCargoGroup.width := 190;
			
			currentTop := currentTop + self.cmbCargoGroup.height + VerticalSpacing;
		elseif self.lblName5.visible then
			currentTop := currentTop + self.lblName5.height + VerticalSpacing;
		endif;
		// TFS 56747 end
		
        if self.lblName6.visible then                                                           //JIRA-35530
            self.lblName6.top 	    := TopMargin-5;                                             //JIRA-35530
			self.lblName6.left 	    := LeftMargin + 400;                                        //JIRA-35530
			self.lblName6.width 	:= 170;                                                     //JIRA-35530
			self.lblName6.height 	:= 30;                                                      //JIRA-35530
        endif;                                                                                  //JIRA-35530
        
        if self.cmbTrailerCargoType.visible then                                                //JIRA-35530
            self.cmbTrailerCargoType.top	:= TopMargin;	                                    //JIRA-35530		
			self.cmbTrailerCargoType.left	:= self.lblName6.left + self.lblName6.width + 5;	//JIRA-35530		
			self.cmbTrailerCargoType.width  := 190;                                             //JIRA-35530
        endif;                                                                                  //JIRA-35530
        
		if self.btnSetDefault2.visible then
			self.btnSetDefault2.top 	:= currentTop;
			self.btnSetDefault2.left 	:= LeftMargin;
			self.btnSetDefault2.width 	:= 170;
			self.btnSetDefault2.height 	:= 30;
			
			currentTop := currentTop + self.btnSetDefault1.height + VerticalSpacing;
		endif;
		// Available/Selected Transactions
		control := self.mulSelect2;
		parent := control.parent;
		
		control.move(LeftMargin, currentTop, parent.width - 10, parent.height - currentTop - 10);
		
		control.cnEcResizeContents();	
	endif;
	
	currentTop := TopMargin;
	
	// CCMS 1051 AKB2002JUNE from here
	// COARRI Import Ports
	if (self.shtMultiSelect3.visible = true) then
		control := self.mulSelect3;
		parent 	:= control.parent;
		
		control.move (LeftMargin, currentTop, parent.width - 10, parent.height - currentTop - 10);
		
		control.cnEcResizeContents();
	endif;	
	// SECONDARY QUEUES Sheet
	if (self.shtMultiAlign.visible = true) then
		control := self.mulAlign1;
		parent 	:= control.parent;
		
		control.move (LeftMargin, currentTop, parent.width - 10, parent.height - currentTop - 10);
		
		control.cnEcResizeContents();
	endif;	
	
	// CCMS 1051 AKB2002JUNE to here
	currentTop := TopMargin;
	
	if (self.shtMultiSelect4.visible = true) then
		if (self.lblName1.visible) and (comboBox1.visible) then		
			self.lblName1.top	:= currentTop;
			self.lblName1.left	:= LeftMargin;
			self.lblName1.width := (self.mulSelect41.parent.width/2).Integer - 10;
			
			self.comboBox1.top 		:= currentTop - 4;
			self.comboBox1.left 	:= (self.mulSelect41.parent.width/2).Integer + 25;
			self.comboBox1.width	:= 100;
			
			currentTop := currentTop + self.lblName1.height + VerticalSpacing;
		endif;
		
		//07 Dec 2012	NDL	Par 24669
		if (self.optTypes.visible) then		
			self.optTypes.top	:= currentTop;
			self.optTypes.left	:= LeftMargin;
			
			self.optGroups.top	:= currentTop;
			
			currentTop := currentTop + self.optTypes.height + VerticalSpacing;
		endif;
		
		// Available/Selected Operators
		self.mulSelect41.top 	:= currentTop;
		self.mulSelect41.left	:= LeftMargin;
		self.mulSelect41.width 	:= self.mulSelect41.parent.width - 10;
		self.mulSelect41.height := ((self.mulSelect41.parent.height - self.mulSelect41.top)/2).Integer -20;
		
		self.mulSelect41.cnEcResizeContents();
		
		currentTop := self.mulSelect41.top + self.mulSelect41.height + VerticalSpacing;
		// Available/Selected Consignees
		self.mulSelect42.top 	:= currentTop;
		self.mulSelect42.left	:= LeftMargin;
		self.mulSelect42.width 	:= self.mulSelect42.parent.width - 10;
		self.mulSelect42.height := self.mulSelect42.parent.height - self.mulSelect42.top -20 ;
		
		self.mulSelect42.cnEcResizeContents();
	endif;	

	currentTop := TopMargin;
	
	// CCMS 1051 AKB2002JUNE from here
	// SCHEDULED TIMES Sheet
	if (self.shtMultiSelect5.visible = true) then
		// rs mar 2006 par8977
		self.lblTime1.move(10, currentTop, 90, 20);
		self.lblTime2.move(175, currentTop, 20, 20);
		self.txtTimeBox1.move(120, currentTop, 45, 20);

		currentTop := currentTop + 20 + VerticalSpacing;

		self.frmInterval.move(10, currentTop, (self.txtTimeBox1.parent.width/2).Integer-5, (20 + VerticalSpacing)*2+10);
		self.lblTime3.move(5, 5, 90, 20);
		self.txtTimeInterval.move(110, 5, 45, 20);	//19 Apr 2012	cnwrs1	par 29516	
		self.lblTime4.move(5, self.txtTimeInterval.height + VerticalSpacing*2, 40, 20);
		self.txtTimeIntStart.move(110, self.txtTimeInterval.height + VerticalSpacing*2, 45, 20);	
		self.lblTime5.move(160, self.txtTimeInterval.height + VerticalSpacing*2, 20, 20);
		self.txtTimeIntEnd.move(175, self.txtTimeInterval.height + VerticalSpacing*2, 45, 20);	

		currentTop := currentTop + frmInterval.height + VerticalSpacing*2;

		self.btnTimeAdd.move((self.txtTimeBox1.parent.width /2).Integer - 70 - LeftMargin, currentTop, 80, 25);
		currentTop := currentTop + self.btnTimeAdd.height + VerticalSpacing;
		
		self.btnTimeRemove.move((self.txtTimeBox1.parent.width /2).Integer - 70 - LeftMargin, currentTop, 80, 25);
		currentTop := currentTop + self.btnTimeRemove.height + 10;

		self.frmAdhoc.caption := "Adhoc Protocol Run";
		self.frmAdhoc.move(10, currentTop, (self.txtTimeBox1.parent.width/2).Integer-10, (self.txtTimeBox1.parent.height)-(currentTop+40));
		
		self.lblStart.move(5,25,170,15);
		self.lblStart.caption := "Start Date and Time";
		
		self.txtDateStart.move(5,40,80,20);
		self.txtTimeStart.move(90,40,80,20);
		
		self.lblEnd.move(5,70,170,15);
		self.lblEnd.caption := "End Date and Time";
		
		self.txtDateEnd.move(5,85,80,20);
		self.txtTimeEnd.move(90,85,80,20);
		self.txtDateStart.setDate(date - 1); 
		self.txtDateEnd.setDate(date);

		self.txtTimeStart.setTime("01:00".asTimeJMT()); 
		self.txtTimeEnd.setTime("01:00".asTimeJMT());
		
		self.chkLogExcluded.left	:= 5;		// par 29601 July 2012
		self.chkLogExcluded.top		:= 115;		// par 29601 July 2012
		
		self.btnRunAdhoc.move(self.frmAdhoc.width - 100, 130, 80, 20);
		
		self.frmAdhoc.height	:=	self.btnRunAdhoc.top + self.btnRunAdhoc.height + 20;
		
		currentTop := TopMargin;
		
		self.timelistBox1.top 		:= currentTop;
		self.timelistBox1.left		:= (self.timelistBox1.parent.width/2).Integer + LeftMargin;
		self.timelistBox1.width 	:= (self.timelistBox1.parent.width/2).Integer - 30;
		self.timelistBox1.height 	:= self.timelistBox1.parent.height - self.timelistBox1.top - 20;
	endif;
	
	self.initShtSingleSelect1();
	self.initShtSingleSelect3();
	
	currentTop := TopMargin;
	
	// SPECIAL PROTOCOL SETTINGS Sheet
	if (self.shtSingleSelect2.visible = true) then
		stdCheckboxHeight	:= self.chkNullVoyage.height;	// par 27460 cnwcs5
		stdCheckboxWidth	:= self.shtSingleSelect2.width;	// par 27460 cnwcs5
		
		//31 Jan 2018	NDL	TFS 36466 - remove the display of this one...
//		self.chkNonPlanned.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight-5);
		
// PAR 33644		currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;

// PAR 33644		self.chkNonWorked.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight-5);	
	
//		currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;

		self.chkNullVoyage.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight-5);
		
		currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;

		self.chkPandoRInUnPck.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight-5);
		
		currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;

		self.chkPandoSntPack.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
		
		currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;
		
		self.chkPonOperator.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
		
		currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;
		
		//31 Jan 2018	NDL	TFS 36466
		if self.myCurrentTableItem.isKindOf( SOPTM_CamProtocol ) then
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkReprocessChangeID.name ).Control;
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;
			
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkHLCSel_Suppress.name ).Control;
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;
			
		else
			self.chkFullsOnly.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;
			
			self.chkMTsOnly.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;
			
		endif;

		self.chkMSCForNZPOE.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
		
		currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	
		
		self.chkDaysLookBack.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
		
		currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;

		self.chkTempFormat.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
		
		currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;
		
		self.chkEDIXlatCtn.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
		
		currentTop	:= currentTop + stdCheckboxHeight + VerticalSpacing;

		self.chkIncludeChild.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);

		currentTop	:= currentTop + stdCheckboxHeight + VerticalSpacing;

		self.chkSendCarrier.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);

		currentTop	:= currentTop + stdCheckboxHeight + VerticalSpacing;
		
		self.chkUseCarrierRef.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
		
		currentTop	:= currentTop + stdCheckboxHeight + VerticalSpacing;
		
		self.chkCliRefBooking.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);		// cnwrd par 34369
	
		currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;
		
		//31 Jan 2018	NDL	TFS 36466
		if self.myCurrentTableItem.isKindOf( SOPTM_CamProtocol ) then	
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkIncludeChassis.name ).Control;
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	
		endif;
		
		//08 Sep 2015	NDL	Par 36876
		self.txtDelayMins.move (LeftMargin, currentTop, stdCheckboxHeight, stdCheckboxHeight);
		self.txtDelayMins.alignment := 2;
		self.lblDelayMins.move (LeftMargin + self.txtDelayMins.width + 3, currentTop, stdCheckboxWidth, stdCheckboxHeight);
		currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;
		
		//31 Jan 2018	NDL	TFS 36466
		if self.myCurrentTableItem.isKindOf( SOPTM_CamProtocol ) then	
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkCOARRIBGM.name ).Control;
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	
			chkControl := control.CheckBox;
			chkControl.setEventMapping("change", SOP_TableMaintForm::doChkboxChange.name);
			
			//26Jan2023 navsp1 TFS 56282
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkCOARRIBGM4446.name ).Control;
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	
			chkControl := control.CheckBox;
			chkControl.setEventMapping("change", SOP_TableMaintForm::doChkboxChange.name);
			
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkVERMASDOC.name ).Control;
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	
			
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkVERMASNAD.name ).Control;
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	
			
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkPackUnpackStatusChange.name ).Control;
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	
			
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkIncludeRestowShifter.name ).Control;
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	
			
			lblControl := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::lblBGMRepCode.name ).Control;
			txtControl := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::txtBGMRepCode.name ).Control;
			lblControl.move (LeftMargin, currentTop + 1, 120, 18);
			txtControl.move (LeftMargin + lblControl.width, currentTop, 40, 18);
			currentTop := currentTop + txtControl.height + VerticalSpacing;	
			
			lblControl := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::lblBGMDamCode.name ).Control;
			txtControl := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::txtBGMDamCode.name ).Control;
			lblControl.move (LeftMargin, currentTop + 1, 120, 18);
			txtControl.move (LeftMargin + lblControl.width, currentTop, 40, 18);
			currentTop := currentTop + txtControl.height + VerticalSpacing;	
			
			// jlgka1 TFS 44737 --&gt;
			lblControl := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::lblVGMBGMMsgCode.name ).Control;
			txtControl := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::txtVGMBGMMsgCode.name ).Control;
			lblControl.move (LeftMargin, currentTop + 1, 220, 18);
			txtControl.move (LeftMargin + lblControl.width, currentTop, 40, 18);
			currentTop := currentTop + txtControl.height + VerticalSpacing;	
			// jlgka1 TFS 44737 &lt;--
			
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkIncludeExtraVGM.name ).Control;
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	
			
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkVERMASVer10.name ).Control;
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	

			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkCoarri95BLocPDS.name ).Control;	// TFS 39345
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);	// TFS 39345
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	// TFS 39345
			
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkProduceDAMSegment.name ).Control; // TFS 41786
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);	// TFS 41786
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	// TFS 41786
			
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkEnhancedGensetInfo.name ).Control; // --&gt; TFS 43706
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;	// &lt;-- TFS 43706		
			
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkTShipImports.name ).Control; 	// TFS 48785
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);									// TFS 48785
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;												// TFS 48785
			
			//26 Jan 2021	NDL	TFS 50708
			control := self.myCurrentTableItem.getPropertyValue( SOPTM_CamProtocol::chkIncludeRFFBM162.name ).Control; 	
			control.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);									
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;												
			
			control := self.myCurrentTableItem.getPropertyValue(SOPTM_CamProtocol::chkIncludeLOC7InterTerm.name).Control;	// TFS 50726
			control.move(LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);										// TFS 50726
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;													// TFS 50726															
			
			//jlgka1 TFS 41641 --&gt;			
			self.chkRelaxedIdChecking.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;
			//jlgka1 TFS 41641 &lt;--
			
			//jlgka1 TFS 43785 --&gt;			
			self.chkUseCodecoNonStruc.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;
			//jlgka1 TFS 43785 &lt;--
			
			self.chkDGSDetailsInGroup14.move (LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);	//JIRA-20814
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;									//JIRA-20814
			
			//jlika1 TFS 53181 --&gt;
			control := self.myCurrentTableItem.getPropertyValue(SOPTM_CamProtocol::chkIsCustomsProtocol.name).Control;		
			control.move(LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);										
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;													
			//jlika1 TFS 53181 &lt;--
			
			control := self.myCurrentTableItem.getPropertyValue(SOPTM_CamProtocol::chkIncludeNADMSForSMDG213.name).Control;	// TFS 54142
			control.move(LeftMargin, currentTop, stdCheckboxWidth, stdCheckboxHeight);										// TFS 54142
			currentTop := currentTop + stdCheckboxHeight + VerticalSpacing;													// TFS 54142
		endif;				
		
	endif;
end;</source>
