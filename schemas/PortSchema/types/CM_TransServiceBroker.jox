    <JadeMethod name="getInvoiceLineDescForResource" id="b2b81b3f-3937-4ce3-8980-7d796ae89885">
        <source>getInvoiceLineDescForResource(_aSBController: CMIF_ServiceBroker input; resourceUsage: CM_ResourceTypeUsage);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars
	tmpDebtor : CM_Debtor;
	aDM : CM_DebtorMap;
begin

	// ### CHECK SPECIAL MAPPINGS FOR DEBTOR
	if not self.allDebtorMapsByDebtor.isEmpty then
		tmpDebtor := self.getDebtorForTransaction(_aSBController).CM_Debtor;
		if  tmpDebtor &lt;&gt; null then
			aDM := self.allDebtorMapsByDebtor[tmpDebtor.name];		
			if aDM &lt;&gt; null then
				aDM.getInvLineDescForResourceUsage(_aSBController,resourceUsage);
				return;
			endif;
		endif;
	endif;
	
	self.myChildQuantityMap.getInvLineDescForResourceUsage(_aSBController,resourceUsage);

epilog

end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
        <Parameter name="resourceUsage" type="CM_ResourceTypeUsage"/>
    </JadeMethod>
