    <JadeMethod name="utlCreateWagonContainer" id="7d739157-78ad-45d3-b2f4-49cf6ad83b1e">
        <source>utlCreateWagonContainer(pNewWagon : CM_Wagon;lWagonPosition : CMIF_TIWagonPosition input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lNumContainer, lNumTIs	: Integer;
	lContainer				: CM_TrackedItem;
	lController		 : CM_LocationsController;
	lPos : Integer;
	
begin

/*	lContainer := lWagonPosition.myTrackedItem;
	lPos := lWagonPosition.position;
	lController := pNewWagon.allLocationsControllersArray[lPos];
	lController.CM_WagonController.setController(lContainer, lWagonPosition.hasTwistLocks, 
										lWagonPosition.twistLocksAreUp, lWagonPosition.available, 
										 _passport); */
										 
	//14 Oct 2014	NDL	Par 35040
	lPos := lWagonPosition.position;
	lController := pNewWagon.allLocationsControllersArray[lPos];
	foreach lContainer in lWagonPosition.allTrackedItems do
		lController.CM_WagonController.setController(lContainer, lWagonPosition.hasTwistLocks, 
											lWagonPosition.twistLocksAreUp, lWagonPosition.available, 
											 _passport);
	endforeach;

end;</source>
        <Parameter name="pNewWagon" type="CM_Wagon"/>
        <Parameter name="lWagonPosition" type="CMIF_TIWagonPosition" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateWagonFromCMIF" id="a493d7b3-e3a7-4381-a1e2-b5d1dfabb596">
        <source>utlCreateWagonFromCMIF(	_wagonController : CMIF_WagonUpdateController input;
						_realWagon : CM_Wagon output; 
						_isValidate : Boolean;
						_isInitialise : Boolean;
						_passport : CM_Passport input);
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
//28/07/2010	cnwdad1		PAR #25120, added parameter for calling "initialiseActivity".

begin
	if _isInitialise then
		self.initialiseActivity();
	endif;
	
	app.setContinueCMExceptions(true);
	app.myValCA.valWagonController(_wagonController, _passport);
	
	if not self.checkValidationWithPassport(_passport) or _isValidate then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	//_wagonController.actionForCreate(_realWagon, _passport); //- cnwmd1, CCMS 1067, Par 19919
	_wagonController.actionForCreate(_realWagon, _passport, self.myCreateAuditAgent); //+ cnwmd1, CCMS 1067, Par 19919
end;</source>
