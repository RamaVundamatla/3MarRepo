    <JadeMethod name="exceptionHandler_click" id="0e43080e-daa6-4fa9-a178-e69b4d4fe6be">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>exceptionHandler_click(checkbox: CheckBox input) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	value	: Boolean;

begin

    value := not checkbox.value;
    app.setPassBackExceptions(value, value);
//    app.setPassBackExceptions(false, true);

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDBPath" id="9ffded60-96fa-4bde-bf4c-6fc5b4cd5071">
        <source>getDBPath() : String;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
begin
	return "DB Path - " &amp; app.dbPath;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lblWebLinkBlog_click" id="77f4ca02-905c-4b2a-8064-a9f2963dc646">
        <controlMethod name="Label::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblWebLinkBlog_click(label: Label input) updating;
/*
Purpose:			
Date		Who		Reason
19 Apr 2013	cnwab1	Initial creation
10 Oct 2016	cnwkpd1	TFS JMT 2805 - JADE 7.1.08 upgrade

*/


vars
	result			: Integer;

begin
	app.mousePointer := MousePointer_HourGlass;
	result := call _shellExecute(null, 'open', 'https://www.jadelogistics.com/master-terminal-dev-blog/', null,null, 1);
	if result &lt; 32 then
		app.msgBox('Unable to open browser (' &amp; result.String &amp; ')', 'Warning',MsgBox_Exclamation_Mark_Icon);
	endif;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lblWebLinkInter_click" id="69a5416d-bde0-4371-a65f-6191d79fedb6">
        <controlMethod name="Label::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblWebLinkInter_click(label: Label input) updating;
/*
Purpose:			
Date		Who		Reason
12 Jan 2016	cnwab1	Initial creation
10 Oct 2016	cnwkpd1	TFS JMT 2805 - JADE 7.1.08 upgrade
*/

vars

	result			: Integer;

begin
	app.mousePointer := MousePointer_HourGlass;
	result := call _shellExecute(null, 'open', 'https://interchange.jadelogistics.com/', null,null, 1);
	if result &lt; 32 then
		app.msgBox('Unable to open browser (' &amp; result.String &amp; ')', 'Warning',MsgBox_Exclamation_Mark_Icon);
	endif;

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lblWebLink_click" id="c75ead1d-1680-4d60-99a2-3b9fada4097e">
        <controlMethod name="Label::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblWebLink_click(label: Label input) updating;
// ---------------------------------------------------------------------------
// Created:  June  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/*

Date		Who		Reason
06 Sep 2012	cnwkpd1	PAR #30306 - New graphics for 8.1.2
10 Oct 2016	cnwkpd1	TFS JMT 2805 - JADE 7.1.08 upgrade
11 Oct 2021 jlier1 TFS 51963 
	
*/

vars
	result			: Integer;
	url	 			: String;
begin
	//epr TFS 48656 21/2/19

	url:='http://www.jadelogistics.com';
	
	
	app.mousePointer := MousePointer_HourGlass;
	result := call _shellExecute(null, 'open', url, null,null, 1);
	if result &lt; 32 then
		app.msgBox('Unable to open browser (' &amp; result.String &amp; ')', 'Warning',MsgBox_Exclamation_Mark_Icon);
	endif;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="legalLink_click" id="8ff4d76a-eba9-4f12-a9a7-64cd2fcfd1fc">
        <controlMethod name="Label::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>legalLink_click(label: Label input) updating;

vars

begin

	app.msgBox(app.getCopyrightNotice, "Copyright Notice", MsgBox_OK_Only + MsgBox_Information_Icon);

end;
</source>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="08e7ba08-434b-404f-8107-fd2ec340c3d6">
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Date		Who		Reason
30 May 2013	cnwkpd1	Make DB path visible to all
18 Sep 2015	cnwkpd1	Add release build date
23 Jun 2016	cnwkpd1	Add System timezone	display
23 Sep 2021 navmd1	Show whether we're running ANSI or Unicode

*/

vars
	lDate : Date;
	platform : String;
	
begin
	if app.isSpecial then
		label7.foreColor := Red;
	endif;
	
	if app.isUnicode then
		platform := "UNICODE";
	else
		platform := "ANSI";
	endif;

	self.caption := "About " &amp; app.niceName;
	self.centreWindow;
	//epr TFS 42569 15/5/19
	label1.caption := app.myRoot.getSystemModeDesc &amp;  " - Version " &amp; app.myRoot.getVersionAndPatchLevelDisplay;
	label2.caption := "Build " &amp; app.getJMTReleaseExtractTime.asStringJMT();
	label3.caption := app.niceName;
	label3.fontBold := true;
	if app.getMyUser &lt;&gt; null then
		label4.caption := "User Name: " &amp; app.getMyUser.userName.trimBlanks;
	endif;
	label5.caption := app.getCopyrightLine; //"Copyright Jade Software Corporation Limited " &amp; lDate.year.String ;
	label6.caption := "All Rights Reserved";
	label7.caption := "Jade " &amp; app.getSystemVersion &amp; " " &amp; platform;
	label7A.caption := 'Locale ' &amp; app.getCurrentLocaleString() &amp; ', ' &amp; app.systemTimeZoneID;

	lblDBPath.caption := self.getDBPath;
	//epr TFS 48656 21/2/19
	self.lblWebLinkBlog.visible:=false;
	self.lblWebLinkInter.visible:=false;
	
    if app.passBackAllExceptions then
        exceptionHandler.value := false;//true;
    else
        exceptionHandler.value := true;//false;
    endif;

end;</source>
    </JadeMethod>
</GUIClass>
