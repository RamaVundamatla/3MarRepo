    <JadeMethod name="setForUpdate" id="5a6be153-c206-49ab-93cd-f9c5144ab553">
        <updating/>
        <source>setForUpdate(_pxy : CM_LogScalingHdr) updating;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfTransient(method);

	self.bolNumber		:= _pxy.bolNumber;
	self.inputDateTime	:= _pxy.inputDateTime;
	self.operatorCode	:= _pxy.operatorCode;
	self.scalerCode		:= _pxy.scalerCode;
	
	
	self.myTerminal		:= _pxy.myTerminal;

	// Now create the real dtl records
	self.createDtls(_pxy);
	
end;</source>
        <Parameter name="_pxy" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a42b0f6f-4165-40d4-a004-165af8bf7898">
        <updating/>
        <source>setProxy(_number, _operatorCode, _scalerCode : String; _inputDateTime : TimeStamp; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.bolNumber		:= _number;
	self.inputDateTime	:= _inputDateTime;
	self.operatorCode	:= _operatorCode;
	self.scalerCode		:= _scalerCode;
	self.myTerminal		:= _terminal;
	
end;</source>
        <Parameter name="_number" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_scalerCode" type="String"/>
        <Parameter name="_inputDateTime" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setThumbnailStr" id="41b5f2cd-a732-41d4-a642-b95551611390">
        <updating/>
        <source>setThumbnailStr(_thumbnailArray : HugeStringArray input) updating;
// -----------------------------------------------------------------------------
// Created:		28 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	ticketDetail : CM_LogScalingDtl;
	strTerm ,
	detailStr	: String;
begin
	_thumbnailArray.add('Docket: ' &amp; Tab &amp; self.bolNumber.String);
	
	strTerm := app.getTerminologyAlternate(app.myRoot.allBOLTypes[BOLType_Log], self.myTerminal, 
													CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier');

	_thumbnailArray.add(strTerm  &amp; ': ' &amp; Tab &amp; self.operatorCode);
	_thumbnailArray.add('Entered: ' &amp; Tab &amp; self.systemToLocalTime(self.inputDateTime).String);	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
	_thumbnailArray.add(Tab &amp; 'Log ID.' &amp; Tab &amp; 'Min Sed' &amp; Tab &amp; 'Max SED' &amp; Tab &amp; 'Condition');
					
	foreach ticketDetail in self.allLogScalingDtls do
		detailStr :=	Tab &amp; ticketDetail.logID &amp; Tab &amp;
						ticketDetail.minSED.String &amp; Tab &amp;
						ticketDetail.maxSED.String &amp; Tab &amp;
						ticketDetail.conditionCode.padBlanks(9) &amp; Tab &amp; 
						ticketDetail.scalerCode;
		_thumbnailArray.add(detailStr);
	endforeach;				

end;</source>
        <Parameter name="_thumbnailArray" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDtls" id="d0332bad-d4a6-4802-8973-9a750ef02b62">
        <source>validateDtls() protected;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	dtl 		: CM_LogScalingDtl;
	extra		: CM_LogScalingExtra;
	idsArray	: StringArray;
	tmpID		: String;
	tmpTI		: CM_TrackedItem;
	
begin

	create idsArray transient;
	
	foreach dtl in self.allLogScalingDtls do
		idsArray.add(dtl.logID);
		dtl.validate();
	endforeach;
	
	self.myTerminal.validateOnsiteTrackedItemIDs(TI_CargoType_Log, idsArray, null, true, true);
	
	foreach extra in self.allLogScalingExtra do
		extra.validate();
	endforeach;

epilog
	delete idsArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
