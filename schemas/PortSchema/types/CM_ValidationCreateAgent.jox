    <JadeMethod name="valPreNotes" id="b9146b09-393b-4751-81b8-db3dee5ee302">
        <updating/>
        <source>valPreNotes(_intFaceArray : CMIF_TIObjectArray; _passport : CM_Passport input) updating;
/*

Purpose:			Validate PreNotes - code removed from trxCreate

Parameters:			

Return Value:		


Date				Who		Reason
19 February 2010	conkc1	Initial creation

*/
vars

	itemObj		: CMIF_TIObject;

begin
// cnwdad1 23/02/20089 - PAR #18927. Added this validation here, ahead of Trx state.
	foreach itemObj in _intFaceArray do
		if itemObj.isKindOf(CMIF_PreNote) then
// cnwdad1 30/04/2009 - CCMS 1735.
			if app.isSubTerminalsOn(itemObj.myTerminal) then
				if itemObj.mySubTerminal = null then
					itemObj.setSubTerminalDefault();
				endif;
			endif;
			
			itemObj.validateForCreate(_passport);		//Also does the sub items
			
			if _passport.allErrors.size &gt; 100 then
				app.setContinueCMExceptions(false);  // dh 10/7/2008 par 17254 added this option for performance
			else
				app.setContinueCMExceptions(true);
			endif;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Item is not a preNote (' &amp; itemObj.String &amp; ')');
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_intFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
