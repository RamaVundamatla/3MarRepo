    <JadeMethod name="createQuickCargo" id="62d92fcc-532b-4abe-96df-2c8768e5f2a3">
        <updating/>
        <source>createQuickCargo(_slots : CM_LCSet; _is40 : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     05 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 29/06/2017		cnwdap1			TFS 4492 SNO VERMAS Changes
// ---------------------------------------------------------------------------

vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	tmpID : String;
	lcs : CM_LCArray;
	subT : CM_SubTerminal;
begin

 
//	slot := "2286.619775".asOid.CM_SlotController;
	aVoy	:= self;
	aTerm := aVoy.myTerminal;

	//lets make cargo
	
	passport := app.myPassport;
	passport.setMyTerminal(aTerm);
	passport.setWarningsIgnored(true);
	passport.setWarningsAcknowledged(true);
	cargoType	:= app.myRoot.allCargoTypesById[1];
	state := TI_STATE_ONSHIP;

	
	create moveController transient;
	create lcs transient;
	
	foreach slot in _slots discreteLock do : outerloop
		moveController.setMyToPrimaryLocation(slot);
		while true do // NAVAB1 added this so that TIs are created if only get warnings.
			tmpID := self.getNextQuickCargoID(cargoType.id);
			lcs.clear();
		
		
		
			pxyTI := aTerm.createTI(cargoType, true);
			pxyTI.zSetPxyTerminal(aTerm);

			pxyTI.setCargoType(cargoType.id);
			pxyTI.setMyOperator(self.myOperator);
			pxyTI.setCommodity("GENL");
			pxyTI.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
			pxyTI.setMyVoyage(aVoy, passport);
			pxyTI.changeState(state, passport);
			pxyTI.setWeight(4000, null,passport);
			
			pxyTI.setTotalWeightAndCertified(4000, 0, 0, true, null, app.myPassport);
			//pxyTI.setWeightCertifiedName("ISHERWOOD VGM CONSULTANTS", null, app.myPassport);		// TFS 4492
			//pxyTI.setWeightCertifiedReference("ALISON VERMAS", null, app.myPassport);				// TFS 4492
			pxyTI.setMyVGMDetails(	"ALISON VERMAS", "ISHERWOOD VGM CONSULTANTS",					// TFS 4492
									null, null, null, null, null, null, 							// TFS 4492
									null, null, null, null, null, null	);							// TFS 4492
			
			
			
			pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
			pxyTI.zSetPxyDischargePort(aTerm.getConfig(PortDestCode).String);
			if _is40 then
				pxyTI.changeISOType("4200", null, app.myPassport);
				
				if slot.isKindOf(CM_SlotController)
				and slot.CM_SlotController.myAftSlot &lt;&gt; null then
					lcs.add(slot);
					lcs.add(slot.CM_SlotController.myAftSlot);
					moveController.updateAllToLocations(lcs);
				endif;
			else
				pxyTI.changeISOType("2200", null, app.myPassport);
			endif;
			if app.isSubTerminalsOn(self.myTerminal) then
				subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																		0,	
																		TI_IMEX_STATUS_IMPORT,
																		"GENL",
																		true); 
				pxyTI.setSubTerminal(subT,null);
			endif;
			pxyTI.zSetPxyId(tmpID);
			passport.setWarningsIgnored(true);
			passport.setWarningsAcknowledged(true);
			app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport); // this deletes the pxyTI
			
			if passport.hasErrors then
				break outerloop;
			endif;
			if app.myPassport.trxCompletedOK then
				break;
			else

				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
			
		endwhile;
	endforeach;


epilog

	delete moveController;
	delete lcs;
end;</source>
        <Parameter name="_slots" type="CM_LCSet"/>
        <Parameter name="_is40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoShipLC" id="9b6a974d-3564-45cf-a5db-9a16ae49b4fd">
        <updating/>
        <source>createQuickCargoShipLC(_numItems : Integer; _cargoType : CM_CargoType; _lc : CM_LocationsController) updating;
/*
Purpose:			
Date		Who			Reason
MARCH 2014	CNWAB1		Initial creation
31/08/2015	cnwdap1		PAR #36766 CCMS SFW 1334 New _lc parameter
*/


vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;

	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	tmpID : String;
	subT : CM_SubTerminal;
	idx : Integer;
	commCode : String;
begin
	aTerm := self.myTerminal;

 
	//lets make cargo
	passport := app.myPassport;
	passport.setMyTerminal(aTerm);
	if _cargoType = null then
		cargoType	:= aTerm.getFirstNonSystemCargoType().CM_CargoType;
	else
		cargoType := _cargoType;
	endif;
	
	if not cargoType.allCommodities.isEmpty() and not cargoType.abbreviation = "CONT" then
		commCode := cargoType.allCommodities.first.code;
	else
		commCode := "GENL";
	endif;
	state := TI_STATE_NORMAL;

	create moveController transient;
	
	if _lc &lt;&gt; null then													// PAR #36766
		moveController.setMyToPrimaryLocation(_lc);						// PAR #36766
	else																// PAR #36766
		moveController.setMyToPrimaryLocation(self.myShipBlockStack);
	endif;																// PAR #36766
	
	foreach idx in 1 to _numItems do
		tmpID := self.getNextQuickCargoID(cargoType.id);
		
		pxyTI := aTerm.createTI(cargoType, true);
		pxyTI.zSetPxyTerminal(aTerm);

		pxyTI.setCargoType(cargoType.id);
		pxyTI.setMyProduct(cargoType.allProducts.first);
		pxyTI.setMyOperator(self.myOperator);
		pxyTI.setCommodity(commCode);
		pxyTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
		pxyTI.setMyVoyage(self, passport);
		pxyTI.changeState(state, passport);
		pxyTI.setWeight(12999, null,passport);
		pxyTI.setTotalWeight(12999, null,passport);
		pxyTI.setMyTotalVolume(1767);	
		pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);
		pxyTI.zSetPxyDischargePort(aTerm.getConfig(PortDestCode).String);
		if app.isSubTerminalsOn(self.myTerminal) then
			subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																	0,	
																	TI_IMEX_STATUS_IMPORT,
																	commCode,
																	true); 
			pxyTI.setSubTerminal(subT,null);
		endif;
		pxyTI.zSetPxyId(tmpID);
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport); // this deletes the pxyTI
	

	

	endforeach;

epilog

	delete moveController;

end;</source>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
