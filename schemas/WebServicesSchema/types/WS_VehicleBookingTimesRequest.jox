    <JadeMethod name="getType" id="fa60b161-bd61-4870-8159-9011521f8128">
        <source>getType():CM_VehicleBookingTimeSlotType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation	Par 35008
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars

	cm_Type : CM_VehicleBookingTimeSlotType;
	
begin

	//cm_Type := self.typeFilter.asOid.CM_VehicleBookingTimeSlotType;		//12.08.2022 navtnr20 52451
	cm_Type := app.myPassport.getObjectOfTypeFromOid(self.typeFilter,CM_VehicleBookingTimeSlotType).CM_VehicleBookingTimeSlotType;		//12.08.2022 navtnr20 52451
	return cm_Type;

epilog

end;</source>
        <ReturnType type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
    <JadeMethod name="getVehicle" id="7a6a696e-8be3-4882-99a7-43d20a1a245d">
        <source>getVehicle(_driver : CM_DriverDetails):CM_Vehicle;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393
20 May 2021 navma1  ChangeRequest 51051: PRP - WebPortal VBS - Driver and Vehicle fields rework
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars

	cm_vehicle : CM_Vehicle;

begin

	//cm_vehicle := self.vehicleFilter.asOid.CM_Vehicle;		//12.08.2022 navtnr20 52451
	cm_vehicle := app.myPassport.getObjectOfTypeFromOid(self.vehicleFilter,CM_Vehicle).CM_Vehicle;		//12.08.2022 navtnr20 52451
	if cm_vehicle = null then  // 20.05.2021 navma1 #51051
		if _driver &lt;&gt; null then
			cm_vehicle 	   := app.myPassport.myTerminal.vehicles[self.vehicleFilter.toUpper, null]; // 20.05.2021 navma1 #51051
			if  cm_vehicle &lt;&gt; null and not _driver.allVehicleMachines.includes(cm_vehicle) then
				return null;
			endif;
		endif;
	endif;
	
	return cm_vehicle;

epilog

end;</source>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
</Class>
