    <JadeMethod name="getDisplayStringForAttribute" id="b64c9d5c-1a12-4085-bb1f-b6ad56fe293c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if _attrName = ETRow_HsCode then
		return self.code.String;
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f8d93232-a6dd-4669-a4b7-5626622e9981">
        <updating/>
        <source>setForCreate(_proxyDutyDocHSCode : CM_DutyDocHSCode) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	_proxyDutyDocHSCode.raiseExceptionIfNotTransient(method);
	
	self.myDutyDocRoot := _proxyDutyDocHSCode.myDutyDocRoot;
	self.setForUpdate(_proxyDutyDocHSCode);
epilog

end;</source>
        <Parameter name="_proxyDutyDocHSCode" type="CM_DutyDocHSCode"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="79cc452c-8b54-467c-952d-aca3fab750fb">
        <updating/>
        <source>setForUpdate(_proxyDutyDocHSCode : CM_DutyDocHSCode) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.code				:= _proxyDutyDocHSCode.code;
	self.longDescription 	:= _proxyDutyDocHSCode.longDescription;
	self.shortDescription 	:= _proxyDutyDocHSCode.shortDescription;
	self.dutyType			:= _proxyDutyDocHSCode.dutyType;
	self.dutyRate			:= _proxyDutyDocHSCode.dutyRate;
	self.dutyExempt			:= _proxyDutyDocHSCode.dutyExempt;
	self.priceCargo			:= _proxyDutyDocHSCode.priceCargo;
	self.chemicalCargo		:= _proxyDutyDocHSCode.chemicalCargo;
	self.nuclearCargo		:= _proxyDutyDocHSCode.nuclearCargo;
epilog

end;</source>
        <Parameter name="_proxyDutyDocHSCode" type="CM_DutyDocHSCode"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="bd14d480-4227-4b61-a43b-ab88bdabea45">
        <updating/>
        <source>setProxy(	_code : Integer64;
			_description, 
			_shortDesc, 
			_dutyType : String;
			_dutyRate : Decimal;
			_dutyExempt,
			_priceCargo,
			_chemicalCargo,
			_nuclearCargo : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.code				:= _code;
	self.longDescription 	:= _description;
	self.shortDescription 	:= _shortDesc[1:256];
	self.dutyType			:= _dutyType;
	self.dutyRate			:= _dutyRate;
	self.dutyExempt			:= _dutyExempt;
	self.priceCargo			:= _priceCargo;
	self.chemicalCargo		:= _chemicalCargo;
	self.nuclearCargo		:= _nuclearCargo;
	self.myDutyDocRoot 		:= app.myDutyDocRoot;

epilog

end;</source>
        <Parameter name="_code" type="Integer64"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_shortDesc" type="String"/>
        <Parameter name="_dutyType" type="String"/>
        <Parameter name="_dutyRate" type="Decimal"/>
        <Parameter name="_dutyExempt" type="Boolean"/>
        <Parameter name="_priceCargo" type="Boolean"/>
        <Parameter name="_chemicalCargo" type="Boolean"/>
        <Parameter name="_nuclearCargo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="15a461db-96f3-4624-bc7e-505f03580090">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if app.myDutyDocRoot.allDutyDocHSCodes[self.code] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
		return;
	endif;
	
	self.validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="df33ee16-6abf-4a46-b72b-06f277b5b609">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="860fcefb-0a0b-4285-91bd-a84ae8a6ac48">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Code), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Code), null, null); // cnwdb2	PAR 35364
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
