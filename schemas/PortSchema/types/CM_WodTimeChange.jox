    <JadeMethod name="pxyCreateUpdateProxy" id="fa0da095-7d2e-4c7c-aee5-cfc45d80d4ea">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

	pxy : SelfType;
	completedOK : Boolean;

begin

	pxy := inheritMethod();
	
	pxy.myHMSResourceUsedToUpdate := self.myHMSResourceUsedToUpdate;
	pxy.myWorkOrderToUpdate := self.myWorkOrderToUpdate;
	
	completedOK := true;
	return pxy;

epilog

	if not completedOK then
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
