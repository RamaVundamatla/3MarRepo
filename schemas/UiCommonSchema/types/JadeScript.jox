    <JadeMethod name="ndl_Seal_Discrepancy_Report" id="bccd3baa-08d6-49d5-9163-7cf0fb7295d3">
        <source>ndl_Seal_Discrepancy_Report();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2010	cnwndl1	Initial creation	Par 25608 Testing.

*/

vars
	queryAgent : CM_QueryAgentFilter;
	reportFilter : CMQF_SealCheckTransactions;
	num : Integer;
begin

	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal("2351.41".asOid.CM_Terminal);	// DP terminal

	create reportFilter transient;
	reportFilter.allTerminals.add( "2351.41".asOid.CM_Terminal );
//	reportFilter.startDate := "01 Sep 2010".Date;
	reportFilter.endDate := "29 Sep 2010".Date;
//	reportFilter.sealType := "OPER";
//	reportFilter.unMatchedOnly := true;
//	reportFilter.receiptTransportMode := 3;
	
	create queryAgent transient;
	num := queryAgent.qrySealCheckDiscrepancy(reportFilter,app.myPassport);
	write num;

epilog

	delete queryAgent;
	delete reportFilter;
	
end;</source>
    </JadeMethod>
