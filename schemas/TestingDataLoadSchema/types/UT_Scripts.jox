    <JadeMethod name="resetData_40571" id="0c098f49-d2eb-4e77-a7f8-bee1206c4fad">
        <updating/>
        <source>resetData_40571() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		     Who		Reason
14 January 2020	NAVMP4	Initial creation

*/

constants

	VoyageId					: String = "VOY_40571";
    ForeignVoy                  : String = '004';
	VoyageId1        		    : String = "GRIG002";
	VesselId					: String = "GRIG";
	CraneId						: String = "CRN1";

vars

	voyage						: CM_Voyage;
	voyage1					    : CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	operator					: CM_Operator;
	voyageDischJob				: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	ti							: CM_Container;
	
	tisToDelete					: StringArray;
	slotsFrom					: CM_SlotControllerArray;
	
	arrivalTS					: TimeStamp;
	departureTS					: TimeStamp;
    controller					: CMIF_TranshipTIController;
begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	create tisToDelete transient;
	tisToDelete.add("JLG40571A01");
	
	self.deleteTIResetScript(tisToDelete, terminal);
	
	self.deleteVoyage(VoyageId);
	
	// set arrival and departure dates
	arrivalTS.setDate("05/11/2021".Date);
	arrivalTS.setTime("15:32:00".Time);
	departureTS := arrivalTS;
	departureTS.setDate("05/11/2049".Date);
	
	self.opts.purge();
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselId[1:9], "MSL", "ANZ");
	if voyage = null then
		app.writeLog("Inward voyage (" &amp; VoyageId &amp; ") was not created.", LogINFO);
	endif;
	
	// add cargo on voyage
	operator := self.getOperator("MSL");
	self.assertNotNull(operator);
	
	self.opts.purge();
	self.opts.addAssoc("OutForeignCode", "004");
	self.createEDIXlation(ForeignVoy, VoyageId, XLATION_TYPE_VOYAGETERMINAL, true, operator, null);
	
	ti := self.addContainerOnShip("JLG40571A01", operator, "2200", "GEN", null, voyage, "USJAX", "118219").CM_Container;
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", "6000");	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(ti);
	app.myPassport.setWarningsIgnored(false);
	
	voyage1 := self.getVoyage(VoyageId1);
	self.assertNotNull(voyage);
	
	create controller transient;
	controller.allTrackedItems.add(ti);
	controller.myExportDestPort    := app.myRoot.allPorts['NZBLU'];
	controller.myExportDisPort     := app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage      := voyage1;
	controller.remarks             := "40571 Tranship";
	self.makeTrackedItemTranship(controller);
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "11", DeckOnDeck, 1, 2, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageId, "11", DeckOnDeck, 1, 2, 1, slotsFrom);
	
	voyageDischJob := self.addVoyageJob(voyage, CraneId, slotsFrom, true);
	self.assertNotNull(voyageDischJob);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
epilog

	app.myPassport.setWarningsIgnored(false);

	app.myPassport.setMyTerminal(passportTerm);
	
	delete tisToDelete;
	delete slotsFrom;
	delete controller;

end;

</source>
    </JadeMethod>
    <JadeMethod name="resetData_40576" id="9067ea22-747d-45fd-ac80-a1369b2416e3">
        <source>resetData_40576();
/*

Purpose:	Reset 37392		

Date		Who		Reason
28/06/2022	navmh5	Initial creation

*/
vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	passportTerm 			: CM_Terminal;
	ti						: CM_TrackedItem;
	vehicle					: CM_Vehicle;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
		
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	ti := self.getTrackedItem("JLG40576A01");
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	
	vehicle := self.getVehicle("40576");
	if vehicle = null then
		app.writeLog("Unable to find vehicle 40576", LogINFO);
		return;
	endif;
	
	foreach vvr in vehicle.visitRecords discreteLock do
		
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
		
		self.deleteVVR(vvr);
		
	endforeach;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_40589" id="22e03cbc-c3ff-4427-9732-5d3d13034237">
        <source>resetData_40589();
/*

Purpose:	Reset 37392		

Date		Who		Reason
21/07/2022	navmh5	Initial creation

*/
constants
	VehicleID				: String = "40589";

vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	passportTerm 			: CM_Terminal;
	
	found					: Boolean;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	vehicle := self.getVehicle(VehicleID);
	if vehicle = null then
		app.writeLog("Unable to find vehicle " &amp; VehicleID, LogINFO);
		return;
	endif;
	
	/*
	foreach vvr in vehicle.visitRecords discreteLock do
		
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
		
		self.deleteVVR(vvr);
		
	endforeach;
	*/
	
	foreach vvr in vehicle.visitRecords discreteLock do
		
		if vvr.timeOut &lt;&gt; null then
			continue;
		endif;
	
		found := true;
		
		break;
	endforeach;
	
	if found then
		self.ignoreTrxWarnings(true); 
		app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_40647" id="411160df-f913-49e4-bf6c-a89acf62e50b">
        <source>resetData_40647();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2020	jlgmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	ti						: Object;
	bookingRef				: CM_BookingRef;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal(terminal);
	
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG40647B01");
	tisToDelete.add("JLG40647B02");
	tisToDelete.add("JLG40647B03");
	tisToDelete.add("JLG40647B04");
	tisToDelete.add("JLG40647B05");
	tisToDelete.add("JLG40647A01");
	tisToDelete.add("JLG40647A02");
	tisToDelete.add("JLG40647A03");
		
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
epilog

	delete tisToDelete;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_40651" id="1a4ee943-eb09-4330-bd1a-42f1e9a19e96">
