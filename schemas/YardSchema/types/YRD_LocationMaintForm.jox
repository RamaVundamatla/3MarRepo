    <JadeMethod name="unload" id="3d7a28b3-1ef2-4057-a3f6-006f6fd2a536">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5		par 30475 - remove location restriction references
// ---------------------------------------------------------------------------

vars

begin
	if self.mySDF &lt;&gt; null then
		delete self.mySDF;
	endif;
	
	if self.myProxyLabourRestriction &lt;&gt; null then
		delete self.myProxyLabourRestriction;
	endif;
	
	//29 Oct 2012	NDL	Par 30282
	if self.myProxyDoorDirectionRule &lt;&gt; null then 
		delete self.myProxyDoorDirectionRule;
	endif;
	
	if self.myProxyTermSubArea &lt;&gt; null then 
		delete self.myProxyTermSubArea;
	endif;
	if self.myProxyTerminalArea &lt;&gt; null then 
		delete self.myProxyTerminalArea;
	endif;
	
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="68a0d0e8-2a30-46a0-95fa-215ddbd0e5ce">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.doNotableNotification(eventType, theObject, eventTag, userInfo);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="zDoCancel" id="380bcb32-f072-4f31-b6dd-6de3ad396f9b">
        <updating/>
        <source>zDoCancel() updating, protected;

vars

begin
	inheritMethod();
	// rs oct 2005 the zDoCancel is stuffing these valid up par 10928
	if self.theAreaMode = YRD_PadArea.AreaMode_Height then
		self.setUpdateDeleteTBButtons(self.theAreaMode);
		self.doEnableControls(false);
		self.frmGridArea.enabled := false;
		self.setMyDataClass();
		self.doSheetRedraw(self.theAreaMode);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
