        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInformation_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		04 January 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if app.activeControl = self.tblTransactions then
		if self.tblTransactions.row &gt; self.tblTransactions.fixedRows then
			self.tblTransactions.accessRow(self.tblTransactions.row).itemObject.inspect;
		endif;
	elseif app.activeControl = self.tblCharges then
		if self.tblCharges.row &gt; self.tblCharges.fixedRows then
			self.tblCharges.accessRow(self.tblCharges.row).itemObject.inspect;
		endif;
	elseif self.fldTrans.topSheet = self.shtTransactions then
		if self.tblTrans.row &gt; self.tblTrans.fixedRows then
			self.tblTrans.accessRow(self.tblTrans.row).itemObject.inspect;
		endif;
	elseif self.fldTrans.topSheet = self.shtCharges then
		if self.tblCharges.row &gt; self.tblCharges.fixedRows then
			self.tblCharges.accessRow(self.tblCharges.row).itemObject.inspect;
		endif;
	endif;
end;</source>
