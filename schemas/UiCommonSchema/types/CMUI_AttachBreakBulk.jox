    <JadeMethod name="cmbVoyage_lostFocus" id="b151e346-a7b9-44ec-b44a-77c8cf2a869d">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     24 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	str	: String;
	voyage :CM_Voyage;
begin

	voyage := self.cmbVoyage.listObject.CM_Voyage;
	if voyage &lt;&gt; null then
		str := voyage.code;
	endif;
	
	self.tblItem.setValueByControlName(combobox.name, str);


end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
