epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLoadContainerTxnTypes" id="4a00e291-f599-4538-adaa-35c24f36a53b">
        <updating/>
        <source>doLoadContainerTxnTypes(
	_lstTblTransact	: CMUI_ListTable input;
	_filterObject	: CMQF_FilterReports ) updating, protected;
	
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	strColl				: CM_ObjectArray;
//	strObj				: CM_String;
	stringWithObject	: CM_StringWithObject;
	defaultTypes		: StringArray;
	cm_TransactionType	: CM_TransactionType;
	aClass				: Class;
	iter1				: Iterator;
	
begin
	if _filterObject &lt;&gt; null and CMQF_Transactions.hasInstance( _filterObject ) then
		// get the default transactions for this report if set
		create defaultTypes transient;
		_filterObject.CMQF_Transactions.getTransTypeStringArray( defaultTypes );
	endif;
	
	// strColl is a reference to all of the possible allowed transactions set below.
	strColl := self.allAllowedTransactionTypes;
	if not strColl.isEmpty then
		strColl.purge();
	endif;
	
	// clears allSelectedObjects on the listTable
	if _lstTblTransact &lt;&gt; null then
		_lstTblTransact.clearSelected();
	endif;
	
	// now populate the allow transactions and set defaulted ones on the listTable allSelectedObjects.
	iter1	:= app.myRoot.allTransactionTypesByDesc.createIterator;
	while iter1.next( cm_TransactionType ) do : cond_loop
		if cm_TransactionType.trxGroup &lt;&gt; TRANS_TYPE_GROUP_TI then		// ie not Cargo
			continue cond_loop;
		endif;
		
		// do not include transaction types that do not have a classNameToCreate or the class is abstract.
		aClass	:= currentSchema.getClass( cm_TransactionType.classNameToCreate );
		if aClass = null or aClass.abstract then
			continue cond_loop;
		endif;
		
		create stringWithObject transient;
		stringWithObject.string	:= cm_TransactionType.description;
		stringWithObject.object	:= cm_TransactionType;
		strColl.add( stringWithObject );					// add to all allowed transactions
		if _lstTblTransact &lt;&gt; null and defaultTypes &lt;&gt; null and defaultTypes.includes( cm_TransactionType.description ) then
			// set the default (previously selected ) ones.
			_lstTblTransact.allSelectedObjects.add( stringWithObject );
		endif;
	endwhile cond_loop;
	
	if _lstTblTransact &lt;&gt; null then
		// now populate the listTable
		_lstTblTransact.displayCollection( strColl, false, Table.DisplayCollection_Forward, null );
		_lstTblTransact.lostFocus( _lstTblTransact );
	endif;
	
	/* cnwrl1 21/07/2009 PAR 20198 - SFW1070 - what it was
	if _filterObject &lt;&gt; null and 
	   CMQF_Transactions.hasInstance(_filterObject) then
		defaultTypes := _filterObject.CMQF_Transactions.allTransTypeDescriptions;
	endif;
	
	strColl := self.allAllowedTransactionTypes;
	
	if (not strColl.isEmpty) then
		strColl.purge();
	endif;
	
	//set allSelected to zero
	if _lstTblTransact &lt;&gt; null then
		_lstTblTransact.clearSelected();
	endif;
	
	create strObj transient;
	strObj.string := CMQF_ContainerTrans.ATTACH_STRING;
	strColl.add(strObj);
	if defaultTypes &lt;&gt; null and defaultTypes.includes(strObj.string) then
		if _lstTblTransact &lt;&gt; null then
			_lstTblTransact.allSelectedObjects.add(strObj);
		endif;
	endif;
	
	create strObj transient;
	strObj.string := CMQF_ContainerTrans.CONNECT_STRING;
	strColl.add(strObj);
	if defaultTypes &lt;&gt; null and defaultTypes.includes(strObj.string) then
		if _lstTblTransact &lt;&gt; null then
			_lstTblTransact.allSelectedObjects.add(strObj);
		endif;
	endif;
	
	create strObj transient;
	strObj.string := CMQF_ContainerTrans.DAMAGE_STRING;
	strColl.add(strObj);
	if defaultTypes &lt;&gt; null and defaultTypes.includes(strObj.string) then
		if _lstTblTransact &lt;&gt; null then
			_lstTblTransact.allSelectedObjects.add(strObj);
		endif;
	endif;
	
	create strObj transient;
	strObj.string := CMQF_ContainerTrans.EDIT_STRING;
	strColl.add(strObj);
	if defaultTypes &lt;&gt; null and defaultTypes.includes(strObj.string) then
		if _lstTblTransact &lt;&gt; null then
			_lstTblTransact.allSelectedObjects.add(strObj);
		endif;
	endif;
	
	create strObj transient;
	strObj.string := CMQF_ContainerTrans.FUMIGATE_STRING;
	strColl.add(strObj);
	if defaultTypes &lt;&gt; null and defaultTypes.includes(strObj.string) then
		if _lstTblTransact &lt;&gt; null then
			_lstTblTransact.allSelectedObjects.add(strObj);
		endif;
	endif;
	
	create strObj transient;
	strObj.string := CMQF_ContainerTrans.INSPECT_STRING;
