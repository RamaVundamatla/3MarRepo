    <JadeMethod name="setupTable_Delay" id="d6d1bd81-4898-4e73-ac42-3e9bba4b8c0b">
        <source>setupTable_Delay()protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
05 August 2008	concms1	Initial creation
*/
constants
	W1 = 50; W2 = 250; W3 = 100; W4 = 100; W5 = 80; Max_Columns = 6;
vars
	tbl			:Table;
	dd 			:DynaDictionary;
	obj			:Object;
	delay		:CM_Delay;
	count, row, intDelay	:Integer;
	strDesc, strDelay		:String;
begin
	self.getDelays (dd);

	if dd.size = 0 then
		return;
	endif;
	
	tbl := self.tblReport;
	
	tbl.rows	:= 0;
	tbl.columns	:= 0;	tbl.columns	:= Max_Columns;
	tbl.fontBold:= false;
	tbl.accessColumn (1).width	:= W1;
	tbl.accessColumn (2).width	:= W2;
	tbl.accessColumn (3).width	:= W3;	//tbl.accessedColumn.fontBold := false;
	tbl.accessColumn (4).width	:= W4;
	tbl.accessColumn (5).width	:= W5;
	tbl.accessColumn (6).width	:= tbl.clientWidth - (W1+W2+W3+W4+W5);
	
	row := tbl.addItem ('DELAYS' &amp; Tab &amp; 'DESCRIPTION' &amp; Tab &amp; 'FROM' &amp; Tab &amp; 'TO' &amp; Tab &amp; 'DURATION' &amp; Tab &amp; 'REMARKS');
		tbl.accessRow (row).fontBold := true;
	
	
	foreach obj in dd do
		delay 	:= obj.CM_Delay;
		count 	:= count + 1;
		
		strDesc 	:= null;
		
		if delay.myDelayType &lt;&gt; null then
			strDesc := delay.myDelayType.description;
		endif;
		
		strDelay	:= (delay.getDelayDuration).asHoursMinutes;
		
		row := tbl.addItem (count.String &amp; Tab &amp; strDesc &amp; Tab &amp; delay.startDT.asStringJMT &amp; Tab &amp; delay.getEndDT.asStringJMT &amp;
							Tab &amp; strDelay &amp; Tab &amp; delay.remarks);
	endforeach;
	
	if dd.isEmpty then
		tbl.addItem (null);
	endif;
	
	// set the table height based on the sum of the row heights
	self.setTableHeight (tbl);
	
	self.frmTable.height	:= tbl.height;

	// now print
	app.printer.print (self.frmNull);
	app.printer.print (self.frmNull);
	app.printer.print (frmTable);		
epilog
	delete dd;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable_Main" id="80a2c9ce-f34f-44f3-995b-db4a40035e02">
        <source>setupTable_Main()protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
01 August 2008	concms1	Initial creation
09 Nov    2017  cnwma1 TFS # 7343 RE: FW: Report Details
*/
constants
	W1	= 100;	// vessel/voyage
	W2 = 100;	// arrival/departure
	W3 = 30; 	// 20' 30' etc
	W4 = 45; 	// hours at berth
	W5 = 75;	// discharged
	W6 = 55;	// loaded
	W7 = 25;	// SOB
	W8 = 25;	// DLR
	W9 = 40; 	// Hatch lid moves
	W10 = 35;	// lashing bins
	W11 = 35;	// lashing bin lifts
	W12 = 50;	// single lifts
	W13 = 50;	// twin lifts
	W14 = 50;	// total lifts
	W15 = 55;	// ship working hours
	W16 = 80; 	// containers/hr
	W17 = 80;	// moves/hr
	Columns = 17;	// number of columns
vars
	tbl				:Table;
	row, int, sum, row20, row30, row40, row45, row53, rowTEU, rowTotal,rowExtra	:Integer;
	voyage			:CM_Voyage;
//	kpi				:CM_KPIVoyage;
	kpiTotals : CM_KPIVoyageTotals;

begin
	tbl				:= self.tblReport;
	tbl.fontSize	:= 8;	
	tbl.rows		:= 0;
	tbl.columns		:= 17;
	
	tbl.accessColumn (1).width	:= W1;
	tbl.accessColumn (2).width	:= W2;
	tbl.accessColumn (3).width	:= W3;	tbl.accessedColumn.alignment := Table.Alignment_Center; tbl.accessedColumn.fontBold := true;
	tbl.accessColumn (4).width	:= W4;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (5).width	:= W5;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (6).width	:= W6;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (7).width	:= W7;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (8).width	:= W8;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (9).width	:= W9;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (10).width	:= W10;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (11).width	:= W11;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (12).width	:= W12;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (13).width	:= W13;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (14).width	:= W14;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (15).width	:= W15;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (16).width	:= W16;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	tbl.accessColumn (17).width	:= W17;	tbl.accessedColumn.alignment := Table.Alignment_Center;

	row := tbl.addItem (Tab &amp; Tab &amp; Tab &amp; 'HOURS' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; 'Hatch' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; 'SHIP');
	tbl.accessRow(row).fontBold := true;		
	
	//row := tbl.addItem ('VOYAGE' &amp; Tab &amp; 'ARRIVAL' &amp; Tab &amp; Tab &amp; 'AT' &amp; Tab &amp; 'CONTAINERS' &amp; Tab &amp; Tab &amp; 'Restows' &amp; Tab &amp; Tab &amp; 'Lid' &amp; Tab &amp; 'Lashing Bins' &amp; Tab &amp; Tab &amp; 'Lifts' &amp; Tab &amp; Tab &amp; Tab &amp; 'WORKING' &amp; Tab &amp; 'GROSS PRODUCTIVITY'); 	// 9.11.2017 cnwma1 TFS # 7343
	row := tbl.addItem ('VOYAGE' &amp; Tab &amp; 'ARRIVAL' &amp; Tab &amp; Tab &amp; 'AT' &amp; Tab &amp; 'CONTAINERS' &amp; Tab &amp; Tab &amp; 'Restows' &amp; Tab &amp; Tab &amp; 'Lid' &amp; Tab   &amp; '           ' &amp; Tab &amp; Tab &amp; 'Lifts' &amp; Tab &amp; Tab &amp; Tab &amp; 'WORKING' &amp; Tab &amp; 'GROSS PRODUCTIVITY');   	// 9.11.2017 cnwma1 TFS # 7343
						tbl.accessCell(row, 5).mergeCells := Table.MergeCells_Merge;	//containers
						tbl.accessCell(row, 7).mergeCells := Table.MergeCells_Merge; 	// restows
						tbl.accessCell(row, 10).mergeCells := Table.MergeCells_Merge; 	// lashing bins
						tbl.accessCell(row, 12).mergeCells := Table.MergeCells_Merge; 	// lifts
						tbl.accessCell(row, 16).mergeCells := Table.MergeCells_Merge; 	// gross productivity

	tbl.accessRow(row).fontBold := true;	
						
	row := tbl.addItem ('VESSEL' &amp; Tab &amp; 'DEPARTURE' &amp; Tab &amp; Tab &amp; 'BERTH' &amp; Tab &amp; 'DISCHARGED' &amp; Tab &amp; 'LOADED' &amp; Tab &amp; 'SOB' &amp; Tab &amp; 'DLR' &amp;Tab &amp; 'Moves' &amp; Tab &amp; '    ' &amp; Tab &amp; '     ' &amp; Tab &amp; 'Single' &amp; Tab &amp; 'Twin' &amp; Tab &amp; 'Total' &amp; Tab &amp; 'HOURS' &amp; Tab &amp; 	'Containers/Hr' &amp; Tab &amp; 'Moves/Hr');
						
	tbl.accessRow(row).fontBold := true;		
	
	// make column 1 as wide as possible for voyage/vessel
	foreach int in 2 to Columns do
		sum := sum + tbl.accessColumn (int).width;
	endforeach;
	
	tbl.accessColumn(1).width := tbl.clientWidth - sum;
	
	// the table is now formatted - now load the data
	voyage 	:= self.getVoyage;

	row20 	:= tbl.addItem (self.getVoyageCode &amp; Tab &amp; self.getArrivalDT &amp; Tab &amp; "20'");
	row30 	:= tbl.addItem (self.getVesselName &amp; Tab &amp; self.getDepartedDT &amp; Tab &amp; "30'");
	row40 	:= tbl.addItem (Tab &amp; Tab &amp; "40'");
	row45 	:= tbl.addItem (Tab &amp; Tab &amp; "45'");
	row53 	:= tbl.addItem (Tab &amp; Tab &amp; "53'");
	rowTEU 	:= tbl.addItem (Tab &amp; Tab &amp; "TEU");
	rowTotal:= tbl.addItem (Tab &amp; Tab &amp; "Total");
	
	tbl.setCellText (row45, 16, 'NET PRODUCTIVITY');	
			tbl.accessCell(row45, 16).fontBold := true; tbl.accessedCell.mergeCells := Table.MergeCells_Merge;
	tbl.setCellText (row53, 16, 'Containers/hr' &amp; Tab &amp; 'Moves/hr' );	
			tbl.accessCell(row53, 16).fontBold := true; 
			tbl.accessCell(row53, 17).fontBold := true; 
	
	kpiTotals := voyage.getKPIByType(KPI_Type_Voyage).CM_KPIVoyageTotals;
	tbl.setCellText (row20, 4, voyage.getHoursAtBerth_HHMM);
	
	if kpiTotals &lt;&gt; null then
		tbl.setCellText (row20, 5, kpiTotals.getDisch20AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getLoad20AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getSOB20AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getDLR20AllItems().asStringOrBlank &amp; 
							//Tab &amp; kpiTotals.getTotalLidMoves().asStringOrBlank &amp; Tab &amp; '***' &amp; Tab &amp; '***' &amp;  	// 9.11.2017 cnwma1 TFS # 7343
							Tab &amp; kpiTotals.getTotalLidMoves().asStringOrBlank &amp; Tab &amp; '   ' &amp; Tab &amp; '   ' &amp;        // 9.11.2017 cnwma1 TFS # 7343
							Tab &amp; kpiTotals.getAllSingleLift().asStringOrBlank &amp; Tab &amp; kpiTotals.getAllTwinLift().asStringOrBlank &amp; Tab &amp; kpiTotals.getAllLifts().asStringOrBlank &amp; Tab &amp; voyage.getKPIAllCranesHoursNet().Decimal.asHoursMinutes);
						
		tbl.setCellText (row30, 5, kpiTotals.getDisch30AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getLoad30AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getSOB30AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getDLR30AllItems().asStringOrBlank);
		tbl.setCellText (row40, 5, kpiTotals.getDisch40AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getLoad40AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getSOB40AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getDLR40AllItems().asStringOrBlank);
		tbl.setCellText (row45, 5, kpiTotals.getDisch45AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getLoad45AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getSOB45AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getDLR45AllItems().asStringOrBlank);
		tbl.setCellText (row53, 5, kpiTotals.getDisch53AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getLoad53AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getSOB53AllItems().asStringOrBlank &amp; Tab &amp; kpiTotals.getDLR53AllItems().asStringOrBlank);

		tbl.setCellText (rowTEU, 5, kpiTotals.getDischargeAllTEU.asStringOrBlank &amp; Tab &amp; kpiTotals.getLoadAllTEU.asStringOrBlank &amp; Tab &amp; kpiTotals.getSOBAllTEU.asStringOrBlank &amp; Tab &amp; kpiTotals.getDLRAllTEU.asStringOrBlank);
		tbl.setCellText (rowTotal, 5, kpiTotals.getDischargeAllItems.asStringOrBlank &amp; Tab &amp; kpiTotals.getLoadAllItems.asStringOrBlank &amp; Tab &amp; kpiTotals.getSOBAllItems.asStringOrBlank &amp; Tab &amp; kpiTotals.getDLRAllItems.asStringOrBlank &amp; Tab &amp; kpiTotals.getTotalLidMoves.asStringOrBlank); //10 Mar 2020	NDL	TFS 48805
		// now do productivity figures
		tbl.setCellText (row20, 16, kpiTotals.getGrossContainersPerHour.asStringOrBlank &amp; Tab &amp; kpiTotals.getGrossMovesPerHour.asStringOrBlank);
		tbl.setCellText (rowTEU, 16, kpiTotals.getNetContainersPerHour.asStringOrBlank &amp; Tab &amp; kpiTotals.getNetMovesPerHour.asStringOrBlank); 
		
		
	else
		// kpi not available - should not happen
	endif;
	// 9.11.2017 cnwma1 TFS # 7343
	rowExtra := tbl.addItem (app.getErrorString(Number_lashings) &amp; Tab &amp; voyage.getNumLashings().asStringOrBlank);
	tbl.accessCell (rowExtra, 1).mergeCells	:= Table.MergeCells_Merge;
	tbl.accessedCell.fontBold := true;
	rowExtra := tbl.addItem (app.getErrorString(Number_unlashings) &amp; Tab &amp; voyage.getNumUnlashings().asStringOrBlank);
	tbl.accessCell (rowExtra, 1).mergeCells	:= Table.MergeCells_Merge;
	tbl.accessedCell.fontBold := true;
	rowExtra := tbl.addItem (app.getErrorString(Number_cage_moves) &amp; Tab &amp; voyage.getNumCageMoves().asStringOrBlank);
	tbl.accessCell (rowExtra, 1).mergeCells	:= Table.MergeCells_Merge; 
	tbl.accessedCell.fontBold := true;
	rowExtra := tbl.addItem (app.getErrorString(Number_extra_moves) &amp; Tab &amp; voyage.getNumExtraMoves().asStringOrBlank);
	tbl.accessCell (rowExtra, 1).mergeCells	:= Table.MergeCells_Merge; 
	tbl.accessedCell.fontBold := true;
	
	rowExtra := tbl.addItem (app.getErrorString(Number_lashing_bin_moves) &amp; Tab &amp; voyage.getNumLashingBinMoves().asStringOrBlank);
	tbl.accessCell (rowExtra, 1).mergeCells	:= Table.MergeCells_Merge; 
	tbl.accessedCell.fontBold := true;
	tbl.accessedCell.alignment := Table.Alignment_Left; 

	// set the table height based on the sum of the row heights
	self.setTableHeight (tbl);
	
	self.frmTable.height	:= tbl.height;

	// now print
	app.printer.print (self.frmNull);
	app.printer.print (frmTable);	
epilog

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable_Times" id="e1d7a724-8d8f-430c-b7fa-3dce20bfec97">
        <source>setupTable_Times()protected;
/*
	Purpose:			
	Parameters:		
	Return Value:		

Date			Who		Reason
01 August 2008	concms1	Initial creation
*/
constants
	
vars
	tbl 			:Table;
	voyage			:CM_Voyage;
	kpi				:CM_KPIVoyageCraneShift;
	delay			:Object;
	row, fixedWidth,
	col				:Integer;
	crane			:Object;
	craneArray		:ObjectArray;
	value			:Decimal[23,8];
	str				:String;
begin
	tbl				:= self.tblReport;

	// the superclass method sets up a table with 5 columns - we will extend it to show individual times
	// for each crane
	inheritMethod;
	
	// make changes to table for this report - cols 5-13 in row 4 contain working time for each crane
	tbl.columns	:= 13;
	fixedWidth	:= (tbl.accessColumn (5).width/9).Integer;
	
	foreach col in 5 to 13 do
		tbl.accessColumn(col).width := fixedWidth;	tbl.accessedColumn.alignment := Table.Alignment_Center;
	endforeach;
	
//	create craneArray transient;		// PAR #27874
	self.getCranes (craneArray);
	
	voyage	:= self.getVoyage;
//	kpi		:= voyage.getKPIByTypeNEW(KPI_Type_Voyage).CM_KPIVoyageTotals;
	
	tbl.accessCell (5, 4).text := ('Ship Working Crane Time');

	col := 5;
	
	foreach crane in craneArray do
		value := 0; // PAR 31484
		foreach kpi in crane.CM_Crane.allVoyageKPICraneShifts discreteLock
			where kpi.myVoyage = voyage do // PAR 31484 add WHERE statement as this is a collection of KPIs for all voyages that this crane has been used for
			
		//	value 	:= value + kpi.hoursNet; //kpi.getNetHours_Crane (crane.CM_Crane);
			value 	:= value + kpi.getHoursNetLessDownTime;	//04 Apr 2012	NDL	Par 29369
		endforeach;
		str		:= value.asHoursMinutes; 
		tbl.accessCell (4, col).text := crane.CM_Crane.code;	tbl.accessedCell.fontBold := true;	// heading
		tbl.accessCell (5, col).text := str;					tbl.accessedCell.fontBold := false;	// hh:mm
		col := col + 1;
	endforeach;	

	// set the table height based on the sum of the row heights
	self.setTableHeight (tbl);
	
	self.frmTable.height	:= tbl.height;

	// now print
	app.printer.print (self.frmNull);
	app.printer.print (self.frmNull);
	app.printer.print (frmTable);	
epilog
	delete craneArray;		// PAR #27874
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
