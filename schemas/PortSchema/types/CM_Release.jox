    <JadeMethod name="getSealsListAtRelease" id="d154faa8-3449-4a44-8c3a-89918b3bc338">
        <source>getSealsListAtRelease(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 July 2017	jlgndl1	Initial creation	TFS 5314

*/

vars

	sealCheckTrx : CM_SealCheck;

begin
	
	sealCheckTrx := self.getTransactionByTypeSameTRX( TRANS_TYPE_SEAL_CHECK ).CM_SealCheck;
	
	if sealCheckTrx &lt;&gt; null then
		return sealCheckTrx.getSealNumbersList;
	endif;
	
	return inheritMethod();
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasStockMovements" id="e8e36eea-bd37-48b4-a20b-bcd428d733e0">
        <source>hasStockMovements(): Boolean;
// ---------------------------------------------------------------------------
// Created:     03 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myStockMovementIn &lt;&gt; null or
	   self.myStockMovementOut &lt;&gt; null then
	   	return true;
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasStockMovementsOtherThanMe" id="d59750cd-17cb-491c-911c-6203a115538d">
        <source>hasStockMovementsOtherThanMe(_stockMovementBeingDeleted: CM_StockMovement input): Boolean;

// Created by cnwdvb1 on 26 July 2006

vars

begin

	if (self.myStockMovementIn &lt;&gt; null and (self.myStockMovementIn &lt;&gt; _stockMovementBeingDeleted)) or
	   (self.myStockMovementOut &lt;&gt; null and (self.myStockMovementOut &lt;&gt; _stockMovementBeingDeleted)) then
	   	return true;
	endif;
	
	return inheritMethod(_stockMovementBeingDeleted);

end;</source>
        <Parameter name="_stockMovementBeingDeleted" type="CM_StockMovement" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
