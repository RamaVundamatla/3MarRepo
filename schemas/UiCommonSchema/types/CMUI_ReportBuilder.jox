    <JadeMethod name="createProxiesForEdit" id="aa4ce31e-69b7-4bb3-8e63-f21a273b6767">
        <updating/>
        <source>createProxiesForEdit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 January 2008 by cnwar2
//
// Purpose:     Initiailise report agent date fields.
//				This is necessary as a fix to #15387 - previously, saving a 
//				report was setting fields from the agent which contained null
//				or old data.  This initialisation should occur around the
//				same time as the edit proxies are created.

// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
// ---------------------------------------------------------------------------
vars
	defaultTemplate	: CMQF_FilterReports;
	
begin	
	if self.myReportAgent = null or self.myCurrentObject = null then
		return;
	endif;
	
	defaultTemplate := self.myCurrentObject.CM_QryReport.myFilterObject;
	if defaultTemplate = null then
		return;
	endif;
	
	self.myReportAgent.txtArriveDFrom 	:= defaultTemplate.getDisplayStringForAttribute(ETRow_ArrivalsDateFrom, false);
	self.myReportAgent.txtArriveDTo 	:= defaultTemplate.getDisplayStringForAttribute(ETRow_ArrivalsDateTo, false);
	self.myReportAgent.txtBaseDate 		:= defaultTemplate.getDisplayStringForAttribute(ETRow_BaseDate, false);
	self.myReportAgent.txtCloseDate 	:= defaultTemplate.getDisplayStringForAttribute(ETRow_CloseDate, false);
	self.myReportAgent.txtDepartDFrom 	:= defaultTemplate.getDisplayStringForAttribute(ETRow_DepartedDateFrom, false);
	self.myReportAgent.txtDepartDTo 	:= defaultTemplate.getDisplayStringForAttribute(ETRow_DepartedDateTo, false);
	self.myReportAgent.txtInPortDFrom 	:= defaultTemplate.getDisplayStringForAttribute(ETRow_InPortDateFrom, false);
	self.myReportAgent.txtInPortDTo 	:= defaultTemplate.getDisplayStringForAttribute(ETRow_InPortDateTo, false);
	self.myReportAgent.txtMatchStart 	:= defaultTemplate.getDisplayStringForAttribute(ETRow_MatchDateStart, false);
	self.myReportAgent.txtMatchEnd 		:= defaultTemplate.getDisplayStringForAttribute(ETRow_MatchDateEnd, false);
	self.myReportAgent.txtOnDate 		:= defaultTemplate.getDisplayStringForAttribute(ETRow_ArrivalsDateTo, false);
	self.myReportAgent.txtOpenDate 		:= defaultTemplate.getDisplayStringForAttribute(ETRow_OnDate, false);
	self.myReportAgent.txtEstimatedArrivalDFrom  :=  defaultTemplate.getDisplayStringForAttribute(ETRow_ExpectedArrivalDateFrom, false);				//+TFS39280
	self.myReportAgent.txtEstimatedArrivalDTo  :=  defaultTemplate.getDisplayStringForAttribute(ETRow_ExpectedArrivalDateTo, false);
	self.myReportAgent.txtEstimatedDepartDFrom  :=  defaultTemplate.getDisplayStringForAttribute(ETRow_ExpectedDepartDateFrom, false);
	self.myReportAgent.txtEstimatedDepartDTo  :=  defaultTemplate.getDisplayStringForAttribute(ETRow_ExpectedDepartDateTo, false);
	
	// 20/04/2023	navkc1	CR 55654 Task 55670 --&gt;
	self.myReportAgent.txtContractFromStartDate		:= defaultTemplate.getDisplayStringForAttribute(ETRow_ContractFromStartDate, false);
	self.myReportAgent.txtContractToStartDate		:= defaultTemplate.getDisplayStringForAttribute(ETRow_ContractToStartDate, false);
	self.myReportAgent.txtDetailFromStartDate		:= defaultTemplate.getDisplayStringForAttribute(ETRow_DetailFromStartDate, false);
	self.myReportAgent.txtDetailToStartDate			:= defaultTemplate.getDisplayStringForAttribute(ETRow_DetailToStartDate, false);
	self.myReportAgent.txtRateEntryFromStartDate	:= defaultTemplate.getDisplayStringForAttribute(ETRow_RateFromStartDate, false);
	self.myReportAgent.txtRateEntryToStartDate		:= defaultTemplate.getDisplayStringForAttribute(ETRow_RateToStartDate, false);
	
	self.myReportAgent.txtContractFromEndDate		:= defaultTemplate.getDisplayStringForAttribute(ETRow_ContractFromEndDate, false);
	self.myReportAgent.txtContractToEndDate			:= defaultTemplate.getDisplayStringForAttribute(ETRow_ContractToEndDate, false);
	self.myReportAgent.txtDetailFromEndDate			:= defaultTemplate.getDisplayStringForAttribute(ETRow_DetailFromEndDate, false);
	self.myReportAgent.txtDetailToEndDate			:= defaultTemplate.getDisplayStringForAttribute(ETRow_DetailToEndDate, false);
	self.myReportAgent.txtRateEntryFromEndDate		:= defaultTemplate.getDisplayStringForAttribute(ETRow_RateFromEndDate, false);
	self.myReportAgent.txtRateEntryToEndDate		:= defaultTemplate.getDisplayStringForAttribute(ETRow_RateToEndDate, false);
	// 20/04/2023	navkc1	CR 55654 Task 55670 &lt;--
	
	
// cnwdad1 19/11/2010 - PAR #25218.
	if self.myReportAgent.txtOpenDate.trimBlanks() = null then
		self.myReportAgent.txtOpenDate	:=	defaultTemplate.getDisplayStringForAttribute(ETRow_OpenDate, false);
	endif;
	
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
