    <JadeMethod name="doSave" id="f9131e3d-9bd6-46a9-a403-f7f7216ccc4a">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2022	jlier1	Initial creation 55583
26/02/2023			navkc1 	CR 59577 Task 62412: UI - HS Code Sys Admin
*/

vars
	theForm		: SOP_TableMaintForm;
	isAdd,isActive,
	notAvail	: Boolean;
	pxyHarmonizedSystem , realHarmonisedSystem: CM_HarmonizedSystem;
	code,
	description,
	extRef1,
	extRef2,
	extRef3,
	unitQuantity: String;
	hsType : Integer;
begin
		
	theForm:=self.myForm;
	isAdd:=theForm.mode = theForm.Mode_Add;
	if theForm.mode = theForm.Mode_Add then
		hsType:=self.myForm.comboBox1.listData;
		if hsType = CM_HarmonizedSystem.HS_Section then
			create pxyHarmonizedSystem as CM_HSCodeSection transient;
		elseif hsType = CM_HarmonizedSystem.HS_Chapter then
			create pxyHarmonizedSystem as CM_HSCodeChapter transient;
		elseif hsType = CM_HarmonizedSystem.HS_Heading then
			create pxyHarmonizedSystem as CM_HSCodeHeading transient;
		elseif hsType = CM_HarmonizedSystem.HS_Code then
			create pxyHarmonizedSystem as CM_HSCodeCode transient;
		elseif  hsType = CM_HarmonizedSystem.HS_SubCode then
			create pxyHarmonizedSystem as CM_HSCodeSubCode transient;
		elseif hsType = CM_HarmonizedSystem.HS_Taric then //26/02/2023	navkc1 CR 59577 Task 62412
			create pxyHarmonizedSystem as CM_HSCodeTaric transient;
		else
			app.raiseCMException(Please_select_hscode_type,null,null);
			return false;
		endif;
	else
		if theForm.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
		pxyHarmonizedSystem:=theForm.myProxyObject.CM_HarmonizedSystem;
		isActive:=pxyHarmonizedSystem.isActive;
		hsType:=pxyHarmonizedSystem.getType;
	endif;
	
	code := theForm.tblInput1.getValueByName(ETRow_HsCode).String;
	description := theForm.tblInput1.getValueByName(ETRow_HsCodeDescription).String;
	notAvail	:= theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	
	pxyHarmonizedSystem.setProxy(code, description, isActive,notAvail,  null);
	
	if hsType = CM_HarmonizedSystem.HS_Code or hsType = CM_HarmonizedSystem.HS_SubCode   then
		extRef1:=theForm.tblInput1.getValueByName(ETRow_ExternalRef1).String;
		extRef2:=theForm.tblInput1.getValueByName(ETRow_ExternalRef2).String;
		extRef3:=theForm.tblInput1.getValueByName(ETRow_ExternalRef3).String;
		unitQuantity:=theForm.tblInput1.getValueByName(ETRow_UnitQuantity).String;	
		pxyHarmonizedSystem.setDetails(extRef1,extRef2,extRef3,unitQuantity);
	endif;
	
	if hsType = CM_HarmonizedSystem.HS_Chapter then
		pxyHarmonizedSystem.setMyParent(app.myRoot.allHSSections[theForm.tblInput1.getValueByName(ETRow_HsParentSection).String[1:2]]);
	elseif hsType = CM_HarmonizedSystem.HS_Heading then
		pxyHarmonizedSystem.setMyParent(app.myRoot.allHSChapters[theForm.tblInput1.getValueByName(ETRow_HsParentChapter).String[1:2]]);
	elseif hsType = CM_HarmonizedSystem.HS_Code then
		pxyHarmonizedSystem.setMyParent(app.myRoot.allHSHeadings[theForm.tblInput1.getValueByName(ETRow_HsParentHeading).String[1:4]]);
	elseif hsType = CM_HarmonizedSystem.HS_SubCode then
		pxyHarmonizedSystem.setMyParent(app.myRoot.allHSCodes[theForm.tblInput1.getValueByName(ETRow_HsParentCode).String[1:6]]);
	elseif hsType = CM_HarmonizedSystem.HS_Taric then //26/02/2023	navkc1 CR 59577 Task 62412
		pxyHarmonizedSystem.setMyParent(app.myRoot.allHSSubCodes[theForm.tblInput1.getValueByName(ETRow_HsParentSubCode).String[1:8]]);
	endif;
	
	if isAdd then
		app.myTrxCA.trxCreateHarmonizedSystem(pxyHarmonizedSystem, realHarmonisedSystem, app.myPassport);	
	else
		app.myTrxUA.trxUpdateHarmonizedSystem(pxyHarmonizedSystem,  app.myPassport);							
	endif;
	
	if realHarmonisedSystem &lt;&gt; null then
		self.allHSCodes.add(realHarmonisedSystem);
	
	endif;
	
	return app.myPassport.trxCompletedOK;

epilog
	if isAdd and pxyHarmonizedSystem &lt;&gt; null then
		delete pxyHarmonizedSystem;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
