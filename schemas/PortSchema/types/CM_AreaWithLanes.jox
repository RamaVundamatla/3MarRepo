    <JadeMethod name="pxyCreateNewLane" id="e2424339-3de0-4f0d-9a55-0afd5dba853e">
        <updating/>
        <source>pxyCreateNewLane(_in :Boolean):CM_LaneController updating;
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyRow	:CM_RoadRow;
	pxyCol	:CM_RoadColumn;
	pxyLane	:CM_LaneController;
begin
	self.raiseExceptionIfNotTransient (method);
	
	pxyRow 	:= self.pxyGetRowByNumber (self.allGridRows.size + 1);	// will create if not there
	pxyCol	:= self.pxyGetDefaultColumn;
	
	pxyLane := self.pxyAddLaneController (pxyRow, pxyCol);
	
	pxyLane.setIsUnavailable (false);
	
	if _in then
		pxyLane.setLaneDirection (CM_LaneController.Is_In_Lane);
		pxyLane.setVehicleDirection (CM_LaneController.Is_In_Lane);
	else
		pxyLane.setLaneDirection (CM_LaneController.Is_Out_Lane);
		pxyLane.setVehicleDirection (CM_LaneController.Is_Out_Lane);
	endif;
	
	pxyLane.setMyTerminalAreaProxy (self);
	
	return pxyLane;
epilog
	
end;</source>
        <Parameter name="_in" type="Boolean"/>
        <ReturnType type="CM_LaneController"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="57d1d7b4-d2a9-4095-a8e6-6584530bc255">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy			:SelfType;
	completedOK		: Boolean;
begin
	self.raiseExceptionIfTransient (method);
	
	proxy := inheritMethod();

	// do not set proxy.myInTransitToLocation - it is never maintained
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyGetDefaultColumn" id="c426ed13-aaea-4749-bc8c-f91da769b3ef">
        <updating/>
        <source>pxyGetDefaultColumn():CM_RoadColumn updating, protected;
// ---------------------------------------------------------------------------
// Created:     21 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy	:CM_RoadColumn;
begin
	self.raiseExceptionIfNotTransient (method);
	
	if not self.allGridColumns.isEmpty then
		// should only ever be one
		return self.allGridColumns.first.CM_RoadColumn;
	endif;
	
	create proxy transient;
	
	proxy.setForProxy (1, 1.String, self);
	
	self.numberOfColumns := 1;
	
	return proxy;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_RoadColumn"/>
    </JadeMethod>
    <JadeMethod name="pxyGetRowByNumber" id="a79d064c-d1a1-4f18-9690-c1f649da86b8">
        <updating/>
        <source>pxyGetRowByNumber(_row :Integer):CM_RoadRow updating, protected;
// ---------------------------------------------------------------------------
// Created:     21 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy	:CM_RoadRow;
begin
	self.raiseExceptionIfNotTransient (method);
	
	proxy := self.getRowByNumber (_row).CM_RoadRow;
	
	if proxy &lt;&gt; null then
		return proxy;
	endif;
	
	create proxy transient;
	
	proxy.setForProxy (_row, _row.String, self);
	
	self.numberOfRows := _row;
	
	return proxy;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="CM_RoadRow"/>
    </JadeMethod>
    <JadeMethod name="pxyHasLanesDefined" id="f0aae6fc-f3b7-453e-b287-9e0293fb4d80">
        <source>pxyHasLanesDefined():Boolean;
// ---------------------------------------------------------------------------
// Created:     23 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     True if the CMRoadRow objects corresponding to actual lanes
//				have been created
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient (method);
	
	return not self.allGridRows.isEmpty;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyUpdateLaneCount" id="b229a989-3bf8-45e2-a0ad-f162fa3d67bc">
        <updating/>
        <source>pxyUpdateLaneCount(_value :Integer)updating;
// ---------------------------------------------------------------------------
// Created:     21 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  _value - number of lanes
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/10/2012	cnwcs5		par 30629
// ---------------------------------------------------------------------------
vars
	int, size		:Integer;
	lane, pxyLane	:CM_RoadRow;
	lc				:CM_LaneController;
begin
	self.raiseExceptionIfNotTransient (method);
	
	if _value = self.laneCount then
		return;	// nothing to do
	endif;
	
	size := self.allGridRows.size;	// 24/02/2010
	
	if _value &gt; size then			// 24/02/2010
		// create new lane proxies
		//size := self.allGridRows.size;

		foreach int in (size + 1) to _value do
			self.pxyCreateNewLane (true);	// input by default			
		endforeach;
		
	elseif _value &lt; size then	// 24/02/2010

		// delete extra lanes we don't need		
		// we will also delete any real lanes and re-create default lanes
		int := self.allGridRows.size;
		
		while int &gt; _value do
			lane := self.allGridRows[int].CM_RoadRow;
			
			lane.erase (NORMAL_ERASE);	// make sure we delete lane devices
			
			int := int - 1;
		endwhile;
		
		if _value = 0 and self.allGridRows.size = 0 then
			// create new default lanes if necessary
			self.pxyCreateDefaultLanes;
		endif;
	elseif self.laneCount = _value then		// par 30629 oct 2012
		// no change from user perspective
		return;
	endif;
	
	self.laneCount := _value;
	
	if _value = 0 then
		// always have default in/out
		self.numberOfRows	:= 2;
	else
		self.numberOfRows	:= _value;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9163693e-9f7c-4c04-bc10-1cb604104e77">
        <updating/>
        <source>setForCreate(_proxy :CM_AreaWithLanes input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     18 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	// i can pass a null value in the passport parameter cos i know it does not get used
	inheritMethod (_proxy, _passport);
	
	self.laneCount	:= _proxy.laneCount;
	
	self.createInTransitToLocation;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_AreaWithLanes" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
