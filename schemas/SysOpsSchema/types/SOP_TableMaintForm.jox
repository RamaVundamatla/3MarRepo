    <JadeMethod name="loadCmbType" id="362b62f5-c44c-4023-ba75-171e77e8d63b">
        <updating/>
        <source>loadCmbType(_type : String; _todotask : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2022 navds20 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance

*/

vars
	cmb : CMUI_ComboBox;
begin

	cmb := self.cmbType;
	cmb.clear();
