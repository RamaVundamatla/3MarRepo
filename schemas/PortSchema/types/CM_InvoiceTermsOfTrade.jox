    <JadeMethod name="getDueRuleString" id="32273ac9-6daf-4ee0-9597-a337deccdbf7">
        <options>4</options>
        <source>getDueRuleString(_dueRule : Integer) : String typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/01/2023	navkc1 ChangeRequest 59145 Task 61333: Jade - Other Changes

*/

vars
	string	: String;
begin
	
	if _dueRule = CM_InvoiceTermsOfTrade.EndOfPeriodPlusDueDays then
		string := CM_InvoiceTermsOfTrade.EndOfPeriodPlusDueDaysStr;
	elseif _dueRule = CM_InvoiceTermsOfTrade.PostedDatePlusDueDays then
		string := CM_InvoiceTermsOfTrade.PostedDatePlusDueDaysStr;
	elseif _dueRule = CM_InvoiceTermsOfTrade.EndDatePlusDueDays then
		string := CM_InvoiceTermsOfTrade.EndDatePlusDueDaysStr;
	elseif _dueRule = CM_InvoiceTermsOfTrade.InvoiceDatePlusDueDays then
		string := CM_InvoiceTermsOfTrade.InvoiceDatePlusDueDaysStr;
	endif;
	
	return string;
	
epilog

end;</source>
        <Parameter name="_dueRule" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="90bd02d0-cbf3-4a0a-9bcc-569df061bb03">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------
//Created: 17 October 2001 By: cnwgd1
//----------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : CM_InvoiceTermsOfTrade;
	completedOK		: Boolean;
begin

	proxy := inheritMethod();
	//------------------
	//Copy over references
	//------------------
	proxy.myBank := self.myBank;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setActive" id="3914c3b3-5ffa-4152-9dab-08da603de03a">
        <updating/>
        <source>setActive(pActive : Boolean) updating;
//----------------------------------------------
//Created: 19 October 2001 By: cnwgd1
//----------------------------------------------
vars

begin
	if self.isActive &lt;&gt; pActive then
		self.isActive := pActive;
	endif;
end;</source>
        <Parameter name="pActive" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="21db359f-2781-47fd-8313-533421b95c12">
        <updating/>
        <source>setForCreate(_theTerminal : CM_Terminal;prxyTerms : CM_InvoiceTermsOfTrade) updating;
//----------------------------------------------
//Created:  16 October 2001 By: cnwgd1
//----------------------------------------------

vars

begin
	prxyTerms.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.code := prxyTerms.code.toUpper;
	self.description := prxyTerms.description;
	self.dueDays := prxyTerms.dueDays; //15/01/2023	navkc1 ChangeRequest 59145 Task 61328
	self.dueRule := prxyTerms.dueRule; //15/01/2023	navkc1 ChangeRequest 59145 Task 61328
	self.myBank := app.myRoot.myRootCompany;

end;</source>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
        <Parameter name="prxyTerms" type="CM_InvoiceTermsOfTrade"/>
    </JadeMethod>
