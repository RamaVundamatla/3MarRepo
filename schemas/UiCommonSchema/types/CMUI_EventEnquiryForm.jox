    <JadeMethod name="addObjectsForDT" id="013faca6-27ca-45d1-b9f3-2a52a26323b0">
        <updating/>
        <source>addObjectsForDT(_eventByDTDict : CM_EventTransByDateTime; 
				_iter 			: Iterator input;
				_numItems 		: Integer io;
				_breakOut 		: Boolean output) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		
----------   ----------  --------------------------------------------------
*/
vars
	eventTrans		: CM_EventTransaction;
	toDT			: TimeStamp;
	dtKey			: TimeStamp;
	testToDT		: Boolean;
begin
	toDT := self.filtToDT;
	testToDT := toDT &lt;&gt; null and toDT.isValid();
	
	while _iter.next(eventTrans) do : eventTransLoop
		_iter.getCurrentKeys(dtKey); //MTN-35226
		if (testToDT and dtKey &gt; toDT) then
			return;
		endif;
		
		if self.includesObject(eventTrans) then
			self.addObjectToTable(eventTrans, _numItems, _breakOut);
			_numItems := _numItems + 1;
		endif;
		if _breakOut then
			return;
		endif;
	endwhile;

end;

</source>
        <access>protected</access>
        <Parameter name="_eventByDTDict" type="CM_EventTransByDateTime"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="addObjectsForTypeDT" id="778beee3-5fd1-4873-9617-e1564054cfbf">
        <updating/>
        <source>addObjectsForTypeDT(_eventType 		: Integer;
					_eventByTypeDict : CM_EventTransByTypeDateTime; 
					_iter 			: Iterator input;
					_numItems 		: Integer io;
					_breakOut 		: Boolean output) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		
----------   ----------  --------------------------------------------------
*/
vars
	eventTrans		: CM_EventTransaction;
	toDT			: TimeStamp;
	eventTypeKey	: Integer;
	dtKey			: TimeStamp;
	testToDT		: Boolean;
begin
	toDT := self.filtToDT;
	testToDT := toDT &lt;&gt; null and toDT.isValid();
	
	while _iter.next(eventTrans) do : eventTransLoop
		_iter.getCurrentKeys(eventTypeKey, dtKey);  //MTN-35226
		if (eventTypeKey &lt;&gt; _eventType) or
		   (testToDT and dtKey &gt; toDT) then
			return;
		endif;
		
		if self.includesObject(eventTrans) then
			self.addObjectToTable(eventTrans, _numItems, _breakOut);
			_numItems := _numItems + 1;
		endif;
		if _breakOut then
			return;
		endif;
	endwhile;

end;

</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_eventByTypeDict" type="CM_EventTransByTypeDateTime"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="4f85e616-b0de-4fc3-b313-9109b5941fd1">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 July 2007 By cnwth2

Purpose:	This is currently a very efficient and optimised search - please be careful what you change and
			that changes do not effect performance in any way.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	terminal			: CM_Terminal;
	iter				: Iterator;
	eventByTypeDict 	: CM_EventTransByTypeDateTime;
	eventByDTDict 		: CM_EventTransByDateTime;
	eventType			: Integer;
	fromDT,
	toDT				: TimeStamp;
	breakOut			: Boolean;
begin
	
	self.beginClassNotification(CM_EventTransaction, false, Object_Create_Event, Response_Continuous, 1);
	
	self.tblData.rows := self.tblData.fixedRows;
	self.initDataTable();//changes columns depending on whether a user event type has been included
	self.allLoadedEvents.clear();
	
	fromDT := self.filtFromDT;
	if self.filtIncludeNoTerm then
		//check root - only events with no terminal should be in this collection
		if self.filtNeedFilterEventTypes then
			eventByTypeDict := app.myRoot.allEventsByTypeDateTime;
			iter := eventByTypeDict.createIterator();
			foreach eventType in self.filtAllEventTypes do
				eventByTypeDict.startKeyGeq(eventType, fromDT, iter);
				self.addObjectsForTypeDT(eventType, eventByTypeDict, iter, _numItems, breakOut);
				if breakOut then
					return;
				endif;
			endforeach;
		else
			eventByDTDict := app.myRoot.allEventsByDateTime;
			iter := eventByDTDict.createIterator();
			eventByDTDict.startKeyGeq(fromDT, iter);
			self.addObjectsForDT(eventByDTDict, iter, _numItems, breakOut);
			if breakOut then
				return;
			endif;
		endif;
	endif;
	
	//check through all selected terminals (if any)
	foreach terminal in self.filtAllTerminals do
		delete iter;
		
		if self.filtNeedFilterEventTypes then
			eventByTypeDict := terminal.allEventsByTypeDateTime;
			iter := eventByTypeDict.createIterator();
			foreach eventType in self.filtAllEventTypes do
				eventByTypeDict.startKeyGeq(eventType, fromDT, iter);
				self.addObjectsForTypeDT(eventType, eventByTypeDict, iter, _numItems, breakOut);
				if breakOut then
					return;
				endif;
			endforeach;
		else
			eventByDTDict := terminal.allEventsByDateTime;
			iter := eventByDTDict.createIterator();
			eventByDTDict.startKeyGeq(fromDT, iter);
			self.addObjectsForDT(eventByDTDict, iter, _numItems, breakOut);
		endif;
		if breakOut then
			return;
		endif;
	endforeach;
	
epilog
	delete iter;
	if _numItems &gt; 0 then
		self.zHideSearcher();
	endif;
end;
</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="5f55a922-ed07-494a-bd4c-8f1009d3e92e">
