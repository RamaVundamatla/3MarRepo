    <JadeMethod name="getTotalTaxAmountForLine" id="5136ac98-a901-41bc-9c5a-20ef5ccc324d">
        <source>getTotalTaxAmountForLine() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Nov 2018	jlgsl4	TFS 41230 - ADP - Invoice export
21 Oct 2019 cnwma1  Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars
	taxAmounts 	   : DecimalArray;
	totalTaxAmount,
	taxAmount 	   : Decimal[23,6];
begin
	totalTaxAmount := 0;
	create taxAmounts transient;
	self.getTaxAmountsForCharges(taxAmounts);
	foreach taxAmount in taxAmounts do
		totalTaxAmount := totalTaxAmount + taxAmount;
	endforeach;
	return totalTaxAmount;
epilog
	delete taxAmounts;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalTaxAmountForLineTen" id="592c6a74-8a89-4dbe-a257-a21ec63cd75d">
        <source>getTotalTaxAmountForLineTen() : Decimal;
/*

Purpose:			Return total tax amount in 10 decimal

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2025	navkc1 JIRA EPIC-34131 STORY-34815 GPHA | XML Invoice Export 10DC - Ten Decimal Place Methods

*/

vars
	taxAmounts			: DecimalArray;
	totalTaxAmount,
	taxAmount			: Decimal[23,10];
	
begin
	
	totalTaxAmount := 0;
	
	create taxAmounts transient;
	
	self.getTaxAmountsForCharges(taxAmounts);
	
	foreach taxAmount in taxAmounts do
		totalTaxAmount += taxAmount;
	endforeach;
	
	return totalTaxAmount;

epilog
	delete taxAmounts;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
