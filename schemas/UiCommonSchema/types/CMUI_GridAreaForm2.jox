    <JadeMethod name="userNotify" id="3af8fc3b-3f8d-4524-ad1f-abea82b12deb">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin

	if eventType = EVENT_CODE_COLOUR_CHANGE then
		self.frmColLegendTIs.redisplayViewModeCodes();
		// need to redraw to update colours of displayed TIs
		self.redraw();
		return;
	endif;
	
	if eventType = EVENT_DrawingAttrControllerAdd then
//		self.frmColLegendTIs.addRow();
	endif;

	inheritMethod(eventType, theObject, eventTag, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xmlToolbar" id="ca9e7065-9782-4e21-b3fd-54d238ffd454">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>xmlToolbar(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		This means HIDE the toolbars
//
// ---------------------------------------------------------------------------

vars

begin
	if set then
		if not _value then
			self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_HIDE;
			self.mnuWorkDisplayHideTB.caption := self.MNU_TOOLBAR_HIDE;
		else
			self.showHideToolbars(true);
			self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_SHOW;
			self.mnuWorkDisplayHideTB.caption := self.MNU_TOOLBAR_SHOW;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zzDelete_doBuildMnuStopsSub" id="7537720d-1902-4ffb-a3cd-f33fea6333d0">
        <source>zzDelete_doBuildMnuStopsSub(_index : Integer; _desc : String; _checked : Boolean;_theTI : CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2010	cnwcs5		par 24342 - DELETE THIS METHOD NOT USED
// ---------------------------------------------------------------------------

vars
	mnuChild	: MenuItem;

begin
	mnuChild := self.mnuStops.getMenuItem(_index); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := self.mnuStops.loadSubMenu(_index); // Clone menu
	endif;
	//self.mnuStopsSub.visible := false;
	mnuChild.caption := _desc;
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := _desc;
	mnuChild.userObject := _theTI;
	mnuChild.checked := _checked;



end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_checked" type="Boolean"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
</GUIClass>
