    <DbClassMap file="baserep"/>
    <Constant name="FILE_PARAMETERS" id="daf63a20-3614-4431-a627-5673b45f0b7e">
        <source>"baserepparams.txt"</source>
        <type name="String"/>
    </Constant>
    <Constant name="FILE_REPORTS" id="9c95ff14-733e-4b9e-b222-cb0f74cdad03">
        <source>"basereps.txt"</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="myBaseRoot" id="d7ad4bcc-cb91-4a75-9537-08137cb59525">
        <embedded/>
        <type name="CnEcBaseRoot"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myReportAgent" id="9e9d0e04-84f4-494e-801f-2c811790b602">
        <embedded/>
        <type name="CnEcReportAgent"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="browseForDirectory" id="5ccf763a-867c-40aa-8337-58bc879d26bf">
        <source>browseForDirectory(pTheFolder:FileFolder):String protected;
// --------------------------------------------------------------------------------
// Created:		17 February 2001 by cnwdad1
//
// Purpose:		Browse for a disk directory name.
//
// Parameters:	pTheFolder - The FileFolder to browse.
//
// Returns:		The name of the selected directory.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	directoryName	: String;
	
begin
	directoryName	:=	pTheFolder.browseForFolder("BaseReport files directory", "c:" &amp; global.cnEcGetFileSeparator());
	return directoryName;
end;</source>
        <access>protected</access>
        <Parameter name="pTheFolder" type="FileFolder"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="16c56f8e-11b5-4bbc-ad56-3bfff4f91e5d">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		17 February 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myBaseRoot	:=	CnEcBaseRoot.firstInstance();
	create self.myReportAgent transient;
end;</source>
    </JadeMethod>
    <JadeMethod name="createParameters" id="97e61385-1220-4130-a068-b1174b80bfa7">
        <source>createParameters(pTheParametersFile:CnEcFileDefinition) protected;
// --------------------------------------------------------------------------------
// Created:		17 February 2001 by cnwdad1
//
// Purpose:		Creates report parameter objects from a file structure.
//
// Parameters:	pTheParametersFile - The file structure containing the parameter
//					information.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFileRecord		: CnEcFileRecord;
	theRecordField		: CnEcFileField;
	theReportDefinition	: CnEcReportDefinition;
	reportName			: String;
	theReportParameter	: CnEcReportParameter;
	parameterName		: String;
	displayValue		: String;
	hasValueList		: Boolean;
	parameterType		: String;
	sequence			: Integer;
	errorMessage		: String;

begin
	foreach theFileRecord in pTheParametersFile.allRecords do
		foreach theRecordField in theFileRecord.allFields do
			if theRecordField.fieldNo = 1 then
				parameterName		:=	theRecordField.fieldValue;
			elseif theRecordField.fieldNo = 2 then
				reportName			:=	theRecordField.fieldValue;
			elseif theRecordField.fieldNo = 3 then
				displayValue		:=	theRecordField.fieldValue;
			elseif theRecordField.fieldNo = 4 then
				hasValueList		:=	(theRecordField.fieldValue = "true");
			elseif theRecordField.fieldNo = 5 then
				parameterType		:=	theRecordField.fieldValue;
			elseif theRecordField.fieldNo = 6 then
				sequence			:=	theRecordField.fieldValue.Integer;
			endif;
		endforeach;
		
		theReportDefinition	:=	self.myBaseRoot.allReportDefinitions.getAtKey(reportName);
		
		if theReportDefinition = null then
			write "Report '" &amp; reportName &amp; "' for the '" &amp; parameterName &amp; "' parameter is missing.";
			continue;
		endif;
		
		theReportParameter	:=	theReportDefinition.allReportParameters.getAtKey(parameterName);
		
		if theReportParameter = null then
			write "Creating Report Parameter: " &amp; parameterName &amp; "...";
			errorMessage	:=	self.myReportAgent.trxReportParameterCreate(	theReportDefinition,
																				parameterName,
																				displayValue,
																				sequence,
																				parameterType,
																				hasValueList,
																				theReportParameter);
		else
			write "Updating Report Parameter: " &amp; parameterName &amp; "...";
			errorMessage	:=	self.myReportAgent.trxReportParameterUpdate(	theReportParameter,
																				0,
																				theReportDefinition,
																				parameterName,
																				displayValue,
																				sequence,
																				parameterType,
																				hasValueList);
		endif;

		if errorMessage &lt;&gt; null then
			write "ERROR: " &amp; errorMessage;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheParametersFile" type="CnEcFileDefinition"/>
    </JadeMethod>
    <JadeMethod name="createReports" id="0bd0fee7-15d0-4112-9fac-1bc9d2ca1cc7">
        <source>createReports(pTheReportsFile:CnEcFileDefinition) protected;
// --------------------------------------------------------------------------------
// Created:		17 February 2001 by cnwdad1
//
// Purpose:		Creates report definition objects from a file structure.
//
// Parameters:	pTheReportsFile - The file structure containing the report
//					definition information.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFileRecord		: CnEcFileRecord;
	theRecordField		: CnEcFileField;
	theReportCategory	: CnEcReportCategory;
	categoryName		: String;
	theReportDefinition	: CnEcReportDefinition;
	reportName			: String;
	copies				: Integer;
	formName			: String;
	isLocalAllowed		: Boolean;
	marginBottom		: Integer;
	marginLeft			: Integer;
	marginRight			: Integer;
	marginTop			: Integer;
	orientation			: Integer;
	paperSize			: Integer;
	printerName			: String;
	reportDescription	: String;
	parameterArray		: CnEcReportParameterArray;
	errorMessage		: String;

begin
	create parameterArray transient;
	
	foreach theFileRecord in pTheReportsFile.allRecords do
		foreach theRecordField in theFileRecord.allFields do
			if theRecordField.fieldNo = 1 then
				reportName			:=	theRecordField.fieldValue;
			elseif theRecordField.fieldNo = 2 then
				categoryName		:=	theRecordField.fieldValue;
			elseif theRecordField.fieldNo = 3 then
				copies				:=	theRecordField.fieldValue.Integer;
			elseif theRecordField.fieldNo = 4 then
				formName			:=	theRecordField.fieldValue;
			elseif theRecordField.fieldNo = 5 then
				isLocalAllowed		:=	(theRecordField.fieldValue = "true");
			elseif theRecordField.fieldNo = 6 then
				marginBottom		:=	theRecordField.fieldValue.Integer;
			elseif theRecordField.fieldNo = 7 then
				marginLeft			:=	theRecordField.fieldValue.Integer;
			elseif theRecordField.fieldNo = 8 then
				marginRight			:=	theRecordField.fieldValue.Integer;
			elseif theRecordField.fieldNo = 9 then
				marginTop			:=	theRecordField.fieldValue.Integer;
			elseif theRecordField.fieldNo = 10 then
				orientation			:=	theRecordField.fieldValue.Integer;
			elseif theRecordField.fieldNo = 11 then
				paperSize			:=	theRecordField.fieldValue.Integer;
			elseif theRecordField.fieldNo = 12 then
				printerName			:=	theRecordField.fieldValue;
			elseif theRecordField.fieldNo = 13 then
				reportDescription	:=	theRecordField.fieldValue;
			endif;
		endforeach;
		
		theReportCategory	:=	self.myBaseRoot.allReportCategories.getAtKey(categoryName);
		
		if theReportCategory = null then
			write "Creating Report Category: " &amp; categoryName &amp; "...";
			errorMessage	:=	self.myReportAgent.trxReportCategoryCreate(categoryName, self.myBaseRoot, theReportCategory);
		else
			write "Updating Report Category: " &amp; categoryName &amp; "...";
			errorMessage	:=	self.myReportAgent.trxReportCategoryUpdate(theReportCategory, 0, categoryName);
		endif;
		
		if errorMessage &lt;&gt; null then
			write "ERROR: " &amp; errorMessage;
			continue;
		endif;
		
		theReportDefinition	:=	self.myBaseRoot.allReportDefinitions.getAtKey(reportName);
		
		if theReportDefinition = null then
			write "Creating Report: " &amp; reportName &amp; "...";
			errorMessage	:=	self.myReportAgent.trxReportDefinitionCreate(	reportName,
																				theReportCategory,
																				reportDescription,
																				formName,
																				printerName,
																				copies,
																				isLocalAllowed,
																				paperSize,
																				orientation,
																				marginTop,
																				marginBottom,
																				marginLeft,
																				marginRight,
																				parameterArray,
																				theReportDefinition);
		else
			write "Updating Report: " &amp; reportName &amp; "...";
			errorMessage	:=	self.myReportAgent.trxReportDefinitionUpdate(	theReportDefinition,
																				0,
																				reportName,
																				theReportCategory,
																				reportDescription,
																				formName,
																				printerName,
																				copies,
																				isLocalAllowed,
																				paperSize,
																				orientation,
																				marginTop,
																				marginBottom,
																				marginLeft,
																				marginRight,
																				parameterArray);
		endif;

		if errorMessage &lt;&gt; null then
			write "ERROR: " &amp; errorMessage;
		endif;
	endforeach;
epilog
	delete parameterArray;
end;</source>
        <access>protected</access>
        <Parameter name="pTheReportsFile" type="CnEcFileDefinition"/>
    </JadeMethod>
    <JadeMethod name="delete" id="c4c5e972-61af-4bf6-afb1-12c0a2eec625">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		17 February 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.myReportAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractReports" id="41f33878-c619-447c-a3e7-08736a369b5b">
        <source>extractReports():Boolean;
// --------------------------------------------------------------------------------
// Created:		17 February 2001 by cnwdad1
//
// Purpose:		Extracts report definitions and their parameters to a structured
//				disk file.
//
// Parameters:	None
//
// Returns:		True if the definitions were successfully extracted.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theReportDefinition	: CnEcReportDefinition;
	theReportParameter	: CnEcReportParameter;
	directoryName		: String;
	theFileFolder		: FileFolder;
	theReportsFile		: File;
	theParametersFile	: File;
	
begin
	create theFileFolder transient;
	directoryName	:=	self.browseForDirectory(theFileFolder);
	
	if directoryName = null then
		return false;
	else
		theFileFolder.fileName	:=	directoryName;
		create theReportsFile transient;
		create theParametersFile transient;
	endif;
	
	theReportsFile.fileName		:=	directoryName &amp; global.cnEcGetFileSeparator() &amp; self.FILE_REPORTS;
	
	if theReportsFile.isAvailable() then
		theReportsFile.purge();
	endif;
	
	theParametersFile.fileName	:=	directoryName &amp; global.cnEcGetFileSeparator() &amp; self.FILE_PARAMETERS;
	
	if theParametersFile.isAvailable() then
		theParametersFile.purge();
	endif;
	
	foreach theReportDefinition in self.myBaseRoot.allReportDefinitions do
		theReportsFile.writeLine(theReportDefinition.cnEcGetExtractString());
		
		foreach theReportParameter in theReportDefinition.allReportParameters do
			theParametersFile.writeLine(theReportParameter.cnEcGetExtractString());
		endforeach;
	endforeach;
	
	theReportsFile.close();
	theParametersFile.close();
		
	return true;
epilog
	delete theFileFolder;
	delete theReportsFile;
	delete theParametersFile;
	
	write "The reports and parameters have been extracted.";
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadReports" id="d328d454-1342-4bae-bc5f-f09ab272f570">
        <source>loadReports():Boolean;
// --------------------------------------------------------------------------------
// Created:		17 February 2001 by cnwdad1
//
// Purpose:		Imports report definitions and their parameters from a structured
//				disk file.
//
// Parameters:	None
//
// Returns:		True if the definitions were successfully imported.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFileFolder		: FileFolder;
	theReportsFile		: CnEcFileDefinition;
	theParametersFile	: CnEcFileDefinition;
	directoryName		: String;
	theCsvFile			: CnEcCsvFile;
	theFileRecord		: CnEcFileRecord;
	theRecordField		: CnEcFileField;

begin
	create theFileFolder transient;
	directoryName	:=	self.browseForDirectory(theFileFolder);
	
	if directoryName = null then
		return false;
	else
		theFileFolder.fileName	:=	directoryName;
		create theReportsFile transient;
		create theParametersFile transient;
		create theCsvFile transient;
	endif;
	
	// Load the reports file.
	
	theReportsFile.set(self.FILE_REPORTS, directoryName &amp; global.cnEcGetFileSeparator() &amp; self.FILE_REPORTS, directoryName);
	theCsvFile.cnEcLoadCsvFile(theReportsFile, true, 10);

	if (theCsvFile.isCancelled) then
		return false;
	endif;

	self.createReports(theReportsFile);

	// Now load the parameters file.
	
	theParametersFile.set(self.FILE_PARAMETERS, directoryName &amp; global.cnEcGetFileSeparator() &amp; self.FILE_PARAMETERS, directoryName);
	theCsvFile.cnEcLoadCsvFile(theParametersFile, true, 10);

	if (theCsvFile.isCancelled) then
		return false;
	endif;

	self.createParameters(theParametersFile);
	
	return true;
epilog
	delete theReportsFile;
	delete theParametersFile;
	delete theCsvFile;
	delete theFileFolder;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
