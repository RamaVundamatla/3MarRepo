    <JadeMethod name="getDebtorsString" id="82760258-360a-4d7c-9f40-ab59c3d569c3">
        <source>getDebtorsString() : String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aDebtor : CM_Debtor;
	aString : String;
begin
	foreach aDebtor in self.allConsolidatingDebtor do
		if aString = null then
			aString := aDebtor.name;
		else
			aString := aString &amp; ", " &amp; aDebtor.name;
		endif;
	endforeach;
	
	return aString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6cd09b41-2d33-4b51-bde9-297908261039">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_DebtorString then
		return self.getDebtorsString();
	elseif _attrName = ETRow_NumInvLineDesc then
		return self.allConsolidatingInvLineDesc.size.String;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvDescString" id="1fd915fc-6fb6-454d-8da8-7f73c80f8c08">
        <source>getInvDescString() : String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aInvoiceLineDesc : CM_InvoiceLineDesc;
	aString : String;
begin
	foreach aInvoiceLineDesc in self.allConsolidatingInvLineDesc do
		if aString = null then
			aString := aInvoiceLineDesc.narration;
		else
			aString := aString &amp; ", " &amp; aInvoiceLineDesc.narration;
		endif;
	endforeach;
	
	return aString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
