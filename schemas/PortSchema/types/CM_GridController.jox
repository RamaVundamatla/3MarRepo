        <source>getNumOverstowsForTI(_ti: CM_TrackedItem): Integer;
/* ---------------------------------------------------------------------------
Created:     29 June 2010 by cnwrs2

Purpose:     CCMS JMT 1956 - get num overstows for cargo item
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	if _ti = null then
