<Class name="CM_ShippingLine">
    <JadeMethod name="exportPDXMLMyCollections" id="dd13514a-f16e-4dcc-9e68-308c621fb41e">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	obj: Object;
begin
	if _property.name = CM_ShippingLine::shipPortGroups.name then
		_file.writeLine('&lt;'&amp;CM_ShippingLine::shipPortGroups.name&amp;'&gt;');
		foreach obj in self.shipPortGroups do
			_file.writeLine('&lt;class&gt;'&amp;obj.class.name&amp;'&lt;/class&gt;');
			obj.CM_ShipPortGroup.exportPDXML(_file, _objArray, true, true);
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_ShippingLine::shipPortGroups.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="35b40b76-12c7-40b0-9413-358ca4e85eb1">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars

begin
	inheritMethod(_name, _collectionsBlock);
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollectionsOLD" id="9aebd375-ef5a-4099-be45-dc45b7bfe3fd">
        <source>importPLXMLCollectionsOLD(_name: String; _collectionsBlock: String);

vars
	proxyArray: ObjectArray;
	newObject: Object;
begin
	create proxyArray transient;
	if _name = CM_ShippingLine::shipPortGroups.name then
		self.importPLXMLNewCollectionWorker(_collectionsBlock, _name, proxyArray);
		foreach newObject in proxyArray do
			newObject.CM_ShipPortGroup.setShippingLine(self);
		endforeach;
	endif;
	
epilog
	delete proxyArray;		// PAR #27874
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="903a2e1b-9320-4c00-9ab6-95ee3027385e">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_ShippingLine::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
