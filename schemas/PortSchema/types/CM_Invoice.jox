    <JadeMethod name="setDetailCode" id="261be58b-1bae-48dd-9078-0040541fd7b6">
        <updating/>
        <source>setDetailCode() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navab1	Initial creation
22 September 2022	navpw1	TFS: 54565 (54384)

*/
vars
	debtorSep : CM_InvTypeDebtorSeparation;

begin
	debtorSep := self.invoiceType.getDebtorSeparation(self.debtor); // ### BUG 56925 07MAR2023 NAVAB1
	
    // ### TFS 51219 25MAY2021 NAVAB1
	//if invoiceType.isCargoItemSpecific()
	if self.invoiceType.isCargoSpecificSeparation(debtorSep)
	 // ### BUG 56925 07MAR2023 NAVAB1 if invoiceType.isCargoItemSpecificDebtor(self.debtor)		// ### TFS 54565 (54384) 22Sep2022 NAVPW1
	and self.myTrackedItem &lt;&gt; null then
		self.detailCode := self.myTrackedItem.id;
	//elseif invoiceType.isVoyageGroupSpecific() 
	elseif self.invoiceType.isVoyageGrpSpecificSeparation(debtorSep)
	 // ### BUG 56925 07MAR2023 NAVAB1	elseif invoiceType.isVoyageGroupSpecificDebtor(self.debtor)	// ### TFS 54565 (54384) 22Sep2022 NAVPW1
	and self.myVoyage &lt;&gt; null then
		self.detailCode := self.myVoyage.voyageGroupCode;
	//elseif invoiceType.isVoyageSpecific() 
	elseif self.invoiceType.isVoyageSpecificSeparation(debtorSep)
	 // ### BUG 56925 07MAR2023 NAVAB1	elseif invoiceType.isVoyageSpecificDebtor(self.debtor)		// ### TFS 54565 (54384) 22Sep2022 NAVPW1 
	and self.myVoyage &lt;&gt; null then
		self.detailCode := self.myVoyage.code;
		
	//elseif invoiceType.isBOLSpecific()
	elseif self.invoiceType.isBOLSpecificSeparation(debtorSep)
	 // ### BUG 56925 07MAR2023 NAVAB1	elseif invoiceType.isBOLSpecificDebtor(self.debtor)			// ### TFS 54565 (54384) 22Sep2022 NAVPW1
	and self.myBOL &lt;&gt; null then
		self.detailCode := self.myBOL.number;
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setExtNumberForCreditNote" id="945a0164-56d7-48b8-b9fb-5db775da1efe">
        <updating/>
        <source>setExtNumberForCreditNote() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2023	navkc1	Initial creation navkc1	TFS CR 55305 TASK 55537

*/

vars
	bank 		: CM_Bank;
	category	: Integer;
begin
	
	category := self.category;
	
	if category &lt;&gt; InvoiceCategory_CreditNote then
		return;
	endif;
	
	bank := self.bank;
	
	if bank &lt;&gt; null then
		self.externalNumber := bank.generateNextCrdExtNumber();
	endif;
epilog

end;</source>
    </JadeMethod>
