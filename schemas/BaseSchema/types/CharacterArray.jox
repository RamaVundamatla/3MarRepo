<CollClass name="CharacterArray">
    <JadeMethod name="cnEcDoSort" id="5fd536cb-755d-4aad-b22d-6cde468b7ed0">
        <lockReceiver/>
        <updating/>
        <source>cnEcDoSort(pSorterObj : CnEcSorter) lockReceiver, updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	charValue		: Character;
	sortKeyObj		: Object;

begin
	foreach charValue in self do
		pSorterObj.addKey(charValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.allKeys do
		self.add(sortKeyObj.CnEcSortKey.getKey().Character);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="CnEcSorter"/>
    </JadeMethod>
    <JadeMethod name="cnEcLoadFromString" id="eceda029-532a-4a4d-a81e-4d1403533c40">
        <lockReceiver/>
        <updating/>
        <source>cnEcLoadFromString(pString:String) updating;
// --------------------------------------------------------------------------------
// Created:		02 October 2006 by cnwdad1
//
// Purpose:		Using the specified string, populate the receiver with all of the
//				string's characters.
//
// Parameters:	pString - The string to populate the receiver with.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	char	: Character;
	length	: Integer;
	pointer	: Integer;
	
begin
	length	:=	pString.length();
	
	foreach pointer in 1 to length do
		self.add(pString[pointer:1].Character);
	endforeach;
end;</source>
        <Parameter name="pString" type="String"/>
    </JadeMethod>
</CollClass>
