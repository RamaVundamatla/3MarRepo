    <JadeMethod name="setChangeTracker" id="18f2b9d6-6c77-4604-9d30-abbb0990b000">
        <source>setChangeTracker(_cmif : CMIF_BGPManagerChildren input) : Boolean protected;
// --------------------------------------------------------------------------------
// Created:		24 February 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
