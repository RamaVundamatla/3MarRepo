<Class name="CMIF_BlockStackShift" id="186586f7-014d-4fb1-a455-5966c025c178">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Used in block stack to shift containers up/down the stack.
-ve values in shiftBy move down, +ve shift up.
Readded to development 29/12/99 to enable compiles to work. Check sources when deleting.</text>
    <PrimAttribute name="inPlanMode" id="9ba613a7-33a9-4139-ab43-55e84af0eadf">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="shiftBy" id="85122b81-d72b-40d1-8526-448d57711cde">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
</Class>
