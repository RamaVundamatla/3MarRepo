    <JadeMethod name="trxCreateTrainEvent" id="88bc2261-54b7-45bc-a3f3-c4af7baba2bd">
        <updating/>
        <source>trxCreateTrainEvent(_pxyEvent : CM_EventTransaction input; _event : CM_EventTransaction output; _train : CM_Train io; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 October 2009	cnwndl1	Initial creation	Par 21519
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	_passport.useEventDeferUpdate := true; //30/05/2025	navkc1 JIRA MTN 34639
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateTrainEvent(_pxyEvent, _event, _train, _passport);
	_event.setCAMSTimeStamp(app.actualTimeServer);	

epilog
	//30/05/2025	navkc1 JIRA MTN 34639
	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;
	self.finaliseActivityWithPassport(_passport);

end;</source>
