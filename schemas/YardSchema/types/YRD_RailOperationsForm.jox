	optDirInTB.translateCaption(Xlat_0011024, locale);
	optDirOutTB.translateCaption(Xlat_0011026, locale);
	optPrintISORelWS.translateCaption(Xlat_0011027, locale);
	optPrintImpRelWS.translateCaption(Xlat_0011028, locale);
	optPrintList.translateCaption(Xlat_0011029, locale);
	shtAdvanced.translateCaption(Xlat_0012423, locale);
	shtSelectAreas.translateCaption(Xlat_0011030, locale);
	shtSelectTrains.translateCaption(Xlat_0014665, locale);
end;</source>
