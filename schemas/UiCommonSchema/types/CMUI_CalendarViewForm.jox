    <JadeMethod name="translateForm" id="10e64ae2-196b-42a1-a614-879dcdc0b1fb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015949, locale);
	btnBack.translateCaption(Xlat_0015950, locale);
	btnCalendar.translateCaption(Xlat_0015951, locale);
	btnCloseFilter.translateCaption(Xlat_0015952, locale);
	btnColorCancel.translateCaption(Xlat_0015953, locale);
	btnColorSave.translateCaption(Xlat_0015954, locale);
	btnFilter.translateBubbleHelp(Xlat_0015955, locale);
	btnFilter.translateCaption(Xlat_0015956, locale);
	btnNext.translateCaption(Xlat_0015957, locale);
	btnPrint.translateBubbleHelp(Xlat_0015958, locale);
	btnPrint.translateCaption(Xlat_0015959, locale);
	btnRefresh.translateCaption(Xlat_0015960, locale);
	btnShowFilter.translateCaption(Xlat_0015961, locale);
	btnToday.translateCaption(Xlat_0015962, locale);
	btnUserColours.translateBubbleHelp(Xlat_0015963, locale);
	btnUserColours.translateCaption(Xlat_0015964, locale);
	clrCurrentDay.translateBubbleHelp(Xlat_0015965, locale);
	clrDateBack.translateBubbleHelp(Xlat_0015966, locale);
	clrNonCurrMth.translateBubbleHelp(Xlat_0015967, locale);
	frmPeriod.translateCaption(Xlat_0015968, locale);
	lblCurrentDay.translateCaption(Xlat_0015969, locale);
	lblDateCol.translateCaption(Xlat_0015970, locale);
	lblNonCurrMth.translateCaption(Xlat_0015971, locale);
	lblUserPref.translateCaption(Xlat_0015972, locale);
