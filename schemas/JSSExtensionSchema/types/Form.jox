    <JadeMethod name="jssGetAllChildControls" id="64b46d19-db2d-4089-b4ed-aa05b69d5fa6">
        <source>jssGetAllChildControls(pAllChildControls: JSSControlArray io);
// --------------------------------------------------------------------------------
// Refer to the Window class abstraction for a description etc.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlIndex		: Integer;
	numberOfControls	: Integer;
	
begin
	pAllChildControls.clear();
	numberOfControls	:=	self.controlCount;
	
	foreach controlIndex in 1 to numberOfControls do
		pAllChildControls.add(controls(controlIndex));
	endforeach;
end;</source>
        <Parameter name="pAllChildControls" type="JSSControlArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssGetUserInput" id="ba79f4d3-caf0-4a3f-9fb4-59ec12824af8">
        <source>jssGetUserInput(pTitle:String; pInstruction:String; pDefaultValue:String):String;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 -  jssGetUserInput
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theInputForm	: JSSUserInputForm;
	inputValue		: String;

begin
	create theInputForm;
	theInputForm.setProperties(pTitle, pInstruction, pDefaultValue);

	if theInputForm.showModal() = 1 then
		inputValue	:=	theInputForm.getValue();
	endif;
epilog
	return inputValue;
end;</source>
        <Parameter name="pTitle" type="String"/>
        <Parameter name="pInstruction" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</GUIClass>
