vars

begin
	self.doTblRowColumChg(table);
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a679564f-5481-49c2-8dc1-bf368b8f8571">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017524, locale);
	btnAdd.translateCaption(Xlat_0016264, locale);
	btnNew.translateCaption(Xlat_0016265, locale);
	btnRemove.translateCaption(Xlat_0016266, locale);
	chkMax.translateCaption(Xlat_0016267, locale);
	chkQtyZero.translateCaption(Xlat_0016268, locale);
	lblInvoiceLine.translateCaption(Xlat_0016269, locale);
	lblInvoiceYA.translateCaption(Xlat_0016270, locale);
	lblQtyAttribute.translateCaption(Xlat_0016271, locale);
	lblQtyEnd.translateCaption(Xlat_0016272, locale);
	lblQtyMapType.translateCaption(Xlat_0016273, locale);
	lblQtyStart.translateCaption(Xlat_0016274, locale);
	optMapTypeEscalt.translateCaption(Xlat_0016275, locale);
	optMapTypeSingle.translateCaption(Xlat_0016276, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateInput" id="b21bf33b-9343-4085-9a31-46e3cae4f975">
        <source>validateInput() : Boolean;

vars

begin
	// no attribute selection
	if self.cmbQtyAttribute.listIndex &lt; 1 then
		app.msgBox('Please select an item.', self.lblQtyAttribute.caption, MsgBox_OK_Only+MsgBox_Information_Icon);	
		self.cmbQtyAttribute.setFocus();
		return false;
	endif;
	
	// no quantity range
	if self.txtQtyStart.text.Integer = 0 and
	   self.txtQtyEnd.text.Integer = 0 then
		app.msgBox('Please select a quantity range.', self.lblQtyStart.caption, MsgBox_OK_Only+MsgBox_Information_Icon);
		self.txtQtyStart.setFocus();
		return false;
	endif;
	
	// no invoice line desc selection
	if self.cmbInvoiceLine.listIndex &lt; 1 then
		app.msgBox('Please select an item.', self.lblInvoiceLine.caption, MsgBox_OK_Only+MsgBox_Information_Icon);	
		self.cmbInvoiceLine.setFocus();
		return false;
	endif;

	return true;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
