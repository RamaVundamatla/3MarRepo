    <JadeMethod name="backupRunning" id="b1800ddc-43c7-4f3e-bd1f-ce29cb7607c3">
        <source>backupRunning() : Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	sched: JACBackupSchedule;
begin
	sched := app.myServerAppObject.jacBackupScheduleObjects.getAtKeyGeq(JACBackupRunning, null);
	if sched = null or
	   sched.status &lt;&gt; JACBackupRunning then
		sched := app.myServerAppObject.jacBackupScheduleObjects.getAtKeyGeq(JACBackupActivated, null);
		if sched = null or
		   sched.status &lt;&gt; JACBackupActivated then
			sched := null;
		endif;
	endif;
	if sched = null then
		return false;
	else
		return true;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="btnBackupAbort_click" id="c6082854-1b6d-4bd2-bd27-fdc1d5cc7065">
        <controlMethod name="Button::click"/>
