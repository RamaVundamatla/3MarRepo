    <JadeMethod name="getWorkActualRate" id="e8a039e0-d650-41bb-9f22-769a56dcaa53">
        <source>getWorkActualRate() : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	toDoDuration,aveDuration,duration,rate : Integer;
	movesDone : Integer;
	etc : TimeStamp;
begin
	
	duration := self.getWorkDurationTime(app.actualTimeServer); // get total seconds so far worked// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	movesDone := self.getWorkTotalMovesCompleted();
	if movesDone = 0 then
		return null;
	endif;
			
	aveDuration := (duration / movesDone).Integer; // average for each move done so far
	if aveDuration &lt;&gt; 0 then
		rate := (SecondsPerHour / aveDuration).Integer;
		
		if rate &lt;= 0 then
			rate := 1;
		endif;
		return rate;
	else
		return null;
	endif;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkDepartureTargetRatePH" id="880a1d23-7726-42fd-a76e-2ccbf9359f72">
        <source>getWorkDepartureTargetRatePH(): Integer;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	// Par 9527 Made totHours huge so no precision error.
	totHours : Decimal[23,2];
	toDoDuration,aveDuration,duration,rate : Integer;
	movesDone,movesToDo,movesTotal : Integer;
	etc, endTS : TimeStamp;
	theVoyage : CM_Voyage;
begin
	theVoyage := self.myVoyage;
	endTS := app.actualTimeServer();
	if theVoyage &lt;&gt; null then
		if not theVoyage.departTargetDT.isValid() then // PAR 9475
			endTS := theVoyage.departTargetDT;
		endif;
	endif;
	
	duration := self.getWorkDurationTime(endTS); // get total seconds so far worked
	movesDone := self.getWorkTotalMovesCompleted();
	movesToDo := self.getWorkTotalMovesIncomplete();
	if movesDone = 0 then
		return null;
	endif;
	
	movesTotal := movesDone + movesToDo;
	
	totHours := (duration / SecondsPerHour).roundedTo(2);

	if totHours &gt; 0 then	// PAR 9712
		return (movesTotal / totHours).Integer;
	//else
	//	return (movesTotal / 1).Integer;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkDurationTime" id="55319309-d618-44f1-a90e-a73e1d07b08a">
        <source>getWorkDurationTime(entTS : TimeStamp): Integer;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	duration : Integer;
begin
//	duration := inheritMethod(entTS);

	if duration = null then
		duration := self.myVoyage.getWorkDurationTime(entTS);
	endif;
	return duration;
end;</source>
        <Parameter name="entTS" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkETCActual" id="a82bbd7a-4ef5-46e2-99a4-6e29a0a956ab">
        <source>getWorkETCActual() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		get Estimated Time to Completion
//
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	toDoDuration,aveDuration,duration : Integer;
	ratePH, movesDone,movesToDo, numSecs : Integer;
	etc : TimeStamp;
	numHours : Real;
begin

	movesDone := self.getWorkTotalMovesCompleted();
	movesToDo := self.getWorkTotalMovesIncomplete();
	if movesDone = 0 then
		return null;
	endif;
	ratePH := self.getWorkActualRateNoDelays();

	if ratePH &lt;&gt; 0 then // PAR 9393
		numHours := (movesToDo /ratePH);	
	endif;
	numSecs := (numHours * SecondsPerHour).Integer;
	
	etc := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	etc.addSecondsInterval(numSecs);
	return etc;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkETCTarget" id="8f297be3-59be-41a4-b8a8-07f716a9a709">
        <source>getWorkETCTarget() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		get Estimated Time to Completion using the Entered TI Per Hour Rate
//
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	ratePH, movesDone,
	movesToDo, numSecs	: Integer;
	etc					: TimeStamp;
	numHours			: Real;
	crane				: CM_Crane;
	terminal			: CM_Terminal;
	workedStartedAt, workCompletedAt : TimeStamp;

begin
	
	// ### When does work start?
	workedStartedAt := self.getWorkStartedAtTS(); // ### TFS 53105 30JUN2022 NAVAB1 

 // ### TFS 52413 29NOV2021 NAVAB1	movesDone := self.getWorkTotalMovesCompleted();
	movesToDo := self.getWorkTotalMovesIncomplete();
 // ### TFS 52413 29NOV2021 NAVAB1	if movesDone = 0 then
 // ### TFS 52413 29NOV2021 NAVAB1		return null;
 // ### TFS 52413 29NOV2021 NAVAB1	endif;
	
	//ratePH := self.myVoyage.tiPerHour;
	// 29099 Mar 2012 machines unique per terminal
	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null then
		crane := terminal.machines[self.crane].CM_Crane;
	endif;
	
	if crane &lt;&gt; null then
		ratePH := crane.targetRatePH;
	endif;
	
	if ratePH &lt;&gt; 0 then // PAR 9393
		numHours := (movesToDo /ratePH);	
	endif;
	numSecs := (numHours * SecondsPerHour).Integer;
	
	etc := workedStartedAt;  // ### TFS 53105 30JUN2022 NAVAB1 app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	etc.addSecondsInterval(numSecs);
	return etc;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkETCTargetGC" id="cc413c6a-5b04-4b3c-a537-6c804e5a164a">
        <source>getWorkETCTargetGC() : TimeStamp;
/*
Purpose:			

Date		Who		Reason
23 June 2022	navab1	TFS 53105
*/
constants
	Job_Type_Default : Integer = -1;
	Tsfr_Type_Default : Integer = 1;  // RORO 
	MilliSecondsPerHour = 3600000;  // 3,600,000

vars
	cargoTypeUsed : CM_CargoType;
	wp : CM_WorkPoint;
	job : CM_Job;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	totWeight : Decimal[23,4];
	totQuantity : Integer;
	cargoCounter : CMIF_WorkPointCargoRates;
	cargoCounters : CMIF_WorkPointCargoRatesByCT;
	jobType : Integer;
	rate : CM_WorkPointCargoRates;
	hoursToComplete : Decimal[23,2];
	secondsToComplete : Integer64;
	
	workedStartedAt, workCompletedAt : TimeStamp;
	targetRate : Decimal [23,4];
	precisionOverflowed : Boolean;
begin
	on Exception do self.handlePrecisionOverflow(exception, self, precisionOverflowed); 

	wp := self.myWorkPoint;

	if wp = null then
		return null;
	endif;
	
	
	// ### When does work start?
	workedStartedAt := self.getWorkStartedAtTS();
	
	
	// Get all the different cargo types being handled and accumulate the weights and quantities.
	create cargoCounters transient;
	
	foreach job in self.allJobsByOrder discreteLock do

		foreach wle in job.workListEntries discreteLock do
			ti := wle.myTrackedItem;
			
			if ti &lt;&gt; null then
				cargoTypeUsed:= ti.myCargoType;
				
				cargoCounter := cargoCounters[cargoTypeUsed];
				if cargoCounter = null then
					// ### Assume that same cargo type is either being discharged or loaded, not both
					if wle &lt;&gt; null then
						if wle.isReceipt then
							jobType := JOB_TYPE_DISCHARGE;
						elseif wle.isSOB then
							jobType := JOB_TYPE_SOB;
						else
							jobType := JOB_TYPE_LOAD;
						endif;	
					endif;
				
					create cargoCounter transient;
					cargoCounter.myCargoType := cargoTypeUsed;
					cargoCounters.add(cargoCounter);
					cargoCounter.jobType := jobType;
				endif;
				cargoCounter.totalQuantity += ti.totalQuantity;
				cargoCounter.totalWeight += ti.totalWeight;
			
			endif;
		endforeach;
	
	endforeach;

	// ### Get the rate for each cargo type on the work point and calculate how long the total amount for the cargo type is going to take
	// ### There will be one cargoCounter per cargo type
	workCompletedAt := workedStartedAt; // set start time

	foreach cargoCounter in cargoCounters do
		rate := wp.allWorkPointRates.getAtKey( cargoCounter.myCargoType, null, wp, jobType, Tsfr_Type_Default );
		if rate = null then
			//try with a non specific job type
			rate := wp.allWorkPointRates.getAtKey( cargoCounter.myCargoType, null, wp, Job_Type_Default, Tsfr_Type_Default );
		endif;
		if rate &lt;&gt; null then
			if cargoCounter.myCargoType.isBulk() then
				targetRate:= rate.targetRatePHWeight.max(1); // default to 1
				hoursToComplete := cargoCounter.totalWeight / targetRate;
				
				if rate.dailyHoursWorkable &gt; 0 
				and rate.dailyHoursWorkable &lt; hoursToComplete then
					hoursToComplete := hoursToComplete / rate.dailyHoursWorkable;
					hoursToComplete := hoursToComplete * 24;
				endif;
				secondsToComplete := (hoursToComplete * SecondsPerHour).Integer64;
	
				workCompletedAt.addSecondsInterval64(secondsToComplete); // add how long this cargo type will take
				
				cargoCounter.estimatedCompletion := workCompletedAt; // when will this cargo type finish
			else // break bulk containers vehicles
				targetRate:= rate.targetRatePHQuantity.max(1); // default to 1
				hoursToComplete := cargoCounter.totalQuantity / targetRate;
				
				if rate.dailyHoursWorkable &gt; 0 
				and rate.dailyHoursWorkable &lt; hoursToComplete then
					hoursToComplete := hoursToComplete / rate.dailyHoursWorkable;
					hoursToComplete := hoursToComplete * 24;
				endif;

				secondsToComplete := (hoursToComplete * SecondsPerHour).Integer64;
	
				workCompletedAt.addSecondsInterval64(secondsToComplete); // add how long this cargo type will take, this will push out further for each cargo type as we are adding the time to complete to the start
				
				cargoCounter.estimatedCompletion := workCompletedAt; // when will this cargo type finish			
			endif;
		else
			targetRate:= wp.targetRatePHWeight.max(1); // default to 1
			hoursToComplete := cargoCounter.totalWeight / targetRate;
			secondsToComplete := (hoursToComplete * SecondsPerHour).Integer64;
			if precisionOverflowed then
				secondsToComplete := 1;
			endif;
			
			workCompletedAt.addSecondsInterval64(secondsToComplete); // add how long this cargo type will take
			
			cargoCounter.estimatedCompletion := workCompletedAt; // when will this cargo type finish
		
		endif;
		
	endforeach;
	
	if cargoCounter &lt;&gt; null then // last cargoCounter will have the final time
		return cargoCounter.estimatedCompletion;
	endif;
	
	// Should not happen unless there are no rates setup on the cargo type.
	return self.myVoyage.estimatedDepartureDT;

epilog
	cargoCounters.purge();
	delete cargoCounters;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkFinishedDT" id="22a1a88f-8d0c-4293-bde1-ad4c996cacfc">
        <source>getWorkFinishedDT():TimeStamp protected;
/*
	Purpose:		Return time final job was completed		
	Parameters:			
	Return Value:		

Date			Who		Reason
12 August 2008	concms1	Par 17592 - Initial creation
*/
vars
	toTS		: TimeStamp;
	fromTS_theor: TimeStamp;
	tran		: CM_TITransaction;

begin
	toTS := null;
	
	tran := self.allShipReceivals.last;
	
	if tran &lt;&gt; null then
		toTS := tran.dateTime;
	endif;
	
	tran := self.allShipReleases.last;
	
	if tran &lt;&gt; null then
		if tran.dateTime &gt; toTS then
			toTS := tran.dateTime;
		endif;
	endif;

	return toTS;	// will be null if no transactions
end;</source>
        <access>protected</access>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkStarted" id="2dae7d6e-759f-4423-9b92-3841723b0e2a">
        <source>getWorkStarted(): TimeStamp;

vars
	tmpWorkStarted : TimeStamp;
begin
	//epr par 2/8/13 32088
	tmpWorkStarted:=null;
	tmpWorkStarted:=inheritMethod();

	if (not tmpWorkStarted.isValid()) then
		// this should never happen
		if self.myVoyage.shipExchangeDate &lt;&gt; null then
			tmpWorkStarted := self.myVoyage.shipExchangeDate;
		else
			tmpWorkStarted:=self.myVoyage.arrivedDT;
		endif;
	endif;
	return tmpWorkStarted;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkStartedAtTS" id="44963ff6-e2e3-420e-b8b4-691ba8f1ec33">
        <source>getWorkStartedAtTS() : TimeStamp;
/*
Purpose:			

Date		Who		Reason
30 June 2022	navab1	TFS 53105
*/

vars
	workedStartedAt: TimeStamp;
	voyage : CM_Voyage;
begin
	
	// ### When does work start?
	workedStartedAt := self.workStarted; //  self.workStarted is set by the first completed WLE
	
	if not workedStartedAt.isValid() then
		voyage := self.myVoyage;
		workedStartedAt := voyage.getWorkStartedAtTS();
	endif;

	return workedStartedAt;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="handlePrecisionOverflow" id="87f43aab-6fde-4391-8944-722e1049844a">
        <source>handlePrecisionOverflow(_exc : Exception; _obj : Object; _overflowed : Boolean io) : Integer;
/*
Purpose:			

Date		Who		Reason
01 July 2022	navab1	TFS 53105
*/

constants
	PrecisionOverFlow	= 4013;
	
vars
	returnVal		: Integer;

begin
	returnVal := Ex_Pass_Back;
	_overflowed := false;
	
	if _exc.errorCode = PrecisionOverFlow then
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
			_overflowed := true;
		endif;
	endif;

epilog
	return returnVal;
end;

	
</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_overflowed" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasJobSheetGotHeavies" id="2eced631-43d1-4740-b894-117830a874c2">
        <source>hasJobSheetGotHeavies() : Boolean;
// ---------------------------------------------------------------------------
// Created:		17 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	vJob : CM_VoyageJob;
begin
	
	foreach vJob in self.allJobsByJobNum discreteLock do
		if vJob.isDischarge then
			continue;
		endif;
		
		if vJob.hasJobGotHeavies() then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesWPOpHrs" id="6480e17f-556d-47ab-ab80-a3644c366d21">
        <source>includesWPOpHrs() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

begin

	if self.crane = null or self.myVoyage = null then
		return false;
	endif;

	return self.myVoyage.includesWPOpHrsFor( self.crane ); 

epilog

end;</source>
        <ReturnType type="Boolean"/>
