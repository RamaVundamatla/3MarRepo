    <JadeMethod name="optTasks_click" id="a5a46b6d-f8ab-4326-965a-38d997ab21e5">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optTasks_click(optionbutton: OptionButton input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation

*/

vars

begin

	self.clickOpts( false );

epilog

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="de4a6000-e131-4f96-9f05-74b16ff7a0f8">
        <source>populateCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation

*/

vars

	stop : CM_StopsTable;
	task : CM_ToDoTaskDesc;
	str : String;
	
	allStops : ObjectArray;
	allTasks : ObjectArray;
	obj : Object;
	
	user : CM_User;

begin

	self.cmbStops.clear();
	self.cmbTasks.clear();
	user := app.getMyUser();
	
	create allStops transient;
	create allTasks transient;
	
	if self.myRealDocumentAction &lt;&gt; null then
		foreach stop in self.myRealDocumentAction.allStopTablesToAdd do
			if allStops.includes( stop ) then
				continue;
			endif;
			self.cmbStops.itemObject[self.cmbStops.addItem( stop.shortHeading )] := stop;
			allStops.add( stop );
		endforeach;
		
		foreach task in self.myRealDocumentAction.allTaskDescsToAdd do
			if allTasks.includes( task ) then
				continue;
			endif;
			str := task.shortDescription;
			if not task.allResourceTypes.isEmpty then
				str := str &amp; " (" &amp; app.getErrorString(Uses_resources) &amp; ")";
			endif;
			self.cmbTasks.itemObject[self.cmbTasks.addItem( str )] := task;
			allTasks.add( task );
		endforeach;
		
	endif;
	
	if self.cmbStops.listCount &gt; 0 then
		self.cmbStops.addItemAt( app.getErrorString(AllStops), 1 );
		self.cmbStops.listIndex := 1;
		self.cmbStops.click( self.cmbStops);
	endif;
	
	if self.cmbTasks.listCount &gt; 0 then
		self.cmbTasks.addItemAt( app.getErrorString(AllTasks), 1 );
		self.cmbTasks.listIndex := 1;
		self.cmbTasks.click( self.cmbTasks);
	endif;
	
	if self.cmbStops.listCount &gt; 0 then
		self.optStops.value := true;
	elseif self.cmbTasks.listCount &gt; 0 then
		self.optTasks.value := true;
	endif;
	
	self.clickOpts( true );

epilog

	delete allStops;
	delete allTasks;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTblCargo" id="453d8eff-188a-4fa9-a8df-f9f296a6b177">
        <source>populateTblCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	reserveDetail : CM_ReserveDetail;
	bulkRelease : CM_BulkRelease;
	bookingItem : CM_BookingRefItem;
	booking : CM_BookingRef;
	alreadyKnown : CM_TIArray;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	heading : String;
	rowIndex : Integer;
	amount : Real;
	allTis	: CM_TISet;

begin

	app.mousePointer := Busy;

	create alreadyKnown transient;
	create tiArray transient;
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408

	if self.myRealDocumentAction &lt;&gt; null then
	
		if self.myRealDocumentAction.isReserveDetailAction then
			reserveDetail := self.myRealDocumentAction.CM_ReserveDetailActions.myReserveDetail;
			if reserveDetail &lt;&gt; null then
				bulkRelease := reserveDetail.myReserveHeader;
			endif;
		elseif self.myRealDocumentAction.isBookingItemAction then
			bookingItem := self.myRealDocumentAction.CM_BookingItemActions.myBookingItem;
			if bookingItem &lt;&gt; null then
				booking := bookingItem.myBookingReference;
			endif;
		endif;
		
		self.myRealDocumentAction.getAllTis( alreadyKnown );
	
		if reserveDetail &lt;&gt; null then
			//self.getBRPropsectiveCargo( bulkRelease, reserveDetail, tiArray );
			//29 Nov 2016	NLD	TFS 3016 / 2549 - No longer valid to list items that are not already assigned.
			reserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
			//if not reserveDetail.allTrackedItems.isEmpty then
			if not allTis.isEmpty then //23/06/2023	navkc1	CR 58406 Task 58408
				//reserveDetail.allTrackedItems.copy( tiArray );
				allTis.copy( tiArray ); //23/06/2023	navkc1	CR 58406 Task 58408
			endif;
		
		elseif bookingItem &lt;&gt; null then
			//bookingItem.findProspects( tiArray );
			//29 Nov 2016	NLD	TFS 3016 / 2549 - No longer valid to list items that are not already assigned.
			if not bookingItem.allTIs.isEmpty then
				bookingItem.allTIs.copy( tiArray );
			endif;
		
		endif;
		
		//OK you have a list of prospects now remove the ones already known to us, and display the rest
		foreach ti in alreadyKnown do
			if tiArray.includes(ti) then
				tiArray.remove(ti);
			endif;
		endforeach;
	
	endif;
	
	
	self.tblCargo.columns := 6;
	self.tblCargo.fixedColumns := 0;
	self.tblCargo.rows := 1;
	self.tblCargo.fixedRows := 1;
	heading :=  app.getErrorString(Select) &amp; Tab &amp; app.getErrorString(Cargo_group) &amp; Tab &amp; app.getErrorString(CargoId) &amp; Tab &amp; app.getErrorString(CargoType) &amp; Tab &amp; app.getErrorString(Location) &amp; Tab &amp; app.getErrorString(Amount);
	self.tblCargo.setCellText(1,1,heading);
	
	foreach ti in tiArray do
	
		amount := ti.totalQuantity.max(1);
		if ti.myCargoType.allowDuplicates then
			if ti.myCargoType.isBulkByVolume then
				amount := ti.totalVolume;
			elseif ti.myCargoType.isBulkByWeight then
				amount := ti.totalWeight;
			endif;	
		endif; 
		
		rowIndex := self.tblCargo.addItem( "0" &amp; Tab &amp; ti.getMyCargoGroupId &amp; Tab &amp; ti.id &amp; Tab &amp; ti.cargoTypeDescr &amp; Tab &amp; ti.locationId &amp; Tab &amp; amount.String);
		self.tblCargo.accessCell( rowIndex, 1 ).inputType := Table.InputType_CheckBox;
		self.tblCargo.accessCell( rowIndex, 2 ).inputType := Table.InputType_None;
		self.tblCargo.accessCell( rowIndex, 3 ).inputType := Table.InputType_None;
		self.tblCargo.accessCell( rowIndex, 4 ).enabled := false;
		self.tblCargo.accessCell( rowIndex, 4 ).inputType := Table.InputType_None;
		self.tblCargo.accessCell( rowIndex, 4 ).enabled := false;
		self.tblCargo.accessCell( rowIndex, 5 ).inputType := Table.InputType_None;
		self.tblCargo.accessCell( rowIndex, 5 ).enabled := false;
		self.tblCargo.accessCell( rowIndex, 6 ).inputType := Table.InputType_TextNumeric;
		self.tblCargo.accessCell( rowIndex, 6 ).enabled := false;
		self.tblCargo.accessRow( rowIndex ).itemObject := ti;
	endforeach;
	
	if not self.canUpdate then
		self.tblCargo.accessColumn( 1 ).enabled := false;
	endif;
	
	if not self.cargoGroupEnabled then
		self.tblCargo.accessColumn( 2 ).visible := false;
	endif;

epilog

	delete alreadyKnown;
	delete tiArray;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTblCargoIds" id="4980729e-1fd8-46af-b4ba-78a215b0a564">
        <source>populateTblCargoIds();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/09/2016	cnwndl1	Initial creation	TFS 2649 / 2001
28/09/2016	cnwdap1	TFS 2652 Check user can access stops / tasks for update
*/

vars

	documentActions : CM_DocumentActions;
	stop : CM_StopsTable;
	task : CM_ToDoTaskDesc;
	heading : String;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	tiIdArray : StringArray;
	index : Integer;
	requiresResource : Boolean;
	obj : Object;
	user : CM_User;							// TFS 2652
	disableItem : Boolean;					// TFS 2652
	remark : String;

begin

	app.mousePointer := Busy;
	user := app.getMyUser;					// TFS 2652

	self.tblCargoIDs.rows := 1;

	if self.myRealDocumentAction = null then
		self.tblCargoIDs.columns := 1;
		self.tblCargoIDs.setCellText(1,1, app.getErrorString(Action_declar_stops_tasks_proc) );
		return;
	endif;

	if self.optStops.value then
		self.tblCargoIDs.clear;
		if self.cmbStops.listCount &lt; 1 then
			self.tblCargoIDs.columns := 1;
			self.tblCargoIDs.setCellText(1,1,app.getErrorString(Stop_selected_process) );
			return;
		endif;
		if self.cmbStops.listIndex &gt; 0 then
			stop := self.cmbStops.itemObject[ self.cmbStops.listIndex ].CM_StopsTable;
		endif;
		
		
	elseif self.optTasks.value then
		self.tblCargoIDs.clear;
		if self.cmbTasks.listCount &lt; 1 then
			self.tblCargoIDs.columns := 1;
			self.tblCargoIDs.setCellText(1,1,app.getErrorString(Task_selected_process) );
			return;
		endif;
		if self.cmbTasks.listIndex &gt; 0 then
			task := self.cmbTasks.itemObject[ self.cmbTasks.listIndex ].CM_ToDoTaskDesc;
		endif;
		
		
	endif;
	
	self.tblCargoIDs.columns := 7;
	self.tblCargoIDs.fixedColumns := 1;
	self.tblCargoIDs.rows := 1;
	self.tblCargoIDs.fixedRows := 1;
	heading :=  "" &amp; Tab &amp; app.getErrorString(Select) &amp; Tab &amp; app.getErrorString(Cargo_group) &amp; Tab &amp; app.getErrorString(CargoId) &amp; Tab &amp; app.getErrorString(Quantity_complete) &amp; Tab &amp; app.getErrorString(Outstanding_total)&amp; Tab &amp; app.getErrorString(Remarks);
	self.tblCargoIDs.setCellText(1,1,heading);
	
	create tiArray transient;
	create tiIdArray transient;
	
	if stop &lt;&gt; null or task &lt;&gt; null then
		self.tblCargoIDs.accessColumn(7).visible := task &lt;&gt; null;
		self.myRealDocumentAction.getTIsToBeCompleted( tiArray, stop, task, null );
		remark := self.myRealDocumentAction.getRemarksFor(task);
		foreach ti in tiArray do
			if ti.hasBeenMerged then
				continue;
			endif;
			if not ti.isOnSite then
				continue;
			endif;
			if tiIdArray.includes(ti.id) then
				continue;
			endif;
			tiIdArray.add(ti.id);
			disableItem := false;														// TFS 2653
			if stop &lt;&gt; null then														// TFS 2653
				disableItem := not user.canUpdateStop(self.myTerminal, stop);			// TFS 2653
			elseif task &lt;&gt; null then													// TFS 2653
				disableItem := not user.canCompleteTodoTask(self.myTerminal, task);		// TFS 2653
			endif;																		// TFS 2653
			self.addInCompleteTableItem( stop, task, ti, disableItem, remark );					// TFS 2652
		endforeach;
		
	else
		if self.optStops.value then
			self.tblCargoIDs.accessColumn(7).visible := false;
			remark := null;
			foreach index in 1 to self.cmbStops.listCount do
				tiIdArray.clear();
				stop := self.cmbStops.itemObject[ index ].CM_StopsTable;
				if stop &lt;&gt; null then			
					self.myRealDocumentAction.getTIsToBeCompleted( tiArray, stop, null, null );
					foreach ti in tiArray do
						if ti.hasBeenMerged then
							continue;
						endif;
						if not ti.isOnSite then
							continue;
						endif;
						if tiIdArray.includes(ti.id) then
							continue;
						endif;
						tiIdArray.add(ti.id);
						disableItem := not user.canUpdateStop(self.myTerminal, stop);			// TFS 2653
						self.addInCompleteTableItem( stop, null, ti, disableItem, remark );				// TFS 2652
					endforeach;	
				endif;
			endforeach;
		
		elseif self.optTasks.value then
			self.tblCargoIDs.accessColumn(7).visible := true;
			foreach index in 1 to self.cmbTasks.listCount do
				tiIdArray.clear();
				task := self.cmbTasks.itemObject[ index ].CM_ToDoTaskDesc;
				if task &lt;&gt; null then
					remark := self.myRealDocumentAction.getRemarksFor(task);
					requiresResource := not task.allResourceTypes.isEmpty;
					self.myRealDocumentAction.getTIsToBeCompleted( tiArray, null, task, null );
					foreach ti in tiArray do
						if ti.hasBeenMerged then
							continue;
						endif;
						if not ti.isOnSite then
							continue;
						endif;
						if tiIdArray.includes(ti.id) then
							continue;
						endif;
						tiIdArray.add(ti.id);
						disableItem := not user.canCompleteTodoTask(self.myTerminal, task);					// TFS 2653
						self.addInCompleteTableItem( null, task, ti, requiresResource or disableItem, remark );		// TFS 2652
					endforeach;
				endif;
			endforeach;
		
		endif;
		
	endif;
	
	if not self.canUpdate then
		self.tblCargoIDs.accessColumn( 2 ).enabled := false;
	endif;
	
	if not self.cargoGroupEnabled then
		self.tblCargoIDs.accessColumn( 3 ).visible := false;
	endif;
	
epilog

	delete tiArray;
	delete tiIdArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTblTrans" id="7c73d17b-314f-40d9-b0c7-8da2ed7fa747">
        <source>populateTblTrans();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001

*/

vars

	entDef : EntTableDef;
	iter : Iterator;
	trx : CM_TITransaction;
	invalidObj : Boolean;
	ti : CM_TrackedItem;

begin

	app.mousePointer := Busy;

	self.tblTrans.rows := 1;
	
	entDef := app.myController.getEntTableDef(ETDef_TransForDocActions);
	self.tblTrans.setMyEntTableDef( entDef );
	self.tblTrans.setTblDataEntRowsFromDef( entDef );
	
	if not self.cargoGroupEnabled then
		self.tblTrans.hideColumnByColName(ETRow_CargoGroup);
	endif;
	
	on Exception do app.handleDeletedObject(exception, trx, invalidObj );
	on Exception do app.handleDeletedObject(exception, ti, invalidObj );
	
	if self.myRealDocumentAction = null then
		return;
	endif;
	
	iter := self.myRealDocumentAction.allCompletedStopTrx.createIterator;
	while iter.next(trx) do
		invalidObj := false;
		ti := trx.myTrackedItem;
		if invalidObj or ti = null or not ti.isOnSite then
			continue;
		endif;
		if not ti.isOnSite then
			continue;
		endif;
		if invalidObj then
			continue;
		endif;
		self.tblTrans.addItemObject(trx, trx.getAttributeStringForDefArray(self.tblTrans.allTblDataEntRows));
	endwhile;
	
	delete iter;
	iter := self.myRealDocumentAction.allCompletedTaskTrx.createIterator;
	while iter.next(trx) do
		invalidObj := false;
		ti := trx.myTrackedItem;
		if invalidObj or ti = null or not ti.isOnSite then
			continue;
		endif;
		if not ti.isOnSite then
			continue;
		endif;
		if invalidObj then
			continue;
		endif;
		self.tblTrans.addItemObject(trx, trx.getAttributeStringForDefArray(self.tblTrans.allTblDataEntRows));
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyDocumentAction" id="43122421-12eb-40b3-94ce-17a3bc4bb7fe">
        <updating/>
        <source>setMyDocumentAction( _documentAction : CM_DocumentActions ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation	TFS 2649

*/

vars

	pxyResDetail : CM_ReserveDetail;
	realResDetail : CM_ReserveDetail;
	pxyBookingItem : CM_BookingRefItem; 
	realBookingItem : CM_BookingRefItem; 

begin

	self.myPxyDocumentAction := _documentAction;
	if _documentAction &lt;&gt; null and _documentAction.isTransient then
		if _documentAction.isReserveDetailAction then
			pxyResDetail := _documentAction.CM_ReserveDetailActions.myReserveDetail;
			if pxyResDetail &lt;&gt; null then
				realResDetail := pxyResDetail.pxyGetRealObject().CM_ReserveDetail;
				if realResDetail &lt;&gt; null then
					self.myRealDocumentAction := realResDetail.myReserveDetailActions;
				endif;
			endif;
		elseif _documentAction.isBookingItemAction then
			pxyBookingItem := _documentAction.CM_BookingItemActions.myBookingItem;
			if pxyBookingItem &lt;&gt; null then
				realBookingItem := pxyBookingItem.pxyGetRealObject().CM_BookingRefItem;
				if realBookingItem &lt;&gt; null then
					self.myRealDocumentAction := realBookingItem.myBookingRefItemActions;
				endif;
			endif;
		endif;
	elseif _documentAction &lt;&gt; null and not _documentAction.isTransient then 
		self.myRealDocumentAction := _documentAction;
	endif;

epilog

end;</source>
        <Parameter name="_documentAction" type="CM_DocumentActions"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5b3d930c-d119-443d-89e8-9cb59f881a71">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001

*/

vars

	msg : String;

begin

	self.minimumWidth := 420;
	self.minimumHeight := 400;

	self.canUpdate := app.getMyUser.canDo( self.myTerminal, PmAdmDocActionsMaint );
	
	self.cargoGroupEnabled := app.isCargoGroupEnabled;

	inheritMethod();
	
	if self.left &lt; app.mainForm.left then
		self.left := app.mainForm.left + self.left;
	endif;
	if self.top &lt; app.mainForm.top then
		self.top := app.mainForm.top + self.top;
	endif; 
	
	if self.myPxyDocumentAction = null then
		self.lblDocName.caption := "No Document Action selected!";
		self.lblDocName.foreColor := Red;
		self.lblDocName.fontBold := true;
	else
		self.lblDocName.caption := self.myPxyDocumentAction.getParentDocId &amp; "  /  " &amp; self.myPxyDocumentAction.getDocumentId;
	endif;
	
	if self.myRealDocumentAction = null then
		msg := "Cargo can not be assigned to the Document Actions, until the Release has been saved.";
		app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only );
	endif;
	
	self.populateCombos();
	
	self.btnCancel.caption := app.getErrorString(Close);
	
	self.btnOk.parent := self.shtAddCompl;
	self.btnOk.left := self.shtAddCompl.width - self.btnOk.width - 5;
	self.btnOk.top := self.shtAddCompl.height - self.btnOk.height + 14;
	
	self.fldMain.topSheet := self.shtAddCompl;
	
	self.btnOk.enabled := self.canUpdate;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblTrans_contextMenu" id="5ed98994-7077-4f28-93da-f81caa09c77f">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTrans_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2016	cnwndl1	Initial creation

*/

vars

	obj : Object;
	tiTrx : CM_TITransaction;
	canUpdate : Boolean;
	x1 : Real;
	y1 : Real;

begin

	obj := table.accessRow(table.row).itemObject;
	if obj &lt;&gt; null and obj.isKindOf( CM_TITransaction ) then
		tiTrx := obj.CM_TITransaction;
	endif;
	
	self.mnuDelete.visible := false;
	self.mnuUnDelete.visible := false;
	
	if tiTrx &lt;&gt; null then
		if tiTrx.deleted then
			self.mnuUnDelete.visible := true;
			self.mnuUnDelete.userObject := tiTrx;
		else
			self.mnuDelete.visible := true;
			self.mnuDelete.userObject := tiTrx;
		endif;
	endif;
	
	x1	:=	x;
	y1	:=	y;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(mnuDelUndel, x1.Integer, y1.Integer);
	
	return false;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="30fe2a6c-dacb-49e7-ae1b-f408f54caa0a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 October 2016 09:00:17.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021358, locale);
	lblDocName.translateCaption(Xlat_0021359, locale);
	mnuDelUndel.translateCaption(Xlat_0021360, locale);
	mnuDelete.translateCaption(Xlat_0021361, locale);
	mnuUnDelete.translateCaption(Xlat_0021362, locale);
	optStops.translateCaption(Xlat_0021363, locale);
	optTasks.translateCaption(Xlat_0021364, locale);
	shtAddCargo.translateCaption(Xlat_0021365, locale);
	shtAddCompl.translateCaption(Xlat_0021366, locale);
	shtDelCompl.translateCaption(Xlat_0021367, locale);
end;</source>
    </JadeMethod>
</GUIClass>
