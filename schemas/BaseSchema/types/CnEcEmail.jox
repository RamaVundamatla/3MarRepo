        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xHandlerEmail" id="108a03fd-7b23-4846-92cb-97db1f69f514">
        <updating/>
        <source>xHandlerEmail(pTheExceptionObject: Exception):  Integer updating, protected; 

constants
	Unavailable1	: Integer = 450;
	Unavailable2	: Integer = 550;
	Notlocal		: Integer = 551;
	Namenotallowed	: Integer = 553;
	Objnotcreated	: Integer = 100000;
	Nomailserver	: Integer = 100001;
	Messandfile		: Integer = 100002;
	Nomessorfile	: Integer = 100003;
	Nosendfrom		: Integer = 100004;
	Nosendto		: Integer = 100005;
	Nosubject		: Integer = 100006;
	Morethan1000	: Integer = 100007;
	Nonascii		: Integer = 100008;
	Invalidtype		: Integer = 100009;
	Nomessfile		: Integer = 100010;
	Sendfromover64	: Integer = 100011;
	Sendtoover64	: Integer = 100012;
	Morethan100to	: Integer = 100013;
	Replyover64		: Integer = 100014;
	Senderover64	: Integer = 100016;
	Noattach		: Integer = 100017;
	Invalattach		: Integer = 100018;

vars
	returnvalue	: Integer;
	errorCode	: Integer;

begin
	returnvalue	:=	0;
	errorCode	:=	pTheExceptionObject.errorCode;

	if errorCode = Unavailable1 or errorCode = Unavailable2 then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Notlocal  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Namenotallowed  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Objnotcreated  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Nomailserver  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Messandfile  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Nomessorfile  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Nosendfrom  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Nosendto  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Nosubject  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Nomailserver  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Nonascii  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Invalidtype  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Nomessfile  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Sendfromover64  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Sendtoover64  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Morethan100to  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Replyover64  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Senderover64  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Noattach  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Invalattach  then
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = Morethan1000  then
		returnvalue :=  Ex_Abort_Action;
	endif;

	if returnvalue = 0 then
		returnvalue := Ex_Pass_Back;	 //default dialog
	endif;		

	return returnvalue;
end;</source>
        <access>protected</access>
        <Parameter name="pTheExceptionObject" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
