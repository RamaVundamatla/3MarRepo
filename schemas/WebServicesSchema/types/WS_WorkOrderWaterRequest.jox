    <JadeMethod name="setProxyFromObject" id="2fc64e0b-901c-4a1c-aaf0-15ef240e6254">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodWaterRequest) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation

*/

vars
	transferTypeObj : CM_VoyageJobTransferType;
begin
	inheritMethod(_object);
	
	create self.myHMSResourceUsed transient;
	self.myHMSResourceUsed.setProxyFromWorkOrder(_object);
	
	transferTypeObj := app.myRoot.allVoyageJobTransferTypes[_object.transferType];
	if transferTypeObj &lt;&gt; null then
		self.transferType:=transferTypeObj.getOidAsString;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_WodWaterRequest"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="2b625e6a-2680-4510-bc4c-2661ce0e3a0c">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WodWaterRequest input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlger1	Initial creation

*/

vars
	resource		: HMS_Resource;
	resourceType 	: HMS_ResourceType;
	transferTypeObj	: CM_VoyageJobTransferType;
	transferTypeCode : Integer;
begin
	inheritMethod(_pxyWorkOrder);
	
	self.validateDateIsDuringVoyage( self.voyage, self.requiredByDT.asTimeStampFromWebInterface );	//28 Sep 2018	NDL	TFS 41148
	self.validateDateIsDuringVoyage( self.voyage, self.myHMSResourceUsed.fromDateTime.asTimeStampFromWebInterface );	//28 Sep 2018	NDL	TFS 41148
	self.validateDateIsDuringVoyage( self.voyage, self.myHMSResourceUsed.toDateTime.asTimeStampFromWebInterface );	//28 Sep 2018	NDL	TFS 41148
	
	if self.myHMSResourceUsed.resource  &lt;&gt; null then
		resource:=app.myPassport.getObjectOfTypeFromOid(self.myHMSResourceUsed.resource,HMS_Resource).HMS_Resource;	
	endif;
	if self.myHMSResourceUsed.resourceType  &lt;&gt; null then
		resourceType:= app.myPassport.getObjectOfTypeFromOid(self.myHMSResourceUsed.resourceType ,HMS_ResourceType).HMS_ResourceType;
	endif;
	
	if self.transferType &lt;&gt; null then
		transferTypeObj:=app.myPassport.getObjectOfTypeFromOid(self.transferType,CM_VoyageJobTransferType).CM_VoyageJobTransferType;
		if transferTypeObj &lt;&gt; null then
			transferTypeCode:=transferTypeObj.id;
		endif;
	endif;
	
	_pxyWorkOrder.setProxyWodWaterRequest(self.myHMSResourceUsed.fromDateTime.asTimeStampFromWebInterface,
											self.myHMSResourceUsed.toDateTime.asTimeStampFromWebInterface,
											self.myHMSResourceUsed.quantity,transferTypeCode,
											resource,
											resourceType);
											
											
											
epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WodWaterRequest" usage="input"/>
    </JadeMethod>
</Class>
