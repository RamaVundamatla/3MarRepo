    <JadeMethod name="pxyCreateUpdateProxy" id="96d2fbdb-8457-45ea-9890-0ed1c77ea25a">
        <source>pxyCreateUpdateProxy(): SelfType;

// cmwrs1 28 July 2011 CCMS 1009
//Date			Who		Reason

vars
	pxy	: SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();

	completedOK := true;
	return pxy;
epilog
	if not completedOK then
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="783d2b6b-23ca-4def-bb02-746f9c0fb64c">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// cmwrs1 28 July 2011 CCMS 1009
//
vars

begin
	inheritMethod(_proxyEDITI);
	self.layoutId := _proxyEDITI.layoutId;
	self.longPos := _proxyEDITI.longPos;
	self.transPos := _proxyEDITI.transPos;
	self.pointOrder := _proxyEDITI.pointOrder;
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
