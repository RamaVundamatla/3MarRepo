    <JadeMethod name="getCategory" id="ff6d12b1-7265-4740-b2ed-83f4fa30fffe">
        <source>getCategory() :Integer protected;
// ---------------------------------------------------------------------------
// Created:		14 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	result	: Integer;
	ti		: CM_TrackedItem;
begin
	ti := self.myTI;
	
	if ti.cargoType = TI_CargoType_Container then   // ISO Container...
		if (not ti.isFull) then  // Empty...
	    	result := Category_Empty;
	  	elseif self.porthole or self.powered then // Reefer, porthole, powered etc...
	    	result := Category_Full_Reefer;
	  	else // General (not reefer, porthole, powered.)
			result := Category_Full;
		endif;
	else
		result := Category_Other;
	endif;
  	
  	return result;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="onVoyage" id="a826bcd0-5c40-4333-a6fd-427b1370220d">
        <source>onVoyage() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		14 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
begin
	if self.showSequenced then
  		return (self.myTI.plannedState = TI_STATE_ONSHIP) or 
  				(self.myTI.isRehandle and self.myTI.plannedState = TI_STATE_NORMAL);
	else
  		return (self.myTI.state = TI_STATE_ONSHIP);
  	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="porthole" id="58de3b1b-c332-407a-a3e9-9ed211af67d9">
        <source>porthole() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		14 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	cont : CM_Container;
begin
// Porthole AND requires temperature and no cou...
	if self.myTI.isKindOf(CM_Container) then
		cont := self.myTI.CM_Container;
		return cont.isPortHole and cont.requiresTemperature and not cont.hasCOU;
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="powered" id="a6f3b010-aa4a-4794-ac4b-dfe038e7516d">
        <source>powered() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		14 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if self.myTI.isKindOf(CM_Container) then		
		if self.myTI.CM_Container.requiresPower and not self.porthole then
			return true;
		endif;
	endif;

	return false;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="set" id="ce0fb6b1-468a-4e32-8bec-9a3b97656275">
        <source>set(_category : Integer; _onship: Boolean; _forty: Boolean; _imExStatus: Integer; _portHole: Boolean; _powered: Boolean) :Integer protected;
// ---------------------------------------------------------------------------
// Created:		14 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	---------	--------------------------------------------------
// 07/06/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	result : Integer;
begin
	//clear out if SOB	- don't care what category
	if _imExStatus = TI_TransitStatusSOB and
		self.myTI.getTransitStatus = TI_TransitStatusSOB then
			return 1;
	elseif _imExStatus = TI_TransitStatusDLR and
		self.myTI.getTransitStatus = TI_TransitStatusDLR then
			//keep going...
	elseif _imExStatus &lt;&gt; self.myTI.getImExStatus then
		if _imExStatus = TI_IMEX_STATUS_EXPORT and self.myTI.getImExStatus = TI_IMEX_STATUS_TRANSHIP and self.myVoyage = self.myTI.myExportVoyage then	// PAR #23645 CCMS 1116
			// we want this one - continue																												// PAR #23645 CCMS 1116
		else																																			// PAR #23645 CCMS 1116
			return 0;
		endif;
	endif;
	
	//match category
	if  _category &lt;&gt; self.getCategory() then
		return 0;
	endif;
	
	//Export or DLR containers from here - categories and imExStatus match
	
	if _onship then
		if not self.onVoyage then
			return 0;
		endif;
	else
		if (not self.myTI.state = TI_STATE_NORMAL) and (not self.myTI.state = TI_STATE_ONSHIP) then
			return 0;
		endif;
	endif;
	
	//clear out if "other" than container - dont care about reefer, forty etc.
	if _category = Category_Other then
		return 1;
	endif;
	
	if _portHole then
		if not self.porthole then
			return 0;
		else
			return 1;
		endif;
	endif;
	
	if _powered then
		if not self.powered then
			return 0;
		else
			return 1;
		endif;
	endif;
	
	//now do length 
	
	if _forty &lt;&gt; self.myTI.isAttributeTrue(TI_Attrib_IsForty) then
		return 0;
	endif;
	
	return 1;	//should be right
	
end;</source>
        <access>protected</access>
        <Parameter name="_category" type="Integer"/>
        <Parameter name="_onship" type="Boolean"/>
        <Parameter name="_forty" type="Boolean"/>
        <Parameter name="_imExStatus" type="Integer"/>
        <Parameter name="_portHole" type="Boolean"/>
        <Parameter name="_powered" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSequenced" id="ab39721b-7c60-4764-a947-10ae1d5ab89b">
        <updating/>
        <source>setSequenced(_value: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		17 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	self.showSequenced := _value;
	
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSummaryFields" id="7565b67f-0965-4601-b3ec-06042eb5d273">
        <updating/>
        <source>setSummaryFields() updating;
// ---------------------------------------------------------------------------
// Created:		14 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	//								category,				onship	forty,	imexStatus,			  portHole,		powered
	
	self.shipGen20 			:= set(	Category_Full, 			true,	false,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.shipGen20DLR 		:= set(	Category_Full,			true,	false,	TI_TransitStatusDLR,  false,		false);
	self.shipGen40 			:= set(	Category_Full,			true,	true,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.shipGen40DLR 		:= set(	Category_Full,			true,	true,	TI_TransitStatusDLR,  false,		false);
	self.shipMT20 			:= set(	Category_Empty,			true,	false,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.shipMT20DLR 		:= set(	Category_Empty,			true,	false,	TI_TransitStatusDLR,  false,		false);
	self.shipMT40 			:= set(	Category_Empty,			true,	true,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.shipMT40DLR 		:= set(	Category_Empty,			true,	true,	TI_TransitStatusDLR,  false,		false);
	self.shipOther 			:= set(	Category_Other,			true,	false,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.shipPortHole 		:= set(	Category_Full_Reefer,	true,	false,	TI_IMEX_STATUS_EXPORT, true,		false);
	self.shipPortHoleDLR 	:= set(	Category_Full_Reefer,	true,	false,	TI_TransitStatusDLR,  true,		false);
	self.shipPowered 		:= set(	Category_Full_Reefer,	true,	false,	TI_IMEX_STATUS_EXPORT, false,		true);
	self.shipPoweredDLR 	:= set(	Category_Full_Reefer,	true,	false,	TI_TransitStatusDLR,  false,		true);
	self.shipReefer20 		:= set(	Category_Full_Reefer,	true,	false,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.shipReefer20DLR 	:= set(	Category_Full_Reefer,	true,	false,	TI_TransitStatusDLR,  false,		false);
	self.shipReefer40 		:= set(	Category_Full_Reefer,	true,	true,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.shipReefer40DLR 	:= set(	Category_Full_Reefer,	true,	true,	TI_TransitStatusDLR,  false,		false);
	self.shipSOB 			:= set(	Category_Full,			true,	false,	TI_TransitStatusSOB,  false,		false);
	self.yardGen20 			:= set(	Category_Full,			false,	false,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.yardGen40 			:= set(	Category_Full,			false,	true,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.yardMT20 			:= set(	Category_Empty,			false,	false,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.yardMT40 			:= set(	Category_Empty,			false,	true,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.yardOther 			:= set(	Category_Other,			false,	false,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.yardPortHole 		:= set(	Category_Full_Reefer,	false,	false,	TI_IMEX_STATUS_EXPORT, true,		false);
	self.yardPowered 		:= set(	Category_Full_Reefer,	false,	false,	TI_IMEX_STATUS_EXPORT, false,		true);
	self.yardReefer20 		:= set(	Category_Full_Reefer,	false,	false,	TI_IMEX_STATUS_EXPORT, false,		false);
	self.yardReefer40 		:= set(	Category_Full_Reefer,	false,	true,	TI_IMEX_STATUS_EXPORT, false,		false);
/*	
	write self.myTI.id &amp; " " &amp; self.shipGen20.String &amp; " " &amp;  		
	self.shipGen20DLR.String &amp; " " &amp;  		 
	self.shipGen40.String &amp; " " &amp;  		 	
	self.shipGen40DLR.String &amp; " " &amp;  		
	self.shipMT20.String &amp; " " &amp;  		 	
	self.shipMT20DLR.String &amp; " " &amp;  		
	self.shipMT40.String &amp; " " &amp;  		 	
	self.shipMT40DLR.String &amp; " " &amp;  		
	self.shipOther.String &amp; " " &amp;  		 	
	self.shipPortHole.String &amp; " " &amp;  		 
	self.shipPortHoleDLR.String &amp; " " &amp;  		
	self.shipPowered.String &amp; " " &amp;  		 	
	self.shipPoweredDLR.String &amp; " " &amp;  		 
	self.shipReefer20.String &amp; " " &amp;  		 	
	self.shipReefer20DLR.String &amp; " " &amp;  		
	self.shipReefer40.String &amp; " " &amp;  		 	
	self.shipReefer40DLR.String &amp; " " &amp;  		
	self.shipSOB.String &amp; " " &amp;  		 		
	self.yardGen20.String &amp; " " &amp;  		 		
	self.yardGen40.String &amp; " " &amp;  		 		
	self.yardMT20.String &amp; " " &amp;  		 		
	self.yardMT40.String &amp; " " &amp;  		 		
	self.yardOther.String &amp; " " &amp;  		 		
	self.yardPortHole.String &amp; " " &amp;  		 	
	self.yardPowered.String &amp; " " &amp;  		 	
	self.yardReefer20.String &amp; " " &amp;  		 	
