    <ImplicitInverseRef name="btnCancel" id="b84eb01d-54e9-491b-8f25-7c023c05eb66">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <PrimAttribute name="isCancelled" id="9ea6ac70-42ba-402a-9a43-f4dda346046f">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="lblDescription" id="4c4520f7-aade-4678-957e-8a78318cb9f7">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="progressBar" id="dfb825b4-25a9-4248-8161-f60b4975279a">
        <embedded/>
        <type name="ProgressBar"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="3493e4c8-66b2-4e81-8f67-e478b0c4abc6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		29 May 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isCancelled	:=	true;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkCancel" id="2246e876-040d-4db0-b4c2-92c6e9a405cb">
        <updating/>
        <source>checkCancel():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		02 September 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the user has confirmed
//				their request to cancel the progress.
//
// Parameters:	None
//
// Returns:		True if the user confirmed the cancel, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	userResponse	: Integer;
	returnValue		: Boolean;
	
begin
	self.visible	:=	false;
	userResponse	:=	app.msgBox(	"Do you wish to cancel ?",
									"Cancel",
									MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
	
	if userResponse = MsgBox_Return_Yes then
		returnValue	:=	true;
		unloadForm();
	else
		self.resetCancelFlag();
		returnValue		:=	false;
		self.visible	:=	true;
	endif;
epilog
	return returnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="ae74d021-07ad-4a52-8d8b-41267f62a687">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		29 May 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/05/2002	cnwdad1		Removed the setting of the "alwaysOnTop" flag because,
//							if an application had cause to show a dialog box, then
//							the dialog would appear beneath this progress form.
// --------------------------------------------------------------------------------
begin
	self.centreWindow();
//	self.alwaysOnTop(true);		// cnwdad1 08/05/2002 - Removed at User request.
end;</source>
    </JadeMethod>
    <JadeMethod name="resetCancelFlag" id="7c65736a-7d13-469b-a4e7-26aa78990568">
        <updating/>
        <source>resetCancelFlag() updating;
// --------------------------------------------------------------------------------
// Created:		27 August 2001 by cnwdad1
//
// Purpose:		Resets the cancelled flag back to a value of false.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isCancelled	:=	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="startProgress" id="9eec3168-2527-45b3-87c2-8e0d07d262ef">
        <updating/>
        <source>startProgress(pDescription:String; pParts:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		29 May 1999 by cnwdad1
//
// Purpose:		Used to show the progress of a lengthy process.
//
// Parameters:	pDescription (String) - A description of the process.
//				pParts (Integer) - The number of parts in the process.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.lblDescription.caption	:=	pDescription;
	self.progressBar.partsInJob	:=	pParts;
	self.progressBar.partsDone	:=	0;
	self.refreshNow();
end;</source>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pParts" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="b3bd8590-a0fd-4899-96ca-af4f0f232a2d">
        <source>updateProgress(pPartsDone:Integer);
// --------------------------------------------------------------------------------
// Created:		29 May 1999 by cnwdad1
//
// Purpose:		Used to show the progress of a lengthy process.
//
// Parameters:	pPartsDone (Integer) - The number of completed parts in the process.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.progressBar.partsDone	:=	pPartsDone;
	self.refreshNow();
	btnCancel.doWindowEvents(0);
end;</source>
        <Parameter name="pPartsDone" type="Integer"/>
    </JadeMethod>
</GUIClass>
