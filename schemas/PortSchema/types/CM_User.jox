    <JadeMethod name="getDefaultCarrierForWeb" id="25f4cf60-7190-4baa-a887-64465be09bf4">
        <source>getDefaultCarrierForWeb() : CM_Carrier;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2013	cnwmc5:1	Initial creation

*/

vars
	carrier : CM_Carrier;
	failedDAC : CM_DataAccessController;
begin
	foreach carrier in app.myRoot.allCarriers discreteLock do
		if carrier.isNotAvailableForEntry then
			continue;
		endif;
		
		if not carrier.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
		return carrier;
	endforeach;
epilog

end;</source>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
