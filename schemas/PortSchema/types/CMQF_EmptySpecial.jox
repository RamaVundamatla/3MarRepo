<Class name="CMQF_EmptySpecial" id="9572a583-55de-45cd-8f25-d1313edced5d">
    <superclass name="CMQF_Container"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="doRecSummaryInfo" id="4a20a373-19dc-4fca-a336-5088fac30741">
        <source>doRecSummaryInfo(_mtTrans: CM_JRWEmpty input; ti: CM_Container);
// ---------------------------------------------------------------------------
// Created:		25 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	summaryCont	: CMIF_SummaryContainer;
	todoTask	: CM_ToDoTask;
begin
	
	if _mtTrans.allTrackedItems.includes(ti) then
		return;	
	endif;
	
	_mtTrans.allTrackedItems.add(ti);
	
	create summaryCont transient;
	summaryCont.id := ti.id.trimBlanks;
	summaryCont.isoCode := ti.isoType.trimBlanks;
	summaryCont.myTI := ti;
	summaryCont.setTIFields();
	_mtTrans.allSummaryTIs.add(summaryCont);
	
	foreach todoTask in ti.allToDoTasksToDo do
		if todoTask.toDoTaskDescTransType = TRANS_TYPE_WASH then		// 04/11/2010 cnwar2 #26198
		//if todoTask.toDoTaskDescTrans = CM_Wash.name then
			summaryCont.toWash := 1;
		elseif todoTask.toDoTaskDescTransType = TRANS_TYPE_PRETRIP then	// 04/11/2010 cnwar2 #26198
		//elseif 	todoTask.toDoTaskDescTrans = CM_PreTrip.name then
			summaryCont.toPreTrip := 1;
		elseif todoTask.toDoTaskDescTransType = TRANS_TYPE_REPAIR then	// 04/11/2010 cnwar2 #26198
		//elseif 	todoTask.toDoTaskDescTrans = CM_Repair.name then
			summaryCont.toRepair := 1;
		elseif todoTask.toDoTaskDescTransType = TRANS_TYPE_SURVEY then	// 04/11/2010 cnwar2 #26198
		//elseif 	todoTask.toDoTaskDescTrans = CM_Survey.name then
			summaryCont.toSurvey := 1;
		endif;

	endforeach;

end;</source>
        <Parameter name="_mtTrans" type="CM_JRWEmpty" usage="input"/>
        <Parameter name="ti" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="filterEmptySpecial" id="be83379a-7c5c-47b6-a7b6-2647a0446a34">
        <updating/>
        <source>filterEmptySpecial(_jrwTrans: CM_JRWEmpty input; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		25 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave in begin load state
//14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
vars
	iterTrans	: Iterator;
	iterTI		: Iterator;
	transaction	: CM_TITransaction;
	ti			: CM_TrackedItem;
//	transArray	: CM_TransactionArray;
	theTransTypes	: IntegerArray;
//	tmpTransArray	: CM_TransactionArray;
	tempCollection	: CM_TITransactionByDateTypeDict;
	tranType		: Integer;
	terminal		: CM_Terminal;
	endDateTime		: TimeStamp;
	ls				: Boolean;
	keyType			: Integer;
	keyID			: String;
	lBulk			: CM_BulkRelease;
	breakOut		: Boolean;
begin 
	//-----------------
	// Part one transactions (ins, outs, washes, surveys, pretrips, repairs)
	//-----------------
	endDateTime.setTime("23:59:59.999".Time);
	endDateTime.setDate(self.endDate);

	create tempCollection  transient;
	create theTransTypes transient;	
	
	self.setupTransTypes(theTransTypes);
	
	foreach tranType in theTransTypes do
		tempCollection.clear();
		foreach terminal in self.allTerminals do
			terminal.getTITxnsForTypeAll(tranType, self.startDate.TimeStamp, endDateTime, null, self, tempCollection);
		endforeach;
		//sort
		foreach transaction in tempCollection do
			self.sortTrans(_jrwTrans, transaction, _passport);
		endforeach;
	endforeach;
	//-----------
	// Part two
	// Pending todo tasks
	//-----------

	app.cmsBeginLoad(ls);
	
	foreach terminal in self.allTerminals do
		if iterTI &lt;&gt; null then
			delete iterTI;
		endif;
		
		iterTI := terminal.allOnsiteTIsByCargoTypeId.createIterator();
		terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container, null, iterTI);
		
		while iterTI.next(ti) do
			iterTI.getCurrentKeys(keyType, keyID);	//MTN-35226	
		
			if keyType &lt;&gt; TI_CargoType_Container then
				break;
			endif;
	
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
//				if breakOut then
//					return;
//				endif;
				self.doRecSummaryInfo(_jrwTrans, ti.CM_Container);
			endif;
		endwhile;	

	endforeach;

	app.cmsEndLoad(ls);
	//-----------
	// Part three
	// Active releases
	//-----------
	
	app.cmsBeginLoad(ls);
	
	foreach terminal in self.allTerminals do
//	
//		foreach lBulk in terminal.allBulkReleaseByStatusByCode where lBulk.status = BR_ACTIVE do // AKB2005MAY
		foreach lBulk in terminal.allBulkReleaseByTypeByStByCd discreteLock where lBulk.status = BR_ACTIVE  do
			if self.includeBulkRelease(lBulk) then
				_jrwTrans.allActiveReleases.add(lBulk);
			endif;
		endforeach;
	endforeach;
	app.cmsEndLoad(ls);

epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347

//	delete transArray;
	delete iterTrans;
	delete iterTI;	
	delete theTransTypes;
end;</source>
        <Parameter name="_jrwTrans" type="CM_JRWEmpty" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includeBulkRelease" id="d407e9ea-c7fd-4b11-bb8f-fd8e34cc4734">
        <source>includeBulkRelease(_bulkRel: CM_BulkRelease):Boolean;
// ---------------------------------------------------------------------------
// Created:		25 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if self.myOperator = null or (self.myOperator = _bulkRel.myOperator) then
		return true;
	endif;

	return false;
	
end;</source>
        <Parameter name="_bulkRel" type="CM_BulkRelease"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="ff1ca8b1-b1eb-491e-b41e-4edd5d10385d">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		09 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if _ti.isEmpty and _ti.isStorage and
	   inheritMethod(_ti, _passport, _breakOut) then
	 	return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupTransTypes" id="88ada12c-318c-4dc6-96a4-34a975e035f8">
        <source>setupTransTypes(_transTypes: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:		25 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	_transTypes.clear();
	//todos
	_transTypes.add(TRANS_TYPE_REPAIR);
	_transTypes.add(TRANS_TYPE_SURVEY);
	_transTypes.add(TRANS_TYPE_WASH);
	_transTypes.add(TRANS_TYPE_PRETRIP);
	//recs
	_transTypes.add(TRANS_TYPE_REC_SHIP);
	_transTypes.add(TRANS_TYPE_REC_ROAD);
	_transTypes.add(TRANS_TYPE_REC_RAIL);
	_transTypes.add(TRANS_TYPE_REC_ROAD_INTER_TERM);
	_transTypes.add(TRANS_TYPE_REC_RAIL_INTER_TERM);
	//rels
	_transTypes.add(TRANS_TYPE_REL_SHIP);
	_transTypes.add(TRANS_TYPE_REL_ROAD);
	_transTypes.add(TRANS_TYPE_REL_RAIL);
	_transTypes.add(TRANS_TYPE_REL_ROAD_INTER_TERM);
	_transTypes.add(TRANS_TYPE_REL_RAIL_INTER_TERM);
end;</source>
        <Parameter name="_transTypes" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sortTrans" id="7c4a2f7b-cf88-49d2-94ab-ada8785da61d">
        <updating/>
        <source>sortTrans(_mtTrans: CM_JRWEmpty input; _trans: CM_TITransaction; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		25 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ti				: CM_TrackedItem;
	type			: Integer;
	breakOut		: Boolean;
begin
	
	type := _trans.type;
	ti := _trans.myTrackedItem;
	
	if ti = null or _trans.deleted then
		return;
	endif;
	
	if ti.state = TI_STATE_DELETED then
		return;
	endif; 
	
	if not self.checkStatusIncludesObject(ti, _passport, breakOut) then
//	if not self.includesObject(ti, _passport, breakOut) or breakOut then

		return;
	endif;
	
	if type = TRANS_TYPE_REPAIR
	or type = TRANS_TYPE_SURVEY
	or type = TRANS_TYPE_WASH
	or type = TRANS_TYPE_PRETRIP then
		_mtTrans.allToDoTrans.add(_trans);
		return;
	endif;
	
	if type = TRANS_TYPE_REC_SHIP 
	or type = TRANS_TYPE_REC_ROAD 
	or type = TRANS_TYPE_REC_RAIL 
	or type = TRANS_TYPE_REC_ROAD_INTER_TERM 
	or type = TRANS_TYPE_REC_RAIL_INTER_TERM then
		_mtTrans.allRecTrans.add(_trans);
		return;
	endif;
	
	if type = TRANS_TYPE_REL_SHIP
	or type = TRANS_TYPE_REL_ROAD
	or type = TRANS_TYPE_REL_RAIL
	or type = TRANS_TYPE_REL_RAIL_INTER_TERM
	or type = TRANS_TYPE_REL_ROAD_INTER_TERM then
		_mtTrans.allRelTrans.add(_trans);
		return;
	endif;

end;</source>
        <Parameter name="_mtTrans" type="CM_JRWEmpty" usage="input"/>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
