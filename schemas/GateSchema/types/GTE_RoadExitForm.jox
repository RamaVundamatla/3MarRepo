    <JadeMethod name="deleteCurrentJobEntry" id="71b6a511-7a32-4a57-b4aa-04d6ea35c676">
        <updating/>
        <source>deleteCurrentJobEntry(_vvr : CM_VehicleVisitRecord; _reason : String) updating, protected;
/*

Purpose:			Deletes the vehicle visit job entry

Parameters:			_vvr	CM_VehicleVisitRecord	The vehicle visit record to delete the jobs for
					_reason	String					The reason we deleted the jobs

Return Value:		NONE

Date		Who		Reason
16 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

vars
	result		: Integer;
	wleArray 	: CM_WLEArray;
	wle			: CM_WorkListEntry;
	
begin
	create wleArray transient;
	_vvr.vehicle.allRoadJobs.first.workListEntries.copy(wleArray ); 	
	if wleArray.isEmpty then
		return;
	endif;
	
	foreach wle in wleArray discreteLock do
		while true do
			app.myTrxDA.trxDeleteJobEntry(wle, _reason, app.myPassport); 
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(XLAT_Road_operations), app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endforeach;

epilog
	delete wleArray;
	
end;</source>
        <access>protected</access>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="doBtnRetroChange" id="2607a30b-5635-417b-8980-731b41d7cd17">
        <updating/>
        <source>doBtnRetroChange(_isRetroMode: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit

*/

vars
	rowId,
	startRowId : Integer;
	job			: CM_Job;
begin
	self.clearFilter();
	self.doFilterTable();
	startRowId := self.tblData.fixedRows + 1;
	
	foreach rowId in startRowId to self.tblData.rows do
		job := self.tblData.accessRow(rowId).itemObject.CM_Job;
		if job.isRetrospective &lt;&gt; _isRetroMode then
			self.tblData.accessRow(rowId).visible := false;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_isRetroMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCancelVVR" id="35ea54ad-28ec-4270-9dc2-15ae35f524b3">
        <updating/>
        <source>doCancelVVR(_vvr : CM_VehicleVisitRecord) protected, updating;
/*

Purpose:			Cancels a vehicle visit record

Parameters:			_vvr	CM_VehicleVisitRecord	The vehicle visit record to cancel.

Return Value:		NONE

Date		Who		Reason
16 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

vars
	vehicle: 	CM_Vehicle;
	form: 		GTE_VehicleTurnaroundReason;
	vvr 		: CM_VehicleVisitRecord;
	result:		Integer;
begin
	
	if not app.myCurrentUserCan(self.myTerminal, PmGteGateCanCancelFlexiJob) then
		return;
	endif;
	
	vvr := _vvr;
	
	if vvr = null then
		return;
	endif;
		
	if vvr.isBulkGateVVR then		
		form := app.loadForm(GTE_VehicleTurnaroundReason, 
							GTE_Assistant, 
							false, false, true, 
							self.myTerminal, null).GTE_VehicleTurnaroundReason;
		result := form.showModal();
		if result = IDOK then
			if vvr.myRoadJob = null and vvr.isUpdatable and not vvr.isCancelled then		
				self.doVehicleVisitCancel(vvr,form.txtReason.text);
			else	
				if  vvr.status = CM_VehicleVisitRecord.Status_Unverified then
					if vvr.myRoadJob = null then
						self.doUpdateChangeStatus(vvr);
					else
						self.deleteCurrentJobEntry(vvr,form.txtReason.text);
					endif;
				endif;
			endif;
		else
			return;
		endif;		
	else
		if  vvr.status &lt;&gt; vvr.Status_Cancelled then							
			form := app.loadForm(GTE_VehicleTurnaroundReason, 
							GTE_Assistant, 
							false, false, true, 
							self.myTerminal, null).GTE_VehicleTurnaroundReason;
			result := form.showModal();
			if result = IDOK then
				self.doVehicleVisitCancel(vvr, form.txtReason.text);
			else
				return;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="doChangeInspectionStatus" id="c2c45ca1-0df9-477c-9d00-ed5b39718cc7">
        <updating/>
        <source>doChangeInspectionStatus(_newStatus : String; _vvr : CM_VehicleVisitRecord) updating;
/*

Purpose:            

Parameters:            

Return Value:        

Date                Who        Reason
14 December 2022    navmp20    ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes

*/


vars
    pxyVVR : CM_VehicleVisitRecord;
    theReturn : Integer;
begin
	pxyVVR := app.createUpdateProxy(_vvr).CM_VehicleVisitRecord;
	if pxyVVR = null then
		return;
	endif;
    pxyVVR.updateGateCheckDetails(false, _newStatus, app.actualTimeServer);
    while true do
        app.myTrxUA.trxUpdateVehicleVisitFlexi(pxyVVR,app.myPassport);
        if app.myPassport.trxCompletedOK then
            // Clear errors/warnings from form and err/warnings window
            self.clearErrorWarnings();
            global.beep;
            break;
        else
            theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
            if app.myPassport.noErrors and
               theReturn = IDOK then
                // there must have just been warnings that the user has acknowledged so ..
                app.myPassport.warningsAcknowledged    := true;
                continue;
            endif;
            self.setAllErrorWarnings(app.myPassport);    // copies errors to this form and shows in err/warnings window
            return;
        endif;
        break;
    endwhile;

epilog
	delete pxyVVR;
end;</source>
        <Parameter name="_newStatus" type="String"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="aeaa996c-ef53-4dfe-84d1-e3060fdee7b7">
