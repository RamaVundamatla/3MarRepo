    <JadeMethod name="doResize" id="700f62a8-e57f-4156-b9cf-3a81e3536b1f">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		05 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
constants
	GAP : Real = 10;
vars
	topVal		: Real;
	widthVal	: Real;
begin
	inheritMethod();
	
	//Reefer sheet
	self.splReefer.move(0,0,self.frmDetailsTop.clientWidth,self.frmDetailsTop.clientHeight);
	self.splReefer.cnEcResizeContents();//move(0,0,self.frmDetailsTop.width,self.frmDetailsTop.height);
//	self.tblReadings.move(0,0,self.tblReadings.parent.width, self.tblReadings.parent.height-GAP);
//	self.tblReeferInfo.move(0,0,self.tblReeferInfo.parent.width, self.tblReeferInfo.parent.height);
	
//	self.tblReeferInfo.cnAdjustColumnWidths();
//	self.tblSearch.cnAdjustColumnWidths();
//	self.adjustTblReadings();
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowReeferInfo" id="9ea940fe-4f1b-4f55-af56-8c44465fd467">
        <updating/>
        <source>doShowReeferInfo() updating;
// ---------------------------------------------------------------------------
// Created:		05 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 08/12/2009	cnwdap1		CCMS MES 1007 Other carg can now be reefers, not just containers
vars
	intRow		: Integer;
	theRow		: JadeTableRow;
	//reefer	: CM_Container;		// CCMS 1007
	reefer		: CM_TrackedItem;		// CCMS 1007
	strInfo		: String;
	infoArray	: HugeStringArray;
begin
	self.tblReeferInfo.rows := 0;
//	self.tblReeferInfo.fixedColumns := 1;
//	self.tblReeferInfo.accessColumn(1).width := 125;
	//reefer := self.myCurrentObject.CM_Container;		// CCMS 1007
	reefer := self.myCurrentObject.CM_TrackedItem;		// CCMS 1007
	self.myDisplayedReefer := reefer;	
	
	if reefer = null then
		//clear
		return;
	endif;
	
	create infoArray transient;
	
	reefer.getReeferMonInfo(infoArray);
	
	foreach strInfo in infoArray do
		intRow := self.tblReeferInfo.addItem(strInfo);
		if intRow mod 2 = 0 then
			self.tblReeferInfo.accessRow(intRow).backColor := self.colorRow1;
		else
			self.tblReeferInfo.accessRow(intRow).backColor := self.colorRow2;
		endif;

		if strInfo[1:11] = "Curtains In" then
			self.tblReeferInfo.accessRow(intRow).backColor := LightGreen;
		endif;
		
	endforeach;
	
epilog
	delete infoArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowWorkListTIs" id="74910bdb-0527-41b4-990b-01bc9068e1eb">
        <updating/>
        <source>doShowWorkListTIs() updating;
//----------------------------------------------------------------
//	Created:	30 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ls				: Boolean;
	ignoreConnected	: Boolean;
begin

	//if app.getMyTerminal.allReeferConnectTIs.isEmpty then
	if self.myTerminal.allReeferConnectTIs.isEmpty then
		app.msgBox(app.getErrorString(Empty_Reefer_Connection_List), app.getErrorString(Display_Connection_List), MsgBox_OK_Only + MsgBox_Information_Icon); 
		return;
	endif;

	self.tblData.clearAllData();

	app.cmsBeginLoad(ls);
	
	self.resetNotifications();
	
	self.copyWorkListToTable(false);	//requires a CCMS to do anything other than (false)
	
	if self.mode = Mode_Search then
		if self.modalDialogReturnValue = ModalDialogReturn_Option1 then
			// Cancel and do NOT return results
			self.tblData.clearAllData();
			self.resetNotifications();
			self.zShowThumbnailData(null);
		endif;
	endif;
	
	self.setCaption("Reefer Monitoring - LastConnection Report");
	
epilog
	app.cmsEndLoad(ls);

end;</source>
    </JadeMethod>
