<Class name="Feature">
    <JadeMethod name="getFeatureType" id="f2cefa1c-060b-4a06-ace6-5848de99c565">
        <source>getFeatureType() : Type;
// ---------------------------------------------------------------------------
// Created:     16 July 2003 by cnwsb1
//
// Purpose:		Returns the Type of any of the named features.
//				The feature can be any of the following:
//				- Attribute
//				- Reference
//				- Method
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
23 Mar 2017	cnwkpd1	Fix issue with JMTRelease application Data Dump install by using metadata
					for methods as well
	
*/

vars
	rtnType : ReturnType;
	
begin
	if self.type = null then
		// Methods
		if self.name = DataDumpGetOidStringMethod then
			// JADE PAR 30280 - there is an issue with sendMsg and getOidString
			return Object;
		elseif self.isKindOf(Method) then
			rtnType := self.Method.returnType;
			if rtnType &lt;&gt; null then
				return rtnType.type;
			endif;
		endif;
	else
		// Attributes and references
		return self.type;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="Type"/>
    </JadeMethod>
    <JadeMethod name="getRefs" id="1a63e383-bb65-484b-bbb9-6b067229ac61">
        <source>getRefs(startSchema : Schema; schemasToCheck : SchemaColl; indirectRefs, visited : FeatureSet input);

// recurse through method refs, and add to indirectRefs collection ONLY IF they are in the schemasToCheck collection

vars
	meths : MethodSet;
	meth : Method;
begin
	create meths transient;
	getMethodRefs(meths);
	
	foreach meth in meths do
	
		if visited.includes(meth) or indirectRefs.includes(meth) then	// avoid circular refs
			continue;
		endif;
		visited.add(meth);

		if schemasToCheck.includes(meth.getSchema) then
			indirectRefs.add(meth);
		else
			meth.getRefs(startSchema, schemasToCheck, indirectRefs, visited);
		endif;
	endforeach;
	
epilog
	delete meths;
end;</source>
        <Parameter name="startSchema" type="Schema"/>
        <Parameter name="schemasToCheck" type="SchemaColl"/>
        <Parameter name="indirectRefs" type="FeatureSet" usage="input"/>
        <Parameter name="visited" type="FeatureSet" usage="input"/>
    </JadeMethod>
</Class>
