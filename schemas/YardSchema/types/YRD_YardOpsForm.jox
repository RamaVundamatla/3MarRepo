    <JadeMethod name="filterForCargoID" id="cfca29c3-6531-4c5b-9e25-a5fd0a74149d">
        <source>filterForCargoID();

/*

Purpose:			
Not realy a filter as such , just find a (partial) match WLE in the table and select that.
Parameters:			

Return Value:		


Date		Who		Reason
14 September 2009	cnwrd1	Initial creation

*/

vars
	wle : CM_WorkListEntry;
	aTI : CM_TrackedItem;
	idx,
	fixedRows,
	pos,
	rows : Integer;
	invalidWLE,
	invalidTI : Boolean;
begin


	
	// no cargo id to filter?
	if self.filterCargoID = null then 
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, wle, invalidWLE);
	on Exception do app.handleDeletedObject(exception, aTI, invalidTI);
	
	// step through table rows for WLE's check if has TI and check that TI's cargo ID
	
	rows := self.tblWorkEntries.rows;
	fixedRows := self.tblWorkEntries.fixedRows;
	
	foreach idx in fixedRows to rows do
		wle := self.tblWorkEntries.accessRow(idx).itemObject.CM_WorkListEntry;
		if wle = null then
			continue;
		endif;		
	//	wle.fetchLatest();
	//	resynchObject(wle);
		
		
		aTI := wle.myTrackedItem;
		
		if aTI = null then
			continue;
		endif;

		pos := aTI.id.pos(self.filterCargoID, 1);
		//pos := self.filterCargoID.pos(aTI.id, 1);
	
		if  (pos &lt;&gt; 0) then // may need refining
			self.tblWorkEntries.selectRow(idx, false);
			break;
		endif;
		
	endforeach;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="filterForShippingLine" id="54da1569-19c3-4af7-a78f-5a96daa3214d">
        <source>filterForShippingLine();

/*

Purpose:			
Not realy a filter as such , just find a (partial) match WLE in the table and select that.
Parameters:			

Return Value:		


Date		Who		Reason
03 June 2022	navak20 ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI

*/

vars
	wle : CM_WorkListEntry;
	aTI : CM_TrackedItem;
	idx,
	fixedRows,
	pos,
	rows : Integer;
	invalidWLE,
	invalidTI : Boolean;
	shipLine : String;
begin


	
	// no shipping line to filter?
	if self.filterShippingLine = null then 
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, wle, invalidWLE);
	on Exception do app.handleDeletedObject(exception, aTI, invalidTI);
	
	// step through table rows for WLE's check if has TI and check that TI's cargo ID
	
	rows := self.tblWorkEntries.rows;
	fixedRows := self.tblWorkEntries.fixedRows;
	
	foreach idx in fixedRows to rows do
		wle := self.tblWorkEntries.accessRow(idx).itemObject.CM_WorkListEntry;
		if wle = null then
			continue;
		endif;		
		
		aTI := wle.myTrackedItem;
		if aTI = null then
			continue;
		endif;
		
		pos := aTI.getShippingLineCode().pos(self.filterShippingLine, 1); //13/07/2022 navgm20 Tfs 53195

		if  (pos &lt;&gt; 0) then // may need refining
			self.tblWorkEntries.selectRow(idx, false);
			break;
		endif;
		
	endforeach;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="filterJob" id="4851545e-cb10-453f-8255-439161bf56e6">
        <source>filterJob(_job : CM_Job) : Boolean;
// -----------------------------------------------------------------------------
// Created:		22 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//	13 Feb 2023	navcs2		ChangeRequest 56318:[56319] EUP - Enable ToDo Work Order job on Yard Operation Screen)

// -----------------------------------------------------------------------------

vars
	taskType 	: Object;
	wle 		: CM_WorkListEntry;
	wleArray 	: CM_WLEArray;
	workOrder 	: CM_WorkOrder;
	reqDate 	: TimeStamp;
	shift		: CM_Shift;
begin
	if _job = null then
		if self.filterJobId &lt;&gt; null or self.filterDateFrom &lt;&gt; null or self.filterDateTo &lt;&gt; null
		or self.filterWorkOrderId &lt;&gt; null or self.filterOrganisation &lt;&gt; null
		or self.filterOperator &lt;&gt; null or self.allTaskTypesFiltered.size &lt;&gt; self.allTaskTypes.size then
			return false;
		endif;
	endif;

	if self.filterJobId &lt;&gt; null and ( ( _job.id &lt;&gt; null and _job.id &lt;&gt; self.filterJobId ) or (_job.id = null and  _job.jobId &lt;&gt; self.filterJobId ) ) then	// 05 Nov 2012	NDL	Par 20486
		return false;
	elseif self.filterDateFrom &lt;&gt; null and _job.createdTime.date() &lt; self.filterDateFrom then
		return false;
	elseif self.filterDateTo &lt;&gt; null and _job.createdTime.date() &gt; self.filterDateTo then
		return false;
	endif;

	if self.filterWorkOrderId &lt;&gt; null then
		workOrder := _job.getWorkOrder();
		if workOrder = null or workOrder.id &lt;&gt; self.filterWorkOrderId then
			return false;
		endif;
	endif;
	
	
	reqDate := _job.getRequiredByDT();
	if self.filterDateReqFrom &lt;&gt; null and reqDate.date() &lt; self.filterDateReqFrom then
		return false;
	elseif self.filterDateReqTo &lt;&gt; null and reqDate.date() &gt; self.filterDateReqTo then
		return false;
	endif;
		
	if self.filterShift &lt;&gt; null then
		if  reqDate &lt; self.filterShift.startDateTime then
			return false;
		elseif reqDate &gt; self.filterShift.endDateTime then
			return false;
		endif;
	endif;

	taskType := self.getTaskTypeForJob(_job);
	
	if taskType = null or not (self.allTaskTypesFiltered.includes(taskType)) and not 
	   self.allTaskTypesFiltered.includes(self.getClassForObject(_job.myWorkOrderDtlToDo)) then // 13 Feb 2023	navcs2 56318:[56319] 
		return false;
	endif;
	
	return true;
	
epilog
	delete wleArray;
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
