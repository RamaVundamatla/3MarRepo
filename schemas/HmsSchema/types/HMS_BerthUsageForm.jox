    <JadeMethod name="cmbMonth_click" id="b5f86ada-20e6-4337-a586-7e8708f79090">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMonth_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation	Par 29120

*/

vars

	newMonth : Integer;
	date : Date;
	newDate : Date;

begin

	if cmbMonth.listIndex &gt; 0 then
	
		newMonth := cmbMonth.listIndex;
	
		date := self.txtFromDate.getDate();

		if date &lt;&gt; null then
			newDate.setDate(01,newMonth,date.year);
			self.txtFromDate.setDate(newDate);
		endif;
		
		date := null;
		date := self.txtToDate.getDate();
		if date &lt;&gt; null then
			if newMonth = 12 then
				newDate.setDate(01,01,date.year + 1);
			else
				newDate.setDate(01,newMonth + 1,date.year);
			endif;
			self.txtToDate.setDate(newDate - 1);
		endif;
	
	
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbYear_click" id="0ae4e85b-d53e-46a3-8eea-4ba97009a7cd">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbYear_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation	Par 29120

*/

vars

	newYear : Integer;
	date : Date;
	newDate : Date;

begin


	if self.cmbYear.listIndex &gt; 0 then
		newYear := self.cmbYear.text.Integer;
		
		date := self.txtFromDate.getDate();
		if date &lt;&gt; null then
			newDate.setDate(01,date.month,newYear);
			self.txtFromDate.setDate(newDate);
		endif;
		
		date := null;
		date := self.txtToDate.getDate();
		if date &lt;&gt; null then
			if date.month = 12 then
				newDate.setDate(01,01,newYear + 1);
			else
				newDate.setDate(01,date.month + 1,newYear);
			endif;
			self.txtToDate.setDate(newDate - 1);
		endif;
	
	endif;
	
	
	
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
