    <JadeMethod name="setupForm" id="1d7eda39-b099-4245-92f3-2391b3fb7fd2">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.usesQueryFrame := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.usesQueryFrame := false;
	self.setCaption(app.getErrorString(PlanningGuide));
	self.useTableInfo := false;
	self.useTableSorting := true;
	inheritMethod();
	

	self.setNavigatorHeading(self.caption);
	self.btnQuery.visible := true;
	self.btnDelete.visible := false;
	self.btnPrint.visible := true;
	self.btnQuery.visible := false;
	self.cmbVoyage.visible := true;

	self.frmModalDialog.height := 100;
	self.frmModalDialog.width := 400;
	self.frmModalDialog.centreWindow;
	self.frmModalDialog.top := 50;

	self.frmProgressCtr.move(0,0,self.frmModalDialog.clientWidth,self.frmModalDialog.clientHeight);
	self.lblModalMessage.move(0,10,self.frmModalDialog.width,40);
	self.lblModalMessage.alignment := Frame.Alignment_Center_Middle;
	self.lblModalInfo.move(0,55,self.frmModalDialog.width,20);
	self.lblModalInfo.alignment := Frame.Alignment_Center_Middle;
	self.lblModalMessage.visible := true;
	self.lblModalInfo.visible := true;
	self.frmModalDialog.visible := false;


end;</source>
    </JadeMethod>
