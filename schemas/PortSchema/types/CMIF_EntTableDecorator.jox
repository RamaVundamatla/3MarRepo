    <JadeMethod name="setTableHeightToRows" id="b8b7f729-d8b1-47b8-806b-d209c1afd94f">
        <source>setTableHeightToRows();
// ---------------------------------------------------------------------------
// Created:     22 September 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 25511
// ---------------------------------------------------------------------------

vars
	row, rowH, totHeight, numBlk : Integer;
	tblRow : JadeTableRow;
	txt : String;
begin
	if self.myTable = null then
		return;
	endif;
	
	if self.myTable.rows = 0 then
		return;
	endif;
	

	foreach row in 1 to self.myTable.rows do
		tblRow := self.myTable.accessRow(row);
		if not  tblRow.visible then
			continue;
		endif;
		
		txt := self.myTable.accessCell(row,self.headingColumn).text.trimBlanks();
		if txt &lt;&gt; null then
			rowH := row;
		endif;
	endforeach;
	if rowH &lt;= 0 then
		return;
	endif;
	totHeight := self.myTable.accessCell(rowH,1).positionTop() + self.myTable.accessRow(rowH).height; //+ 20;
	
	rowH := rowH + 1;
	if rowH &lt;= self.myTable.rows then
		foreach row in rowH  to self.myTable.rows do
			if row &lt;= self.myTable.rows then
				self.myTable.accessRow(row).visible := false;
			else
				break;
			endif;
		endforeach;
	endif;
	
	self.myTable.height := totHeight;
	
	
	
epilog

end;</source>
    </JadeMethod>
