<GUIClass name="CMUI_VoyageLoadDisSummary" id="c1757b67-3b11-4faa-aa58-c4170c575809">
    <superclass name="CMUI_VoyageWeightSummary"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="addTotalsRow" id="d1314f57-1fef-44a4-ba64-ae4c630f0541">
        <source>addTotalsRow() protected;
// ---------------------------------------------------------------------------
// Created:     20 July 2004	cnwth2
//			 
// ----------   ----------  --------------------------------------------------
// 26/11/2012	cnwcs5		par 30773 - fix bug with totals row
constants
	SeperatorWidth	= 10;
	TypeColumn		= 2;
vars
	countTotal,  numRows, numColumns,
	row, column			: Integer;
	tbl					: Table;
	startRow, totalRows	: Integer; 
	strTotal			: String;
begin

	tbl := self.tblReport;

	//////////////////////////////////	
	//add column seperator and totals column
	numColumns 	:= tbl.columns + 2;
	tbl.columns := numColumns;
	strTotal	:= app.getErrorString (Total);	// par 30773 nov 2012
	
	tbl.setCellText(1, numColumns, strTotal);	// par 30773 nov 2012
	
	tbl.accessColumn(numColumns).fontBold 	:= true;
	tbl.accessColumn(1).fontBold 			:= true;
	tbl.accessColumn(numColumns - 1).width 	:= SeperatorWidth;
	tbl.accessedColumn.backColor 			:= Grey;
	//////////////////////////////////
	tbl.accessColumn(1).width := 30;
	tbl.accessColumn(2).width := 25;

	startRow 	:= tbl.fixedRows + 1;
	totalRows	:= tbl.rows;
	
	foreach row in startRow to totalRows do
		countTotal := 0;

		foreach column in 3 to numColumns do
			countTotal := countTotal + tbl.accessCell(row, column).text.Integer;
		endforeach;
		
		if countTotal &lt;&gt; null then
			tbl.setCellText(row, numColumns, countTotal.String);
		endif;	
	endforeach;

	numRows 	:= tbl.rows;
	numColumns 	:= tbl.columns;
	
	//add row seperator and totals row
	tbl.rows 								:= numRows + 2;
	tbl.accessCell(tbl.rows, 1).text 		:= strTotal;	// par 30773 nov 2012
	tbl.accessRow(tbl.rows).fontBold 		:= true;
	tbl.accessRow(tbl.rows -1).backColor 	:= Grey;
	tbl.accessedRow.height 					:= SeperatorWidth;
	
	foreach column in 3 to numColumns do
		countTotal := null;
		
		if tbl.accessColumn(column).width &gt; 35 then
			tbl.accessedColumn.width := 35;
		endif;
		
		foreach row in 2 to numRows do
			if self.isSubTotalRow (tbl, row) then		// par 30773 nov 2012
				continue; //sub-total row;
			endif;
			
			countTotal := countTotal + tbl.accessCell(row, column).text.Integer;
		endforeach;
		
		if countTotal &lt;&gt; 0 then
			tbl.setCellText(numRows + 2, column, countTotal.String);	
		endif;	
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getDisplayValueForKey" id="91034809-6508-4d12-a062-b1a50c76437a">
        <source>getDisplayValueForKey(_keyValue : String) : String;
// ---------------------------------------------------------------------------
// Created:     21 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _keyValue = CMQF_VoyageSummary.KEY_VALUE_DLR then
		return 'DLR';
	elseif _keyValue = CMQF_VoyageSummary.KEY_VALUE_SOB then
		return 'SOB';
	else
		return _keyValue;
	endif;

end;</source>
        <Parameter name="_keyValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="00a1faa5-5b7e-402b-a375-9fe1a272056d">
        <source>getTerminal():CM_Terminal protected;
/*
Date		Who		Reason
22 Nov 2012	cnwcs5	Initial creation - par 30773
27 Nov 2012	cnwcs5	par 30816 - use CMIF_VoyageSummary method
*/
vars
	terminal	: CM_Terminal;
	summary 	: CMIF_VoyageSummary;
begin
	// if we are running this report as part of a packge then we cannot assume that the terminal will be set on the passport
	summary := self.myJRWVoyageSummary.allVoyageSummaryObjects.first;
	
	if summary &lt;&gt; null then 
		terminal := summary.getTerminal;	// par 30816
	endif;
	
	return terminal;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="isSubTotalRow" id="2276d5e3-35e4-4b5f-b424-dc3de66142cc">
        <source>isSubTotalRow(_table :Table input; _row :Integer):Boolean protected;
/*
Date		Who		Reason
26 Nov 2012	cnwcs5	Initial creation - par 30773
*/
vars

begin
	// we need to know which rows are sub-totals.  this is a bit manky
	// but i am seeting itemObject to self for sub-total rows.
	// we can't rely on looking for 'total' in the text as this is now translatable.
	// we can't rely on a row number as showing 30', 45', 53' is configurable.
	
	return _table.accessRow (_row).itemObject = self;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateTable" id="267e702c-dcba-47ce-8828-1f9e527a292d">
        <source>populateTable() protected;
/*
Date		Who		Reason
12 Apr 2010	cnwndl1	Initial creation	Par 23052	- rewritten to handle 30's, 45's and 53's.
22/11/2012	cnwcs5	par 30773 - fix 1090 when report run as part of a package
*/
constants	
	NotShown	= 0;
	OwnColumn	= 1;
	OtherColumn	= 2;
vars
	tbl 						: Table;
	terminal					: CM_Terminal;
	show30, show45, show53 		: Integer;
	includeCol30, includeCol45, includeCol53, 
	includeColOther 			: Boolean;
	othersArray 				: IntegerArray;
	voySummary 					: CMIF_VoyageSummary;
	column, rowIndex, totalRows	: Integer;
	
begin
	tbl 		:= self.tblReport;
	terminal	:= self.getTerminal;
	
	// soft columns for 30's, 45's and 53's.  0 = do not show, 1 = show own column, 2 = include in others column
	if terminal &lt;&gt; null then 
		show30 := terminal.getConfig(Is30IncludedForReports).Integer;
		show45 := terminal.getConfig(Is45IncludedForReports).Integer;
		show53 := terminal.getConfig(Is53IncludedForReports).Integer;
	endif;
	
	includeCol30 	:= (show30 = OwnColumn);
	includeCol45 	:= (show45 = OwnColumn);
	includeCol53 	:= (show53 = OwnColumn);
	includeColOther := (show30 = OtherColumn) or (show45 = OtherColumn) or (show53 = OtherColumn);
	
	if includeColOther then
		create othersArray transient;
		
		if show30 = OtherColumn then
			othersArray.add(30);
		endif;
		if show45 = OtherColumn then
			othersArray.add(45);
		endif;
		if show53 = OtherColumn then
			othersArray.add(53);
		endif;
	endif;

	//setup column and rows headings////////////////
	totalRows := 25;
	
	if includeCol30 then
		totalRows := totalRows + 8;
	endif;
	
	if includeCol45 then
		totalRows := totalRows + 8;
	endif;
	
	if includeCol53 then
		totalRows := totalRows + 8;
	endif;
	
	if includeColOther then
		totalRows := totalRows + 8;
	endif;
	
	tbl.rows 						:= totalRows;
	tbl.fixedRows 					:= 1;
	tbl.columns 					:= 2;
	tbl.fixedColumns 				:= 2;
	tbl.accessColumn(1).fontBold 	:= true;
	tbl.accessRow(1).fontBold 		:= true;
	
	// setup labels
	self.populateTable_Labels (tbl, includeCol30, includeCol45, includeCol53, includeColOther);
	
	foreach voySummary in self.myJRWVoyageSummary.allVoyageSummaryObjects discreteLock do
		// add another column
		column 		:= tbl.columns + 1;
		tbl.columns := column;
		
		tbl.accessCell(1, column).text := voySummary.keyValue1;	// I think this is operator
		
		//Discharge//////////////////////////
		rowIndex := 2;
		
		self.populateTable_Data (tbl, rowIndex, column, othersArray, includeCol30, includeCol45, includeCol53, includeColOther, 
									voySummary.numDischarge20ftFull, voySummary.numDischarge30ftFull, voySummary.numDischarge40ftFull,
									voySummary.numDischarge45ftFull, voySummary.numDischarge53ftFull, 
									voySummary.numDischarge20ftEmpty, voySummary.numDischarge30ftEmpty, voySummary.numDischarge40ftEmpty,
									voySummary.numDischarge45ftEmpty, voySummary.numDischarge53ftEmpty, 
									voySummary.numDischargeOther, voySummary.totalDischarge);
									
		//Load///////////////////////////////
		rowIndex := rowIndex + 1;

		self.populateTable_Data (tbl, rowIndex, column, othersArray, includeCol30, includeCol45, includeCol53, includeColOther, 
									voySummary.numLoad20ftFull, voySummary.numLoad30ftFull, voySummary.numLoad40ftFull,
									voySummary.numLoad45ftFull, voySummary.numLoad53ftFull, 
									voySummary.numLoad20ftEmpty, voySummary.numLoad30ftEmpty, voySummary.numLoad40ftEmpty,
									voySummary.numLoad45ftEmpty, voySummary.numLoad53ftEmpty, 
									voySummary.numLoadOther, voySummary.totalLoad);	
									
		//DLR/////////////////////////////////
		rowIndex := rowIndex + 1;

		self.populateTable_Data (tbl, rowIndex, column, othersArray, includeCol30, includeCol45, includeCol53, includeColOther, 
									voySummary.num20ftDLR, voySummary.num30ftDLR, voySummary.num40ftDLR,
									voySummary.num45ftDLR, voySummary.num53ftDLR, 
									voySummary.num20ftDLRMT, voySummary.num30ftDLRMT, voySummary.num40ftDLRMT,
									voySummary.num45ftDLRMT, voySummary.num53ftDLRMT, 
									voySummary.numOtherDLR, voySummary.totalDLR);
									
		//SOB/////////////////////////////////////
		
		rowIndex := rowIndex + 1;

		self.populateTable_Data (tbl, rowIndex, column, othersArray, includeCol30, includeCol45, includeCol53, includeColOther, 
									voySummary.num20ftSOB, voySummary.num30ftSOB, voySummary.num40ftSOB,
									voySummary.num45ftSOB, voySummary.num53ftSOB, 
									voySummary.num20ftSOBMT, voySummary.num30ftSOBMT, voySummary.num40ftSOBMT,
									voySummary.num45ftSOBMT, voySummary.num53ftSOBMT, 
									voySummary.numOtherSOB, voySummary.totalSOB);		
	endforeach;	
	
epilog
	delete othersArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTable_Data" id="95a5a079-7369-42c3-bbcd-e9898e84f374">
        <source>populateTable_Data(_table :Table input; _row :Integer io; _column :Integer; _othersArray :IntegerArray;
					_includeCol30, _includeCol45, _includeCol53, _includeColOther :Boolean;
					_full20, _full30, _full40, _full45, _full53, _mt20, _mt30, _mt40, _mt45, _mt53, _gc, _total :Integer) protected;
/*
Date		Who		Reason
22 Nov 2012	cnwcs5	Initial creation - par 30773
*/
vars
	numOthersEmpty, numOthersFull 	:Integer;
begin
	// 20' Empty		
	if _mt20 &lt;&gt; null then
		_table.accessCell(_row, _column).text := _mt20.String;
	endif;
	
	_row := _row + 1;
	
	// 20' Full
	if _full20 &lt;&gt; null then
		_table.accessCell(_row, _column).text := _full20.String;
	endif;
	
	if _includeCol30 then
		_row := _row + 1;
		
		// 30' Empty
		if _mt30 &lt;&gt; null then
			_table.accessCell(_row, _column).text := _mt30.String;
		endif;
		
		_row := _row + 1;
		
		// 30' Full
		if _full30 &lt;&gt; null then
			_table.accessCell(_row, _column).text := _full30.String;
		endif;
		
	elseif _includeColOther and _othersArray.includes(30) then
		numOthersEmpty 	:= numOthersEmpty + _mt30;
		numOthersFull 	:= numOthersFull + _full30;
	endif;
	
	_row := _row + 1;
	
	// 40' Empty
	if _mt40 &lt;&gt; null then
		_table.accessCell(_row, _column).text := _mt40.String;
	endif;
	
	_row := _row + 1;
	
	// 40' Full
	if _full40 &lt;&gt; null then
		_table.accessCell(_row, _column).text := _full40.String;
	endif;
	
	if _includeCol45 then
		_row := _row + 1;
		
		// 45' Empty
		if _mt45 &lt;&gt; null then
			_table.accessCell(_row, _column).text := _mt45.String;
		endif;
		
		_row := _row + 1;
		
		// 45' Full
		if _full45 &lt;&gt; null then
			_table.accessCell(_row, _column).text := _full45.String;
		endif;
		
	elseif _includeColOther and _othersArray.includes(45) then
		numOthersEmpty	:= numOthersEmpty + _mt45;
		numOthersFull 	:= numOthersFull + _full45;
	endif;
	
	if _includeCol53 then
		_row := _row + 1;
		
		// 53' Empty
		if _mt53 &lt;&gt; null then
			_table.accessCell(_row, _column).text := _mt53.String;
		endif;
		
		_row := _row + 1;
		
		// 53' Fulll
		if _full53 &lt;&gt; null then
			_table.accessCell(_row, _column).text := _full53.String;
		endif;
		
	elseif _includeColOther and _othersArray.includes(53) then
		numOthersEmpty	:= numOthersEmpty + _mt53;
		numOthersFull 	:= numOthersFull + _full53;
	endif;
	
	if _includeColOther then
		_row := _row + 1;
		
		// Other Empty
		if numOthersEmpty &lt;&gt; null then
			_table.accessCell(_row, _column).text := numOthersEmpty.String;
		endif;
		
		_row := _row + 1;
		
		// Other Full
		if numOthersFull &lt;&gt; null then
			_table.accessCell(_row, _column).text := numOthersFull.String;
		endif;
	endif;
	
	_row := _row + 1;
	
	// General cargo
	if _gc &lt;&gt; null then
		_table.accessCell(_row, _column).text := _gc.String;
	endif;
	
	_row := _row + 1;
	
	// Total
	if _total &lt;&gt; null then
		_table.accessCell(_row, _column).text := _total.String;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer" usage="io"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_othersArray" type="IntegerArray"/>
        <Parameter name="_includeCol30" type="Boolean"/>
        <Parameter name="_includeCol45" type="Boolean"/>
        <Parameter name="_includeCol53" type="Boolean"/>
        <Parameter name="_includeColOther" type="Boolean"/>
        <Parameter name="_full20" type="Integer"/>
        <Parameter name="_full30" type="Integer"/>
        <Parameter name="_full40" type="Integer"/>
        <Parameter name="_full45" type="Integer"/>
        <Parameter name="_full53" type="Integer"/>
        <Parameter name="_mt20" type="Integer"/>
        <Parameter name="_mt30" type="Integer"/>
        <Parameter name="_mt40" type="Integer"/>
        <Parameter name="_mt45" type="Integer"/>
        <Parameter name="_mt53" type="Integer"/>
        <Parameter name="_gc" type="Integer"/>
        <Parameter name="_total" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateTable_Labels" id="e4a6b04f-0418-4fb3-8377-747477f90493">
        <source>populateTable_Labels(_table :Table input; _includeCol30, _includeCol45, _includeCol53, _includeColOther :Boolean) protected;
/*
Date		Who		Reason
22 Nov 2012	cnwcs5	Initial creation - par 30773.  Translations
*/
vars
	row							:Integer;
	full20, full30, full40, full45, full53, fullOther,
	mt20, mt30, mt40, mt45, mt53, mtOther,
	gc							: String;	// used so we only xlate once
begin
	// we only want to do translations once
	mt20 	:= app.getErrorString (CM_20FT_Empty); 
	full20	:= app.getErrorString (CM_20FT_Full);
	
	if _includeCol30 then
		mt30	:= app.getErrorString (CM_30FT_Empty);
		full30	:= app.getErrorString (CM_30FT_Full);
	endif;
	
	mt40	:= app.getErrorString (CM_40FT_Empty);
	full40	:= app.getErrorString (CM_40FT_Full);
	
	if _includeCol45 then
		mt45 	:=  app.getErrorString (CM_45FT_Empty);
		full45	:= app.getErrorString (CM_45FT_Full);
	endif;
	
	if _includeCol53 then
		mt53	:= app.getErrorString (CM_53FT_Empty);
		full53	:= app.getErrorString (CM_53FT_Full);
	endif;
	
	if _includeColOther then
		mtOther		:= app.getErrorString (CM_Other_Empty);
		fullOther	:= app.getErrorString (CM_Other_Full);
	endif;
	
	gc	:= app.getErrorString (CM_General_Cargo);
	
	// Discharge labels
	row := 2;			_table.accessCell(row, 1).text :=  app.getErrorString (CM_Discharge);
	
	self.populateTable_Labels2 (_table, row, _includeCol30, _includeCol45, _includeCol53, _includeColOther, 
								full20, full30, full40, full45, full53, fullOther, mt20, mt30, mt40, mt45, mt53, mtOther, gc); 
								
	row := row + 1;		_table.accessCell(row, 2).text := app.getErrorString (CM_Total_Discharge);	self.setSubTotalRow (_table, row);
	
	
	// load labels
	row := row + 1;		_table.accessCell(row, 1).text := app.getErrorString (CM_Load);
	
	self.populateTable_Labels2 (_table, row, _includeCol30, _includeCol45, _includeCol53, _includeColOther, 
								full20, full30, full40, full45, full53, fullOther, mt20, mt30, mt40, mt45, mt53, mtOther, gc); 
								
	
	row := row + 1;		_table.accessCell(row, 2).text := app.getErrorString (CM_Total_Load);	self.setSubTotalRow (_table, row);
	
	//DLR labels
	row := row + 1;		_table.accessCell(row, 1).text := app.getErrorString (CM_DLR);
	
	self.populateTable_Labels2 (_table, row, _includeCol30, _includeCol45, _includeCol53, _includeColOther, 
								full20, full30, full40, full45, full53, fullOther, mt20, mt30, mt40, mt45, mt53, mtOther, gc); 
								
	row := row + 1;		_table.accessCell(row, 2).text := app.getErrorString (CM_Total_DLR);	self.setSubTotalRow (_table, row);
	
	//SOB labels
	row := row + 1;		_table.accessCell(row, 1).text := app.getErrorString (CM_SOB);
	
	self.populateTable_Labels2 (_table, row, _includeCol30, _includeCol45, _includeCol53, _includeColOther, 
								full20, full30, full40, full45, full53, fullOther, mt20, mt30, mt40, mt45, mt53, mtOther, gc); 
								
	row := row + 1;		_table.accessCell(row, 2).text := app.getErrorString (CM_Total_SOB);	self.setSubTotalRow (_table, row);
	
	// end of labels setup

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_includeCol30" type="Boolean"/>
        <Parameter name="_includeCol45" type="Boolean"/>
        <Parameter name="_includeCol53" type="Boolean"/>
        <Parameter name="_includeColOther" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateTable_Labels2" id="ebeb34c0-b434-49d6-b7c2-63f546f6f4aa">
        <source>populateTable_Labels2(_table :Table input; _row :Integer io; _includeCol30, _includeCol45, _includeCol53, _includeColOther :Boolean; 
						_full20, _full30, _full40, _full45, _full53, _fullOther, _mt20, _mt30, _mt40, _mt45, _mt53, _mtOther, _gc :String) protected;
/*
Date		Who		Reason
22 Nov 2012	cnwcs5	Initial creation - par 30773
*/
vars

begin
	_table.accessCell(_row, 2).text := _mt20;
	
	_row := _row + 1;		_table.accessCell(_row, 2).text := _full20;
	
	if _includeCol30 then
		_row := _row + 1;	_table.accessCell(_row, 2).text := _mt30;
		_row := _row + 1;	_table.accessCell(_row, 2).text := _full30;
	endif;
	
	_row := _row + 1;		_table.accessCell(_row, 2).text := _mt40;
	_row := _row + 1;		_table.accessCell(_row, 2).text := _full40;
	
	if _includeCol45 then
		_row := _row + 1;	_table.accessCell(_row, 2).text := _mt45;
		_row := _row + 1;	_table.accessCell(_row, 2).text := _full45;
	endif;
	
	if _includeCol53 then
		_row := _row + 1;	_table.accessCell(_row, 2).text := _mt53;
		_row := _row + 1;	_table.accessCell(_row, 2).text := _full53;
	endif;
	
	if _includeColOther then
		_row := _row + 1;	_table.accessCell(_row, 2).text := _mtOther;
		_row := _row + 1;	_table.accessCell(_row, 2).text := _fullOther;
	endif;
	
	_row := _row + 1;		_table.accessCell(_row, 2).text := _gc;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer" usage="io"/>
        <Parameter name="_includeCol30" type="Boolean"/>
        <Parameter name="_includeCol45" type="Boolean"/>
        <Parameter name="_includeCol53" type="Boolean"/>
        <Parameter name="_includeColOther" type="Boolean"/>
