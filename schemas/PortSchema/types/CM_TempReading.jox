    <JadeMethod name="temperatureInFahrenheit" id="5dfbee01-1fd6-42c7-9f86-11940e8710e0">
        <source>temperatureInFahrenheit():Real;
//rs 2/12/2003 round all fahreinheit temps
// 11/12/2009	cnwdap1		CCMS MES 1007 myContainer reference now redundant, use myReeferProperties instead
vars

begin
	//if self.myContainer.myOperator = null then
	if self.myReeferProperties.myParent.CM_TrackedItem.myOperator = null then
		return NULL_TEMPERATURE;
	//elseif self.myContainer.myOperator.displayTempFahrenheit then
	elseif self.myReeferProperties.myParent.CM_TrackedItem.myOperator.displayTempFahrenheit then
		return app.myRoot.convCelsiusToFahrenheit(self.temperature).rounded;
	else
		return NULL_TEMPERATURE;
	endif;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
</Class>
