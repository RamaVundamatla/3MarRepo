<Class name="CM_RelRequestUnassign" id="0a9a75c3-1f7e-4d75-b438-ac2210779d8e">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="myBulkReleaseCode" id="415d5589-9b7f-4448-990d-219492ddc67e">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="65641d3f-5570-423d-b020-1a0b5d284cb3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			if self.context &lt;&gt; 0 then
				lDetail := " [" &amp; app.transModeToString(self.context) &amp; "]";
			endif;
			return app.getErrorString1(Unassigned_from, self.myBulkReleaseCode &amp; lDetail);
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="4d02b286-f20f-4064-a7ef-6564339b6503">
        <source>getEnquiryRow(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 February 2009	cnwar2	Initial creation

*/

vars
	lDetail 	: String;
	lReturn		: String;
	
begin
	lDetail := inheritMethod();
	
	lReturn := lDetail &amp; app.getErrorString1(Unassigned_from, self.myBulkReleaseCode);		// 27/03/2009 cnwar2 #19235
	
	//17 Aug 2016	NDL	TFS 2559
	if self.context &lt;&gt; 0 then
		lReturn :=  lReturn &amp; " [" &amp; app.transModeToString(self.context) &amp; "]";
	endif;
	
	return lReturn;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="1f72bf6d-669a-45a0-af24-7e58d50d6faa">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 February 2009	cnwar2	Initial creation

*/

vars

begin

	if not app.isInProformaMode then
		self.myBulkReleaseCode := _tiTransCntrl.myBulkRelease.code;		// 27/03/2009 cnwar2 #19235
		self.context := _tiTransCntrl.myBulkRelease.type;	//17 Aug 2016	NDL	TFS 2559
	endif;
	inheritMethod(_tiTransCntrl, _passport);
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
