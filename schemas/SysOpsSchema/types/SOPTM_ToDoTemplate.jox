    <JadeMethod name="setupThumbnailDetails" id="1a288a75-4502-4725-b73e-01e009451a4c">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;
begin
 
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ToDoTemplateMaintTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Id, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_ToDoTemplateMaint);
	theForm.shtTblInput1.visible := true;

	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="2740a068-cdc6-492e-93da-379a01eef263">
        <updating/>
        <source>showThumbnail(pToDoTemplate: CM_ToDoTemplate) updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm 	: SOP_TableMaintForm;
	t 			: Time;
	mtGrade		: CM_MTGrade;
begin
  
  	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Id, pToDoTemplate.id);
	theForm.tblInput1.setValueByName(ETRow_Empties,	pToDoTemplate.empties);
	theForm.tblInput1.setValueByName(ETRow_Exports,pToDoTemplate.exports);
	theForm.tblInput1.setValueByName(ETRow_Imports,pToDoTemplate.imports);
	theForm.tblInput1.setValueByName(ETRow_Full,pToDoTemplate.full);
	theForm.tblInput1.setValueByName(ETRow_Storage,pToDoTemplate.storage);
	theForm.tblInput1.setValueByName(ETRow_Tranships,pToDoTemplate.tranships);	// 21/09/2010 cnmwh5 #25602
	///if theForm.myCurrentObject &lt;&gt; null and theForm.myCurrentObject.isKindOf(CM_ToDoTemplate) then	// 04/10/2010 cnwmh5 #25602
	///	theForm.tblInput1.setValueByName(ETRow_Tranships, theForm.myCurrentObject.CM_ToDoTemplate.getExtraDataValueForTranships()); 
	///endif;
	mtGrade := pToDoTemplate.availabilityGradeToApply;
	if mtGrade &lt;&gt; null then
		theForm.cmbAvaGrades.setObjectAndOperator(mtGrade, null, null);
		theForm.tblInput1.setValueByName(ETRow_AvailabilityGradeToApply,mtGrade.code.String &amp; "       " &amp; mtGrade.description);
	endif;

	theForm.mulSelect1.setSelected(pToDoTemplate.availabilityGrades);
	theForm.mulSelect2.setSelected(pToDoTemplate.operators);
	theForm.mulSelect3.setSelected(pToDoTemplate.toDoTasks);
	theForm.mulSelect41.setSelected(pToDoTemplate.isoTypes);
	theForm.mulSelect42.setSelected(pToDoTemplate.isoGroups);
	
	//07 Dec 2012	NDL	Par 24669
	if not pToDoTemplate.isoGroups.isEmpty then
		theForm.optGroups.value := true;
	else
		theForm.optTypes.value := true;
	endif;
	theForm.doClickTypeGroupOpts();

	theForm.mulSelect1.cnEcResizeContents();
	theForm.mulSelect2.cnEcResizeContents();
	theForm.mulSelect3.cnEcResizeContents();
	theForm.mulSelect41.cnEcResizeContents();
	theForm.mulSelect42.cnEcResizeContents();
end;</source>
        <Parameter name="pToDoTemplate" type="CM_ToDoTemplate"/>
    </JadeMethod>
</Class>
