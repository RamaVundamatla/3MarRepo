<Class name="WS_Job" id="bec383e4-3dee-4058-a2bb-f77945e4834f">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents jobs related to a specific voyage </text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allWorkListEntries" id="9024b3c9-0cfc-4608-888d-353fdb640b4d">
        <memberTypeInverse/>
        <type name="WS_VoyageWLEArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="description" id="650afa2c-8837-4339-ba2e-b122b2d8e39a">
        <length>51</length>
        <embedded/>
        <type name="String"/>
        <text>Description of the Job ex. "01 C OD "  which means  Bay 01 Center Over Deck</text>
    </PrimAttribute>
    <PrimAttribute name="id" id="2e827243-f5a9-4f0f-acb2-fc60fecb5c9b">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Voyage Job ID</text>
    </PrimAttribute>
    <PrimAttribute name="location" id="649fa24d-d2cc-43a1-a653-a90cca5c6f56">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Bay ID</text>
    </PrimAttribute>
    <PrimAttribute name="plannedLocation" id="53dd98d8-9f47-4542-9c14-9e4fa7dd7b19">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="shiftCode" id="2dd3a71e-6194-45f0-b838-5448bf425f93">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="shiftEnd" id="98b988ec-c2c1-4031-a3a5-37bee40635ee">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="shiftStart" id="42a526fd-6633-4014-b0da-47e742c49b1e">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="type" id="76c79d4f-ceb8-45ac-8929-5f0caa2f0679">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>voyage Job Type ex. 0 = Load ,1 = Discharge , 2 = Shift on Board</text>
    </PrimAttribute>
    <PrimAttribute name="voyageCode" id="e369fe2f-549b-47bc-8d9b-d80e537ef068">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="workPointCode" id="edc44216-b172-4f23-a299-7242db6e896b">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Work point code used for this voyage</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="1f9022f5-25b1-4644-9d97-e09208ea9369">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2026 navma1 MTN-36897 PEN - Transient File Growth in PEN Production Environment 

*/

vars

begin
	self.allWorkListEntries.purge();		//08.01.2026 navma1 #MTN-36897
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="3afaafef-b5f1-40ff-bf4b-963a15a448be">
        <updating/>
        <source>setProxyFromObject(_object: CM_Job) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation
21 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
*/

vars
	request : CM_VoyageRequest;
	voyage	: CM_Voyage;
	req		: CM_HoldRequest;
	loc		: CM_GeneralCargoController;
begin
	inheritMethod(_object);
	self.id	:= _object.id;
	
	if _object.isKindOf(CM_VoyageDeckJob) then
		// jobs are always created from voyage allocations get the voyage allocation description
		request:=_object.allRequests.first.CM_VoyageRequest;
		if request &lt;&gt; null then
			self.description:= request.getAllocationName()[1:50];
		endif;
	endif;
	
	if self.description = null then
		self.description:=_object.getDescription()[1:50];
	endif;
	//26 Oct 2011	NDL	Par 28303
	self.type := _object.jobType.String;
	if _object.isKindOf(CM_VoyageJob) then
		self.location :=_object.CM_VoyageJob.bayId;
		voyage := _object.CM_VoyageJob.myVoyage;
		if voyage &lt;&gt; null then
			self.voyageCode := voyage.code;		// 21/6/18 MAP TFS38046
		endif;
		
		self.workPointCode := _object.CM_VoyageJob.craneId; // 05/11/21 jlizm1 TFS 52028
		self.setWLEDetails(_object);
	endif;
	
	if _object.myShift &lt;&gt; null then		// 18/6/18 MAP TFS38046
		self.shiftCode := _object.getShiftCode();
		self.shiftStart := _object.getShiftStart().asStringForWebInterface();
		self.shiftEnd := _object.getShiftEnd().asStringForWebInterface();
	endif;
	
	if _object.isKindOf(CM_VoyageWorkPointJob) then				//21.12.2023 navhl20 #58400[61617]
		req := _object.CM_VoyageWorkPointJob.allRequests.first.CM_HoldRequest;
		loc	:= req.myHoldControllerLoad;
		if loc &lt;&gt; null then
			self.plannedLocation := loc.getFullId();
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="setWLEDetails" id="fd0f1913-9ec3-4cba-acf6-853e74b159c6">
        <updating/>
        <source>setWLEDetails(_job : CM_Job) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 November 2021	jlizm1	Initial creation TFS 52028 Work hold jobs in handheld app
06 Mar 2025 		navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle    : CM_WorkListEntry;
	pxyWLE : WS_VoyageWLE;
begin
	
	if _job = null then
		return;
	endif;
	
	if _job.isKindOf(CM_VoyageJob) then
		foreach wle in _job.workListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
			if wle.isKindOf(CM_VoyageWLE) and wle.status &lt;&gt; WLE_COMPLETED then
				create pxyWLE transient;
				pxyWLE.setProxyFromObject(wle.CM_VoyageWLE);
				self.allWorkListEntries.add(pxyWLE);
			endif;
		
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
</Class>
