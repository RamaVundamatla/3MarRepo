    <JadeMethod name="isCurrent" id="594d9987-515f-46ee-bc12-2db8dad39848">
        <condition/>
        <source>isCurrent():Boolean condition;

/*

Purpose:	This is a condition for the Collection 'allCurrentWagons' on
			CM_Wagonmaster.
			
			WARNING: Changing this method will cause a reorg !!!!

Parameters:			

Return Value:		


Date		Who		Reason
08 July 2009	cnwndl1	Initial creation

*/

begin

	if myTerminalDeparted &lt;&gt; null then
		// this wagon has already departed from the terminal, therefore
		// it is no longer current.
		return false;
	endif;
	
	return true;

end;</source>
