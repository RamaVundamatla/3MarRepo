<Class name="TransactionAgent" id="653f749f-293c-4903-a374-76cd7b60ca01">
    <superclass name="JSSTransactionAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
