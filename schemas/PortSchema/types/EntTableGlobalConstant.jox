    <JadeMethod name="initialiseFromGlbConstant" id="7fa094f3-d72e-4fcf-b4b0-0f815dcd1afc">
        <updating/>
        <source>initialiseFromGlbConstant(pConstant : GlobalConstant; pAgent : EntTableAgent) updating;
// ---------------------------------------------------------------------------
// Created:     17 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.constantName	:= pConstant.name;
	self.constantValue	:= pConstant.valueAsString;
	
	self.myAgent	:= pAgent;

end;</source>
        <Parameter name="pConstant" type="GlobalConstant"/>
        <Parameter name="pAgent" type="EntTableAgent"/>
    </JadeMethod>
