    <JadeMethod name="auditId" id="46d9468e-bc5d-4bea-8e70-7fb729c28f95">
        <source>auditId(): String;
// ---------------------------------------------------------------------------
// Created:     24 Jun 2009 by cnwndl1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.code;
end;
</source>
