    </JadeMethod>
    <JadeMethod name="setAllCriteria" id="6b085a29-9f2d-4b12-a1ff-219d889bfd7b">
        <source>setAllCriteria(_rtConfig: CM_RTVehicleConfig);
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	CCMS MES 1080, PAR 24294
   
Change Date		Who		Reason
16/10/2019	JLGNS1	ChangeRequest 46451: JMT - Tandem Lift moves - Order of selecting and set down items using Vehicle App
------------------------------------------------------------------------------*/
vars
	crit, proxyCriteria		: CM_YARTVConfigCriteria;
	cmifCriteria			: CMIF_YACriteriaPriority;
	itemCode				: String;
	value					: Any;
	obj					: Object;

begin

	self.lblCriteria.caption		:= "";
	self.lblCriteria.visible		:= false;
	self.btnTemplCritEdit.visible	:= false;
	self.chkTandemToDiffTargets.visible := false;
	self.chkDoSwapChangeCargo.visible := false; //29/10/2025	navkc1 JIRA 36186

	if self.allCriteria.size &gt; 0 then
		self.allCriteria.purge;	
	endif;
	
	if _rtConfig = null then
		return;
	endif;

	if _rtConfig.allCriteria.size &gt; 0 then
		foreach crit in _rtConfig.allCriteria do
			create proxyCriteria transient;
			itemCode := crit.myYACriteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
			value := crit.myYAData.getDataValue();
			proxyCriteria.setProxy(crit.myYACriteriaType, value, itemCode);
			cmifCriteria := proxyCriteria.getTransient();
			self.allCriteria.add(cmifCriteria);
		endforeach;
		self.displayCriteriaDesc();
	endif;
	
	obj := self.lstObject.listObject;
	if obj.isKindOf(CM_Terminal) then
		self.displayCriteriaDesc();
		self.lblCriteria.visible		:= true;
		self.btnTemplCritEdit.visible	:= true;
	elseif (obj.isKindOf(CM_MachineType) and obj.CM_MachineType.type = MACHINETYPE_FORK_LIFT) or (obj.isKindOf(CM_Machine) and obj.CM_Machine.machineType = MACHINETYPE_FORK_LIFT) then		// 26/11/19 MAP TFS47394
		self.chkTandemToDiffTargets.visible := true;
		
		//29/10/2025	navkc1 JIRA 36186 - Only set this to visible when Allow Tandem Lift with different target locations is true.
		if self.chkTandemToDiffTargets.value then
			self.chkDoSwapChangeCargo.visible := true;
		endif;
	endif;
	
end;</source>
        <Parameter name="_rtConfig" type="CM_RTVehicleConfig"/>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="5055feb0-9e49-46a5-829f-7af09ed0587c">
        <updating/>
        <source>setCorrectComboStyle() updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
11 June 2024	navab1	BUG 64462
*/

vars

begin
	inheritMethod();

	self.cmbLocationDisplay.style := 2;
	self.cmbOstowMode.style := 2;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultTaskMode" id="e46d9e4e-c144-4682-b5e0-055fe4d2848a">
        <source>setDefaultTaskMode(_defaultIsList : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	cnwer1	Initial creation

*/

vars

begin
	if _defaultIsList then
		self.lblDefGetNext.caption :=app.getErrorString(SetDefault);
		self.lblDefList.caption:= app.getErrorString(Default)  ;
	else
		self.lblDefGetNext.caption :=  app.getErrorString(Default) ;
		self.lblDefList.caption:=app.getErrorString(SetDefault)  ;
	endif;
epilog

end;</source>
        <Parameter name="_defaultIsList" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultTaskModeVisibility" id="f1e53e39-1b2f-4266-9e01-94ffc37db2f7">
        <source>setDefaultTaskModeVisibility();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	cnwer1	Initial creation

*/

vars
	bothVisible : Boolean;
begin	
	bothVisible:=self.chkTaskList.value and self.chkTaskGetNext.value ;
	self.lblDefGetNext.visible:= bothVisible ;
	self.lblDefList.visible:= bothVisible;
	self.chkAutoGetNext.visible:=self.chkTaskGetNext.value;
	self.lblNumQEntries.visible:=self.chkTaskList.value;
	self.txtNumQEntries.visible:=self.chkTaskList.value;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setPicSettingsScrollRange" id="a9d02cef-7ab0-4fc5-bf30-247407754d93">
        <source>setPicSettingsScrollRange();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2010	cnwer1	Initial creation

*/

vars
	maxHScroll,
	maxVScroll	: Integer;
begin
	if (self.grpOstow.top + self.grpOstow.clientHeight + 15).Integer -self.shtSetttings.clientHeight &gt; 0 then
		maxVScroll:= (self.grpOstow.top + self.grpOstow.clientHeight + 15).Integer -self.shtSetttings.clientHeight;
	else
		maxVScroll:=0;
	endif;
	
	if (self.grpOstow.left + self.grpOstow.clientWidth ).Integer -self.shtSetttings.clientWidth &gt; 0 then
		maxHScroll:= (self.grpOstow.left + self.grpOstow.clientWidth).Integer -self.shtSetttings.clientWidth;
	else
		maxHScroll:=0;
	endif;
	
	self.picSettings.setScrollRange(ScrollBar_Vertical, 0,maxVScroll, 20, 100);
	self.picSettings.setScrollRange(self.ScrollBar_Horizontal, 0,maxHScroll, 20, 100);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControlFromParent" id="d910a60d-301a-4fa6-8afb-cbe303be83e4">
        <source>setupControlFromParent(	_frm 	: Control input;
						_parentFrame: Window input;
						_offsetLeft,
						_offsetTop : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2010	cnwer1	Initial creation

*/

vars

begin
	_frm.left:=_offsetLeft;
	_frm.top:=_offsetTop;
		
	if _parentFrame.isKindOf(Control) then
		_frm.width:=_parentFrame.Control.clientWidth-_offsetLeft;
		_frm.height:=_parentFrame.Control.clientHeight-_offsetTop;
	else
		_frm.width:=_parentFrame.Form.clientWidth-_offsetLeft;
		_frm.height:=_parentFrame.Form.clientHeight-_offsetTop;
	endif;
	
	_frm.parentAspect:=Control.ParentAspect_StretchBoth;
	_frm.borderStyle:=Control.BorderStyle_None;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_frm" type="Control" usage="input"/>
        <Parameter name="_parentFrame" type="Window" usage="input"/>
        <Parameter name="_offsetLeft" type="Integer"/>
        <Parameter name="_offsetTop" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ea1320b6-c416-4890-afd7-611d7fb3ef56">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2010	cnwer1	Initial creation
15 Sep 2020	jlgdap1	TFS 49316 MTN Machine Idle Time
03/10/2022 navds21 TFS 50083 MTN - Machine Delay Idle Time
*/

vars
	entTableDef : EntTableDef;
	theCaption	: String;
begin
	inheritMethod();
	
	self.setupControlFromParent(self.dbcMain,self,0,0);
	self.setupControlFromParent(self.lstObject,self.dbcList,0,0);
	self.setupControlFromParent(self.fldDetails,self.dbcDetails,0,0);
	self.setupControlFromParent(self.picSettings,self.shtSetttings,0,0);

	self.setupControlFromParent(self.lblMainInfo,self.frmDetailsTop,20,0);
	
	self.setupControlFromParent(self.mulSecondaryTask,self.shtVehAppSecondary2,0,20);
	self.setupControlFromParent(self.mulPrimaryTask,self.shtVehAppPrimary2,0,20);
	
	self.setupControlFromParent(self.mulPrimaryCargo,self.shtVehAppPrimCargo2,0,20);
	self.setupControlFromParent(self.mulSecondaryCargo,self.shtVehAppSecCargo2,0,20);
	
	self.setupControlFromParent(self.mulPrimaryDirector,self.shtVehAppPrimDir2,0,20);
	self.setupControlFromParent(self.mulSecondaryDirector,self.shtVehAppPrimary2,0,20);
	
	
	self.dbcDetails.alignChildren:=JadeDockBar.AlignChildren_AllHorizontal;
	self.setupLstObject();
	self.setPicSettingsScrollRange();
	
	self.myAssistant.comboBoxOverstowMode(self.cmbOstowMode);
	self.myAssistant.comboBoxLocationDisplayFormat(self.cmbLocationDisplay);
	
	self.setupMultiSelectLists(self.mulPrimaryTask,ETDef_VehicleAppFields,app.getErrorString(Primary),CMUI_RTVehicleConfig::displayEntryRTEntryField.name,btnTransPrimary);
	self.setupMultiSelectLists(self.mulSecondaryTask,ETDef_VehicleAppFields,app.getErrorString(Secondary),CMUI_RTVehicleConfig::displayEntryRTEntryField.name,null);
	self.setupMultiSelectLists(self.mulPrimaryCargo,ETDef_VehicleAppCargoFields	,app.getErrorString(Primary),CMUI_RTVehicleConfig::displayEntryRTEntryField.name,null);
	self.setupMultiSelectLists(self.mulSecondaryCargo,ETDef_VehicleAppCargoFields,app.getErrorString(Secondary),CMUI_RTVehicleConfig::displayEntryRTEntryField.name,null);
	self.setupMultiSelectLists(self.mulPrimaryDirector,ETDef_VehicleAppCargoFields	,app.getErrorString(Primary),CMUI_RTVehicleConfig::displayEntryRTEntryField.name,null);
	self.setupMultiSelectLists(self.mulSecondaryDirector,ETDef_VehicleAppCargoFields,app.getErrorString(Secondary),CMUI_RTVehicleConfig::displayEntryRTEntryField.name,null);
	
	
	self.lstObject.listIndex:=1;
	self.lstObject.click(self.lstObject);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.picSettings.enabled:= false;
		self.mulPrimaryTask.enabled:=false;
		self.mulSecondaryTask.enabled:=false;
		self.btnHookDoorDir.enabled:= false;
		self.btnHookISO.enabled:= false;
		self.btnHookLocation.enabled:= false;
		self.btnDelete.enabled:= false;
		self.btnSave.enabled:= false;
	endif;
	
	// TFS 49316 start
	//if not self.myTerminal.getConfig(IdleTimeEnabled).Boolean then   // 03.10.2022 navds21 TFS 50083
	if not self.myTerminal.getConfig(IdleTimeEnabled).Boolean and not self.myTerminal.getConfig(DelayTimeEnabled).Boolean then // 03.10.2022 navds21 TFS 50083
		self.grpIdleandDelay.enabled := false;
		self.grpIdleandDelay.visible := false;
		self.grpUserHooks.top:=self.grpIdleandDelay.top; 	//jlier1 TFS 52160 26/10/21
	else
		self.grpIdleandDelay.enabled := true;
		self.grpIdleandDelay.visible := true;
	endif;
	// TFS 49316 end
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupLstObject" id="6841383a-eb61-4f0d-a98b-0f48ac814659">
        <source>setupLstObject() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2010	cnwer1	Initial creation
14 May 2018	jlgmd1	TFS #38555 - MSL - Portainer Crane in RT

*/

vars
	iter,machineIter 	: Iterator;
	machineType 		: CM_MachineType;
	machine				: CM_Machine;
	machineByTypeIdDict 	: CM_MachineByTypeIdDict;
	addMachineType		: Boolean;
	idx 				: Integer;
begin

	idx:=self.lstObject.addTreeObject(self.myTerminal.code,self.myTerminal,1,true);
	
	iter:=app.myRoot.allMachineTypes.createIterator;
	create machineByTypeIdDict transient;
	self.myTerminal.machines.copy(machineByTypeIdDict);
	machineIter:=machineByTypeIdDict.createIterator;
	while iter.next(machineType) do
		//portainer cranes are not used in RT apps so ignore for now
		//if machineType.type = MACHINETYPE_PORTAINER_CRANE then
		if not machineType.supportsRT then	// TFS 38555
			continue;
		endif;
		machineIter.reset;
		machineByTypeIdDict.startKeyGeq(machineType.type,null,machineIter);
		addMachineType:=false;
		while machineIter.next(machine) do
			if machine.machineType &lt;&gt; machineType.type then
				break;
			endif;
			if not addMachineType then
				idx:=self.lstObject.addTreeObject(machineType.description,machineType,2,true);
				addMachineType:=true;
			endif;
			idx:=self.lstObject.addTreeObject(machine.id,machine,3,false);
		endwhile;
		
	endwhile;
	
epilog
	delete machineByTypeIdDict;
	delete iter;
	delete machineIter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMultiSelectLists" id="21c51fb4-8c5f-4bd8-93d0-9a1954e7c81c">
        <source>setupMultiSelectLists(	_multiList : CMUI_MultiSelectGroupBox input;
						_entDefName : String;
						_catption : String;
						_displayCallback : String;
						_translateButton : Button input) protected;
/*

Date		Who		Reason
20 June 2017	cnwer1	Initial creation TFS

*/

vars
	entTableDef : EntTableDef;
begin
	entTableDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[_entDefName];
	_multiList.myAvailableListBox.sorted:=true;
	_multiList.mySelectedListBox.sorted:=false;
	_multiList.setupControl(_catption, entTableDef.allEntTableRows, _displayCallback);
	_multiList.setVisibleButtons(true,true,true);
	_multiList.mySelectedListBox.tabIndex := _multiList.mySelectedListBox.tabIndex + 1;
	//epr 24/8/11 CCMS 1033 - btn to open up translations of cargo fields
	if _translateButton &lt;&gt; null then
		_translateButton.top:=0;
		_translateButton.parent:=_multiList;
		_translateButton.left:=_multiList.myAddSelectedBtn.left;
		_translateButton.top:=_multiList.myBottomSelectedBtn.top + _multiList.myBottomSelectedBtn.clientHeight + 5;
		_translateButton.tabIndex := _multiList.myDownSelectedBtn.tabIndex + 1;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_multiList" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_entDefName" type="String"/>
        <Parameter name="_catption" type="String"/>
        <Parameter name="_displayCallback" type="String"/>
        <Parameter name="_translateButton" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="skipToAttribute" id="46ed1ad2-95fa-4296-803e-4d0b6df63bf7">
        <updating/>
        <source>skipToAttribute(_attributeName: String; _shtName: String) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 21 March 2023
TFS#		: 57126
Function	: To be able to locate the Settings Tab in the Configure Option Locator

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars

	index : Integer;
	control : Control;
	tmpSheet : CMUI_Sheet;
begin

	foreach index in 1 to self.controlCount do
		control := self.controls(index);
		if control.isKindOf( CMUI_Sheet ) then
			tmpSheet := control.CMUI_Sheet;
			if tmpSheet.name = "shtLookFeel" then
				continue;
			endif;
		else
			continue;
		endif;
		if _shtName &lt;&gt; tmpSheet.caption then
			continue;
		endif;		
		tmpSheet.showMySheet();
		
		break;
		
	endforeach;	
	
epilog

end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9db05c13-0004-44e1-a0c2-4197d39e79e0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 November 2025 09:44:57.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014999, locale);
	btnCancel.translateCaption(Xlat_0015000, locale);
	btnDelete.translateCaption(Xlat_0015001, locale);
	btnHookDoorDir.translateCaption(Xlat_0019413, locale);
	btnHookISO.translateCaption(Xlat_0019414, locale);
	btnHookLocation.translateCaption(Xlat_0019415, locale);
	btnSave.translateCaption(Xlat_0015002, locale);
	btnTemplCritEdit.translateBubbleHelp(Xlat_0016133, locale);
	btnTemplCritEdit.translateCaption(Xlat_0024553, locale);
	btnTransCargo.translateBubbleHelp(Xlat_0016916, locale);
	btnTransPrimary.translateBubbleHelp(Xlat_0022020, locale);
