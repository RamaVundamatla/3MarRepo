<GUIClass name="ComboBox">
    <JadeMethod name="jssSet" id="3b76c59d-e670-48c2-9101-28929255b7ec">
        <updating/>
        <source>jssSet(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Updates the receiver's listIndex with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.listIndex &lt;&gt; pValue then
		self.listIndex	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssSetObjectIndex" id="2dea056c-1cfd-484c-a0d7-14fba4b88293">
        <updating/>
        <source>jssSetObjectIndex(pTheObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Sets the list index of the receiver to the index that contains the
//				specified object.
//
// Parameters:	pTheObject - The object who's index to scan for.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.listIndex	:=	self.findObject(pTheObject);
end;</source>
        <Parameter name="pTheObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="jssSetTextIndex" id="2f042266-eae3-45df-8ea2-7537c0ff4809">
        <updating/>
        <source>jssSetTextIndex(pTextValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Sets the list index of the receiver to the index that contains the
//				specified text.
//
// Parameters:	pTextValue - The text to scan for.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.listIndex	:=	self.findString(1, pTextValue);
end;</source>
        <Parameter name="pTextValue" type="String"/>
    </JadeMethod>
</GUIClass>
