    <JadeMethod name="setValue" id="f69806ca-a2cf-457c-81ff-a34f0493f3a3">
        <updating/>
        <source>setValue(_value : Decimal) updating;
/*

Date		Who		Reason
04 April 2016	cnwer1	Initial creation TFS 1707
18/10/2023	navcs2	ChangeRequest 59995: EUP | Damage Recording - Updating Cargo Details
This method takes either weight in kgs etc  i.e the stored default and sets the value column the value converted to the current unit
*/

vars
	measure		: CM_MeasurementType;
	value		: String;
begin
	measure:=self.getMeasurementType();
	if measure &lt;&gt; null then														//18/10/2023	navcs2	ChangeRequest 59995									
		value:=app.convertMeasurementForDisplay( measure.shortName, _value);
		value := measure.removeDecimalZeros(value);
	endif;
	self.accessCell(1, self.ColumnValue).text := value;
epilog

end;</source>
        <Parameter name="_value" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setValueDefault" id="fe30309e-7d12-448d-9190-42568a89d384">
        <updating/>
        <source>setValueDefault(_value : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2013	cnwdap1	Initial creation
*/
vars
	measure		: CM_MeasurementType;
	unit		: String;
	converted	: String;

begin
	if self.measurementType &lt;&gt; null then
		measure := app.getDefaultMeasurementForType(self.measurementType);
		unit := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit, _value.Decimal);
		self.setValues(converted &amp; Space &amp; unit);		
	endif;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setValues" id="deaf1cba-09a8-4575-949e-295b6a9ab223">
        <updating/>
        <source>setValues(_str : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 UImperial Measurements
11/03/2014	cnwdap1	PAR #33603 Correct measurement handling for different locales - can't use Comma 
					as a delimiter, as some locales (e.g. Italian) use Comma as a decimal separator
29/04/2024	jlika1	TFS 63742 CUX - 14075 error in MTN When we click on MAFI with long characters in Height field
*/
vars
	pos, width		: Integer;
	value, unit 	: String;
	measure			: CM_MeasurementType;
	//commaPos	: Integer;									// PAR #33603
	semiColonPos	: Integer;								// PAR #33603
	endPos			: Integer;
	precisionError	: Boolean;
begin
	on Exception do app.handlePrecisionError(exception, precisionError);
	
	pos := _str.pos(Space, 1);
	//commaPos := _str.pos(Comma, 1);						// PAR #33603
	//if commaPos &lt;&gt; null then								// PAR #33603
	//	endPos := commaPos - pos - 1;						// PAR #33603
	semiColonPos := _str.pos(SemiColon, 1);					// PAR #33603
	if semiColonPos &lt;&gt; null then							// PAR #33603
		endPos := semiColonPos - pos - 1;					// PAR #33603
	else
		endPos := _str.length;
	endif;
	if pos &lt;&gt; null then
		value := _str[1:pos-1];
		unit := _str[pos+1:endPos];
		self.accessCell(1, self.ColumnUnit).text := unit;
		self.change(self);
		measure := app.myRoot.allMeasurementTypesByShortName[unit];
		if measure &lt;&gt; null then
			value := measure.removeDecimalZeros(value);
		endif;		
		self.accessCell(1, self.ColumnValue).text := value;			
	endif;
	width := self.getTextExtent(value);
	if width &lt; 40 then
		width := 40;
	endif;
	if self.parent.isKindOf(Table) then
		self.setColumnWidths(width + 10, self.getTextExtent(unit) + 40);
	endif;
	
	if precisionError then				
		//Just do nothing		
	endif;
	
epilog

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setup" id="f52d3598-15f5-48a3-86e5-eb1c59851232">
        <updating/>
        <source>setup(_type : String; _backColor : Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

	type : String;

begin

	if _type = Type_Length
	or _type = Type_Height
	or _type = Type_Width
	then
		type := Type_Linear;
	else
		type := _type;
	endif;
	

	self.measurementType := type;
	self.loadCombo;
	self.change(self);
	self.accessColumn(self.ColumnSpacer).width := 5;
	self.accessColumn(self.ColumnSpacer).backColor := _backColor;
	if not self.parent.isKindOf(Table) then
		self.tabKey := J_key_Tab;
		self.rowHeight[1] := (self.height - 2).Integer;
	endif;
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_backColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupFromCargoType" id="72fc420d-b0a6-4bd5-b645-858c7895ac97">
        <updating/>
        <source>setupFromCargoType( _cargoType : CM_CargoType; _product : CM_Product; _backColor : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	cargoType : CM_CargoType;
	product : CM_Product;
	
	measureType : CM_MeasurementType;
	unit : String;

begin
	
	if _cargoType &lt;&gt; null then
		cargoType := _cargoType;
	endif;
	
	if _product &lt;&gt; null then
		product := _product;
		cargoType := _product.myCargoType;
	endif;
	
	if cargoType = null then
		return;
	endif;
	
	if cargoType.isTrackByVolume then
		self.tabKey := J_key_Tab;
		self.setup(Type_Volume, _backColor);
		if product &lt;&gt; null then
			measureType := product.getDefaultMeasurementForType(Type_Volume);
		endif;
		if measureType = null then
			measureType := cargoType.getDefaultMeasurementForType(Type_Volume);
		endif;
		
	
	elseif cargoType.isTrackByWeight then
		self.tabKey := J_key_Tab;
		self.setup(Type_Weight, _backColor);
		if product &lt;&gt; null then
			measureType := product.getDefaultMeasurementForType(Type_Weight);
		endif;
		if measureType = null then
			measureType := cargoType.getDefaultMeasurementForType(Type_Weight);
		endif;
	
	else
		return;
	endif;
	
	unit := measureType.shortName;
	self.setMeasurementType( measureType.measurementType );
	self.setValues( "0 " &amp; unit );
	
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_backColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="c73372ba-5c24-4286-bb4e-1c66bb4e84b9">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2013	cnwdap1	Initial creation
12 February 2019	jlgzm1	TFS43291 some skins cauing visual issues when tabbing
*/
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	self.columns := 3;
	self.rows := 1;
	self.fixedRows := 0;
	self.fixedColumns := 0;
	self.show3D := self.Show3D_Not3D;
	self.alignment := self.Alignment_Left_Middle;
	self.scrollBars := self.ScrollBars_None;
	
	self.accessCell(1, self.ColumnValue).inputType := self.InputType_TextNumeric;
	self.accessedCell.cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	self.accessCell(1, self.ColumnUnit).inputType := self.InputType_ComboBox;
	self.accessCell(1, self.ColumnSpacer).inputType := self.InputType_None;
	
	self.accessColumn(self.ColumnSpacer).enabled := false;
	
	self.ignoreSkin := true; //tfs43291
	
	//cnwmc5 - PAR 32613 - T822
	self.selectMode := self.SelectMode_None;
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
