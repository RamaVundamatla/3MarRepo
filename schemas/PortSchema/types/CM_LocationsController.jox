    <JadeMethod name="isStockControlled" id="913b4cea-d83d-4a49-b83c-0836c3c7a689">
        <source>isStockControlled() : Boolean;
// ---------------------------------------------------------------------------
// Created:     24 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.canBeStockControlled) then
		return false;
	endif;

	if self.myTerminalArea = null then
		return false;
	endif;
	
	return self.myTerminalArea.isStockControlled;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
