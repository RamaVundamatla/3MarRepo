    <JadeMethod name="getDisplayStringForAttribute" id="ee41c7a6-c8f0-4324-9596-dc5c815ff977">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08 March 2018	jlgdap1		Initial creation TFS 
//
vars
	eventType : CM_EventType;
	resource : HMS_Resource;
	str : String;

begin
	if _attrName = ETRow_EmailOptions then
		if self.myEmailTemplate &lt;&gt; null then
			return self.myEmailTemplate.subject;
		else
			return app.getErrorString(Not_Set);
		endif;
		
	elseif _attrName = ETRow_VoyageEvents then
		if self.allEventsToCreate.isEmpty then
			return app.getErrorString(Not_Set);
		else
			foreach eventType in self.allEventsToCreate do
				if str = null then
					str := eventType.name;
				else
					str := str &amp; Comma &amp; eventType.name;
				endif;
			endforeach;
			return str;
		endif;
		
	elseif _attrName = ETRow_HmsResourcesEst then
		if self.allHMSResourcesAllowed.isEmpty then
			return app.getErrorString(Not_Set);
		else
			foreach resource in self.allHMSResourcesAllowed do
				if str = null then
					str := str &amp; resource.description;
				else
					str := str &amp; Comma &amp; resource.description;
				endif;
			endforeach;
			return str;
		endif;
	
	elseif _attrName = ETRow_HmsResourcesApp then	//01 Aug 2018	NDL	TFS 39900
		if self.allHMSResourcesApproval.isEmpty then
			return app.getErrorString(Not_Set);
		else
			foreach resource in self.allHMSResourcesApproval do
				if str = null then
					str := str &amp; resource.description;
				else
					str := str &amp; Comma &amp; resource.description;
				endif;
			endforeach;
			return str;
		endif; 
		
	elseif _attrName = ETRow_Id then	//01 Aug 2018	NDL	TFS 39900
			return self.id.asStringJMT;
			
	elseif _attrName = ETRow_VoyageProcess then
		return self.myProcess.description;
		
	elseif _attrName = ETRow_ReportToRun then	//31 May 2018	NDL	TFS 38905
		return self.reportToRun;
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHMSResourceForClass" id="3460334a-7104-4975-87db-08dc5430f35b">
        <source>getHMSResourceForClass(_harbour : HMS_Harbour;
						_class : Class ) : HMS_Resource;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlger1	Initial creation

*/

vars
	hmsResource : HMS_Resource;
	hmsResourceType : HMS_ResourceType;
begin
	foreach hmsResource in self.allHMSResourcesAllowed discreteLock do
		if hmsResource.myHarbour &lt;&gt; _harbour then
			continue;
		endif;
		
		hmsResourceType:=hmsResource.myResourceType;
		if hmsResourceType = null or hmsResourceType.isNotAvailableForEntry or
			hmsResourceType.isMarineService then
			continue;
		endif;	
	
		if hmsResource.isResourceForClass(_class) then
			return hmsResource;
		endif;
	
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="hasWebPortalAction" id="ebcc2208-0540-4704-ab17-f482a5a825cd">
        <source>hasWebPortalAction() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/03/2018	jlgdap1		Initial creation TFS 37540 PEL1 Voyage Statuses Pelindo 1
// 22/03/2017	jlgdap1		TFS 37544 PEL1 Voyage Statuses InaPortNet
// 11 OCt 2021	jlier1 	TFS 51963 removed inapornet 
vars

begin
	if self.id.isOneOf(Voyage_Status_CargoReqPending, Voyage_Status_ServicesPending, Voyage_Status_DepServPending) then	// TFS 37544
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
