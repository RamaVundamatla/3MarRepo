<Class name="UM_BlameItem" id="2b770abd-b18e-4e4a-b8f0-ae6d2b75d4a9">
    <superclass name="UM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
