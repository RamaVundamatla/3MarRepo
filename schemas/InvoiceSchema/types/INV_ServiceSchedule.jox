    <JadeMethod name="translateForm" id="ab94c1e0-c76d-4c53-8bad-b537fac42120">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 January 2017 09:50:16.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006216, locale);
	btnAudits.translateBubbleHelp(Xlat_0006217, locale);
	btnAudits.translateCaption(Xlat_0006218, locale);
	btnDelete.translateBubbleHelp(Xlat_0002246, locale);
	btnDelete.translateCaption(Xlat_0002249, locale);
	btnNew.translateBubbleHelp(Xlat_0002247, locale);
	btnNew.translateCaption(Xlat_0002250, locale);
	btnNewGroup.translateBubbleHelp(Xlat_0002248, locale);
	btnNewGroup.translateCaption(Xlat_0002251, locale);
	btnPrint.translateBubbleHelp(Xlat_0006219, locale);
	btnPrint.translateCaption(Xlat_0006220, locale);
	btnProperties.translateBubbleHelp(Xlat_0002244, locale);
	btnProperties.translateCaption(Xlat_0002245, locale);
	mnuAudits.translateCaption(Xlat_0021732, locale);
	mnuInspect.translateCaption(Xlat_0006221, locale);
	mnuNewGroup.translateCaption(Xlat_0006222, locale);
	mnuNewService.translateCaption(Xlat_0006223, locale);
	mnuService.translateCaption(Xlat_0006224, locale);
	mnuServiceDelete.translateCaption(Xlat_0006225, locale);
	mnuServiceNew.translateCaption(Xlat_0006226, locale);
	mnuServiceProperties.translateCaption(Xlat_0006227, locale);
end;</source>
    </JadeMethod>
