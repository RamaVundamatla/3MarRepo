	tmpCol : CM_LogLengthsBySortOrder;
begin
	if _length &lt;&gt; null then
		_table.setValueByControlName(_lengthCmb.name, _length.code);
	else
		_table.setValueByControlName(_lengthCmb.name, null);
	endif;
	if _grade &lt;&gt; null then
		//tmpCodeGroup := _grade.allLogLengths;
		tmpCol := _grade.allLogLengthsBySortOrder;		
	endif;

	//self.comboBoxAddCode(_lengthCmb, tmpCodeGroup, _length, false);
	self.comboBoxAddCode(_lengthCmb, tmpCol, _length, false);	

