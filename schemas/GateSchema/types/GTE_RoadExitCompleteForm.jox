    <JadeMethod name="getTrailerFromJob" id="6e44c73f-3d91-48ed-88ca-36052c3d5303">
        <updating/>
        <source>getTrailerFromJob() : CM_TILC protected, updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 05 June 2007
//
//----------------------------------------------------------------------

vars
	job : CM_Job;
	wle : CM_WorkListEntry;
begin
	job := self.myJob;

	foreach wle in job.workListEntries where CM_TILC.hasInstance(wle.myTrackedItem) and not wle.isReceipt do
		self.myTrailer := wle.myTrackedItem;
		return wle.myTrackedItem.CM_TILC;
	endforeach;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_TILC"/>
    </JadeMethod>
    <JadeMethod name="getTrailerWorkEntry" id="60782c8b-7105-4d5a-812c-4ba52c5cb3da">
        <updating/>
        <source>getTrailerWorkEntry(_ti : CM_TrackedItem): CM_WorkListEntry updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 19 June 2007
//
//----------------------------------------------------------------------

vars
	job : CM_Job;
	wle : CM_WorkListEntry;
begin
	job := self.myJob;

	foreach wle in job.workListEntries where CM_TILC.hasInstance(wle.myTrackedItem) do
		self.myTrailer := wle.myTrackedItem;
		return wle;
	endforeach;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getUnassignedReleases" id="d6fd3c6c-f4da-40ce-8a9e-98fe118664b0">
        <updating/>
        <source>getUnassignedReleases(_wleArray : CM_WLEArray input; _tiArray : CM_TIArray input )  updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 29 June 2007
//
//----------------------------------------------------------------------

vars
	tbl : CM_DataTable;
	rowIdx,
	rows	: Integer;
	wle : CM_WorkListEntry;
	str : String;
	ti	: CM_TrackedItem;
	cargoType : Integer;
begin
	tbl := self.tblReleases;
	rows := tbl.rows;
	//CHECK EACH ROW IN TABLE FOR UNASSIGNED RELEASES
	foreach rowIdx in 2 to rows do
		wle := tbl.accessRow(rowIdx).itemObject.CM_WorkListEntry;
		if wle = null  or wle.status = WLE_COMPLETED then
			continue;
		endif;
		
		if wle.myTrackedItem = null then
			str := tbl.getCellText(rowIdx, self.cargoIdColumnRelease);
		endif;
	
		ti := self.myTerminal.lookupTrackedItem(str, null, TI_STATE_NORMAL, null, false);
		if ti &lt;&gt; null then
			_tiArray.add(ti);
			_wleArray.add(wle);
		endif;
			
		app.writeStatement( str);
	endforeach;
	
	//CHECK FOR CARGO ITEM IN RELEASE
	
	//RETURN THE WLE SET
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWorkEntriesToComplete" id="64554239-6daa-4edc-a912-8fa37a2a3506">
        <updating/>
        <source>getWorkEntriesToComplete(_wleArray : CM_ObjectArray io) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 29 June 2007
//
//----------------------------------------------------------------------

vars
	tbl : CM_DataTable;
	rowIdx,
	rows	: Integer;
	wle : CM_WorkListEntry;
	str : String;
	ti	: CM_TrackedItem;
	cargoType : CM_CargoType;
	cmifWLE : CMIF_WorkEntry;
	comboBox : CMUI_ComboBox;
	exc : Exception;
begin
	//GET INCOMPLETE WLES.
	//THESE ARE ONES THAT HAVE NOT BEEN MOVED OFF THE TRUCK.
	tbl := self.tblReceivals;
	rows := tbl.rows;
	foreach rowIdx in (tbl.fixedRows + 1) to rows do
		wle := tbl.accessRow(rowIdx).itemObject.CM_WorkListEntry;
		if wle = null  or wle.status = WLE_COMPLETED then
			continue;
		endif;
		
		str := tbl.getCellText(rowIdx, self.locationColumn);
						
		create cmifWLE transient;
		cmifWLE.set(null, str, cargoType, wle, wle.myTrackedItem, self.myTerminal);
				
		_wleArray.add(cmifWLE);
	endforeach;

	//NOW CHECK FOR RELEASES THAT HAVE NOT BEEN LOADED OR ALLOCATED A TRACKED ITEM.
	tbl := self.tblReleases;
	rows := tbl.rows;
	//RESET STR AS IT MAY HAVE BEEN USED IN THE ABOVE INFO GATHERING.
	str := null;
	foreach rowIdx in 2 to rows do
		wle := tbl.accessRow(rowIdx).itemObject.CM_WorkListEntry;
		if wle = null  or wle.status = WLE_COMPLETED then
			continue;
		endif;
		
		if wle.myTrackedItem = null then
			str := tbl.getCellText(rowIdx, self.cargoIdColumnRelease);
		endif;
		
		comboBox := tbl.accessCell(rowIdx, self.cargoTypeColumnReleaseTable).cellControl.CMUI_ComboBox;
		if comboBox &lt;&gt; null and comboBox.listObject &lt;&gt; null then
			cargoType := comboBox.listObject.CM_CargoType;
		endif;
		
		create cmifWLE transient;
		cmifWLE.set(str, null, cargoType, wle, wle.myTrackedItem, self.myTerminal);
		
		_wleArray.add(cmifWLE);
	endforeach;

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_wleArray" type="CM_ObjectArray" usage="io"/>
    </JadeMethod>
