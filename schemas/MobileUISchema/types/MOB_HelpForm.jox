        <embedded/>
        <type name="MOB_Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="frm_Enquiry" id="04beacc6-d643-4b0c-b1e7-08a07384b74a">
        <embedded/>
        <type name="MOB_Frame"/>
    </ImplicitInverseRef>
