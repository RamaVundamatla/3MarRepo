end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a22f38bb-b208-4358-b135-5af2ccd967b3">
        <updating/>
        <source>setProxy(pCode, pDescription : String; _codeGroups : CM_CodeGroupsByTypeDict;  _isAvailableForEntry : Boolean) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code 			:= pCode[1:4];
	self.description 	:= pDescription[1:30];
	self.allCodeGroups.clear();
	_codeGroups.copy(self.allCodeGroups);
	self.myRoot 		:= app.myRoot;
	self.isAvailableForEntry := _isAvailableForEntry;
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_codeGroups" type="CM_CodeGroupsByTypeDict"/>
        <Parameter name="_isAvailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="6a14cc81-758b-4bee-840a-2934c5ca1361">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
    if app.myRoot.allOperatorGroups[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;
	self.validateForUpdate;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="353918f3-f7f0-4943-a419-406b6d7e2232">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.allOperators.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "Operators", null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="7b7dbce3-f8ac-432f-a450-a1b8213c507d">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr		: String;
begin
	if self.code = null then
		tmpStr := app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr &amp; 'Group Code', null, null);
		app.raiseCMException1(Input_required_field_andGrpCod, tmpStr, null, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
		tmpStr := app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr &amp; 'Group Description', null, null);
		app.raiseCMException1(Input_required_field_andGrpDes, tmpStr, null, null); // cnwdb2	PAR 35364
	endif;
	
	
end;</source>
    </JadeMethod>
</Class>
