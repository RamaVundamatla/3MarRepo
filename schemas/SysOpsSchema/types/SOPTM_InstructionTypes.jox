    <JadeMethod name="setupThumbnailDetails" id="35cfecdc-5683-457a-a5f9-344912620917">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_InstructionType);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_InstructionType);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="3109e032-7eb1-41ce-940a-ee03b396d63f">
        <updating/>
        <source>showThumbnail(_instructionType : CM_InstructionType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
31 Aug 2023	jlizm1	TFS 59567 Kiosk instruction type maint
*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	
	theForm.tblInput1.setValueByName(ETRow_Code, _instructionType.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _instructionType.description);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, _instructionType.notAvailableForEntry);
	theForm.tblInput1.setValueByName(ETRow_AlwaysToGateOffice, _instructionType.alwaysToGateOffice);
	
	theForm.mulSelect1.setSelected(_instructionType.allTrailerTypes);
	

epilog

end;</source>
        <Parameter name="_instructionType" type="CM_InstructionType"/>
    </JadeMethod>
</Class>
