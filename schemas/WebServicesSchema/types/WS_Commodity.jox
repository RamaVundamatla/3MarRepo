<Class name="WS_Commodity" id="5e87d617-b20d-4061-bc38-145a0420625c">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>The commodity associated with a Tracked Item</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="ae10abac-c1b3-4774-b80d-6bd0092488b5">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <text>4 character commodity code</text>
    </PrimAttribute>
    <PrimAttribute name="comboboxDescription" id="6513c01a-3cde-449c-a746-2ae881cfd30a">
        <length>41</length>
        <embedded/>
        <type name="String"/>
        <text>Concatenated code and description of the commodity.</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="4b1085da-83fc-4fc8-8626-05f51d0a9391">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Commodity Description</text>
    </PrimAttribute>
    <PrimAttribute name="hasTemp" id="ef33bf58-5533-4c6a-a921-1f1ec7522c3b">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isEmpty" id="e975cd88-8464-43fc-922c-3414837b9e1a">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="requiresMAFFields" id="93c07c5f-817e-4caa-add2-f5c43a2bf5c7">
        <embedded/>
        <type name="Boolean"/>
        <text>Specify that the commodity requires its storage details to be recorded. ex. True/False</text>
    </PrimAttribute>
    <PrimAttribute name="requiresPower" id="9343ba68-4dfe-4822-ad95-cd26a778c8e4">
        <embedded/>
        <type name="Boolean"/>
        <text>Power required for this commodity ex.True/False</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="a5012931-d1c2-4485-a46f-26fadf4b706f">
        <updating/>
        <source>setProxyFromObject(_object: CM_Commodity) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
13 Mar 2009	cnwkpd1	PAR #19109 - Show code and description in Web combo boxes
27 Apr 2018 jlgam15 TFS 38006 - Add 'isEnpty' to indicate if the container is empty.

*/

vars

begin
	inheritMethod(_object);
	
	self.code := _object.code;
	self.description := _object.description;
	self.requiresMAFFields := _object.requiresMAFFields;
	self.requiresPower := _object.requiresPower;
	self.comboboxDescription := self.code &amp; " " &amp; self.description;
	self.hasTemp := _object.hasTemp;
	self.isEmpty := _object.isEmpty;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_Commodity"/>
    </JadeMethod>
</Class>
