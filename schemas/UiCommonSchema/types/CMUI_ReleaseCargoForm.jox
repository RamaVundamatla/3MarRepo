    <JadeMethod name="txtNumItems_hasLostFocus" id="cf8f7de6-1cbf-48ca-949b-7a8232455a7f">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtNumItems_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2024	navsp1	Initial creation TFS 62064

*/

vars

begin
	if _fieldFrame.CMUI_FieldTextBox.getString().asIntegerJMT &lt;&gt; null and self.isByTypeByQuantity then
		self.txtReleaseQty.setValue(_fieldFrame.CMUI_FieldTextBox.getString().asIntegerJMT);
	endif;
epilog

end;</source>
