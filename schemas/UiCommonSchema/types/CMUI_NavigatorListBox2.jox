    <JadeMethod name="addCMUI_NavObject" id="6cacec89-bb3b-4594-b769-b09e5d3dd355">
        <updating/>
        <source>addCMUI_NavObject(pNavObj : CMUI_NavigatorObject) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
	
begin

	idx := self.addItem(pNavObj.itemText);
	self.itemObject[idx] := pNavObj;
	self.itemLevel[idx]	 := pNavObj.level;
	self.itemExpanded[idx] := (not pNavObj.isChildObject);
	self.itemPicture[idx] := null;
	return idx;

end;</source>
        <Parameter name="pNavObj" type="CMUI_NavigatorObject"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addCMUI_NavObjectAt" id="d2ab4ba5-6d95-42b7-a2fa-795cd3be6bee">
        <updating/>
        <source>addCMUI_NavObjectAt(pNavObj : CMUI_NavigatorObject; pIdx : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.addItemAt(pNavObj.itemText, pIdx);
	self.itemObject[pIdx] := pNavObj;
	self.itemLevel[pIdx]  := pNavObj.level;
	self.itemExpanded[pIdx] := true;
	
end;</source>
        <Parameter name="pNavObj" type="CMUI_NavigatorObject"/>
        <Parameter name="pIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemObject" id="6f7cbb2f-c941-47b6-8d73-b849f13a8b4d">
        <updating/>
        <source>addItemObject(_menuEnt : CM_MenuEntity) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	itemAbove			: CM_MenuEntity;
	levelAbove,
	level,
	idx	: Integer;
			
begin
	
	idx := self.addItem(_menuEnt.getHeading);
	self.itemObject[idx] := _menuEnt;
	level := _menuEnt.getLevel;

	self.itemLevel[idx]	 := level;
	if level &lt;= 2 then
		self.itemExpanded[idx] := true;
	endif;
	self.itemPicture[idx] := _menuEnt.pictureIcon;	//getPictureIcon(); //null;
	return idx;

end;</source>
        <Parameter name="_menuEnt" type="CM_MenuEntity"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemObjectAsLastChild" id="56b435cb-111e-411c-a66a-fe74cdf06b88">
        <updating/>
        <source>addItemObjectAsLastChild(_parentIndex : Integer; _menuEnt : CM_MenuEntity) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2015	cnwndl1	Initial creation	Par 36846

*/

vars

	parentLevel : Integer;
	startIndex : Integer;
	endIndex : Integer;
	useIndex : Integer; 
	idx : Integer; 

begin

	parentLevel := self.itemLevel[_parentIndex];
	startIndex := _parentIndex + 1;
	endIndex := self.listCount;
	
	if startIndex &lt; endIndex then	
		foreach idx in startIndex to endIndex do
			if self.itemLevel[idx] = parentLevel then
				//found the next parent position, use this.
				useIndex := idx;
				break;
			endif;
		endforeach;
		idx := 0;
		
	endif;
	
	if useIndex &gt; 0 then
		idx := useIndex;
		self.addItemAt(_menuEnt.getHeading, idx);
		self.itemObject[idx] := _menuEnt;
		
	else
		idx := self.addItem(_menuEnt.getHeading);
		self.itemObject[idx] := _menuEnt;
		
	endif;
	
	return idx;

epilog

end;</source>
        <Parameter name="_parentIndex" type="Integer"/>
        <Parameter name="_menuEnt" type="CM_MenuEntity"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemObjectAt" id="5700ab18-4ba1-47e0-92ca-5403c4254446">
        <updating/>
        <source>addItemObjectAt(_menuEnt : CM_MenuEntity input; _idx : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/02/2010	cnwmh5		PAR22373 - Make sure itemLevel is never 0
// ---------------------------------------------------------------------------
vars
	theItemLevel,
	tmpLevel		: Integer;
	theHeading 		: String;
begin
	//cnwmc5 - changed to make nav items with blank headings, now have a heading
	if _menuEnt.getHeading = null then
		if _menuEnt.myParent &lt;&gt; null then
			theHeading:=_menuEnt.myParent.getHeading.trimBlanks();
			if _menuEnt.getMyTerminal() &lt;&gt; null then
				theHeading:=theHeading &amp; " " &amp; _menuEnt.getMyTerminal.code;
			endif;
			_menuEnt.setHeading(theHeading);
		endif;
	endif;
	
	self.addItemAt(_menuEnt.getHeading, _idx);

	self.itemObject[_idx] := _menuEnt;
	theItemLevel := _menuEnt.getLevel;
	if theItemLevel = 0 then
		theItemLevel := 1;
	endif;
	//par 14839 code is given so that itemlevel incremental is avoided 
	if _idx &gt; 1 then					// 16/02/2010 cnwmh5 #22373 - Change from 0 to 1 as if index is 1 then itemLevel becomes 0
		tmpLevel := self.itemLevel[_idx-1];
		
		if theItemLevel &gt; tmpLevel + 1 then
			theItemLevel := tmpLevel + 1;
		endif;
	endif;

	self.itemLevel[_idx]  := theItemLevel;
	self.itemExpanded[_idx] := true;
	
end;</source>
        <Parameter name="_menuEnt" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addMenuEntity" id="be63e4ba-a418-43a1-8b32-a341bb1a06bb">
        <updating/>
        <source>addMenuEntity(_menuEnt : CM_MenuEntity; _callBackMethod : String; _expandToLevel : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     22 November 2002		cnwth2	
//
// Purpose:     
/* Changes

Date		Name	TFS#		Description
============================================================================
20/09/2019 jlgka1 TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	idx					: Integer;
	subMenuEntity		: CM_MenuEntity;
	level				: Integer;
	isExpanded,
	isMenuDtl			: Boolean;
	menuDtl				: CM_MenuUserDtl;
	reportAvailability	: Integer;
	userCargoReportHdr	: CM_MenuUserHdr;	//25 Nov 2015	NDL	Par 36846
	parentIndex			: Integer;	//25 Nov 2015	NDL	Par 36846
	
begin
	if _menuEnt = null then
		return null;
	endif;
	
	isMenuDtl := _menuEnt.isKindOf(CM_MenuUserDtl);
	if isMenuDtl then
		menuDtl := _menuEnt.CM_MenuUserDtl;
		reportAvailability := menuDtl.getReportAvailability();
		if reportAvailability &lt;&gt; null and 
			reportAvailability &lt;&gt; CM_QryReport.ReportAvailability_JMT and
			reportAvailability &lt;&gt; CM_QryReport.ReportAvailability_WebAndJMT then
				return null;
		endif;
		if menuDtl.myMenuItem.isKindOf(CM_QryReportSystem) then
			if menuDtl.myMenuItem.CM_QryReportSystem.isInternal then
				return null;
			endif;
		endif;
	else
		//25 Nov 2015	NDL	Par 36846 
		if _menuEnt.isKindOf(CM_MenuUserHdr) then
			parentIndex := self.findObject(_menuEnt);
			if parentIndex &gt; 0 then
				return null;
			endif;
		endif;
	endif;
	
	//25 Nov 2015	NDL	Par 36846 - default the user defined reports that are not in a folder to appear in the 
	// "User Define Reports" folder
	if isMenuDtl then
		level := _menuEnt.getLevel;
		if level = 2 then
			if menuDtl.myMenuItem.isKindOf(CM_QryReportUser) then
				userCargoReportHdr := menuDtl.CM_MenuUserDtl.getUserCargoReportHdr();
				if userCargoReportHdr &lt;&gt; null then
					parentIndex := self.findObject(userCargoReportHdr);
					if parentIndex &lt; 1 then
						parentIndex := addMenuEntity(userCargoReportHdr, _callBackMethod, _expandToLevel);
					endif;
					if parentIndex &gt; 0 then
						level := self.itemLevel[parentIndex] + 1;
						idx := self.addItemObjectAsLastChild(parentIndex, _menuEnt);
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if idx = 0 then	//25 Nov 2015	NDL	Par 36846
	
		idx := self.addItem(_menuEnt.getHeading);
		self.itemObject[idx] := _menuEnt;
		level := _menuEnt.getLevel;
		
	endif;

	if app.isDevelopmentSystem or app.isSpecial then
		if app.myPassport.getUserCode() = 'CNWSH3' then
		else
			self.itemForeColor[idx] := _menuEnt.getListTextColour();
		endif;
	endif;
	
	
	
	if level &lt;= 0 then
		level := 1;
	endif;
	
	self.itemLevel[idx]	 := level;
	if (level &lt;= _expandToLevel) and (level &gt; 0) then
		isExpanded := true;
		self.itemExpanded[idx] := isExpanded;
	endif;

	if isMenuDtl then	//_menuEnt.isKindOf(CM_MenuUserDtl) then
		self.itemPicture[idx] := menuDtl.pictureIcon;	//getPictureIcon();
		self.itemPictureType[idx] := self.ItemPictureType_Leaf;
		
//write "DETAIL" &amp; "," &amp;  _menuEnt.getHeading() &amp; "," &amp; _menuEnt.pictureStringIcon &amp; "," &amp; _menuEnt.pictureStringButton &amp; "," &amp; _menuEnt.pictureStringButtonDown;

	//	self.itemObject[idx].bubbleHelp := 'hello';
	elseif _menuEnt.isKindOf(CM_MenuRoot) or _menuEnt.isKindOf(CM_MenuUserHdr) then
		//if self.itemExpanded[idx] = true then
	//	if isExpanded then
//write "HEADER" &amp; "," &amp;  _menuEnt.getHeading() &amp; "," &amp; _menuEnt.pictureStringIcon &amp; "," &amp; _menuEnt.pictureStringButton &amp; "," &amp; _menuEnt.pictureStringButtonDown;
		if level &lt; _expandToLevel then	//27 Nov 2015	NDL	Par 36846
			self.itemPicture[idx] := _menuEnt.pictureButton;
			self.itemPictureType[idx] := self.ItemPictureType_Open;
		else
			self.itemPicture[idx] := _menuEnt.pictureButtonDown;	//getPictureButtonDown;
			self.itemPictureType[idx] := self.ItemPictureType_Closed;
		endif;

	elseif _menuEnt.isKindOf(CM_MenuUserToolbar) or _menuEnt.isKindOf(CM_MenuToolbar) then
		self.itemPicture[idx] := _menuEnt.pictureButton;

	endif;
	
	if (_menuEnt.isKindOf(CM_MenuUserHdr) and (_menuEnt.CM_MenuUserHdr.isBGPReportHeader)) or
		(_menuEnt.isKindOf(CM_MenuRootUserBackgroundReps)) then
		//only display headers
		foreach subMenuEntity in _menuEnt.allChildren do
			if subMenuEntity.isKindOf(CM_MenuUserHdr) then
				if _callBackMethod &lt;&gt; null then
					if not self.form.sendMsgWithParams(_callBackMethod, subMenuEntity).Boolean then
						continue;
					endif;
				endif;
				self.addMenuEntity(subMenuEntity, null, _expandToLevel - 1);
			endif;
		endforeach;
		
	else
		foreach subMenuEntity in _menuEnt.allChildren do
			if _callBackMethod &lt;&gt; null then
				if not self.form.sendMsgWithParams(_callBackMethod, subMenuEntity).Boolean then
					continue;
				endif;
			endif;
			
			//cnwmc5 - 18 Dec 2013 - PAR 33186
			if self.isMenuEntityDeprecated(subMenuEntity) then
				continue;
			endif;
			
			self.addMenuEntity(subMenuEntity, _callBackMethod, _expandToLevel - 1);
		endforeach;
	endif;
		
	return idx;

end;</source>
        <Parameter name="_menuEnt" type="CM_MenuEntity"/>
        <Parameter name="_callBackMethod" type="String"/>
        <Parameter name="_expandToLevel" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarItemAt" id="edd5d2ee-5283-4292-89b4-e515e0ee3030">
        <updating/>
        <source>addToolbarItemAt(_menuEntity : CM_MenuEntity input;
				_insertAt : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     22 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pictureIcon			: Binary;
	idx,
	theListCount		: Integer;
begin
	if _menuEntity = null then
		return null;
	endif;
	
	theListCount := self.listCount;
	
	if _insertAt &lt; 1 or _insertAt &gt; theListCount then
		idx := theListCount;
	else
		idx := _insertAt;
	endif;
	
	self.addItemObjectAt(_menuEntity, idx);
	self.itemPicture[idx] := _menuEntity.pictureButton;

	self.itemPictureType[idx] := self.ItemPictureType_Leaf;
	return idx;

end;</source>
        <Parameter name="_menuEntity" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_insertAt" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="bubbleHelp" id="5f1c1ed0-67d2-4def-8b56-1d86aff2637e">
