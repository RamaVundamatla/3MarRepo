    <JadeMethod name="getCurrentLengthOfTime" id="f843c652-a37c-4eaa-80c4-c1945db79733">
        <source>getCurrentLengthOfTime(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2018	jlger1	Initial creation 42159

*/

vars
	lengthOfTime : Decimal[12,2];
	wodVoyageCargoRequest : CM_WodVoyageCargoRequest;
	voyage : CM_Voyage;
begin
	 
	
	lengthOfTime:= inheritMethod();
	if lengthOfTime &lt;&gt; null then
		return lengthOfTime;
	endif;
	
	//if going to a logical berth return 0.0 epr TFS 42396 13/12/18
	if not self.requiresLengthOfTime then  //private berth tfs 42396
		return 0.0;
	endif;
	
	voyage := self.getMyVoyageObject;
	wodVoyageCargoRequest := voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WodVoyageCargoRequest;
	//epr TFS 42159 3/12/18 
	if wodVoyageCargoRequest = null then
	
		//22 Oct 2019	NDL	TFS 47125
		if self.myRelatedPermitRequest &lt;&gt; null then
			return self.myRelatedPermitRequest.getCurrentLengthOfTime();
		endif;
		
		return 0.0;
	endif;
	
	//if coming from anchorage to the cargo request berth return the lenght of time from the cargo request
	if  (self.myToBerth = wodVoyageCargoRequest.myBerth) then
		//if (self.myFromBerth &lt;&gt; null and self.myFromBerth.isLogicalBerth) and
			return wodVoyageCargoRequest.myParent.CM_WorkOrderVoyage.lengthOfTime;
		
	endif;
	
	
	// if this is to a logical berth then return the cargo request ETMAL
		
	return 0.0;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getCurrentLocation" id="993981a8-abab-4b2d-bc06-031e3bf91e0a">
        <source>getCurrentLocation(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2018	jlgndl1	Initial creation	TFS 41272

*/

vars

	berth : HMS_Berth;

begin

	if self.myFromBerth &lt;&gt; null then
		return self.myFromBerth.description;
	endif;
	
	if self.myHMSVoyageMovement &lt;&gt; null then
		berth := self.myHMSVoyageMovement.getMyBerth;
		if berth &lt;&gt; null then
			return berth.description;
		endif;
	endif;

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
