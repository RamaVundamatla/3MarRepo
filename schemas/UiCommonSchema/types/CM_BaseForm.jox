    <JadeMethod name="showExtraInformation" id="1bfcb6d1-d80a-40ab-a3ff-2ded8835d144">
        <source>showExtraInformation(_dataContainer :CM_DataContainer;_theTable : CM_DataTable input;
		_reset : Boolean; _useBigFont : Boolean; _maxColumns : Integer;
		 _colsForData, _colsForHeader, _colsForIcon, _colsforLabel : Integer);
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CMUI_TableAgent to display data
// ---------------------------------------------------------------------------
//23/05/2018 	Jlgns1	Bug 38662: STWO - Transaction resync for 2291 transactions gives error 14051

vars
	tableAgent : CMUI_TableAgent;

begin
	create tableAgent transient;
	tableAgent.addDataToTable(_dataContainer, _theTable, _reset,
			_maxColumns, _useBigFont, _colsForData, _colsForHeader,
			_colsForIcon, _colsforLabel, 0, false);	


	tableAgent.formatMultiLines();
	
	self.doResizeColumnWidths(_theTable,true); //epr par 19271 3/4/09 added this so it always resizes correctly
epilog
	delete tableAgent;
end;
</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_useBigFont" type="Boolean"/>
        <Parameter name="_maxColumns" type="Integer"/>
        <Parameter name="_colsForData" type="Integer"/>
        <Parameter name="_colsForHeader" type="Integer"/>
        <Parameter name="_colsForIcon" type="Integer"/>
        <Parameter name="_colsforLabel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showFormFromPermission" id="bce68ae2-75fe-451c-9811-023d33918f45">
        <source>showFormFromPermission(_thePermission : Integer; _show :Boolean) : Form;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aForm		: Form;
	menuAction	: CMUI_MenuAction;
	
begin
	menuAction := app.myController.createMenuAction(_thePermission, null, self.myMasterMenuAction, self.myTerminal);
	
	if menuAction = null then
		return null;
	endif;
	
	aForm := menuAction.goToObject(null, null, false, null); 
	
	if aForm = null then
		return null;
	endif;
	
	if _show then
		aForm.show;	
	endif;

	return aForm;
end;</source>
        <Parameter name="_thePermission" type="Integer"/>
        <Parameter name="_show" type="Boolean"/>
        <ReturnType type="Form"/>
    </JadeMethod>
