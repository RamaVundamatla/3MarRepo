<Class name="CM_AutoTaskExternalDB" id="907fbd2d-2ca1-4fc5-a606-f0831bdcb603">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Data Extract&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ExplicitInverseRef name="myDataDumpExtractDef" id="0fadece2-470a-4f6a-85b2-5468ef45f104">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_DataDumpExtractDef"/>
        <access>readonly</access>
        <Inverse name="CM_DataDumpExtractDef::allAutoTasks"/>
    </ExplicitInverseRef>
    <JadeMethod name="getEntryTableViewName" id="848469ca-ef8f-4bc6-8706-c4b6273d80cb">
        <source>getEntryTableViewName(): String;

// cnwdvb1 30 June 2003 

vars

begin
	return 'bgpAutoViewExtDB';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="a5822b38-338e-4140-b9f0-90bca1e7df11">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _rowName = ETRow_BgpAutoExtractDefs then
		if global.isValidObject(self.myDataDumpExtractDef) then
			return self.myDataDumpExtractDef.description;
		endif;
	endif;
	
	return inheritMethod(_rowName, _obj);

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="4ce7fbe8-52ef-4666-9d66-907999d37545">
        <source>pxyCreateUpdateProxy() : SelfType;

// cnwdvb1 19 June 2003 
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	task : CM_AutoTaskExternalDB;
	completedOK		: Boolean;
	
begin
	
	task := inheritMethod();
	task.myDataDumpExtractDef := self.myDataDumpExtractDef;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return task;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete task;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4ff2be16-c93e-4369-ab03-960cce09f22b">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskExternalDB) updating;

// cnwdvb1 30 June 2003 

vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName := BGP_ExternalDBRequest.name;
	self.myDataDumpExtractDef := _pxyAutoTask.myDataDumpExtractDef;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskExternalDB"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="89fbb2a7-cb6b-407c-897b-08df49be8fdb">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskExternalDB) updating;

// cnwdvb1 01 August 2003 

vars

begin
	inheritMethod(_pxyAutoTask);
	self.myDataDumpExtractDef := _pxyAutoTask.myDataDumpExtractDef;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskExternalDB"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="661730a0-0e94-4a45-a27d-b4a2d7ba1bb5">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
//--------------------------------------------------------------
//Created: 19 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _rowName = ETRow_BgpAutoExtractDefs then
		self.myDataDumpExtractDef := _value.CM_DataDumpExtractDef;
	else
		inheritMethod(_rowName, _value);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
