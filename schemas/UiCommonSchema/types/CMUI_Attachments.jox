    <JadeMethod name="updateItem" id="28e52e2c-401c-434c-a61d-095e25f6a18a">
        <updating/>
        <source>updateItem() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cargoType	: Integer;
	selectedItem : CMIF_InOutAttachment;
begin

	if self.mySelectedItem = null then
		return false;
	else
		selectedItem := self.mySelectedItem.CMIF_InOutAttachment;
	endif;

	if cmbTiType.listObject &lt;&gt; null then
		cargoType := cmbTiType.listObject.CM_CargoType.id;
	endif;
		
	selectedItem.set(self.myTerminal,
				  cargoType, 
	 			  tblItem.getValueByName(ETRow_Id).String,
			  	  tblItem.getValueByName(ETRow_IsoType).String,
				  tblItem.getValueByName(ETRow_WeightTotal).Integer);

	// check all fields have been entered
	on CM_Exception do addExceptionHandler(exception, app.myPassport);

	app.setContinueCMExceptions(true);

	selectedItem.checkFieldsNotNull(cargoType);

	if app.myPassport.hasErrors then
		app.showErrorWarningDialog('Attachments', app.myPassport, ErrWarnMode_Update);
		return false;
	endif;

	tblAll_ShowAttachment(selectedItem, self.selectedRow);

	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
