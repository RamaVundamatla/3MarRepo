<GUIClass name="MOB_CompleteContainerForm" id="c7f75f9a-3d53-4992-9c6d-8bd9666ed8b5">
    <superclass name="MOB_TwoEntryModalForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="setupForm" id="37cc909b-df48-458e-8f76-88a303427b82">
        <updating/>
        <source>setupForm() updating, protected;

vars

begin
	inheritMethod();
	self.lbl_Input3.caption := "Seal Number";
	self.txt_Input3.case := TextBox.Case_Upper;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="659e5ace-63d0-4761-84fd-194d387cb4b3">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018477, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
