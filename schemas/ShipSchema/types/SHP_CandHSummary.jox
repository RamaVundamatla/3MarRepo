    <JadeMethod name="optActual_change" id="2731643a-20b1-4a46-8692-9b2678398c36">
        <controlMethod name="OptionButton::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optActual_change(optionbutton: OptionButton input) updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin



	self.chkHideEdits.enabled := optionbutton.value;
	self.chkHideColours.enabled := optionbutton.value and (not self.chkHideEdits.value);

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
