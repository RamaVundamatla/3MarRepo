    <JadeMethod name="loadTerminals" id="25edb598-dac6-4065-be70-6c1cda15cb06">
        <source>loadTerminals();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 November 2014	cnwdb2	Initial creation

*/

vars
	term : CM_Terminal ; 
begin

	cmbFilterTerms.addItem("");
	foreach term in app.myRoot.allTerminals do
		cmbFilterTerms.itemObject[cmbFilterTerms.addItem(term.name)] := term;
	endforeach ; 
	
//	cmbFilterTerms.listCollection(app.myRoot.allTerminals,true,0) ; 
	 
epilog
end;</source>
