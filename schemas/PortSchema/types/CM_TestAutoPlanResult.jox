    <JadeMethod name="getAttributeStringForDefArray" id="59011b3d-94be-4cd5-84aa-94ed87dedc78">
        <source>getAttributeStringForDefArray(_array : EntTableRowArray) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	entRow		: EntTableRow;
	tmpStr,
	rtnStr		: String;
	firstTime	: Boolean;
	
begin

	firstTime := true;

	foreach entRow in _array do	
		tmpStr := self.getDisplayStringForAttribute(entRow.name, true);
		if firstTime then
			firstTime := false;
			rtnStr := tmpStr;
		else
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif;
		if entRow.sortFieldName &lt;&gt; null then
			tmpStr := self.getDisplayStringForAttribute(entRow.sortFieldName, false);
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif;
	endforeach;

	return rtnStr;

epilog

end;</source>
        <Parameter name="_array" type="EntTableRowArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a7148fcf-6a2a-4cf7-9ce3-336630784376">
        <source>getDisplayStringForAttribute(_attrName : String; _short : Boolean) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	invalidObject : Boolean;

begin

	if self.myTrackedItem = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalidObject);

	if _attrName = ETRow_AllocationUsed then
		return null;
	
	elseif _attrName = ETRow_CurrentLocation then
		if self.myTrackedItem.myPrimaryActualLocation &lt;&gt; null then
			return self.myTrackedItem.myPrimaryActualLocation.getFullId;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_DischargePort then
		return self.myTrackedItem.dischargePortDescription;
	
	elseif _attrName = ETRow_Id then
		return self.myTrackedItem.id;
	
	elseif _attrName = ETRow_PlanLocation then
		return null;
	
	elseif _attrName = ETRow_PrimeAllocation then
		on Exception do app.handleDeletedObject( exception, self.myPrimeYardAllocation, invalidObject);
		if self.myPrimeYardAllocation &lt;&gt; null then
			return self.myPrimeYardAllocation.code;
		else
			return null;
		endif;
		if invalidObject then
			invalidObject := false;
			return null;
		endif;
	
	elseif _attrName = ETRow_Reason then
		return null;
	
	elseif _attrName = ETRow_VoyageCode then
		if self.myTrackedItem.myVoyage &lt;&gt; null then
			return self.myTrackedItem.myVoyage.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_CreateDT then
		return self.creationTime.asStringJMT;
	elseif _attrName = ETRow_IsInAllocation then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.isInAllocation.String;
		endif;
		return null;
	else
		return app.getErrorString(Contact_developer) &amp; " - Unknown EntTable row. [" &amp; _attrName &amp; "]";
		
	endif;

	

epilog

	if invalidObject then
		return null;
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
