        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblMachineName" id="d74ab18e-cd98-4f68-af86-b53f7d01df32">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtCode" id="44671d35-9830-4677-a4c4-a28f9eb7365e">
        <embedded/>
        <type name="CMUI_TextBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtDescription" id="fb7db1cb-7b2a-4da0-9149-f59e62523f01">
        <embedded/>
