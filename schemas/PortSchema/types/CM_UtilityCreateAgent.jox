    <JadeMethod name="utlCreateBGPRequest" id="e6fd0000-68a2-4cbf-886a-bb41dbc85569">
        <updating/>
        <source>utlCreateBGPRequest(_class : Class; _bgpRequest : BGP_Request io; _task : CM_AutoTask; _transientEventDataDict	: CM_EventDataByTypeDict) : Boolean updating;

// cnwdvb1 11 December 2002 

vars
	requestLimit,
	instancesSize	: Integer;
	bgpRequest		: BGP_Request;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.writeLog('Processing task (' &amp; _task.description &amp; ' ' &amp; _class.name &amp; ')', LogINFO);

	create bgpRequest as _class transient;
	
	requestLimit 	:= bgpRequest.getRequestLimit();
	instancesSize	:= bgpRequest.getInstances(_task) + 1;

	if (requestLimit &gt; 0 and requestLimit &lt; instancesSize) then
		app.writeLog('INFO &gt;&gt; Cannot create ' &amp; _class.name &amp; ' as limit of ' &amp; requestLimit.String &amp; ' has been surpassed' , LogINFO);
		app.remoteErrorWarningToAlert('INFO &gt;&gt; Cannot create ' &amp; _class.name &amp; ' as limit of ' &amp; requestLimit.String &amp; ' has been surpassed' , null, null, null, false, false);
		return false;
	endif;
	
	create _bgpRequest as _class persistent;

	if _transientEventDataDict &lt;&gt; null then
		_bgpRequest.setEventData(_transientEventDataDict);
	endif;
	
	_bgpRequest.initRequestFromTask(_task);
	
	return true;
epilog
	delete bgpRequest;	// TRANSIENT ONE
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_bgpRequest" type="BGP_Request" usage="io"/>
        <Parameter name="_task" type="CM_AutoTask"/>
        <Parameter name="_transientEventDataDict" type="CM_EventDataByTypeDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBGPRequestController" id="1cd32aa4-59e9-4c89-aa54-6fa739dc1177">
