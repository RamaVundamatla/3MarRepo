    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="db65ed6d-8b1c-4fe2-952b-9cf6785df77f">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs: CM_ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//18/08/2023	navkc1	CR 59603 Task 59604: UI - CustDocs More Stop Criteria

*/

vars
	user	: CM_User;
	userTerm: CM_UserTerminal;
	terminal : CM_Terminal;
	
begin
	terminal := _terminalObj;
	
	if terminal = null then
		user := app.getMyUser();
		
		foreach userTerm in user.allUserTerminals do
			terminal := userTerm.getMyTerminal();
			
			if terminal = null then
				continue;
			endif;
			
			terminal.allCustomDocumentTypes.copy(_allCriteriaValues);
		endforeach;
	else
		terminal.allCustomDocumentTypes.copy(_allCriteriaValues);
	endif;
epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
