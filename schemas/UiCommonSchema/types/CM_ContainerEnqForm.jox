    <JadeMethod name="getSiteStateFromString" id="38f91bce-47e9-4cb9-97df-827cd8a49c17">
        <source>getSiteStateFromString(_siteStr : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     17 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _siteStr = ANYSITE_STRING then
		return null;
	elseif _siteStr = ONSITE_STRING then
		return TI_STATE_NORMAL;
	elseif _siteStr = OFFLOADED_STRING then
		return TI_STATE_OFFLOADED;
	elseif _siteStr = OFFSITE_STRING then
		return TI_STATE_OFFSITE;
	elseif _siteStr = ONSHIP_STRING then
		return TI_STATE_ONSHIP;
	elseif _siteStr = NOTIFIED_STRING then
		return TI_STATE_NOTIFIED;
	elseif _siteStr = DELETED_STRING then
		return TI_STATE_DELETED;
	elseif _siteStr = TRANSFER_STRING_TO then
		return TI_STATE_TRANSFER_TO;
	elseif _siteStr = TRANSFER_STRING_FROM then
		return TI_STATE_TRANSFER_FROM;
	else
		return null;
	endif;	

end;</source>
        <Parameter name="_siteStr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIsForLocationsController" id="aad114cd-e995-4ecd-a67e-c94c4b13443c">
        <updating/>
        <source>getTIsForLocationsController(_lc : CM_LocationsController; 
						_numItems : Integer io;
						_tisAdded: CM_TISet io; //	_tisAdded: CM_TIByIdCargoTypeDict input; //cnwrd1 par 24107 10.5.2010
						_filterID : String;
						_passport : CM_Passport) updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// cnwrd1 par 24107 added _filterID parameter for multi cargo ID search
vars	
	displayMode			: Integer;
	tis : CM_TIArray;
begin
	if _lc = null then
		return;
	endif;
	
	endLoad;
	beginLoad;

	displayMode := self.getDisplayMode();
	
	create tis transient; // PAR 32308 AKB
	
	if displayMode = DISPLAY_MODE_ACTUAL then
		_lc.getTIs(tis, REAL_MODE,true);
		
	elseif displayMode = DISPLAY_MODE_QUEUE then
		_lc.getTIs(tis, QUEUE_MODE,true);
		
	elseif displayMode = DISPLAY_MODE_PLAN then
		_lc.getTIs(tis, PLANNING_MODE,true);
	endif;
	
	//epr TFS 37038 was causing a 1309 and there didn't seem to be any point to the id stuff which is filtered by addObjectsToTable
	tis.copyNoDuplicates(_tisAdded);
	
epilog
	endLoad;
	delete tis;
	
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_tisAdded" type="CM_TISet" usage="io"/>
        <Parameter name="_filterID" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getTIsUsingBookingRefXref" id="ee4b52bf-3e45-4a1d-8332-defe7f010226">
        <updating/>
        <source>getTIsUsingBookingRefXref(_brXref : CM_TerminalTIsByBR;
						  _numItems : Integer io; _masterSet : CM_TISet io) updating, protected;

/*

Purpose:			Load the results table with TIs matching the filter criteria using
					the passed in Booking Ref

Parameters:			Cross reference

Return Value:		_numItems updated with the number of matches returned


Date		Who		Reason
04 Sep 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality
14 Sep 2009	cnwkpd1	PAR #20645 - Moved state check from includeObjectTI
30 Sep 2009	cnwkpd1	PAR #20754 - For Tranship items, return imports only when they are on ship,
					and exports only when the import is not on ship
13 May 2010	cnwdap1	CCMS 1116 Tranship changes
13 May 2010 cnwrd1	par 24107 multi cargo id search
*/

vars
	cmifMonitor		: CMIF_Monitor;
	tiSet			: CM_TISet;
	ti				: CM_TrackedItem;
	invalidTI,
	breakOut		: Boolean;
	
begin
   	create cmifMonitor transient;
   	cmifMonitor.myParent := self;
	
	create tiSet transient;
	_brXref.getTIsForBookingRef(self.filterBookingRef, true, tiSet, cmifMonitor);
	
	if self.modalDialogReturnValue = self.ModalDialogReturn_Option1 then
		// Cancel button pressed
		return;
	endif;
	
	self.modalDialogReturnValue := ModalDialogReturn_Null;
	
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);
	
	foreach ti in tiSet do
		if ti.isValid then

			// PAR #20645 - Moved state check here from includeObjectTI
			if self.filterState &lt;&gt; null then
				if ti.state &lt;&gt; self.filterState then
					continue;
				endif;
			endif;
	
			// PAR #20754 - Ensure only one half of a tranship is returned	// PAR #23645 CCMS 1116
			//if ti.isTranshipImport() and ti.state &lt;&gt; TI_STATE_ONSHIP then	// PAR #23645 CCMS 1116
			//	continue;													// PAR #23645 CCMS 1116
			//endif;														// PAR #23645 CCMS 1116
			//if ti.isTranshipExport() then									// PAR #23645 CCMS 1116
			//	if ti.myTranshipImport.state = TI_STATE_ONSHIP then			// PAR #23645 CCMS 1116
			//		continue;												// PAR #23645 CCMS 1116
			//	endif;														// PAR #23645 CCMS 1116
			//endif;														// PAR #23645 CCMS 1116
			if not _masterSet.includes(ti) then
				_masterSet.add(ti);
			endif;
		/*
			if self.includeObjectTI(ti, _numItems, breakOut) then
				self.addObjectToTable(ti, _numItems, breakOut);
			endif;
			*/
		endif;
		
		if breakOut then
			break;
		endif;
	endforeach;

	
epilog
	delete cmifMonitor;
	delete tiSet;

end;</source>
        <access>protected</access>
        <Parameter name="_brXref" type="CM_TerminalTIsByBR"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_masterSet" type="CM_TISet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTableColumFilters" id="2d789ba3-70e9-4417-845d-480c1064221e">
        <updating/>
        <source>getTableColumFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	self.allColumnFilters.cloneFiltersForTable( _table, _allFilterColumns );
	

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTableForRow" id="07c944d9-cae9-4e40-8db6-c15082199613">
        <source>getTableForRow(_name : String) : CM_EntryTable protected;
// CCMS 1776 now that tabs are user-defined, each table must be potentially searched to find a given row
vars
	updateAlphaOrFF	: Boolean;
	idx,
	numDefs,
	row			: Integer;
	tbl			: CM_EntryTable;
begin
	updateAlphaOrFF := (self.isShowingAlphabetised or (not self.canUpdate and self.canChangeFreightForwarder)); // PAR 16564
	if updateAlphaOrFF then
		tbl := self.tblAlpha;
		row := tbl.getRow(_name);
		if row &gt; 0 then
			return tbl;
		else
			return null;
		endif;
	endif;
	numDefs := self.numberOfSheets;
	foreach idx in 1 to numDefs do
		tbl := self.getEditTableForIndex(idx);
		row := tbl.getRow(_name);
		if row &gt; 0 then
			return tbl;
		endif;
	endforeach;

	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_EntryTable"/>
    </JadeMethod>
    <JadeMethod name="getTblDataDef" id="5582e87f-d66b-4d54-a102-2a75af944b7f">
        <source>getTblDataDef() : EntTableDef;
// ---------------------------------------------------------------------------
// Created:     17 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  Returns an appropriate data able definition for the particular selected TI Type
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/10/2009	cnwmh5		PAR 21368	If entDef is null then it causes a 75768
//										error to occur.  Currently it is only
//										cargo type of chassis which is doing this
//										as the ent def it's looking for doesn't exist
//										which is to be addressed in 7.8.1.
// ---------------------------------------------------------------------------
vars
	entDef				: EntTableDef;
	entDefStr			: String;
begin
	
	if self.myCurrentCargoBOLType &lt;&gt; null then
		entDefStr := self.myCurrentCargoBOLType.maintFormTblDataDef;
				
		if entDefStr = null then//it's a centreport cargoBOLtype
			entDefStr := ETDef_DefaultDataTable;
		endif;
		
		entDef := app.myController.getEntTableDef(entDefStr);
		
		// 15/10/2009 cnwmh5 21368
		if entDef = null then
			entDef := app.myController.getEntTableDef(ETDef_DefaultDataTable);
		endif;
		
	else
		entDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);
	endif;

	return entDef;
	
end;</source>
        <ReturnType type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="getTblDataXML" id="c91c089a-8c01-4e2b-93cf-86fa11dddd7f">
        <updating/>
        <source>getTblDataXML(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
11 December 2024		jlizm1	Initial creation MTN 33442 Mafi load details column organiser not saved

*/

vars
	tmpStr : String;
	
begin
	inheritMethod(_userWindow);
	
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblView2.XMLTag_Table &amp; self.tblView2.name);
	self.xmlStrTblView2 := global.formatAsXML( self.tblView2.XMLTag_Table &amp; self.tblView2.name ,tmpStr);

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="getValueFromTables" id="b92d041e-ffd3-44d9-8512-002852f9784b">
        <source>getValueFromTables(_name : String) : Any protected;
// CCMS 1776 now that tabs are user-defined, each table must be potentially searched to find a given row
vars
	updateAlphaOrFF	: Boolean;
	idx,
	numDefs,
	row			: Integer;
	tbl			: CM_EntryTable;
begin
	updateAlphaOrFF := (self.isShowingAlphabetised or (not self.canUpdate and self.canChangeFreightForwarder)); // PAR 16564
	if updateAlphaOrFF then
		tbl := self.tblAlpha;
		row := tbl.getRow(_name);
		if row &gt; 0 then
			return tbl.getValue(row);
		else
			return null;
		endif;
	endif;
	numDefs := self.numberOfSheets;
	foreach idx in 1 to numDefs do
		tbl := self.getEditTableForIndex(idx);
		row := tbl.getRow(_name);
		if row &gt; 0 then
			return tbl.getValue(row);
		endif;
	endforeach;

	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getWeighFormObjects" id="8371e880-1e03-42ab-9e76-83f8ca3dc9b4">
        <source>getWeighFormObjects( _obj : CM_Object;  _objArray: ObjectArray input ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation	Par 33268
08 Jan 2018	NDL	TFS 36437
*/

vars

	errMsg : String;

begin

	if _obj &lt;&gt; null then
		_objArray.addExclusive( _obj );
		_obj.isWeighBridgeWeighable(_objArray,errMsg);
	endif;

	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="85160791-bea3-440c-a11c-d9646c2205f0">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2005	cnwhjg1
//
// Purpose:     
//
// Changed On   Changed By  reason
// ----------   ----------  --------------------------------------------------
// 14/04/2023	navkc1	CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop
// 10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
// 11/12/2024	jlizm1		MTN 33442 Mafi load details column organiser not saved
// ---------------------------------------------------------------------------
vars
	xmlStr	: String;
	userWindow : CM_UserWindow;
	userWinXml : String;
	tblXML : String;
begin

	//22 Feb 2019	NDL	TFS 43332
	//Before we close, reset the local 'xmlStrTblData' (tblData settings) with the current value from the userWindow,
	//as individual parts (based on teh Entable in use) of this get updated in real time from us ( and any other copy
	//of this form that we have open, as we close teh column organiser.
	//So, refresh now so that we don't overwrite those values with whatever this version currently has.
	userWindow := app.getUserWindow(self.name, true);
	userWinXml := userWindow.xmlInfo;	
	tblXML := userWinXml.cnEcGetTagValueOfName( self.tblData.XMLTag_Table &amp; self.tblData.name );
	if tblXML &lt;&gt; null then
		self.xmlStrTblData := global.formatAsXML( self.tblData.XMLTag_Table &amp; self.tblData.name ,tblXML);
	endif;
	
	
	xmlStr := inheritMethod();

// store sort column and value for log dockets. Par 9917
	xmlStr := xmlStr &amp; global.formatAsXML('LogDetails_Sort_ Column' ,self.columnTblView2.String);	
	xmlStr := xmlStr &amp; global.formatAsXML('Log_Sort_Ascending' ,self.sortAscendingTblView2.Integer.String);	

	//epr TFS 47132 14/11/19
	if self.mnuRememberQuery.userObject &lt;&gt; null then
		xmlStr := xmlStr &amp; global.formatAsXML(XmlTag_SelectorQuery, self.mnuRememberQuery.userObject.getOidString);
	endif;
	
	tblXML := userWinXml.cnEcGetTagValueOfName(self.tblView2.XMLTag_Table &amp; self.tblView2.name);
	if tblXML &lt;&gt; null then
		self.xmlStrTblView2 := global.formatAsXML( self.tblView2.XMLTag_Table &amp; self.tblView2.name ,tblXML);
	endif;
	xmlStr := xmlStr &amp; self.xmlStrTblView2;

	return xmlStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="7572743c-e274-4c5d-8c5d-64d6f19da5f6">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theXML,
	theXMLValue			: String;
	columnSortNum		: Integer;
	sortAscending		: Boolean;
	userWindow		: CM_UserWindow;
begin
	inheritMethod();

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	
	theXML := userWindow.xmlInfo;
	
	theXMLValue := theXML.cnEcGetTagValueOfName('LogDetails_Sort_ Column');
 	if theXMLValue &lt;&gt; null then
 		self.columnTblView2 := theXMLValue.Integer;
 	endif;
 	
 	theXMLValue := theXML.cnEcGetTagValueOfName('Log_Sort_Ascending');
 	if theXMLValue &lt;&gt; null then
 		sortAscending := theXMLValue.Integer.Boolean;
 	else
 		sortAscending := true;
 	endif;

	self.sortAscendingTblView2 := sortAscending;
 	
end;</source>
    </JadeMethod>
    <JadeMethod name="handleEndNotification1066" id="07b17cd9-5fb5-4234-b44e-2550f8e908ba">
        <source>handleEndNotification1066(exObj: Exception): Integer;
// ---------------------------------------------------------------------------
// Created:		06 November 2007 By Andrew Bishop cnwab1
//
// Purpose:		PAR 15277
//
// ---------------------------------------------------------------------------
vars
begin
	if exObj.errorCode = 1066 then // notification not set for this OID
		return Ex_Resume_Next;
	endif;
	return Ex_Continue;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleUnavailableCargoType" id="aef25d41-441a-4cd4-943c-ab3e005e6fb3">
        <source>handleUnavailableCargoType(uie : UserInterfaceException) : Integer;
// --------------------------------------------------------------------------------
// Created:		8 February 2010 by cnwjo3
//
// Purpose:		This exception handler deals with situations where some how the customer has a TI with a cargo type that is not available in
//				their terminal and can cause issues with cmbCargoType.  Also deals with situations where CM_ContainerEnqForm::setCargoTypeCombo has
//				not correctly set up all available cargo types
//				
vars
	ct : CM_CargoType;
begin
	if self.myProxyObject &lt;&gt; null and self.myProxyObject.CM_TrackedItem.myCargoType &lt;&gt; null then
		ct := self.myProxyObject.CM_TrackedItem.myCargoType;
		write "**** CargoType: " &amp; ct.description &amp; " appears to be invalid for this terminal.  Contact System Administrator or Developer.";
	endif;
	return Ex_Abort_Action;
end;</source>
        <Parameter name="uie" type="UserInterfaceException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasMultiSelectedQueuedItems" id="23468e44-eb84-4736-a909-0abbdc7c4dc8">
        <source>hasMultiSelectedQueuedItems():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 December 2013	cnwndl1	Initial creation	Par 32900

*/

vars

	obj : Object;
	ti : CM_TrackedItem;
	count : Integer;

begin
	
	if self.tblData.allSelectedObjects.size &lt; 2 then
		return false;
	endif;
	
	foreach obj in self.tblData.allSelectedObjects do
		if CM_TrackedItem.hasInstance( obj ) then
			ti := obj.CM_TrackedItem;
			if not ti.isQueued then
				continue;
			endif;
			count := count + 1;
			if count &gt; 1 then
				break;
			endif;
		endif;
	endforeach;
	
	return ( count &gt; 1 );

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideEmptyRow" id="f2300888-6794-477e-ac56-763f8b7009ef">
        <source>hideEmptyRow(_tbl : CM_EntryTable input; _entRow : EntTableRow; _rowValue : String) : Boolean protected;
/*

Date		Who		Reason
22 January 2015	cnwer1	Initial creation PAR 35553

*/

vars

begin
	if _rowValue.trimBlanks = null then
		_tbl.hideRowByName(_entRow.name, false);
		return true;	
	else
		
		//if _entRow.measurementType &lt;&gt; null and  _rowValue.Decimal = 0 then
		if _entRow.measurementType &lt;&gt; null and  _rowValue.asDecimalJMT = 0 then	//22 Oct 2015	NDL	Par 36655
			_tbl.hideRowByName(_entRow.name, false);
			return true;		
		endif;
		
		if _rowValue = "false" then// or _rowValue = "No" then
			_tbl.hideRowByName(_entRow.name, false);
			return true;	
		endif;			
		
		_tbl.showRowByName(_entRow.name, false);
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entRow" type="EntTableRow"/>
        <Parameter name="_rowValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideShowDataTable" id="69c183ec-be2b-4baf-9453-4d7985a03c14">
        <updating/>
        <source>hideShowDataTable() updating;

// Created by cnwdvb1 on 24 January 2007

vars

begin
	inheritMethod();
	
	if self.isDataTableVisible then
		self.btnPrintList.enabled := true;
		
	else
		self.btnPrintList.enabled := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="hideShowSearchRow" id="82307d71-3a4e-41b7-a671-934a2d6c4cdd">
        <source>hideShowSearchRow(_hide : Boolean; _propName : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2019	jlger1	Initial creation TFS 47132

*/

vars
	critLine : CM_SelectorCriteriaLine;
	rowIdx : Integer;
begin
	if self.myCriteriaLineHolder = null then
		return;
	endif;
	critLine:=self.myCriteriaLineHolder.findCriteriaByName(_propName);
	if critLine &lt;&gt; null then
		if self.tblSearch.findObjectInRow(critLine,rowIdx) then
			if _hide then
				self.tblSearch.hideRow(rowIdx);
			else
				self.tblSearch.showRow(rowIdx);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="_propName" type="String"/>
    </JadeMethod>
    <JadeMethod name="hideToDoTaskMenus" id="afcfb661-c000-4967-9eab-1788bf55f138">
        <updating/>
        <source>hideToDoTaskMenus() updating;
// --------------------------------------------------------------------------------
// Created:		21 May 2009 by cnwjo3
//
// Purpose:		Set ToDo 'No Tasks' Menu item to invisible so they don't appear
//
vars
	idx : Integer;
	ctrl : Control;
	mi : MenuItem;
	hideToDos : ObjectArray;
	obj : Object;
begin
	create hideToDos transient;

	foreach idx in 1 to self.menuItemCount do
		mi := self.menuItems(idx);
		if mi &lt;&gt; null then
			if mi.caption = app.getErrorString(NO_TASKS) then
				hideToDos.add(mi);
			endif;
		endif;
	endforeach;
	
	foreach obj in hideToDos do
		mi := obj.MenuItem;
		mi.visible := false;
	endforeach;
	
epilog
	delete hideToDos;
end;</source>
    </JadeMethod>
    <JadeMethod name="idFilterIsMatch" id="f63197d8-2ea8-4d34-a30c-aa9956157208">
        <source>idFilterIsMatch(testId : String) : Boolean;

/*

Date		Who		Reason
17 Sep 2009	cnwkpd1	PAR #20657 - Change substring match to "startsWith or endsWith" to
					match the rules used when dictionary searches are performed
07 May 2010 cnwrd1	Par 24107 - changed to use a possibly tokanised string for multiple cargo ID searches.
*/

vars
	pos : Integer;
	allFilterIDs : HugeStringArray;
	tokenString,
	tiID: String;
begin
	//1: No filter applies
	if self.filterId = null then
		return true;
	endif;


//	tokenString := self.filterId;
//	tokenString.replaceChar(',', ' ');
	
//	create allFilterIDs transient;
//	tokenString.trimBlanks().getTokensForDelimiterHuge(' ',allFilterIDs);

	if self.myFilterIDList.size &gt; 0 then
		foreach tiID in self.myFilterIDList do
	
			//2: Id is exact match
			if testId = tiID then
				return true;
			endif;
			
			//3: filterId is a substring of testId (eg first or last few characters)
			if testId.startsWith(tiID) then		// PAR #20657
				return true;
			endif;
			
			if testId.endsWith(tiID) then			// PAR #20657
				return true;
			endif;
	
		endforeach;	
	
	else // no entered ti ID.
		return true;
	endif;
		

	/*
	//2: Id is exact match
	if testId = self.filterId then
		return true;
	endif;
	
	//3: filterId is a substring of testId (eg first or last few characters)
	if testId.startsWith(self.filterId) then		// PAR #20657
		return true;
	endif;
	
	if testId.endsWith(self.filterId) then			// PAR #20657
		return true;
	endif;*/

/*	PAR #20657 - old code replaced
	if filterId.length &lt; testId.length then
		pos := testId.pos(filterId, 1);
	endif;
	return (pos &lt;&gt; 0);
*/
	
	return false;
epilog 
	//delete allFilterIDs;
end;</source>
        <Parameter name="testId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="7670aaff-ba58-44e7-8f68-6973bfd45bdf">
        <updating/>
        <source>includeObject(_obj: Object;  passport : CM_Passport): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	breakOut	: Boolean;
	tmpTI		: CM_TrackedItem;
	tmpBOL		: CM_BOL;
begin
	
	if CM_TrackedItem.hasInstance(_obj) then
	
		tmpTI := _obj.CM_TrackedItem;
		return self.includeObjectTI(tmpTI, 0, breakOut);

	elseif CM_BOL.hasInstance(_obj) then
	/* jlier1 JIRA- 35606 1/8/25
		if self.filterCargoTypeId &lt;&gt; BOLType_Log then
			return false;
		endif;*/
		tmpBOL := _obj.CM_BOL;
		return self.includeObjectBOL(tmpBOL, 0,  breakOut);
	endif;

	return false;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObjectBOL" id="08da6f3e-9c3b-41de-8b95-b3de20079887">
        <updating/>
        <source>includeObjectBOL(_bol: CM_BOL; _numItems : Integer; _breakOut : Boolean output): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idLength 		: Integer;
	failedDAC  		:CM_DataAccessController;
	tiID			: String;	
	matched 		: Boolean;
	removedCritLines, tempLines : ObjectSet;
	validClass : Class;	//22 May 2020	NDL	TFS 49379
begin

	if self.mode = Mode_Search then
		if (self.numItemsSearched mod 200) = 0 then
			self.chkSearchReturnOption(_numItems);
			if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
				_breakOut := true;
			endif;
		endif;
		self.numItemsSearched := self.numItemsSearched + 1;
	endif;
	
	//epr TFS 47132 14/11/19
	if self.useSelectorTable then
	
		create removedCritLines transient;
		create tempLines transient;
		self.doPreSelectorSearch(removedCritLines,tempLines);
		
		//22 May 2020	NDL	TFS 49379 - protect against sys note being for a different class
		// than the query is set up for.
		if self.myEnqController &lt;&gt; null then
			validClass := self.myEnqController.myFilterClass;
			if validClass &lt;&gt; null then
				if not validClass.hasInstance( _bol ) then
					return false;
				endif;
			endif;
		endif;
		
		if not _bol.qrySelector(self.myCriteriaLineHolder) then
			return false;
		endif;
			
		if (not _bol.canUserAccessSelf(null, failedDAC, app.myPassport)) then
			return false;
		endif;
	
		return true;
		
	endif;

	matched := false;
	
	if self.filterId = null then

		matched := true;
	else
		foreach tiID in self.myFilterIDList do
		
			idLength := tiID.length;	
			if _bol.number[1 : idLength] =  tiID then //cnwrd1 par 24107 10.5.2010
				matched := true;
				break;
			endif;	
		endforeach;
	endif;
	
	if not matched then
		return false;
	endif;
	

	if self.filterCargoTypeId &lt;&gt; null and
	   _bol.bolType &lt;&gt; self.filterCargoTypeId then
		return false;
	endif;
				
	if _bol.isKindOf(CM_BOLOut) and
	   self.filterState &lt;&gt; TI_STATE_ONSHIP then
		return false;
	endif;

	if self.filterOperator &lt;&gt; null and
	   _bol.myOperator &lt;&gt; self.filterOperator then
		return false;
	elseif (not _bol.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return false;
	endif;

	return true;
epilog
	if self.useSelectorTable then
		self.doPostSelectorSearch(removedCritLines,tempLines);
		delete removedCritLines;
		delete tempLines;
	endif;
end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObjectTI" id="6ba3574f-c99f-4b22-b683-d76f14243283">
        <updating/>
        <source>includeObjectTI(_ti: CM_TrackedItem; _numItems : Integer; _breakOut : Boolean output): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
04 Sep 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality
					Re-ordered checks for performance, and reduced number of refreshes of the
					progress to improve performance on thin client
14 Sep 2009	cnwkpd1	PAR #20645 - Remove state check from here, and move to Booking Ref search only
					to prevent issues with Logical Delete Areas
17/03/2010	cnwmh5	PAR #22715 - Change to use _ti.productCode rather than _ti.myProduct.code as 
						myProduct could have been deleted and causes Error 4
27/05/2010	cnwdap1	CCMS 1116 Tranship changes - voyage filter
07/05/2020	jlgdap1	TFS 49252 CPL Cargo Types not showing in System Admin
*/

constants
	TimeBetweenUpdates		= 2000;
	
vars

	failedDAC	: CM_DataAccessController;
	invalidTI	: Boolean;
	now			: Decimal[20];
	removedCritLines, tempLines : ObjectSet;
	foundMultiId : Boolean;
	idCrit : CM_SelectorCriteriaLine;
	id : String;
	validClass : Class;	//22 May 2020	NDL	TFS 49379
	originalMultiID : String;	//07 Aug 2020	NDL	TFS 49850
	
begin
	/*
	Date		Who		Reason
	8 Aug. 2008	cnwdz2	Par16734 - Use app.handleDeletedObject() to handle invalid object reference.
	*/
	on Exception do app.handleDeletedObject(exception, _ti, invalidTI);

	if self.mode = Mode_Search then
		// PAR #20398 - Changed this check to be based on time, not objects
		//cnwth2 changed mod from 500 to 50, fully understanding the trade off involved in increased notifications.
		//if (self.numItemsSearched mod 50) = 0 then
		now := app.relativeMachineTime();
		if (now - self.lastUpdateMessage) &gt; TimeBetweenUpdates then
			self.lastUpdateMessage := now;
			self.chkSearchReturnOption(_numItems);
			if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
				_breakOut := true;
			endif;
		endif;
		self.numItemsSearched := self.numItemsSearched + 1;
	endif;
	
	//epr TFS 47132 14/11/19
	if self.useSelectorTable then
		//epr TFS 47132 14/11/19

		create removedCritLines transient;
		create tempLines transient;
		self.doPreSelectorSearch(removedCritLines,tempLines);
		
		//22 May 2020	NDL	TFS 49379 - protect against sys note being for a different class
		// than the query is set up for.
		if self.myEnqController &lt;&gt; null then
			validClass := self.myEnqController.myFilterClass;
			if validClass &lt;&gt; null then
				if not validClass.hasInstance( _ti ) then
					return false;
				endif;
			endif;
		endif;
		
		//05 May 2020	NDL	TFS 49240 - Notes were removing lines when multiple ids used
		if self.myFilterIDList.size &gt; 1 then
			originalMultiID := self.myFilterIDList.concatenate(' ');	//07 Aug 2020	NDL	TFS 49850
			idCrit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);  // This guy will have multiple ids in him.  A one to one match will fail.
			//check ids manually first
			foundMultiId := false;
			foreach id in self.myFilterIDList do
				if _ti.id.length &gt;= id.length then
			//		foundMultiId := (_ti.id[1:id.length] = id ) or (_ti.idReversed[1:id.length] = id );
					foundMultiId := (_ti.id[1:id.length] = id ) or (_ti.idReversed[1:id.length] = id.reverse );	//07 Aug 2020	NDL	TFS 49850
					if foundMultiId then
						break;
					endif;
				endif;
			endforeach;
	
			if not foundMultiId then
				//can't be one
				return false;
			endif; 
			//temporarily remove the id check, to check everything else
			idCrit.setMyCriteriaLineHolder( null );
			foundMultiId := _ti.qrySelector( self.myCriteriaLineHolder );
			
			//put the id check back again
			idCrit.setMyCriteriaLineHolder( self.myCriteriaLineHolder );
			
			return foundMultiId;
			
		else
			if not _ti.qrySelector(self.myCriteriaLineHolder) then
				return false;
			endif;
		endif;
	
		if (not _ti.canUserAccessSelf(null, failedDAC, app.myPassport)) then
			return false;
		endif;
		
		if invalidTI then
			return false;
		endif;
		
		return true;

	endif;
	
	if self.filterCargoTypeId &lt;&gt; null then
		if _ti.cargoType &lt;&gt; self.filterCargoTypeId then
			return false;
		endif;
	endif;
	
	if self.filterISOType &lt;&gt; null then
		if _ti.getISOType &lt;&gt; self.filterISOType then
			return false;
		endif;
	endif;

	if self.filterIMEXStatus &lt;&gt; NULL_INTEGER then
		if _ti.getImExStatus() &lt;&gt; self.filterIMEXStatus then
			return false;
		endif;
	endif;	
	
	if self.filterOperator &lt;&gt; null and _ti.myOperator &lt;&gt; self.filterOperator then
		return false;
	endif;
	
	
	// cnwrl1 09/12/2009 PAR 21907 - start of coding
	if self.filterCustomsReference &lt;&gt; null then
		if not _ti.customsReference.startsWith( self.filterCustomsReference ) then
			return false;
		endif;
	endif;
	// cnwrl1 09/12/2009 PAR 21907 - end of coding
	
	//epr par 16659 6/5/08
	if filterTrailerType &lt;&gt; null then
		if not _ti.isKindOf(CM_TILC) then
			return false;
		endif;
		if _ti.CM_TILC.myTILCType &lt;&gt; filterTrailerType then
			return false;
		endif;
	endif;
	
	if (_ti.cargoType &gt; TI_CargoBOLType_Max
	and _ti.cargoType &lt; TI_CargoBOLType_JMTMax) //we are handling a break bulk generic, so check against product
	or (_ti.cargoType &gt; TI_CargoBOLType_JMTMax and app.myRoot.isClientCentrePort)		// TFS 49252
	then
		if self.filterProduct &lt;&gt; null and
			self.filterProduct &lt;&gt; Any_String then //we are filtering by a product
			//if _ti.myProduct &lt;&gt; null and _ti.myProduct.code &lt;&gt; self.filterProduct then		// - 17/03/2010 cnwmh5 #22715
			if _ti.myProduct &lt;&gt; null and _ti.productCode &lt;&gt; self.filterProduct then				// + 17/03/2010 cnwmh5 #22715
				return false;
			endif;
		endif; 
	endif;

	//Check ISO and ID filters here. Other filters were resolved when
	//entries were copied to the dyna dict
	if self.filterVoyage &lt;&gt; null then
		// 19/04/2013 cnwar2 #21971
		if self.filterCargoTypeId = TI_CargoType_Log	// for logs, only want to see logs that have been loaded to the voyage (i.e. onship)
		and _ti.site &lt;&gt; TI_SITE_ONSHIP then				// not logs offloaded from the voyage (i.e. onsite)
			return false;
		endif;
	
		if _ti.isTranshipItem and (self.filterVoyage = _ti.myImportVoyage or self.filterVoyage = _ti.myExportVoyage) then	// PAR #23645 CCMS 1116
			// we want this one																								// PAR #23645 CCMS 1116
		elseif _ti.myVoyage &lt;&gt; self.filterVoyage then
			return false;
		endif;
	endif;
	
	// cnwdad1 25/05/2009 - CCMS 1735.
	if filterSubTerminal &lt;&gt; null then
		if _ti.mySubTerminal &lt;&gt; filterSubTerminal then
			return false;
		endif;
	endif;
	
	// cnwdad1 09/06/2009 - CCMS 1834.
	if self.filterBookingRef &lt;&gt; null
	//and not _ti.getBookingReference().isBookingRefMatch(self.filterBookingRef, true)
	and not _ti.getBookingReference().toUpper().isBookingRefMatch(self.filterBookingRef, true)	// 16/07/2013 cnwar2 #31683
	then
		return null;
	endif;
	
	//02 May 2013	NDL	Par 31506
	if self.filterAltId &lt;&gt; null
	and not altIdFilterIsMatch(_ti.alternativeId) then
		return false;
	endif;
	
	if self.idFilterIsMatch(_ti.id) = false
	and self.idFilterIsMatch(_ti.alternativeId) = false	//11 Jun 2015	NDL	Par 36338
	then
		return false;
	endif;
	
	//09 Dec 2013	Par 32854
	if self.filterBOL &lt;&gt; null then
		if _ti.billOfLading &lt;&gt; self.filterBOL then
			return false;
		endif;
	endif;
	
	//09 Dec 2013	Par 32854
	if self.filterUnpackedFrom &lt;&gt; null then
		if _ti.getMyUnpackedFromContainerId &lt;&gt; self.filterUnpackedFrom then
			return false;
		endif;
	endif; 
	
	//29 Aug 2019	NDL	TFS 46118
	if self.filterMark &lt;&gt; null then
		if _ti.mark.trimBlanks &lt;&gt; self.filterMark then
			return false;
		endif;
	endif;
	
	if (not _ti.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return false;
	endif;
	
	if invalidTI then
		return false;
	endif;
	
	return true;
epilog

	//07 Aug 2020	NDL	TFS 49850
	if originalMultiID &lt;&gt; null and idCrit &lt;&gt; null  then
		idCrit.myQueryOperator.setSearchValue(originalMultiID);
	endif;
	
	if self.useSelectorTable then
		self.doPostSelectorSearch(removedCritLines,tempLines);
		delete removedCritLines;
		delete tempLines;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesCargoGroupAnCargoItems" id="56c0f9e2-0c78-48a7-8d15-005b3705d04d">
        <source>includesCargoGroupAnCargoItems( _tbl : CM_DataTable ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	obj : Object;
	includesCargoGroup : Boolean;
	includesNonCargoGroup : Boolean;
	msg : String;

begin

	foreach obj in _tbl.allSelectedObjects do
		if obj.isKindOf(CM_TrackedItem) and obj.CM_TrackedItem.isCargoGroupItem then
			includesCargoGroup := true;
		else
			includesNonCargoGroup := true;
		endif;
		if includesCargoGroup and includesNonCargoGroup then
			msg := app.getErrorString(Multi_updat_selec_not_inclu_bo);
			app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_tbl" type="CM_DataTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="9206a445-75a4-4208-ae5b-1a929c99cef1">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:     30 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTypeId 	: Integer;
	debtorType	: CM_DebtorType;
begin
	if self.amInitialisingWithObject and
	   self.myCurrentCargoBOLType &lt;&gt; null then
		tmpTypeId := self.myCurrentCargoBOLType.id;
	else
		tmpTypeId := self.getDefaultTiType(self.myCurrentCargoBOLType);
	endif;
	
	self.tblData.setGridLinesHorizontal(false);
	
	// Setup entTblRows for user-defined debtor types - 10/07/2008 cnwar2 #17010/CCMS1047
	if self.myDataClass &lt;&gt; CM_BOL	// 16/07/2008 cnwar2 #17533 - Only tracked items have debtor types
	and self.myDataClass &lt;&gt; CM_CargoGroup	//03 Jun 2015	NDL	Par 36338
	then	
		self.addDebtorTypes();
	endif;
	
	self.setupTblDataForCargoType(tmpTypeId);
	self.applyDataTblColSecurity();  //cnwrd1 18.11.08 CCMS JMT 1743/1764 
	self.allowMultiSelectEdit := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="initFilterValuesForTA" id="e07bdc51-ab02-4ca0-848e-86b1361da2e5">
        <updating/>
        <source>initFilterValuesForTA(_termArea : CM_TerminalArea; _theLocation : CM_LocationsController) updating;
//-----------------------------------------
// Created: 16 September 2003 By: cnwgd1
//-----------------------------------------
vars
	voyage : CM_Voyage;
	areaType : Integer;
	taType : CM_TerminalAreaType;
begin
	//epr TFS 47132 30/12/19
	if self.useSelectorTable then
		return;
	endif;
	
	if _termArea &lt;&gt; null then
		taType := _termArea.myType;
		areaType := _termArea.type;
	else
		areaType := TA_TYPE_NULL;
	endif;
	
	self.myAssistant.comboBoxTAType(cmbFiltTAType, taType, false);	
	cmbFiltTAType.click(cmbFiltTAType);
	cmbFiltTAType.lostFocus(cmbFiltTAType);	
	//tblSearch.setValueByControlName(cmbFiltTAType.name, cmbFiltTAType.text);

	self.myAssistant.comboBoxTerminalArea(cmbFiltTermArea, areaType, _termArea);
	cmbFiltTermArea.click(cmbFiltTermArea);		
	self.cmbFiltTermArea.lostFocus(cmbFiltTermArea);
	//self.filterTerminalArea := _termArea;
	
	if self.filterTerminalArea &lt;&gt; null then
		// PAR 32308 self.myAssistant.comboBoxLocationControllers(cmbFiltYardLocn, self.filterTerminalArea.getLCsCollectionForDisplay, false);
		self.setYardLocations(self.filterTerminalArea);// PAR 32308
		
		if _theLocation &lt;&gt; null then
			self.tblSearch.setValueByControlName(cmbFiltYardLocn.name, _theLocation.displayEntry);
			cmbFiltYardLocn.listObject := _theLocation;
			 //Don't do lostFocus as it cause a zDoFilter, this will get done later.
			//cmbFiltYardLocn.lostFocus(cmbFiltYardLocn);
			self.filterYardLocation := _theLocation;
		endif;
	elseif _theLocation &lt;&gt; null then
		if _theLocation.isKindOf(CM_VoyageController) then
			// Voyage controllers do not have a terminal area
			voyage := _theLocation.CM_VoyageController.myVoyage;
			if voyage.archived then
				// override setting on form if the voyage here is archived
				self.myAssistant.comboBoxVoyageCurrent(	self.cmbFiltVoyage,
														voyage,
														true,
														true,
														self.includeSailedVoyages,
														true,
														true,
														true,
														true,
														false,
														false); //cnwrs1 par15258 nov 2007
			else
				self.myAssistant.comboBoxVoyageCurrent(	self.cmbFiltVoyage,
														voyage,
														true,
														self.includeArchivedVoyages,
														self.includeSailedVoyages,
														true,
														true,
														true,
														true,
														false,
														false); //cnwrs1 par15258 nov 2007
			endif;
			if self.cmbFiltVoyage.findObject(voyage) &gt; 0 then
				self.filterVoyage := voyage;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
        <Parameter name="_theLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="initFldEdit" id="49da7e69-549c-4a93-9800-b4887d52acaf">
