<Class name="CM_MachineTaskState" id="fe9ca5aa-eef6-4369-9157-2c88ab26be1e">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="planning"/>
    <ExplicitInverseRef name="myMachine" id="4a6f4f34-a3bc-49ec-9ded-77a8ce3e9fee">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Machine"/>
        <access>readonly</access>
        <Inverse name="CM_Machine::allMachineTaskStates"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myQueueTask" id="718fe2b9-5472-478d-be0e-6c38ee57f59f">
        <embedded/>
        <type name="CM_RTQueueTask"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="queueTaskEdition" id="5a9a0b5a-a5de-445c-a0d7-8b37223a8b19">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="isMatch" id="2e5b137a-50b5-4ee8-bae5-c0ad2a3a0a49">
        <source>isMatch(_task : CM_RTQueueTask input) : Boolean;
/*

Date		Who		Reason
23 June 2017	cnwer1	Initial creation TFS 4836

*/

vars
	invalidTask : Boolean;
	taskEdition : Integer;
begin
	
	on Exception do app.handleDeletedObject(exception,self.myQueueTask,invalidTask);
	
	if self.myQueueTask &lt;&gt; _task then
		return false;
	endif;
	
	if self.queueTaskEdition &lt;&gt; _task.edition then
		return false;
	endif;
	
	taskEdition:=self.myQueueTask.edition;
	
	if invalidTask then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="fd0ade53-f0a6-469b-9eeb-8894aede01df">
        <updating/>
        <source>setDetails(	_machine : CM_Machine input;
			_rtTask : CM_RTQueueTask input) updating;
/*

Date		Who		Reason
23 June 2017	cnwer1	Initial creation TFS 4836

*/

vars

begin
	if _rtTask = null then
		return;
	endif;
	
	self.myQueueTask :=_rtTask;
	self.queueTaskEdition:=_rtTask.edition;
	
	self.myMachine:=_machine;
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
    </JadeMethod>
</Class>
