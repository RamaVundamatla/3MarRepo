    <JadeMethod name="noteRotation" id="a45e755d-af3c-4d25-8cd4-e62171b4365a">
        <updating/>
        <source>noteRotation(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			
Date		Who		Reason
02 March 2012	cnwab1	Initial creation
*/

vars

	deckItemLayoutArray : CM_RORODeckItemLayoutArray;
	deckItem : CM_DeckItem;
	locnDefn, otherDefn : CM_ROROLocnDefn;
invalidLocn : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, locnDefn, invalidLocn);	

	create deckItemLayoutArray transient;
	foreach deckItem in self.allOrderedROROLocns  discreteLock do
		locnDefn := deckItem.CM_ROROLocnDefn;
		deckItemLayoutArray.add(locnDefn.myLayout);
		if invalidLocn then // PAR 28990
			continue;
		endif;
	endforeach;
	self.doOrderROROLocns(deckItemLayoutArray);


epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="noteUser" id="b4190235-ce5b-4c90-aa54-9a565f6aaacb">
        <updating/>
        <source>noteUser(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Date		    Who			Reason
26 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	actualEvent 	: Integer;
	
	
begin
	
	actualEvent := self.myTerminal.getEventFromTerminalEvent(eventType);	
	
	if actualEvent = ShowHide_CargoSideView and userInfo.isKindOf(Boolean) then //cnwas3 23840a
		if userInfo.Boolean &lt;&gt; self.visible then
			self.visible := userInfo.Boolean;
		endif;		
	
	endif;	
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="noteVoyage" id="a4741842-e04e-4cc0-8fa6-c9633b4a4304">
        <updating/>
        <source>noteVoyage(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			
Date		Who		Reason
02 March 2012	cnwab1	Initial creation
*/

vars

	lController : CM_ROROSlotController;
	event : Integer;
	gotException	: Boolean;
begin
	
		on Exception do app.handleDeletedObject(exception, lController, gotException);		

		if not userInfo.isKindOf(CM_ROROSlotController) then 
			return;
		endif;
		lController := userInfo.CM_ROROSlotController;
		if lController &lt;&gt; null then	
			// PAR 28986 if the note is not for a locn that we are viewing then ignore
			if not self.allOrderedROROLocns.includes(lController.mySlotDefn.myROROLocnDen) then
				return;
			endif;
			
			self.myROROLocnDrawingController.drawSlotFromNote(lController);
			self.doRedrawWeightsAndHeights(lController); 	//cnwas3 par 28401		
			if gotException then
				// Exception handler resumes here if lController was invalid.
				return;
			endif;
			// 28747 Dec 2011 clear status selected message as items have been un-selected in notification processing
			self.setStatusCaption(null,false);
		endif;


epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
