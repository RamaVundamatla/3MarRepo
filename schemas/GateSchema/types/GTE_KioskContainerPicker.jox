// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------

vars

begin
	app.mousePointer := self.lastMousePointer;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getMyReserveDetail" id="db929a6f-ba8e-4b7d-888e-e92dd31f98c0">
        <source>getMyReserveDetail() : CM_ReserveDetail;
// --------------------------------------------------------------------------------
// Created:		23 February 2009 by cnwjo3
//
// Purpose:		return reservedetail to be used after form is closed and no longer visible
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
begin
	return self.myReserveDetail;
end;</source>
        <ReturnType type="CM_ReserveDetail"/>
    </JadeMethod>
