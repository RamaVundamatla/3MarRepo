    <JadeMethod name="showHideCCP" id="d3c4ffd5-22a2-4f7a-92e5-2beb03823e1e">
        <updating/>
        <source>showHideCCP(_show : Boolean) updating;



// NOT USED


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwas3	Initial creation

*/

vars


begin
	if not _show and ( self.myCCPalette &lt;&gt; null or self.myCCPaletteLoad &lt;&gt; null ) then 
	
		if self.myCCScreen &lt;&gt; null then // PAR 23450
			self.iCCPHeight := self.myCCScreen.top;
			self.iCCPWidth := self.myCCScreen.left;		
		endif;
		if self.myCCPalette &lt;&gt; null then
			self.myCCPalette.unloadForm();
			self.myCCPalette := null;
		endif;
		//24 Jan 2012	NDL	Par 28896
		if self.myCCPaletteLoad &lt;&gt; null then
			self.myCCPaletteLoad.unloadForm();
			self.myCCPaletteLoad := null;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
