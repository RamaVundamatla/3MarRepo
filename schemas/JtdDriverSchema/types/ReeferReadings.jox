    <JadeMethod name="startup2" id="523be061-d123-4522-818d-8b5d1b0f3b36">
        <updating/>
        <source>startup2() updating;

vars
	btnSearchTV:Button;
begin
	loopCount:=app.profileSequenceId * 50;
	app.logMessage(method.qualifiedName&amp;" loopCount="&amp;loopCount.String);
	myCMUI_Navigator:=app.getForm('CMUI_Navigator').CMUI_Navigator;
	myCMUI_SuperAppForm2:=app.getForm('CMUI_SuperAppForm2').CMUI_SuperAppForm2;
	
	myCMUI_Navigator.lstTest.listIndex:=app.atcgGetHierarchicalIndex(myCMUI_Navigator.lstTest,'Port Otago|Yard Functions|Reefer Activities|Reefer Monitoring|');
	myCMUI_Navigator.lstTest.itemSelected[myCMUI_Navigator.lstTest.listIndex]:=true;
	myCMUI_Navigator.lstTest.dblClick(myCMUI_Navigator.lstTest);  // 16:13:09
	
	myYRD_ReeferMonitorForm:=app.getForm('YRD_ReeferMonitorForm').CM_BaseForm;
	btnSearchTV:=myYRD_ReeferMonitorForm.getPropertyValue('btnSearchTV').Button;
	btnSearchTV.click(btnSearchTV);
end;
</source>
    </JadeMethod>
