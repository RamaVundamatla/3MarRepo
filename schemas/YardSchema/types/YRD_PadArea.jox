    <JadeMethod name="drawSpecialAfter" id="e5f067f5-5aa9-4cd3-88bd-be29fcd254f7">
        <updating/>
        <source>drawSpecialAfter() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5 		par 30475 - remove references to location restrictions
// ---------------------------------------------------------------------------

vars
	aCMObject 				: CM_Object;
	pointX, pointY, aColour : Integer;
	anIterator 				: Iterator;
	aLabel 					: String;

begin
	inheritMethod();

	if self.areaMode = YRD_PadArea.AreaMode_SubBlock then
		anIterator := self.allPointLabels.createIterator;
		self.myGridAreaFrame.drawFontSize := 8;
		// Draw the Sub Block Stack Labels
		while anIterator.next(aCMObject) do 
			if global.isValidObject(aCMObject) then
			if aCMObject.isKindOf(CM_TerminalArea) then
				pointX := anIterator.getCurrentKey(1).Integer;
				pointY := anIterator.getCurrentKey(2).Integer;
				aLabel := aCMObject.CM_TerminalArea.id;
				aColour := aCMObject.CM_TerminalArea.myLayoutGraphic.drawLineColour.getInverseColour;
				self.myGridAreaFrame.drawTextAt(aLabel,pointX ,pointY, aColour);
			endif;
			endif;
		endwhile;	
	endif;
epilog
	delete anIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="selectBlock" id="713aa2f3-5fb1-4a66-8507-8b8f2bef77cc">
        <updating/>
        <source>selectBlock(_first, _second : CMUI_GridPoint) updating;

vars

	x1, x2, y1, y2	: Real;
	padPoint			: YRD_PadPoint;
	gridPoint : CMUI_GridPoint;
begin

	x1 := _first.x1;
	x2 := _first.x2;
	y1 := _first.y1;
	y2 := _first.y2;
	
	x1 := x1.min(_second.x1);
	x2 := x2.max(_second.x2);
	y1 := y1.min(_second.y1);
	y2 := y2.max(_second.y2);
	
	foreach gridPoint in self.allGridPoints do
		padPoint := gridPoint.YRD_PadPoint;
		if not padPoint.isGap() then // do not lock gaps, we want them to be included in the collection of location controllers for a restriction or sub block stack
			if padPoint.locked then // AKB2002AUG
				continue;
			endif;
		endif;

		if padPoint.x1 &gt;= x1 and padPoint.y1 &gt;= y1 and padPoint.x2 &lt;= x2 and padPoint.y2 &lt;= y2 then
			
			if not self.allSelectedPoints.includes(padPoint) then
				self.allSelectedPoints.add(padPoint);
			endif;
			padPoint.drawSelf(self.myGridAreaFrame);
		endif;
	endforeach;

end;</source>
        <Parameter name="_first" type="CMUI_GridPoint"/>
        <Parameter name="_second" type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="selectSinglePoint" id="f9116c1e-a444-4760-9aeb-9aab9f4c211f">
        <updating/>
        <source>selectSinglePoint( x, y : Real) : CMUI_GridPoint updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------


vars
	returnPoint, gridPoint	: CMUI_GridPoint;
	x1, y1					: Real;
	aTI : CM_TrackedItem;
	lLetter : String;
	lColour : Integer;
begin

	gridPoint := self.convertPositionToGridPoint(x, y);
	
	if gridPoint &lt;&gt; null then
//write "AKB" &amp; " " &amp; class.name &amp; '::' &amp; method.name &amp; " 1. gridPoint.locked " &amp; gridPoint.locked.String;	
		if gridPoint.locked then
			return gridPoint;
		endif;

		if not self.allSelectedPoints.includes(gridPoint) then
			self.allSelectedPoints.add(gridPoint);
			returnPoint := gridPoint;
		else
			self.allSelectedPoints.remove(gridPoint);
			returnPoint := null;
		endif;

		aTI := gridPoint.getTI(x,y);
		if aTI &lt;&gt; null then
			self.addRemoveTIToFromSelected(aTI);
//			if not self.allSelectedTrackedItems.includes(aTI) then
//				self.allSelectedTrackedItems.add(aTI);
//			else
//				self.allSelectedTrackedItems.remove(aTI);
//			endif;
		endif;

		gridPoint.drawSelf(self.myGridAreaFrame);
		self.dataChanged := true;
		return returnPoint;
	endif;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f9086297-56e8-4beb-bd0b-cf599f59d751">
        <updating/>
        <source>setForCreate(pGridArea : CM_TerminalArea; pAssistant : CMUI_Assistant; pEdit : Boolean; _form : YRD_LocationMaintForm; _areaMode : Integer) updating;//, serverExecution;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/06/2020	jlgdap1		TFS 49453 ASPA satellite View Screen for Flexible Terminal Areas
// ---------------------------------------------------------------------------
vars

begin
	if pGridArea.isKindOf(CM_GridArea) then
		self.createGridArea(pGridArea.CM_GridArea,pAssistant,pEdit,_form,_areaMode);
	elseif pGridArea.isKindOf(CM_RoRoLaneArea) then
		self.createRoRoLaneArea(pGridArea.CM_RoRoLaneArea,pAssistant,pEdit,_form,_areaMode);
	elseif pGridArea.isKindOf(CM_IrregularBlockArea) then				// TFS 3422
		self.createIrregularArea(pGridArea.CM_IrregularBlockArea,pAssistant,pEdit,_form,_areaMode);
	elseif pGridArea.isKindOf(CM_GeneralCargoAllocRowArea) then													// TFS 49453
		self.createGCAllocRowArea(pGridArea.CM_GeneralCargoAllocRowArea, pAssistant, pEdit, _form, _areaMode);	// TFS 49453
	else
		write method.qualifiedName &amp; " unknown area: " &amp; pGridArea.id;
	endif;
end;</source>
        <Parameter name="pGridArea" type="CM_TerminalArea"/>
        <Parameter name="pAssistant" type="CMUI_Assistant"/>
        <Parameter name="pEdit" type="Boolean"/>
        <Parameter name="_form" type="YRD_LocationMaintForm"/>
        <Parameter name="_areaMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setGridRowColPositions" id="873432e3-145f-418f-bb20-abaa00e75839">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>setGridRowColPositions() updating, serverExecution;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/07/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen fro Flexible Terminal Areas
// ---------------------------------------------------------------------------
vars
	tmpRow			: CMUI_GridRow;
	tmpCol			: CMUI_GridColumn;
	yrdGridRow		: YRD_PadRow;
	yrdGridCol		: YRD_PadColumn;
	lastPos,
	theRowHeight,
	theColWidth,
	tmpPos1,
	tmpPos2			: Real;	
	spacing			: Integer;

begin


	theRowHeight := 20;
	theColWidth	 := 35;
	// TFS 3422 for general cargo areas show wider slots to fit the area description and hazard details better
	if self.type = TA_TYPE_IRREGULAR_BLOCK_AREA then
		theColWidth := 60;
	// TFS 49453 For General Cargo Allocation areas, make the slots a bit wider to allow more space for labels
	elseif self.type = TA_TYPE_GEN_CARGO_ALLOC_ROW then
		theColWidth := 50;
	endif;
	foreach tmpRow in self.allGridRows do
		yrdGridRow := tmpRow.YRD_PadRow;
		tmpPos1 := TopMargin + ((yrdGridRow.row - 1) * theRowHeight) + ((yrdGridRow.row - 1) * spacing);
		tmpPos2 := tmpPos1 + theRowHeight;
		yrdGridRow.setYPos(tmpPos1, tmpPos2);
	endforeach;
	
	self.totalPointHeight := tmpPos2 + BottomMargin;
	foreach tmpCol in self.allGridColumns do
		yrdGridCol := tmpCol.YRD_PadColumn;
//		theColWidth := ColWidth * yrdGridCol.maxWidth;
		
		if lastPos = 0 then
			lastPos := LeftMargin;
		endif;
		tmpPos1 := lastPos;
		
		tmpPos2 := tmpPos1 + theColWidth;
		yrdGridCol.setXPos(tmpPos1, tmpPos2);
		
		lastPos := tmpPos2;
	endforeach;

	self.totalPointWidth := tmpPos2 + RightMargin;
end;</source>
    </JadeMethod>
    <JadeMethod name="setSelected" id="703a4789-f810-485c-ac9d-6e6a2407df19">
        <updating/>
        <source>setSelected(_row, _column : Integer) updating;

vars

begin

	self.selectedRow := _row;
	self.selectedColumn := _column;

end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
</Class>
