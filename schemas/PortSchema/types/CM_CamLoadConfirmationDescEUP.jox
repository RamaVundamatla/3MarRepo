    <JadeMethod name="availableCargoTypes" id="7f2a41ce-e2f7-4f55-bd6b-57847b9e1fd7">
        <source>availableCargoTypes(_classColl: ClassColl input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
