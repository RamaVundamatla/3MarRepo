    <JadeMethod name="trxUpdateSlotDefnController" id="2706d9b6-bd08-4023-98ef-7e35b48e6b03">
        <updating/>
        <source>trxUpdateSlotDefnController(_theRequests:CMIF_SlotDefinitionController; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		Use the controller to toggle a single attribute on the collection of slot definitions
// ---------------------------------------------------------------------------
vars
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;
	app.myUtilityUA.utlUpdateSlotDefnController(_theRequests, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theRequests" type="CMIF_SlotDefinitionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateSlotDefnsAttribute" id="720228db-193c-4f06-a8d1-326eca8b3058">
        <updating/>
        <source>trxUpdateSlotDefnsAttribute(_theSlots : CM_SlotControllerSet; _theEditions : CM_ObjectByOidEditionDict; _attribute : String; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		Use the controller to toggle a single attribute on the collection of slot definitions
// ---------------------------------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	tmpSlot,
	aftSlot		: CM_SlotController;
	tmpSlotDefn : CM_SlotDefn;
	tmpVoyage	: CM_Voyage;
	eventUpdateVoyageArea,
	expectedEdition	: Integer;
	tmpStr : String;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _theSlots = null then
		app.raiseCMException1(MethodWithNullParam, '_theSlots', null, null);
		return;
	endif;
	
	if _theEditions = null then
		app.raiseCMException1(MethodWithNullParam, '_theEditions', null, null);
		return;
	endif;
	
	if _theSlots.isEmpty then
		// nothing to do
		return;
	endif;

	app.setContinueCMExceptions(true);
	beginTransaction;
	
	// Do validation
	foreach	tmpSlot in _theSlots do
		expectedEdition := _theEditions.getEditionForObject(tmpSlot);
		if expectedEdition &lt; 0 then
			app.raiseExNoEditionForUpdateObj(tmpSlot);
			continue;
		endif;
		// PAR 16415 CCMS 1029 moved this here cos have to set SlotController in tmpSlotDefn.setAnAttributeFromController
		exclusiveLock(tmpSlot);
		if tmpSlot.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; tmpSlot.ident, null, null);
		endif;

		// This validation is done here because of the way the
		// CM_SlotDefn.pxyCreateUpdateProxy overrides the forttFront attribute
		// which causes problems from elsewhere (eg vessel defn).  If this
		// is fixed then this code can be removed and the validation done
		// in the correct place - rjs 15Jul04
		if (_attribute = CM_SlotRequest.Attribute_Forty  or _attribute = CM_SlotRequest.Attribute_FiftyThree or _attribute = CM_SlotRequest.Attribute_Thirty or _attribute = CM_SlotRequest.Attribute_FortyFive)
		and tmpSlot.myBayVoyage.isLastInHold() then
			// PAR 17841
			if _attribute = CM_SlotRequest.Attribute_Forty then  
				tmpStr := "forty";
			elseif  _attribute = CM_SlotRequest.Attribute_FiftyThree then
				tmpStr := "fifty three";
			elseif  _attribute = CM_SlotRequest.Attribute_FortyFive then
				tmpStr := "forty five";
			elseif _attribute = CM_SlotRequest.Attribute_Thirty then
				tmpStr := "thirty";
			endif;
			app.raiseCMException3(Slot_canno_marke_foot_slot_def, tmpSlot.myBayVoyage.id, tmpSlot.ident, tmpStr, null, null);
			continue;
		endif;

		tmpSlotDefn := tmpSlot.mySlotDefnVoyage; // AKB2004MAY. DQ wants check that there is not already conflicting colour coding
		tmpSlotDefn.setAnAttributeFromController(_attribute); // so need to set slot here to check. if exception, undoes transaction.
		tmpSlotDefn.validateForUpdate();
		
	endforeach;

	if _passport.hasErrors then
		return;
	endif;

	app.setContinueCMExceptions(false);

	foreach	tmpSlot in _theSlots do
		self.updateObjectEdition(tmpSlot);	// par 30292
		
		if _attribute = CM_SlotRequest.Attribute_Forty then
			aftSlot := tmpSlot.myAftSlot;
			if aftSlot &lt;&gt; null then
				self.updateObjectEdition(aftSlot);	// par 30292
			endif;
		endif;
	endforeach;
		
	if _passport.hasErrors then
		return;
	endif;
	
	// update ok so send out notes for updated objects

	eventUpdateVoyageArea := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);

	foreach	tmpSlot in _theSlots do
		tmpVoyage := tmpSlot.myVoyage;
		tmpVoyage.causeEvent(eventUpdateVoyageArea, false, tmpSlot);
		if _attribute = CM_SlotRequest.Attribute_Forty then
			aftSlot := tmpSlot.myAftSlot;
			if aftSlot &lt;&gt; null then
				tmpVoyage.causeEvent(eventUpdateVoyageArea, false, aftSlot);
			endif;
		endif;
	endforeach;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theSlots" type="CM_SlotControllerSet"/>
        <Parameter name="_theEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateSlotReqLinkSOBDLR2" id="d70219a0-352f-4e95-8053-fd6740576fcc">
        <updating/>
        <source>trxUpdateSlotReqLinkSOBDLR2(_slotsFrom, _slotsTo : CM_SlotControllerArray; 
				_expectedEditions : CM_ObjectByOidEditionDict; 
				_isDischarge : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     _slotsFrom cannot be null
//				_slotsTo can be null (this is for delinking)
//				_isDischarge - if true then _slotsFrom holds the discharge request slotController(s),
//							 - if false the _slotsFrom holds the load request slotController(s)
// ---------------------------------------------------------------------------
vars
	slotFrom,
	slotTo,
	loadSlot,
	dischSlot		: CM_SlotController;
	loadEdition,
	dischEdition,
	idx			: Integer;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if _slotsFrom = null then
		app.raiseCMException1(MethodWithNullParam, '_slotsFrom', null, null);
		return;
	endif;
	if _expectedEditions = null then
		app.raiseCMException1(MethodWithNullParam, '_expectedEditions', null, null);
		return;
	endif;
	
	if _slotsTo &lt;&gt; null and 
	   _slotsFrom.size &lt;&gt; _slotsTo.size then
		app.raiseCMException2(ErrNumSlotsToLinkDiffers, _slotsFrom.size.String, _slotsTo.size.String, null, null);
		return;
	endif;

	beginTransaction;
	
	foreach slotFrom in _slotsFrom do
		idx := idx + 1;

		if _slotsTo &lt;&gt; null then
			slotTo := _slotsTo[idx];
		endif;

		if _isDischarge then
			dischSlot := slotFrom;
			loadSlot := slotTo;
		else
			dischSlot := slotTo;
			loadSlot := slotFrom;
		endif;			

		// check the dischSlot
		if dischSlot &lt;&gt; null then
			dischEdition := _expectedEditions.getEditionForObject(dischSlot);	
			if dischEdition &lt; 0 then
				app.raiseExNoEditionForUpdateObj(dischSlot);
				return;
			endif;
		endif;
		
		// check the loadSlot
		if loadSlot &lt;&gt; null then
			loadEdition := _expectedEditions.getEditionForObject(loadSlot);	
			if loadEdition &lt; 0 then
				app.raiseExNoEditionForUpdateObj(loadSlot);
				return;
			endif;
		endif;

		app.myUtilityUA.utlUpdateSlotReqLinkSOBDLR2(loadSlot, dischSlot, loadEdition, dischEdition, _passport);

		if _passport.hasErrors then
			break;
		endif;
		
	endforeach;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_slotsFrom" type="CM_SlotControllerArray"/>
        <Parameter name="_slotsTo" type="CM_SlotControllerArray"/>
        <Parameter name="_expectedEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_isDischarge" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
