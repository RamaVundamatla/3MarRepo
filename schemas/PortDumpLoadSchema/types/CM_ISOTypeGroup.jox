<Class name="CM_ISOTypeGroup">
    <JadeMethod name="importPLXMLReference" id="8950b5f1-0ac5-4c16-a94a-7eb16a62f342">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_ISOTypeGroup::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
