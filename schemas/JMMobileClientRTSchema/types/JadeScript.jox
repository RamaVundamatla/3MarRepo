<Class name="JadeScript">
    <JadeMethod name="testPackage" id="64a8976d-d3d9-4c12-84e7-cbc9e35ae812">
        <source>testPackage();
// -------------------------------------------
// Created 09 January 2006 by cnwdvb1
// -------------------------------------------
vars

	str				: String;
	agent			: RadioTelemetryThinClientAgent;
	dto				: DTO_EnquiryGradingTasks;
//	iter			: Iterator;
	errorStr		: String;	
	stateIngoObj	: DTO_StateInfo;

begin
	beginTransaction;
	create agent persistent;
	commitTransaction;

	
/*	write 'agent -&gt; ' &amp; agent.String;
	write 'agent.myRtnMsgs -&gt; ' &amp; agent.myRtnMsgs.String;
	write 'is valid = ' &amp; global.isValidObject(agent.myRtnMsgs.allMessages).String;
	write 'agent.myRtnMsgs.allMessages -&gt; ' &amp; agent.myRtnMsgs.allMessages.String;
	write 'agent.myRtnMsgs.allMessages.size -&gt; ' &amp; agent.myRtnMsgs.allMessages.size.String;
	write 'agent.myRtnMsgs.allMessages[1] -&gt; ' &amp; agent.myRtnMsgs.allMessages[1];

//	iter := agent.myRtnMsgs.allMessages.createIterator();*/

//	if not agent.doLogon('CNWDVB1', 'password', '12:POE:CNWDVB1A:1010', errorStr) then
	if not agent.doLogon('CNWDVB1', 'password', '12:POE:CNWDVB1A:1010', null, stateIngoObj) then
		write errorStr;
		return;
	endif; 
	
/*	create dto transient;
	
	if not agent.requestTask(dto, errorStr) then
		write errorStr;
		return;
	endif;
	
	dto.inspectModal;*/
	
//	if not agent.doLogOff(errorStr) then
	if not agent.doLogOff(stateIngoObj) then
		write errorStr;
		return;
	endif;

	write '';
	write '';
epilog
	beginTransaction;
	delete agent;
	commitTransaction;
	delete dto;
end;</source>
    </JadeMethod>
