	elseif _organisation.isKindOf(CM_Organisation) then
		organisation := _organisation.CM_Organisation;
	endif;
	
	if organisation &lt;&gt; null then
		app.myTrxUA.trxUpdateOrganisation(organisation, organisation.edition, organisation.logo, organisation.allDataAccessControllerObjects, 
			 self.opts.bool('AvailableForEntry').Boolean, self.opts.bool('AvailableForLabourRestrictions').Boolean, 
			 organisation.myDebtor, null, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog
	
end;</source>
        <Parameter name="_organisation" type="Any" usage="io"/>
    </JadeMethod>
