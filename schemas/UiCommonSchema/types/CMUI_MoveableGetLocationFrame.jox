vars

begin

	delete self.myAssistant;


end;</source>
    </JadeMethod>
    <JadeMethod name="doClick" id="a4efd850-de97-462c-b086-40c291387dfd">
        <updating/>
        <source>doClick(_control: Control) updating;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

	taType	: CM_TerminalAreaType;
	ta		: CM_TerminalArea;
	coll	: Collection;
	obj		: Object;
	iter	: Iterator;

begin

	if _control = self.cmbTAType then
		taType := self.cmbTAType.listObject.CM_TerminalAreaType;
		if taType &lt;&gt; null then
			self.myAssistant.comboBoxTerminalArea(cmbTermArea, self.cmbTAType.listObject.CM_TerminalAreaType.type, null);
			self.cmbTermArea.lostFocus(cmbTermArea);
			self.cmbYardLocation.clear();
			self.mySelectedLocation := null;
			self.cmbYardLocation.lostFocus(cmbYardLocation);
		endif;
	elseif _control = self.cmbTermArea then
		ta := self.cmbTermArea.listObject.CM_TerminalArea;
		if ta &lt;&gt; null then
			self.myAssistant.comboBoxLocationControllers(cmbYardLocation, self.getLocations(ta), false);		
			if ta.isKindOf(CM_BlockStack) then	
				if self.cmbYardLocation.findObject(ta.CM_BlockStack.myLocationsController) &lt;&gt; -1 then
					self.cmbYardLocation.listObject := ta.CM_BlockStack.myLocationsController;
					self.mySelectedLocation := self.cmbYardLocation.listObject.CM_LocationsController;
				endif;
			else
				self.mySelectedLocation := null;
			endif;
			self.cmbYardLocation.lostFocus(cmbYardLocation);
		endif;
	elseif _control = self.cmbYardLocation then
		self.mySelectedLocation := _control.ComboBox.listObject.CM_LocationsController;
		self.cmbYardLocation.lostFocus(cmbYardLocation);
	endif;


end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doDisplayEntry" id="770e8112-fbda-4f55-bf3f-d5f51c949b20">
        <source>doDisplayEntry(_control: Control; _obj: Any): String;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if _control = self.cmbTermArea then
		return _obj.CM_TerminalArea.id; 
	elseif _control = self.cmbYardLocation then
		return self.myAssistant.displayEntryLocationController(_obj.CM_LocationsController);
	endif;

end;</source>
        <Parameter name="_control" type="Control"/>
        <Parameter name="_obj" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doGotFocus" id="a27090a9-05ae-45b9-893d-0be684e1e3e4">
        <updating/>
        <source>doGotFocus(_control: Control) updating;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if _control = self.cmbTermArea or _control = self.cmbTAType then
		self.origValueStr := _control.ComboBox.text;
	endif;


end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doLostFocus" id="88889069-f1d3-4f66-a4e1-6603473b1272">
        <updating/>
        <source>doLostFocus(_control: Control) updating;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

	areaTypeCode	: Integer;
	areaType		: CM_TerminalAreaType;
	combobox		: ComboBox;
	tmpTA 			: CM_TerminalArea;

begin
	
	if _control = self.cmbTAType then
		combobox := _control.ComboBox;
		self.tblMove.setValueByControlName(combobox.name, combobox.text);
	elseif _control = self.cmbTermArea then
		combobox := _control.ComboBox;
		self.tblMove.setValueByControlName(combobox.name, combobox.text);
	elseif _control = self.cmbYardLocation then
		combobox := _control.ComboBox;
		self.tblMove.setValueByControlName(combobox.name, combobox.text);
		self.setTargetLocation();
	endif;
	
end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="getDetailsFromLocation" id="9bb0e034-6b7d-4bd0-9aa5-2e2bc5a91380">
        <source>getDetailsFromLocation(_taType : CM_TerminalAreaType output; _terminalArea : CM_TerminalArea output) protected;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.mySelectedLocation &lt;&gt; null then
		_terminalArea := self.mySelectedLocation.myTerminalArea;
		if _terminalArea &lt;&gt; null then
			_taType := _terminalArea.myType;
		endif;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_taType" type="CM_TerminalAreaType" usage="output"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getLocations" id="6bd36761-9d90-4175-b351-fd438d7868ae">
        <source>getLocations(_ta : CM_TerminalArea) : Collection protected;
// -------------------------------------------
// Created 09 December 2005 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars

	coll	: Collection;
	iter	: Iterator;
	obj		: Object;

begin

	if not self.showOnlyEmptyLocations then
		return _ta.getLCsCollectionForDisplay();
	else
		self.tmpLocations.clear();
		coll := _ta.getLCsCollectionForDisplay();
		iter := coll.createIterator();
		
		while iter.next(obj) do
			if obj.CM_LocationsController.allTrackedItems.isEmpty() then
				self.tmpLocations.add(obj);
			endif;
		endwhile;
		return self.tmpLocations;
	endif;
			
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocation" id="cb0180e8-e648-45f8-be27-bd6e4c33d9bc">
        <source>getTargetLocation() : CM_LocationsController;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.cmbYardLocation.listObject &lt;&gt; null then
		return self.cmbYardLocation.listObject.CM_LocationsController;
	elseif self.cmbTermArea.listObject &lt;&gt; null and self.cmbTermArea.listObject.isKindOf(CM_BlockStack) then
		return self.cmbTermArea.listObject.CM_BlockStack.myLocationsController;
	endif;


end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocationAsStr" id="9daebe05-8f12-48a9-bc26-ba7f65a11b93">
        <source>getTargetLocationAsStr() : String;
// -------------------------------------------
// Created 11 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	return self.tblMove.getValueByName(ETRow_NewLocn).String;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="inDragMode" id="fd114529-aa19-4bde-ad21-920422273cf1">
        <methodInvocation>mapping</methodInvocation>
        <source>inDragMode(set: Boolean; _value: Boolean io) mapping, protected;
// -------------------------------------------
// Created 11 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.isToMove then
		inheritMethod(set, _value);	
	else
		_value := false;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadTACombos" id="81322147-ef48-46b0-b148-342d0d113bc3">
        <source>loadTACombos()protected;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	taType 		: CM_TerminalAreaType;
	ta			: CM_TerminalArea;
	type		: Integer;
	
begin
	
	self.getDetailsFromLocation(taType, ta);

	if taType = null then
		type := TA_TYPE_NULL;
	else
		type := taType.type;
	endif;
	
	self.myAssistant.comboBoxTAType(cmbTAType, taType, false);	
	self.tblMove.setValueByControlName(cmbTAType.name, cmbTAType.text);

	self.myAssistant.comboBoxTerminalArea(cmbTermArea, type, ta);	
	self.cmbTermArea.lostFocus(cmbTermArea);
	
	if ta = null then
		self.myAssistant.comboBoxLocationControllers(cmbYardLocation, null, false);		
	else// if (not ta.isKindOf(CM_BlockStack)) then 
		self.myAssistant.comboBoxLocationControllers(cmbYardLocation, self.getLocations(ta), false);
		if self.cmbYardLocation.findObject(self.mySelectedLocation) &lt;&gt; -1 then		
			self.cmbYardLocation.listObject := self.mySelectedLocation;
		endif;
		self.cmbYardLocation.lostFocus(cmbYardLocation);
		
	endif;
	self.tblMove.setFocus();
	self.tblMove.moveFirst();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTable" id="e1c5b4e6-eeee-43cd-b6d0-0864ea8e0b27">
        <source>loadTable();
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

	entTableControl	: EntTableDef;


begin

	entTableControl := app.myController.getEntTableDef(ETDef_FindLocation);
	self.tblMove.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');

end;</source>
    </JadeMethod>
    <JadeMethod name="resetTerminal" id="c3c5bcc3-6f20-4fe1-a7c2-f0a22985a1e1">
        <updating/>
        <source>resetTerminal() updating;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myAssistant.myTerminal := app.getMyTerminalDO_NOT_USE();
end;</source>
    </JadeMethod>
    <JadeMethod name="setColors" id="36b30b02-784d-422e-898d-e9ee9cca3769">
        <updating/>
        <source>setColors() updating;
// ---------------------------------------------------------------------------
// Created:     25 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	infoColor		: Integer;
	tmpForm		: CM_BaseForm;
begin

	if self.form = null then
		return;
	endif;
	
	tmpForm := self.form.CM_BaseForm;
	
	self.backColor	:= tmpForm.backColor;
	tmpForm.setColorsForEntryTable(self.tblMove);

/*
