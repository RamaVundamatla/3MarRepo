    <JadeMethod name="validateMe" id="7d221839-caf9-4a93-905e-8c1625dc3010">
        <source>validateMe();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	cnwrd1	Initial creation
 required fields for Container are ID, Operator, ISO-TYpe
*/

vars
	taskDescObj		: CM_ToDoTaskDesc;
	cargoTypeObj	: CM_CargoType;
	raisedGenSet	: Boolean;
	
begin

	inheritMethod;
	
	if self.isoType = null then
		// ISO Type required.
	//	app.raiseCMException1(REQUIRED_FIELD, 'ISO Type', 'isoType', null);
		app.raiseCMException(Input_required_field_IsoType, 'isoType', null); // cnwdb2	PAR 35364
	endif;
	
	cargoTypeObj := self.getCargoTypeObject();

	//process.debug();
/*	if self.myInitialLocation = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Initial Location', null, null);
	endif;
*/
	
	foreach taskDescObj in self.allToDoTaskDesc do
		if not self.validateTaskForGenSet(taskDescObj) then	//Par18302. Jan 2009
			if not raisedGenSet	then	// avoiding message duplicate - there are 2 tasks: Attcah and Detach Gen Set
				if self.canHaveGeneratorAttached() then
					app.raiseCMException(ERR_AttachAndDetachGenSet, null, self);	//Reefers can have one of the two Attach / Detach Gen Set todo task
				else
					app.raiseCMException(ERR_AttachDetachGenForNonReefe, null, self);
				endif;
				raisedGenSet := true;
			endif;
		endif;
	endforeach;
	
	
	/* moved up
	if self.myOperatorNew = null or self.myOperatorNew.isKindOf(CM_NullOperator) then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Operator), null, null);
	endif;
	*/
	
	/*
	if self.myOperator = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Operator), null, null);
	endif;
	//process.debug();
	if self.myInitialLocation = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Initial Location', null, null);
	endif;
*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="ccf8bc3f-a978-4aaa-b7ce-b75b221f526e">
        <source>validateUpdate(_passport: CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	cnwrd1	Initial creation

*/

vars

