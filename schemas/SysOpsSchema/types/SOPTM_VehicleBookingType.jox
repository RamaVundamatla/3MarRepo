    <JadeMethod name="doSave" id="33fd9be3-7293-4d4d-97cc-4f35a85232df">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2014	cnwndl1	Initial creation	Par 35008
21 Jun 2022 navma1 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
23 Jan 2023	navak20 Task 55835: EUP - VBS MTN - [8] - Transfer Slots - Validate Transferring slots to future
25 Nov 2024	navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
*/
vars
	isNotAvailableForEntry	: Boolean;
	code 					: String;
	desc 					: String;
	proxyType 				: CM_VehicleBookingTimeSlotType;
	rtnValue 			 	: Boolean;
	terminal 				: CM_Terminal;
	tbl      			 	: CM_EntryTable;
	startTime			 	: Time;
	duration 			 	: Integer;
	gracePeriod 		 	: Integer;
	entryOutsideSlotTime 	: Integer;
	preGateinCheck		 	: Boolean;
	preGateOutCheck		 	: Boolean;
	kioskCheck			 	: Boolean;
	externalReference	 	: Boolean;
	autoAssociateRR			: Boolean;
begin
	tbl := self.myForm.tblInput1;														//16.5.2022 navma1 #52351
	
	isNotAvailableForEntry := tbl.getValueByName(ETRow_NotAvailableForEntry).Boolean;	//21.06.2022 navtnr20 TFS 53697
	code 				   := tbl.getValueByName(ETRow_Code).String;
	desc 				   := tbl.getValueByName(ETRow_Description).String;
	terminal			   := self.myForm.myTerminal;									//21.06.2022 navma1 #53697
	autoAssociateRR 	 	:= tbl.getValueByName(ETRow_AutoAssociateRR).Boolean;		//25.11.2024 navhl20 #33483
	
	//Start 22.06.2022 navtnr20 TFS 53697
	startTime			 := tbl.getValueByName(ETRow_StartTime).Time;		
	duration			 := tbl.getValueByName(ETRow_Duration).Integer;
	gracePeriod			 := tbl.getValueByName(ETRow_GracePeriod).Integer;
	entryOutsideSlotTime := app.vbsStringToEnum(tbl.getValueByName(ETRow_OutsideSlotTimeAction).String);
	preGateinCheck		 := tbl.getValueByName(ETRow_PreGateInCheck).Boolean;
	preGateOutCheck 	 := tbl.getValueByName(ETRow_PreGateOutCheck).Boolean;
	kioskCheck			 := tbl.getValueByName(ETRow_KioskCheck).Boolean;
	externalReference 	 := tbl.getValueByName(ETRow_ExternalRefUpdateAllowed).Boolean;
	//End 22.06.2022 navtnr20 TFS 53697

	if self.myForm.myProxyObject = null then
		if self.myForm.mode = self.myForm.Mode_Add then
			create self.myForm.myProxyObject as CM_VehicleBookingTimeSlotType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	// 23.01.2023 navak20 TFS 55835
	if tbl.getValueByName(ETRow_VbsProcess).String = "Slot Type Validation Process" then
		if duration &lt; 1 then
			app.raiseCMException(Duratio_must_minute_more, null, null);
		endif;
	endif;
	// 23.01.2023 navak20 TFS 55835
	
	proxyType := self.myForm.myProxyObject.CM_VehicleBookingTimeSlotType;
	
	proxyType.setForProxy(	code,					 //_code : String;
							desc,					 //_description : String;
							isNotAvailableForEntry,	 //_notAvailableForEntry : Boolean
							terminal,                //22.06.2022	navtnr20 TFS 53697
							startTime,               //22.06.2022	navtnr20 TFS 53697
							duration,                //22.06.2022	navtnr20 TFS 53697
							gracePeriod,             //22.06.2022	navtnr20 TFS 53697
							entryOutsideSlotTime,    //22.06.2022	navtnr20 TFS 53697
							preGateinCheck,          //22.06.2022	navtnr20 TFS 53697
							preGateOutCheck,         //22.06.2022	navtnr20 TFS 53697
							kioskCheck,              //22.06.2022	navtnr20 TFS 53697
							externalReference,		 //22.06.2022	navtnr20 TFS 53697
							autoAssociateRR);		 //25.11.2024 navhl20 #33483

	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateVBTimeSlotType(proxyType, self.myForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateVBTimeSlotType(proxyType, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.myForm.mode.String &amp; ')');
		return false;
	endif;
	
	return rtnValue;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowObjectCriteriaLineForm" id="392a3571-f3bb-4d65-99b6-81b3e3050653">
        <source>doShowObjectCriteriaLineForm(_vbs : CM_VehicleBookingTimeSlotType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2022	navtnr20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
26 Apr 2023 	navhl20		Bug 57317: MTN - 1090 When Editing VBS Slot Type Criteria
 06/11/2023		navkc1 		Bug 61094: FR | EUP VBS Criteria , Stops Criteria , Delivery Party Address
*/

vars
	pxyObjMatchCriteria   : CM_VBSSlotTypeCriteria;
	criteriaForm 		  : CMUI_ObjectCriteriaLineForm;
	vbsSlotType			  : CM_VehicleBookingTimeSlotType;
	str					  : String;
begin

	create criteriaForm transient;
	criteriaForm.setMyTerminal(self.myForm.myTerminal);
	
	vbsSlotType 		:= self.myForm.myProxyObject.CM_VehicleBookingTimeSlotType;
	
	// 06/11/2023	navkc1 Bug 61094 - In Add mode, it'll be null, create a transient now so they can proceed to set the criteria
	if vbsSlotType = null then
		create self.myForm.myProxyObject as CM_VehicleBookingTimeSlotType transient;
		vbsSlotType := self.myForm.myProxyObject.CM_VehicleBookingTimeSlotType;
	endif;
	
	pxyObjMatchCriteria := vbsSlotType.myVBSSlotTypeCriteria;
	
	// 06/11/2023	navkc1 Bug 61094 - In Add mode, it'll be null, create a transient now so they can proceed to set the criteria
	if pxyObjMatchCriteria = null then
		create pxyObjMatchCriteria transient;
		pxyObjMatchCriteria.setProxyBaseData(vbsSlotType);
	endif;
	
	
	criteriaForm.setBaseData(CM_ObjectMatchCriteria.VBSMatchingCriteriaInt,	//_context : Integer;
							vbsSlotType,									//_contextObj : CM_Object;
							pxyObjMatchCriteria,							//_myObjectMatchCriteria : CM_ObjectMatchCriteria;
							null,											//_myListForm : CMUI_ObjectCriteriaListForm
							null											//_myParentForm: CM_BaseForm
							);
					
	criteriaForm.showModal();
	
	//str := self.myForm.tblDataDisplayRow(self.myForm.tblData, _vbs);
	//self.myForm.tblData.setCellText( self.myForm.tblData.row, 1, str );
	if criteriaForm.contextObject.CM_VehicleBookingTimeSlotType.myVBSSlotTypeCriteria &lt;&gt; null then								//26.4.2023 navhl20 #57317
		str := criteriaForm.contextObject.CM_VehicleBookingTimeSlotType.myVBSSlotTypeCriteria.getTableDisplayString();
	else																														//26.4.2023 navhl20 #57317
		str := app.getErrorString(Criter_not_config_double_click);																//26.4.2023 navhl20 #57317
	endif;																														//26.4.2023 navhl20 #57317
	self.myForm.tblInput1.setValueByName(ETRow_DefineMatchingCriteria,str);
	
epilog
	delete criteriaForm;
end;</source>
        <Parameter name="_vbs" type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
