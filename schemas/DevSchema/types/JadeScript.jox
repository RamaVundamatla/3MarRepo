    <JadeMethod name="eprTestHMSResourceUsed" id="c66f83af-9836-422f-ac64-ee0907ae13e1">
        <source>eprTestHMSResourceUsed();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2018	jlger1	Initial creation

*/

vars

	terminal : CM_Terminal;
	voyage: CM_Voyage;
	now : TimeStamp;
	operator : CM_Operator;
	allPxyResourceUsed : HMS_ResourceUsedSet;
	pxyResourceUsed : HMS_ResourceUsed;
	resourceType : HMS_ResourceType;
	fromTS,
	toTS : TimeStamp;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("CNWER1");
	
	terminal:=CM_Root.firstInstance.allTerminals["JBL"];
	app.myPassport.setMyTerminal(terminal);

	voyage :="4480.1188078".asOid.CM_Voyage;
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	
	create allPxyResourceUsed transient;
	create pxyResourceUsed transient;
	resourceType:="5965.3861".asOid.HMS_ResourceType;
	fromTS:="19/06/2018 12:02".asTimeStampFromWebInterface;
	toTS:="19/06/2018 16:06".asTimeStampFromWebInterface;
	pxyResourceUsed.setProxy(app.myPassport.myTerminal.myHarbour,resourceType,null,null,fromTS,toTS,3,null,null,null);
	allPxyResourceUsed.add(pxyResourceUsed);
	app.myTrxUA.trxUpdateHMSResourcesUsed(allPxyResourceUsed,voyage,null,null,null,null,null,null,null,null,null,false, false,app.myPassport); // TFS 40236
	
	 app.myPassport.dumpErrorWarnings;
epilog
	allPxyResourceUsed.purge;
	delete allPxyResourceUsed; 
end;</source>
    </JadeMethod>
