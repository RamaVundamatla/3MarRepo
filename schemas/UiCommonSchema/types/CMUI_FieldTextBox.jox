    <JadeMethod name="buildSelf" id="1792c0c9-4e11-4709-a213-bbfa57af20d5">
        <updating/>
        <source>buildSelf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Purpose:		Instantiates the appropriate controls, and sets them all up.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlWidth	: Real;
	controlLeft		: Real;
	textboxObj		: CMUI_FieldTextBoxControl;
	
begin
	inheritMethod();
	
	create textboxObj transient;
	
	textboxObj.selectionStyle := textboxObj.SelectionStyle_SelectAll;
	if self.inputKind = self.KIND_DECIMAL then
		textboxObj.dataType	:=	TextBox.DataType_Numeric;
		textboxObj.decimals	:=	self.decimals;
	elseif self.inputKind = self.KIND_INTEGER then
		textboxObj.dataType	:=	TextBox.DataType_Numeric;
		textboxObj.decimals	:=	0;
	elseif self.inputKind = self.KIND_STRING then
		textboxObj.dataType	:=	TextBox.DataType_AlphaNumeric;
		textboxObj.decimals	:=	0;
	endif;
	
	self.myTextBox		:=	textboxObj;
	textboxObj.parent	:=	self;
	self.form.addControl(textboxObj);
	controlLeft			:=	self.myLabel.left + self.myLabel.width + CMUI_FieldFrame.HORIZONTAL_SPACING;
	controlWidth		:=	self.clientWidth() - controlLeft;
	textboxObj.move(controlLeft, 0, controlWidth, textboxObj.height);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="create" id="968e2cb1-bd97-4e67-bc19-c174c32f6720">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.inputKind = null then
		self.inputKind	:=	self.KIND_STRING;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDecimal" id="d4ced577-c1cb-4a9a-8cfd-e91915fdcb0e">
        <source>getDecimal(): Decimal;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.inputKind = self.KIND_DECIMAL then
		return self.myTextBox.text.trimBlanks().asDecimalJMT;
	else
		return inheritMethod();
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
