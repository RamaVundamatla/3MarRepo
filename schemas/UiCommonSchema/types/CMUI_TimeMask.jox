<GUIClass name="CMUI_TimeMask" id="f2cd4116-ff7f-45f1-bb85-98878642bcd7">
    <superclass name="JadeEditMask"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <Constant name="DefaultTimeFormat" id="f230fd5c-1a37-42a2-ab26-72bd7ca07878">
        <source>"hh:mm"</source>
        <type name="String"/>
    </Constant>
    <JadeMethod name="create" id="f06d8f68-6126-4c59-b0a0-86ad946d90f0">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin


	if self.isInPainter() then
		self.mask	:=	self.DefaultTimeFormat;
	else
			//self.mask := CM_BaseTable.EditMask_Time;	//'hh:mm';	// cnwdad1 16/06/2009 - PAR #19942.
		self.mask := app.getTimeEditMaskShortFormat(false);		// cnwdad1 16/06/2009 - PAR #19942.
	endif;
		
	self.selectionStyle := JadeEditMask.SelectionStyle_Select;
	
	// set so overwrite mode applies
	self.insertMode := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTime" id="b9ee368a-34d0-41bf-afe6-88012561b801">
        <source>getTime() : Time;
// cnwrs1 aug 2005
//
// cnwdad1 16/04/2010 - PAR #23647, added exception handler.
//
vars
	time	: Time;
	isError	: Boolean;
begin
	//time := self.text.trimBlanks().asTimeJMT();
	if self.textUser.trimBlanks() = null then
		return NULL_TIME;
	else
		on Exception do self.xHandler(exception, isError);
		
//		if self.isValid() then		// cnwdad1 04/08/2009 - PAR #20417.
			time	:=	self.getTextAsTime();
			if time.isValid() then
				return time;
			else
				return NULL_TIME;
			endif;
//		else
//			return NULL_TIME;
//		endif;
	endif;
epilog
	if isError then
		self.setFocus();
	endif;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="d134da4b-dfc5-41e8-961f-797c0c2d2853">
        <controlMethod name="JadeEditMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>lostFocus(editMask: JadeEditMask input) updating, clientExecution;
//
// cnwdad1 16/04/2010 - PAR #23647, added exception handler, instead of
// reseting to null when invalid value is entered.
//
vars
	tmpTime	: Time;
	time	: Time;
	isError	: Boolean;
	
begin
	inheritMethod(editMask);
	
	//tmpTime := editMask.text.Time;
	if self.textUser.trimBlanks() = null then
		editMask.setTextFromTime(NULL_TIME);
	else
		on Exception do self.xHandler(exception, isError);
		
//		if editMask.isValid() then		// cnwdad1 04/08/2009 - PAR #20417.
			tmpTime	:=	editMask.getTextAsTime();
			if tmpTime.isValid then
				//editMask.text := tmpTime.shortFormatJMT();
				editMask.setTextFromTime(tmpTime);
			//else Don't default to now as some dates are not set
			// was causing a read only and disabled control to be set on dblClick event	
				//editMask.text := time.shortFormatJMT();
			endif;
//		else
//			editMask.setTextFromTime(NULL_TIME);
//		endif;
	endif;
epilog
	if isError then
		self.setTextFromTime(NULL_TIME);
		self.setFocus();
	endif;
end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTime" id="5416aa77-9d09-4908-9707-432c1f72a3be">
        <updating/>
        <source>setTime(_time : Time) updating;
// cnwrs1 aug 2005
//
// cnwdad1 16/04/2010 - PAR #23647, added exception handler.
//
vars
	isError	: Boolean;
	
begin
	on Exception do self.xHandler(exception, isError);
	
	if _time.isValid() then
		//self.text := _time.shortFormatJMT();
		self.setTextFromTime(_time);
	else
		self.text := null;
	endif;
epilog
	if isError then
		self.setFocus();
	endif;
end;</source>
        <Parameter name="_time" type="Time"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="f3082827-2db2-46b8-822c-91c0b295b47b">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		17 June 2009 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isInPainter() then
		self.mask	:=	self.DefaultTimeFormat;
	else
		//self.mask := CM_BaseTable.EditMask_Time;	//'hh:mm';	// cnwdad1 16/06/2009 - PAR #19942.
		self.mask := app.getTimeEditMaskShortFormat(false);		// cnwdad1 16/06/2009 - PAR #19942.
	endif;

	self.selectionStyle := JadeEditMask.SelectionStyle_Select;
	
	// Set so overwrite mode applies.
	self.insertMode := false;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="xHandler" id="cdf57e5f-e3c3-43b0-8e70-4d0416379a9d">
        <source>xHandler(_exceptionObj:Exception; _isError:Boolean output):Integer protected;
// --------------------------------------------------------------------------------
// Created:		16 April 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_isError	:=	true;
	app.msgBox(app.getString(Time_Enter_Valid), app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="Exception"/>
        <Parameter name="_isError" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
