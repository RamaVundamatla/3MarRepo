    <JadeMethod name="hkDeployCardinalBins" id="158883a0-af35-4134-b9fb-34b090d216d6">
        <source>hkDeployCardinalBins();

vars
	b:Binary;
	f,g,h:File;
	ff:FileFolder;
	fn:FileNode;
	m:Machine;
begin
	write "Starting";
	
	create ff; create g;	create h;
	g.usePresentationFileSystem := false;
	g.mode := File.Mode_Output;	
	g.kind := File.Kind_Binary;
	h.usePresentationFileSystem := false;
	
	ff.fileName := "\\cnwchcs118\u$\hk\circs\new";
	//ff.fileName := "\\cnwchcm24\cnwjbl$\Tools\circ\new";

	foreach m in Machine.instances do		
	//foreach m in Machine.instances where m.hostName = "cnwchcs25" or m.hostName = "cnwchcs116" do 
		foreach fn in ff.files where fn.isKindOf(File) do
			f := fn.File;
			f.usePresentationFileSystem := false;
			f.kind := File.Kind_Binary;
			b := f.readBinary(f.fileLength);
			g.fileName := "\\cnwchcs118\u$\hk\circs\pending\" &amp; m.hostName &amp; "_" &amp; f.name;
			//g.fileName := "\\cnwchcs118\u$\hk\circs\pending\" &amp; m.hostName &amp; "\" &amp; f.name;
			g.writeBinary(b);
			g.lastModifiedTime := f.lastModifiedTime;
			g.close;
		endforeach;
		h.fileName:="\\cnwchcs118\u$\hk\myJobs\creatorin\" &amp; m.hostName &amp; "_" &amp; "SyncCardinalBin.job";
		//h.fileName:="\\cnwchcs118\jobs\" &amp; m.hostName &amp; "\creatorin\SyncCardinalBin.job";
		h.writeLine("SyncCardinalBin,,,,,,,,");
		h.close;
	endforeach;
	
	write "Finished";
epilog
	delete ff; delete g; delete h; 
end;</source>
    </JadeMethod>
    <JadeMethod name="hkFindPerlSubs" id="2cd08806-cebf-4da1-9f35-a93681c383c7">
        <source>hkFindPerlSubs();
vars
	s,t,u,v,subName:String;
	i,j,pos,subCount,lineNum,callCount,prevLineNum:Integer;
	f,g:File;
	fn:FileNode;
	ff:FileFolder;
begin
	create f; create g;
	g.fileName := "\\cnwchcs113\c$\thinbin\tools\dev\scripts\jblstdruncnlogmaker.pl";
	f.fileName := "\\cnwchcs113\c$\thinbin\tools\dev\scripts\jblcommonHK.pm";
	//f.fileName := "C:\a\TestFramework\perl\sources\jblworker.pl";
	//f.fileName := "U:\jp\TestFramework\changes\jblworker_no_split.pl";
	//f.fileName := "U:\jp\TestFramework\changes\jblcommon_jhp_AddElementSynopsis_2.pm";
	//f.fileName := "\\cnwchcs118\c$\thinbin\tools\dev\scripts\ppc.pl";
	f.usePresentationFileSystem := false;
	g.usePresentationFileSystem := false;
	s := f.readString(f.fileLength);
	f.close;
	write CrLf &amp; f.fileName;
	pos := 1;
	while true do
		pos := s.pos(CrLf &amp; "sub ", pos);
		if pos = 0 then break; endif;
		subCount := subCount + 1;
		if subCount &gt; 5 then break; endif;  // loop controller
		pos := pos + 5;
		s.scanWhile(" ", pos);
		subName := s.scanUntil(" ([{" &amp; CrLf, pos);
		write CrLf;  // &amp; "sub " &amp; subName;
		//write "sub " &amp; subName; continue;  // to get just a sub name list
		
		callCount := 0;
		lineNum := 0;
		while not f.endOfFile do
			t := g.readLine;
			lineNum := lineNum + 1;
			if t.contains(subName) then
				j := 1;
				t.scanWhile(" 	", j);
				u := t.scanUntil("({ 	", j);
				if u&lt;&gt;"qw" and u &lt;&gt; "logit" and u &lt;&gt; "copyconfig" and u &lt;&gt; "proceed" then
					write lineNum.String &amp; " " &amp; t;
					callCount := callCount + 1;
					if callCount &gt; 8 then
						write "too many calls...";
						break;
					endif;
				endif;
			endif;
		endwhile;
		f.close;
	endwhile;
epilog
	delete f; delete g;
end;</source>
    </JadeMethod>
    <JadeMethod name="hkGetMachinesStatus" id="62fddea9-8810-4a6c-b75c-e8a8206c037b">
        <source>hkGetMachinesStatus();

vars
	f:File;
	s,basicMachineDetails: String;
	m: Machine;

begin
	foreach m in Machine.instances where m.hostName &lt;&gt; "cnwchcs118" do
	
		create f transient;
		f.usePresentationFileSystem:=false;
		f.fileName:=app.miscPath &amp; "\hostconfigstatus\" &amp; m.hostName &amp; "_status.conf";
		if f.isAvailable then
			s:=f.readString(f.fileLength);
	
			basicMachineDetails := m.hostName &amp; " " &amp; s.getXMLValue("Manufacturer") &amp; " " &amp; s.getXMLValue("Model") &amp; ";_processors_: " &amp; s.getXMLValue("ProcessorName") &amp; " Physical " &amp; s.getXMLValue("NumberOfProcessors") &amp; " Cores " &amp; s.getXMLValue("NumberOfCores") &amp; ";_memory_: " &amp; s.getXMLValue("TotalPhysicalMemory") &amp; "Mb" &amp; ";_operating system_: " &amp; s.getXMLValue("osname") &amp; " " &amp; s.getXMLValue("servicepack") &amp; " updates=" &amp; s.getXMLValue("pendingwindowsupdates");
			write basicMachineDetails;
		
		endif;
	endforeach;
epilog
	delete f;
end;
</source>
    </JadeMethod>
    <JadeMethod name="hkJScript" id="eda92dee-c56c-4c2e-8a82-2dc699282fce">
        <source>hkJScript();

vars
	i, startDay, today: Integer;

begin
	startDay := app.actualTime.date.Integer;
	
/*	foreach i in 1 to 100 do
/*		today:= startDay + i;
		if 60 - (today - startDay) &gt; 30 then
			write today.Date.String &amp; "			" &amp; (60 - (today - startDay)).String;
		else
			write today.Date.String &amp; "			" &amp; "30";
		endif; 
		write (60 -(app.actualTime.date + i - "25 may 2016".Date)).max(30).String;
		
	endforeach;/**/
	write (60 -(app.actualTime.date - "25 may 2016".Date)).max(30).String;

epilog

end;
</source>
