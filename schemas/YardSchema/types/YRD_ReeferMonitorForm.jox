    <JadeMethod name="copyWorkListToTable" id="5a0495c3-f5de-448c-a850-7610dd7fe9a0">
        <updating/>
        <source>copyWorkListToTable(_ignoreConnected: Boolean) updating;
//----------------------------------------------------------------
//	Created:	30 September 2003	by Jason Chapman  (cnwjc2)
//	Changed On   Changed By  Reason
//	19/2/2009	 cnwcp2		 PAR# 18073 - incorrect terminal can be returned when using the app method call
//	10/12/2009	 cnwdap1	 CCMS MES 1007 Any TI can now be a reefer, not just containers
//----------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
	numItems	: Integer;
	breakOut	: Boolean;
	intSortCol	: Integer;
	//reefer	: CM_Container;		// CCMS 1007
begin

	foreach ti in self.myTerminal.allReeferConnectTIs do
	 	//if global.isValidObject(ti) and CM_Container.hasInstance(ti) then		// CCMS 1007
	 	if global.isValidObject(ti) then										// CCMS 1007
	 		//reefer := ti.CM_Container;										// CCMS 1007
			//if reefer.isConnected and _ignoreConnected then					// CCMS 1007
			if ti.isConnected and _ignoreConnected then							// CCMS 1007
				continue;
			endif;
			self.addObjectToTable(ti, numItems, breakOut);
		else
			continue;
		endif;
	endforeach;

	//default sort by location
	//set the column and resort
	intSortCol := self.tblData.allTblDataColPropertyNames.indexOf(ETRow_LocationId);
	tblData.column := intSortCol;
	self.zTblDataResort();

	self.numItemsShown	:= numItems;
	if self.useNumRowsShown then
		self.showNumRowsShown();
	endif;
	
end;</source>
        <Parameter name="_ignoreConnected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="0bfa2ca8-237e-4fc6-bca7-8c6741e3f2a1">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		03 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/03/2015	cnwdap1		PAR #35874 TFS 265 Added dyna dictionary for storing all types of readings
vars

begin

	self.permissionView	:= PmAdmReefermonitorView;
	self.permissionMaint := PmAdmReefermonitorMaint;
	
	self.allReadings.setMembership(CM_Object);						// PAR #35874
	self.allReadings.addExternalKey(TimeStamp, 8, false, true);		// PAR #35874
	self.allReadings.addExternalKey(String, 20, false, false);		// PAR #35874
	self.allReadings.endKeys(false);								// PAR #35874

end;</source>
    </JadeMethod>
    <JadeMethod name="doMenuColourLegend" id="1ab71061-8ca6-48bc-a4d2-f3032eebcb84">
        <source>doMenuColourLegend(menuItem: MenuItem input);
//----------------------------------------------------------------
//	Created:	29 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	colLegend	: CMUI_ColourLegend;
begin

	// Update the navigator
	create colLegend;
	self.myMasterMenuAction.setHeading(colLegend.caption); 
	colLegend.setAssistantAndTerminalRefs(self.myAssistant, self.myTerminal);

	colLegend.addLegendItem(app.getErrorString(Temperature_Reading_Colours), self.ColorGreyDark, White, null, false);	//cnwmc5 - PAR 32526 - 11 Oct 2013
	colLegend.addLegendItem(app.getErrorString(Reading_Above_Commodity_Range), null, LightRed, null, false);
	colLegend.addLegendItem(app.getErrorString(Reading_Within_Commodity_Range), null, null, null, false);
	colLegend.addLegendItem(app.getErrorString(Reading_Below_Commodity_Range), null, LightBlue, null, false);
	colLegend.addLegendItem(app.getErrorString(Reading_Defrost), null, ColourVioletLight, null, false); //Aug 2007 cnwrs1 CCMS1551
	colLegend.addLegendItem("", null, null, null, false);
	colLegend.addLegendItem(app.getErrorString(Connection_Status_Colours), self.ColorGreyDark, White, null, false);		//cnwmc5 - PAR 32526 - 11 Oct 2013
	colLegend.addLegendItem(app.getErrorString(Reefer) &amp; " " &amp; app.getErrorString(Not_Connected), null, LightRed, null, false);
	colLegend.addLegendItem(app.getErrorString(Reefer) &amp; " " &amp; app.getErrorString(Connected), null, White,null, false);
	colLegend.addLegendItem(app.getErrorString(Reefer) &amp; " " &amp; app.getErrorString(Disconnected), null, self.ColorGreenLight, null, false);
	colLegend.addLegendItem(app.getErrorString(Reefer) &amp; " " &amp; app.getErrorString(Defrosted), null, ColourVioletBright, null, false); //Aug 2007 cnwrs1 CCMS1551
	
	colLegend.centreWindow;
	colLegend.showModal;

epilog
//	delete colLegend;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMenuConnectDisClick" id="d674d076-4ae4-43a3-90b8-c6fab8c0c69d">
        <updating/>
        <source>doMenuConnectDisClick(_menuItem: MenuItem input;_action:Integer constant) updating;
// ---------------------------------------------------------------------------
// Created:		04 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	connectForm		: CMUI_ConnectAttach;
	reefer			: Object;
	rowIdx			: Integer;
	strDisplay		: String;
	bCont			: Boolean;
begin
	
	if self.myCurrentObject = null then
		return;
	endif;
		
	create connectForm;
	
	if self.tblData.allSelectedObjects.size &gt; 0 then
		self.tblData.allSelectedObjects.copy(connectForm.allTrackedItems);
	endif;

	connectForm.centreWindow;
	connectForm.setMyTerminal(self.myTerminal);
	connectForm.myParent := self;
	connectForm.action := _action;
	connectForm.startupMode := CMUI_ConnectAttach.StarupMode_TowerPower;
//	connectForm.myTerminalArea := self.filterTerminalArea;
	connectForm.showModal;


epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
        <Parameter name="_action" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMenuReeferTempReadingClick" id="bd2edbf6-766b-418b-bcff-0f3d4c19b314">
        <source>doMenuReeferTempReadingClick(_menuItem: MenuItem input);
// ---------------------------------------------------------------------------
// Created:		04 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 11/03/2010	cnwdap1		PAR #22938 Correct reefer checking
vars
	form			: YRD_AddTempReading;
	timeOut,
	commCheckMode	: Integer;
	obj				: Object;
	ids, msg 		: String;
	commChkDisabled	: Boolean;
begin
	
	if self.tblData.allSelectedObjects.size = 0 then 
		return;
	endif;
	
	commChkDisabled := self.myTerminal.getConfig(RefConDisableCommCheck).Boolean;
	timeOut := self.myTerminal.getConfig(RefConCommGracePeriod).Integer;
	msg := self.getRefConCommMessage(timeOut);
	
	if (not commChkDisabled)
//	and app.myRoot.canDo(PmRefCon)
	and app.myRoot.canDo(Mod_BaseSystem)	//07 Oct 2019	NDL	TFS 46169
	and app.msgBox(msg,'Communication Check',MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		commCheckMode := Comm_Check_RefCon;
	else
		commCheckMode := Comm_Check_Readings;
	endif;
	
	//setup and get things registered
	create form;
	form.centreWindow;
	form.commCheckMode := commCheckMode;
	self.tblData.allSelectedObjects.copy(form.allReefers);
	form.setForSetup(self.myTerminal);
	form.myParentForm := self;
	
	if commCheckMode = Comm_Check_RefCon then
		foreach obj in self.tblData.allSelectedObjects do
			if CM_Container.hasInstance(obj) or (obj.CM_TrackedItem.isReefer) then		// PAR #22938
				//ids := ids &amp; "/" &amp; obj.CM_Container.id;	// CCMS 1007
				ids := ids &amp; "/" &amp; obj.CM_TrackedItem.id;	// CCMS 1007
			endif;
		endforeach;
		
		self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(EVENT_REFCON_REQUEST), true, ids);
	endif;
	
	form.showModal;
	
epilog
	delete form;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="c4a943b6-d586-4d2d-9ae0-8194535fb648">
        <updating/>
        <source>doMnuFormContextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*
Purpose:			
Date		Who		Reason
11 July 2016	cnwab1	Initial creation
*/

