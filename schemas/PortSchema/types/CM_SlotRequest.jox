    <JadeMethod name="setDoorMotorDirDefault" id="a49bf3af-ea87-4880-9ed8-2c6583176f37">
        <updating/>
        <source>setDoorMotorDirDefault() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	isInteg : Boolean;
	isForty : Boolean;
	tmpSlotDefn	: CM_SlotDefn;
	
begin

	tmpSlotDefn := self.mySlotDefinition;
	if tmpSlotDefn = null then
		return;
	endif;
	
	if (not self.isLoad) then
		return;
	endif;
	
	theTI := self.getTrackedItem();
	
	self.doorsDirection := TI_DOORSDIRN_NULL;	
	self.motorDirection := Motor_Null;
	
	if theTI &lt;&gt; null then
	
	// 09 Apr 2010	NDL	Par 22526	- remove reliance on being a 40 to make use of 
	// 'motor40Aft' and 'doors40Aft'	attributes...
	//	isForty := theTI.isAttributeTrue(TI_Attrib_IsForty);
		isInteg := (theTI.isAttributeTrue(TI_Attrib_IsIntegral) or
				   theTI.isAttributeTrue(TI_Attrib_IsWaterCooled));

		if isInteg then
			if tmpSlotDefn.motor40Aft or tmpSlotDefn.motor20Aft then
				self.motorDirection := Motor_Aft;
			else
				self.motorDirection := Motor_Forward;
			endif;
		else
			if tmpSlotDefn.doors40Aft or tmpSlotDefn.doors20Aft then
				self.doorsDirection := TI_DOORSDIRN_AFT;
			else
				self.doorsDirection := TI_DOORSDIRN_FWD;
			endif;
		endif;

	else
		// no TI yet so use the slot request
		
		if tmpSlotDefn.motor40Aft or tmpSlotDefn.motor20Aft then
			self.motorDirection := Motor_Aft;
		else
			self.motorDirection := Motor_Forward;
		endif;
		
		if tmpSlotDefn.doors40Aft or tmpSlotDefn.doors20Aft then
			self.doorsDirection := TI_DOORSDIRN_AFT;
		else
			self.doorsDirection := TI_DOORSDIRN_FWD;
		endif;
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEDIAttributes" id="654db339-2087-441b-a244-7950ad22cb56">
        <updating/>
        <source>setEDIAttributes(_verifyOnly : Boolean; _loadCC: CMIF_LoadColorCode) updating;
//----------------------------------------------------------------
//	Created:	04 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isoType		: CM_ISOType;
begin
	self.empty			:= _loadCC.isEmpty;
	self.halfHeight		:= _loadCC.halfHeight;
	self.hazardous		:= _loadCC.isHazardous;
	self.highCubed		:= _loadCC.highCube;
	self.overDimension	:= _loadCC.overDimension;
	self.power 			:= _loadCC.requiresPower;
	self.waterCooled 	:= _loadCC.waterCooled;
	
	// TFS 47372 jlgmd1 14/11/2019
	isoType := _loadCC.myISOType;
	if isoType &lt;&gt; null then
		self.flat 		:= isoType.isFlat;			// TFS 47372
		self.crib 		:= isoType.isCrib;			// TFS 47372
		self.tank 		:= isoType.isTank;			// TFS 47372
		self.opentop 	:= isoType.isOpenTop;		// TFS 47372
		self.fantainer	:= isoType.isFantainer;		// TFS 47372
		self.frame		:= isoType.isFrame;			// TFS 47372
	endif;
	
	if _verifyOnly then
		self.fortyFront := _loadCC.isForty; // PAR 24041
	endif;
	
end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode"/>
    </JadeMethod>
