    <JadeMethod name="valCreateSlotRequestAttribute" id="21546f4f-2ebf-4091-86e4-ab5356711029">
        <source>valCreateSlotRequestAttribute(_theSlot, _theSlotAlt : CM_SlotController; _isLoad : Boolean; _loadCC : CMIF_LoadColorCode input; _theEditions : CM_ObjectByOidEditionDict; _attribute : String; _passport : CM_Passport input);
//----------------------------------------------------------------
//	Created:	04 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpSlot,
	tmpSlotAlt			: CM_SlotController;
	expectedEdition		: Integer;
	tmpSlotDefn			: CM_SlotDefnVoyage;
	tmpSlotRequest		: CM_SlotRequest;
begin

	tmpSlot := _theSlot;
	
	expectedEdition := _theEditions.getEditionForObject(tmpSlot);

	if expectedEdition &lt; 0 then
		app.raiseExNoEditionForUpdateObj(tmpSlot);
	endif;
		
	exclusiveLock(tmpSlot);
	if tmpSlot.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; tmpSlot.ident, null, null);
		return;
	endif;
	
	tmpSlotDefn := tmpSlot.mySlotDefnVoyage;
	
	if tmpSlotDefn.unavailable then
 // PAR 26684		app.raiseCMException2(SlotIsUnavailable, tmpSlotDefn.myBay.id &amp; tmpSlot.ident, app.getErrorString(MoveCargo), null, null);
		app.raiseCMException2(SlotIsUnavailable, tmpSlot.getFullId(), app.getErrorString(MoveCargo), null, null); // PAR 26684
		return;
	endif;
			
	if (not _isLoad) then
		if _attribute &lt;&gt; CM_SlotRequest.Attribute_Erase then
			// if discharging and we have no tracked items then raise an error
			if tmpSlot.allTrackedItems.isEmpty then 
				app.raiseCMException1(SlotHasNoTIsToDischarge, tmpSlot.myBayVoyage.id &amp; tmpSlot.ident, null, null);
				return;
			endif;
		endif;
		tmpSlotRequest := tmpSlot.mySlotRequestDischarge;
	else
		if _theSlotAlt &lt;&gt; null and _attribute &lt;&gt; CM_SlotRequest.Attribute_Erase then
			// if discharging and we have no tracked items then raise an error
			if _theSlotAlt.allTrackedItems.isEmpty then 
				app.raiseCMException1(SlotHasNoTIsToDischarge, _theSlotAlt.myBayVoyage.id &amp; _theSlotAlt.ident, null, null);
				return;
			endif;
		endif;
		tmpSlotRequest := tmpSlot.mySlotRequestLoad;
	endif;
	
	if _attribute = CM_SlotRequest.Attribute_Erase 
	and tmpSlotRequest &lt;&gt; null then
		if tmpSlotRequest.myJob &lt;&gt; null then
			if tmpSlotRequest.myJob.CM_VoyageJob.isLoadedToOperations then
				app.raiseCMException1(ERR_JOB_LOADED, tmpSlotRequest.myJob.jobId, null, null);
				return;
			endif;
		endif;
	endif;

	// PAR 21746 if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.fortyBack then
	if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.getAttrIsBackend() then // PAR 21746
		app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.myBayVoyage.id &amp; tmpSlot.ident, null, null);
	endif;

	tmpSlotAlt := _theSlotAlt;

	if tmpSlotAlt = null then
		return;
	endif;

	expectedEdition := _theEditions.getEditionForObject(tmpSlotAlt);
	if expectedEdition &lt; 0 then
		app.raiseExNoEditionForUpdateObj(tmpSlotAlt);
		return;
	endif;
			
	exclusiveLock(tmpSlotAlt);
	if tmpSlotAlt.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; tmpSlotAlt.myBayVoyage.id &amp; tmpSlotAlt.ident, null, null);
		return;
	endif;
	tmpSlotDefn := tmpSlotAlt.mySlotDefnVoyage;
	if tmpSlotDefn.unavailable then
		app.raiseCMException2(SlotIsUnavailable, tmpSlotAlt.myBayVoyage.id &amp; tmpSlotAlt.ident, app.getErrorString(UpdateIt), null, null);
		return;
	endif;

	if _isLoad then
		tmpSlotRequest := tmpSlot.mySlotRequestLoad;

		if _attribute = CM_SlotRequest.Attribute_SOB then
			// if isLoad then the alt slots are the discharge part so if no tracked items then raise an error
			if tmpSlotAlt.allTrackedItems.isEmpty then
				app.raiseCMException1(SlotHasNoTIsToDischarge, tmpSlotAlt.myBayVoyage.id &amp; tmpSlotAlt.ident, null, null);
				return;
			endif;
		endif;
	else
		tmpSlotRequest := tmpSlot.mySlotRequestDischarge;
	endif;

	// PAR 21746 if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.fortyBack then
	if tmpSlotRequest &lt;&gt; null and tmpSlotRequest.getAttrIsBackend()  then // PAR 21746 
		app.raiseCMException1(SlotRequestUpdateFromBack, tmpSlot.myBayVoyage.id &amp; tmpSlot.ident, null, null);
	endif;

end;</source>
        <Parameter name="_theSlot" type="CM_SlotController"/>
        <Parameter name="_theSlotAlt" type="CM_SlotController"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode" usage="input"/>
        <Parameter name="_theEditions" type="CM_ObjectByOidEditionDict"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
