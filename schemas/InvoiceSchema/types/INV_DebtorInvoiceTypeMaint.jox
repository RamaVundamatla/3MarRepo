    <JadeMethod name="deletePackage" id="d8fd778a-a7b6-43da-a380-43a79f4a913e">
        <updating/>
        <source>deletePackage() updating, protected;

vars

	result			: Integer;
	msgStr			: String;
	package	: CM_Package;
begin

	package := self.msPackages.mySelectedListBox.listObject.CM_Package;
	if package = null then
		package := self.msPackages.myAvailableListBox.listObject.CM_Package;
	endif;
	if package = null then
		return;
	endif;
   	msgStr := app.getErrorString2(ConfirmDelete, 'Package', package.description);
	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	
	
	while true do
	  	app.myTrxDA.trxDeletePackage(package, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayPackage" id="0972de52-6536-4a8f-bfad-9a8395ac2f1c">
        <source>displayPackage(_obj : Object) : String protected;

vars

begin
	if _obj = null then
		return null;
	else
		if _obj.CM_Package.description &lt;&gt; null then
			return _obj.CM_Package.description;
		else
			return _obj.CM_Package.code;
		endif;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
