    <JadeMethod name="defaultDetailsFromParentItem" id="bbcb6466-8290-4748-ba1d-65f762c5c1cb">
        <updating/>
        <source>defaultDetailsFromParentItem(_parent: CMIF_TIObject) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2009	cnwdap1	Initial creation
*/
vars

begin
	self.companyCode 		:= _parent.companyCode;
	self.mySubTerminal 		:= _parent.mySubTerminal;
	self.myTerminal 		:= _parent.myTerminal;
	self.subTerminalCode 	:= _parent.subTerminalCode;
epilog

end;</source>
