        <source>initialise(_trackedItem: CM_TrackedItem; _quantity: Integer; _weight: Decimal; _volume: Decimal; _targetLocationId : String; _unpackTime : TimeStampOffset) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 September 2024	navcs2	ChangeRequest 65967: CUX | MasterTerminalAPI - Pack and Unpack APIs

*/

vars

begin
	self.trackedItem 		:= _trackedItem;
	self.quantity 			:= _quantity;
	self.weight				:= _weight;
	self.volume				:= _volume;
	self.targetLocationId	:= _targetLocationId;
	self.unpackTime			:= _unpackTime;
epilog

end;</source>
