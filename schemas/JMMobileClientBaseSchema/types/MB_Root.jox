    <JadeMethod name="getClientConnectionDetails" id="8159817a-f0f1-474c-b04b-a9e53c0b17e4">
        <source>getClientConnectionDetails(_machineName : String output; _portNumber : Integer output);

vars
	tmpStr	: String;
	tmpPos	: Integer;
begin

	if self.clientMachineName &lt;&gt; null then
		_machineName := self.clientMachineName;
		_portNumber	:= self.clientPortNumber;
		return;
	endif;
	
	// get it off the app
//	tmpStr := app.getPersistentAppByNameJMT('JMMobileClientBase', 'JMMobileListener').getPropertyValue('_webMachineName').String;
	
	if tmpStr = null then
		return;
	endif;
	
	tmpPos := 1;
	_machineName := tmpStr.getNextToken(tmpPos);
	if tmpPos &gt; 0 then
		_portNumber := tmpStr.getNextToken(tmpPos).Integer;
	endif;

end;</source>
        <Parameter name="_machineName" type="String" usage="output"/>
        <Parameter name="_portNumber" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getClientConnectionFormatted" id="50b8a156-8847-4c79-a647-752b87aee6e9">
        <source>getClientConnectionFormatted() : String;

vars
	tmpMachineName	: String;
	tmpPortNumber	: Integer;
begin
	self.getClientConnectionDetails(tmpMachineName, tmpPortNumber);
	return tmpMachineName &amp; ':' &amp; tmpPortNumber.String;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getServerConnectionDetails" id="0f5966a5-a353-4b9b-9806-5dee0edf35bd">
        <source>getServerConnectionDetails(_machineName : String output; _portNumber : Integer output);

vars
	tmpStr	: String;
	tmpPos	: Integer;
begin

	if self.serverMachineName &lt;&gt; null then
		_machineName	:=	self.serverMachineName;
		_portNumber		:=	self.serverPortNumber;
		return;
	endif;
	
	if app.myDTOInterface = null then
		return;
	endif;
	
	// get it off the web-service
	tmpStr := app.myDTOInterface.getEndpointURL();
	
	if tmpStr = null then
		return;
	endif;
	
	tmpPos := tmpStr.pos('//', 1);
	if tmpPos &lt;= 0 then
		return;
	endif;
	
	tmpStr := tmpStr[tmpPos + 2 : end];
	tmpPos := tmpStr.pos('//', 1);
	if tmpPos &lt;= 1 then
		return;
	endif;
	tmpStr := tmpStr[1 : tmpPos-1]; 
	
	tmpPos := 1;
	_machineName := tmpStr.getNextToken(tmpPos);
	if tmpPos &gt; 0 then
		_portNumber := tmpStr.getNextToken(tmpPos).Integer;
	endif;
end;</source>
        <Parameter name="_machineName" type="String" usage="output"/>
        <Parameter name="_portNumber" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getServerConnectionFormatted" id="20d0c41d-596f-4e55-ba2a-1eff01a9526f">
        <source>getServerConnectionFormatted() : String;

vars
	tmpMachineName	: String;
	tmpPortNumber	: Integer;
begin
	self.getServerConnectionDetails(tmpMachineName, tmpPortNumber);
	return tmpMachineName &amp; ':' &amp; tmpPortNumber.String;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setConnectionDetails" id="a9383b6c-39b0-42f5-bd68-5f146ea6b1da">
        <updating/>
        <source>setConnectionDetails(	_clientMachineName : String;
						_clientPortNumber : Integer;
						_serverMachineName : String;
						_serverPortNumber : Integer) updating;

/*

Date		Who		Reason
03 Apr 2008	cnwkpd1	PAR #16421 - Rework to reduce locking on system collections

*/
						
vars
	restartListener	: Boolean;
	tmpProcess		: Process;
	tmpProcesses	: ProcessDict;
	invalidProcess	: Boolean;
	
begin

	if self.clientMachineName &lt;&gt; _clientMachineName or
	   self.clientPortNumber &lt;&gt; _clientPortNumber then
		// client has changed so need to check if running and restart
		
		tmpProcesses := node.processes.cloneSelf(true);		// PAR #16421
		
		on Exception do app.handleDeletedObject(exception, tmpProcess, invalidProcess);
		
		foreach tmpProcess in tmpProcesses do
			if tmpProcess.persistentApp.name = 'JMMobileListener' then
				restartListener := true;
				node.causeEvent(Event_TerminateListenerApp, true, null);
				break;
			endif;
		endforeach;
	endif;

	beginTransaction;
	self.clientMachineName 	:= _clientMachineName;
	self.clientPortNumber	:= _clientPortNumber;

	self.serverMachineName 	:= _serverMachineName;
	self.serverPortNumber	:= _serverPortNumber;
	commitTransaction;

	if app.myDTOInterface &lt;&gt; null then
		app.myDTOInterface.setConnectionDetails(self.getServerConnectionFormatted());
	endif;
	
	if restartListener then
		app.startListenerApp();
	endif;
	
	
epilog
	delete tmpProcesses;
	
end;</source>
        <Parameter name="_clientMachineName" type="String"/>
        <Parameter name="_clientPortNumber" type="Integer"/>
        <Parameter name="_serverMachineName" type="String"/>
        <Parameter name="_serverPortNumber" type="Integer"/>
    </JadeMethod>
</Class>
