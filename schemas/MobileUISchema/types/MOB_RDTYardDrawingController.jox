    <JadeMethod name="drawAreaSubsetLandscape" id="c8fadd9e-97b9-4501-bfef-c89391c6a084">
        <source>drawAreaSubsetLandscape() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwjk3	Initial creation

*/

vars
	y1 				: Real;
	flipCol,
	row 			: Integer;
	gridWidth,
	gridHeight		: Real;
	finishedRows	: Boolean;
begin	
	 
	if self.flipV then
		y1 := self.myDrawingFrame.clientHeight() + self.yDrawOffset - self.bottomOffset;	
	else
		y1 := self.yDrawOffset + self.topOffset;
	endif;
	
	gridWidth  := self.getGridWidth();
	gridHeight := self.getGridHeight();
	
	if self.flipV then
		row := self.bottomGridRowDraw;	
	else
		row := self.topGridRowDraw;
	endif;

	while not finishedRows do	
		
		//gridRow := self.myGridArea.allGridRows[row];	
		self.drawRowsLandscape(y1, gridWidth, gridHeight, row);
				
		row := row + 1;
		if self.flipV then
			finishedRows := row &gt; self.topGridRowDraw;
		else
			finishedRows := row &gt; self.bottomGridRowDraw;
		endif;	
		
		
		// Move up/down
		if self.flipV then
			y1 := y1 - gridHeight;
		else
			y1 := y1 + gridHeight;
		endif;
		
	endwhile;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawAreaSubsetLandscapeOLD" id="a428afcd-d8b1-4e0e-be50-4f77e6d61167">
        <source>drawAreaSubsetLandscapeOLD() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwjk3	Initial creation

*/

