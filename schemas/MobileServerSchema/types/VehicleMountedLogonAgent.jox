<Class name="VehicleMountedLogonAgent" id="cca51a19-0f89-48c0-be64-a4b5d9f80c74">
    <superclass name="HandHeldAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="mobileServer"/>
    <ImplicitInverseRef name="myMachine" id="aabbac80-02db-40f6-b79a-dcac9ddaf662">
        <embedded/>
        <type name="CM_Machine"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myRTQueue" id="5e7328ac-292d-4e7b-be11-69a8a8c418d4">
        <embedded/>
        <type name="CM_RadioTelemetryQueue"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="doLogon" id="1fcbf4a8-7aff-4fea-9083-4fcd04f97b69">
        <updating/>
        <source>doLogon(_userName: String; _password : String; _errorStr: String output) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 October 2006	cnwer1	Initial creation - PAR#xxxx
20 Feb	   2009 cnwer1 	par 18256  - changed so the logon transaction is done through the transaction agent method trxUpdateLogonWithMachine
								   - this is so if a CM exception haappens it will be handled with the correct exception handler will not get a jade one
								   and central services will not get a tracker fault

								   
 */
vars
	passport 	: CM_Passport;
	result		: Integer;
begin
	
	
	if not self.validateRTDeviceDetails(_errorStr) then
		return;
	endif;
	
	user := app.myRoot.allUsers[_userName];
	
	if user = null then
		_errorStr :=  app.getErrorString(ERR_PASSWORD);
		return;
	endif;
	
	if not self.validateUserPermissions(_errorStr) then
		return;
	endif;
	
	
	result:=app.myTrxUA.trxUpdateLogonWithMachine(	_userName, _password,self.myMachine,passport);
	
	if result &lt;&gt; 0 then
		_errorStr := app.getErrorString(result);
		
		app.myRoot.resolveMessagesWithExtraInfo(result, _errorStr); //+ cnwmd1 Par 22287
		
		return;
	endif;
	
		
	if passport &lt;&gt; null then
		passport.setMyTerminal(self.myTerminal);
	endif;
	
	if _errorStr &lt;&gt; null then
		return;
	endif;
	
	self.myRTQueue:=self.myMachine.myPrimaryQueue;
	

	

epilog

end;</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_errorStr" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getAgentClass" id="d9525f6b-dea0-425c-bbef-d8e551942f9c">
        <source>getAgentClass() : Class;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	machineType : CM_MachineType;
begin
	if self.myMachine = null then
		return null;
	endif;
	
	if self.myMachine.machineType = MACHINETYPE_RTG or
		self.myMachine.machineType = MACHINETYPE_RMG then
		return VehicleMountedRTGAgent;
	elseif self.myMachine.machineType = MACHINETYPE_IMV then
		return VehicleMountedIMVAgent;
	elseif self.myMachine.machineType = MACHINETYPE_FORK_LIFT or
		self.myMachine.machineType = MACHINETYPE_SIDE_LOADER or
			self.myMachine.machineType = MACHINETYPE_TOP_LIFT then
		return VehicleMountedRAILAgent;
	elseif self.myMachine.machineType = MACHINETYPE_STRADDLE then
		return VehicleMountedSTRADAgent;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getAppLicencePermission" id="376fb270-7914-425a-9aa7-58eecb330520">
        <source>getAppLicencePermission(): Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if self.myMachine.machineType = MACHINETYPE_RTG or
		self.myMachine.machineType = MACHINETYPE_RMG then
	//	return PmHandHeldRTGClient;
		return null;	//07 Oct 2019	NDL	TFS 46169
	elseif self.myMachine.machineType = MACHINETYPE_IMV then
		return PmAdmVMIMVJobs;
	elseif self.myMachine.machineType = MACHINETYPE_FORK_LIFT or
		self.myMachine.machineType = MACHINETYPE_SIDE_LOADER or
			self.myMachine.machineType = MACHINETYPE_TOP_LIFT then
		return PmAdmVMRailJobs;
	elseif	self.myMachine.machineType = MACHINETYPE_STRADDLE then
		return PmAdmVMRailJobs;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
