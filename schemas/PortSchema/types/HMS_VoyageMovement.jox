    <JadeMethod name="setProxyDefaultsForVoyage" id="45df333f-1c28-4488-b1fe-954b3405373e">
        <updating/>
        <source>setProxyDefaultsForVoyage(_myVoyageData : HMS_VoyageData; _movementType : String; _passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	30 March 2004 By: cnwgd1
//--------------------------------------------------
//Called by the voyage data setForCreate to set move default from the voyage and/or vessel data
// 21 Sep 2016	cnwrs1	TFS 2615 1090 creating voyage in new termuinal
// 08 Feb 2024	naviv1	Bug 61983 - POB - QShips - voyage code not showing in the invalid date/time error
// 12 Aug 2024  navsp1  TFS ChangeRequest 63842: NSW | OnePort Integration Dev
vars
	defMoveDT			: TimeStamp;
	tmpVoyage			: CM_Voyage;
	tmpVDHarbour		: HMS_VesselDataHarbour;
	tmpHMSVessel		: HMS_VesselData;
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myHMSVoyageData := _myVoyageData;
	if self.myHMSVoyageData = null then
		app.raiseCMException1(ERR_NO_OBJECT, 'Voyage Data', null, null);
		return;
	endif;

	self.myHarbour := self.myHMSVoyageData.myHarbour;
	if self.myHarbour = null then
//		app.raiseCMException1(ERR_NO_OBJECT, 'Harbour', null, null);
		app.raiseCMException1(HMSNoHarbourForTerminal, _passport.myTerminal.code, null, null);
		return;
	endif;
	
	tmpVoyage := self.myHMSVoyageData.myVoyage;
	if tmpVoyage = null then
		app.raiseCMException1(ERR_NO_OBJECT, 'Voyage', null, null);
		return;
	endif;

	if tmpVoyage.arrivedDT.isValid() and			//TFS 63842
	   tmpVoyage.departedDT.isValid() and			//TFS 63842
	   tmpVoyage.arrivedDT &gt;= tmpVoyage.departedDT then
		app.raiseCMException1(AutoScheduleDateError, 'Voyage : ' &amp; tmpVoyage.getDisplayDetails(true) &amp; " - The arrival date/time must be before the departure date/time", null, null); //08.02.2024 naviv1 #61983
		return;
	endif;

	tmpHMSVessel := self.myHMSVoyageData.getMyHMSVesselData();
	if tmpHMSVessel &lt;&gt; null then
		tmpVDHarbour := tmpHMSVessel.allVesselDataForHarbour[self.myHarbour];
	endif;

	self.moveType := _movementType;
	//self.moveStatus := MovementStatus_Planned;
		
	if _movementType = HMSMovementTypeArrival then
		defMoveDT := tmpVoyage.arrivedDT;			
	elseif _movementType = HMSMovementTypeDeparture then
		defMoveDT := tmpVoyage.departedDT;
	endif;
	
	self.setProxyForMoveConfirmation(defMoveDT, MovementStatus_Planned, null, null);

	// Orientation
	self.sideTo := self.init_Orientation();
	// 31/05/2010 cnwmh5 #23494 - Start
	// set the default value based on voyages starboardBerthed value
	if tmpVoyage.starboardBerthed then
		self.sideTo := OrientStarboardSideTo;
	endif;	
	// 31/05/2010 cnwmh5 #23494 - End

	// Set default berth 
	//self.init_BerthBowSternMarks(); Done when both movements have been created

	// Number of lines crew
	self.numLineCrewRequired := self.init_NumLinesCrewReqd();

	// Set default tidal class for movement
	self.myTidalClass := self.init_MoveTidalClass();

	// Set pilot exempt status
	self.pilotExempt := self.init_IsPilotExempt();

	// Set pilot launch
	//self.myPilotLaunch := self.init_PilotLaunch(); PAR 10455 do not default to first pilot launch

	// Set pilot
	//self.myPilot := self.init_Pilot(); PAR 10455 do not default to first pilot

	// Set customer for movement
	self.myShippingAgent := self.myHMSVoyageData.myShippingAgent;
	self.myLineCompany := self.myHMSVoyageData.myLineCompany;
		
	self.myShippingLine := self.myHMSVoyageData.myVoyage.myShippingLine;
	if self.myShippingLine = null
	and tmpHMSVessel &lt;&gt; null then
		self.myShippingLine := tmpHMSVessel.myDefaultShippingLine;
	endif;
	
	if self.myShippingAgent &lt;&gt; null then
		if tmpVDHarbour &lt;&gt; null then
			self.isAgentDefault := self.myShippingAgent = tmpVDHarbour.myShippingAgent;
		endif;
		self.myContact := self.myShippingAgent.allContacts.first;
	elseif self.myShippingLine &lt;&gt; null then
		self.myContact := self.myShippingLine.allContacts.first;
	endif;

	// PAR 11494 default should be true
	self.chargeForMove := true;
	//self.chargeForMove := (self.myShippingLine &lt;&gt; null or self.myShippingAgent &lt;&gt; null);	

	// Set line company
	/*if self.myLineCompany = null then
		self.myLineCompany := init_LineCompany; PAR 10455 do not default to first line company
	endif;*/	

	// Set Marine Service order locations (Pilot Launch, Tugs)
	self.init_MarineServOrderLocations();
	
	// Set relative order times for marine services
	self.init_MarineServOrderTimes();

	//CCMS1299 create default resources from vessel movement resource used
	self.setDefaultResourcesUsed(true, _passport);
	
end;</source>
        <Parameter name="_myVoyageData" type="HMS_VoyageData"/>
        <Parameter name="_movementType" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyForMoveConfirmation" id="0cffbf9e-63c4-49a2-b5bb-b33aebb026ed">
        <updating/>
        <source>setProxyForMoveConfirmation(_occursOnDT : TimeStamp; _moveStatus : Integer; _draftAft, _draftFwd : Decimal) updating;
//--------------------------------------------------
// Created:	07 January 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.moveStatusNEW 	:= _moveStatus;
	self.occursOnDTNEW 	:= _occursOnDT;

	self.draftAft := _draftAft;
	self.draftFwd := _draftFwd;
end;</source>
        <Parameter name="_occursOnDT" type="TimeStamp"/>
        <Parameter name="_moveStatus" type="Integer"/>
        <Parameter name="_draftAft" type="Decimal"/>
        <Parameter name="_draftFwd" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setPxyCancelledAttribs" id="755555a1-aad2-42af-bfcb-80a0d574e976">
        <updating/>
        <source>setPxyCancelledAttribs( _pxyReplaceCancelled : HMS_VoyageMovement output;
						_woDtlForStatusChg : CM_WorkOrderVoyageDtl output;
						_woPermitToClear : CM_WodPermitRequest output
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2018	jlgndl1	Initial creation	TFS 42043
04 Dec 2018	NDL	TFS 42043 - reworked for further changes

*/

vars

	voyage : CM_Voyage;

begin

	voyage := self.getMyVoyage();
	if self.moveType = HMSMovementTypeArrival then
		if voyage &lt;&gt; null then
			_woDtlForStatusChg:= voyage.getWorkOrderForIMSR();
			if _woDtlForStatusChg &lt;&gt; null then
				_woPermitToClear := _woDtlForStatusChg.myRelatedPermitRequest;
			endif;
		endif;
	elseif self.moveType = HMSMovementTypeShift then
		if voyage &lt;&gt; null then
			_woDtlForStatusChg := voyage.getWodShiftForMovement( self.pxyGetRealObject );	//10 Dec 2018	TFS 42043
			if _woDtlForStatusChg &lt;&gt; null then
				_woPermitToClear := _woDtlForStatusChg.myRelatedPermitRequest;
			endif;
		endif;
	elseif self.moveType = HMSMovementTypeDeparture then
		if voyage &lt;&gt; null then
			_woDtlForStatusChg:= voyage.getWorkOrderForDMSR();
		endif;
	endif;

	
	if self.moveType &lt;&gt; HMSMovementTypeShift then	//11 Dec 2018	NDL	TFS 42043 - But NOT for SHIFTs this week.....
		//make a a new copy for the creation process of the replacement to the cancelled movement
		_pxyReplaceCancelled := self.cloneMySelf( true );
		_pxyReplaceCancelled.setMyBerth( self.myBerth );
		_pxyReplaceCancelled.setMyCancelledMovement( self );
		_pxyReplaceCancelled.myNextMovement := self.myNextMovement;
		_pxyReplaceCancelled.myPreviousMovement := self.myPreviousMovement;
	endif;
	
	
	//now set the result of being cancelled on me, the current proxy of the item being cancelled. 
	if self.moveType = HMSMovementTypeArrival then	
		self.moveType := HMSMovementTypeCanceledArrival;
		
	elseif self.moveType = HMSMovementTypeShift then
		self.moveType := HMSMovementTypeCanceledShift;
		
	elseif self.moveType = HMSMovementTypeDeparture then
		self.moveType := HMSMovementTypeCanceledDepart;
		
	endif;
	
	self.myHMSVoyageData := null;
	self.myVoyageGlobal := null;	//17 Dec 2018	NDL	TFS 42583
	self.myNextMovement := null;
	self.myPreviousMovement := null;

epilog

end;</source>
        <Parameter name="_pxyReplaceCancelled" type="HMS_VoyageMovement" usage="output"/>
        <Parameter name="_woDtlForStatusChg" type="CM_WorkOrderVoyageDtl" usage="output"/>
        <Parameter name="_woPermitToClear" type="CM_WodPermitRequest" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="5b0a7bf3-08b3-455c-a6ce-73847a49af3e">
