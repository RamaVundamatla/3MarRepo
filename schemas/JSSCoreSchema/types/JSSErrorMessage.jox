    <JadeMethod name="getParameterizedText" id="14c9b251-44d9-46e2-b476-01c14e3f14c9">
        <source>getParameterizedText(pAllParameters : HugeStringArray):String;
// --------------------------------------------------------------------------------
// Created:		25 March 2002 by cnwdad2
//
// Purpose:		Returns the error text with substituted parameters.
//
// Parameters:	pAllParameters - An array of message parameters.
//
// Returns:		The parameterized error text.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.substituteParameters(pAllParameters);
end;</source>
        <Parameter name="pAllParameters" type="HugeStringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeFromGlobalConstant" id="2c9231df-485d-4e75-b11a-d38487dcb9a1">
        <updating/>
        <source>initializeFromGlobalConstant(pManagerObj:JSSServiceManagerObject; pGlobalConstantObj : GlobalConstant) updating;
// --------------------------------------------------------------------------------
// Created:		25 March 2002 by cnwdad1
//
// Purpose:		Assumes that the supplied global constant is of type Integer.
//
// *********************************************************************************
// * This method is intendd for Peer Schemas only.  Use "initializeGlobalConstant" *
// * for peer schemas.                                                             *
// *********************************************************************************
//
// Parameters:	pTheGlobalConstant - The global constant from which to initialize.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set property values.
	
	self.errorText	:=	pGlobalConstantObj.text;
	
	// Set any key values.
	
	self.errorCode	:=	pGlobalConstantObj.valueAsInteger();
	
	// Set any inverse references.
	
	self.myServiceManager	:=	pManagerObj;
end;</source>
        <Parameter name="pManagerObj" type="JSSServiceManagerObject"/>
        <Parameter name="pGlobalConstantObj" type="GlobalConstant"/>
    </JadeMethod>
    <JadeMethod name="initializeGlobalConstant" id="3fd28060-933e-4286-8c57-7a4095bed9fb">
        <updating/>
        <source>initializeGlobalConstant(pApplicationObj:JSSCoreSchema; pTheGlobalConstant : GlobalConstant) updating;
// --------------------------------------------------------------------------------
// Created:		25 March 2002 by cnwdad1
//
// Purpose:		Assumes that the supplied global constant is of type Integer.
//
// *********************************************************************************
// * This method is intendd for Packages only.  Use "initializeFromGlobalConstant" *
// * for peer schemas.                                                             *
// *********************************************************************************
//
// Parameters:	pTheGlobalConstant - The global constant from which to initialize.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set property values.
	
	self.errorText	:=	pTheGlobalConstant.text;
	
	// Set any key values.
	
	self.errorCode	:=	pTheGlobalConstant.valueAsInteger();
	
	// Set any inverse references.
	
	self.myApplication	:=	pApplicationObj;
end;</source>
        <Parameter name="pApplicationObj" type="JSSCoreSchema"/>
        <Parameter name="pTheGlobalConstant" type="GlobalConstant"/>
    </JadeMethod>
    <JadeMethod name="substituteParameters" id="76a0a61f-b46a-4c90-bc34-1426e59a4061">
        <source>substituteParameters(pAllParameters : HugeStringArray):String protected;
// --------------------------------------------------------------------------------
// Created:		25 March 2002 by cnwdad2
//
// Purpose:		Returns a new string which is self with all %n parameters
//				substituted from the values in the supplied string array.
//
// Parameters:	pAllParameters - An array of message parameters.
//
// Returns:		The parameterized error text.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	paramIndex		: Integer;
	originalMsgLen	: Integer;
	charPos			: Integer;
	copyFromPos		: Integer;
	originalMsg		: String;
	substitutedMsg	: String;
	currentChar		: Character;
	nextChar		: Character;
	
begin
	copyFromPos		:=	1;
	originalMsg		:=	self.errorText;
	originalMsgLen	:=	originalMsg.length();
	substitutedMsg	:=	null;
	
	foreach charPos in 1 to originalMsgLen do
		currentChar	:=	originalMsg[charPos];
		
		if charPos + 1 &lt;= originalMsgLen then
			nextChar	:=	originalMsg[charPos + 1];
		else
			nextChar	:=	null;
		endif;
		
		if currentChar = '%' and nextChar &gt;= '1' and nextChar &lt;= '9' then
			paramIndex		:=	nextChar.Integer - '0'.Integer;
			substitutedMsg	:=	substitutedMsg &amp; originalMsg[copyFromPos : (charPos - copyFromPos)];
			
			if paramIndex &lt;= pAllParameters.size() then
				substitutedMsg	:=	substitutedMsg &amp; pAllParameters[paramIndex].trimBlanks;
				
			endif;
			
			charPos		:=	charPos + 2;
			copyFromPos	:=	charPos;
		endif;
	endforeach;
	
	if copyFromPos &lt;= originalMsgLen then
		substitutedMsg	:=	substitutedMsg &amp; originalMsg[copyFromPos : (charPos - copyFromPos)];
	endif;
	
	return substitutedMsg;
end;</source>
        <access>protected</access>
        <Parameter name="pAllParameters" type="HugeStringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
