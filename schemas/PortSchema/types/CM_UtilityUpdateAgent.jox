	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TAXCODE_UPDATE), false, realTaxCode);
	endif;	
	
end;</source>
        <Parameter name="_pxyTaxCode" type="CM_TaxCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTaxRate" id="f9f0fc9a-1848-4fb9-a834-4e90cd529d57">
        <source>utlUpdateTaxRate(_pxyTaxRate : CM_TaxRate; _passport : CM_Passport input);
//---------------------------------------
// Created: 18 May 2006 By: cnwgd1
//---------------------------------------
vars

	expectedEdition	: Integer;
	realTaxRate	: CM_TaxRate;

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	
	_pxyTaxRate.raiseExceptionIfNotProxy(method);
	_pxyTaxRate.pxyGetRealObjectAndEdition(realTaxRate, expectedEdition);

	exclusiveLock(realTaxRate);

	if _passport.noErrors and realTaxRate.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Tax Rate', null, null);
		return;
	endif;
	

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTaxRate, true);
	endif;
	
	if _passport.noErrors then
		realTaxRate.setForUpdate(_pxyTaxRate, _passport);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTaxRate, false);
	endif;
	
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TAXRATE_UPDATE), false, realTaxRate);
	endif;	

end;</source>
        <Parameter name="_pxyTaxRate" type="CM_TaxRate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTempRange" id="3b075bee-afbb-48ef-b936-4e830f72d3fe">
        <source>utlUpdateTempRange(pProxyTempRange:CM_TempRange; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realTempRange:CM_TempRange;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
	
begin

	self.initialiseActivity();

	pProxyTempRange.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyTempRange.pxyGetRealObjectAndEdition(realTempRange, expectedEdition);
	
	if realTempRange = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TempRange.name, null, null);
		return;
	endif;

	app.myValUA.valTempRange(realTempRange, pProxyTempRange);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realTempRange);

	if _passport.noErrors and realTempRange.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'tempRange', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTempRange, true);
	endif;
	
	if _passport.noErrors then
		if realTempRange.colour &lt;&gt; pProxyTempRange.colour then
			codeChanged := true;
		endif;
		realTempRange.setForUpdate(pProxyTempRange);
	endif;

	if _passport.noErrors then
		if codeChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realTempRange.value.String  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realTempRange.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realTempRange.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realTempRange, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyTempRange" type="CM_TempRange"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTemperatureConversion" id="7882b7d5-f0ab-4270-be0f-c95752922d81">
