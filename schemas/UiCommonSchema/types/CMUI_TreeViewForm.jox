    <JadeMethod name="btnDelete_click" id="637b5c7a-c579-4a61-8a41-06f3237a8292">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(btn: Button input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.mode = self.Mode_View then
		return;//should not be enabled;
	endif;
	
	self.zDoDelete();

end;


</source>
