    <JadeMethod name="getFromLocationDescr" id="ce94b650-dade-4f31-b041-461e7e5b756c">
        <source>getFromLocationDescr() : String;
// ---------------------------------------------------------------------------
// Created:     26 October 2006 by cnwrs2
//
// Purpose:     Returns the harbour region for the berth
//05 Jun 2025 navma1 MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
// ---------------------------------------------------------------------------
vars
	tmpBerth	: HMS_Berth;
	tmpRegion	: HMS_HarbourRegion;
	str			: String;
	
begin
	// do not user prevMove here as this can be null 
	if self.isArrivalDirectFromOtherHarbor() and
	   self.myPreviousMovement &lt;&gt; null then
		return self.myPreviousMovement.getFromLocationDescr();
	else
		tmpBerth := self.getMyBerthPrevious();
		if tmpBerth = null then
			tmpRegion := app.myRoot.getSeaHarbourRegion();		//05.06.2025 navma1 #MTN-34114
		else
			tmpRegion := tmpBerth.myHarbourRegion;
		endif;
		//epr par 17492 9/7/08
		if tmpRegion &lt;&gt; null then
			str := tmpRegion.code;
		endif;
		if tmpBerth &lt;&gt; null then
			
			if (not tmpBerth.isLogicalBerth) then
				str := str &amp; ' (' &amp; tmpBerth.code &amp; ')';
			endif;
			
		endif;
		if str &lt;&gt; null then
			return str;
		endif;
	endif;
	
	return '&lt;unknown&gt;';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHarbour" id="0f86d952-f92a-4fb4-af85-d5076725e653">
