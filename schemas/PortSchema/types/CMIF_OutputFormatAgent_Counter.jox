    <JadeMethod name="createData_CapacityTable" id="7ffb9105-29a9-4f10-9d59-f742247b2d17">
        <updating/>
        <source>createData_CapacityTable(_voyage :CM_Voyage; _isActual :Boolean)updating, protected;
/*
Date		Who		Reason
05 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars

begin
	self.isActual	:= _isActual;
	
	if _isActual then
		self.createData_CapacityTableActual (_voyage);
	else
		self.createData_CapacityTableProp (_voyage);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_isActual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createData_CapacityTableActual" id="59af967c-865c-41cc-8c7f-49e79feedc4e">
        <source>createData_CapacityTableActual(_voyage :CM_Voyage) protected;
/*	

Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
06/01/2015	cnwdap1	PAR #35397 CCMS SFW 1394 Voyage Rationalisation - holds, onsite, offsite and prenoted cargo included
					Also allow for only counting selected TIs
*/
vars
	dd_headings		:DynaDictionary;
	roroStructure	:CM_ROROVoyageStructure;
	loloStructure	:CM_CellularVoyageStructure;
	deck			:CM_DeckVoyage;
	bay				:CM_BayVoyage;
	roroController	:CM_VoyageROROController;
	slotController	:CM_SlotController;
	roroRequest		:CM_RORORequest;
	slotRequest		:CM_SlotRequest;
	ti				:CM_TrackedItem;
	obj				:CM_Object;
	coll_container	:CM_KPIVoyageMoveDtlContDict;
	coll_GC			:CM_KPIVoyageMoveDtlGCDict;
	doHeading		:Boolean;
	gcStructure		:CM_GeneralCargoVoyageStructure;					// PAR #35397
	gcController	:CM_GeneralCargoController;							// PAR #35397
	holdStr 		:String;	// 22 Dec 2015	NDL	Par 36982
begin
	dd_headings 	:= self.allColumnHeadings;
	roroStructure	:= _voyage.myROROStructure;
	loloStructure	:= _voyage.myCellularVoyageStructure;
	gcStructure		:= _voyage.myGeneralCargoVoyage;					// PAR #35397
	
	if roroStructure &lt;&gt; null then
		foreach deck in roroStructure.allDecks do
			doHeading := false;
			
			foreach roroController in deck.allROROControllers do
				foreach ti in roroController.allTrackedItems do
					if not ti.myPrimaryActualLocation = roroController then
						continue;
					endif;
					if not self.allSelectedTIs.isEmpty and not self.allSelectedTIs.includes(ti) then	// PAR #35397
						continue;																		// PAR #35397
					endif;																				// PAR #35397
					
					if ti.isContainer then
						if self.createData_ContainerTI (ti.CM_Container, deck, roroController) then
							doHeading := true;
						endif;
					else
						if self.createData_GCTI (ti, deck, roroController) then
							doHeading := true;
						endif;
					endif;				
				endforeach;
			endforeach;
			
			if doHeading then
				if dd_headings [1, deck.code] = null then
					dd_headings[1, deck.code] := deck;
				endif;
			endif;
		endforeach;
	endif;
	
	if loloStructure &lt;&gt; null then
		foreach bay in loloStructure.allBayVoyagesByOrdinal do
			doHeading := false;
			
			foreach slotController in bay.allSlotControllersByOrdinal do
				foreach ti in slotController.allTrackedItems do
					if not ti.myPrimaryActualLocation = slotController then
						continue;
					endif;
					if not self.allSelectedTIs.isEmpty and not self.allSelectedTIs.includes(ti) then	// PAR #35397
						continue;																		// PAR #35397
					endif;																				// PAR #35397
					
					if ti.isContainer then
						if self.createData_ContainerTI (ti.CM_Container, bay, slotController) then
							doHeading := true;
						endif;
					else
						if self.createData_GCTI (ti, bay, slotController) then
							doHeading := true;
						endif;
					endif;				
				endforeach;		
			endforeach;
			
			if doHeading then
				if dd_headings [2, bay.id] = null then
					dd_headings[2, bay.id] := bay;
				endif;
			endif;
		endforeach;
	endif;
	
	// PAR #35397 Holds
	if gcStructure &lt;&gt; null then
		foreach gcController in gcStructure.allLocationsByHatchPlace discreteLock do
			doHeading := false;
			
			foreach ti in gcController.allTrackedItems discreteLock do
				if not ti.myPrimaryActualLocation = gcController then
					continue;
				endif;
				if not self.allSelectedTIs.isEmpty and not self.allSelectedTIs.includes(ti) then		// PAR #35397
					continue;																			// PAR #35397
				endif;																					// PAR #35397
				
				if ti.isContainer then
					if self.createData_ContainerTI(ti.CM_Container, gcController, gcController) then
						doHeading := true;
					endif;
				else
					if self.createData_GCTI(ti, gcController, gcController) then
						doHeading := true;
					endif;
				endif;
			endforeach;
			
			if doHeading then
				//22 Dec 2015	NDL	Par 36982
				holdStr := app.getErrorString(Hold) &amp; " " &amp; gcController.getID;
				if dd_headings [3, holdStr] = null then
					dd_headings[3, holdStr] := gcController;
				endif;
			endif;
		endforeach;
		
	endif;
	
	// PAR #35397 Ship Block Stack cargo
	if _voyage.myShipBlockStack &lt;&gt; null then
		foreach ti in _voyage.myShipBlockStack.allTrackedItemsById discreteLock do
			if not self.allSelectedTIs.isEmpty and not self.allSelectedTIs.includes(ti) then				// PAR #35397
				continue;																					// PAR #35397
			endif;																							// PAR #35397
			doHeading := false;
			if ti.isContainer then
				if self.createData_ContainerTI (ti.CM_Container, _voyage.myShipBlockStack, null) then
					doHeading := true;
				endif;
			else
				if self.createData_GCTI (ti, _voyage.myShipBlockStack, null) then
					doHeading := true;
				endif;
			endif;				
	
			if doHeading then
				if dd_headings [4, "Ship Block Stack"] = null then
					dd_headings[4, "Ship Block Stack"] := _voyage.myShipBlockStack;
				endif;
			endif;
		endforeach;
	endif;
	
	// PAR #35397 onsite cargo
	foreach ti in _voyage.allOnsiteTIsByIdCargoType discreteLock do
		if not self.allSelectedTIs.isEmpty and not self.allSelectedTIs.includes(ti) then				// PAR #35397
			continue;																					// PAR #35397
		endif;																							// PAR #35397
		doHeading := false;
		if ti.isContainer then
			if self.createData_ContainerTI (ti.CM_Container, _voyage, null) then
				doHeading := true;
			endif;
		else
			if self.createData_GCTI (ti, _voyage, null) then
				doHeading := true;
			endif;
		endif;				

		if doHeading then
			if dd_headings [5, TI_SITE_ONSITE_str] = null then
				dd_headings[5, TI_SITE_ONSITE_str] := _voyage;
			endif;
		endif;
	endforeach;
	// PAR #35397 Also tranship imports from this voyage onsite (that now have a voyge reference to their export voyage)
	foreach ti in _voyage.allTranshipTIsImport discreteLock where ti.isOnSite do
		if not self.allSelectedTIs.isEmpty and not self.allSelectedTIs.includes(ti) then				// PAR #35397
			continue;																					// PAR #35397
		endif;																							// PAR #35397
		doHeading := false;
		if ti.isContainer then
			if self.createData_ContainerTI (ti.CM_Container, _voyage, null) then
				doHeading := true;
			endif;
		else
			if self.createData_GCTI (ti, _voyage, null) then
				doHeading := true;
			endif;
		endif;				

		if doHeading then
			if dd_headings [5, TI_SITE_ONSITE_str] = null then
				dd_headings[5, TI_SITE_ONSITE_str] := _voyage;
			endif;
		endif;
	endforeach;
	
	
	// PAR #35397 offsite cargo
	foreach ti in _voyage.allOffsiteTIsByIdCargoType discreteLock do
		if not self.allSelectedTIs.isEmpty and not self.allSelectedTIs.includes(ti) then				// PAR #35397
			continue;																					// PAR #35397
		endif;																							// PAR #35397
		doHeading := false;
		if ti.isContainer then
			if self.createData_ContainerTI (ti.CM_Container, _voyage.myTerminal, null) then
				doHeading := true;
			endif;
		else
			if self.createData_GCTI (ti, _voyage.myTerminal, null) then
				doHeading := true;
			endif;
		endif;				

		if doHeading then
			if dd_headings [6, TI_SITE_OFFSITE_str] = null then
				dd_headings[6, TI_SITE_OFFSITE_str] := _voyage.myTerminal;
			endif;
		endif;
	endforeach;
	
	// PAR #35397 Pre Notes
	foreach ti in _voyage.allNotifiedTIsByIdCargoType discreteLock do
		if not self.allSelectedTIs.isEmpty and not self.allSelectedTIs.includes(ti) then				// PAR #35397
			continue;																					// PAR #35397
		endif;																							// PAR #35397
		doHeading := false;
		if ti.isContainer then
			if self.createData_ContainerTI (ti.CM_Container, _voyage.myVessel, null) then
				doHeading := true;
			endif;
		else
			if self.createData_GCTI (ti, _voyage.myVessel, null) then
				doHeading := true;
			endif;
		endif;				

		if doHeading then
			if dd_headings [7, "Prenotified"] = null then
				dd_headings[7, "Prenotified"] := _voyage.myVessel;
			endif;
		endif;
	endforeach;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createData_CapacityTableProp" id="cc0e8f2d-797b-494f-b9ff-17dd8d467d1e">
        <source>createData_CapacityTableProp(_voyage :CM_Voyage)protected;
/*
Date		Who		Reason
05 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	dd_headings		:DynaDictionary;
	roroStructure	:CM_ROROVoyageStructure;
	loloStructure	:CM_CellularVoyageStructure;
	deck			:CM_DeckVoyage;
	bay				:CM_BayVoyage;
	roroController	:CM_VoyageROROController;
	slotController	:CM_SlotController;
	roroRequest		:CM_RORORequest;
	slotRequest		:CM_SlotRequest;
	ti				:CM_TrackedItem;
	obj				:CM_Object;
	coll_container	:CM_KPIVoyageMoveDtlContDict;
	coll_GC			:CM_KPIVoyageMoveDtlGCDict;
	doHeading		:Boolean;
begin
	dd_headings 	:= self.allColumnHeadings;
	roroStructure	:= _voyage.myROROStructure;
	loloStructure	:= _voyage.myCellularVoyageStructure;
	
	if roroStructure &lt;&gt; null then
		foreach deck in roroStructure.allDecks do
			doHeading := false;
			
			foreach roroController in deck.allROROControllers do
				// need to include all Remain on Board Cargo with Unknown transit status as these will not have a request
				foreach ti in roroController.allTrackedItems do
					if ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD or ti.getTransitStatus &lt;&gt;  TI_TransitStatusNull then
						// there will be a request so we will process this ti in createData_Request
						continue;
					endif;
					
					if not ti.myPrimaryActualLocation = roroController then
						continue;
					endif;
					
					if ti.isContainer then
						if self.createData_ContainerTI (ti.CM_Container, deck, roroController) then
							doHeading := true;
						endif;
					else
						if self.createData_GCTI (ti, deck, roroController) then
							doHeading := true;
						endif;
					endif;				
				endforeach;
				// in proposed mode we are only interested in load requests as discharges will be discharged :-)
				if self.createData_Request (roroController.myRORORequestLoad, deck) then
					doHeading := true;
				endif;				
			endforeach;
			
			if doHeading then
				if dd_headings [1, deck.code] = null then
					dd_headings[1, deck.code] := deck;
				endif;
			endif;
		endforeach;
	endif;
	
	if loloStructure &lt;&gt; null then
		foreach bay in loloStructure.allBayVoyagesByOrdinal do
			doHeading := false;
			
			foreach slotController in bay.allSlotControllersByOrdinal do
				foreach ti in slotController.allTrackedItems do
					if ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD or ti.getTransitStatus &lt;&gt;  TI_TransitStatusNull then
						// there will be a request so we will process this ti in createData_Request
						continue;
					endif;
					
					if not ti.myPrimaryActualLocation = slotController then
						continue;
					endif;
					
					if ti.isContainer then
						if self.createData_ContainerTI (ti.CM_Container, bay, slotController) then
							doHeading := true;
						endif;
					else
						if self.createData_GCTI (ti, bay, slotController) then
							doHeading := true;
						endif;
					endif;				
				endforeach;	
				// in proposed mode we are only interested in load requests as discharges will be discharged :-)
				if self.createData_Request (slotController.mySlotRequestLoad, bay) then
					doHeading := true;
				endif;				
			endforeach;
			
			if doHeading then
				if dd_headings [2, bay.id] = null then
					dd_headings[2, bay.id] := bay;
				endif;
			endif;
		endforeach;
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createData_ContainerRequest" id="123c3ef2-0308-49c7-a934-39cab1f6c04d">
        <source>createData_ContainerRequest(_request :CM_Request; _ti :CM_Container;_obj :Object) protected;
/*
Date		Who		Reason
05 Sep 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
03/09/2012	cnwcs5	par 30290
*/
vars
	dd				:DynaDictionary;
	array			:ObjectArray;
	length, index	:Integer;
	coll			:CM_TISet;
	gotException	:Boolean;
begin	
	on Exception do app.handleDeletedObject (exception, _ti, gotException);
	
	dd 		:= self.allData_Containers;
	length	:= self.getContainerLength (_ti);
	
	if gotException or length = -1 then		// par 30290 Sep 2012
		return;
	endif;
		
	array	:= dd.getAtKey (length, _obj).ObjectArray;
		
	if array = null then
		create array transient;
		array[self.getMaxIndex]	:= null;
		
		dd.putAtKey (length, _obj, array); 
	endif;
	
	index := self.getIndexForRequest (_request, _ti);
	
	coll := array [index].CM_TISet;
		
	if coll = null then
		create coll transient;
		array [index] := coll;
		
		self.allObjectsToGarbageCollect.add (coll);
	endif;
		
	coll.add (_ti);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_request" type="CM_Request"/>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="createData_ContainerTI" id="f48afb2e-2a88-4562-a668-4c4abc85da8f">
        <source>createData_ContainerTI(_ti :CM_Container;_obj :Object; _lc :CM_VoyageController):Boolean protected;
/*
Date		Who		Reason
05 Sep 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
03/09/2012	cnwcs5	par 30290 
*/
vars
	dd				:DynaDictionary;
	array			:ObjectArray;
	length, index	:Integer;
	coll			:CM_TISet;
	gotException	:Boolean;
	loadRequest,
	dischargeRequest	:CM_Request;
begin	
	on Exception do app.handleDeletedObject (exception, _ti, gotException);
	
	dd 		:= self.allData_Containers;
	length	:= self.getContainerLength (_ti);
	
	if gotException or length = -1 then		// par 30290 Sep 2012
		return false;
	endif;
		
	array	:= dd.getAtKey (length, _obj).ObjectArray;
		
	if array = null then
		create array transient;
		array[self.getMaxIndex]	:= null;
		
		dd.putAtKey (length, _obj, array); 
	endif;
	
	index := self.getIndexForTrackedItem (_ti, _lc);
	
	if index = null then 
		return false;
	endif;
	
	coll := array [index].CM_TISet;
		
	if coll = null then
		create coll transient;
		array [index] := coll;
		
		self.allObjectsToGarbageCollect.add (coll);
	endif;
		
	// I don't know why we need to handle duplicates but we do 
	coll.addNoDuplicates (_ti, false);
	
	return true;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_lc" type="CM_VoyageController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createData_GCRequest" id="85f3df7b-f9e3-4caa-abab-1b76e791ccb7">
        <source>createData_GCRequest(_request :CM_Request; _ti :CM_TrackedItem;_obj :Object) protected;
/*
Date		Who		Reason
05 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	dd				:DynaDictionary;
	cargoType		:CM_CargoType;
	array			:ObjectArray;
	index			:Integer;
	coll			:CM_TISet;
	gotException	:Boolean;
begin	
	on Exception do app.handleDeletedObject (exception, _ti, gotException);
	
	dd 			:= self.allData_GeneralCargo;
	cargoType	:= _ti.myCargoType;
	
	if gotException then
		return;
	endif;
		
	array	:= dd.getAtKey (cargoType, _obj).ObjectArray;
		
	if array = null then
		create array transient;
		array[self.getMaxIndex]	:= null;
		
		dd.putAtKey (cargoType, _obj, array);
	endif;
	
	index := self.getIndexForRequest (_request, _ti);
	
	coll := array [index].CM_TISet;
		
	if coll = null then
		create coll transient;
		array [index] := coll;
		
		self.allObjectsToGarbageCollect.add (coll);
	endif;
		
	coll.add (_ti);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_request" type="CM_Request"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="createData_GCTI" id="8e5d45ba-4702-41e3-a715-5c25e9927d0a">
        <source>createData_GCTI(_ti :CM_TrackedItem;_obj :Object; _lc :CM_VoyageController):Boolean protected;
/*
Date		Who		Reason
05 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	dd				:DynaDictionary;
	cargoType		:CM_CargoType;
	array			:ObjectArray;
	index			:Integer;
	coll			:CM_TISet;
	gotException	:Boolean;
begin	
	on Exception do app.handleDeletedObject (exception, _ti, gotException);
	
	dd 			:= self.allData_GeneralCargo;
	cargoType	:= _ti.myCargoType;
	
	if gotException then
		return false;
	endif;
		
	array	:= dd.getAtKey (cargoType, _obj).ObjectArray;
		
	if array = null then
		create array transient;
		array[self.getMaxIndex]	:= null;
		
		dd.putAtKey (cargoType, _obj, array);
	endif;
	
	index := self.getIndexForTrackedItem (_ti, _lc);
	
	if index = null then
		return false;
	endif;
	
	coll := array [index].CM_TISet;
		
	if coll = null then
		create coll transient;
		array [index] := coll;
		
		self.allObjectsToGarbageCollect.add (coll);
	endif;
		
	coll.add (_ti);
	
	return true;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_lc" type="CM_VoyageController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createData_Request" id="9e3d30a8-9b30-44e4-8a22-fc32704a3879">
        <source>createData_Request(_request :CM_Request; _obj :Object):Boolean protected;
/*
Date		Who		Reason
07 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	result	:Boolean;
	coll	:CM_TIArray;
	ti		:CM_TrackedItem;
begin
	if _request = null then
		return false;
	endif;
	
	if _request.isKindOf (CM_VoyageRequest) and _request.CM_VoyageRequest.isBackEndRequest () then					
		return false;
	endif;
	
	if _request.isKindOf (CM_SlotRequest) and _request.CM_SlotRequest.isBackend then					
		return false;
	endif;
	
	create coll transient;
	
	_request.getAllTrackedItems (coll);

	foreach ti in coll do
		if ti &lt;&gt; null then
			if ti.isContainer then
				self.createData_ContainerRequest(_request, ti.CM_Container, _obj);
			else
				self.createData_GCRequest(_request, ti, _obj);
			endif;
			
			result := true;
		endif;
	endforeach;
	
	return result;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_request" type="CM_Request"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayCapacityTable" id="a75b4727-2a9f-4e23-a3d5-ca24887b609c">
        <updating/>
        <source>displayCapacityTable(_voyage :CM_Voyage; _table :Table input; _isActual :Boolean; 
						_contCount, _contTEU, _gcCount, _gcArea, _gcLM, _gcQty, _gcVolume, _gcWeight :Boolean;
						_cargoTypes :Collection)updating;
/*
Date		Who		Reason
09 Aug 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
03/09/2012	cnwcs5	par 30292 - use terminal config options for 30, 45, 53
30/01/2015	cnwdap1	PAR #35397 CCMS SFW 1394 Allow Cargo Coutner to run without enquiring on Containers
*/
vars
	table		:Table;
	terminal	:CM_Terminal;
	showCont	:Boolean;					// PAR #35397
begin
	table := self.myTable;
	
	if table &lt;&gt; null and table &lt;&gt; _table then
		// can't change table
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Cannot change KPI table');
	endif;
	
	self.myTable 	:= _table;
	self.myVoyage	:= _voyage;
	terminal		:= _voyage.getMyTerminal;
	
	self.allCargoTypes.clear;
	_cargoTypes.copy (self.allCargoTypes);
	if self.allCargoTypes.includes(app.myRoot.allCargoTypesById[TI_CargoType_Container]) then	// PAR #35397
		showCont := true;																		// PAR #35397
	endif;																						// PAR #35397
	
	self.mode		:= self.Mode_CapacityTable;
	self.isActual	:= _isActual;
	
	self.is30Included	:= terminal.getConfig (Is30IncludedForReports).Integer;	// par 30290 Sept 2012
	self.is45Included	:= terminal.getConfig (Is45IncludedForReports).Integer;	// par 30290 Sept 2012
	self.is53Included	:= terminal.getConfig (Is53IncludedForReports).Integer;	// par 30290 Sept 2012
	
	self.clearTable;
	self.init_CapacityTable (_table);
	self.setup_CapacityTable ();
	self.createData_CapacityTable (_voyage, _isActual);
	self.displayHeadings_CapacityTable (_table);
	self.displayData_Usage (_table, _isActual);
	if showCont then																			// PAR #35397
		self.displayData_Containers (_table, self.Capacity_RowDeck, _contCount, _contTEU, true);
	endif;																						// PAR #35397
	self.displayData_GC (_table, self.Capacity_RowDeck, _gcCount, _gcArea, _gcLM, _gcQty, _gcVolume, _gcWeight, true, _cargoTypes);
epilog
	// membership of these collections is transient collection - they need to be deleted
	self.allData_Containers.purge;
	self.allData_GeneralCargo.purge;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_isActual" type="Boolean"/>
        <Parameter name="_contCount" type="Boolean"/>
        <Parameter name="_contTEU" type="Boolean"/>
        <Parameter name="_gcCount" type="Boolean"/>
        <Parameter name="_gcArea" type="Boolean"/>
        <Parameter name="_gcLM" type="Boolean"/>
        <Parameter name="_gcQty" type="Boolean"/>
        <Parameter name="_gcVolume" type="Boolean"/>
        <Parameter name="_gcWeight" type="Boolean"/>
        <Parameter name="_cargoTypes" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="displayData_Usage" id="4db96239-1da2-4131-8461-733c13fd7a78">
        <source>displayData_Usage(_table :Table input; _isActual :Boolean) protected;
/*
Return Value:		

Date		Who		Reason
15 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
06/01/2015	cnwdap1	PAR #35397 CCMS SFW 1394 Voyage Rationalisation
*/
vars
	coll	:DynaDictionary;
	obj		:Object;
	bay		:CM_BayVoyage;
	deck	:CM_DeckVoyage;
	col		:Integer;
	availArea, availLM, availVolume, availTEU, 
	usedArea, usedLM, usedVolume, usedTEU, 
	leftArea, leftLM, leftVolume, leftTEU		:Decimal[12,2];
begin
	coll := self.allColumnHeadings;
	
	foreach obj in coll do
		col	:= self.findColumnForObject (_table, self.Capacity_RowDeck, obj);
		
		if col = null then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Unable to find Deck/Bay in table');
		endif;
		
		if obj.isKindOf (CM_DeckVoyage) then
			deck := obj.CM_DeckVoyage;
			// Area
			availArea	:= deck.totalArea;
			availLM		:= deck.totalLM;
			availVolume	:= deck.totalVolume;
			
			if _isActual then
				deck.getKPIUsed (ShpDisplayMode_Actual, usedVolume, usedArea, usedLM);
			else	
				deck.getKPIUsed (ShpDisplayMode_Proposed, usedVolume, usedArea, usedLM);
			endif;	
			
			leftArea	:= availArea - usedArea;
			leftLM		:= availLM - usedLM;
			leftVolume	:= availVolume - usedVolume;

			_table.accessCell (self.Capacity_RowArea, col + self.Offset_Used).text	:= usedArea.asStringJMT;
			_table.accessCell (self.Capacity_RowArea, col + self.Offset_Left).text	:= leftArea.asStringJMT;
			
			_table.accessCell (self.Capacity_RowLM, col + self.Offset_Used).text	:= usedLM.asStringJMT;
			_table.accessCell (self.Capacity_RowLM, col + self.Offset_Left).text	:= leftLM.asStringJMT;

			_table.accessCell (self.Capacity_RowVolume, col + self.Offset_Used).text	:= usedVolume.asStringJMT;
			_table.accessCell (self.Capacity_RowVolume, col + self.Offset_Left).text	:= leftVolume.asStringJMT;
			
		elseif obj.isKindOf(CM_GeneralCargoVoyageStructure) then	// Holds cargo 				// PAR #35397
		elseif obj.isKindOf(CM_VoyageController) then				// Ship Block Stack cargo 	// PAR #35397
		elseif obj.isKindOf(CM_Voyage) then							// Onsite cargo 			// PAR #35397
		elseif obj.isKindOf(CM_Terminal) then						// Offsite cargo 			// PAR #35397
		elseif obj.isKindOf(CM_Vessel) then							// Prenotified cargo		// PAR #35397
		
		else
			bay := obj.CM_BayVoyage;
			
			// TEU
			if _isActual then
				bay.getKPIUsed (ShpDisplayMode_Actual, availTEU, usedTEU);
			else
				bay.getKPIUsed (ShpDisplayMode_Proposed, availTEU, usedTEU);
			endif;
			
			leftTEU		:= availTEU - usedTEU;
			
			_table.accessCell (self.Capacity_RowTEU, col + self.Offset_Used).text	:= usedTEU.asStringJMT;
			_table.accessCell (self.Capacity_RowTEU, col + self.Offset_Left).text	:= leftTEU.asStringJMT;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_isActual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayHeadings_CapacityTable" id="f25a74c0-c294-416f-9e37-dbdfd7cc3a2f">
        <source>displayHeadings_CapacityTable(_table :Table input)protected;
/*	
Purpose:	Display all required column headings

Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
15/11/2011		cnwcs5	Leaking iterator
06/01/2015	cnwdap1	PAR #35397 CCMS SFW 1394 - cater for onsite, offsite and prenoted cargo
*/
constants
	
vars
	strTotal, strLoad, strTS, strDischarge, strSOB, strDLR, strROB, 
	strUsed, strLeft, 
	strExport, strImport			:String;
	coll			:Collection;
	iter			:Iterator;
	obj				:Object;
	key1, type		:Integer;
	key2, desc	:String;
	col, offset_SubTotal	:Integer;
	isOnSite, isOffSite, isPrenote : Boolean;			// PAR #35397
	offset_Discharge		:Integer;					// PAR #35397
	offset_DischargeTS		:Integer;					// PAR #35397
	offset_Load				:Integer;					// PAR #35397
	offset_LoadTS			:Integer;					// PAR #35397
	offset_DLR				:Integer;					// PAR #35397
	offset_SOB				:Integer;					// PAR #35397
	offset_ROB				:Integer;					// PAR #35397
begin
	offset_SubTotal	:= self.getOffsetSubTotal;
	
	strTotal		:= app.getErrorString (Total);
	strLoad			:= app.getErrorString (VoyJob_Load);
	strDischarge	:= app.getErrorString (VoyJob_Discharge);
	strSOB			:= app.getErrorString (VoyJob_SOB);
	strDLR			:= app.getErrorString (VoyJob_DLR );
	strROB			:= 'ROB';
	strTS			:= app.getErrorString (VoyJob_Tranship);
	strUsed			:= app.getErrorString (Capacity_USED);
	strLeft			:= app.getErrorString (Capacity_LEFT);
	strExport		:= app.getErrorString (Export);
	strImport		:= app.getErrorString (Import);
	// add columns for cargo types
	_table.columns 		:= 1;
	_table.rows			:= self.Capacity_RowImex2;
	_table.fixedRows	:= self.Capacity_RowImex2;
	
	_table.accessCell (self.Capacity_RowDeck, 1).text	:= app.getErrorString(Deck) &amp; ' &gt;';			_table.accessRow (self.Capacity_RowDeck).fontBold := true;
	_table.accessCell (self.Capacity_RowArea, 1).text	:= app.getErrorString(Area_m2) &amp; ' &gt;';		_table.accessedCell.fontBold := true;
	_table.accessCell (self.Capacity_RowLM, 1).text	:= app.getErrorString(LM) &amp; ' &gt;';			_table.accessedCell.fontBold := true;
	_table.accessCell (self.Capacity_RowVolume, 1).text	:= app.getErrorString(Volume_m3) &amp; ' &gt;';	_table.accessedCell.fontBold := true;
	_table.accessCell (self.Capacity_RowTEU, 1).text	:= app.getErrorString(TeuHeading) &amp; ' &gt;';	_table.accessedCell.fontBold := true;
	_table.accessRow (self.Capacity_RowImex1).fontBold := true;
	_table.accessCell (self.Capacity_RowImex2, 1).text	:= app.getErrorString(IMEX) &amp; ' &gt;';			_table.accessRow (self.Capacity_RowImex2).fontBold := true;

	
	coll := self.allColumnHeadings;
	iter := coll.createIterator;
	
	while iter.next (obj) do
		col := _table.columns;
		
		isOnSite 			:= false;																			// PAR #35397
		isOffSite 			:= false;																			// PAR #35397
		isPrenote 			:= false;																			// PAR #35397
		offset_SubTotal		:= self.getOffsetSubTotal;															// PAR #35397
		offset_Discharge 	:= self.Offset_Discharge;															// PAR #35397
		offset_DischargeTS	:= self.Offset_DischargeTS;															// PAR #35397
		offset_Load			:= self.Offset_Load;																// PAR #35397
		offset_LoadTS		:= self.Offset_LoadTS;																// PAR #35397
		offset_DLR			:= self.Offset_DLR;																	// PAR #35397
		offset_SOB			:= self.Offset_SOB;																	// PAR #35397
		offset_ROB			:= self.Offset_ROB;																	// PAR #35397
		
		iter.getCurrentKeys (key1, key2);
				
		if key1 &lt;&gt; type or key2 &lt;&gt; desc then
			self.addSplitterColumn (_table, self.Capacity_RowDeck);
			col := col + 1;
			
			// new bay or deck - add new columns for it
			if obj.isKindOf(CM_Voyage) then																	// PAR #35397
				offset_SubTotal := offset_SubTotal - 2;		// no SOB or ROB 								// PAR #35397
				isOnSite := true;																			// PAR #35397
			elseif obj.isKindOf(CM_Terminal) then															// PAR #35397
				offset_SubTotal := offset_SubTotal - 5;		// no ROB, SOB, DLR, LOAD or T/S LOAD 			// PAR #35397
				isOffSite := true;																			// PAR #35397
			elseif obj.isKindOf(CM_Vessel) then																// PAR #35397
				offset_SubTotal := offset_SubTotal - 6;		// no ROB, SOB, DLR, DISCHARGE, T/S DISCHARGE,	// PAR #35397
				offset_Load := offset_Load - 2;				// or Load T/S									// PAR #35397
				offset_LoadTS := offset_LoadTS - 2;															// PAR #35397
				isPrenote := true;																			// PAR #35397
			endif;																							// PAR #35397
			_table.columns := col + offset_SubTotal + 1;
			// col is the start for our headings
			col := col + 1;
			
			// add deck/bay heading
			if obj.isKindOf (CM_DeckVoyage) then
				_table.accessCell (self.Capacity_RowDeck, col).text 	:= key2;
			elseif obj.isKindOf(CM_GeneralCargoVoyageStructure) then										// PAR #35397
				_table.accessCell (self.Capacity_RowDeck, col).text	:= key2;								// PAR #35397
			elseif obj.isKindOf(CM_VoyageController) then													// PAR #35397
				_table.accessCell (self.Capacity_RowDeck, col).text	:= key2;								// PAR #35397
			elseif obj.isKindOf(CM_Voyage) then																// PAR #35397
				_table.accessCell (self.Capacity_RowDeck, col).text	:= TI_SITE_ONSITE_str;					// PAR #35397
			elseif obj.isKindOf(CM_Terminal) then															// PAR #35397
				_table.accessCell (self.Capacity_RowDeck, col).text	:= TI_SITE_OFFSITE_str;					// PAR #35397
			elseif obj.isKindOf(CM_Vessel) then																// PAR #35397
				_table.accessCell (self.Capacity_RowDeck, col).text	:= "Prenotified";						// PAR #35397
			else
				_table.accessCell (self.Capacity_RowDeck, col).text	:= app.getErrorString1 (Bay_And_ID, obj.CM_Bay.id);
			endif;
			
			_table.accessedCell.itemObject 		:= obj;
			_table.accessedCell.mergeCells		:= Table.MergeCells_Merge;
			_table.accessedCell.gridRight		:= false;	// because there will be a splitter
			
			_table.accessColumn (col).itemObject := obj;
			
			if not isOnSite and not isOffSite and not isPrenote then												// PAR #35397
				// add headings for used/left
				_table.accessCell (2, col).text								:= strUsed; 
				_table.accessedCell.mergeCells								:= Table.MergeCells_Merge;
				_table.accessedCell.fontBold								:= true;
				_table.accessCell (self.Capacity_RowArea, col).mergeCells	:= Table.MergeCells_Merge;
				_table.accessedCell.alignment								:= Table.Alignment_Center;
				_table.accessCell (self.Capacity_RowLM, col).mergeCells		:= Table.MergeCells_Merge;
				_table.accessedCell.alignment								:= Table.Alignment_Center;
				_table.accessCell (self.Capacity_RowVolume, col).mergeCells	:= Table.MergeCells_Merge;
				_table.accessedCell.alignment								:= Table.Alignment_Center;
				_table.accessCell (self.Capacity_RowTEU, col).mergeCells	:= Table.MergeCells_Merge;
				_table.accessedCell.alignment								:= Table.Alignment_Center;
	
				_table.accessCell (2, col+3).text							:= strLeft; 
				_table.accessedCell.mergeCells								:= Table.MergeCells_Merge;
				_table.accessedCell.fontBold								:= true;
				_table.accessedCell.gridRight								:= false;	// because there will be a splitter
				_table.accessCell (self.Capacity_RowArea, col+3).mergeCells	:= Table.MergeCells_Merge;
				_table.accessedCell.alignment								:= Table.Alignment_Center;
				_table.accessedCell.gridRight								:= false;	// because there will be a splitter
				_table.accessCell (self.Capacity_RowLM, col+3).mergeCells	:= Table.MergeCells_Merge;
				_table.accessedCell.alignment								:= Table.Alignment_Center;
				_table.accessedCell.gridRight								:= false;	// because there will be a splitter
				_table.accessCell (self.Capacity_RowVolume, col+3).mergeCells	:= Table.MergeCells_Merge;
				_table.accessedCell.alignment								:= Table.Alignment_Center;
				_table.accessedCell.gridRight								:= false;	// because there will be a splitter
				_table.accessCell (self.Capacity_RowTEU, col+3).mergeCells	:= Table.MergeCells_Merge;
				_table.accessedCell.alignment								:= Table.Alignment_Center;
				_table.accessedCell.gridRight								:= false;	// because there will be a splitter
			endif;																									// PAR #35397

			// add headings for dicharge/load
			if not isPrenote then																					// PAR #35397
				//_table.accessCell (self.Capacity_RowImex1, col + self.Offset_Discharge).text	:= 	strDischarge;	// PAR #35397
				_table.accessCell (self.Capacity_RowImex1, col + offset_Discharge).text	:= 	strDischarge;			// PAR #35397
				_table.accessedCell.mergeCells			:= Table.MergeCells_Merge;
				//_table.accessColumn (col + self.Offset_Discharge).alignment	:= Table.Alignment_Center;			// PAR #35397
				_table.accessColumn (col + offset_Discharge).alignment	:= Table.Alignment_Center;					// PAR #35397
			endif;																									// PAR #35397
			
			if not isOffSite then																					// PAR #35397
				//_table.accessCell (self.Capacity_RowImex1, col + self.Offset_Load).text	:= 	strLoad;			// PAR #35397
				_table.accessCell (self.Capacity_RowImex1, col + offset_Load).text	:= 	strLoad;					// PAR #35397
				_table.accessedCell.mergeCells			:= Table.MergeCells_Merge;
				//_table.accessColumn (col + self.Offset_Load).alignment	:= Table.Alignment_Center;				// PAR #35397
				_table.accessColumn (col + offset_Load).alignment	:= Table.Alignment_Center;						// PAR #35397
			endif;																									// PAR #35397
			
			if not isOffSite and not isPrenote then																	// PAR #35397
				//_table.accessCell (self.Capacity_RowImex1, col + self.Offset_DLR).mergeCells	:= Table.MergeCells_NotAvailable;	// PAR #35397
				_table.accessCell (self.Capacity_RowImex1, col + offset_DLR).mergeCells	:= Table.MergeCells_NotAvailable;			// PAR #35397
			endif;																									// PAR #35397

			// add headings for export/import/TS/total
			if not isPrenote then																					// PAR #35397
				//_table.accessCell (self.Capacity_RowImex2, col + self.Offset_Discharge).text	:= 	strImport;		// PAR #35397
				_table.accessCell (self.Capacity_RowImex2, col + offset_Discharge).text	:= 	strImport;				// PAR #35397
				_table.accessedCell.mergeCells			:= Table.MergeCells_Merge;
				//_table.accessColumn (col + self.Offset_Discharge).alignment	:= Table.Alignment_Center;			// PAR #35397
				_table.accessColumn (col + offset_Discharge).alignment	:= Table.Alignment_Center;					// PAR #35397
				
				//_table.accessCell (self.Capacity_RowImex2, col + self.Offset_DischargeTS).text	:= 	strTS;		// PAR #35397
				_table.accessCell (self.Capacity_RowImex2, col + offset_DischargeTS).text	:= 	strTS;				// PAR #35397
				_table.accessedCell.mergeCells			:= Table.MergeCells_Merge;
				//_table.accessColumn (col + self.Offset_DischargeTS).alignment	:= Table.Alignment_Center;			// PAR #35397
				_table.accessColumn (col + offset_DischargeTS).alignment	:= Table.Alignment_Center;				// PAR #35397
			endif;																									// PAR #35397
			
			if not isOffSite then																					// PAR #35397
				//_table.accessCell (self.Capacity_RowImex2, col + self.Offset_Load).text		:= 	strExport;		// PAR #35397
				_table.accessCell (self.Capacity_RowImex2, col + offset_Load).text		:= 	strExport;				// PAR #35397
				_table.accessedCell.mergeCells			:= Table.MergeCells_Merge;
				//_table.accessColumn (col + self.Offset_Load).alignment	:= Table.Alignment_Center;				// PAR #35397
				_table.accessColumn (col + offset_Load).alignment	:= Table.Alignment_Center;						// PAR #35397
			endif;																									// PAR #35397
				
			if not isOffSite and not isPrenote then																	// PAR #35397
				//_table.accessCell (self.Capacity_RowImex2, col + self.Offset_LoadTS).text		:= 	strTS;			// PAR #35397
				_table.accessCell (self.Capacity_RowImex2, col + offset_LoadTS).text		:= 	strTS;				// PAR #35397
				_table.accessedCell.mergeCells			:= Table.MergeCells_Merge;
				//_table.accessColumn (col + self.Offset_LoadTS).alignment	:= Table.Alignment_Center;				// PAR #35397
				_table.accessColumn (col + offset_LoadTS).alignment	:= Table.Alignment_Center;						// PAR #35397
				//_table.accessCell (self.Capacity_RowImex2, col + self.Offset_DLR).text		:= 	strDLR;			// PAR #35397
				_table.accessCell (self.Capacity_RowImex2, col + offset_DLR).text		:= 	strDLR;					// PAR #35397
				_table.accessedCell.mergeCells			:= Table.MergeCells_Merge;
				//_table.accessColumn (col + self.Offset_DLR).alignment	:= Table.Alignment_Center;					// PAR #35397
				_table.accessColumn (col + offset_DLR).alignment	:= Table.Alignment_Center;						// PAR #35397
			endif;																									// PAR #35397
			
			if not isOffSite and not isPrenote and not isOnSite then												// PAR #35397
				//_table.accessCell (self.Capacity_RowImex2, col + self.Offset_SOB).text		:= 	strSOB;			// PAR #35397
				_table.accessCell (self.Capacity_RowImex2, col + offset_SOB).text		:= 	strSOB;					// PAR #35397
				_table.accessedCell.mergeCells			:= Table.MergeCells_Merge;
				//_table.accessColumn (col + self.Offset_SOB).alignment	:= Table.Alignment_Center;					// PAR #35397
				_table.accessColumn (col + offset_SOB).alignment	:= Table.Alignment_Center;						// PAR #35397
				
				//_table.accessCell (self.Capacity_RowImex2, col + self.Offset_ROB).text		:= 	strROB;			// PAR #35397
				_table.accessCell (self.Capacity_RowImex2, col + offset_ROB).text		:= 	strROB;					// PAR #35397
				_table.accessedCell.mergeCells			:= Table.MergeCells_Merge;
				//_table.accessColumn (col + self.Offset_ROB).alignment	:= Table.Alignment_Center;					// PAR #35397
				_table.accessColumn (col + offset_ROB).alignment	:= Table.Alignment_Center;						// PAR #35397
			endif;																									// PAR #35397

			// TOTAL
			_table.accessCell (self.Capacity_RowImex2, col + offset_SubTotal).text		:= 	strTotal;
			_table.accessColumn (col + offset_SubTotal).alignment	:= Table.Alignment_Center;
			
		endif;
		
		type 	:= key1;
		desc	:= key2;
	endwhile;
	
	// now add column for Grand Total
	self.addSplitterColumn (_table, self.Capacity_RowDeck);

	col 			:= _table.columns;
	col				:= col + 1;
	_table.columns	:= col;
	
	_table.accessCell (1, col).text	:= 	strTotal.toUpper;
	_table.accessedCell.mergeCells	:= Table.MergeCells_NotAvailable;
	
	_table.accessCell (2, col).mergeCells						:= Table.MergeCells_NotAvailable;
	_table.accessCell (self.Capacity_RowArea, col).mergeCells	:= Table.MergeCells_NotAvailable;
	_table.accessCell (self.Capacity_RowLM, col).mergeCells		:= Table.MergeCells_NotAvailable;
	_table.accessCell (self.Capacity_RowVolume, col).mergeCells	:= Table.MergeCells_NotAvailable;
	_table.accessCell (self.Capacity_RowTEU, col).mergeCells	:= Table.MergeCells_NotAvailable;
	_table.accessColumn (col).alignment							:= Table.Alignment_Center;
		
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItems" id="8c7db777-0358-42c4-ac3c-ac6b2b8d01ee">
        <source>getAllTrackedItems(_coll :Collection input);
/*

Date		Who		Reason
30 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	voyage			:CM_Voyage;
	kpi				:CM_KPIVoyageEntity;
	ti				:CM_TrackedItem;
	gotException	:Boolean;
begin
	// get all tracked items that are part of voyage and pass to summary form
	voyage := self.myVoyage;
	
	if voyage = null then
		return;
	endif;
	
	kpi := voyage.getKPI;
	if kpi = null then		// 10/10/2011 cnwmh5 #28410 
		return;
	endif;
	
	on Exception do app.handleDeletedObject (exception, ti, gotException);
	
	// may be limited by cargo type
	foreach ti in kpi.allTrackedItems do 
		if self.allCargoTypes.includes (ti.myCargoType) or ti.myCargoType.id = TI_CargoType_Container then
			_coll.add (ti);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
