    <JadeMethod name="doMnuContextViewTxnsClick" id="4b2b67bb-2d0a-4baf-88c4-47379952400f">
        <updating/>
        <source>doMnuContextViewTxnsClick() updating, protected;
// Feb 2012 CCMS 1262 transaction enquiry, invoice list and line to show transactions for the selected invoice or invoice lines
// This is called for both INV_ListInvoices (invoices) and INV_ListLines (invoice lines)
vars
	int,
	mode	: Integer;
	first	: Boolean;
	str		: String;
	form	: CMUI_TransactionEnquiry;
	ia		: IntegerArray;
	coll,
	lines,
	oa		: ObjectArray;
	obj		: Object;
	invoice	: CM_Invoice;
	line	: CM_InvoiceLine;
begin
	create oa transient;
	self.tblData.allSelectedObjects.copy(oa);
	if oa.size = 0 then
		return;
	endif;
	
	create ia transient;
	ia[1] := 0;
	ia[2] := 0;
	ia[3] := 0;
	ia[4] := 0;		//21 Nov 2019	NDL	TFS 47650
	create lines transient;
	create coll transient;
	// get all invoice lines which have transactions of any type
	// ia is to detect mixed transaction types
	foreach obj in oa do
		if obj.isKindOf(CM_Invoice) then
			invoice := obj.CM_Invoice;
			foreach line in invoice.invoiceLines do
				if line.myTransactionTI &lt;&gt; null then
					ia[1] := 1;
					lines.add(line);
				elseif line.myTransactionEvent &lt;&gt; null then
					ia[2] := 1;
					lines.add(line);
				elseif line.myTransactionHMS &lt;&gt; null then
					ia[3] := 1;
					lines.add(line);
				elseif line.myTransactionBOL &lt;&gt; null then		//21 Nov 2019	NDL	TFS 47650
					ia[4] := 1;
					lines.add(line);
				endif;
			endforeach;
		elseif obj.isKindOf(CM_InvoiceLine) then
			line := obj.CM_InvoiceLine;
			if line.myTransactionTI &lt;&gt; null then
				ia[1] := 1;
				lines.add(line);
			elseif line.myTransactionEvent &lt;&gt; null then
				ia[2] := 1;
				lines.add(line);
			elseif line.myTransactionHMS &lt;&gt; null then
				ia[3] := 1;
				lines.add(line);
			elseif line.myTransactionBOL &lt;&gt; null then	//21 Nov 2019	NDL	TFS 47650
				ia[4] := 1;
				lines.add(line);
			endif;
		endif;
	endforeach;
	
	int := ia[1] + ia[2] + ia[3] + ia[4];
	if int &gt; 1 then
		app.msgBox('Invoice lines have mixed transaction types, unable to enquire on them', app.getErrorString(Error), 0);
		return;
	endif;
	
	ia.clear();
	// ia is now the invoice numbers
	foreach obj in lines do
		line := obj.CM_InvoiceLine;
		if line.myTransactionTI &lt;&gt; null then
			if not ia.includes(line.invoice.sequenceNum) then
				ia.add(line.invoice.sequenceNum);
			endif;
			mode := CMUI_TransactionEnquiry.Mode_Cargo_Transaction_Enquiry;
			coll.add(line.myTransactionTI);
		elseif line.myTransactionEvent &lt;&gt; null then
			if not ia.includes(line.invoice.sequenceNum) then
				ia.add(line.invoice.sequenceNum);
			endif;
			mode := CMUI_TransactionEnquiry.Mode_Event_Transaction_Enquiry;
			coll.add(line.myTransactionEvent);
		elseif line.myTransactionHMS &lt;&gt; null then
			if not ia.includes(line.invoice.sequenceNum) then
				ia.add(line.invoice.sequenceNum);
			endif;
			mode := CMUI_TransactionEnquiry.Mode_HMS_Transaction_Enquiry;
			coll.add(line.myTransactionHMS);
		elseif line.myTransactionBOL &lt;&gt; null then	//04 Nov 2019	NDL	TFS 47100
			if not ia.includes(line.invoice.sequenceNum) then
				ia.add(line.invoice.sequenceNum);
			endif;
			mode := CMUI_TransactionEnquiry.Mode_BOL_Transaction_Enquiry;
			coll.add(line.myTransactionBOL);
		endif;
	endforeach;
	
	if coll.size = 0 then
		return;
	endif;

	form := app.loadForm (CMUI_TransactionEnquiry, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_TransactionEnquiry;
	if form &lt;&gt; null then
		form.centreWindow;
		form.setMyTerminal(self.myTerminal);
		// set up the invoice number(s) display for the transaction enquiry
		first := true;
		foreach int in ia do
			if first then
				if ia.size = 1 then
					str := app.getErrorString(INV_Invoice) &amp; ': ' &amp; int.String;
					// if a single invoice line is selected, show both invoice and line numbers
					if oa.size = 1 then
						obj := oa[1];
						if obj.isKindOf(CM_InvoiceLine) then
							line := obj.CM_InvoiceLine;
							str := app.getErrorString(INV_Invoice) &amp; ': ' &amp; int.String &amp; " " &amp; app.getErrorString(Invoice_line) &amp; ": " &amp; line.sequenceNum.String;
						endif;
					endif;
				else
					str := app.getErrorString(INV_Invoices) &amp; ': ' &amp; int.String;
				endif;
				first := false;
			else
				str := str &amp; ', ' &amp; int.String;
			endif;
		endforeach;
		form.displayText := str;
		form.displaySelectorResults (coll, mode);
		
		form.show;
	endif;
epilog
	delete ia;
	delete oa;
	delete lines;
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
