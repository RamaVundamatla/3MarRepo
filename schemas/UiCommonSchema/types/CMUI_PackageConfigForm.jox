        <source>doFillFileFormatCombo(_cmb: ComboBox input) protected;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 20/05/2016	cnwdap1		TFS #1881 BAPLIE/EDI VGM Updates
