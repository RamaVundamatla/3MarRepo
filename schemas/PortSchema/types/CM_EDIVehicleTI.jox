    <JadeMethod name="assignValueSpecial" id="5001be9b-cdfb-44a2-9599-6c29c95d07a4">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*

Date		Who		Reason
08 Dec 2014	cnwer1	Initial creation PAR
17 Oct 2024	navcs2	MTN-33066 EUP - NTO-980 - "89636: Total Weight Should Not be Zero" Error when Uploading Transport Manifest with weights in kilograms only
07 Nov 2024	navdap1	MTN-33400 MTN - User Defined EDI is not longer loading Volume details
*/
vars	
	isWeightZero,							// 17 Oct 2024		navcs2	MTN-33066
	isKg,									// 17 Oct 2024		navcs2	MTN-33066
	shouldChange		: Boolean;			// 17 Oct 2024		navcs2	MTN-33066
	value,									// 17 Oct 2024		navcs2	MTN-33066
	str,									// 17 Oct 2024		navcs2	MTN-33066
	type				: String;			// 17 Oct 2024		navcs2	MTN-33066
begin
	if _propName.isMeasurementType then	
		_propName.getRowNameMeasureType(str, type);	
		
		if str = ETRow_TareWeight or str = ETRow_MaxGross then
			if str = ETRow_MaxGross then
				isWeightZero 		:= self.maxGross = 0;
			else 
				isWeightZero 		:= self.tareWeight = 0;
			endif;
			isKg				:= type = self.KGString;
			value 				:= app.convertMeasurementForStorage(type, _processedValue.Decimal).asStringJMT;
			shouldChange		:= (isWeightZero and not value = null) or (isKg and not value = null);
			if str = ETRow_TareWeight then												// MTN-33400
				if shouldChange then
					if value = null then
						self.setPropertyValue(ETRow_TareWeight, NULL_WEIGHT);
					else
						self.setPropertyValue(ETRow_TareWeight, value.asDecimalJMT); 
					endif;
				endif;
				return true;																										
			elseif str = ETRow_MaxGross then												// MTN-33400
				if shouldChange then
					if value = null then
						self.setPropertyValue(ETRow_MaxGross, NULL_WEIGHT);
					else
						self.setPropertyValue(ETRow_MaxGross, value.asDecimalJMT); 
					endif;
				endif;
				return true;																										
			endif;
		else																			// MTN-33400
			return self.assignValueSpecial(str, _processedValue, _xlationOperator);		// MTN-33400
		endif;
	endif;

	return inheritMethod(_propName, _processedValue, _xlationOperator);
	
	

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProxy" id="18d37438-efb1-407d-bfb8-2cd6eba3474b">
        <source>createProxy() : CM_Vehicle;
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	realVehicle,
	proxy : CM_Vehicle;
begin
	
	if self.action = self.EDI_ACTION_ADD then
		create proxy transient;
	else
		realVehicle:=self.getVehicle();
		if realVehicle = null then
			return null;
		endif;
		proxy:=realVehicle.pxyCreateUpdateProxy.CM_Vehicle;
	endif;
	
	proxy.setProxy(self.regNumber,null,self.tareWeight,self.maxGross,self.getCarrier,self.state,self.notAvailable.asBooleanJMT,self.getMyTerminal);
	
	return proxy;
epilog

end;</source>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="getCarrier" id="f8eb88dc-d13e-40b2-803e-ba8c4d24685c">
        <source>getCarrier() : CM_Carrier;
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	carrier : CM_Carrier;
begin
	carrier:=app.myRoot.allCarriers[self.carrierCode];
	
	if carrier = null then
		return null;
	endif;
	
	if not carrier.isRoad then
		return null;
	endif;
	if  carrier.isNotAvailableForEntry then
		return null;
	endif;
	
	return carrier;
epilog

end;</source>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6a242b65-78e1-4d45-8bac-0a42b864a827">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Date		Who		Reason
08 December 2014	cnwer1	Initial creation PAR

*/

vars

	rowName, type	: String;

begin
	if _attrName.isMeasurementType then
		_attrName.getRowNameMeasureType(rowName, type);
		return self.getMeasurementStringForAttrib(rowName, type, _short);
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefName" id="b080e222-b5e9-4fe9-8b00-910ee9c533e2">
        <source>getMyTIDisplayDefName(): String;
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars

begin
	return ETDef_EDITIVehicle;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVehicle" id="beb06885-fadc-4950-a148-81b45c0864cb">
        <source>getVehicle() : CM_Vehicle;
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	terminal : CM_Terminal;
begin
	terminal:=self.getMyTerminal();
	return terminal.vehicles[self.regNumber,self.state];
epilog

end;</source>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="d92fdd94-b0b1-4193-89fa-72086ca87587">
        <source>loadDB(_validateOnly: Boolean; _passport: CM_Passport input);
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	realVehicle,
	proxyVehicle : CM_Vehicle;
begin
	self.verifySelf();
	
	if _validateOnly then
		return;
	endif;

	if self.action = self.EDI_ACTION_ADD then
		proxyVehicle:=self.createProxy();
		app.myUtilityCA.utlCreateVehicle(proxyVehicle, realVehicle, _passport);
	elseif self.action = self.EDI_ACTION_UPDATE then
		proxyVehicle:=self.createProxy();
		app.myUtilityUA.utlUpdateVehicle(proxyVehicle,_passport);
	elseif self.action = self.EDI_ACTION_DELETE then
		realVehicle:=self.getVehicle();
		app.myUtilityDA.utlDeleteVehicle(realVehicle,_passport);
	endif;
	
epilog
	delete proxyVehicle;
end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="92f05d02-9854-49a0-8320-7ea6b8313437">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Date		Who		Reason
11 June 2015	cnwer1	Initial creation PAR

*/

vars

begin
	inheritMethod(_proxyEDITI);
	self.action:=_proxyEDITI.action;
	self.carrierCode:=_proxyEDITI.carrierCode;
	self.maxGross:=_proxyEDITI.maxGross;
	self.notAvailable:=_proxyEDITI.notAvailable;
	self.regNumber:=_proxyEDITI.regNumber;
	self.state:=_proxyEDITI.state;
	self.tareWeight:=_proxyEDITI.tareWeight;
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementTypeValue" id="43320a15-ed8c-4d8c-99e3-62ccf028fa05">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String): Boolean updating;
/*

Date		Who		Reason
08 December 2014	cnwer1	Initial creation PAR

*/

vars
	rowName,
	measureType		: String;
	
begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	if rowName = ETRow_MaxGross then
		self.maxGross := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	elseif rowName = ETRow_TareWeight then
		self.tareWeight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="55aa4df4-f504-4358-aa71-44a350cf0444">
        <source>verifySelf();
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	vehicle 		: CM_Vehicle;
	terminal : CM_Terminal;
begin
	if self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD 
			and self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE
			and self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE then
			app.raiseCMException1(EDI_Action_Is_Invalid, action, ETRow_Action, self);
			return;
	endif;
	

	if self.regNumber = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Reg Number', null, null);
		app.raiseCMException(Input_required_field_regNum, null, null); // cnwdb2	PAR 35364
	else
		vehicle:=getVehicle;
		if action  = CM_EDITrackedItem.EDI_ACTION_ADD then
			if vehicle &lt;&gt; null then
				app.raiseCMException1(VB_DUPLICATED_ITEM, self.regNumber &amp; " " &amp; self.state, null, null);
			endif;
		elseif action = CM_EDITrackedItem.EDI_ACTION_UPDATE then
			if vehicle = null then
				app.raiseCMException2(Does_not_exist_cannot_update,app.getErrorString(Vehicle), self.regNumber &amp; " " &amp; self.state, null, null);
			endif;
		elseif action = CM_EDITrackedItem.EDI_ACTION_DELETE then
			if vehicle = null then
				app.raiseCMException2(Object_DoesNotExist_Too_Delete,app.getErrorString(Vehicle), self.regNumber &amp; " " &amp; self.state, null, null);
			endif;
		endif;	
	endif;
	
	if self.carrierCode = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Carrier', null, null);
		app.raiseCMException(Input_required_field_carrier, null, null); // cnwdb2	PAR 35364


	else
		if self.getCarrier = null then
			
		endif;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
</Class>
