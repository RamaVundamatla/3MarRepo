    <JadeMethod name="doTblInvRateContMenu" id="bdd7608e-ea08-4cdb-adc2-ee346b0b08b5">
        <updating/>
        <source>doTblInvRateContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;	
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
