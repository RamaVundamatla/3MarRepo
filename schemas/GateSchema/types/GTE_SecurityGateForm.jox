    <JadeMethod name="doAddNewVisit" id="b2a8097c-6fa1-4445-8b37-60d5e6611668">
        <source>doAddNewVisit();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 27/06/2018	JLGNS1		Bug 39463: STWR - RE: Ticket 39428 - Steinweg Rotterdam - Error when trying to open Road Operations
//
vars
	form	: GTE_SecurityGateVisitEntry;

begin
	form := app.loadForm(	GTE_SecurityGateVisitEntry, 
							self.myAssistant.class, 
							false, false, true, 
							self.myTerminal, null).GTE_SecurityGateVisitEntry;
	
	if form &lt;&gt; null then
		form.numberOfDays := self.txtSearchDays.text.Integer.max(1);	//Bug 39463
	
		form.showModal;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="20c62a70-6422-4875-ab24-2575a2781a4d">
        <updating/>
