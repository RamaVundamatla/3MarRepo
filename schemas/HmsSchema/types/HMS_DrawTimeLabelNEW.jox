    <JadeMethod name="drawMe" id="ef02aeda-0936-46e9-b371-19e8ed05aab2">
        <updating/>
        <source>drawMe()updating;
//--------------------------------------------------
// Created:	04 May 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
 	self.myLabelFrame.clearGraphics;
	self.setMyLabelFrmHeight();
	 	
	self.drawTimeLegend();
	self.drawTimeScale();
	
	self.lblTimePointer.caption := self.systemToLocalTime(self.fromTimePeriod).date.shortFormatJMT() &amp; ' to ' &amp; 
						self.systemToLocalTime(self.toTimePeriod).date.shortFormatJMT();	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
end;</source>
    </JadeMethod>
    <JadeMethod name="drawMidnightLines" id="1a47534b-8fb7-4aa2-ad0b-6bb9964c33d7">
        <updating/>
        <source>drawMidnightLines(_scrollingWharfFrm : HMS_ScrollingWharfFrame input) updating;
constants
	ROUNDTO:						Integer = 5;
vars
   	cacHeight:						Real;
   	cacWidth:						Real;
   	midnight_Next_Day:				TimeStamp;
   	minutesOffsetToFirstMidnight:	Real;
   	pixelOffsetToFirstMidnight:	 	Real;
   	pixelOffsetBetweenMidnights:	Real;
   	y:								Real;
   	yPosn:							Real;
   	yBase:							Real;
   	adjustedMinsPerPixel:			Real;
   	count:							Integer;
	midnightNextDaySystem:			TimeStamp;
begin
 	// This method draw lines horizontally across the main graphical view area at the time of midnight each day
 	adjustedMinsPerPixel := minutesPerPixel;

 	cacHeight := self.scaleHeight;
 	cacWidth := _scrollingWharfFrm.width;

// 	midnight_Next_Day:=(((fromTimePeriod.Date)+1).Date.String &amp; ", 00:00:00").TimeStamp;
 	midnightNextDaySystem.setDate(fromTimePeriod.date+1);
 	midnightNextDaySystem.setTime(null);
	midnight_Next_Day := self.localToSystemTime(midnightNextDaySystem);
 	minutesOffsetToFirstMidnight:=fromTimePeriod.minutesDiff(midnight_Next_Day);	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support

 	pixelOffsetToFirstMidnight:=(minutesOffsetToFirstMidnight/adjustedMinsPerPixel);
	pixelOffsetBetweenMidnights:=(1440/adjustedMinsPerPixel);

 	y := cacHeight-pixelOffsetToFirstMidnight;

 	_scrollingWharfFrm.drawWidth := 1;

 	yBase := y;
 	yPosn := yBase;

 	count := 1;
 	while yPosn.roundedTo(ROUNDTO) &gt;= 0 do
 		_scrollingWharfFrm.drawLine(0, yPosn, cacWidth, yPosn, self.midnightLineColour);
 		y := pixelOffsetBetweenMidnights*count;
 		yPosn := yBase-y;
 		count := count+1;
 	endwhile;

end;</source>
        <Parameter name="_scrollingWharfFrm" type="HMS_ScrollingWharfFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawTimeLegend" id="29a57bf8-d086-4e28-9912-4e2cf2ef045c">
        <updating/>
        <source>drawTimeLegend() updating, protected;

vars
begin
	self.endTimer(UpdateCurrentTimeMarker);
	self.drawCurrentTime();
	self.beginTimer(30000,Timer_Continuous,UpdateCurrentTimeMarker);	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawTimeScale" id="f6c9bb98-d914-4c39-8c8f-32c0082017cd">
        <updating/>
        <source>drawTimeScale() updating, protected;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 29/03/2016	cnwdap1		PAR #35843 Make progress bar updates time-based, not object counts
constants
	DAYFONT : String = "Courier"; //cnwjo3 par 21212
	ROUNDTO : Integer = 5;

vars
	int:						Integer;
	minutesInView:				Real;
 	daysInView:					Real;
 	//pixelsPerHr:				Real;
 	pixelsPerDay:				Real;
 	pixelsPerMinUnit:			Real;
 	pixelsToFirstMinUnit:		Real;
 	minLegendSpace:				Integer;
 	maxLegendWidth:				Integer;
 	numOfDaysForMinSpacing:		Integer;
 	hourDivisionArray:			IntegerArray;
 	count:						Integer;
 	startOfFirstDay:			TimeStamp;
 	minsToStartOfPeriod:		Real;
 	minsToFirstMinUnit:			Integer;
 	minsPerMinimumUnit:			Integer;
 	numOfMinDivsToNearestOffset:Integer;
 	numOfDivisionsPerDay:		Integer;				
 	numOfLevels:				Integer;
 	yPosn:						Real;
 	divID:						Integer;
 	level:						Integer;
 	markWidth:					Integer;
 	ts:							TimeStamp;
 	timeToFirstMinUnit:			Time;
 	timeOfMinUnit:				Time;
 	minLabelSpacing:			Integer;
 	numDaysBtwnDayLabels:		Integer;
 	pixelsBtwnDayLabels:		Real;
 	daysToNextDayLabel:			Integer;
 	numDivsToLabel:				Integer;
 	pixelsBtwnTimeLabels:		Real;
 	numDivsBtwnTimeLabels:		Integer;
 	firstDivIDToLabel:			Integer;
 	divisionsToNextLabel:		Integer;
 	minUnitHrs:					Integer;
 	minUnitDays:				Integer;
 	daysToFirstMinUnit:			Integer;
 	hrsToFirstMinUnit:			Integer;
    scaleLabelWidth:			Real;
    numLetters:					Integer;
//    useShortDate,
    //thinClientMode:				Boolean;
	tmpHeight:					Real;
	lastDate,
	tmpStr:						String;
	txtExtent,
	origFontSize,
	tmpYPos,
	lastYPos,
	yPos,
	xTime:						Real;
	cancelButton:				CMUI_Button;
	tmpMonitor:					CMIF_Monitor;
	partsDone,
	partsInJob:					Integer;
	message:					String;
	planningNote:				HMS_PlanningNote;
	originalFont : String;  //par 21212 cnwjo3
	lastUpdate	: Decimal[20];						// PAR #35843
	fromLocal:					TimeStamp;
	
begin
 	// This is a new method to draw the time scale
	cancelButton := self.myGraphicalView.btnModalDefault;
 	// Set minimum spacing for legend marks
 	minLegendSpace:=3;		// ie. legend markers cannot be closer than 2 pixels

 	// Set minimum spacing for legend labels
 	//minLabelSpacing:=20;		// ie. legend labels cannot be closer than 20 pixels
 	minLabelSpacing:=15;		// ie. legend labels cannot be closer than 20 pixels

 	// Set maximum width for legend labels
 	maxLegendWidth:=7;		// ie. legend markers cannot be wider than 7 pixels

 	// Build an array of equal divisions of a 24 hr block
 	create hourDivisionArray transient;
 	hourDivisionArray.add(24);  // 24 x  1hr divisions
 	hourDivisionArray.add(12);	// 12 x  2hr divisions
 	hourDivisionArray.add(8);	// 	8 x  3hr divisions
 	hourDivisionArray.add(6);	//  6 x  4hr divisions
 	hourDivisionArray.add(4);	// 	4 x  6hr divisions
 	hourDivisionArray.add(3);	// 	3 x  8hr divisions
 	hourDivisionArray.add(2);	//  2 x 12hr divisions
 	hourDivisionArray.add(1);	//  1 x 24hr division

	// Get the length of the viewing window in days 	
	minutesInView:=fromTimePeriod.minutesDiff(toTimePeriod);
	daysInView:=minutesInView/1440;
	
	tmpHeight := self.scaleHeight;
	// Calc number of pixels per day
	pixelsPerDay := tmpHeight/daysInView;

	// Calc the number of days at the minimum pixel spacing [1 or less] or [2,3,4....]
	numOfDaysForMinSpacing:=1;
	numOfDivisionsPerDay:=0;
	pixelsPerMinUnit:=pixelsPerDay;
	minUnitHrs := (24*numOfDaysForMinSpacing).Integer;
	//timeOfMinUnit.setTime((24*numOfDaysForMinSpacing),0,0,0);
	
	//Set up locals ready for checking if the user has cancelled selection.
	tmpMonitor := app.myPassport.myCMIFMonitor;
	if tmpMonitor &lt;&gt; null then
		partsDone := tmpMonitor.partsDone;
		partsInJob := tmpMonitor.partsInJob;
		message := tmpMonitor.message;
	endif;
	
	int := 0;
	while pixelsPerMinUnit &lt; minLegendSpace do
		int := int + 1;
		//if int mod 1000 = 0 then 																	// PAR #35843
		if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
			if tmpMonitor &lt;&gt; null then
				if (not tmpMonitor.updateProgress(message, partsInJob, partsDone)) then
					return;
				endif;
			endif;
			lastUpdate := app.relativeMachineTime;													// PAR #35843
		endif;
		// Minimum unit becomes every XX (numOfDaysForMinSpacing) days
		numOfDaysForMinSpacing := numOfDaysForMinSpacing+1;
		// Calc pixelsPerMinUnit
		pixelsPerMinUnit := tmpHeight/(daysInView/numOfDaysForMinSpacing);
		minUnitHrs := (24*numOfDaysForMinSpacing).Integer;
		//timeOfMinUnit.setTime(0,(hrs*60).Integer,0,0);
		minsPerMinimumUnit := numOfDaysForMinSpacing*1440;
	endwhile;
	
	// Calc number of days for minimum label spacing
	numDaysBtwnDayLabels := 1;
	pixelsBtwnDayLabels := pixelsPerDay*numDaysBtwnDayLabels;
	
	int := 0;
	while pixelsBtwnDayLabels &lt; minLabelSpacing do
		int := int + 1;
		//if int mod 1000 = 0 then 																	// PAR #35843
		if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
			if tmpMonitor &lt;&gt; null then
				if (not tmpMonitor.updateProgress(message, partsInJob, partsDone)) then
					return;
				endif;
			endif;
			lastUpdate := app.relativeMachineTime;													// PAR #35843
		endif;
		// Minimum day labelling becomes every XX (numDaysBtwnDayLabels) days
		numDaysBtwnDayLabels := numDaysBtwnDayLabels+1;
		// Calc pixelsBtwnDayLabels
		pixelsBtwnDayLabels := pixelsPerDay*numDaysBtwnDayLabels;
	endwhile;
	
	// Test to see if the number of days at the minimum pixel spacing is 1 or less
	count:=1;
	if numOfDaysForMinSpacing=1 then
		// ie. 1 or less
		// Determine what the minimum hour unit is to be: ie. 1,2,3,4,6,8,12,24 hrs
		// Calc number of pixels per hour
		pixelsPerMinUnit := pixelsPerDay/hourDivisionArray[count];
		numOfDivisionsPerDay := hourDivisionArray[count];
		timeOfMinUnit.setTime(0, ((24/hourDivisionArray[count]) * 60).Integer, 0, 0);
		int := 0;
		while pixelsPerMinUnit &lt; minLegendSpace and count &lt; hourDivisionArray.size do
			int := int + 1;
			//if int mod 1000 = 0 then 																	// PAR #35843
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				if tmpMonitor &lt;&gt; null then
					if (not tmpMonitor.updateProgress(message, partsInJob, partsDone)) then
						return;
					endif;
				endif;
				lastUpdate := app.relativeMachineTime;													// PAR #35843
			endif;
		
			count := count+1;
			pixelsPerMinUnit := pixelsPerDay/hourDivisionArray[count];
			numOfDivisionsPerDay := hourDivisionArray[count];
			timeOfMinUnit.setTime(0, ((24/hourDivisionArray[count]) * 60).Integer, 0, 0);
		endwhile;
		
				
		minsPerMinimumUnit := ((24/hourDivisionArray[count]) * 60).Integer;
		minUnitHrs := ((24/hourDivisionArray[count])).Integer;  // Mod RH

		// Calc number of divisions between time labels
		numDivsToLabel := numOfDivisionsPerDay;
		pixelsBtwnTimeLabels := pixelsPerDay/numDivsToLabel;
		// while pixelsBtwnTimeLabels&lt;minLabelSpacing and numOfDivisionsPerDay&gt;1 do   - old code - fix 25/08/99
		//int := 0;
		while (pixelsBtwnTimeLabels &lt; minLabelSpacing) and (numOfDivisionsPerDay &gt; 1) and (numDivsToLabel &gt; 1) do
			// Minimum time labelling becomes every XX divsions
			numDivsToLabel := numDivsToLabel - 1;
			// Find next whole number divisior of the 'numOfDivisionsPerDay'
		
			while (numOfDivisionsPerDay mod numDivsToLabel) &lt;&gt; 0 and numDivsToLabel &gt; 1 do
				//write "numOfDivisionsPerDay mod numDivsToLabel=" &amp; (numOfDivisionsPerDay mod numDivsToLabel).String;
				numDivsToLabel := numDivsToLabel - 1;
			endwhile;
			// Calc pixelsBtwnTimeLabels
			pixelsBtwnTimeLabels := pixelsPerDay / numDivsToLabel;
		endwhile;
		
		numDivsBtwnTimeLabels := (numOfDivisionsPerDay/numDivsToLabel).Integer;
 	endif;

	// Calc offset to first minimum unit
	fromLocal := self.systemToLocalTime(fromTimePeriod);
	startOfFirstDay := (fromLocal.Date.String &amp; ", 00:00:00").TimeStamp;	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	minsToStartOfPeriod := startOfFirstDay.minutesDiff(fromLocal);


	// Calc nearest unit mark
	numOfMinDivsToNearestOffset := (minsToStartOfPeriod/minsPerMinimumUnit).Real.roundedUp;
	minsToFirstMinUnit := ((minsPerMinimumUnit*numOfMinDivsToNearestOffset)-minsToStartOfPeriod).Integer;
	pixelsToFirstMinUnit := minsToFirstMinUnit*(pixelsPerDay/1440);

	// Set timestamp for first min unit
	daysToFirstMinUnit:=(minsToFirstMinUnit/1440).Integer;
	minsToFirstMinUnit:=minsToFirstMinUnit-(daysToFirstMinUnit*1440);
	hrsToFirstMinUnit:=(minsToFirstMinUnit/60).Integer;
	minsToFirstMinUnit:=minsToFirstMinUnit-(hrsToFirstMinUnit*60);
	timeToFirstMinUnit.setTime(hrsToFirstMinUnit.Integer,minsToFirstMinUnit.Integer,0,0);
	ts:=fromTimePeriod+timeToFirstMinUnit;
	ts:=((ts.Date+daysToFirstMinUnit).Date.String &amp; "," &amp; ts.Time.String).TimeStamp;
	
	// Get DivID of first mark
	if numOfMinDivsToNearestOffset=numOfDivisionsPerDay then
		divID:=0;
	else
		if numOfDivisionsPerDay=0 then
			divID:=0;
		else
			divID:=numOfMinDivsToNearestOffset;
		endif;
	endif;

	// Get number of levels
	numOfLevels:=0;
	if numOfDivisionsPerDay&gt;0 then
		if numOfDivisionsPerDay mod 2 = 0 then
			// Even number
			numOfLevels:=((numOfDivisionsPerDay/2)+1).Integer;
		else
			// Odd number
			numOfLevels:=((numOfDivisionsPerDay+1)/2).Integer;
		endif;
	else
		numOfLevels:=1;
	endif;


	// Calc the number of units from the first offset to the first division that needs a label
	if numOfDaysForMinSpacing=1 then
		firstDivIDToLabel:=0;
		while firstDivIDToLabel&lt;divID do
			firstDivIDToLabel:=firstDivIDToLabel+numDivsBtwnTimeLabels;
		endwhile;
		divisionsToNextLabel:=firstDivIDToLabel-divID;
	endif;

	// Set days and hours of minimum unit
	// ------------------------------------------------------------------------------------------
	if numOfDaysForMinSpacing=1 and minUnitHrs&lt;24 then
		// Min spacing is less than 24 hrs - set days to 0 and leave minUnitHrs as they were
		// timeOfMinUnit already set	
		minUnitDays:=0;
	else
		// Min spacing 24hrs or more - split into days and hours
		minUnitDays:=(minUnitHrs/24).Integer;
		minUnitHrs:=(minUnitHrs-(24*minUnitDays)).Integer;
		timeOfMinUnit.setTime(minUnitHrs,0,0,0);
  	endif;
  	// ------------------------------------------------------------------------------------------

	// Draw lines
	daysToNextDayLabel:=0;
	yPosn := tmpHeight-pixelsToFirstMinUnit;
	scaleLabelWidth := self.myLabelFrame.clientWidth;	//AJA: Thin Client Mods
	
	if pixelsBtwnDayLabels &lt; 50 then
		numLetters := 1;
	elseif pixelsBtwnDayLabels &lt; 110 then
		//useShortDate := true; 
		numLetters := 3;
	endif;
	
	xTime := 15;
	origFontSize := self.myLabelFrame.drawFontSize;
	
	int := 0;
	while yPosn.roundedTo(ROUNDTO) &gt; 0 do
		int := int + 1;
		//if int mod 1000 = 0 then 																	// PAR #35843
		if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
			if tmpMonitor &lt;&gt; null then
				if (not tmpMonitor.updateProgress(message, partsInJob, partsDone)) then
					return;
				endif;
			endif;
			lastUpdate := app.relativeMachineTime;													// PAR #35843
		endif;
		// Get level
		if divID&gt;=(numOfDivisionsPerDay/2) then
			level:=numOfDivisionsPerDay-divID;
		else
			level:=divID;
		endif;

		// Get mark width
		markWidth:=(maxLegendWidth*((numOfLevels-level)/numOfLevels)).Integer; 
		markWidth:=maxLegendWidth-markWidth;
		if markWidth=0 then
			markWidth := 1;
		endif;
		markWidth := (scaleLabelWidth-markWidth).Integer;
		// Draw line
		self.myLabelFrame.drawLine(markWidth,yPosn,scaleLabelWidth,yPosn,Black);

        // Label date
		if level=0 then
			// Label date
			if daysToNextDayLabel&lt;=0 then
				yPos := yPosn - textOffset;
				tmpStr := ts.date.shortFormatJMT();
				
				planningNote := self.myGraphicalView.getNoteForDate (ts.date);
				// cnwdad1 10/05/2007 - Should be "&lt;&gt;", not "=".
				//if planningNote = null then
				if planningNote &lt;&gt; null then
					self.myLabelFrame.drawTextAt(tmpStr, 0, yPos, self.planningNotesDateColour);
				else
					self.myLabelFrame.drawTextAt(tmpStr, 0, yPos, self.dayLabelColour);  //draw date value (10/10/09, 13/2/01, etc)
				endif;
				
				
				if lastDate &lt;&gt; null then
					tmpStr := lastDate;
					if numLetters &gt; 0 then
						tmpStr := tmpStr[1:numLetters];
					endif;
					txtExtent := tmpStr.length*10;
					tmpYPos := ((lastYPos+yPos-txtExtent)/2)-10;					
					self.myLabelFrame.drawFontSize := 10;
					self.myLabelFrame.drawTextRotation := 270;										

					originalFont := self.myLabelFrame.drawFontName;   //cnwjo3 par 21212
					self.myLabelFrame.drawFontName := DAYFONT;   //cnwjo3 par 21212
					self.myLabelFrame.drawTextAt(tmpStr, 8, tmpYPos, self.dayLabelColour);  //draw Day (Monday, Tuesday, Wednesday, etc, or Mon, Tue, Wed, etc..)
					
					self.myLabelFrame.drawFontName := originalFont;  //cnwjo3 par 21212
					self.myLabelFrame.drawFontSize := origFontSize;
					self.myLabelFrame.drawTextRotation := 0;

				endif;
				daysToNextDayLabel:=numDaysBtwnDayLabels;				
				lastDate := ts.date.dayName;
				lastYPos := yPos;
			endif;
			if numOfDaysForMinSpacing=1 then
				daysToNextDayLabel:=daysToNextDayLabel-1;
			else
				daysToNextDayLabel:=daysToNextDayLabel-minUnitDays;
			endif;
		endif;

		// Label time
		if divisionsToNextLabel=0 then
			if level&lt;&gt;0 then
				// Label this time
// cnwdad1 18/06/2009 - PAR #19942.
				//tmpStr := ts.time.format('HH:mm');
				tmpStr := self.systemToLocalTime(ts).time.format(app.getTimeShortFormat(false));	// 27/5/16 cnwmp6 TFS 488 - Multi timezone support
				self.myLabelFrame.drawTextAt(tmpStr, xTime, yPosn - textOffset, Black);
			endif;
			divisionsToNextLabel:=numDivsBtwnTimeLabels;
		endif;
		divisionsToNextLabel:=divisionsToNextLabel-1;

		// Get next yPosn
		yPosn:=yPosn-pixelsPerMinUnit;
		divID:=divID+1;
		if divID&gt;=numOfDivisionsPerDay then
			divID:=0;
		endif;

		// Move time forward to next min time unit
		ts:=ts+timeOfMinUnit;
		// Add number the "Days" component of the minimum unit
		ts:=((ts.Date+minUnitDays).Date.String &amp; "," &amp; ts.Time.String).TimeStamp;
		
		if yPosn.roundedTo(ROUNDTO) = 0 then
			tmpStr := self.systemToLocalTime(ts).date.shortFormatJMT();
			self.myLabelFrame.drawTextAt(tmpStr, 0, yPosn - textOffset, self.midnightLineColour);
		endif;
	endwhile;
	
	if lastDate &lt;&gt; null then
		tmpStr := lastDate;
		if numLetters &gt; 0 then
			tmpStr := tmpStr[1:numLetters];
		endif;
		txtExtent := tmpStr.length*10;
		yPos := yPosn - textOffset;
		tmpYPos := ((lastYPos+yPos-txtExtent)/2)-10;					
		self.myLabelFrame.drawFontSize := 10;
		self.myLabelFrame.drawTextRotation := 270;
		originalFont := self.myLabelFrame.drawFontName;   //cnwjo3 par 21212
		self.myLabelFrame.drawFontName := DAYFONT;   //cnwjo3 par 21212
		self.myLabelFrame.drawTextAt(tmpStr, 8, tmpYPos, self.dayLabelColour);
		self.myLabelFrame.drawFontName := originalFont;  //cnwjo3 par 21212
		self.myLabelFrame.drawFontSize := origFontSize;
		self.myLabelFrame.drawTextRotation := 0;
	endif;
epilog
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  ' &amp; self.String &amp; ' END. ');
	delete hourDivisionArray;		 
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getCurrentTimeTopPosition" id="2e373a98-e0a3-41c0-bfc7-07a1c9e8214a">
        <source>getCurrentTimeTopPosition() : Integer;
//-----------------------------------------
// Created: November 2004 By: cnwgd1
//-----------------------------------------
vars
	now : TimeStamp;
	tmpTop : Real;
begin
	now := app.actualTimeServer();		// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	return (self.scaleHeight - (self.fromTimePeriod.minutesDiff(now) / self.minutesPerPixel)).Integer;	
	
	/*tmpTop := self.scaleHeight - (self.fromTimePeriod.minutesDiff(now) / self.minutesPerPixel);
	//AJA 12/7/01: If time period is too far into the future then 'tmpTop' can get too
	//large and cause the background control to freeze up when setting the time line
	//Happens in Win 98, but not observed in NT. Solution is to limit the value of 'tmpTop'
	if tmpTop &gt; self.scaleHeight then
		tmpTop := self.scaleHeight + 10;
	endif;

	return tmpTop.Integer;*/

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDateFromClick" id="b2db1c5a-ee64-4456-b50a-84f41b7f3f51">
        <source>getDateFromClick( y : Integer) : TimeStamp;
//-----------------------------------------------------------------------
//	Created:	02 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	dateClicked		: TimeStamp;
	minsDiff		: Integer;
begin
	minsDiff	:= (y * minutesPerPixel).Integer;
	dateClicked	:= self.toTimePeriod.cnEcAddMinutes( -minsDiff );
	return dateClicked;
epilog

end;</source>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
