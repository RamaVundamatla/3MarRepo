    <JadeMethod name="create" id="af627592-2dd2-46f7-a5e0-407acee1d808">
        <updating/>
        <source>create() updating;

constants
	LookingForParamName  = 1;
	LookingForEquals     = 2;
	LookingForParamValue = 3;
	
vars
	cmdLine, paramName, paramValue : String;
	cmdLineLen, n : Integer;
	tokenStartPos : Integer;
	inQuote : Boolean;
	char : Character;
	state : Integer;
	
begin
	cmdLine := app.jtdMyContext.jtdGetCommandLine;
	cmdLineLen := cmdLine.length;

	if cmdLineLen &lt;= 2 then
		return;
	endif;

	if cmdLine[1] = '"' then
		n := cmdLine.pos('"', 2);
		if n &gt; 2 then
			self.jtdCommand := cmdLine[2 : n - 2];
			n := n + 1;
			if n &gt; cmdLineLen then
				return;
			endif;
			cmdLine := cmdLine[n : end];
		else
			return;
		endif;
	endif;

	cmdLine := cmdLine.trimBlanks;
	cmdLineLen := cmdLine.length;
	
	inQuote := false;
	state := LookingForParamName;

	tokenStartPos := 1;
	n := 1;
	
	while n &lt;= cmdLineLen do
		char := cmdLine[n];
		
		if char = ' ' then
			if not inQuote then
				if state = LookingForParamName then
					paramName := cmdLine[tokenStartPos : n - tokenStartPos].trimBlanks;
					if paramName.toLower = "endjade" then
						return;
					endif;
					tokenStartPos := n;
					state := LookingForEquals;
				elseif state = LookingForParamValue then
					paramValue := cmdLine[tokenStartPos : n - tokenStartPos].trimBlanks;
					self.jtdSetValue(paramName, paramValue);
					tokenStartPos := n;
					state := LookingForParamName;
				endif;
			endif;
		
		elseif char = '=' then
			if not inQuote then
				if state = LookingForParamName then
					paramName := cmdLine[tokenStartPos : n - tokenStartPos].trimBlanks;
					if paramName.toLower = "endjade" then
						return;
					endif;
					tokenStartPos := n + 1;
					state := LookingForParamValue;
				elseif state = LookingForEquals then
					tokenStartPos := n + 1;
					state := LookingForParamValue;
				endif;
			endif;
		
		elseif char = '"' then
			inQuote := not inQuote;
			
		elseif n = cmdLineLen then
			if not inQuote and state = LookingForParamValue then
				paramValue := cmdLine[tokenStartPos : end].trimBlanks;
				self.jtdSetValue(paramName, paramValue);
				return;
			endif;
		endif;

		n := n + 1;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdAsString" id="be551954-33c1-4f6d-b67d-703b2f17d270">
        <source>jtdAsString() : String;

begin
	return '"' &amp; self.jtdCommand &amp; '" path="' &amp; self.jtdPath &amp; '" schema="' &amp;
		self.jtdSchemaName &amp; '" app="' &amp; self.jtdAppName &amp; '" appServer="' &amp;
		self.jtdAppServer &amp; '" appServerPort="' &amp; self.jtdAppServerPort &amp;
		'" ini="' &amp; self.jtdIni &amp; '" server="' &amp; self.jtdServer &amp; '"';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdSetValue" id="f6129788-be52-454c-8351-c3bc9b4fc5eb">
        <updating/>
        <source>jtdSetValue(paramName, paramValue : String) updating, protected;

vars
	i, len : Integer;
	ns, vs : String;
	
begin
	if paramName = null or paramValue = null then
		return;
	endif;
	
	ns := paramName.toLower;

	// strip double-quotes out of value string
	if paramValue.pos('"', 1) &lt; 1 then
		vs := paramValue;
	else
		vs := null;
		len := paramValue.length;
		foreach i in 1 to len do
			if paramValue[i] &lt;&gt; '"' then
				vs := vs &amp; paramValue[i];
			endif;
		endforeach;
	endif;
	
	if ns = "app" then
		self.jtdAppName := vs;
	elseif ns = "appserver" then
		self.jtdAppServer := vs;
	elseif ns = "appserverport" then
		self.jtdAppServerPort := vs;
	elseif ns = "ini" then
		self.jtdIni := vs;
	elseif ns = "path" then
		self.jtdPath := vs;
	elseif ns = "schema" then
		self.jtdSchemaName := vs;
	elseif ns = "server" then
		self.jtdServer := vs;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="paramName" type="String"/>
        <Parameter name="paramValue" type="String"/>
    </JadeMethod>
</Class>
