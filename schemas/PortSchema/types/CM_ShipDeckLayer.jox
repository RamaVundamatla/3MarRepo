    <JadeMethod name="doCopyLayer" id="4e3b0a39-dd64-4e0d-a054-d27072823d69">
        <source>doCopyLayer(_deck : CM_ShipDeck);
// ---------------------------------------------------------------------------
// Created:     16 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	currentBun, newBun : CM_ShipDeckLayer;
	pxyGraphic, clonedGraphic : CM_Graphic;
begin
	currentBun := self;
	
	create newBun transient;
	newBun.setProxy(self.code, self.description, self.remarks, _deck, true);
	
	
	foreach pxyGraphic in currentBun.allGraphics discreteLock do
		clonedGraphic := pxyGraphic.cloneSelf(true);
		pxyGraphic.CM_ROROGraphic.copyMe(clonedGraphic.CM_ROROGraphic, newBun, 0);
	endforeach;


epilog

end;</source>
        <Parameter name="_deck" type="CM_ShipDeck"/>
    </JadeMethod>
    <JadeMethod name="doOrderLayoutGraphicsSet" id="39497155-3a8e-4828-babd-f3eaf57388e2">
        <updating/>
        <source>doOrderLayoutGraphicsSet(_pxyOrder : CM_GraphicArray; _realOrder: CM_GraphicArray; _deckNum : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		take a pxy collection of graphics in the new order
//				dettach the graphics on this real terminal
//				reattach the graphic to this real termianl by going through the graphic in the new 
//				AND linking from the proxy object to the real object
// ---------------------------------------------------------------------------
vars
	aGraphic,pxyGraphic : CM_Graphic;
begin
	if _pxyOrder.size &lt;&gt; _realOrder.size then
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. Graphic arrays different sizes. (" &amp; _realOrder.String &amp; ")");
		return;
	endif;
	
	// detach
	while not _realOrder.isEmpty do
		aGraphic := _realOrder.first;
		
		// if we have just created a new polygon it will not be linked so do not dettach
		pxyGraphic := aGraphic.pxyGetProxyObject();
		if pxyGraphic = null then
			return;
		endif;

		aGraphic.CM_ROROGraphic.setLayer(null);
	endwhile;
	
	if not _realOrder.isEmpty then
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 2. Graphic array is not EMPTY!");
		return;
	endif;
	
	//attach in the new order
	foreach pxyGraphic in _pxyOrder do
		aGraphic := pxyGraphic.pxyGetRealObject();
		if aGraphic = null then
			continue;
		endif;
		aGraphic.CM_ROROGraphic.setLayer(null);
	endforeach;
	
end;</source>
        <Parameter name="_pxyOrder" type="CM_GraphicArray"/>
        <Parameter name="_realOrder" type="CM_GraphicArray"/>
        <Parameter name="_deckNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGraphicSamePoints" id="60dc5af3-0d44-4313-9792-ef9c2be91cb7">
        <source>getGraphicSamePoints(_tmpGraphic : CM_ROROGraphic) : CM_ROROGraphic;
// ---------------------------------------------------------------------------
// Created:     06 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	actualGraphic : CM_Graphic;
	actualPoint, tmpPoint : Point;
	idx, actualX, actualY, tempX, tempY : Integer;
	
begin
	if _tmpGraphic = null then
		return null;
	endif;
	
	foreach actualGraphic in self.allGraphics discreteLock do : outerLoop
		if actualGraphic.pointsPolygon.size = _tmpGraphic.pointsPolygon.size then
			foreach idx in 1 to actualGraphic.pointsPolygon.size do
				actualPoint := actualGraphic.pointsPolygon[idx];
				actualX := actualPoint.x();
				actualY := actualPoint.y();
				
				tmpPoint := _tmpGraphic.pointsPolygon[idx];
				tempX := tmpPoint.x();
				tempY := tmpPoint.y();
				
				if ((tempX &lt;&gt; actualX) or (tempY &lt;&gt; actualY)) then
					continue outerLoop;
				endif;
			endforeach;
			return actualGraphic.CM_ROROGraphic;
			
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_tmpGraphic" type="CM_ROROGraphic"/>
        <ReturnType type="CM_ROROGraphic"/>
    </JadeMethod>
    <JadeMethod name="moveLayer" id="2454191f-6388-47f1-ac1a-fdf7d899059c">
        <updating/>
        <source>moveLayer(_up : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	tmpDeck : CM_ShipDeck;
	tmpLayer : CM_ShipDeckLayer;
	objs : CM_ObjectArray;
	obj : Object;
begin
	create objs transient;

	tmpDeck := self.myShipDeck;
	tmpDeck.allDeckLayers.copy(objs);
	
	objs.moveElement(self, _up);
	// DETTACH LAYERS
//	tmpDeck.allDeckLayers.clear();
	foreach obj in objs discreteLock do
		tmpLayer := obj.CM_ShipDeckLayer;
		tmpLayer.myShipDeck := null;
	endforeach;
	// REATTACH LAYERS
	foreach obj in objs discreteLock do
		tmpLayer := obj.CM_ShipDeckLayer;
		tmpLayer.myShipDeck := tmpDeck;
	endforeach;
	
	
epilog
	delete objs;
end;</source>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f0244ae7-dea2-4e0e-b0fa-6851a0a178c9">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     22 December 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20/04/2011		cnwmh5			PAR #27401 - Add code to handle prossible exceptions occurring when
//									trying to create the proxy
// ---------------------------------------------------------------------------

vars
	pxyMe : SelfType;
	completedOK		: Boolean;
begin
	pxyMe := inheritMethod();

	pxyMe.myShipDeck := self.myShipDeck.pxyGetProxyObject();
	if pxyMe.myShipDeck = null then
		pxyMe.myShipDeck := self.myShipDeck;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
