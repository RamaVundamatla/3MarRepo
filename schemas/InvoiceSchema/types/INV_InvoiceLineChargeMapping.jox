    <JadeMethod name="doCmbBankBuild" id="949ce6e7-bda8-41fe-81cd-77b81e338ddb">
        <source>doCmbBankBuild();
//	35874 build combo for business unit query
vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCmbBusinessUnitBuild" id="d91ed263-90fc-494f-a7a3-8ac062c4f575">
        <source>doCmbBusinessUnitBuild();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	combo, combo2 : CMUI_ComboBox;
	idx : Integer;
	company : CM_Bank;
begin

	combo := self.cmbParentObject;
	combo.clear;
	combo2 := self.cmbParentCopy;
	combo2.clear;
	foreach company in self.myTerminal.companies do
		if company.isBusinessUnit then
			idx := combo.addItem(company.code &amp; " - " &amp; company.mailingName);
			combo.itemObject[idx] := company;
			idx := combo2.addItem(company.code);
			combo2.itemObject[idx] := company;
		endif;
	endforeach;



end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCarrierBuild" id="638d1ad4-61dc-4527-87a1-6d92638eecdc">
        <source>doCmbCarrierBuild();
// 24094 add Carrier to Invoice Line Description
vars
	combo, combo2 : CMUI_ComboBox;
	idx : Integer;
	aCarrier : CM_Carrier;
begin

	combo := self.cmbParentObject;
	combo.clear;
	combo2 := self.cmbParentCopy;
	combo2.clear;
	foreach aCarrier in app.myRoot.allCarriers discreteLock do
		if not aCarrier.isNotAvailableForEntry then
			idx := combo.addItem(aCarrier.description);
			combo.itemObject[idx] := aCarrier;
			idx := combo2.addItem(aCarrier.description);
			combo2.itemObject[idx] := aCarrier;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbChargeComBuild" id="707426d3-512f-4e59-a63f-20b81f1d1a8c">
        <source>doCmbChargeComBuild();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	combo : CMUI_ComboBox;
begin
	combo := self.cmbChargeTypeCom;
	self.doCmbChargesBuild(combo); // PAR 17557
	
end;</source>
    </JadeMethod>
