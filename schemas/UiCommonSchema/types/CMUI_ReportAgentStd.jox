    <JadeMethod name="doLoadLogTxnTypes" id="b482d916-93dc-4b9f-b045-14ca5c351114">
        <source>doLoadLogTxnTypes(_cmb : CMUI_ComboBox input; _txnTypeDescription : String) protected;
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 8/6/2009 cnwsh3 PAR19843 Add Docket Correction Transaction as option for transaction reporting.
vars

begin
	
	_cmb.clear();
	
	_cmb.itemData[_cmb.addItem('Receive Road')] 					:= TRANS_TYPE_REC_ROAD;
//	_cmb.itemData[_cmb.addItem('Receive Road Inter Terminal')] 		:= TRANS_TYPE_REC_ROAD_INTER_TERM;
	_cmb.itemData[_cmb.addItem('Receive Rail')] 					:= TRANS_TYPE_REC_RAIL;
//	_cmb.itemData[_cmb.addItem('Receive Rail Inter Terminal')] 		:= TRANS_TYPE_REC_RAIL_INTER_TERM;
	_cmb.itemData[_cmb.addItem('Receive Ship')] 					:= TRANS_TYPE_REC_SHIP;
	
	_cmb.itemData[_cmb.addItem('Release Road')] 					:= TRANS_TYPE_REL_ROAD;
//	_cmb.itemData[_cmb.addItem('Release Road Inter Terminal')] 		:= TRANS_TYPE_REL_ROAD_INTER_TERM;
	_cmb.itemData[_cmb.addItem('Release Rail')] 					:= TRANS_TYPE_REL_RAIL;
//	_cmb.itemData[_cmb.addItem('Release Rail Inter Terminal')] 		:= TRANS_TYPE_REL_RAIL_INTER_TERM;
	_cmb.itemData[_cmb.addItem('Release Ship')] 					:= TRANS_TYPE_REL_SHIP;
	
	_cmb.itemData[_cmb.addItem('Operator Change')] 			:= TRANS_TYPE_OperatorChange;
	_cmb.itemData[_cmb.addItem( app.getErrorString(Product) &amp;' Change')] 			:= TRANS_TYPE_ProductCodeChange;
	_cmb.itemData[_cmb.addItem('Edit')] 					:= TRANS_TYPE_EDIT;
	_cmb.itemData[_cmb.addItem('Docket Correction')] 		:= TRANS_TYPE_DocketCorrection;//8/6/2009 - cnwsh3 PAR19843
	_cmb.itemData[_cmb.addItem('Disassembly')] 				:= TRANS_TYPE_DISASSEMBLY;
	_cmb.itemData[_cmb.addItem('No-Number Offload')] 		:= TRANS_TYPE_LogNoNumberOffload;
	_cmb.itemData[_cmb.addItem('No-Number Retain')] 		:= TRANS_TYPE_LogNoNumberRetain;
	_cmb.itemData[_cmb.addItem('No-Number Swap')] 			:= TRANS_TYPE_LogNoNumberSwap;
	_cmb.itemData[_cmb.addItem('Move')] 					:= TRANS_TYPE_MOVE;
	_cmb.itemData[_cmb.addItem('Reject Transactions')] 		:= TRANS_TYPE_REJECT;
//	_cmb.itemData[_cmb.addItem('Re-instate Reject')] 		:= TRANS_TYPE_ProductCodeChange;	PAR 8638  JC
	_cmb.itemData[_cmb.addItem('Re-instate Reject')] 		:= TRANS_TYPE_ReinstateReject;
	
	if _txnTypeDescription &lt;&gt; null then
		_cmb.text := _txnTypeDescription;
	else
		_cmb.listIndex := 1;
	endif;
	self.setValueByName(ETRow_LogTxnType, _cmb.text);

end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_txnTypeDescription" type="String"/>
    </JadeMethod>
