    <JadeMethod name="utlUpdateMachineStatus" id="54a34451-12ef-4c2b-a1b8-11840732c02a">
        <source>utlUpdateMachineStatus(_machine : CM_Machine input;
					   _newStatus : Integer;
					   _availCode : String;
					   _fromLogOn : Boolean;
					   _passport : CM_Passport input);

// cnwdvb1 27 March 2003 
/*

Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18915 - Removed Auditing fom this method (now in utlUpdateMachineStatusAudited)
					to reduce overhead/contention in Move transactions

*/

vars

begin
	self.initialiseActivity();
	
	if _passport.noErrors then
		_machine.setMachineStatus(_newStatus, _availCode, _fromLogOn);
	endif;

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_availCode" type="String"/>
        <Parameter name="_fromLogOn" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMachineStatusAudited" id="5aeaf70d-cd73-42f3-93a0-929d63a1c15d">
        <source>utlUpdateMachineStatusAudited(_machine : CM_Machine input;
							  _newStatus : Integer;
							  _availCode : String; 
							  _fromLogOn : Boolean;
							  _passport : CM_Passport input);

/*

Purpose:			Update the passed in Machine status, auditing the changes

Return Value:		None


Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18915 - Created to allow existing method to be called without Auditing

*/

vars

begin
	self.initialiseActivity();

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_machine, true);
	endif;
	
	if _passport.noErrors then
		//epr TFS 4620 16/6/17
		if _machine.loggedOn and _newStatus = STATUS_OFFLINE then
			_machine.addInfoToHistory(CM_MachineInfoHistory.InfoType_ControlReset, null, null,null);		
		endif;
		self.utlUpdateMachineStatus(_machine,
									_newStatus,
									_availCode,
									_fromLogOn,
									_passport);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_machine, false);
	endif;

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_availCode" type="String"/>
        <Parameter name="_fromLogOn" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
