    <JadeMethod name="doHandleNotification" id="3b714afb-079e-4049-8d79-eb0f00bb4d13">
        <source>doHandleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	testEdition	: Integer;
	rowIndex : Integer;
	isInvalid	: Boolean;
	isPlanned : Boolean;
	str : String;
	result : CM_TestAutoPlanResult;

begin

	if theObject = null or not theObject.isKindOf( CM_TrackedItem ) then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, ti, isInvalid);
	ti := theObject.CM_TrackedItem;
	// 34605 check that ti is valid
	testEdition := ti.edition;
	if isInvalid then
		return;
	endif;
	
	if not self.allNotableTis.includes( ti ) then
		return;
	endif;
	
	self.tblSelected.findObjectInRow( ti, rowIndex );
	if rowIndex &lt; 1 then
		return;
	endif;
	str := ti.getAttributeStringForDefArray(self.tblSelected.allTblDataEntRows);
	isPlanned := ti.myPrimaryPlannedLocation &lt;&gt; null;
	if isPlanned then
		self.tblSelected.accessRow( rowIndex ).backColor := Grey;
		result := self.myTestAutoPlanRoot.getResultFor(ti);
		if result = null then
			return;
		endif;
		if result.isFailed then
			self.refreshTable( self.tblFailed, true );
		elseif result.isPlanned then
			self.refreshTable( self.tblWouldPlan, true );
		endif;
	else
		self.tblSelected.accessRow( rowIndex ).backColor := White;
		
	endif;
	
	

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="a6ec1870-ef39-43e8-8e45-192e2314a7cb">
        <updating/>
        <source>doRefresh() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin
	
	self.shtSelected.setFocus();
	
	self.refreshTable( self.tblSelected, false );
	self.refreshTable( self.tblWouldPlan, true );
	self.refreshTable( self.tblFailed, true );
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="3cf29157-3e08-4de2-8975-e86338afa776">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	vGap : Real;
	vLeft : Real;

begin

	vGap := self.btnClose.left - self.btnClear.left;
	vLeft := ( vGap / 2 ) + self.btnClear.left;
	self.btnTestAP.left := vLeft;

	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblFailedDragTrackedItem" id="7fca8ab5-823b-4104-a173-827390669459">
        <updating/>
        <source>doTblFailedDragTrackedItem() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	result : CM_TestAutoPlanResult;
	theTI : CM_TrackedItem;
	pic : Picture;
	
begin

	result := self.tblFailed.accessRow( self.tblFailed.row ).itemObject.CM_TestAutoPlanResult;
	if result &lt;&gt; null and
	   result.myTrackedItem &lt;&gt; null then
	   theTI := result.myTrackedItem;
	else
		return;
	endif;
	
	app.myDraggedTrackedItem := theTI;
	self.moveTrackedItem(theTI);
	self.tblFailed.dragMode := DragMode_Drag;

	create pic transient;
	self.setPictureDragCursor(pic);
	if pic.picture &lt;&gt; null then
		self.tblFailed.dragCursor := pic.picture;
	endif;

epilog
	if pic &lt;&gt; null then
		delete pic;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTestAutoPlan" id="8680b9c3-85d0-46ac-abb3-5fce21516bf6">
        <updating/>
        <source>doTestAutoPlan( term : CM_Terminal ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	terminal : CM_Terminal;
	iter : Iterator;
	result : CM_TestAutoPlanResult;
	planSize : Integer;
	failSize : Integer;

begin

	self.fldMain.topSheet := self.shtSelected;
	self.fldMain.doWindowEvents(0);

	terminal := self.cmbTerminal.listObject.CM_Terminal;
	if terminal = null then
		app.msgBox(app.getErrorString(Must_select_valid_term), app.getErrorString(Error), MsgBox_OK_Only);
		self.cmbTerminal.setFocus();
		return;
	endif;

	self.clearWouldPlanAndFailed();

	self.myTestAutoPlanRoot.doTestAutoPlan( self.tblSelected,	//_tblSelected : Table input;
											null,	//_alternateSelection : CM_TIArray input;
											terminal,	//_terminal : CM_Terminal;
											null,	//_terminalArea : CM_TerminalArea
											true
											);
											
	iter := myTestAutoPlanRoot.allTestAutoPlanResults.createIterator;	
	while iter.next( result ) do
		if result.isFailed then
			self.tblFailed.addItemObject( result, result.getAttributeStringForDefArray(self.tblFailed.allTblDataEntRows) );
		elseif result.isPlanned then
			self.tblWouldPlan.addItemObject( result, result.getAttributeStringForDefArray(self.tblWouldPlan.allTblDataEntRows) );
		endif;
	endwhile;
	
	planSize := self.tblWouldPlan.rows - self.tblWouldPlan.fixedRows;
	self.shtResults.caption := "(x" &amp; planSize.String &amp; ") " &amp; app.getErrorString(Would_plan);
	
	failSize := self.tblFailed.rows - self.tblFailed.fixedRows;
	self.shtFail.caption := "(x" &amp; failSize.String &amp; ") " &amp; app.getErrorString(Failed_test_plan);
	
	if failSize &gt; 0 then
		self.fldMain.topSheet := self.shtFail;
	elseif planSize &gt; 0 then
		self.fldMain.topSheet := self.shtResults;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getSelectedResultTIs" id="0a93159c-79bf-46ca-830f-9cf2e2aae9d5">
        <source>getSelectedResultTIs( _table : CM_DataTable; _tiArray : CM_TIArray input ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	iter : Iterator;
	obj : Object;
	result : CM_TestAutoPlanResult;
	invalidObject : Boolean;
	ti : CM_TrackedItem;

begin

	if _table = null then
		return;
	endif;
	
	if _table.allSelectedObjects.isEmpty then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, result, invalidObject );
	
	iter := _table.allSelectedObjects.createIterator;
	while iter.next( obj ) do
		result := obj.CM_TestAutoPlanResult;
		invalidObject := false;
		ti := result.myTrackedItem;
		if invalidObject then
			continue;
		endif;
		if ti &lt;&gt; null then
			_tiArray.addExclusive(ti);
		endif;
	endwhile;
	
epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTableColumFilters" id="12c5b02e-ac73-4bb0-a15c-f81cb39c5da8">
        <updating/>
        <source>getTableColumFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	self.allColumnFilters.cloneFiltersForTable( _table, _allFilterColumns );

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="ce94c925-aa1b-4f39-b257-fe09a870b7b5">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	theXML		: String;

begin
	
	theXML := inheritMethod();
	
	theXML := theXML &amp; self.tblFailed.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblSelected.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblWouldPlan.getXmlStrForColumns(true);
	
	return theXML;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initTables" id="b80d72c1-5e53-458c-b602-63afc59cf9d9">
        <updating/>
        <source>initTables() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	ti : CM_TrackedItem;

begin

	while true do
		if self.allNotableTis.isEmpty then
			break;
		endif;
		ti := self.allNotableTis.first;
		self.removeNotableTi( ti );
	endwhile;

	// set up the Selected Cargo table.
	self.tblSelected.clear();
	self.tblSelected.fixedRows := 1;
	self.tblSelected.rows := self.tblSelected.fixedRows;
	self.tblSelected.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblSelected.multiSelect := CM_BaseTable.MultiSelect_Simple;
	
	self.tblSelected.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_CargoEnqDefaultData));
	self.tblSelected.setForm (self);
	self.shtSelected.caption := app.getErrorString(Selected_Cargo);
	
	// set up the results tables.
	self.clearWouldPlanAndFailed();
	
epilog
	
end;</source>
