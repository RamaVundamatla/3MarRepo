    <JadeMethod name="utlCreateCashPayment" id="b19883d8-e38c-4143-8cc6-fdd0b9c6f3c2">
        <source>utlCreateCashPayment(_proxyCashPayment : CM_CashPayment; _passport : CM_Passport input) : CM_CashPayment;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		TFS		Reason
20 Jul 2012	cnwndl1			Initial creation
12 Jul 2019	jlgdi1	45301	Added code for audit purposes
*/

vars
	newCashPayment : CM_CashPayment;

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCashPayment(_proxyCashPayment);

	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create newCashPayment persistent;
	newCashPayment.setForCreate(_proxyCashPayment);
	
	// TFS 45301
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(newCashPayment);
	endif;
	
	return newCashPayment;
end;</source>
        <Parameter name="_proxyCashPayment" type="CM_CashPayment"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCashPrintProforma" id="0ce8283c-bc90-4869-bab1-1adb0f5dcf5f">
        <source>utlCreateCashPrintProforma(	_proxyCashReceiptProforma : CM_CashReceiptProformaPrint; 
							_newCashReceiptProforma : CM_CashReceiptProformaPrint output; 
							_passport : CM_Passport input	);
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------------------------
10/08/2017	jlgdap1		Initial creation TFS 5740 AAT Changes to Pro Forma Invoices
12 Jul 2019	jlgdi1		TFS 45301 Added code for audit purposes
*/

vars
	seqNum : Integer;
	ti : CM_TrackedItem;
	realReceipt : CM_CashReceiptProformaPrint;
	payment, newPayment : CM_CashPayment;
	proxyPayment, realPayment : CM_CashPaymentProformaPrint;
	paymentsToDelete : ObjectArray;
	a1090Causer : CM_TrackedItem;
	voyage : CM_Voyage;

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCashReceipt(_proxyCashReceiptProforma);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	// see if the debtor already has a cash receipt proforma print
	ti := _proxyCashReceiptProforma.allTrackedItems.first;
	if ti &lt;&gt; null then // TFS 37454
		foreach payment in ti.allCashPaymentProformaPrints where payment.myDebtorTerminal = _proxyCashReceiptProforma.myDebtorTerminal do
			seqNum := payment.myCashReceipt.sequenceNum;
			break;
		endforeach;
	else // TFS 37454
		voyage := _proxyCashReceiptProforma.myVoyage; // TFS 37454
		if voyage &lt;&gt; null then // TFS 37454
			foreach payment in voyage.allCashPaymentProformaPrints where payment.myDebtorTerminal = _proxyCashReceiptProforma.myDebtorTerminal do
				seqNum := payment.myCashReceipt.sequenceNum;
				break;
			endforeach;
		endif;
	endif;
	realReceipt := _proxyCashReceiptProforma.myDebtorTerminal.allCashReceiptProformaPrints[seqNum].CM_CashReceiptProformaPrint;
	if realReceipt = null then
		create _newCashReceiptProforma persistent;
	else
		_newCashReceiptProforma := realReceipt;
	endif;
	
	// delete any existing proforma payments for the tracked items and debtor involved 
	create paymentsToDelete transient;
	foreach ti in _proxyCashReceiptProforma.allTrackedItems do
		foreach payment in _newCashReceiptProforma.allCashPayments do
			if payment.myTrackedItem = ti and payment.myDebtorTerminal = _newCashReceiptProforma.myDebtorTerminal then
				paymentsToDelete.addExclusive(payment);
			endif;
		endforeach;

		if ti &lt;&gt; null then // TFS 37454

			foreach newPayment in _proxyCashReceiptProforma.allCashPayments do
				foreach payment in ti.allCashPaymentProformaPrints do
					if payment.proformaDesc = newPayment.proformaDesc and payment.cashValue = newPayment.cashValue then
						paymentsToDelete.addExclusive(payment);
					endif;
				endforeach;
			endforeach;
		endif;
	endforeach;
	// double-check for any minimum charge lines that we also need to delete - these have no TI 
	foreach payment in _newCashReceiptProforma.allCashPayments do
		foreach newPayment in _proxyCashReceiptProforma.allCashPayments do
			if payment.proformaDesc = newPayment.proformaDesc and payment.cashValue = newPayment.cashValue then
				paymentsToDelete.addExclusive(payment);
			endif;
		endforeach;
	endforeach;
	// now delete all the over-written or no longer valid (because they've moved to a new debtor) payments
	paymentsToDelete.purge();

	_newCashReceiptProforma.setForCreate(_proxyCashReceiptProforma);
	foreach payment in _proxyCashReceiptProforma.allCashPayments do
		proxyPayment := payment.CM_CashPaymentProformaPrint;
		create realPayment persistent;
		realPayment.setForUpdate(proxyPayment);
		realPayment.setCashReceipt(_newCashReceiptProforma);
	endforeach;
	
	// TFS 45301
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newCashReceiptProforma);
	endif;
	
epilog
	delete paymentsToDelete;
end;</source>
        <Parameter name="_proxyCashReceiptProforma" type="CM_CashReceiptProformaPrint"/>
        <Parameter name="_newCashReceiptProforma" type="CM_CashReceiptProformaPrint" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCashReceipt" id="bb926f9d-995c-4759-a246-f7d142ed0e87">
        <source>utlCreateCashReceipt(_proxyCashReceipt : CM_CashReceipt; _newCashReceipt : CM_CashReceipt output; _comments : String; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
20 July 2012	cnwndl1	Initial creation	Par 29968
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels

*/

vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCashReceipt(_proxyCashReceipt);

	if not self.checkValidationWithPassport(_passport) then
		app.invLog(method.qualifiedName &amp; " Validation Tripped ", LogTRACE.String); // LOG CASH
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _newCashReceipt persistent;

	_newCashReceipt.setForCreate(_proxyCashReceipt);
	
	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_newCashReceipt); // TFS 44275
	
	if _newCashReceipt.myCashInvoice&lt;&gt; null then
		if _comments &lt;&gt; "" then
			_newCashReceipt.myCashInvoice.narration := _comments[1:640];		// 36165, limit from 37141
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxyCashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_newCashReceipt" type="CM_CashReceipt" usage="output"/>
        <Parameter name="_comments" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCashReceiptPayments" id="2510dd69-bbe5-4306-ac56-e1f3fd2270f3">
        <source>utlCreateCashReceiptPayments(_proxyCashReceipt   : CM_CashReceipt  input; 
							 _newCashReceipt     : CM_CashReceipt  output; 
							 _allPxyCashPays     : ObjectArray;
							 _allRealCashPays    : ObjectArray     input;
							 _comments           : String; 
							 _passport 			 : CM_Passport     input);
/*
Purpose:	TFS 45953	refactor receipt and payments code into a UTL
Date				Who			Reason
   Sep 2019		    JLGAB1 initial creation
30 Jan 2020         cnwma1 Bug 48416: ADP - Invoice lines not going to expected cash invoice
22 Feb 2021         cnwma1 Bug 50843: GUQ - Error 1090 in Cash Collection while trying to save
*/

vars
	invoice		   : CM_Invoice;
	pxyObj 		   : Object;
	pxyCashPay     : CM_CashPayment;
	newCashPayment : CM_CashPayment;
	allPxyCashPays : ObjectArray;
	term           : CM_Terminal;
	invOnEveryRec  : Boolean; //20/08/2025	navkc1 JIRA MTN 35791
begin

	// Perform the operation
	if _proxyCashReceipt &lt;&gt; null then	// 33520 create a cash receipt if there is a proxy, even if zero value
		app.myUtilityCA.utlCreateCashReceipt(_proxyCashReceipt, _newCashReceipt,_comments, _passport); // PAR 36165
	endif;
	
	term := _passport.myTerminal; //20/08/2025	navkc1 JIRA MTN 35791
	
	if term &lt;&gt; null then
		invOnEveryRec := term.getConfig(CashInvoiceEveryReceipt).Boolean; //20/08/2025	navkc1 JIRA MTN 35791
	endif;
	
	if _allPxyCashPays &lt;&gt; null and not _allPxyCashPays.isEmpty then
		// 32851 if there is a new cash receipt and the terminal cash invoice type is set, there will be a new invoice created for the
		//	cash receipt invoice lines.  Get it and update the cash payment proxies to use this.
		if _newCashReceipt &lt;&gt; null then
			invoice := _newCashReceipt.myCashInvoice;
			
			allPxyCashPays := _allPxyCashPays; 								// TFS 44275
			_newCashReceipt.createTaxLinesAndPaymentProxy(allPxyCashPays);  // TFS 44275
			_newCashReceipt.createRoundingDifferenceLine(allPxyCashPays);   // TFS 44275

		endif;
	
		foreach pxyObj in _allPxyCashPays do
			if not _passport.noErrors then
				return;
			endif;
			pxyCashPay := pxyObj.CM_CashPayment;
			
			// 22.02.2021 cnwma1 #50843
			if invoice = null then
				//term := _passport.myTerminal; //20/08/2025	navkc1 JIRA MTN 35791 Moved to top, outside loop
				//if term &lt;&gt; null and not term.getConfig(CashInvoiceEveryReceipt).Boolean then
				if not invOnEveryRec then //20/08/2025	navkc1 JIRA MTN 35791
					if pxyCashPay.myTrackedItem &lt;&gt; null then
						invoice := pxyCashPay.myTrackedItem.getCashInvoice();
					endif;
				endif;
			endif;
			// 22.02.2021 cnwma1 #50843
			
			// 33885 set payment link to receipt
			if _newCashReceipt &lt;&gt; null then
				pxyCashPay.setCashReceipt(_newCashReceipt);		// populates receipt.allCashPayments
			endif;
			
			newCashPayment := pxyCashPay.pxyGetRealObject.CM_CashPayment;
			
				
			if invoice &lt;&gt; null then                 // 30.01.2020 cnwma1 #48416
				pxyCashPay.pxySetInvoice(invoice);
			endif;
			
			if newCashPayment = null then
				newCashPayment := app.myUtilityCA.utlCreateCashPayment(pxyCashPay, _passport);
			else
				app.myUtilityUA.utlUpdateCashPayment(pxyCashPay, _passport);
			endif;
			
			if newCashPayment &lt;&gt; null then
				_allRealCashPays.add(newCashPayment);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_proxyCashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_newCashReceipt" type="CM_CashReceipt" usage="output"/>
        <Parameter name="_allPxyCashPays" type="ObjectArray"/>
        <Parameter name="_allRealCashPays" type="ObjectArray" usage="input"/>
        <Parameter name="_comments" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
