    <JadeMethod name="btnRemove_click" id="079e632a-3aee-4e8d-b72b-43f0dcde20f5">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemove_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
	rate : CM_InvoiceContractRateEntry;
begin
	 // ### TFS BUG 61374 27NOV2023 NAVAB1
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;

	rate := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContractRateEntry;
	
	if rate = null then
		self.tblData.removeItem(self.tblData.row);
	else
		self.doRemove(rate);
		self.tblDisplayRow();
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
