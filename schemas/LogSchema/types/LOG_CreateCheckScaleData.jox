    <JadeMethod name="initTblDetail" id="c79c447e-b49a-4310-a385-699e2ce3e142">
        <source>initTblDetail();
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	self.tblDetail.setColumnHeadingsFromDef(ETDef_ScaleDetailEnt, false);
	self.tblDetail.selectMode := Table.SelectMode_CurrentRow;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblEntDetail" id="c14a256c-bf77-4d19-a5a7-176c5adbff0a">
        <source>initTblEntDetail();
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;

begin

	theTable := self.tblEntDetail;
	
	entTableDef := app.myController.getEntTableDef(ETDef_ScaleDetailEnt);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(200);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef FullReleaseFind not found');
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblEntHeader" id="8cf88553-ecaa-40ac-b99a-213b924ebb4e">
        <source>initTblEntHeader();
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;

begin

	theTable := self.tblEntHeader;
	
	entTableDef := app.myController.getEntTableDef(ETDef_ScaleHdrEnt);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(200);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef FullReleaseFind not found');
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="b19fcea3-e84b-4be9-b85d-f0d7d2a815d5">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	
	self.setColorsForTable(self.tblDetail);
	self.setColorsForEntryTable(self.tblEntDetail);
	self.setColorsForEntryTable(self.tblEntHeader);

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5616d330-9e71-4a09-a699-422711525b60">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	dateTime		: TimeStamp;

begin
	inheritMethod();
	create self.myCheckScaleHdr transient;
	
	self.initForm();
	
	dateTime := self.systemToLocalTime(app.actualTimeServer());// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.tblEntHeader.setValueByName(ETRow_UserCode, app.getMyUser.code);
	self.tblEntHeader.setValueByName(ETRow_Date, dateTime.date);
	self.tblEntHeader.setValueByName(ETRow_Time, dateTime.Time);
		
	self.tblEntDetail.goToRowByName(ETRow_LogId);
	self.tblEntDetail.setFocus();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5e11c06f-7124-4280-9a4e-0241cbfd9df3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006308, locale);
	btnAdd.translateCaption(Xlat_0002344, locale);
	btnClose.translateCaption(Xlat_0002342, locale);
	btnRemove.translateCaption(Xlat_0002341, locale);
	btnSave.translateCaption(Xlat_0002343, locale);
	cMUI_Label3.translateCaption(Xlat_0002340, locale);
	lblDetails.translateCaption(Xlat_0002345, locale);
	lblHdrInfo.translateCaption(Xlat_0002346, locale);
end;</source>
    </JadeMethod>
