/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

	rowIndex : Integer;
	gridStackHeight : CM_GriddedTAStackHeight;

begin

	rowIndex := self.tblExtraList.row;
	if rowIndex &gt; self.tblExtraList.fixedRows and rowIndex &lt;= self.tblExtraList.rows then
		gridStackHeight := self.tblExtraList.accessRow( rowIndex).itemObject.CM_GriddedTAStackHeight;
		self.displayStackHeightCriteria( gridStackHeight );
	endif;

epilog

end;</source>
