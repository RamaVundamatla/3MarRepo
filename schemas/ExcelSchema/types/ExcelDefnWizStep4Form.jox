    </ImplicitInverseRef>
    <JadeMethod name="getFileName" id="ac2564a1-73d4-4c10-af18-3fe61ae7a066">
        <source>getFileName() : String;

/*****************************************************
	Written by	:	cnwpra1		06 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	cmd			: CMDFileOpen;
	file		: File;

begin
	
	create cmd;
	cmd.dialogTitle := 'Select the workbook to load';
	cmd.fileMustExist := true;
	cmd.initDir := app.getJadeInstallDir;
	cmd.fileTitle := myDA.myWorkbookDefinition.workbookName;
	cmd.filter := 'Excel workbooks|*.xls';
	cmd.createPrompt := false;
	cmd.defaultExt := '.xls';
	
	if cmd.open = 0 then
		if cmd.readOnly then
			app.msgBox('The selected file must not be read only. The file will be updated by changes made while Excel is open.', 
							'Selected File', MsgBox_OK_Only);
			return null;
		endif;
		
		create file;
		file.usePresentationFileSystem := true;
		file.fileName := cmd.fileName;
		file.mode := File.Mode_IO;
		file.kind := File.Kind_Binary;
		file.allowReplace := true;
		file.shareMode := File.Share_Exclusive;
		
		if not file.tryOpen then
			app.msgBox('The selected file could not be opened for input-output. The file will be updated by changes made while Excel is open.', 
							'Selected File', MsgBox_OK_Only);
			return null;
		endif;
		
		return cmd.fileName;
	else
		return null;
	endif;

epilog
	delete cmd;
	delete file;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadForm" id="605c60d8-a00a-45f5-8c5d-e39fd6946689">
        <updating/>
        <source>loadForm() updating;

/*****************************************************
	Written by	:	cnwpra1		07 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	inheritMethod();
	
	if myDA.hasExistingWorkbook then
		optOpenExisting.caption := 'Work with existing workbook';
		optOpenNew.caption := 'Replace existing workbook';
	else
		optOpenExisting.caption := 'Open Excel from an existing file';
		optOpenNew.caption := 'Open Excel with a new workbook';
	endif;
	
	lblWarning.caption := 'When Excel is open it is interacting with the Wizard.' &amp; CrLf &amp; CrLf &amp;
							'At the end of the definition process, pressing the Finish button will save the definition and close Excel automatically. Similarly if you Cancel or close a Wizard form (using the control box), this will also automatically close Excel.' &amp; CrLf &amp; CrLf &amp;
							'If you close Excel yourself you will lose any updates you may have made to the workbook.';

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProcessingParameters" id="b57a54ef-7316-4cf6-8df1-3343086d8437">
        <updating/>
        <source>setProcessingParameters() updating;

/*****************************************************
	Written by	:	cnwpra1		09 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	fileName	: String;

begin
	if myDA.hasExistingWorkbook then
		myDA.setBlnUpdateWorkbook(optOpenExisting.value);
		myDA.setBlnReplaceWorkbook(optOpenNew.value);
		myDA.setBlnOpenExistingFile(false);
		myDA.setBlnNewWorkbook(false);
	else
		myDA.setBlnOpenExistingFile(optOpenExisting.value);
		myDA.setBlnNewWorkbook(optOpenNew.value);
		myDA.setBlnUpdateWorkbook(false);
		myDA.setBlnReplaceWorkbook(false);
	endif;
	
	myDA.setFileName(null);
	
	if myDA.fileRequired then
		fileName := getFileName;
		
		if fileName = null then		// they selected cancel
			blnError := true;		// tell the superclass
			return;
		endif;
		
		myDA.setFileName(fileName);
	endif;

epilog

end;</source>
    </JadeMethod>
</GUIClass>
