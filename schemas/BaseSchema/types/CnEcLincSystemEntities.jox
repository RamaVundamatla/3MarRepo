    <JadeMethod name="deleteExceptionHandler" id="78c8573b-5137-4804-bac2-fedf403da0e9">
        <updating/>
        <source>deleteExceptionHandler(e:Exception):Integer updating;

begin
	//	if e.isKindOf(LockException) then
	if e.errorCode = 1027 then
		abortTransaction;
		app.msgBox(	'This instance is locked by another user' &amp; CrLf &amp;
					'so it can not be deleted now,  try again later.',
					self.display(),
					MsgBox_OK_Only + MsgBox_Information_Icon);
		return Ex_Abort_Action;
	endif;

	// If someone else has already deleted our target instance, then thats OK!
	if e.errorCode = 4 then			// Object not found
		app.msgBox(	'Warning! Object ' &amp; self.display() &amp;
					'has already been deleted.',
					self.display(),
					MsgBox_OK_Only + MsgBox_Information_Icon);
		return Ex_Continue;
	endif;

	// Anything else, propage error throgh handlers
	return Ex_Pass_Back;
end;</source>
        <Parameter name="e" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="readExceptionHandler" id="5fe765ad-f16f-44bf-9629-7f13abf4d43e">
        <updating/>
        <source>/*******************************************************
*
* Description :	Trap exceptions when reading database
*				objects
*
* Parameters :	e		Exception code
*
* Return :		Indicates following action :
*				continue | abort | propagate error
*
* Notes :		Modified from handler produced by Jade
*				Form Wizard
*
* History :		rmb	12/12/96	Initial version
*
*******************************************************/
readExceptionHandler(e:Exception):Integer updating;
begin
	//	if e.isKindOf(LockException) then
	if e.errorCode = 1027 then
		endLoad;
		app.msgBox(	'This instance is locked by another user' &amp; CrLf &amp;
					'so it can not be read now, try again later.',
					self.display(),
					MsgBox_OK_Only + MsgBox_Information_Icon);
		return Ex_Abort_Action;
	endif;

	if e.errorCode = 4 then			// Object not found
		endLoad;
		abortTransaction;
		app.msgBox(	'This instance has now been deleted by another' &amp; CrLf &amp;
					'user, therefore it can not be displayed.',
					self.display(),
					MsgBox_OK_Only + MsgBox_Information_Icon);
		return Ex_Abort_Action;
	endif;

	// Anything else, propage error throgh handlers
	return Ex_Pass_Back;
end;</source>
        <Parameter name="e" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="saveExceptionHandler" id="dbd572b2-2d51-4923-b2ab-b1bd9db093e4">
        <updating/>
        <source>/*******************************************************
*
* Description :	Trap exceptions when saving database
*				objects (creating OR updating)
*
* Parameters :	e		Exception code
*
* Return :		Indicates following action :
*				continue | abort | propagate error
*
* Notes :		Modified from handler produced by Jade
*				Form Wizard
*
* History :		rmb	12/12/96	Initial version
*
*******************************************************/
saveExceptionHandler(e:Exception):Integer updating;
begin
	//	if e.isKindOf(LockException) then
	if e.errorCode = 1027 then			// Object locked
		abortTransaction;
		app.msgBox(	'This instance is locked by another user, try again later.',
					self.display(),
					MsgBox_OK_Only + MsgBox_Information_Icon);
		return Ex_Abort_Action;
	endif;

	if e.errorCode = 1310 then		// Key already in dictionary
		abortTransaction;
		app.msgBox(	e.text(),
					self.display(), 
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return Ex_Abort_Action;
	endif;

	if e.errorCode = 4 then			// Object not found
		app.msgBox(	'This instance has now been deleted by another' &amp; CrLf &amp;
					'user, therefore it can not be updated.',
					self.display(),
					MsgBox_OK_Only + MsgBox_Information_Icon);
		return Ex_Abort_Action;
	endif;

	// Anything else, propage error throgh handlers
	return Ex_Pass_Back;
end;</source>
        <Parameter name="e" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
