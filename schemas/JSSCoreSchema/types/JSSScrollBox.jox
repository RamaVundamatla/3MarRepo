    <JadeMethod name="alterField" id="6874f039-2ba7-4470-9acc-d8b095d998dd">
        <updating/>
        <source>alterField(pIsIncrement:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Adjusts the displayed field value, either by incrementing or
//				decrementing the value shown.
//
// Parameters:	pIsIncrement - If true, the field will be incremented, otherwise
//					it will be decremented.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsIncrement then
		self.setScrollValue(self.getValue() + 1);
	else
		self.setScrollValue(self.getValue() - 1);
	endif;
	
	self.selectFieldNumber(self.getCurrentFieldNumber());
end;</source>
        <access>protected</access>
        <Parameter name="pIsIncrement" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="click" id="c2108608-67c1-4594-8f4c-0d7da35bd52b">
        <updating/>
        <source>click(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.selectFieldNumber(self.getCurrentFieldNumber());
epilog
	inheritMethod(textbox);
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="decrementField" id="d9052bd8-d515-427c-ad14-92d746f2b478">
        <updating/>
        <source>decrementField() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Decrements the displayed field value.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.alterField(false);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getCurrentFieldNumber" id="d99f578f-645d-4c1e-b211-fbae63f423ee">
        <source>getCurrentFieldNumber():Integer protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Returns the field number that is currently being edited.
//
// Parameters:	None
//
// Returns:		The number of the field.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fieldNumber		: Integer;
	textPosition	: Integer;
	
begin
	// Return the currently selected field number by counting the ':' characters preceding selStart.
	
	fieldNumber	:=	1;
	
	// Start just after CrLf.
	
	foreach textPosition in 3 to self.selStart do
		if self.text[textPosition:1] = ":" then
			fieldNumber	:=	fieldNumber + 1;
		endif;
	endforeach;
	
	return fieldNumber;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFieldValue" id="1275f3a8-0b41-495b-86c0-f7440e18a5e3">
        <source>getFieldValue(pFieldNo:Integer):Integer protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Returns the value of the specified field.
//
// Parameters:	pFieldNo - The number of the field who's value to return.
//
// Returns:		The value of the requested field.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 04/12/2001	cnwdad1		Changed to check whether the textbox already has a
//							value, and return zero if not.
// --------------------------------------------------------------------------------
vars
	textValue		: String;
	allValuesArray	: StringArray;
	integerValue	: Integer;
	
begin
	create allValuesArray transient;
	
	textValue		:=	self.text;

	textValue.replaceChar(Cr, ' ');
	textValue.replaceChar(Lf, ' ');
	allValuesArray	:=	textValue.trimBlanks().getTokens();
	
	if allValuesArray.isEmpty() then
		integerValue	:=	0;
	else
		integerValue	:=	allValuesArray[pFieldNo].Integer;
	endif;
	
	return integerValue;
epilog
	delete allValuesArray;
end;</source>
        <access>protected</access>
        <Parameter name="pFieldNo" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="2b002e2c-7113-4f62-b710-7bc66bcaf30a">
        <source>getValue():Integer;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Returns the current value of the field.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.getFieldValue(1);
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
