		self.switchDateBoxComboBox(true, ETRow_FilterToDate, self.cmbCloseDate);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_DateFrom, self.cmbOpenDate);			// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_DateTo, self.cmbCloseDate);			// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_ActArrivedDateFrom, self.cmbProcDate);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_ActArrivedDateTo, self.cmbPackByDate);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_ActDepartedDateFrom, self.cmbBaseDate);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_ActDepartedDateTo, self.cmbCloseDate);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_SchedDepartedDateFrom, self.cmbDepartDFrom);	// TFS 52643
		self.switchDateBoxComboBox(true, ETRow_SchedDepartedDateTo, self.cmbDepartDTo);		// TFS 52643
		
		// HMS
		self.switchDateBoxComboBox(true, ETRow_ArrivalsDateFrom, self.cmbArriveDFrom);
		self.switchDateBoxComboBox(true, ETRow_ArrivalsDateTo, self.cmbArriveDTo);
		self.switchDateBoxComboBox(true, ETRow_DepartedDateFrom, self.cmbDepartDFrom);
		self.switchDateBoxComboBox(true, ETRow_DepartedDateTo, self.cmbDepartDTo);
		self.switchDateBoxComboBox(true, ETRow_InPortDateFrom, self.cmbInPortDFrom);
		self.switchDateBoxComboBox(true, ETRow_InPortDateTo, self.cmbInPortDTo);
		
		// 20/04/2023	navkc1	CR 55654 Task 55670 --&gt;
		self.switchDateBoxComboBox(true, ETRow_ContractFromStartDate, self.cmbContractFromStartDate);
		self.switchDateBoxComboBox(true, ETRow_ContractToStartDate, self.cmbContractToStartDate);
		self.switchDateBoxComboBox(true, ETRow_DetailFromStartDate, self.cmbDetailFromStartDate);
		self.switchDateBoxComboBox(true, ETRow_DetailToStartDate, self.cmbDetailToStartDate);
		self.switchDateBoxComboBox(true, ETRow_RateFromStartDate, self.cmbRateFromStartDate);
		self.switchDateBoxComboBox(true, ETRow_RateToStartDate, self.cmbRateToStartDate);
		
		self.switchDateBoxComboBox(true, ETRow_ContractFromEndDate, self.cmbContractFromEndDate);
		self.switchDateBoxComboBox(true, ETRow_ContractToEndDate, self.cmbContractToEndDate);
		self.switchDateBoxComboBox(true, ETRow_DetailFromEndDate, self.cmbDetailFromEndDate);
		self.switchDateBoxComboBox(true, ETRow_DetailToEndDate, self.cmbDetailToEndDate);
		self.switchDateBoxComboBox(true, ETRow_RateFromEndDate, self.cmbRateFromEndDate);
		self.switchDateBoxComboBox(true, ETRow_RateToEndDate, self.cmbRateToEndDate);
		// 20/04/2023	navkc1	CR 55654 Task 55670 &lt;--
		
		self.switchDateBoxComboBox (true,ETRow_ExpectedArrivalDateFrom, self.cmbExpArrDFrom);					//+TFS39280
		self.switchDateBoxComboBox (true,ETRow_ExpectedArrivalDateTo, self.cmbExpArrDTo);
		self.switchDateBoxComboBox (true,ETRow_ExpectedDepartDateFrom, self.cmbExpDepDFrom);
		self.switchDateBoxComboBox (true,ETRow_ExpectedDepartDateTo, self.cmbExpDepDTo);
		
		self.switchDateBoxComboBox(false, ETRow_DateToRun, self.cmbOpenDate);	//14 Aug 2019	NDL	TFS 46131
		
		
		//self.switchDateBoxComboBox(true, ETRow_MovementDateFrom, self.cmbArriveDFrom);
		//self.switchDateBoxComboBox(true, ETRow_MovementDateTo, self.cmbArriveDTo);
		
		//PAR22361 - cnwsh3 - 18/02/2010 - Remove references to CM_MenuUserReport.myReportRequest 
		//mapped method.  Now using getBGPReportRequest method
		//self.setOutputType(self.myMenuEntity.CM_MenuUserReport.myReportRequest);
		self.setOutputType(self.myMenuEntity.CM_MenuUserReport.getBGPReportRequest());
		self.switchDateBoxComboBox(true, ETRow_DateFromWO, self.cmbOpenDate);			//21.3.2023 navhl20 #57144
		self.switchDateBoxComboBox(true, ETRow_DateToWO, self.cmbCloseDate);			//21.3.2023 navhl20 #57144
		
		// Switch dynamic query report parameter date fields to Combo Box
		self.switchQryParamsDateBoxToCmb(true);  // 27-oct-25 navec1 MTN-36160: switch all date fields in allQueryReportParams to combo box
		
	elseif _state = self.myReportAgent.STATE_TEMPLATE_EDIT then
		self.tblTerminals.enabled 	:= true;
		self.lbReportTree.enabled 	:= false;
		self.btnEdit.enabled 		:= false;
		self.btnPrint.enabled 		:= true;
//		self.btnPrint.caption 		:= '&amp;Save';			// cnwrl1 30/11/2009 PAR 19950 - what it was
//		self.btnDeleteBGR.caption 	:= '&amp;Cancel';		// cnwrl1 30/11/2009 PAR 19950 - what it was
		// cnwrl1 30/11/2009 PAR 19950 - start of coding
		// change the button captions using the translatable values.
		self.btnPrint.translateCaption( Xlat_0005398, null );			// &amp;Save
		self.btnDeleteBGR.translateCaption( Xlat_0005393, null );		// &amp;Cancel
		// cnwrl1 30/11/2009 PAR 19950 - end of coding
		self.btnDeleteBGR.enabled 	:= true;
		self.tblParameter.visible 	:= true;
		self.tblParameter.userInputEnabled := true;
		self.tblPrintOptions.disableRowByName(ETRow_ProcessOption);
		self.switchDateBoxComboBox(true, ETRow_ProcessDate, self.cmbProcDate);	//2/12/13 epr par 32220 
		
		// Switch dynamic query report parameter date fields to Combo Box
		self.switchQryParamsDateBoxToCmb(true);  // 27-oct-25 navec1 MTN-36160: switch all date fields in allQueryReportParams to combo box
		
	elseif _state = self.myReportAgent.STATE_NULL then
		//already disabled/hidden			
		self.grpOutputOptions.visible    := false;       //MTN-36668
	endif;
	
end;</source>
        <Parameter name="_state" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="aa198583-f2da-4f38-809f-11155985b368">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     18 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	proxyUserWindow	: CM_UserWindowForOpen;
begin

	if self.visible and app.getMyUser &lt;&gt; null then
		proxyUserWindow := app.getUserWindow(self.name, true);
		//create proxyUserWindow transient;
		if proxyUserWindow &lt;&gt; null then
			proxyUserWindow.setProxy(app.getMyUser, self.name, self.getXMLSettingsForSave(), self.top, self.left, self.width, self.height, self.windowState);
		endif;
	endif;

	self.doTreeClick();

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblParameterHeight" id="ff250973-676b-415f-acc1-a9493b334201">
