    <JadeMethod name="setHeadingTextColor" id="6663273a-52db-4187-ad2c-e7d46b72f4e8">
        <updating/>
        <source>setHeadingTextColor(pValue: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Updates the text color for headings, and resets all other colors.
//
// Parameters:	pValue - The new text color for the headings.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.headingTextColor &lt;&gt; pValue then 
  		self.changeColors(	self.availableColor,
  							self.availableTextColor,
  							self.unavailableColor,
  							self.unavailableTextColor,
  							self.highlightColor,
  							self.highlightTextColor,
  							pValue,
  							self.headingColor);
		self.headingTextColor := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
