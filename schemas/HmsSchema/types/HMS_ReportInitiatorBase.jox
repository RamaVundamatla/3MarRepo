    <JadeMethod name="resetTops" id="087cdc7d-1e15-4c7c-b651-e57cb0cae851">
        <updating/>
        <source>resetTops() protected, updating;
// -------------------------------------------
// Created 10 May 2004 by cnwdvb1
// -------------------------------------------
vars

	oldTop,
	diff	: Real;

begin

	oldTop := self.frmMain.top;
	self.frmMain.top := self.topMargin;
	diff := self.frmMain.top - oldTop;
	self.frmMain.height := self.frmMain.height - diff;

end;</source>
        <access>protected</access>
    </JadeMethod>
