	endif;
	if _code = PARCEL then
		return 17;
	endif;
	if _code = PIECES then
		return 18;
	endif;
	if _code = PACKAGE then
		return 19;
	endif;
	if _code = PALETS then
		return 20;
	endif;
	if _code = REEL then
		return 21;
	endif;
	if _code = ROLLS then
		return 22;
	endif;
	if _code = SET then
		return 23;
	endif;
	if _code = SHEETS then
		return 24;
	endif;
	if _code = SKD then
		return 25;
	endif;
	if _code = SKIP then
		return 26;
	endif;
	if _code = UNITS then
		return 27;
	endif;
	if _code = VARIOUS then
		return 28;
	endif;
	if _code = WOODENBOX then
		return 29;
	endif;
	return 0;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPackingText" id="d1f4e15c-2746-4e0d-af5e-e1df529ba127">
        <source>getPackingText(_id: Integer): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2013	cnwdw1	Initial creation
*/
vars

begin
	if _id = 1 then
		return BAGS;
	endif;
	if _id = 2 then
		return BALES;
	endif;
	if _id = 3 then
		return BULK;
	endif;
	if _id = 4 then
		return BUNDELS;
	endif;
	if _id = 5 then
		return BOX;
	endif;
	if _id = 6 then
		return BARREL;
	endif;
	if _id = 7 then
		return CANS;
	endif;
	if _id = 8 then
		return CASES;
	endif;
	if _id = 9 then
		return COILS;
	endif;
	if _id = 10 then
		return CRATES;
	endif;
	if _id = 11 then
		return CARTONS;
	endif;
	if _id = 12 then
		return CYLINDER;
	endif;
	if _id = 13 then
		return DRUMS;
	endif;
	if _id = 14 then
		return KEGS;
	endif;
	if _id = 15 then
		return LOTS;
	endif;
	if _id = 16 then
		return NUMBERS;
	endif;
	if _id = 17 then
		return PARCEL;
	endif;
	if _id = 18 then
		return PIECES;
	endif;
	if _id = 19 then
		return PACKAGE;
	endif;
	if _id = 20 then
		return PALETS;
	endif;
	if _id = 21 then
		return REEL;
	endif;
	if _id = 22 then
		return ROLLS;
	endif;
	if _id = 23 then
		return SET;
	endif;
	if _id = 24 then
