    <JadeMethod name="setProxy" id="5bdef148-740a-4042-8edc-3c4998ee32e1">
        <updating/>
        <source>setProxy(_isMaximumLength : Boolean;
		 _length          : Integer;
		 _decimalDigits   : Integer;
		 _name            : String;
		 _extractClass    : CM_DataDumpExtractClass;
		 _jadeFeature     : CM_DataDumpFeature;
		 _sqlDataType     : CM_DataDumpSQLDataType;
		 _sqlColumnOrdinalPosition : Integer) updating;
/*
Purpose:			Setup Proxy Object

Parameters:			

Return Value:		

Date			Who		Reason
20 April 2010	conkc1	Initial creation

*/
vars

begin
	self.isMaximumLength        := _isMaximumLength;
	self.length                 := _length;
	self.decimalDigits          := _decimalDigits;
	self.name                   := _name;
	//self.myDataDumpExtractClass := _extractClass;
	self.myDataDumpFeature      := _jadeFeature;
	self.myDataDumpSQLDataType  := _sqlDataType;
    self.sqlColumnOrdinalPosition := _sqlColumnOrdinalPosition;
epilog

end;</source>
        <Parameter name="_isMaximumLength" type="Boolean"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_decimalDigits" type="Integer"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_jadeFeature" type="CM_DataDumpFeature"/>
        <Parameter name="_sqlDataType" type="CM_DataDumpSQLDataType"/>
        <Parameter name="_sqlColumnOrdinalPosition" type="Integer"/>
    </JadeMethod>
