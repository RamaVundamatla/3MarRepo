    <JadeMethod name="cmbAgent_displayEntry" id="f392d5e5-00b2-4522-93f6-683e6e4b57c2">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbAgent_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// clearing agent is customs agent or consignee
vars
	display	: String;
begin
	if obj.isKindOf(CM_CustomsAgent) then
		 display := obj.CM_CustomsAgent.code &amp; ' ' &amp; obj.CM_CustomsAgent.name;
	elseif obj.isKindOf(CM_ConsigneeConsignor) then
		display := obj.CM_ConsigneeConsignor.code &amp; ' ' &amp; obj.CM_ConsigneeConsignor.description;
	endif;
	return display;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
