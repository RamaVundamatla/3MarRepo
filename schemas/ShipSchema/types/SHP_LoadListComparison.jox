    <JadeMethod name="doCmbLoadListBuild" id="0f5a1113-2601-46ca-8df0-f7c0ca67cbcf">
        <updating/>
        <source>doCmbLoadListBuild(_loadLists: CM_EDIDataArray) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx		: Integer;
	aVoyage : CM_Voyage;
	ediData : CM_EDIData;
	loadList: CM_EDIDataLoadList;
	opCode	: String;
	listType : String;
	comboListCount : Integer;					//navra1 - MTN-34348 - 13th March 2025
	cnt : Integer;								//navra1 - MTN-34348 - 13th March 2025
	prepopulatedLoadList : CM_EDIDataLoadList;	//navra1 - MTN-34348 - 13th March 2025
begin
	//navra1 - MTN-34348 - 13th March 2025 - start
	if self.myCurrentVoyage.isAutomaticProcess() and self.cmbLoadList.listCount() &gt; 0 then
		self.cmbLoadList.listIndex :=1;
		prepopulatedLoadList := self.cmbLoadList.listObject.CM_EDIDataLoadList;
	endif;
	//navra1 - MTN-34348 - 13th March 2025 - end
	
	self.cmbLoadList.clear;
	self.cmbLoadList.sorted := true;

	aVoyage := self.myCurrentVoyage;
	if aVoyage = null then
		return;
	endif;

	foreach ediData in _loadLists do
		loadList := ediData.CM_EDIDataLoadList;
		//th2 CCMS 1547 - add if verified with warnings
		if loadList.status = CM_EDIFile.EDI_STATUS_VERIFIED or 
			loadList.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			if loadList.listType &lt;&gt; null then//cnwrs1 CCMS 1137 15 June 2010
				listType := loadList.listType &amp; " - ";
			endif;
			if loadList.myOperator &lt;&gt; null then
				opCode := loadList.myOperator.code;
			endif;
			idx := self.cmbLoadList.addItem(listType &amp; loadList.voyageCode &amp; " - " &amp; loadList.createdTime.shortCurrentLocaleFormat &amp; " - " &amp; opCode);
			self.cmbLoadList.itemObject[idx] := loadList;
		endif;
	endforeach;
	
	//navra1 - MTN-34348 - 13th March 2025 - start
	if self.myCurrentVoyage.isAutomaticProcess() and self.cmbLoadList.listCount &gt; 1 then
		if prepopulatedLoadList &lt;&gt; null then
			comboListCount := self.cmbLoadList.listCount;
			foreach cnt in 1 to comboListCount do
				self.cmbLoadList.listIndex := cnt;
				loadList := self.cmbLoadList.listObject.CM_EDIDataLoadList;
				if loadList.createdTime = prepopulatedLoadList.createdTime then	//this is the one you are interested in
					if loadList.listType = 'D' then
						self.btnDischargeComp.value := true;
						self.comparisonMode := DISCHARGE_COMPARISON;
						self.btnDischargeComp_click(btnDischargeComp); //if we know it is a discharge list then set the discharge button
					elseif loadList.listType = 'L' then
						self.btnLoadComp.value := true;
						self.comparisonMode := LOAD_COMPARISON;
						self.btnLoadComp_click(btnDischargeComp); //if we know it is a discharge list then set the discharge button
					endif;
						
					break;
				endif;
			endforeach;	
		endif;
	endif;	
	//navra1 - MTN-34348 - 13th March 2025 - end
	
	if idx = 1 then
		self.cmbLoadList.listIndex := idx;
		loadList := self.cmbLoadList.listObject.CM_EDIDataLoadList;	//cnwrs1 CCMS 1137 08 July 2010
		if loadList.listType = 'D' then		
			self.btnDischargeComp.value := true;
			self.comparisonMode := DISCHARGE_COMPARISON;
			self.btnDischargeComp_click(btnDischargeComp); //if we know it is a discharge list then set the discharge button			
		elseif loadList.listType = 'L' then			
			self.btnLoadComp.value := true;
			self.comparisonMode := LOAD_COMPARISON;
			self.btnLoadComp_click(btnDischargeComp); //if we know it is a discharge list then set the discharge button			
		endif;
	endif;
	
	if self.cmbLoadList.listCount &lt; 1 then
		idx := self.cmbLoadList.addItem(aVoyage.code &amp; " - No verified load list data found");
		//self.cmbLoadList.itemObject[idx] := loadList;
	endif;
	
epilog

end;</source>
        <Parameter name="_loadLists" type="CM_EDIDataArray"/>
    </JadeMethod>
    <JadeMethod name="doCmbReefManBuild" id="3fc1f2eb-f722-4215-a3b1-cebbf4b1cbc0">
        <source>doCmbReefManBuild(_reefManifests: CM_EDIDataArray);
//----------------------------------------------------------------
//	Created:	04 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx		: Integer;
	aVoyage : CM_Voyage;
	ediData : CM_EDIData;
begin
	aVoyage := self.myCurrentVoyage;
	if aVoyage = null then
		return;
	endif;

epilog

end;</source>
        <Parameter name="_reefManifests" type="CM_EDIDataArray"/>
    </JadeMethod>
    <JadeMethod name="doCmbViewBuild" id="922f51d8-3763-43a1-8017-69e17b65813a">
        <source>doCmbViewBuild();
// CNWJC2 23/10/2003
vars
	idx : Integer;
begin
	self.cmbView.clear;
	self.cmbView.sorted := false;
		
	self.cmbView.addItem(self.VIEW_MATCHING);
	self.cmbView.addItem(self.VIEW_DISCREPS);
	self.cmbView.addItem(self.VIEW_NOT_IN_DB);
	self.cmbView.addItem(self.VIEW_NOT_IN_LIST);
	self.cmbView.addItem(self.VIEW_DUPLICATES);
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageBuild" id="731e440f-5e8a-4968-9271-77071576f9a0">
        <updating/>
        <source>doCmbVoyageBuild() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/06/2019	jlgdap1		TFS 45334 MSL Cargo Comparison
// ---------------------------------------------------------------------------
vars
	aVoyage : CM_Voyage;
	idx : Integer;
	theVoyages : CM_VoyageSet;
begin
	
	self.cmbVoyage.clear;
	self.cmbVoyage.sorted := true;
	
	create theVoyages transient;
	//self.myTerminal.getAllCurrentCellularVoyages(theVoyages, false, false);
	//self.myTerminal.getAllCurrentCellularVoyages(theVoyages, true, false);	// 09/02/2009 cnwar2 CCMS1797 (PAR18881)
	//self.myTerminal.getAllCurrentVoyages(theVoyages, true, false, false);		// 14/04/2009 cnwar2 #19452		// TFS 45334
	//self.myTerminal.getAllVoyagesOperational(theVoyages, true, app.myPassport);	// 14/04/2009 cnwar2 #19452		// TFS 45334
	self.myTerminal.getAllVoyagesOperational(theVoyages, self.chkCurrentVoys.value, app.myPassport);	//23 Feb 2021	NDL	TFS 50836

	foreach aVoyage in theVoyages do
		if global.cnwer1 and not aVoyage.hasLoadListsForComparison() then
			continue;
		endif;
		
		idx := self.cmbVoyage.addItem(aVoyage.code &amp; " - " &amp; aVoyage.description);
		self.cmbVoyage.itemObject[idx] := aVoyage;
	endforeach;
	
	//cnwjo3 par 23105
	aVoyage := app.getMyCurrentVoyageForTerminal(self.myTerminal);
	
	if aVoyage &lt;&gt; null then
		idx := self.cmbVoyage.findObject(aVoyage);
		if idx &gt; 0 then
			self.cmbVoyage.listIndex := idx;
		endif;
		self.cmbVoyage.click(self.cmbVoyage);
	endif;
	
epilog
	delete theVoyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageClick" id="e7b0c0ca-631f-45ec-86d7-5a990fccc33f">
        <updating/>
        <source>doCmbVoyageClick() updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003	cnwjc2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	isInvalid	: Boolean;					// cnwrl1 09/08/2010 PAR 24337
	iEdition	: Integer;					// cnwrl1 09/08/2010 PAR 24337
	ediDatas	: CM_EDIDataArray;
	
begin
	// cnwrl1 09/08/2010 PAR 24337 - start of coding
	on SystemException do app.handleEndNotification1066( exception );
	self.endNotification( self.myCurrentVoyage, Object_Delete_Event );
	// cnwrl1 09/08/2010 PAR 24337 - end of coding

	self.myCurrentVoyage := cmbVoyage.listObject.CM_Voyage;
	
	if self.myCurrentVoyage = null then
		self.setNavigatorHeading( app.getErrorString( List_Comparison ) );			// cnwrl1 16/04/2009 PAR 19440
		return;
	endif;
	
	// cnwrl1 09/08/2010 PAR 24337 - start of coding
	// Need to handle the case where the voyage has been deleted from the combo box.
	on Exception do app.handleDeletedObject( exception, self.myCurrentVoyage, isInvalid );
	// Check availability by doing a de-reference
	iEdition	:= self.myCurrentVoyage.edition;
	if isInvalid then
		// Attempt to correct the issue by rebuilding the combo and let
		// the users select again - will default to app.myCurrentVoyage.
		self.doCmbVoyageBuild();
	endif;
	// cnwrl1 09/08/2010 PAR 24337 - end of coding
	
	//app.myCurrentVoyage := self.myCurrentVoyage;
	//cnwjo3 par 23105
	app.setMyCurrentVoyage(self.myCurrentVoyage);
	
	// cnwrl1 09/08/2010 PAR 24337 - start of coding
	if self.myCurrentVoyage = null then
		return;
	else
		// NOTE: There are various calls to endNotificationForSubscriber which will end this notification.
		beginNotification( self.myCurrentVoyage, Object_Delete_Event, Response_Continuous, null );	
	endif;
	// cnwrl1 09/08/2010 PAR 24337 - end of coding
	
	create ediDatas transient;
	
//	self.myCurrentVoyage.myCellularVoyageStructure.getAllEDILoadLists(ediDatas);	cnwrl1 16/04/2009 PAR 19471
	self.myCurrentVoyage.getAllEDILoadLists(ediDatas);
	
	self.doCmbLoadListBuild(ediDatas);
	self.doListOperatorBuild();
	self.setFormCaption(); // caption and navi
	
	//navra1 - MTN-34348 - 13th March 2025 - start
	if self.myCurrentVoyage.isAutomaticProcess() then
		//if a discharge or load list is selected
		if self.cmbLoadList &lt;&gt; null and self.cmbLoadList.listCount() &gt; 0 and self.cmbLoadList.listIndex &gt; 0 and self.cmbLoadList.listObject &lt;&gt; null then
			//if there is only one operator selected, which happens when you come from right click option of "Cargo Compare..." from erroneous stage
			if self.lstTblOperator &lt;&gt; null and self.lstTblOperator.allSelectedObjects.size() = 1 then
				//navra1 - MTN-34348-1 10th Apr 2025 - start
				/*
				//hide query box
				if self.frmQuery.visible then
					self.doShowSearcherClick();
				endif;
				self.initiateCompare(false);
				*/
				
				//make the query visible
				self.frmQuery.visible:= true;
				
				if self.cmbLoadList.listCount() = 1 then
					self.cmbLoadList.listIndex := 1;
				else
					self.cmbLoadList.listIndex := -1;
				endif;
				//navra1 - MTN-34348-1 10th Apr 2025 - end
			endif;
		endif;
	endif;
	//navra1 - MTN-34348 - 13th March 2025 - end
	
	//27 Apr 2010	NDL	Par 23912
	self.hasWarnedOfVoyageDiscreps := false;
	self.hasVoyageDiscreps := false;
	
epilog
	delete ediDatas;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doListOperatorBuild" id="30cf1ac1-64b7-4639-b92d-dda936a39320">
        <updating/>
        <source>doListOperatorBuild() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars

	aOperator : CM_Operator;
	idx : Integer;
	ls : Boolean;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	passport : CM_Passport;
	opDict : CM_OperatorByCodeDict;
	failedDAC  :CM_DataAccessController;
	ediDataArray : CM_EDIDataArray;					//navra1 - MTN-34348 - 13th March 2025
	ediData	: CM_EDIData;							//navra1 - MTN-34348 - 13th March 2025
	ediTi : CM_EDITrackedItem;							//navra1 - MTN-34348 - 13th March 2025
	op : CM_Operator;								//navra1 - MTN-34348 - 13th March 2025
	opDictTran : CM_OperatorByCodeDict;				//navra1 - MTN-34348 - 13th March 2025
	opArray : ObjectArray;						//navra1 - MTN-34348 - 13th March 2025
	
begin
	passport := app.myPassport;
	self.lstTblOperator.zOrder(1);
	self.lstTblOperator.rows := 0;
	
	if self.myCurrentVoyage &lt;&gt; null then
		opDict := self.myCurrentVoyage.allOperators;		
	else
		opDict := app.myRoot.allOperators;
	endif;
	
	//navra1 - MTN-34348 - 13th March 2025 - start
	create opDictTran transient;
	if self.myCurrentVoyage.isAutomaticProcess() then
		create ediDataArray transient;
		self.myCurrentVoyage.getAllEDILoadLists(ediDataArray);
		foreach ediData in ediDataArray do
			foreach ediTi in ediData.allEDITrackedItems do
				op := app.myRoot.allOperators[ediTi.getOperatorCode()];
				if op &lt;&gt; null and not opDictTran.includes(op) then
					opDictTran.add(op);				
				endif;
			endforeach;
		endforeach;
	endif;
	
	foreach op in opDict do
		if not opDictTran.includes(op) then
			opDictTran.add(op);
		endif;
	endforeach;	
	//navra1 - MTN-34348 - 13th March 2025 - end
	
	app.cmsBeginLoad(ls);
	foreach aOperator in opDictTran do			//navra1 - MTN-34348 - 13th March 2025
		if aOperator.canUserAccessSelf(null, failedDAC, passport) then
			self.lstTblOperator.addItemObject(aOperator.code &amp; " - " &amp; aOperator.description, aOperator);
		endif;
	endforeach;
	app.cmsEndLoad(ls);
	
	//navra1 - MTN-34348 - 13th March 2025 - start
	if self.myCurrentVoyage.isAutomaticProcess() then
		create opArray transient;
		self.lstTblOperator.allSelectedObjects.copy(opArray);		
		self.lstTblOperator.setSelected(opArray);		
	else
		self.lstTblOperator.setSelected(null);
	endif;
	//navra1 - MTN-34348 - 13th March 2025 - end

	self.lstTblOperator.userInputEnabled := true;

epilog
	delete opDictTran;			//navra1 - MTN-34348 - 13th March 2025
	delete ediDataArray;		//navra1 - MTN-34348 - 13th March 2025	
	delete opArray;				//navra1 - MTN-34348 - 13th March 2025	
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuild" id="9667ab76-2d1a-4849-8b53-387e5b21cc85">
        <updating/>
        <source>doMnuContextBuild(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	anObject	: Object;
	aLLTI		: CM_EDILoadListComparisonTI;
	newMenuItem : MenuItem;
	
begin
	//self.mnuColumnOrganiser.visible := false;
	self.mnuContextTIEnquire.enabled := false;
	self.mnuContextTIEdit.enabled := false;
	self.mnuContextTIEnquire.caption := "Cargo Enquiry...";
	self.mnuContextTIEdit.caption := "Cargo Edit...";
	
	anObject :=  cntrl.accessRow(cntrl.row).itemObject;
	if CM_EDILoadListComparisonTI.hasInstance(anObject) then
		aLLTI := anObject.CM_EDILoadListComparisonTI;
		if aLLTI.myTrackedItem &lt;&gt; null then
			self.mnuContextTIEnquire.enabled := true;
			self.mnuContextTIEdit.enabled := true;
		endif;
	elseif CM_TrackedItem.hasInstance(anObject) then
		self.mnuContextTIEnquire.enabled := true;
		self.mnuContextTIEdit.enabled := true;
	else
	//	return false;
	endif;
	
	self.mnuContextSep01.visible := true;
	self.mnuContextTIEnquire.visible := true;
	self.mnuContextTIEdit.visible := true;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuContextTIEdit.enabled := false;

	endif;

	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuCreatePrenotes" id="d1913fb6-2ba0-4d94-aea1-4cf9160f3583">
        <updating/>
        <source>doMnuCreatePrenotes() updating;
// --------------------------------------------------------------------------------
// Created:		3 August 2009 by cnwjo3
//
// Purpose:		create prenotes from the information selected in the table.  For CCMS 1084
//
// Notes:		this method is called from CMUI_QueryEnquiry::mnuCreatePrenotes_click()
vars
	isInvalid		: Boolean;				// cnwrl1 16/08/2010 PAR 24337
	iEdition		: Integer;				// cnwrl1 16/08/2010 PAR 24337
	obj : Object;
	dll : CM_EDIDataLoadList;
	passport : CM_Passport;
	result : Integer;
	
begin
	passport := app.myPassport;
	on CM_Exception do addExceptionHandler(exception, passport);
	app.setContinueCMExceptions(true);
	passport.clearErrorsWarnings();
	
	// cnwrl1 16/08/2010 PAR 24337 - start of coding
	if self.tblData.allSelectedObjects.isNotEmpty then
		on Exception do app.handleDeletedObject( exception, obj, isInvalid );
		foreach obj in self.tblData.allSelectedObjects do : obj_loop
			// Check availability by doing a de-reference
			iEdition	:= obj.edition();
			if isInvalid then
				self.myLLCAgent.validateAgentReferences( obj );
				break;
				//isInvalid	:= false;			// to allow further objects to be checked
			endif;
		endforeach obj_loop;
		if isInvalid then
			self.tblData.allSelectedObjects.removeInvalidObjects();
		endif;
		// if have removed all objects from the selection refresh screen and exit now.
		if self.tblData.allSelectedObjects.isEmpty then
			self.doRefresh();
			return;
		endif;
	endif;
	// cnwrl1 16/08/2010 PAR 24337 - end of coding
	
	create dll transient;

	while true do
		dll.createPreNotes(self.tblData.allSelectedObjects, app.myPassport);
	
		if passport.trxCompletedOK() then
		
			self.doRefresh();	//refresh since the prenote doesn't exist in "View: Cargo only in Load list"
								//it should have been moved to "Matching Cargo" or "Matching with discrepancies"
			break;
		else
			result := app.showErrorWarningDialog(self.caption, passport,ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				passport.warningsAcknowledged := true;
				continue;
			else
				break;
			endif;
			
		endif;
	endwhile;

epilog
	delete dll;
	app.setContinueCMExceptions(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="doMnuCreateTBA" id="57392bb5-4ef3-41ce-afb0-f0905526aee3">
        <updating/>
        <source>doMnuCreateTBA() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2019	jlgmp6	Initial creation	TFS 45590

*/

vars
	loadList: CM_EDIDataLoadList;
	passport: CM_Passport;
	result: Integer;

begin
	if self.tblData.allSelectedObjects.size() &lt;&gt; 1 then
		return;
	endif;

	passport := app.myPassport;
	app.setContinueCMExceptions(true);
	passport.clearErrorsWarnings();

	create loadList transient;

	while true do
		loadList.createTBA(self.tblData.allSelectedObjects, passport);
	
		if passport.trxCompletedOK() then
		
			self.doRefresh();	//refresh since the TBA doesn't exist in "View: Cargo only in Load list"
								//it should have been moved to "Matching Cargo" or "Matching with discrepancies"
			break;
		else
			result := app.showErrorWarningDialog(self.caption, passport,ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				passport.warningsAcknowledged := true;
				continue;
			else
				break;
			endif;
			
		endif;
	endwhile;

epilog
	delete loadList;
	app.setContinueCMExceptions(false);
end;</source>
    </JadeMethod>
