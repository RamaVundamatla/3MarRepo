    <JadeMethod name="checkClashesInXYDictNew" id="0d83ff26-28e8-4ce1-8ecd-8ba60e0854b9">
        <source>checkClashesInXYDictNew( allNewJobDrawControllers : SHP_CraneJobDrawControllerDict input; 
						 _addX1, _addY1, _addX2, _addY2 : Real;
						 _oldY1 : Real;
						 _voyageJob : CM_VoyageJob;
						 _crane : CM_Crane;
						_jobStartTime,
						_jobEndTime: TimeStamp ) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	iter	: Iterator;
	obj : Object;
	cX1,cY1,cX2,cY2 : Real;
	z  		: Integer;
	minY,maxY : Real;
	dict :CMUI_ObjectByRealX1Y1X2Y2Dict;
	objectArray : ObjectArray;
	potentialClash, jobDrawController,
	beforeController,
	afterController: SHP_CraneJobDrawingController;
	allPotentialClashes : SHP_CraneJobDrawControllerDict;
	before : Boolean;
	clashStartTime,
	clashEndTime: TimeStamp;
	clashMsg, clearanceWarning : String;
	voyageJob : CM_VoyageJob;
	clashCraneId : String;
	craneClearance : Integer;
	bayLength, clearanceBays  :Real;
begin 

	craneClearance:=self.getCraneClearance;
	craneClearance:=null;
	clearanceBays:=self.getBayLength * craneClearance;
	//get a collection of craneJobDrawingControllers with potential clashes i.e.
	//get all the jobs at the time i.e. x values; then when can check if bays clash | cranes cross | crane clearance has been breached
	create allPotentialClashes transient;

	foreach jobDrawController in allNewJobDrawControllers do
		potentialClash:=null;
		maxY:=null;
		minY:=null;
		dict:=jobDrawController.allJobObjects;
		delete iter;
		iter:=dict.createIterator;
		
		dict.startKeyLeq(_addX1,null,_addX1,null,null,iter);
		
		while iter.next(obj) do
			if self.mySelectedJobDrawConroller.allJobObjects.includes(obj) then
				continue;	
			endif;
			dict.getIteratorKeys(cX1,cY1,cX2,cY2,z, iter);
			if obj.isKindOf(CM_Delay) then
				continue;
			endif;
			if cX2 &lt; _addX1 then
				continue;
			endif;
			if cX1 &gt; _addX2 then
				break;
			endif;
			maxY:=maxY.max(cY2);			
			if potentialClash = null then
				create potentialClash transient;
				potentialClash.setCrane(jobDrawController.crane);
				potentialClash.dontCleanUpTransients:=true;
			endif;
			potentialClash.addJobAt(obj,cX1,cY1,cX2,cY2,z);
		endwhile;
		if potentialClash &lt;&gt; null then
			allPotentialClashes.add(potentialClash);
		endif;
	endforeach;
	
	
	foreach jobDrawController in allPotentialClashes do
		dict:=jobDrawController.allJobObjects;
		delete iter;
		iter:=dict.createIterator;
		dict.getMinMaxY(minY,maxY);
		
		before:=_oldY1 &lt; minY;
		while iter.next(obj) do
			dict.getIteratorKeys(cX1,cY1,cX2,cY2,z, iter);
			voyageJob:=obj.CM_VoyageJob;
			clashCraneId:=jobDrawController.crane.id;
			if ((cY1 &lt;= _addY1 and cY2 &gt;= _addY1) or (cY1 &gt;= _addY1 and cY2 &lt;= _addY2) or (cY1 &lt;= _addY2 and cY2 &gt;= _addY2)) then
				//clashed ouch -error
				clashStartTime:= self.myTimeLineDrawController.getTimeForX(cX1);
				clashEndTime:=self.myTimeLineDrawController.getTimeForX(cX2);
				clashMsg:="Moving Job " &amp; _voyageJob.id.String &amp; " to " &amp; _jobStartTime.time.String &amp; " - " &amp; _jobEndTime.time.String &amp; " clashes with  - " &amp; CrLf &amp; "Job " &amp; voyageJob.id.String  &amp; " for crane " &amp; clashCraneId &amp; " on " &amp; clashStartTime.time.String &amp; " to " &amp; clashEndTime.time.asStringJMT;
				if not self.allWarnings.includes(clashMsg) then
					self.allWarnings.add(clashMsg);
				endif;
				
				//app.msgBox(clashMsg ,"Invalid drag drop"  ,MsgBox_OK_Only);
				//return true;
			endif;
			/*
			if before then
				if _addY1 &gt; cY2 then
				//cranes have crossed  -error
					clashMsg:="Moving Job " &amp; _voyageJob.id.String &amp; " will result in crane " &amp;  _crane.id &amp; " crossing over with crane " &amp; clashCraneId;
				//	app.msgBox(clashMsg ,"Invalid drag drop"  ,MsgBox_OK_Only);
					if not self.allWarnings.includes(clashMsg) then
						self.allWarnings.add(clashMsg);
					endif;
				//	return false;
				endif;			
			else
				if _addY2 &lt; cY2 then
				//cranes have crossed  -error
					clashMsg:="Moving Job " &amp; _voyageJob.id.String &amp; " will result in crane " &amp;  _crane.id &amp; " crossing over with crane " &amp; clashCraneId;
				//	app.msgBox(clashMsg ,"Invalid drag drop"  ,MsgBox_OK_Only);
					if not self.allWarnings.includes(clashMsg) then
						self.allWarnings.add(clashMsg);
					endif;
					//return false;
				endif;
			endif;
		
			//warning crane clearance
			if craneClearance &lt;&gt; null then
			//if we are checking an object which will moved to a new crane check clearance problem is for the crane it will be moved to
				//if this job hasn't already been moved and waiting to be moved then skip
				if  self.mySelectedJobDrawConroller.allJobObjects.includes(_voyageJob) then
					if not self.allJobDrawControllers[_crane].allJobObjects.includes(_voyageJob) then
						if self.mySelectedJobDrawConroller.crane = _crane then
							continue;
						endif;
					endif;
				endif;
				if (_addY2 &lt; cY1) and ((cY1 - clearanceBays) &lt;= _addY2) then				
					clearanceWarning:="Moving Job " &amp; _voyageJob.id.String &amp; " resulted in job " &amp; voyageJob.id &amp; " breaching crane clearance with crane " &amp; clashCraneId;
					if not self.allWarnings.includes(clearanceWarning) then
						self.allWarnings.add(clearanceWarning);
					endif;
				endif;
				if (_addY1 &gt; cY2) and	((cY2 + clearanceBays) &gt;= _addY1)  then
					clearanceWarning:="Moving Job " &amp; _voyageJob.id.String &amp; " resulted in job " &amp; voyageJob.id &amp; " breaching crane clearance with crane " &amp; clashCraneId;
					if not self.allWarnings.includes(clearanceWarning) then
						self.allWarnings.add(clearanceWarning);
					endif;
				endif;
			endif;*/
	
		endwhile;
	endforeach;
	
	return true;
epilog
	if allPotentialClashes &lt;&gt; null then
		allPotentialClashes.purge;
		delete allPotentialClashes;
	endif;
	delete iter;
end;</source>
        <Parameter name="allNewJobDrawControllers" type="SHP_CraneJobDrawControllerDict" usage="input"/>
        <Parameter name="_addX1" type="Real"/>
        <Parameter name="_addY1" type="Real"/>
        <Parameter name="_addX2" type="Real"/>
        <Parameter name="_addY2" type="Real"/>
        <Parameter name="_oldY1" type="Real"/>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_jobStartTime" type="TimeStamp"/>
        <Parameter name="_jobEndTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkCompletionTimeChanged" id="5dab26e0-e529-4da7-9a37-d7469c55702e">
        <updating/>
        <source>checkCompletionTimeChanged() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	jobCraneDrawController : SHP_CraneJobDrawingController;
	x1, y1, x2, y2,maxX2 : Real;
	z		: Integer;
	newTime : TimeStamp;
begin
	foreach jobCraneDrawController in self.allJobDrawControllers do
		jobCraneDrawController.getXYZsForJob(jobCraneDrawController.allJobObjects.last.CM_VoyageJob,x1, y1, x2, y2,z);
		if x2 &gt; maxX2 then
			maxX2:=x2;
		endif;
	endforeach;

	newTime :=self.myTimeLineDrawController.getTimeForX(maxX2);
	if  newTime &lt;&gt; self.voyageEndTime then
		self.setVoyageEndTime(newTime);
		self.myForm.setSailingTimes();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="checkCraneClearance" id="b481cb8b-5d66-4fc8-82ad-4626f117e95a">
        <source>checkCraneClearance(_toCrane : CM_Crane);
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	craneJobController,
	jobDrawController: SHP_CraneJobDrawingController;
	selVoyageJob,job, otherCraneJobs, priorJob : CM_VoyageJob;
	iter , otherCraneIter : Iterator;
	x1,y1,x2,y2,
	cX1,cY1,cX2,cY2,
	pX1,pY1,pX2,pY2: Real;
	z 	: Integer;
	dict : CMUI_ObjectByRealX1Y1X2Y2Dict;
	craneClearance : Integer;
	clearanceBays  :Real;
	clearanceWarning,
	crossoverWarning: String;
begin
	//ONLY CHECK FOR THOSE JOBS THAT HAVE JUST BEEN MOVED I.E SELECTED JOBS
	//GET CRANE JOB DRAWING CONTROLLER 
	craneClearance:=self.getCraneClearance;
	clearanceBays:=self.getBayLength * craneClearance;
	if clearanceBays = 0 then
		return;
	endif;
	craneJobController:=self.allJobDrawControllers[_toCrane];
	if craneJobController = null then
		return;
	endif;
	
	if self.mySelectedJobDrawConroller.allJobObjects.size = null then
		return;
	endif;
	
	selVoyageJob:= self.mySelectedJobDrawConroller.allJobObjects.first.CM_VoyageJob;
	//IF THE JOB IN SELECTED IS NOT TRANSIENT GET ITS PROXY OBJECT FOR THE REAL ONE 
	if not selVoyageJob.isTransient then
		selVoyageJob:=app.myProxyManager.getProxyObject(selVoyageJob).CM_VoyageJob;
	endif;
	
	if selVoyageJob = null then
		return;
	endif;
	iter:=craneJobController.allJobObjects.createIterator;
	//START AT FIRST JOB IN SELECTED CONTROLLER
	iter.startAtObject(selVoyageJob);
	if craneJobController.allJobObjects.first &lt;&gt; selVoyageJob then
	//GET THE PRIOR JOB FOR THE CROSSOVER CHECK
		iter.back(job);
		iter.back(job);
		priorJob:=job;
		craneJobController.allJobObjects.getIteratorKeys(pX1,pY1,pX2,pY2,z,iter);
	endif;
	

	while iter.next(job) do
		if priorJob &lt;&gt; null and job = priorJob then
			continue;
		endif;
		//GET ALL OTHER JOBS FOR OTHER CRANES AT THIS JOBS X1,Y1,X2,Y2
		craneJobController.allJobObjects.getIteratorKeys(x1,y1,x2,y2,z,iter);
		foreach jobDrawController in self.allJobDrawControllers do
			if jobDrawController = craneJobController then
				continue;
			endif;
			dict:=jobDrawController.allJobObjects;
			delete otherCraneIter;
			otherCraneIter:=dict.createIterator;
			dict.startKeyLeq(x1,null,null,null,null,otherCraneIter);
			while otherCraneIter.next(otherCraneJobs) do
				
				clearanceWarning :=null;
				crossoverWarning:=null;
				dict.getIteratorKeys(cX1,cY1,cX2,cY2,z, otherCraneIter);
				if otherCraneJobs.isKindOf(CM_Delay) then
					continue;
				endif;
				if cX2 &lt; x1 then
					continue;
				endif;
				if cX1 &gt; x2 then
					break;
				endif;
				//check the cross over
				if priorJob &lt;&gt; null then
				//check the in crane above
					if pY2 &lt; y1 then
						if cY1 &gt;= pY2 and cY2 &lt;= y1 then
							crossoverWarning:="Moving Job " &amp; job.id.String &amp; " will result in crane " &amp;  _toCrane.id &amp; " crossing over with crane " &amp; jobDrawController.crane.id;
						endif;
					elseif pY1 &gt;= y2 then
				//check jobs in crane below
						if cY1 &gt;= y2 and cY2 &lt;= pY1 then
							crossoverWarning:="Moving Job " &amp; job.id.String &amp; " will result in crane " &amp;  _toCrane.id &amp; " crossing over with crane " &amp; jobDrawController.crane.id;
						endif;
					endif;
					if crossoverWarning &lt;&gt; null and not self.allWarnings.includes(crossoverWarning) then
						self.allWarnings.add(crossoverWarning);
					endif;
				endif;
				
				
				//check the clearance
				if cY2 &lt; y1 then
					if (y1 - clearanceBays) &lt; cY2 then
						clearanceWarning:="Moving Job " &amp; job.id.String &amp; " to crane " &amp; _toCrane.id &amp;  " resulted in job " &amp; otherCraneJobs.id &amp; " breaching crane clearance with crane " &amp; jobDrawController.crane.id;
					endif;
				endif;
				if cY1 &gt; y2 then
					if (y2  +  clearanceBays) &gt; cY1 then
						clearanceWarning:="Moving Job " &amp; job.id.String &amp; " to crane " &amp; _toCrane.id &amp;  " resulted in job " &amp; otherCraneJobs.id &amp; " breaching crane clearance with crane " &amp; jobDrawController.crane.id;
					endif;	
				endif;
				if clearanceWarning = null then
					continue;
				endif;
				if not self.allWarnings.includes(clearanceWarning) then
					self.allWarnings.add(clearanceWarning);
				endif;
			endwhile;
		endforeach;
		priorJob:=job;
		pX1:=x1;
		pY1:=y1;
		pX2:=x2;
		pY2:=y2;
	endwhile;
	

epilog
	delete iter;
	delete otherCraneIter;
end;</source>
        <Parameter name="_toCrane" type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="create" id="024afd8f-b68c-4205-bdeb-e09e0f3305cd">
        <updating/>
        <source>create() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	create self.myTimeLineDrawController transient;
	create self.myVoyageDrawController transient;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="ef7d5495-6f22-4c65-a0ee-ed366604f12d">
        <updating/>
        <source>delete() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	delete self.myTimeLineDrawController;
	delete self.myVoyageDrawController; 
	self.allJobDrawControllers.purge;
	delete self.mySelectedJobDrawConroller;
	if self.myVoyageStats &lt;&gt; null then
		delete self.myVoyageStats;
	endif;
	
	if self.myVoyageJobControllerState &lt;&gt; null then
		beginTransientTransaction;
		delete self.myVoyageJobControllerState;
		commitTransientTransaction;
	endif;


epilog
	self.endNotificationForSubscriber(self); //cnwrd1 par 23748 22.7.2010
end;</source>
    </JadeMethod>
    <JadeMethod name="displayJobBubble" id="fe37197a-2e0a-4686-817c-e8cc62a26984">
        <updating/>
        <source>displayJobBubble(_obj : Object;
					x, y : Real)  updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	job : CM_VoyageJob;
	cmifObj : CMIF_JobTITotals;
	str : String;
	currentCrane : CM_Crane;
	currentCraneJobDrawController : SHP_CraneJobDrawingController;
	moveX1,moveY1,moveX2,moveY2 : Real;
	z : Integer;
	txtBox : TextBox;
	theStartTime,
	theEndTime : TimeStamp;
	totalTime : Integer;
	entRow : EntTableRow;
	entRowName,
	entRowHeading : String;
	noSLOD,
	noSLUD,
	noTLOD,
	noTLUD,
	noOD : Real;
	craneMoveRate : CM_CraneMoveRates;
begin
	str:=null;
	create cmifObj transient;
	txtBox:=self.myForm.txtJobBubble;
	if _obj = null then
		self.myForm.frmJobBubble.visible:=false;
	else
		if not _obj.isKindOf(CM_VoyageJob) then
			self.frmJobBubble.visible:=false;
			return;
		else
			job := _obj.CM_VoyageJob;
		endif;
		if job  &lt;&gt; self.currentBubbleJob then
			currentCrane:=job.getJobCrane;
			currentCraneJobDrawController:=self.allJobDrawControllers[currentCrane];
			currentCraneJobDrawController.getXYZsForJob(job,moveX1,moveY1,moveX2,moveY2,z);
			theStartTime:=self.myTimeLineDrawController.getTimeForX(moveX1);
			theEndTime:=self.myTimeLineDrawController.getTimeForX(moveX2);
			totalTime:=theEndTime.getDifferenceInMinutes(theStartTime);
			currentBubbleJob:=job;
			currentBubbleJob.getJobTITotals(cmifObj);
			craneMoveRate:=job.getCraneMoveRate(currentCrane);
			if craneMoveRate = null then
				noSLOD:=currentCrane.targetRatePH;
				noSLUD:=currentCrane.targetRatePH;
				noTLOD:=currentCrane.targetRatePH;
				noTLUD:=currentCrane.targetRatePH;
				noOD:=currentCrane.targetRatePH;
			else
				noSLOD:=craneMoveRate.ratePerHourSLOD;
				noSLUD:=craneMoveRate.ratePerHourSLUD;
				noTLOD:=craneMoveRate.ratePerHourTLOD;
				noTLUD:=craneMoveRate.ratePerHourTLUD;
				noOD:=craneMoveRate.ratePerHourOD;
			endif;
			foreach entRow in self.myForm.allToolTipsEntArray do 
				entRowName := entRow.name;
				entRowHeading:=entRow.getHeading(null,null,app.myCurrentLocale) &amp; " : ";
				if entRowName = ETRow_TotalTime then
					str:=str &amp; 	entRowHeading &amp; totalTime.asStringJMT;
				elseif entRowName = ETRow_CraneRateODSL then
					str:=str &amp; 	entRowHeading &amp; noSLOD.asStringJMT;
				elseif entRowName = ETRow_CraneRateODTL then
					str:=str &amp; 	entRowHeading &amp; noTLOD.asStringJMT;
				elseif entRowName = ETRow_CraneRateUDSL then
					str:=str &amp; 	entRowHeading &amp; noSLUD.asStringJMT;
				elseif entRowName = ETRow_CraneRateUDTL then
					str:=str &amp; 	entRowHeading &amp; noTLUD.asStringJMT;
				elseif entRowName = ETRow_CraneRateOD then
					str:=str &amp; 	entRowHeading &amp; noOD.asStringJMT;
				elseif entRowName = ETRow_TotalLifts then
					str:=str &amp; entRowHeading &amp; job.getTotalLifts.asStringJMT;
				elseif entRowName = ETRow_AdditionalRemarks then
						str:=str &amp; entRowHeading &amp; job.getAdditionalRemarks;
				elseif entRowName = ETRow_JobStart then
					str:=str &amp; entRowHeading &amp; self.systemToLocalTime(theStartTime).asStringJMT;	// 18/5/16 cnwmp6 TFS 488 - Multi timezone support
				elseif entRowName = ETRow_JobEnd then
					str:=str &amp; entRowHeading &amp; self.systemToLocalTime(theEndTime).asStringJMT;	// 18/5/16 cnwmp6 TFS 488 - Multi timezone support
				else
					str:=str &amp; 	entRowHeading &amp; cmifObj.getDisplayStringForAttribute(entRowName,true);
				
				endif;
				if entRow &lt;&gt; self.myForm.allToolTipsEntArray.last then
					str:=str &amp; CrLf;
				endif;
			endforeach;
			if str &lt;&gt; null then
				self.frmJobBubble.visible:=true;
			else
				self.frmJobBubble.visible:=false;
				return;
			endif;
			txtBox.text:=str;
			txtBox.width:=txtBox.getTextExtent(txtBox.text)+10;
			txtBox.height:=txtBox.getTextHeight(txtBox.text)+10;
			self.frmJobBubble.width:= txtBox.width + 8; //txtBox.getTextExtent(txtBox.text)+18;//
			self.frmJobBubble.height:= txtBox.height + 8; //txtBox.getTextHeight(txtBox.text)+18;//
		
			self.frmJobBubble.top := y - 10;
			self.positionJobBubble(x);

		else
			if txtBox.text &lt;&gt; null then
				self.positionJobBubble(x);
			endif;
		endif;
	endif;

epilog
	if cmifObj &lt;&gt; null then
		delete cmifObj;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="displayJobBubbleAtXY" id="4256a7b9-d1ee-401b-881f-cc8fbf93dbce">
        <updating/>
        <source>displayJobBubbleAtXY(	_x,
						_y : Real
						)  updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	numJobsFound	: Integer;
	voyageJob: CM_VoyageJob;
begin

	voyageJob:=self.getBubbleJob(_x,_y,true, numJobsFound);

	if voyageJob = null then
		return;
	endif;
	
	self.displayJobBubble(voyageJob,_x, _y); //vY1);
	
epilog

end;</source>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doBeginTimerForRefresh" id="948078b6-2af7-4bac-8643-80dc54e8e8e4">
        <source>doBeginTimerForRefresh();
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	refreshTime : Integer;
	refreshMins : Real;
begin
	refreshMins:=self.myTimeLineDrawController.zoom/self.myTimeLineDrawController.scaleNoLines;
	refreshTime:=refreshMins.roundedUp;
	refreshTime:=refreshTime*60*1000;

	if refreshTime &lt;&gt; null then
		self.beginTimer(refreshTime,Timer_OneShot,null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeJobZOrder" id="6281639a-6bd9-430d-9121-7926102511bc">
        <source>doChangeJobZOrder(_job : CM_VoyageJob; _zOrder : Integer);
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	jobDrawController : SHP_CraneJobDrawingController;
	obj : Object;
	objs : ObjectArray;
	x1,y1,x2,y2 : Real;
	z : Integer;
	zOrder, invZOrder : Integer;
begin
	invZOrder:=(not _zOrder.Boolean).Integer;
	create objs transient;
	foreach jobDrawController in self.allJobDrawControllers do
		if not jobDrawController.allJobObjects.includes(_job) then
			continue;
		endif;
		jobDrawController.getXYZsForJob(_job,x1,y1,x2,y2,z);
		jobDrawController.allJobObjects.findObjectsInDict(x1,y1,x2,y2,objs,CM_VoyageJob,true);
		foreach obj in objs do 
				jobDrawController.allJobObjects.findObjectInDictGetXY(obj, x1,y1,x2,y2,z);
				if obj &lt;&gt; _job and z  &lt;&gt; invZOrder then
					jobDrawController.allJobObjects.removeKeyEntry(x1,y1,x2,y2,z,obj);
					jobDrawController.allJobObjects.putAtKey(x1,y1,x2,y2,invZOrder,obj);
				elseif obj = _job and z &lt;&gt; _zOrder then
					jobDrawController.allJobObjects.removeKeyEntry(x1,y1,x2,y2,z,obj);
					jobDrawController.allJobObjects.putAtKey(x1,y1,x2,y2,_zOrder,obj);
				endif;
		endforeach;
		

		zOrder:=0;
		while zOrder &lt;= 1 do
			foreach obj in objs do 
				jobDrawController.allJobObjects.findObjectInDictGetXY(obj, x1,y1,x2,y2,z);
				if z &lt;&gt; zOrder then
					continue;
				endif;
				jobDrawController.drawJob(false,self.getCurrentTimeX,obj,x1,y1,x2,y2,
											jobDrawController.getOriginalFontName,
											jobDrawController.getCranePastColour,
											jobDrawController.getCraneMovedColour);
			endforeach;
			zOrder:=zOrder + 1;
		endwhile;
		
	endforeach;


epilog
	delete objs;
end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_zOrder" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doChangeJobZoom" id="e9d1a018-f70f-471f-aafd-72703ee32f93">
        <updating/>
        <source>doChangeJobZoom() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	allJobsStartEndTime : ObjectArray;
	screenHeight : Real;
		jobDrawController : SHP_CraneJobDrawingController;
		voyageStats :	CMIF_VoyageStats;
begin
	if timeScale = 1 then
		self.drawVoyage();
		return;
	endif;
	
	if self.hasChanged then
		create voyageStats transient;
		//voyageStats:=self.myVoyageStats;
		voyageStats.init(self.myVoyage);
		self.getVoyageStats(voyageStats); //voyageStats);
	else
		voyageStats:=self.myVoyageStats;
	endif;
	
	self.setupVoyageFrame();
	self.myVoyageDrawController.drawVoyageOverviewLines;
	
	
	self.frmScrollingMain.visible:=true;
	
	//get rid of the fillers
	self.resizeScrollableMain;
	
	//set up the past frame
	//self.drawCurrentTime();
	
	foreach jobDrawController in self.allJobDrawControllers do
		jobDrawController.allJobObjects.clear;
	endforeach;
	
	self.getAllJobDrawControllersNew(voyageStats);//voyageStats);
	
	self.drawAllJobs(true);

epilog
	if voyageStats &lt;&gt; self.myVoyageStats then
		delete voyageStats;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeJobsCrane" id="ba3174d0-57e0-4fd0-980d-83c74bfdf989">
        <updating/>
        <source>doChangeJobsCrane(	_jobs : CM_VoyageJobArray input;
					_toCrane : CM_Crane) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	crane : CM_Crane;
	_x,_y,
	x1,y1,x2,y2,
	t1,s1,t2,s2,
	f1,g1,f2,g2,
	tarX1,tarY1,tarX2,tarY2: Real;
	z	: Integer;
	craneJobController,
	toJobCraneController: SHP_CraneJobDrawingController;
	theCompletionTime : TimeStamp;
	iter : Iterator;
	jobObj : CM_Object;
	voyageJob : CM_VoyageJob;
	yFound: Boolean;
	job : CM_VoyageJob;
	hasErrors : Boolean;
begin
	app.mousePointer:=Window.MousePointer_HourGlass;

	if _jobs.size = 0 then
		return;
	endif;
	if not self.doCheckCanEdit() then
		self.doClearAllSelected(false);
		return;
	endif;
	self.doClearAllSelected(false);
	theCompletionTime:=self.voyageEndTime;
	crane:=_jobs.first.getJobCrane;//_job.getJobCrane;
	craneJobController:=allJobDrawControllers[crane];
	toJobCraneController:=allJobDrawControllers[_toCrane];

	if self.mySelectedJobDrawConroller = null then
		create self.mySelectedJobDrawConroller transient;
		self.mySelectedJobDrawConroller.setDetails(_toCrane,null,self.frmScrollingMain);
		self.mySelectedJobDrawConroller.dontCleanUpTransients:=true;
	else
		self.mySelectedJobDrawConroller.setCrane(_toCrane);
	endif;
	self.allWarnings.clear;
	foreach job in _jobs do
		craneJobController.getXYZsForJob(job,_x,y1,x2,y2 ,z);
		toJobCraneController.getXYZsForJob(toJobCraneController.allJobObjects.last.CM_VoyageJob,t1,s1,t2,s2,z );
		toJobCraneController.getXYZsForJob(toJobCraneController.allJobObjects.first.CM_VoyageJob,f1,g1,f2,g2,z );
		if _x &gt; t2  then
			_x:=t2;
			_y:=s2;	
			yFound:=true;
			
		elseif _x &lt; f1 then
			_x:=f1;
			_y:=g1;	
			yFound:=true;
			
		else
			iter:=toJobCraneController.allJobObjects.createIterator; 
			toJobCraneController.allJobObjects.startKeyGeq( x1,null,x1,null,1,iter);
			while iter.next(jobObj) do
				voyageJob:=jobObj.CM_VoyageJob;
				toJobCraneController.allJobObjects.getIteratorKeys(x1, y1, x2, y2,z, iter);
				if _x &gt;= x1 and 
						_x &lt; x2 then
					//find the obj with that crane at that x position there can be only one
				
					toJobCraneController.allJobObjects.findObjectInDictGetXY(voyageJob,tarX1,tarY1,tarX2,tarY2,z);
					self.mySelectedJobDrawConroller.addJobAt(voyageJob,tarX1,tarY1,tarX2,tarY2,z);
						// different crane
						_y:=tarY1;		
						yFound:=true;
					break;		
				endif;
			endwhile;
			delete iter;
		endif;
	
		if not yFound then
			break;
		endif;
		
		if not self.doChangeJobsCraneAtXYNew(job,_jobs,_toCrane,_x, _y ) then
			hasErrors:=true;
			return;
		endif;
	endforeach;
	
	self.checkCraneClearance(_toCrane);
		
	if theCompletionTime &lt;&gt; self.voyageEndTime then
			//need to change the time scale
		self.doChangeTimeScale();
	else
		self.drawAllJobs(true);
	endif;
	
	if not hasErrors and self.allWarnings.size &lt;&gt; null then
		self.doDisplayWarnings();
	endif;
	
epilog
	delete iter;
	app.mousePointer:=Window.MousePointer_Default;
end;</source>
        <Parameter name="_jobs" type="CM_VoyageJobArray" usage="input"/>
        <Parameter name="_toCrane" type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="doChangeJobsCraneAtXYNew" id="40f1071a-1f51-4566-aa8a-ebba16b66123">
        <updating/>
        <source>doChangeJobsCraneAtXYNew(moveObject : CM_VoyageJob input;
						_allMoveObjects : CM_VoyageJobArray input; 
					_toCrane : CM_Crane;
					_x, _y  : Real io) : Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 January 2007	cnwer1	Initial creation - PAR#xxxx 

*/
vars
	currentCrane : CM_Crane;
	currentCraneJobDrawController,
	toCraneJobController,
	jobCraneDrawController,
	fromClashCraneJobController: SHP_CraneJobDrawingController;
	allClashJobControllers : SHP_CraneJobDrawControllerDict;
	moveX1,moveY1,moveX2,moveY2,
	newMoveX2,
	x1,y1,x2,y2,
	toX1,toY1,
	toX2,toY2,
	widthMoveObj,
	newWidthMoveObj,
	widthToObj,
	newX1,newX2,
	halfway: Real;
	moveZ,toZ,z : Integer;
	toObject,
	startObject,
	obj : Object;
	before,
	back: Boolean;
	fromCraneRemove,
	fromCraneAdd,
	toCraneRemove,
	toCraneAdd,
	fromClash,
	selected: CMUI_ObjectByRealX1Y1X2Y2Dict;
	iter : Iterator;
	jobStartTime,
	jobEndTime,
	currentJobStart,
	newJobEnd, newJobStart: TimeStamp;
	realVoyageJob , transientMoveObj,_moveObject: CM_VoyageJob;
	jobStart ,
	jobEnd : TimeStamp;
	allMoveObjects : CM_VoyageJobArray;
begin
	_moveObject:=moveObject;
	if _moveObject = null then
		app.msgBox("You need to select job(s) to move" ,"Invalid drag drop"  ,MsgBox_OK_Only);
		return false;
	else
		
		currentCrane:=_moveObject.getJobCrane;
		currentCraneJobDrawController:=self.allJobDrawControllers[currentCrane];
		if currentCraneJobDrawController = null then
			return null;
		endif;
		
		if not _moveObject.isTransient then
			transientMoveObj:=app.myProxyManager.getProxyObject(_moveObject).CM_VoyageJob;
			if not transientMoveObj  = null then
				_moveObject:= transientMoveObj;
			endif;
		endif;
		currentCraneJobDrawController.getXYZsForJob(_moveObject,moveX1,moveY1,moveX2,moveY2,moveZ);
		
		
		widthMoveObj:=moveX2-moveX1;
		currentJobStart:=self.myTimeLineDrawController.getTimeForX(moveX1);
		realVoyageJob:=getRealVoyageJob(_moveObject);
	endif;
	
	create allMoveObjects transient;
	self.mySelectedJobDrawConroller.allJobObjects.copy(allMoveObjects);
	toCraneJobController:=self.allJobDrawControllers[_toCrane];
	//find where to move it
	toObject:=toCraneJobController.findJobAtXY(_x, _y,toX1,toY1,toX2,toY2,toZ);
	if toObject = null then
		toCraneJobController.getXYZsForJob(toCraneJobController.allJobObjects.last.CM_VoyageJob,toX1,toY1,toX2,toY2,toZ);
		if _x &gt; toX1 or _x &gt; toX2 then
			toObject :=toCraneJobController.allJobObjects.last.CM_VoyageJob;
		endif;
	endif;
	
	
	//from spec for job ship controll if the x, y is left hand end of the job position before else
	// position on right
	halfway:=(toX1 + toX2)/2;
	widthToObj:=toX2-toX1;
	before:= _x &lt; halfway;
	
	if not self.validateDropToObject(toObject,_moveObject,before) then
		return false;
	endif;
	
	//dragging from right to left
	back := moveX1 &gt; toX1;
	
	if before then
		newX1:=toX1;
	else
		newX1:=toX2;
	endif;
	
	newJobStart:=self.myTimeLineDrawController.getTimeForX(newX1);
	
	if newJobStart &lt; self.currentTime then
		newJobStart:=self.currentTime;
		newX1:=self.myTimeLineDrawController.getXForTime(newJobStart);
	endif;
	newJobEnd:=self.getNewJobEndTimeForCrane(realVoyageJob,_toCrane,newJobStart); 
	newX2:=self.myTimeLineDrawController.getXForTime(newJobEnd);
	newWidthMoveObj:=newX2-newX1;
	
	
	if self.isBeforeCurrentTime(newX1,newX2) and before then
		before :=not before;
		newX1:=toX2;
		newJobStart:=self.myTimeLineDrawController.getTimeForX(newX1);
		newJobEnd:=self.getNewJobEndTimeForCrane(realVoyageJob,_toCrane,newJobStart); //realVoyageJob.getEndTsWithDelays(newJobStart,newJobEnd,_toCrane);
		newX2:=self.myTimeLineDrawController.getXForTime(newJobEnd);
		newWidthMoveObj:=newX2-newX1;
	endif;		
	

	if self.isBeforeCurrentTime(newX1,newX2) then
		app.msgBox("Can not move job " &amp; _moveObject.id &amp; " before the current time","Invalid drag drop"  ,MsgBox_OK_Only);
		return false;
	endif;
	
	create fromCraneRemove transient;
	create fromCraneAdd transient;
	create toCraneRemove transient;
	create toCraneAdd transient;
	//remove obj from current crane
	fromCraneRemove.putAtKey(moveX1,moveY1,moveX2,moveY2,moveZ,_moveObject);
	if self.isBeforeCurrentTime(moveX1,moveX2) then
		app.msgBox("Can not move job " &amp; _moveObject.id &amp; " that is before the current time" ,"Invalid drag drop"  ,MsgBox_OK_Only);
		return false;
	endif;	
	
	jobStart:=currentJobStart;
	
	if not self.doShiftSubSetOfJobs(currentCraneJobDrawController,currentCrane,fromCraneRemove,fromCraneAdd,_moveObject,null,true,false,
							jobStart,	jobEnd) then
		return false;
	endif;
	//delete iter;
	create allClashJobControllers transient;
	create fromClashCraneJobController transient;
	fromClashCraneJobController.setCrane(currentCrane);
	fromClashCraneJobController.dontCleanUpTransients:=true;
	
	create fromClash transient;	
	currentCraneJobDrawController.findAllJobsFromXtoJob(fromClash,_x,_moveObject);
	fromClash.copy(fromClashCraneJobController.allJobObjects);
	iter:=fromCraneAdd.createIterator;
	while iter.next(obj) do
		fromCraneAdd.findObjectInDictGetXY(obj , x1,y1,x2,y2,z);
		fromClashCraneJobController.addJobAt(obj,x1,y1,x2,y2,z);
	endwhile;
	delete iter;
	allClashJobControllers.add(fromClashCraneJobController);
	
	fromClashCraneJobController.removeAllJobs(allMoveObjects);
	//the transient job sheet were the moved object has come from 
	jobStartTime:=self.myTimeLineDrawController.getTimeForX(newX1);
	jobEndTime:=self.myTimeLineDrawController.getTimeForX(newX2);
	
	if not checkClashesInXYDictNew(allClashJobControllers,newX1,moveY1,newX2,moveY2,moveY1,_moveObject,currentCrane,jobStartTime,jobEndTime) then
		return false;
	endif;

	if before then
		_x:=newX1+1;
	else
		_x:=newX2-1;
	endif;
	_y:=moveY1+1;
	
	toCraneAdd.putAtKey(newX1,moveY1,newX2,moveY2,0,_moveObject);
	
	iter:=toCraneJobController.allJobObjects.createIterator;
	if before then
		toCraneJobController.allJobObjects.startKeyGeq(toX1,toY1,toX2,toY2,0 ,iter);
	else
		toCraneJobController.allJobObjects.startKeyGtr(toX1,toY1,toX2,toY2,1 ,iter);
	endif;
	
	while iter.next(obj) do
		toCraneJobController.getXYZsForJob(obj.CM_VoyageJob,x1,y1,x2,y2,z);
		newX1:=x1+newWidthMoveObj;
		newX2:=x2+newWidthMoveObj;
		
		jobStartTime:=self.myTimeLineDrawController.getTimeForX(x1);
		jobEndTime:=self.myTimeLineDrawController.getTimeForX(x2);
	
		
		foreach jobCraneDrawController in allJobDrawControllers do
			//if the crane is out own crane skip
			if jobCraneDrawController.crane = _toCrane or jobCraneDrawController.crane = currentCrane then
				continue;
			endif;
			if not allClashJobControllers.includes(jobCraneDrawController) then
				allClashJobControllers.add(jobCraneDrawController);
			endif;
		endforeach;
		
		if not self.checkClashesInXYDictNew(allClashJobControllers,newX1,y1,newX2,y2,moveY1,obj.CM_VoyageJob,toCraneJobController.crane,jobStartTime,jobEndTime) then
			return false;
		endif;
		toCraneAdd.putAtKey(newX1, y1, newX2, y2,0,obj);
		toCraneRemove.putAtKey(x1,y1,x2,y2,z,obj);
	endwhile;
	
	delete iter;
	
	if self.mySelectedJobDrawConroller &lt;&gt; null then
		selected:=self.mySelectedJobDrawConroller.allJobObjects;
	else
		selected:=null;
	endif;
	currentCraneJobDrawController.addRemoveJobObjects(fromCraneRemove,fromCraneAdd,selected);
	
	toCraneJobController.addRemoveJobObjects(toCraneRemove,toCraneAdd,selected);
	
	//last thing to do is check if the all voyage jobs completion time has changed 
	self.checkCompletionTimeChanged();
	
	return true;

	
epilog
	delete toCraneRemove;
	delete toCraneAdd;
	delete fromCraneRemove;
	delete fromCraneAdd;
	delete fromClash;
	if allClashJobControllers &lt;&gt; null then
		delete allClashJobControllers;
	endif;
	if fromClashCraneJobController &lt;&gt; null then
		delete fromClashCraneJobController;
	endif;
	if allMoveObjects &lt;&gt; null then
		delete allMoveObjects;
	endif;
	delete iter;

end;</source>
        <Parameter name="moveObject" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_allMoveObjects" type="CM_VoyageJobArray" usage="input"/>
        <Parameter name="_toCrane" type="CM_Crane"/>
        <Parameter name="_x" type="Real" usage="io"/>
        <Parameter name="_y" type="Real" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeTimeScale" id="5e9e776d-7c73-436c-a945-1ff057a24888">
        <updating/>
        <source>doChangeTimeScale() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theWidth : Real;
	jobDrawController : SHP_CraneJobDrawingController;
	cmifVoyageStats  :  CMIF_VoyageStats;
	drawTimeScale : Boolean;
begin

	if self.hasChanged then
		create cmifVoyageStats transient;
		cmifVoyageStats.init(self.myVoyage);
		//self.myVoyageStats.init(self.myVoyage);
		self.getVoyageStats(cmifVoyageStats);//self.myVoyageStats); //cmifVoyageStats);
		self.getVoyageTimes(cmifVoyageStats);//self.myVoyageStats);//cmifVoyageStats);
	else
		cmifVoyageStats:=self.myVoyageStats;
	endif;
	
	drawTimeScale:=self.setupTimeLineFrame(timeScale);
	
	if drawTimeScale then
		self.myTimeLineDrawController.drawTimeScale;
	endif;
	self.myTimeLineDrawController.drawTimeLineMileStones(mode=self.MODE_TARGET,cmifVoyageStats);
	theWidth := (self.frmScrollingMain.width + self.getVoyageOverviewLabelFrame.width);
	
	//self.frmScrollingMain.visible:=true;
	self.resizeScrollableMain;
	
	foreach jobDrawController in self.allJobDrawControllers do
		jobDrawController.allJobObjects.clear;
		jobDrawController.allDelayObjects.clear;
	endforeach;
	
	
	self.getAllJobDrawControllersNew(cmifVoyageStats); //cmifVoyageStats);
	self.drawAllJobs(true);

epilog
	if cmifVoyageStats &lt;&gt; self.myVoyageStats then
		delete cmifVoyageStats;
	endif;
	//delete cmifVoyageStats;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckCanEdit" id="bfda1a8e-4c99-4ce7-9c2a-efd370a64fbd">
        <source>doCheckCanEdit() : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	oa : ObjectArray;
	o : Object;
	sjcState : SHP_VoyageJobControllerState;
	voyage : CM_Voyage;
	errorMsg : String;
begin
	return true;
	create oa transient;
	SHP_VoyageJobControllerState.allSharedTransientInstances(oa,0,false);
	
	foreach o in oa  do
		if	self.myVoyageJobControllerState = o then
			continue;
		endif;
		sjcState:= o.SHP_VoyageJobControllerState;
		voyage:=sjcState.voyageOid.asOid.CM_Voyage;
		//if someone else is not editting this voyage then continue
		if voyage = null or voyage &lt;&gt; self.myVoyage then
			continue;
		endif;
		//if they are not editing then continue
		if not sjcState.state then
			continue;
		endif;
		if sjcState.userCode = app.myPassport.myUser.code then
		//	continue;
		endif;
		
		errorMsg:="Can not edit because user " &amp; sjcState.userCode &amp; " is already editing voyage " &amp; voyage.code;
		app.msgBox(errorMsg ,"Edit"  ,MsgBox_OK_Only);
		return false;
	endforeach;

	return true;
epilog
	if oa &lt;&gt; null then
		delete oa;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClearAllSelected" id="977ee274-6376-4e6d-803c-e028c7390534">
        <source>doClearAllSelected(_redraw : Boolean);
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	realJobController: SHP_CraneJobDrawingController;
	zOrder : Integer;
begin
	if self.mySelectedJobDrawConroller = null then
		return;
	endif;
	realJobController:=self.allJobDrawControllers[self.mySelectedJobDrawConroller.crane];
	if _redraw then
		zOrder:=0;
		while zOrder &lt;= 1 do
			self.mySelectedJobDrawConroller.drawAllJobs(false,self.getCurrentTimeX,zOrder);
			zOrder:=zOrder + 1;
		endwhile;
		realJobController.drawAllDelays;
	endif;
	mySelectedJobDrawConroller.allJobObjects.clear;
	mySelectedJobDrawConroller.allJobsInOrderAdded.clear;

epilog

end;</source>
        <Parameter name="_redraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDisplayWarnings" id="ca751102-9f90-4cc6-829b-f1fc0ce5cfe8">
        <source>doDisplayWarnings();
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	warning, warnings : String;
begin
	foreach warning in self.allWarnings do
		warnings:= warnings &amp; warning;
		if self.allWarnings.last &lt;&gt; warning then
			warnings:= warnings &amp; CrLf;
		endif;
	endforeach;

	app.msgBox(warnings,"Warning crane clearance",MsgBox_OK_Only);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFlipVertical" id="c1a850c9-d248-4814-a7f8-6b86409a0934">
        <updating/>
        <source>doFlipVertical(_value : Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	jobDrawController : SHP_CraneJobDrawingController;
	cmifVoyageStats :  CMIF_VoyageStats;
begin
	if self.flipVertical = _value then
		return;
	else
		self.setFlipVertical(_value);
	endif;
	
	if self.hasChanged then
		create cmifVoyageStats transient;
		cmifVoyageStats.init(self.myVoyage);
		self.getVoyageStats(cmifVoyageStats);
	else
		cmifVoyageStats:=self.myVoyageStats;
	endif;
	
	self.getVoyageOverviewLabelFrame.clearGraphics;
	self.setupVoyageFrame();
	self.myVoyageDrawController.drawVoyageOverviewLines;
	//get rid of the fillers
	self.resizeScrollableMain;
	foreach jobDrawController in self.allJobDrawControllers do
		jobDrawController.allJobObjects.clear;
	endforeach;
	//self.allJobDrawControllers.clear;
	self.getAllJobDrawControllersNew(cmifVoyageStats);
	
	self.drawAllJobs(true);
	
epilog	
	if cmifVoyageStats &lt;&gt; self.myVoyageStats then
		delete cmifVoyageStats;
	endif;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doHideCompleted" id="75d3e82c-ca65-44c2-b067-c4e3726b3c34">
        <updating/>
        <source>doHideCompleted(_hide : Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theWidth : Real;

	jobDrawController : SHP_CraneJobDrawingController;
	cmifVoyageStats : CMIF_VoyageStats;
begin		   
	self.setHideCompleted(_hide);
	if _hide then
		self.doChangeTimeScale();
	else
		/*create cmifVoyageStats transient;
		cmifVoyageStats.init(self.myVoyage);
		self.getVoyageStats(cmifVoyageStats);
		self.getVoyageTimes(cmifVoyageStats);*/
		
		
		self.myVoyageStats.init(self.myVoyage);
		self.getVoyageStats(self.myVoyageStats);
		self.getVoyageTimes(self.myVoyageStats);
		foreach jobDrawController in self.allJobDrawControllers do
			jobDrawController.dontCleanUpTransients:=true;
		endforeach;
		
		self.allJobDrawControllers.purge;
		
		//self.drawScrollableMainNew(cmifVoyageStats);
		self.drawScrollableMainNew(myVoyageStats);
		
	endif;
epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMoveJobInJobSheetNew" id="f330e10e-bda5-41e9-84d4-1365977cb496">
        <source>doMoveJobInJobSheetNew(	_moveObject : CM_VoyageJob input;
						_toObject : CM_VoyageJob;
						_before : Boolean
						) : Boolean ;
/*

Purpose:			
				//can't have 2 cranes working the bay at the same time 
				//crane can't work 2 bays at the same time
				// moving stuff in same cranes is fine
				// if we move something from one crane to another have to
					move all the jobs after the one being moved to the end of the target job (we get from x,y)
				//

Return Value:		


Date		Who		Reason
16 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	
	x1,y1,x2,y2,
	moveX1, moveY1,moveX2,moveY2: Real;
	back : Boolean;
	iter : Iterator;
	removeObjects,
	addObjects : CMUI_ObjectByRealX1Y1X2Y2Dict;
	crane : CM_Crane;
	realVoyageJob: CM_VoyageJob;
	craneJobDrawController : SHP_CraneJobDrawingController;
	jobStart,
	jobEnd : TimeStamp;
	jobStartX,
	jobEndX : Real;
	startObject,
	endObject: CM_VoyageJob;
	removeStartObject,
	removeEndObject : Boolean;
	z, moveZ 		: Integer;
begin
	
	if _moveObject = null  then
		app.msgBox("You need to select job(s) to move" ,"Invalid drag drop"  ,MsgBox_OK_Only);
		return false;
	else
		crane:=self.mySelectedJobDrawConroller.crane;//_moveObject.CM_VoyageJob.getJobCrane;
		craneJobDrawController:=self.allJobDrawControllers[crane];
		if craneJobDrawController = null then
			return null;
		endif;
		craneJobDrawController.getXYZsForJob(_moveObject.CM_VoyageJob,moveX1,moveY1,moveX2,moveY2,moveZ);
		
		//do first check that the new position for the move obj is not in the past
		if self.isBeforeCurrentTime(moveX1,moveX2) then
			app.msgBox("Can not move job that is before the current time" ,"Invalid drag drop"  ,MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	if not craneJobDrawController.allJobObjects.includes(_moveObject) then
		return false;
	endif;
	
	//find where to move it
	
	if not self.validateDropToObject(_toObject,_moveObject,_before) then
		return false;
	endif;
	craneJobDrawController.getXYZsForJob(_toObject,x1,y1,x2,y2,z);
	
	back := moveX1 &gt; x1;
	
	iter := craneJobDrawController.allJobObjects.createIterator;
	create removeObjects transient;
	create addObjects transient;
	if back then
		//remove the moved object from where it was and add it to the start
		iter.startAtObject(_toObject);
		startObject:=_toObject.CM_VoyageJob;
		endObject:=_moveObject;
		realVoyageJob:=getRealVoyageJob(_moveObject);
		if _before then
			jobStartX:=x1;
			
			jobStart:=self.myTimeLineDrawController.getTimeForX(jobStartX);
			jobEnd:=self.getNewJobEndTimeForCrane(realVoyageJob,crane,jobStart);
			jobEndX:=self.myTimeLineDrawController.getXForTime(jobEnd);	
		else
			jobStartX:=x2;
			iter.next(startObject);
			iter.next(startObject);
			jobStart:=self.myTimeLineDrawController.getTimeForX(jobStartX);
			jobEnd:=self.getNewJobEndTimeForCrane(realVoyageJob,crane,jobStart);
			jobEndX:=self.myTimeLineDrawController.getXForTime(jobEnd);	
		
		endif;
		//now check that where its being dropped to is not in the past
		if self.isBeforeCurrentTime(jobStartX,jobEndX) then
			app.msgBox("Can not move job to before the current time","Invalid drag drop"  ,MsgBox_OK_Only);
			return false;
		endif;
		
		if not self.updateAddRemoveDictsForJob(	addObjects,
												removeObjects,
												_moveObject,
												jobStartX, moveY1, jobEndX, moveY2,0,
												moveX1, moveY1, moveX2, moveY2,moveZ,null) then
			return false;
		endif;
		jobStartX:=jobEndX;
		
	else
		iter.startAtObject(_moveObject);
		startObject:=_moveObject;
		endObject:=_toObject.CM_VoyageJob;
		jobStartX:=moveX1;
	endif;
	removeStartObject:=not back;
	removeEndObject:=back;
	jobStart:=self.myTimeLineDrawController.getTimeForX(jobStartX);
	if not self.doShiftSubSetOfJobs(craneJobDrawController,crane,removeObjects,addObjects,startObject,endObject,removeStartObject,removeEndObject,
							jobStart,	jobEnd) then
		return false;
	endif;
	
	
	if removeStartObject then
	// add the start object to the end
		jobStart:=jobEnd;//self.myTimeLineDrawController.getTimeForX(jobStartX);
		jobStartX:=self.myTimeLineDrawController.getXForTime(jobStart);
		realVoyageJob:=getRealVoyageJob(_moveObject);
		jobEnd:=self.getNewJobEndTimeForCrane(realVoyageJob,crane,jobStart);
		jobEndX:=self.myTimeLineDrawController.getXForTime(jobEnd);
		//now check that where its being dropped to is not in the past
		if self.isBeforeCurrentTime(jobStartX,jobEndX) then
			app.msgBox("Can not move job to before the current time","Invalid drag drop"  ,MsgBox_OK_Only);
			return false;
		endif;
		if not self.updateAddRemoveDictsForJob(	addObjects,
												removeObjects,
												_moveObject,
												jobStartX, moveY1, jobEndX, moveY2,z,
												moveX1, moveY1, moveX2, moveY2,moveZ,null) then
			return false;
		endif;
	
	endif;
	//remove these objects from self
	
	craneJobDrawController.addRemoveJobObjects(removeObjects,addObjects,self.mySelectedJobDrawConroller.allJobObjects);

	return true;
	
	
epilog
	delete iter;
	delete removeObjects;
	delete addObjects;


end;</source>
        <Parameter name="_moveObject" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_toObject" type="CM_VoyageJob"/>
        <Parameter name="_before" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="7513111e-b158-4717-9173-4e2cae6225ff">
        <updating/>
        <source>doRefresh() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	
	jobDrawController : SHP_CraneJobDrawingController;
begin

	self.frmScrollingMain.clearGraphics;
	self.getTimeLineLabelFrame.clearGraphics;
	self.myVoyageStats.getStats(true);
	self.getVoyageTimes(self.myVoyageStats);
	foreach jobDrawController in self.allJobDrawControllers do
		jobDrawController.dontCleanUpTransients:=false;
	endforeach;
	self.allJobDrawControllers.purge;
	self.allJobDrawControllers.purge;
	delete self.mySelectedJobDrawConroller;
	
	self.drawScrollableMainNew(self.myVoyageStats);

	self.myForm.frmCranesNew.zOrder(1);
	self.myForm.setSailingTimes;
	
	self.myForm.myAssistant.tblVoyageStats(self.myForm.tblCranes,self.myVoyageStats);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveJobSheets" id="67477df2-1cfd-47f0-b1a4-28476525c4cd">
        <source>doSaveJobSheets();
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	craneJobControler : SHP_CraneJobDrawingController;
	oa : ObjectArray;
	allVoyageJobSheets : CM_VoyageJobSheetArray;
	jobsInOrder : CM_VoyageJobArray;
	jobSheet : CM_VoyageJobSheet;
begin

	create oa transient;
	create allVoyageJobSheets transient;
	foreach craneJobControler in self.allJobDrawControllers do
		if not craneJobControler.hasChanged then
			continue;
		endif;
		jobSheet:=self.myVoyage.allJobSheets[craneJobControler.crane.id].CM_VoyageJobSheet;
		allVoyageJobSheets.add(jobSheet);
		create jobsInOrder transient;
		craneJobControler.allJobObjects.copy(jobsInOrder);
		oa.add(jobsInOrder);
	endforeach;
	
	app.myTrxUA.trxUpdateVoyageJobSheetJobs(self.myVoyage,oa,allVoyageJobSheets,app.myPassport);

epilog
	oa.purge;
	delete oa;
	delete allVoyageJobSheets;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShiftSubSetOfJobs" id="a4edce2e-5d48-43cd-9b1b-4f4be1cdf31a">
        <source>doShiftSubSetOfJobs(_craneJobDrawController : SHP_CraneJobDrawingController input;
					_crane : CM_Crane input;
					_removeObjects,
					_addObjects :CMUI_ObjectByRealX1Y1X2Y2Dict input;
					_startVoyageJob,
					_endVoyageJob: CM_VoyageJob input;
					_removeStartObj,
					_removeEndObj : Boolean;
					_jobStart,
					_jobEnd : TimeStamp io) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	iter : Iterator;
	jobStartX,
	jobEndX,
	x1, y1, x2, y2: Real;
	z			: Integer;
	voyageJob,
	realVoyageJob: CM_VoyageJob;
begin
	iter := _craneJobDrawController.allJobObjects.createIterator;
	if _startVoyageJob =  _endVoyageJob then
		return false;
	endif;
	iter.startAtObject(_startVoyageJob);
	jobStartX:=self.myTimeLineDrawController.getXForTime(_jobStart);
	while iter.next(voyageJob) do
		_craneJobDrawController.allJobObjects.getIteratorKeys(x1, y1, x2, y2,z, iter);	
		_jobStart:=self.myTimeLineDrawController.getTimeForX(jobStartX);
		realVoyageJob:=getRealVoyageJob(voyageJob);
		_jobEnd:=self.getNewJobEndTimeForCrane(realVoyageJob,_crane,_jobStart);
		jobEndX:=self.myTimeLineDrawController.getXForTime(_jobEnd);
		
		if voyageJob = _startVoyageJob then
			if _removeStartObj then
				continue;
			endif;
		elseif voyageJob = _endVoyageJob then
			if _removeEndObj then
				break;
			endif;
		endif;
		if not self.updateAddRemoveDictsForJob(	_addObjects,
												_removeObjects,
												voyageJob,
												jobStartX, y1, jobEndX, y2,0,
												x1, y1, x2, y2,z,null) then
			return false;
		endif;
		jobStartX:=jobEndX;
	
		if voyageJob = _endVoyageJob then
			break;
		endif;
	endwhile;

	return true;
epilog
	delete iter;
end;</source>
        <Parameter name="_craneJobDrawController" type="SHP_CraneJobDrawingController" usage="input"/>
        <Parameter name="_crane" type="CM_Crane" usage="input"/>
        <Parameter name="_removeObjects" type="CMUI_ObjectByRealX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_addObjects" type="CMUI_ObjectByRealX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_startVoyageJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_endVoyageJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_removeStartObj" type="Boolean"/>
        <Parameter name="_removeEndObj" type="Boolean"/>
        <Parameter name="_jobStart" type="TimeStamp" usage="io"/>
        <Parameter name="_jobEnd" type="TimeStamp" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateJobControllerState" id="c4d91a20-9499-4cdf-8a46-c63670ad1d0b">
        <updating/>
        <source>doUpdateJobControllerState() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	beginTransientTransaction;
		if self.myVoyageJobControllerState = null then
			create self.myVoyageJobControllerState sharedTransient;
		endif;
		self.myVoyageJobControllerState.setDetails(self.myVoyage.getOidString,self.hasChanged,app.myPassport.getUserCode);
	commitTransientTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawAllJobs" id="6e4e4f29-3eeb-4d92-9c88-10fe8cb99644">
        <updating/>
        <source>drawAllJobs(_clearGraphics : Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	craneJobDrawingController : SHP_CraneJobDrawingController;
	zOrder : Integer;
begin
	if _clearGraphics then
		self.frmScrollingMain.clearGraphics;
	endif;
	
	self.drawCurrentTime;
	self.drawCompletionTime;
	
	self.frmScrollingMain.drawFontSize := 10;
	foreach craneJobDrawingController in self.allJobDrawControllers do
		zOrder:=0;
		while zOrder &lt;= 1 do
			craneJobDrawingController.drawAllJobs(false,self.getCurrentTimeX,zOrder);	
			zOrder:=zOrder + 1;
		endwhile;
			
		craneJobDrawingController.drawAllDelays;
	endforeach;
	
	self.drawHorizontalGrid;
	

	
	//self.doUpdateJobControllerState;
	
epilog

end;</source>
        <Parameter name="_clearGraphics" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawCompletionTime" id="c60f3c5b-c87c-42ea-9074-1fa59bf55f8e">
        <updating/>
        <source>drawCompletionTime() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	targetDepartureTime : TimeStamp;
	lineColour : Integer;
begin
	if self.voyageEndTime = null then
		return;
	endif;	
	
	targetDepartureTime:=self.myVoyage.departTargetDT;
	
	lineColour:=Blue;
	self.drawLineForTime(self.voyageEndTime,lineColour);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawCurrentTime" id="a166d81b-20ff-46ef-b7b6-17a6145663c1">
        <updating/>
        <source>drawCurrentTime() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	maxWidth : Integer;
	lineColour : Integer;
	targetDepartureTime: TimeStamp;
begin
	targetDepartureTime:=self.myVoyage.departTargetDT;
	
	//epr par 15737 22/1/2008 
	// the current time line should be red when the estimated voyage end time is greater than the target departure time
	if (targetDepartureTime &lt;&gt; null and self.voyageEndTime &gt; targetDepartureTime) then
		lineColour:=Red;
	else
		lineColour:=Black;
	endif;

	drawLineForTime(getCurrentTime, lineColour);
	
	self.endTimer(0);
	
	if getCurrentTime &lt;= self.voyageEndTime then
		self.doBeginTimerForRefresh();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawHorizontalGrid" id="4b1265ea-2f53-451b-810f-a65e8b5f6abf">
        <source>drawHorizontalGrid();
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	allBays : CMUI_BayOverviewByBayId;
	bayOverviewObject,
	bayBeforeBridge:  CMUI_BayOverviewObject;
	bridgeAfterBay : String;
	width, y,bridgeY: Real;
	bayLength : Real;
begin

	self.frmScrollingMain.ignoreSkin:=true;
	self.frmScrollingMain.drawStyle:=Window.DrawStyle_Dot;
	allBays:=self.myVoyageDrawController.allBayOverviewObjects;
	self.frmScrollingMain.borderStyle	:= Window.BorderStyle_Single;
	width:=self.getTimeLineLabelFrame.clientWidth;
	foreach bayOverviewObject in allBays do
		self.frmScrollingMain.drawLine(0,bayOverviewObject.y,width, bayOverviewObject.y,Black);	
	endforeach;
	
	bayLength:=self.myVoyageDrawController.bayLength;
	bridgeAfterBay:=self.myVoyage.myCellularVoyageStructure.bridgeAfterBay;
	bayBeforeBridge:=allBays[bridgeAfterBay];
	
	
		if self.myVoyageDrawController.getStartFromTop then
			bayOverviewObject:=allBays.last;
			
			//cnwjo3 par XXXX
			if bayOverviewObject &lt;&gt; null then
				y:=bayOverviewObject.y +  bayLength;
			endif;
			
			if bayBeforeBridge &lt;&gt; null then
				bridgeY:= bayBeforeBridge.y + bayLength;
			endif;
		else
			bayOverviewObject:=allBays.first;
			
			//cnwjo3 par X
			if bayOverviewObject &lt;&gt; null then
				y:=bayOverviewObject.y + bayLength;
			endif;
			
			if bayBeforeBridge &lt;&gt; null then
				bridgeY:=bayBeforeBridge.y - self.myVoyageDrawController.getBridgeHeight;
			endif;
		endif;
		
		//draw bridge line
	if bayBeforeBridge &lt;&gt; null then	
		self.frmScrollingMain.drawLine(0,bridgeY,width,bridgeY,Black);
	endif;
	//draw the last bay line

	self.frmScrollingMain.drawLine(0 ,y,width , y ,Black);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawLineForTime" id="c7567840-8a9b-426d-b048-05d3f96e0d7b">
        <updating/>
        <source>drawLineForTime(_time : TimeStamp;
				_lineColour : Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	x, 
	y1, y2: Real;
	origLineWidth,
	newLineWidth : Integer;
begin
	y1:=self.getVoyageOverviewLabelFrame.top-1;
	y2:=self.getVoyageOverviewLabelFrame.height+1;	
	x:=self.myTimeLineDrawController.getXForTime(_time);
	origLineWidth:=self.frmScrollingMain.drawWidth;
	self.frmScrollingMain.drawStyle:=Window.DrawStyle_Solid;
	self.frmScrollingMain.drawWidth:=2;
	self.frmScrollingMain.drawLine(x,y1,x,y2,_lineColour);
	self.frmScrollingMain.drawWidth:=origLineWidth;

epilog

end;</source>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_lineColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawPrintVoyageNew" id="5947f5c0-c0d8-4ccc-9a49-798b356fb318">
        <updating/>
        <source>drawPrintVoyageNew(_voyageStats : CMIF_VoyageStats ) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	jobDrawController : SHP_CraneJobDrawingController;
begin
	self.frmScrollingMain.clearGraphics;
	self.getTimeLineLabelFrame.clearGraphics;
	self.getVoyageOverviewLabelFrame.clearGraphics;
	self.frmScrollableMain.visible:=true;
	
	self.setupScrollableMain();
	
	self.setupVoyageFrame();
	self.myVoyageDrawController.drawVoyageOverviewLines;
	
	self.drawScrollableMainNew(_voyageStats);
	
	foreach jobDrawController in self.allJobDrawControllers do
		jobDrawController.dontCleanUpTransients:=true;
	endforeach;


epilog

end;</source>
        <Parameter name="_voyageStats" type="CMIF_VoyageStats"/>
    </JadeMethod>
    <JadeMethod name="drawScrollableMainNew" id="c7481a89-5873-46a8-9678-ccb546a6e159">
        <updating/>
        <source>drawScrollableMainNew(_voyageStats : CMIF_VoyageStats) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	drawTimeScale : Boolean;
begin

	drawTimeScale:=self.setupTimeLineFrame(self.timeScale);
	
	
	if drawTimeScale then
		self.myTimeLineDrawController.drawTimeScale;
	else
		self.getTimeLineLabelFrame.visible:=false;
	endif;
	self.myTimeLineDrawController.drawTimeLineMileStones(mode=self.MODE_TARGET,_voyageStats);
	
	
	self.resizeScrollableMain;
	
	delete self.mySelectedJobDrawConroller;
	self.getAllJobDrawControllersNew(_voyageStats);
	self.drawAllJobs(true);
	if self.frmJobBubble &lt;&gt; null then
		self.frmJobBubble.zOrder(1);
	endif;
epilog

end;</source>
        <Parameter name="_voyageStats" type="CMIF_VoyageStats"/>
    </JadeMethod>
    <JadeMethod name="drawVoyage" id="e8b1f20b-bb19-4720-8b71-eb355232fafe">
        <updating/>
        <source>drawVoyage() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	allJobsStartEndTime : ObjectArray;
	jobDrawController : SHP_CraneJobDrawingController;
begin
	self.setMode(self.MODE_TARGET);
	self.frmScrollingMain.clearGraphics;
	self.frmScrollingMain.visible:=true;
	self.getTimeLineLabelFrame.clearGraphics;
	self.getVoyageOverviewLabelFrame.clearGraphics;
	self.frmScrollableMain.visible:=true;
	
	self.setupScrollableMain();
	//par 16697
	//check to see if they have added a crane or removed a crane
	//simple method shouldn't happen very often
	if  self.myVoyageStats.hasJobSheetsCranesChanged then
		self.myVoyageStats.init(self.myVoyage);
	endif;
	
	self.myVoyageStats.getStats(true);
	self.myForm.setupCraneStatsTable();
	self.setupVoyageFrame();
	self.myVoyageDrawController.drawVoyageOverviewLines;
	
	self.getVoyageTimes(self.myVoyageStats);
	
	
	
	foreach jobDrawController in self.allJobDrawControllers do
		jobDrawController.dontCleanUpTransients:=false;
	endforeach;
	
	self.allJobDrawControllers.purge;
	delete self.mySelectedJobDrawConroller;
	
	self.drawScrollableMainNew(self.myVoyageStats);
		
epilog

end;</source>
    </JadeMethod>
