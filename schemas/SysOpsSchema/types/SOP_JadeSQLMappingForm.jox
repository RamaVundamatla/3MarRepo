    <JadeMethod name="setupForm" id="64c1e5ed-b627-4fc6-8dad-ef40cdfa825f">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	#cnwdz2	 24641

*/

vars


begin
	inheritMethod();
	app.mousePointer := Idle;
	if self.mode = self.Mode_Add then
		self.initProxy(null);	
	endif;
	
	self.initOIDColumnNameAndPos();
	self.initCmbJadeClass();
	self.initSQLTableName();
	self.initCmbDeleteOption();
	self.initDeleteActionColNameAndPos();
	self.initOperationColumnNameAndPos();
	self.initExportDTColumnNameAndPos();
	self.initTblExtFeatures();
	if self.mode = self.Mode_Edit then
		self.loadFeaturesForExtractClass(self.myProxyObject.CM_DataDumpExtractClass);
		self.txtSQLTblName.setFocus();
	else
		self.cmbJadeClass.setFocus();
	endif;
	
epilog

end;</source>
    </JadeMethod>
