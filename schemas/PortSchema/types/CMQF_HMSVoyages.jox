epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="b7afc562-52f3-4ced-a13d-ff1b8a4f2819">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 09/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 Adding expected arrival and departure date/time
vars

	runDate	: Date;

begin
	
	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support

	// Arrival
	if _attrName = ETRow_ArrivalsDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.arriveDateFromType, self.arriveDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.arriveDateFromType, self.arriveDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.arriveDateToType, self.arriveDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.arriveDateToType, self.arriveDateToFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsTimeFrom then
		return self.arriveTFrom.shortFormatJMT();
	endif;
	
	if _attrName = ETRow_ArrivalsTimeTo then	
		return self.arriveTTo.shortFormatJMT();
//		Par 10238
//		return self.arriveTFrom.format('HH:mm');
	endif;
	
	// Depart
	if _attrName = ETRow_DepartedDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.departDateFromType, self.departDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.departDateFromType, self.departDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_DepartedDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.departDateToType, self.departDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.departDateToType, self.departDateToFactor);
		endif;
	endif;
	
	if _attrName = ETRow_DepartedTimeFrom then
		return self.departTFrom.shortFormatJMT();
	endif;
	
	if _attrName = ETRow_DepartedTimeTo then
		return self.departTTo.shortFormatJMT();
	endif;
	
	// In Port
	if _attrName = ETRow_InPortDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.inPortDateFromType, self.inPortDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.inPortDateFromType, self.inPortDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_InPortDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.inPortDateToType, self.inPortDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.inPortDateToType, self.inPortDateToFactor);
		endif;
	endif;
	
	if _attrName = ETRow_InPortTimeFrom then
		return self.inPortTFrom.shortFormatJMT();
	endif;
	
	if _attrName = ETRow_InPortTimeTo then
		return self.inPortTTo.shortFormatJMT();
	endif;
	
	// PAR #35826 CCMS SFW 1410 Expected Arrival / Departure From / To
	if _attrName = ETRow_ExpectedArrivalDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.estimatedArrivalDateFromType, self.estimatedArrivalDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.estimatedArrivalDateFromType, self.estimatedArrivalDateFromFactor);
		endif;
	endif;
	if _attrName = ETRow_ExpectedArrivalDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.estimatedArrivalDateToType, self.estimatedArrivalDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.estimatedArrivalDateToType, self.estimatedArrivalDateToFactor);
		endif;
	endif;
	if _attrName = ETRow_ExpectedArrivalTimeFrom then
		return self.estimatedArrivalTimeFrom.shortFormatJMT();
	endif;
	if _attrName = ETRow_ExpectedArrivalTimeTo then
		return self.estimatedArrivalTimeTo.shortFormatJMT();
	endif;
	
	if _attrName = ETRow_ExpectedDepartDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.estimatedDepartDateFromType, self.estimatedDepartDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.estimatedDepartDateFromType, self.estimatedDepartDateFromFactor);
		endif;
	endif;
	if _attrName = ETRow_ExpectedDepartDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.estimatedDepartDateToType, self.estimatedDepartDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.estimatedDepartDateToType, self.estimatedDepartDateToFactor);
		endif;
	endif;
	if _attrName = ETRow_ExpectedDepartTimeFrom then
		return self.estimatedDepartTimeFrom.shortFormatJMT();
	endif;
	if _attrName = ETRow_ExpectedDepartTimeTo then
		return self.estimatedDepartTimeTo.shortFormatJMT();
	endif;
	// PAR #35826 end
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="searchForVoyages" id="76708eb5-dc00-45da-a435-b10746046a30">
        <source>searchForVoyages(_startTs, _endTs : TimeStamp; _collection: Collection input; _inPort : Boolean; _expectedArrival, _expectedDeparture : Boolean; _passport: CM_Passport) protected;
// -------------------------------------------
// Created 25 February 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 09/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 Expected Arrival and Departure dates
vars

	iter,
	iterVoy			: Iterator;
	terminal		: CM_Terminal;
	offset,
	arrivesInPort	: TimeStamp;
	voyage			: CM_Voyage;

begin

	// Basically taken old report and refactor a tensy bit. Much the same though.
	
	iter := self.allTerminals.createIterator();
	while iter.next(terminal) do
		delete iterVoy;
		offset.setTime(self.departTFrom);
		if _inPort then
			//offset.setDate(self.departDateFrom - terminal.myHarbour.shippingReportOffsetDays);
			iterVoy := terminal.allVoyagesByDepartDTCode.createIterator();
			terminal.allVoyagesByDepartDTCode.startKeyGeq(_startTs, null, iterVoy);
			
		// PAR #35826 If Expected Arrival or expected Departure, use allVoyages collection
		elseif _expectedArrival or _expectedDeparture then
			iterVoy := terminal.allVoyagesByArrivalDTCode.createIterator;
			
		else
			offset.setDate(self.departDateFrom);
			iterVoy := terminal.allVoyagesByDepartDTCode.createIterator();	
			//terminal.allVoyagesByArrivalDTCode.startKeyGeq(offset, null, iterVoy);
			terminal.allVoyagesByDepartDTCode.startKeyGeq(offset, null, iterVoy);
							
		endif;
		
		while iterVoy.next(voyage) do
			//if voyage.myHMSVoyageData = null or voyage.myHMSVoyageData.excludeReport then
			if voyage.myHMSVoyageData &lt;&gt; null and voyage.myHMSVoyageData.excludeReport then		// 10/06/2008 cnwar2 #16751
				continue;
			endif;
			
			if _inPort then
				arrivesInPort := voyage.arrivedDT;
				if (arrivesInPort &lt;= _endTs and voyage.departedDT &gt;= _startTs) then
					//_collection.add(voyage);
					self.addVoyage( _collection , voyage , _passport); // cnwrd1 par 23993 25.5.2010 ++
					continue;
				endif;
				
			// PAR #35826 Expected Arrival / Departure														// PAR #35826
			elseif _expectedArrival then																	// PAR #35826
				if voyage.estimatedArrivalDT &gt;= _startTs and voyage.estimatedArrivalDT &lt;= _endTs then			// PAR #35826
					self.addVoyage(_collection, voyage, _passport);											// PAR #35826
				endif;																						// PAR #35826
			elseif _expectedDeparture then																	// PAR #35826
				if voyage.estimatedDepartureDT &gt;= _startTs and voyage.estimatedDepartureDT &lt;= _endTs then		// PAR #35826
					self.addVoyage(_collection, voyage, _passport);											// PAR #35826
				endif;																						// PAR #35826
				
			else
			   	if voyage.departedDT &gt;= _startTs and voyage.departedDT &lt;= _endTs then
					//_collection.add(voyage);
					self.addVoyage( _collection , voyage , _passport); // cnwrd1 par 23993 25.5.2010 ++
					continue;
			   	else
			   		break;
			   	endif;	
			endif;
			
		endwhile;
	endwhile;

epilog
	delete iterVoy;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_startTs" type="TimeStamp"/>
        <Parameter name="_endTs" type="TimeStamp"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_inPort" type="Boolean"/>
        <Parameter name="_expectedArrival" type="Boolean"/>
        <Parameter name="_expectedDeparture" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setDatesForTemplateRun" id="404fb4d1-771a-46dd-b3ca-ef2dd2674a7a">
        <updating/>
        <source>setDatesForTemplateRun(_runDate: Date) updating;
// ---------------------------------------------------------------------------
// Created:     27 April 2005	cnwhjg1
//
// Purpose:     
// 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 09/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 Added expected arrival/depature date/times
vars

begin
	inheritMethod(_runDate);
	self.arriveDateFrom := self.setDateFromTemplate(self.arriveDateFromType, self.arriveDateFromFactor, _runDate);
	self.arriveDateTo	:= self.setDateFromTemplate(self.arriveDateToType, self.arriveDateToFactor, _runDate);
	self.departDateFrom	:= self.setDateFromTemplate(self.departDateFromType, self.departDateFromFactor, _runDate);
	self.departDateTo	:= self.setDateFromTemplate(self.departDateToType, self.departDateToFactor, _runDate);
	self.inPortDateFrom	:= self.setDateFromTemplate(self.inPortDateFromType, self.inPortDateFromFactor, _runDate);
	self.inPortDateTo	:= self.setDateFromTemplate(self.inPortDateToType, self.inPortDateToFactor, _runDate);
	
	self.estimatedArrivalDateFrom 	:= self.setDateFromTemplate(self.estimatedArrivalDateFromType, self.estimatedArrivalDateFromFactor, _runDate);	// PAR #35826
	self.estimatedArrivalDateTo 		:= self.setDateFromTemplate(self.estimatedArrivalDateToType, self.estimatedArrivalDateToFactor, _runDate);		// PAR #35826
	self.estimatedDepartDateFrom 	:= self.setDateFromTemplate(self.estimatedDepartDateFromType, self.estimatedDepartDateFromFactor, _runDate);		// PAR #35826
	self.estimatedDepartDateTo 		:= self.setDateFromTemplate(self.estimatedDepartDateToType, self.estimatedDepartDateToFactor, _runDate);			// PAR #35826
end;</source>
        <Parameter name="_runDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="2f0c7bea-2db8-4a8c-84b2-3eeb2cf4e5c6">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
// ---------------------------------------------------------------------------
// Created:     27 April 2005	cnwhjg1
//
// Purpose:     
// 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 09/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 Added expected arrival/departure from/to date
vars
	eventData : CM_EventDataVoyage;

begin
	inheritMethod(_obj, _runDate, _allEventData);

	self.arriveDateFrom := self.setDateFromTemplate(self.arriveDateFromType, self.arriveDateFromFactor, _runDate);
	self.arriveDateTo	:= self.setDateFromTemplate(self.arriveDateToType, self.arriveDateToFactor, _runDate);
	self.departDateFrom	:= self.setDateFromTemplate(self.departDateFromType, self.departDateFromFactor, _runDate);
	self.departDateTo	:= self.setDateFromTemplate(self.departDateToType, self.departDateToFactor, _runDate);
	self.inPortDateFrom	:= self.setDateFromTemplate(self.inPortDateFromType, self.inPortDateFromFactor, _runDate);
	self.inPortDateTo	:= self.setDateFromTemplate(self.inPortDateToType, self.inPortDateToFactor, _runDate);

	self.estimatedArrivalDateFrom 	:= self.setDateFromTemplate(self.estimatedArrivalDateFromType, self.estimatedArrivalDateFromFactor, _runDate);	// PAR #35826
	self.estimatedArrivalDateTo 		:= self.setDateFromTemplate(self.estimatedArrivalDateToType, self.estimatedArrivalDateToFactor, _runDate);		// PAR #35826
	self.estimatedDepartDateFrom 	:= self.setDateFromTemplate(self.estimatedDepartDateFromType, self.estimatedDepartDateFromFactor, _runDate);		// PAR #35826
	self.estimatedDepartDateTo 		:= self.setDateFromTemplate(self.estimatedDepartDateToType, self.estimatedDepartDateToFactor, _runDate);			// PAR #35826
	
	// This code sets the voyage for event driven schedules.
	// Have to do this for each appropriate class because they have different myVoyage references.
	eventData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventData &lt;&gt; null and eventData.myVoyage &lt;&gt; null then
		self.setMyVoyage( eventData.myVoyage );
	endif;

end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
