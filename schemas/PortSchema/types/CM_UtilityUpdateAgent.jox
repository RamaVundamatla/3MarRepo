		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VesselSection.name, null, null);
		return;
	endif;

	app.myValUA.valCM_Object(_proxyVesselSection,_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realVesselSection);

	if _passport.noErrors and realVesselSection.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "vesselSection", null, null);
		return;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVesselSection, true);
	endif;

	if _passport.noErrors then
		realVesselSection.setForUpdate(_proxyVesselSection,_passport);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVesselSection, false);
	endif;

epilog

end;</source>
        <Parameter name="_proxyVesselSection" type="CM_VesselSection"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVesselStructure" id="6e26a0fa-2092-4d00-a05b-b31b0015ece4">
        <source>utlUpdateVesselStructure(_proxyStructure : CM_VesselStructure; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
// ---------------------------------------------------------------------------
vars
	realStructure : CM_VesselStructure;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	_proxyStructure.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);
	_proxyStructure.pxyGetRealObjectAndEdition(realStructure, expectedEdition);
	
	if realStructure = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VesselStructure.name, null, null);
		return;
	endif;

	app.myValUA.valVesselStructure(_proxyStructure, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realStructure);

	if _passport.noErrors and realStructure.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Vessel_structure), null, null);//cnwas3 par 21579 added translatable string
		return;
	endif;
	
	if _proxyStructure.isKindOf(CM_CellularVesselStructure) then
		self.utlBaysEditionCheck(_proxyStructure.CM_CellularVesselStructure,_passport);		//cnwas3 par 21579
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realStructure, true);
	endif;

	if _passport.noErrors then
		realStructure.setForUpdate(_proxyStructure, _passport);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realStructure, false);
	endif;

end;</source>
        <Parameter name="_proxyStructure" type="CM_VesselStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
