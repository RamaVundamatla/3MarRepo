<GUIClass name="Control">
    <JadeMethod name="getMyTerminalFromForm" id="3920eaf1-9460-4ea7-b94e-2f7421d90350">
        <source>getMyTerminalFromForm(): CM_Terminal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

	agent : MobileDataAgent;
	terminal	: CM_Terminal;

begin
	if self.form &lt;&gt; null and self.form.isKindOf(MOB_BaseForm) then
		agent := self.form.MOB_BaseForm.getMyDataAgent;
		if agent &lt;&gt; null then
			terminal := agent.myTerminal;
		endif;
	endif;
	if terminal = null then
		if app.myLogonAgent = null then
			terminal := app.myLogonAgent.myTerminal;
		endif;
	endif;
	if terminal = null then
		terminal := app.getMyTerminalDO_NOT_USE();
	endif;

	return terminal;
	
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setAndIncrementTabIndex" id="777b22bd-d2f0-4b39-8f1a-47b0d3947a7e">
        <updating/>
        <source>setAndIncrementTabIndex( _tabIndex : Integer io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin
	
	self.tabIndex := _tabIndex;
	_tabIndex := _tabIndex + 1;

epilog

end;</source>
        <Parameter name="_tabIndex" type="Integer" usage="io"/>
    </JadeMethod>
