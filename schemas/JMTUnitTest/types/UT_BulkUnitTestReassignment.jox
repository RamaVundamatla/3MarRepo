    <JadeMethod name="updateTypeSourceString" id="05a23d0f-3baf-43a4-9922-839e0c4ad9a8">
        <source>updateTypeSourceString(_typeSource: String io; _userToAssignTo : String; _method : Method);

/*

Purpose:		

Date			Who		Reason
10/07/2015		cnwmh5	Initial creation

*/

vars

	methodSource							: String;
	firstLine								: String;
	pos										: Integer;

begin

	_typeSource := _typeSource &amp; CrLf &amp; 
		Tab &amp; _method.getSchemaType().name &amp; " (" &amp; CrLf &amp;
		Tab &amp; "jadeMethodSources" &amp; CrLf &amp;
		_method.name &amp; CrLf &amp;
		"{" &amp; CrLf;
		
	methodSource := _method.getSource();
	
	pos := 1;
	
	firstLine := methodSource.scanUntil(CrLf, pos);
	
	_typeSource := _typeSource &amp; 
		firstLine &amp; CrLf &amp;
		"// " &amp; _userToAssignTo &amp; 
		methodSource[pos:end] &amp; CrLf &amp;
		"}" &amp; CrLf &amp;
		Tab &amp; ")";	

epilog

end;</source>
        <Parameter name="_typeSource" type="String" usage="io"/>
        <Parameter name="_userToAssignTo" type="String"/>
        <Parameter name="_method" type="Method"/>
    </JadeMethod>
</GUIClass>
