    <JadeMethod name="doCriteriaChanged" id="03c9ccd8-73bb-4bee-a24a-1727b7717f99">
        <source>doCriteriaChanged();

/*

Purpose:		Call back method for change of criteria value (refer frmCriteria::formCriteriaChangeMethodName)

Parameters:			

Return Value:		


Date			Who		Reason
06 August 2008	consw1	Initial creation

*/

vars
	objs : ObjectSet;
	object : Object;
	control : CMUI_YACriteriaCntl;
	colour : Integer;
begin

	// Do this to save having to write hundreds of YA methods to get the colour
	on Exception do self.handleNoColourException(exception);


	colour := self.clrYAColour.getColor();
	if colour &gt; 0 then
		return;
	endif;
	
	
	control := self.locateControlForCriteriaType(self.myYARailConfig.myYACriteriaTypeForColour);
	create objs transient;
	if control &lt;&gt; null and self.myCurrentYAControl &lt;&gt; null then
		if control = self.myCurrentYAControl then
		if control.txtCriteriaValue.text &lt;&gt; null then
			self.myYARailConfig.myYACriteriaTypeForColour.resolvePattern(control.txtCriteriaValue.text,objs, true);
			
			if not objs.isEmpty() then
				object := objs.first();
				
				// Do this to save having to write hundreds of YA methods to get the colour
				colour := object.getPropertyValue("colour").Integer;
				
				self.clrYAColour.setColor(colour);
			endif;
		endif;
		endif;
	endif;
epilog
	delete objs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doIMEXSelected" id="eb033436-6a65-4a2f-b82f-cffd720cd27b">
        <updating/>
        <source>doIMEXSelected() updating;
//04 August 2008	cnwdw1	
//
vars
	imex : CM_IMEXStatus;
	yaIMEXConfig	: CM_YAIMEXConfig;
	criteriaType: CM_YACriteriaType;
	opCriteria: CM_YACriteriaArray;
	criteria, proxyCriteria: CM_YACriteria;
	allCriteria				: CMIF_Array;
	tmpObjectSet			: ObjectSet;
	transientObj			: CMIF_YACriteriaPriority;
	localAssistant : CMUI_Assistant;
begin
	self.allOperationalCriteria.purge();
	self.allTemplateCriteria.purge();
	imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
	self.cmbIMEX.setIndexFromObject(imex);
	
	if imex &lt;&gt; null and self.myTerminal.myYAConfig &lt;&gt; null then
		yaIMEXConfig := self.myTerminal.myYAConfig.allYARailConfigs[imex.code];
		self.myYARailConfig := yaIMEXConfig.CM_YARailConfig;
		create opCriteria transient;
		if yaIMEXConfig &lt;&gt; null then
		
			if yaIMEXConfig.allOpCriteria.isEmpty then
				app.msgBox(app.getErrorString(Pleas_rail_confi_some_colou_co), app.getErrorString(Problem), MsgBox_OK_Only);
				localAssistant := self.myAssistant;
				self.unloadForm();
//				localAssistant.showYAMaintRailForm(null, self.myMasterMenuAction, self);
			else
				foreach criteriaType in yaIMEXConfig.allOpCriteria do
					if self.myYardAllocation &lt;&gt; null then
						criteria := self.myYardAllocation.getCriteriaOfTypeValue(criteriaType.type);
					else
						//epr par 19078 19/3/09
						if allCriteria &lt;&gt; null and allCriteria.size &gt; 0 then
							criteria:=self.getCriteriaOfTypeFromTI(allCriteria,criteriaType.type);
						endif;
					endif;
					create proxyCriteria transient;
					if criteria = null then
						proxyCriteria.setProxy(criteriaType, "", "");			
					else
						proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
						opCriteria.add(criteria);
					endif;
					self.allOperationalCriteria.add( proxyCriteria.getTransient());
				endforeach;
			endif;
		endif;
		
		
		if self.myYardAllocation &lt;&gt; null then
			foreach criteria in self.myYardAllocation.allCriteria do
				if not opCriteria.includes(criteria) and criteria.myYACriteriaType.type &lt;&gt; YACriteriaType_ImexStatus then
				//if criteria.myYACriteriaType.type &lt;&gt; YACriteriaType_ImexStatus then
					create proxyCriteria transient;
					proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
					self.allTemplateCriteria.add( proxyCriteria.getTransient() );
				endif;
			endforeach; 
		else
			// PAR 19421 no extra template criteria are defaulted
		endif;
		self.populateCriteriaFrames(true);
		self.setIMEXDefaultColour();
	endif;
	

epilog
	if allCriteria &lt;&gt; null then
		allCriteria.purge();
		delete allCriteria;
	endif;
	if tmpObjectSet &lt;&gt; null then
		delete tmpObjectSet;
	endif;
	delete opCriteria;
end;</source>
    </JadeMethod>
