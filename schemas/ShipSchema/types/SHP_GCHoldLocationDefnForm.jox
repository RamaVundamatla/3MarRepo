        <updating/>
        <source>tblItems_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwndl1	Initial creation

*/

vars

	obj : CM_Object;

begin

	obj := self.tblItems.accessRow(self.tblItems.row).itemObject.CM_Object;
	
	self.doSelectItem(obj);

epilog

end;</source>
