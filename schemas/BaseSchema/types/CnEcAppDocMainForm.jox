    <JadeMethod name="doCheckForSave" id="751beb82-c03b-47d5-b771-205fbc4eee77">
        <source>doCheckForSave():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		23 December 2007 by cnwdad1
//
// Purpose:		Checks whether any outstanding changes that have not been saved to
//				the database should be ignored.
//
// Parameters:	None
//
// Returns:		True if there are changes, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aIsChanged then
		return self.cnEcAskToSaveChanges();
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDisplayClassText" id="9352ff0d-a611-4213-a396-67d6a77b8910">
        <updating/>
        <source>doDisplayClassText(pClassObj:Class) updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Purpose:		Loads the text for the specified class.
//
// Parameters:	pClassObj - A reference to the Class who's text to load.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	schemaObj	: Schema;
	
begin
	schemaObj	:=	self.aMyCurrentSchema;
	
	rtfDocumentation.load(pClassObj.text.trimBlanks(), JadeRichText.Load_ReplaceAll);
	rtfDocumentation.scrollVertPos	:=	0;
	
	if pClassObj.isSystemObject()
	or lstSchemas.findObject(pClassObj.rootType().schema) = CNEC_NULL_INDEX
	then
		rtfDocumentation.readOnly	:=	true;
	else
		rtfDocumentation.readOnly	:=	false;
		//rtfDocumentation.load(pClassObj.userText, JadeRichText.Load_ReplaceAll);
	endif;
	
	self.resetIsChanged();
end;</source>
        <access>protected</access>
        <Parameter name="pClassObj" type="Class"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="61906b71-c489-48f4-b2dc-4c8169f947dc">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 December 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	barApplications.visible	:=	false;
	self.doPopulateSchemas();
	self.resetIsChanged();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="581631b5-9ee4-470d-8007-9c09f9ed8d54">
        <updating/>
        <source>doFormUpdate(): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 December 2007 by cnwdad1
//
// Purpose:		Standard method to update the database from with the form's details.
//
// Parameters:	None
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	classObj	: Class;
	classText	: String;
	
begin
	classObj	:=	self.aMyCurrentClass;
	
	if classObj.isSystemObject()
	or lstSchemas.findObject(classObj.rootType().schema) = CNEC_NULL_INDEX
	then
	app.msgBox("You cannot update system class text.", $CNEC_ERROR, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	if classObj = null then
		return false;
	endif;
	
	classText	:=	rtfDocumentation.textRTF.trimBlanks();
	
	beginTransaction;
	classObj.setPropertyValue(SchemaEntity::text.name, classText);
	commitTransaction;
	
	return inheritMethod();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOpenCloseClassNode" id="7a5ee1b2-6d07-47fc-a92f-bc7b4f15dc74">
        <source>doOpenCloseClassNode(pListboxObj:ListBox input; pListPointer:Integer; pIsRecursive:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		14 April 2006 by cnwdad1
//
// Purpose:		Opens/Closes the selected tree node of the specified listbox.
//
// Parameters:	pListboxObj - A reference to the listbox control.
//				pListPointer - The index if the tree node to open/close.
//				pIsRecursive - True if the entire branch is to be eopened/closed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	nextPointer	: Integer;
	
begin
	if (not pListboxObj.itemExpanded[pListPointer])
	and ((pListPointer + 1) &lt;= pListboxObj.listCount)
	and (pListboxObj.itemText[pListPointer + 1] = self.DUMMY_FOLDER)
	and (pListboxObj.itemObject[pListPointer].Class.hasSubclasses)
	then
		self.doPopulateSubclasses(	pListboxObj.itemObject[pListPointer].Class,
									(pListboxObj.itemLevel[pListPointer] + 1));
	endif;

	pListboxObj.itemExpanded[pListPointer]	:=	(not pListboxObj.itemExpanded[pListPointer]);
	
	if pIsRecursive and pListboxObj.itemExpanded[pListPointer] then
		nextPointer	:=	pListPointer + 1;
		
		if nextPointer &lt;= pListboxObj.listCount() then
			self.doOpenCloseClassNode(pListboxObj, nextPointer, pIsRecursive);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pListboxObj" type="ListBox" usage="input"/>
        <Parameter name="pListPointer" type="Integer"/>
        <Parameter name="pIsRecursive" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPopulateClasses" id="fdb2ee3d-8ffa-4bee-a068-63f1c43618a7">
        <source>doPopulateClasses() protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Purpose:		Loads classes into an hierarchical structure within the listbox.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	schemaObj		: Schema;
	listboxObj		: ListBox;
	allClassesObj	: ClassColl;
	classObj		: Class;
	listClassObj	: Class;
	listPointer		: Integer;

begin
	schemaObj	:=	self.aMyCurrentSchema;
	
	if schemaObj = null then
		return;
	endif;
	
	listboxObj	:=	lstClasses;
	listboxObj.clear();
	
	create allClassesObj transient;
	
	// Get the top-level classes for all schemas.
	schemaObj.getClass(Object.name).getSubclasses(allClassesObj);
	
	if allClassesObj.isEmpty() then
		return;
	endif;
	
	listPointer	:=	listboxObj.addItem(self.getClassDescription(schemaObj, Object));
	listboxObj.itemObject[listPointer]	:=	Object;
	listboxObj.itemLevel[listPointer]	:=	1;
	self.getClassForeColor(schemaObj, Object, listboxObj, listPointer);
	
	foreach classObj in allClassesObj do
//		if not classObj.cnEcHasNonSystemSubclass() then
//			continue;
//		endif;
		
		if classObj._isSubschemaCopy then
			listClassObj	:=	classObj.cnEcGetImplementationSchema().getClass(classObj.name);
		else
			listClassObj	:=	classObj;
		endif;
		
		listPointer	:=	listboxObj.addItem(self.getClassDescription(schemaObj, listClassObj));
		listboxObj.itemObject[listPointer]	:=	listClassObj;
		listboxObj.itemLevel[listPointer]	:=	2;
		
		self.getClassForeColor(schemaObj, listClassObj, listboxObj, listPointer);
		
		if listClassObj.hasSubclasses() then
			listPointer	:=	listboxObj.addItem(self.DUMMY_FOLDER);
			listboxObj.itemLevel[listPointer]	:=	3;
		endif;
	endforeach;
epilog
	delete allClassesObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPopulateSchemas" id="1cb2de44-8e6b-440e-99f5-8871e4fcf3b1">
        <source>doPopulateSchemas() protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Purpose:		Populates the listbox with an hierarchy of Schemas.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj			: ListBox;
	schemaObj			: Schema;
	allSubschemasObj	: SchemaNDict;
	rowPointer			: Integer;
	
begin
	listboxObj	:=	lstSchemas;
	create allSubschemasObj transient;
	rootSchema.getSubschemas(allSubschemasObj);// allSubschemas(allSubschemasObj);
	
	foreach schemaObj in allSubschemasObj do
		rowPointer	:=	listboxObj.addItem(schemaObj.name);
		listboxObj.itemObject[rowPointer]	:=	schemaObj;
		
		self.doPopulateSubschemas(schemaObj, listboxObj, 2);
	endforeach;
epilog
	delete allSubschemasObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPopulateSubclasses" id="4c1d9563-bfdd-4225-897b-d140aa6447a2">
        <source>doPopulateSubclasses(pSubclassObj:Class; pLevel:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		09 February 2003 by cnwdad1
//
// Purpose:		Loads all subclasses of the currently selected class.
//
// Parameters:	pSubclassObj (Class) - The class to begin loading from.
//				pLevel (Integer) - The hierarchical list level to start from.
//
// Returns:		nothing	
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	schemaObj		: Schema;
	listboxObj		: ListBox;
	allClassesObj	: ClassColl;
	classObj		: Class;
	listClassObj	: Class;
	listPointer		: Integer;

begin
	schemaObj	:=	self.aMyCurrentSchema;
	
	if schemaObj = null then
		return;
	endif;
	
	listboxObj		:=	lstClasses;
	listPointer		:=	listboxObj.findObject(pSubclassObj);
	listboxObj.removeItem(listPointer + 1);	// Remove the dummy folder item.
	
	create allClassesObj transient;

	// Get the top-level classes for all schemas.
	schemaObj.getClass(pSubclassObj.name).getSubclasses(allClassesObj);
	
	if allClassesObj.isEmpty() then
		write "Didn't find any classes for " &amp; schemaObj.name &amp; ".";
		return;
	endif;
	
	foreach classObj in allClassesObj do
//		if not classObj.cnEcHasNonSystemSubclass() then
//			continue;
//		endif;
		
		if classObj._isSubschemaCopy then
			listClassObj	:=	classObj.rootType().schema.getClass(classObj.name);
		else
			listClassObj	:=	classObj;
		endif;
		
		listPointer							:=	listPointer + 1;
		listboxObj.addItemAt(self.getClassDescription(schemaObj, listClassObj), listPointer);
		listboxObj.itemObject[listPointer]	:=	listClassObj;
		listboxObj.itemLevel[listPointer]	:=	pLevel;
		beginClassNotification(listClassObj, false, Any_System_Event, Response_Continuous, 1);
		self.getClassForeColor(schemaObj, listClassObj, listboxObj, listPointer);
		
		if listClassObj.hasSubclasses() then
			listPointer							:=	listPointer + 1;
			listboxObj.addItemAt(self.DUMMY_FOLDER, listPointer);
			listboxObj.itemLevel[listPointer]	:=	pLevel + 1;
		endif;
	endforeach;
epilog
	delete allClassesObj;
end;</source>
        <access>protected</access>
        <Parameter name="pSubclassObj" type="Class"/>
        <Parameter name="pLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doPopulateSubschemas" id="a9ab39da-10dd-4ad0-8595-56a51612f7af">
        <source>doPopulateSubschemas(pSchemaObj:Schema; pListboxObj:ListBox input; pLevel:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		23 December 2007 by cnwdad1
//
// Purpose:		Populates the subschemas of the specified Schema into the listbox
//				hierarchy.
//
// Parameters:	pSchemaObj - A reference to the Schema who's subclasses to list.
//				pListboxObj - A reference to the listbox control to populate.
//				pLevel - The hierarchy level at which to populate the schemas.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	schemaObj			: Schema;
	allSubschemasObj	: SchemaNDict;
	rowPointer			: Integer;
	
begin
	create allSubschemasObj transient;
	pSchemaObj.getSubschemas(allSubschemasObj);
	
	foreach schemaObj in allSubschemasObj do
		rowPointer	:=	pListboxObj.addItem(schemaObj.name);
		pListboxObj.itemObject[rowPointer]	:=	schemaObj;
		pListboxObj.itemLevel[rowPointer]	:=	pLevel;
		
		self.doPopulateSubschemas(schemaObj, pListboxObj, pLevel + 1);
	endforeach;
epilog
	delete allSubschemasObj;
end;</source>
        <access>protected</access>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pListboxObj" type="ListBox" usage="input"/>
        <Parameter name="pLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="firstChange" id="65ed01b5-331f-49a9-923a-b481b0743849">
        <controlMethod name="Form::firstChange"/>
