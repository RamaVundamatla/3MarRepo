    <JadeMethod name="setProxy" id="8b1c80c9-f314-40dd-8c6c-997ba0d601f1">
        <updating/>
        <source>setProxy(	_deckHeight : Decimal;			
			_lenInUnits : Integer;
			_maxCargoHeight : Decimal;
			_maxLoadWeight : Decimal;
			_overallLength : Decimal;
			_overallWidth : Decimal;
			_tareWeight : Decimal;
			_wellId : String;
			_wellLocations : StringArray
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwndl1	Initial creation

*/

vars

begin

	self.deckHeight := _deckHeight;		
	self.lenInUnits := _lenInUnits;	
	self.maxCargoHeight := _maxCargoHeight;
	self.maxLoadWeight := _maxLoadWeight;	
	self.overallLength := _overallLength;	
	self.overallWidth := _overallWidth;	
	self.tareWeight := _tareWeight;	
	self.wellId := _wellId;	
	
	self.wellLocationIds.clear();
	if not _wellLocations.isEmpty then
		_wellLocations.copy( self.wellLocationIds );
	endif;

epilog

end;</source>
        <Parameter name="_deckHeight" type="Decimal"/>
        <Parameter name="_lenInUnits" type="Integer"/>
        <Parameter name="_maxCargoHeight" type="Decimal"/>
        <Parameter name="_maxLoadWeight" type="Decimal"/>
        <Parameter name="_overallLength" type="Decimal"/>
        <Parameter name="_overallWidth" type="Decimal"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_wellId" type="String"/>
        <Parameter name="_wellLocations" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="4cd692ae-d1f6-4d28-9079-342583ff65ee">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwndl1	Initial creation

*/

vars

begin

	self.validateMe;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="9ec88d90-d215-4ba4-95dc-1d7ed15d536a">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwndl1	Initial creation

*/

vars

	lLoc : Integer;

begin

	if self.myWagonClass = null then
		app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(Associated_object), app.getErrorString(Wagon_posit_rule_must_assoc_wi), null, null);
		return;
	endif;
	
	if self.wellId = null then
		app.raiseCMException(Well_required, null, null);
		return;
	endif;
	
	if self.wellLocationIds.size &lt;&gt; self.lenInUnits then
		app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(Location_ids), app.getErrorString(Enter_listof_of_labels), null, null);
		return;
	endif;
	
	foreach lLoc in 1 to self.lenInUnits do
		if self.wellLocationIds[lLoc].trimBlanks.length &gt;= 2 then
			app.raiseCMException1(Locatio_long_only_charact, self.wellLocationIds[lLoc].trimBlanks, null, null);
			break;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
</Class>
