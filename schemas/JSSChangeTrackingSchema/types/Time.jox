<PrimType name="Time">
    <JadeMethod name="truncateToSecond" id="aebca3af-0f1a-4725-b4cf-47f1c1c35c93">
        <source>truncateToSecond(): Time;
// ---------------------------------------------------------------------------
//27 Jul 2016	cnwrs1	Par 38030 C3 Data Extract loosing updates
// ---------------------------------------------------------------------------
vars
	timeToSecond : Time;
begin
	timeToSecond.setTime(self.hour, self.minute, self.second, 0);
	return timeToSecond;
end;
</source>
        <ReturnType type="Time"/>
    </JadeMethod>
</PrimType>
