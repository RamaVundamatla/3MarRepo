    <JadeMethod name="setupForm" id="49ac1610-1367-4a1b-ad61-eada1ea59dd9">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();


	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.initTblData();	
	
	self.setNavigatorHeading(self.caption);
	
	self.beginClassNotification(CM_Package, false, Object_Delete_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Package, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Package, false, Object_Update_Event, Response_Continuous, 0);
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnDelete.enabled := false;
		self.btnNew.enabled := false;
		self.btnEdit.enabled := false;
	endif;

	

end;</source>
    </JadeMethod>
