    <JadeMethod name="getQueryDefinition" id="e57eabe6-51e2-43be-b031-9312245b8615">
        <source>getQueryDefinition( _form: RadioTelemetryMainForm input; _queryOid: String; _errorStr : String output ) : Boolean;
// -------------------------------------------
// Created 28 April 2008 by cnwvu1
// -------------------------------------------

vars
	rtnValue	: Boolean;
	dtoQueryDef	: MobileServerRTThin::DTO_QueryDefinitionRT;

begin

	create dtoQueryDef transient;
	
	rtnValue := self.myRTThinClientAgent.getQueryDefinition( dtoQueryDef, _queryOid, _errorStr );
	
	if rtnValue then
		_form.loadFormFromQueryDTO( dtoQueryDef );
	endif;

	return rtnValue;

	
epilog
	delete dtoQueryDef;

end;
</source>
        <Parameter name="_form" type="RadioTelemetryMainForm" usage="input"/>
        <Parameter name="_queryOid" type="String"/>
        <Parameter name="_errorStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQuerySet" id="182c2e55-3112-4ef6-86fa-83130b272ea7">
        <source>getQuerySet( _form: RadioTelemetryMainForm input );
// -------------------------------------------
// Created 21 April 2008 by cnwvu1
// -------------------------------------------

vars
	dtoQuerySet	: MobileServerRTThin::DTO_QuerySetForRT;
	
begin

	create dtoQuerySet transient;

	self.myRTThinClientAgent.getQuerySet( dtoQuerySet );
	
