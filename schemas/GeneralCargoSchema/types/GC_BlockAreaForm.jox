    <JadeMethod name="doSetCaption" id="9aff9bc6-3a98-4d95-90f4-080f62d70e1c">
        <updating/>
        <source>doSetCaption() updating, protected;

/*

Purpose:			Set the form caption from the selected cargo areas


Return Value:		None


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	theCaption		: String;
	aTA				: Object;
	
begin
	theCaption := app.getErrorString(TerminalAreas);
	
	if self.myCurrentTerminalArea &lt;&gt; null then
		theCaption := theCaption &amp; " " &amp; myCurrentTerminalArea.id;
	endif;	
	
	self.setCaption ( theCaption ) ;  // cnwrd1 par #17398 , 22.9.08

	// Update the navigator
	self.setNavigatorHeading(self.caption); 
	

end;</source>
        <access>protected</access>
    </JadeMethod>
