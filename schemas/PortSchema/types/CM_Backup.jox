    <JadeMethod name="setStatus" id="8bd9642d-e6d3-4450-8540-5b7e608f09d2">
        <updating/>
        <source>setStatus(_status: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// ---------------------------------------------------------------------------
vars

begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' OldStatus='&amp;self.status.String&amp;'('&amp;self.getDisplayStatus(self.status)&amp;')'&amp;' NewStatus='&amp;_status.String&amp;'('&amp;self.getDisplayStatus(_status)&amp;')', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

	self.status := _status;
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="85fd0005-58f2-4acf-a0fa-d5aeda5d39bd">
        <updating/>
        <source>userNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	backupJornalAgent: CM_BackupAgentJournal;
begin
	// Check for LogTransferEvent notifications
	if _eventType = JadeDatabaseAdmin.JournalTransferEvent then
		create backupJornalAgent transient;
		backupJornalAgent.doJournalTransfer(_userInfo);
		delete backupJornalAgent;
		return;
	endif;

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="c1242555-65aa-4bda-b6ed-40efbe39b95c">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/12/2014  cnwdb2	PAR 35364
// ---------------------------------------------------------------------------
vars

begin
	// CM_Backup must be a singleton
	if CM_Backup.firstInstance &lt;&gt; null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'BackupXX', null, null);
		app.raiseCMException(Input_required_field_bakUpXX, null, null); // cnwdb2	PAR 35364
	endif;
	self.validateForUpdate;
end;</source>
    </JadeMethod>
