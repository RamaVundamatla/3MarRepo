	endif;

	realObject := _voyageDelayProxy.myVoyageData.allVoyageDelays[_voyageDelayProxy.startTime];
	if realObject = null then
		app.myTrxCA.trxCreateHMSObject(_voyageDelayProxy, realObject, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageDelayProxy.startTime.String&amp;" ERROR: "&amp;"Voyage Delay already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageDelayProxy.startTime.String&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageDelayProxy.startTime.String&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
