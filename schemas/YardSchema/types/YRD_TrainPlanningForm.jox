    <JadeMethod name="btnNewWindow_click" id="1528c61d-fe4b-40cb-bdac-d98613494d76">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNewWindow_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars
	menuAction : CMUI_MenuAction;
	tpForm : YRD_TrainPlanningForm;

begin
	menuAction := app.myController.createMenuAction(PmAdmRailPlanningView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;

	tpForm := menuAction.goToObject(null, null, false, null).YRD_TrainPlanningForm;	
	if tpForm = null then
		return;
	endif;
	
	if self.isDisplayedRailAreas then
		tpForm.setDisplayedObject(self.allRailAreas);
	else
		tpForm.setDisplayedObject(self.allTrains);
	endif;
	
	tpForm.setDirection(optDirOutTB.value);

	tpForm.show;	

end;</source>
