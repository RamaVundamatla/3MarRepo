<ExceptionClass name="Exception">
    <JadeMethod name="isMobileServerException" id="25949310-95f4-407a-9911-533bf22ba58c">
        <source>isMobileServerException():Boolean;
// --------------------------------------------------------------------------------
// Created:		18 October 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a Mobile
//				Server error.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Mobile Server error, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSoapException" id="4a58b790-9775-48a5-b24b-fff146f75863">
