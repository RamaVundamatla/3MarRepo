/*	self.splMain.width := self.width - WinLeftMargin - WinRightMargin;
	self.splMain.left := self.lblLogVoyage.left;
	self.splMain.height := self.height - grpUpdate.height - WinTopMargin*2 - lblLogVoyage.height - WinBottomMargin;
	self.splMain.cnEcResizeContents();
	self.btnClose.move(self.width - btnClose.width - WinRightMargin, self.height - btnClose.height - WinBottomMargin, btnClose.width, btnClose.height);
	self.btnUpdate.move(btnClose.left, btnClose.top - VerticalSpacing - btnUpdate.height, btnUpdate.width, btnUpdate.height);
	self.grpUpdate.move(splMain.left, self.height - WinBottomMargin - grpUpdate.height, grpUpdate.width, grpUpdate.height);	
	self.tblData.move(grpUpdate.left + grpUpdate.width + WinRightMargin, grpUpdate.top, tblData.width, tblData.height);		*/
	if self.frmToolbar.visible then
		self.frmToolbar.repositionAfterResize;
