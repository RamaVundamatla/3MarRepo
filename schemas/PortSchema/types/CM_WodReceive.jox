    <JadeMethod name="getCustomEntryNumber" id="8d2b153e-d86d-46f7-a82a-13c41648ee28">
        <source>getCustomEntryNumber(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	ti 		: CM_TrackedItem;
	cen		: String;
begin
	
	
	ti := self.getFirstTI();
	
	if ti &lt;&gt; null then
		cen := ti.customsEntryNumber;
	endif;
	
	if cen = null then
		cen := self.customExportEntryNumber;
	endif;
	
	return cen;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="22db71cd-5abb-4d03-82f4-366664023ed4">
        <source>getDisplayString(_useShortDesc: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 27/06/2018   cnwma1		Bug 39441: Getting 1090 when searching for work orders
// 29 Sep 2021  navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
// 06 Mar 2023  navma1 		ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
//
vars
	displayString : String;
	invalidObj    : Boolean;
	typeDesc      : String;
	code		  : String;
begin
	on Exception do app.handleDeletedObject( exception, self.myBookingRef, invalidObj ); //27.6.2018 cnwma1 TFS #39441
	
	typeDesc := self.getTypeDescription();												 //29.09.2021 navma1 #51925
	
	if _useShortDesc then
		displayString := typeDesc &amp;" Task #" &amp; self.getTaskSequenceNumber().String;		//06.03.2023 navma1 #56457:[56458]
	else
		
		if self.myBookingRef &lt;&gt; null then
			code := self.myBookingRef.bookingReference;									//29.09.2021 navma1 #51925
		endif;
		
		displayString :=  self.getLongDescription(typeDesc,code);						//29.09.2021 navma1 #51925
			
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
