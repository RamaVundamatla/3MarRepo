    <JadeMethod name="getDataAccessController" id="e56d885e-39a4-410f-bf7a-9f33d8412a94">
        <source>getDataAccessController(pClassName : String) : CM_DataAccessController;
// ---------------------------------------------------------------------------
// Created:     27 August 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
