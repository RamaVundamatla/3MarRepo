    <JadeMethod name="updateSelf" id="ff8af81f-c2f3-4aad-a254-a6ab9f19a5c4">
        <updating/>
        <source>updateSelf(_value: Any; _obj :Object) updating;
// ---------------------------------------------------------------------------
// Created:     11 February 2010 by cnwcs5
// Purpose:     par 22140 - new functions
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/02/2010	cnwcs5		par 22435 - release summary extenstions
// ---------------------------------------------------------------------------
vars

begin
	if _value.isKindOf (CM_SnapshotField_Count_True) then
		self.count 	:= self.count + _value.CM_SnapshotField_Count_True.count;
		return;
	endif;
	
	// _value will be Boolean
	if _value.Boolean then
		self.count := self.count + 1;
		
		self.allObjects.addNoDuplicates (_obj, false);	// 22/02/2010
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
