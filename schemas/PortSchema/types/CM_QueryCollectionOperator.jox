<Class name="CM_QueryCollectionOperator" id="490386d2-666b-4251-a33f-8fc726542107">
    <superclass name="CM_QueryOperator"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allSelectionValues" id="b9fb8ae0-d377-44c8-9116-ae90d3334a0d">
        <memberTypeInverse/>
        <type name="ObjectSet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="cloneReferences" id="deceac82-4a41-486e-9220-1632f005a4c2">
        <updating/>
        <source>cloneReferences(_targetReceiver: SelfType input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2013	cnwpjs1	Initial creation  PAR # 31237

*/

vars

begin
	inheritMethod(_targetReceiver);
	self.allSelectionValues.copy(_targetReceiver.allSelectionValues);


epilog

end;</source>
        <Parameter name="_targetReceiver" type="SelfType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSearchValue" id="bb46ca2f-bf27-47b2-b81a-393963b6fe60">
        <source>getSearchValue(): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2013	cnwpjs1	Initial creation   PAr # 31237

*/

vars

begin
	return self.allSelectionValues;

epilog

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="edf552c8-e02f-4a86-936f-48679da58c5d">
        <source>getSearchValueStr(_prop: CM_QueryProperty): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2013	cnwpjs1	Initial creation  PAr # 31237

*/

vars

	obj	: Object;
	str	: String;
	
begin

	foreach obj in self.allSelectionValues do
		if obj = null
		or global.isValidObject(obj) then
			if str = null then
				str := _prop.translateToDisplayValue(obj);
			else
				str := str &amp; ', ' &amp; _prop.translateToDisplayValue(obj);
			endif;
		endif;
	endforeach;
	
	return str;

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidForRT" id="459ab995-4461-47ef-8de2-f8340bffd2f9">
        <source>isValidForRT(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
