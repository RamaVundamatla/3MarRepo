    <Constant name="FORM_HEIGHT" id="232077a1-b584-439f-8dfb-a9b8e2dd2d2b">
        <source>400</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="FORM_WIDTH" id="7eae0809-e2ac-41b2-af83-8c85028f04c2">
