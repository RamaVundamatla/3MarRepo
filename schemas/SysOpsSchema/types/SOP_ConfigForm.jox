    <JadeMethod name="getAuthTypeListIndex" id="c31d90cc-7ccb-46ab-980a-8336ed745c72">
        <source>getAuthTypeListIndex(_itemData : Integer) : Integer protected;

// Created by cnwdvb1 on 14 August 2007

vars

begin
	
	if _itemData = BGP_EmailSendRequest.AUTH_NONE then
		return 1;
	elseif _itemData = BGP_EmailSendRequest.AUTH_LOGIN then
		return 2;
	elseif _itemData = BGP_EmailSendRequest.AUTH_NTLM then
		return 3;
	elseif  _itemData = BGP_EmailSendRequest.AUTH_CRAM_MD5 then
		return 4;
	elseif _itemData = BGP_EmailSendRequest.AUTH_PLAIN then
		return 5;
	elseif _itemData = BGP_EmailSendRequest.AUTH_MSN then
		return 6;
	else
		return -1;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_itemData" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
