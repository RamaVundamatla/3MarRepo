    <JadeMethod name="wsFindCargoQuickView" id="99c81e6c-dc29-4d25-ad87-b32951c6bc8f">
        <source>wsFindCargoQuickView(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlgma1	Initial creation

*/

vars
	ref : String;
	queryRequest : WS_TrackedItemQueryRequest;
		queryResponse		: WS_TrackedItemQueryResponse;
		queryReqService : JMTUserInterfaceService;
		id,bol,booking : String;
		totalFound :Integer;

begin

	create queryRequest transient;
	
	id := "PRE16181";
	bol:= "";
	booking :="";// "UTBK00001";
	queryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterId.name, id);
	queryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterBOL.name, bol);
	queryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterBookingRef.name,booking);
	queryRequest.setPropertyValue(WS_TrackedItemQueryRequest::filterSite.name,TI_SITE_ONSITE.String);
	queryRequest.setPropertyValue(WS_TrackedItemQueryRequest::maxReturnedItems.name,20.Integer);
	
	create queryReqService transient;
	queryResponse := queryReqService.findCargoQuickView(queryRequest);
	if queryResponse = null then
		return "test 1, queryResponse not returned.";
	endif;
	
	totalFound := queryResponse.allTrackedItems.size;
	if totalFound &lt; 1 then
		return " queryResponse no log found, probably wrong.";
	endif;
	
	if queryResponse.hasErrors then
		return "test 2, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	
	delete queryResponse;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsFindCargoQuickView.name; 

epilog

	delete queryResponse;
	delete queryRequest;
	delete queryReqService;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsFindLogDockets" id="3cf38be0-558a-46e6-ad72-f29ce0b2b8e6">
        <source>wsFindLogDockets(_docOid: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlgma1	Initial creation

*/

vars
	ref : String;
		queryRequest : WS_LogDocketQueryRequest;
		queryResponse		: WS_LogDocketResponse;
		queryReqService : JMTUserInterfaceService;
		id : String;
		totalFound :Integer;
begin
	
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	//Query trackeditems
	create queryRequest transient;
	queryRequest.setPropertyValue("filterOID",_docOid);
	// just looking for any cargo that starts with 'UT' anywhere related to terminal 'UT'
	
	queryRequest.maxReturnedItems := 50;
	queryRequest.startFrom := 0;	
	
	create queryReqService transient;
	queryResponse := queryReqService.findLogDockets(queryRequest);
	if queryResponse = null then
		return "test 1, queryResponse not returned.";
	endif;
	
	totalFound := queryResponse.allBOLs.size;
	if totalFound &lt; 1 then
		return " queryResponse no log found, probably wrong.";
	endif;
	
	if queryResponse.hasErrors then
		return "test 2, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	delete queryResponse;	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsFindLogDockets.name; 

epilog
		delete queryResponse;
	delete queryRequest;
	delete queryReqService;
end;</source>
        <Parameter name="_docOid" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsGateInOutInspectionCheck" id="7870f64a-885e-4712-8ec0-5656a3c12d78">
