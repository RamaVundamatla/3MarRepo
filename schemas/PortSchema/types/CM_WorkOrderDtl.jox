    <JadeMethod name="setRequiredByDT" id="346afb4e-85be-4e4f-81ce-78749f22c283">
        <updating/>
        <source>setRequiredByDT(_dateTime : TimeStamp) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/06/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work order fix ups
//
vars

begin
	if self.requiredByDT &lt;&gt; _dateTime then
		self.requiredByDT := _dateTime;
		//jlier1 29/5/25 MTN-34591 
		self.causeTerminalEvent(Event_WODtl_Update);
	endif;
epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="a949c182-4ef3-495b-8124-8b8ee5a1edcb">
        <updating/>
        <source>setStatus(_newStatus : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 Oct 2022		navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
17 Jan 2023 	navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions
28 Mar 2023 	navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars
	transType		: Integer;
	wotran	: CM_WOTransaction; 
begin
	transType := self.getTransTypeByMode();										//30.3.2023 navhl20	#56614[56615]
	if _newStatus = WO_STATUS_COMPLETE 
	and _newStatus &lt;&gt; self.status then
	 // ### TFS CR 54345 TASK 58281 14JUN2023 NAVAB1 removed the following line becasue it was stopping the complete transaction being created when the status was complete.
//	and transType &lt;&gt; TRANS_TYPE_WO_TITODO_COMPLET then							//30.3.2023 navhl20	#56614[56615]
		wotran := self.createWOTransaction(self.TRANS_COMPLETED, null, null);							// 17.01.2023 navcs2 #56633:[56211]

		/* // ### TFS DEFECT 59150 17JUL2023 NAVAB1
		// ### TFS BUG58790 23JUN2023 NAVAB1
		if wotran &lt;&gt; null then
			wotran.createCharge();
		endif;
		*/
	endif;
	
	self.status := _newStatus;
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WODtl_Update);
epilog

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTaskID" id="9c2e7353-d0e1-4c4c-97bf-515435c78da8">
        <updating/>
        <source>setTaskID(_taskId : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05 May 2022	navcs2		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
//
vars

begin
	if self.taskID &lt;&gt; _taskId then
		self.taskID := _taskId;
		
		//jlier1 29/5/25 MTN-34591 
		self.causeTerminalEvent(Event_WODtl_Update);
	endif;
epilog

end;</source>
        <Parameter name="_taskId" type="String"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="a7a623c4-2915-4098-b783-481ec9051082">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_WorkOrderDtl::myWOTransaction.name		or 
		propName = CM_WorkOrderDtl::detailType.name				or 
		propName = CM_WorkOrderDtl::startByDT.name   			or
		propName = CM_WorkOrderDtl::status.name 				
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
