	endif;
	if _code = CANS then
		return 7;
	endif;
	if _code = CASES then
		return 8;
	endif;
	if _code = COILS then
		return 9;
	endif;
	if _code = CRATES then
		return 10;
	endif;
	if _code = CARTONS then
		return 11;
	endif;
	if _code = CYLINDER then
		return 12;
	endif;
	if _code = DRUMS then
		return 13;
	endif;
