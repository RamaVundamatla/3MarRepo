        <source>getViewMode() : Integer protected;
/*

Date		Who		Reason
22 July 2013	cnwer1	Initial creation PAR

*/

vars

begin
	if self.btnViewCommodity.value  then
		return VIEW_COMMODITY;
	elseif self.btnViewCommodity.value then
		return VIEW_CONSIGNEE;
	elseif self.btnViewDischarge.value then
		return VIEW_DISPORT;
	elseif self.btnViewISOGroup.value then
		return VIEW_ISOGROUP;
	elseif self.btnViewOperator.value then
		return VIEW_OPERATOR;
	elseif self.btnViewStatus.value then	
		return VIEW_STATUS;
	elseif  self.btnViewTempRange.value  then
		return VIEW_TEMPERATURE;
	else
		self.btnViewVoyage.value:=true;
		return VIEW_VOYAGE;
	endif;
epilog

