    <JadeMethod name="btnCancel_click" id="a4cd2f8e-95e4-4a74-801c-b7e423715faa">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2010	cnwndl1	Initial creation

*/

vars

begin

	if self.myProxyCalendar &lt;&gt; null and self.myRealCalendar = null then
		// I'm in the throws of creating a new calendar and don't want to anymore...
		self.selectCalendar( null );
		self.btnNewCalendar.enabled := true;
		self.cmbCalendar.enabled := true;
		self.btnCalSave.enabled := false;
		return;
	elseif self.myRealCalendar &lt;&gt; null then
		// abort the changes I made, i.e. reload the data
		self.selectCalendar( cmbCalendar.listObject.CM_Calendar );
	endif;

epilog

end;</source>
