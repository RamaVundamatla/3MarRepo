    <JadeMethod name="doNotableClear" id="0e16e74f-55d8-4b96-be79-4f851e8cbab0">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_TerminalArea) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED));
			removedNotification := removedNotification + 1;
		elseif anObject.isKindOf(CM_Voyage) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_UNPLANNED));
			endNotification(anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED));
			endNotification(anObject, self.myTerminal.getTerminalEvent(TIEvent_Transit_Status_Update));
			removedNotification := removedNotification + 1;
		elseif anObject.isKindOf(CM_TrackedItem) then
			endNotification(anObject, Object_Update_Event);
			endNotification(anObject, Object_Delete_Event);
			removedNotification := removedNotification + 1;
		endif;
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableNotification" id="3cb0ad91-f755-441e-9a2a-4416e546efa9">
        <updating/>
        <source>doNotableNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 25/11/2010	cnwdap1		PAR # 26426 CCMS MES 1102 Deal with WLE notifications
// 31/08/2017	cnwma1		TFS 6554#POL - ##5074## Lica Maersk 754N - Movins/Colour Code Issues (Part 2)
vars
	lController		: CM_LocationsController;
	event,theRow,
	numZeros, idx	: Integer;
	theCode			: String;
	theArea			: CM_BlockStack;
	anObject		: Object;
	theTI,
	theObjectTI		: CM_TrackedItem;
	breakOut		: Boolean;
//	theObjectSR		: CM_SlotRequest;
	theObjectReq	: CM_Request;	//21 Nov 2012	NDL	Par 30754
	invalidVoyage,
	invalidUserInfo, invalidLC	: Boolean; //cnwrd1 par 31419 
	aUserInfoObject : Object; //cnwrd1 par 31419 
	isUnplannedTranship : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentVoyage, invalidVoyage); //10/10/08 cnwdz2 Par 17732
	on Exception do app.handleDeletedObject(exception, aUserInfoObject, invalidUserInfo); //cnwrd1 par 31419 

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. event " &amp; event.String &amp; " theObject: " &amp; theObject.String &amp; " userInfo: " &amp; userInfo.String);	
		
	if event = EVENT_STOP_CARGO_RECEIVAL then
		if theObject.CM_Voyage = self.myCurrentVoyage then
			self.doComboOperatorBuild();
		endif;
		return;
	endif;
	
	if userInfo.isKindOf(Object) then //cnwrd1 par 31419 
		aUserInfoObject := userInfo.Object;
	endif;

	if aUserInfoObject.isKindOf(CM_SlotRequest) then
		theObjectReq := aUserInfoObject.CM_SlotRequest;
	elseif aUserInfoObject.isKindOf(CM_VoyageRequest) then
// PAR 32121 if this was an OOTL and the load CC is erased the LC is also erased
		on Exception do app.handleDeletedObject(exception, userInfo.CM_VoyageROROController, invalidLC); 
		if userInfo.isKindOf(CM_VoyageROROController) then //cnwrd1 par 32670 need to make sure this is the right class!
			theObjectReq := userInfo.CM_VoyageROROController.myRORORequestLoad;
			if invalidLC then
				return;
			endif;
		endif;
	//21 Nov 2012	NDL	Par 30754
	elseif aUserInfoObject.isKindOf(CM_SlotController) then
		theObjectReq := aUserInfoObject.CM_SlotController.mySlotRequestLoad;	
	elseif aUserInfoObject.isKindOf(CM_VoyageROROController) then
		theObjectReq := aUserInfoObject.CM_VoyageROROController.myRORORequestLoad;
	endif;

	if event = TIEvent_Transit_Status_Update or event = EVENT_PLANNING_TI_PLANNED then //cnwrd1 par 31672
	//if event = TIEvent_Transit_Status_Update then //cnwrd1 par 31672
		if aUserInfoObject.isKindOf(CM_TrackedItem) then
			theTI := aUserInfoObject.CM_TrackedItem;
		endif;
		if app.isValidObject(theTI) then
			if theTI.isRehandle then
				// ### DLR NON PLANNED TABLE
				if event = TIEvent_Transit_Status_Update then // TFS 45590 do not do if DLR is now planned 
					self.updateTableItem(self.tblDLR, theTI); // TFS 45590
				endif;
				if self.tblAll.rows &gt; 1 then  //par 18788 only populate All if setup
					self.updateTableItem(self.tblAll, theTI); //par 18788
					self.doTblDataRenumberItems(self.tblAll, 0); //par 18788
				endif;
			else
				// ### DLR UNPLANNED TABLE
				self.tblDLR.removeItemObject(theTI);
				self.doTblDataRenumberItems(self.tblDLR, 0);

				if self.tblAll.rows &gt; 1 then  //par 18788 only populate All if setup
					self.tblAll.removeItemObject(theTI); //par 18788
					self.doTblDataRenumberItems(self.tblAll,0); //par 18788
				endif;
			endif;
			//30 Mar 2020	NDL TFS 47004
			if theTI.isTranshipItem then
				if theTI.myExportVoyage &lt;&gt; null then
					isUnplannedTranship := not theTI.hasFutureMoveLoadForVoyage(PLANNING_MODE,theTI.myExportVoyage);
					if theTI.myPrimaryActualLocation &lt;&gt; null and theTI.myPrimaryActualLocation.isVoyageController and theTI.myPrimaryActualLocation.CM_VoyageController.myVoyage = theTI.myExportVoyage  then
						// its already on the export voyage, don't show it any more
						isUnplannedTranship := false;
					endif;
				endif;
			endif;
	//		if theTI.isTranshipItem then
			if theTI.isTranshipItem and isUnplannedTranship then	//30 Mar 2020	NDL TFS 47004
				// ### TRANSHIP TABLE
				self.tblTranShip.removeItemObject(theTI);  //cnwrd1 par 31672 - for some reason update table item only adds rather than updates so we delete to avoid duplicates.
				self.updateTableItem(self.tblTranShip, theTI);
				self.doNotesStorageStartTimer(theTI, null, null);
				
				if self.tblAll.rows &gt; 1 then  //par 18788 only populate All if setup					
					self.updateTableItem(self.tblAll, theTI); //par 18788
					self.doTblDataRenumberItems(self.tblAll, 0); //par 18788
				endif;
				//self.doCentralisedTINoteUpdate(theTI);
			else
				// ### Tranship TABLE
				self.tblTranShip.removeItemObject(theTI);
				self.doTblDataRenumberItems(self.tblTranShip, 0);
			endif;
			if theTI.isTBA then	// TFS 45590
				// ### TBA TABLE
				self.tblTBA.removeItemObject(theTI); 
				self.updateTableItem(self.tblTBA, theTI);
				self.doNotesStorageStartTimer(theTI, null, null);
				
				if self.tblAll.rows &gt; 1 then  //par 18788 only populate All if setup					
					self.updateTableItem(self.tblAll, theTI); //par 18788
					self.doTblDataRenumberItems(self.tblAll, 0); //par 18788
				endif;
			else // TFS 45590
				// ### TBA TABLE
				self.tblTBA.removeItemObject(theTI);
				self.doTblDataRenumberItems(self.tblTBA, 0);
			endif;
			// ### SUMMARY
			//self.updateSummaryTI(theTI,true);
			self.doNotesStorageStartTimer(theTI, null, null);
		else
			// ### TRANSHIP TABLE
			self.tblTranShip.removeItemObject(theTI);
			self.doTblDataRenumberItems(self.tblTranShip, 0);

			self.tblData.removeItemObject(theTI);
			self.doTblDataRenumberItems(self.tblData, 0);
			// ### SUMMARY
			//self.updateSummaryTI(theTI,true);
			self.doNotesStorageStartTimer(theTI, null, null);
		endif;
		
		//par 18788
		self.cleanUpInvalidObjects(self.tblTranShip);
		self.cleanUpInvalidObjects(self.tblAll);
		self.doTblDataRenumberItems(self.tblAll, 0); //par 18788
		return;
	endif;
	
	
	if event = EDI_ColourCode_Update then
		self.updateSummaryFromEDI();
		self.doSummaryQuery(); //epr TFS 5617 23/8/17
		// Force redraw
		self.doNotesStorageStartTimer(null, null, null);
		return;
	elseif event = Event_SlotRequest_Create then
		
		//self.updateSummarySR(theObjectSR);
		self.doNotesStorageStartTimer(null, theObjectReq, null);
		return;
	elseif event = Event_SlotRequest_Update or event = EVENT_UPDATE_VOYAGE_AREA then
		//self.updateSummarySR(theObjectSR);
		self.doNotesStorageStartTimer(null, theObjectReq, null);
		//self.doSummaryQuery();											//31/08/2017 cnwma1 TFS #6554
		//commented out for cnwer1 tfs 7500 22/10/17
		return;
	elseif event = Event_SlotRequest_Delete then
		//self.removeSRFromSummary(theObjectSR);
		self.doNotesStorageStartTimer(null, null, theObjectReq);
		return;
	endif;
	
	if aUserInfoObject.isKindOf(CM_TrackedItem) then
		theTI := aUserInfoObject.CM_TrackedItem;
		self.doNotesStorageStartTimer(theTI, null, null);
	elseif theObject.isKindOf(CM_TrackedItem) then
		theTI := theObject.CM_TrackedItem;
		self.doNotesStorageStartTimer(theTI, null, null);
	endif;
	
	if not self.shtTranship.visible then
		self.shtTranship.visible := not self.myCurrentVoyage.allTranshipTIsExport.isEmpty;
	endif;
	
	if not self.shtTBA.visible then // TFS 45590
	//	self.shtTBA.visible := not self.myCurrentVoyage.allTbaTIsByCargoTypeId.isEmpty;
		self.shtTBA.visible := not self.myCurrentVoyage.allRRPTIsByCargoTypeId.isEmpty;	//16 Mar 2020	NDL	TFS 47004
	endif;
	
	// PAR #26426 WLE updates
	if event = WLE_Update_Event then
		if not CM_VoyageWLE.hasInstance(theObject) then
			return;
		endif;
		self.doNotesStorageStartTimer(theObject.CM_WorkListEntry, null, null);
		return;
	endif;
epilog
	if not self.startedTimer then
		self.updateShtCaptions();
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doNotesStorageStartTimer" id="473f92dc-0766-4465-a989-721c5b399352">
        <updating/>
        <source>doNotesStorageStartTimer(theObject : CM_Object; _requestUpdate, _requestDelete : CM_Request) protected, updating;
//doNotesStorageStartTimer(theTI : CM_TrackedItem; _requestUpdate, _requestDelete : CM_SlotRequest) protected, updating;	// PA #26426 what it was

// Created by cnwdvb1 on 13 March 2007
// Have decided to allow null in here to forced start of timer.
/*

Date		Who		Reason
29 Mar 2010	cnwkpd1	PAR #23479 - Improve performance of Load List
25 Nov 2010	cnwdap1	PAR #26462 - change signature to allow WLEs to be passed in to this method
*/

constants
	MinimumTimerDelay	= 1000;
	
vars
	randomNumber : Integer;
	theTI		 : CM_TrackedItem;		// PAR #26426
	theWLE		 : CM_WorkListEntry;	// PAR #26426

begin
	on Exception do self.handleTimerException(exception); // PAR 33933
	
	
	if not self.startedTimer then
		randomNumber := 0;
		randomNumber := app.random(10) * 100;
		
		// PAR #23479 - Set timer delay to a minimum of 1 second, maximum of 2 seconds
		randomNumber := MinimumTimerDelay + randomNumber;
				
		self.beginTimer(randomNumber, Timer_OneShot, TimerTag);
		self.startedTimer := true;
	endif;
	
	// PAR #26426 what kindof object are we dealing with?
	if CM_TrackedItem.hasInstance(theObject) then
		theTI := theObject.CM_TrackedItem;
	elseif CM_WorkListEntry.hasInstance(theObject) then
		theWLE := theObject.CM_WorkListEntry;
	endif;
	
	if theTI &lt;&gt; null then
		self.allTIsSummaryUpdate.addNoDuplicates(theTI, false);// ### PAR 13388 15FEB2007
	endif;
	
	if _requestUpdate &lt;&gt; null then
		self.allRequestsSummUpdate.addNoDuplicates(_requestUpdate, false);
	endif;
	
	if _requestDelete &lt;&gt; null then
		self.allRequestsSummDelete.addNoDuplicates(_requestDelete, false);
	endif;
	
	// PAR #26426 Wle handling
	if theWLE &lt;&gt; null then
		self.allWLEsSummaryUpdate.addNoDuplicates(theWLE, false);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="theObject" type="CM_Object"/>
        <Parameter name="_requestUpdate" type="CM_Request"/>
        <Parameter name="_requestDelete" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="doPreferenceOKClick" id="7e7ea0ff-8b46-4479-ae56-7178e9acd299">
        <updating/>
        <source>doPreferenceOKClick() updating;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	function		: Integer;
	allSummariesObj	: CMIF_LoadListSummaryObjectSet;
	
begin
	if self.optEnquire.value then
		function := self.Function_Enquiry;
	elseif self.optLoadList.value then
		function := self.Function_ShowInLoadList;
	elseif self.optLocateCargo.value then
		function := self.Function_LocateGridRows;
	elseif self.optAskMe.value then
		self.defaultDblClickFunction := null;
		self.chkRemember.value := false;
	endif;

	if self.chkRemember.value = true then
		self.defaultDblClickFunction := function;
	endif;

	self.frmPreferences.visible := false;

	if function = null 
	or self.myFunctionObject = null then
		return;
	endif;
	
	create allSummariesObj transient;
	allSummariesObj.add(self.myFunctionObject.CMIF_LoadListSummaryObject);
	
	self.handleFunctionForObject(function, allSummariesObj, self.tblSummary.column);
epilog
	delete allSummariesObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="ab2da307-9060-4553-a5de-4247e879fa69">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	printerOrientation : Integer;
begin
	if self.fldMain.topSheet = self.shtNonplanned then
//		self.doPrintOutTable(self.tblData,self.caption, true,true, false, false);	//commented by 	cnwvu1	PAR13317
		self.myAssistant.showReportOptions(self.tblData, caption , self.caption, true);
	elseif self.fldMain.topSheet = self.shtPlanned then
//		self.doPrintOutTable(self.tblPlanned,self.caption, true,true, false, false);
		self.myAssistant.showReportOptions(self.tblPlanned, caption , self.caption, true);
	elseif self.fldMain.topSheet = self.shtDLR then
//		self.doPrintOutTable(self.tblDLR,self.caption, true,true, false, false);
		self.myAssistant.showReportOptions(self.tblDLR, caption , self.caption, true);
	elseif self.fldMain.topSheet = self.shtTranship then
//		self.doPrintOutTable(self.tblTranShip,self.caption, true,true, false, false);
		self.myAssistant.showReportOptions(self.tblTranShip, caption , self.caption, true);
	elseif self.fldMain.topSheet = self.shtTBA then // TFS 45590
		self.myAssistant.showReportOptions(self.tblTBA, caption , self.caption, true);
	elseif self.fldMain.topSheet = self.shtSummary then
//		self.doPrintOutTable(self.tblSummary,self.caption, true,false, false, false);
		//26 Nov 2009	NDL	CCMS 1864	Par 21652
		printerOrientation := app.printer.orientation;
		app.printer.orientation := Print_Landscape;	//too wide for portrait
		self.myAssistant.showReportOptions(self.tblSummary, caption , self.caption, true);
		app.printer.orientation := printerOrientation;	
	elseif self.fldMain.topSheet = self.shtAll then
//		self.doPrintOutTable(self.tblSummary,self.caption, true,false, false, false);
		self.myAssistant.showReportOptions(self.tblAll, caption , self.caption, true);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="b03f0716-3ec7-45c6-b32c-c3b16eda7090">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/12/2010	cnwdap1		PAR #26426 HIde query frame if we have some details in the Summary tab as well
// ---------------------------------------------------------------------------
vars
	aTI 					: CM_TrackedItem;
	numZeros,
	theFilter				: CMQF_ShipLoadListTIs;
	loadState, newQuery 	: Boolean;
	invalidVoyage : Boolean;

	tmpStr : String;
begin
	tmpStr := method.qualifiedName;
	
	self.cnStartTransaction(tmpStr[1:50]);

	on Exception do app.handleDeletedObject(exception, self.myCurrentVoyage, invalidVoyage); //10/10/08 cnwdz2 Par 17732

	self.startedTimer := false;
	self.allTIsSummaryUpdate.clear();
	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	self.modalDialogShow(null, 'Return Data', 'Cancel', null, app.getErrorString(SearchingForData), null);
	endLoad;
	self.newQuery := true;
	self.mousePointer := Window.MousePointer_HourGlass;
	self.tblData.rows := self.tblData.fixedRows;
	self.tblDLR.rows := self.tblDLR.fixedRows;
	self.tblInfo.rows := 0;
	self.tblTranShipInfo.rows := 0;
	self.tblTranShip.rows := self.tblTranShip.fixedRows;
	self.tblTBAInfo.rows := 0; // TFS 45590
	self.tblTBA.rows := self.tblTBA.fixedRows; // TFS 45590
	self.tblTBA.clearAllSelected();
	self.tblData.clearAllSelected();
	self.tblPlanned.clearAllSelected();
	self.tblTranShip.clearAllSelected();
	// CCMS 1578 Adding a new folder to the LoadList
	self.tblAll.clearAllSelected();
	self.tblAll.allTableObjects.clear();
	// Table for colecting all the information form the other tables (tblData, tblPlanded, tblTranship, tblDLR)
	self.tblAll.rows := self.tblAll.fixedRows;
	self.tbAllInfo.rows := 0;
	
	if self.cmbVoyageNote.listObject = null then
		app.msgBox(app.getErrorString(SHP_You_Must_Choose_A_Voyage), app.getErrorString(SHP_Query_Error), MsgBox_OK_Only);
		return;
	endif;
	
	self.setMyCurrentVoyage( self.cmbVoyageNote.listObject.CM_Voyage,false);
	
	self.quitSummaryMode();
	
	self.doFldMainClick();

	// ### SET FILTER INITIALISE
	//self.shtNonplanned.caption := app.getErrorString(SHP_Non_Planed);
	self.doQueryInitFilter();
	theFilter := self.myQuery;

	app.myQAFilter.qryTerminalTIs(theFilter, app.myPassport);
	self.doNotableClear();
	// setup note for this voyage
	self.doNotableAdd(self.myCurrentVoyage);
	self.displayTable(self.tblData);
	//CCMS 1578 adding the tblData information to the tblAll 	
	foreach aTI in theFilter.allQryTrackedItems do
		self.tblAll.allTableObjects.addObject(aTI);
	endforeach;
		

	// ### SET FILTER TRANSHIP
	theFilter.transhipOnly := true;
	theFilter.tbaOnly := false; // TFS 45590
	theFilter.plannedToShip := false;		// 27/9/19 MAP TFS 45590
	app.myQAFilter.qryTerminalTIs(theFilter, app.myPassport);
	self.displayTable(self.tblTranShip);
	//CCMS 1578 adding the tblTranShip information to the tblAll 	
	foreach aTI in theFilter.allQryTrackedItems do
		self.tblAll.allTableObjects.addObject(aTI);
	endforeach;

	// ### SET FILTER TBA
	theFilter.tbaOnly := true; // TFS 45590
	theFilter.transhipOnly := false; // TFS 45590
	theFilter.plannedToShip := false; // TFS 45590
	app.myQAFilter.qryTerminalTIs(theFilter, app.myPassport); // TFS 45590
	self.displayTable(self.tblTBA); // TFS 45590
	foreach aTI in theFilter.allQryTrackedItems do // TFS 45590
		self.tblAll.allTableObjects.addObject(aTI); // TFS 45590
	endforeach;
		
	// ### SET FILTER PLANNED
	self.tblPlanned.rows := self.tblPlanned.fixedRows;
	self.tblPlannedInfo.rows := 0;
	theFilter.reset;	
	self.doQueryInitFilter();
	theFilter := self.myQuery;
	theFilter.plannedToShip := true; //(self.fldMain.topSheet = self.shtPlanned);
	theFilter.isGroundPos := false;
	theFilter.isOverDiffVoy := false;
	theFilter.isOverstowed := false;
	theFilter.topPosition := null;
	theFilter.useTopPosition := false;
// TFS JLGAB1 REMOVED	theFilter.transhipOnly := true;		// 27/9/19 MAP TFS 45590
	app.myQAFilter.qryTerminalTIs(theFilter, app.myPassport);

	self.displayTable(self.tblPlanned);
	//CCMS 1578 adding the tblPlanned information to the tblAll 	
	foreach aTI in theFilter.allQryTrackedItems do
		self.tblAll.allTableObjects.addObject(aTI);
	endforeach;
		
	self.doSummaryQuery();
	
	self.updateShtCaptions();
	inheritMethod();
	self.shtTranship.visible := not self.myCurrentVoyage.allTranshipTIsExport.isEmpty;
	self.shtTBA.visible := not self.myCurrentVoyage.allTbaTIsByCargoTypeId.isEmpty; // TFS 45590
//	self.shtTBA.visible := not self.myCurrentVoyage.allRRPTIsByCargoTypeId.isEmpty;	//16 Mar 2020	NDL	TFS 47004 // remove 30 Apr 2020	NDL	TFS 49219
	
	self.frmQuery.visible := ((self.tblData.rows = self.tblData.fixedRows) 
						and (self.tblDLR.rows = self.tblDLR.fixedRows) 
						and (self.tblTranShip.rows = self.tblTranShip.fixedRows) 
						and (self.tblTBA.rows = self.tblTBA.fixedRows) // TFS 45590
						and (self.tblPlanned.rows = self.tblPlanned.fixedRows)
						and (self.tblAll.rows = self.tblAll.fixedRows)
						and (self.tblSummary.rows = self.tblSummary.fixedRows));		// PAR #26426
	
epilog
	if theFilter &lt;&gt; null then 
		theFilter.plannedToShip := false;
	endif;
	self.mousePointer := Window.MousePointer_Default;
//	app.cmsEndLoad(loadState);
	endLoad;

	if tmpStr &lt;&gt; null then
		self.cnEndTransaction();
	endif;

	self.progressFinish();
//	app.myPassport.myActivityCapture.stopCaptureDebugMisc();
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="efadf2a5-7110-4774-b2e7-f94ec2efa1af">
        <updating/>
        <source>doQueryAddItem(_table : CM_DataTable input; _theRow : Integer; _theTI : CM_TrackedItem;_numZeros : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theDataLine : String;
	idx : Integer;
begin
	theDataLine := _theTI.getAttributeStringForDefArray(_table.allTblDataEntRows);

	if _theRow = 0 then
		idx := _table.addItem(theDataLine.trimBlanks);
	else
		idx := _theRow;
//	WAS	_table.addItemAt(theDataLine.trimBlanks, idx);
// NOW

		if idx &gt; _table.rows then
			idx := _table.addItem(theDataLine.trimBlanks);
		else
			_table.addItemAt(theDataLine.trimBlanks, idx);
		endif;

	endif;
	_table.accessRow(idx).itemObject := _theTI;
	
	//25 Jan 2012	NDL	Par 25297
	self.doFilterVisibilityForNote( _table, idx );
	
	// setup note for this item
	self.doNotableAdd(_theTI.myTerminalArea);
	self.doNotableAdd(_theTI);	

	// general renumber is called later
	//_table.setCellValueByName(ETRow_RowNumber, idx, _theRow.String.padLeadingZeros(_numZeros));
	self.doQueryColourUp(_table, _theTI, idx);
	
	return idx;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_numZeros" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doQueryColourUp" id="37760c50-98d4-4a79-b537-ee1ffecbcc2a">
        <source>doQueryColourUp(_table : CM_DataTable input;_theTI : CM_TrackedItem;_theRow : Integer);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/08/2010	cnwdap1		PAR #25371 Colour up the Tranship voyage and discharge port columns
// 14/09/2010	cnwdap1		PAR #25742 Avoid 1090 when we don't have a discharge port on the tranship details
// ---------------------------------------------------------------------------

vars
	thePort : CM_Port;
	theColour, theColumn : Integer;
	theCommodity : CM_Commodity;
	theCommodityGrp : CM_CommodityGroup;
	theISOType : CM_ISOType;
	theCell : JadeTableCell;
	drwAtt : CM_DrawingAttribute;	
	cs : CM_ContentsStatus;
	ts : CM_TransitStatus;
	ct : CM_CargoType;
	ig : CM_ISOTypeGroup;
	carrier: CM_Carrier;
begin
	

		// COLOUR UP THE ISO Type
		theColumn := _table.getColumnByRowName(ETRow_IsoTypeDesc);
		if theColumn &gt; 0 then
			if _theTI.isKindOf(CM_Container) then 
				theISOType := _theTI.CM_Container.getISOTypeObject();
				if theISOType &lt;&gt; null then
					theColour := theISOType.colour;
				endif;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
			theColumn := _table.getColumnByRowName(ETRow_IsoType);
			
			if theColumn &gt; 0 then
				_table.accessCell(_theRow,theColumn).backColor := theColour;
				_table.accessedCell.foreColor := theColour.getInverseColour();
			endif;			
		endif;
		// COLOUR UP THE Ready To Ship
		theColumn := _table.getColumnByRowName(ETRow_ReadyToShip);
		if theColumn &gt; 0 then
			if _theTI.readyToShip then
				theColour := Green;
			else
				theColour := Red;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Is Special Stow
		theColumn := _table.getColumnByRowName(ETRow_IsSpecialStow);
		if theColumn &gt; 0 then
			if _theTI.isSpecialStow then
				theColour := Red;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		theColumn := _table.getColumnByRowName(ETRow_SpecialStowCode);
		if theColumn &gt; 0 then
			if _theTI.isSpecialStow then
				theColour := Red;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE ISO Group
		theColumn := _table.getColumnByRowName(ETRow_IsoTypeGroupDesc);
		if theColumn &gt; 0 then
			ig := app.myRoot.allISOTypeGroups[_theTI.isoTypeGroup];
			if ig &lt;&gt; null then
				theColour := ig.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Cargo Type
		theColumn := _table.getColumnByRowName(ETRow_CargoType);
		if theColumn &gt; 0 then
			ct := app.myRoot.allCargoTypesById[_theTI.cargoType];
			if ct &lt;&gt; null then
				theColour := ct.colour;
				if theColour = 0 then // not set?
					if ct.myDrawingAttribute &lt;&gt; null then
						theColour := ct.myDrawingAttribute.colour;					
					endif;
				endif;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Contents Status
		theColumn := _table.getColumnByRowName(ETRow_ContentsStatus);
		if theColumn &gt; 0 then
			cs := app.myRoot.allContentsStatuses[_theTI.getContentsStatus()];
			if cs &lt;&gt; null then
				theColour := cs.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Transit Status
		theColumn := _table.getColumnByRowName(ETRow_TransitStatus);
		if theColumn &gt; 0 then
			ts := app.myRoot.allTransitStatuses[_theTI.getTransitStatus()];
			if ts &lt;&gt; null then
				theColour := ts.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Operator
		theColumn := _table.getColumnByRowName(ETRow_OperatorCode);
		if theColumn &gt; 0 then
			if _theTI.myOperator &lt;&gt; null then
				theColour := _theTI.myOperator.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Discharge Port
		theColumn := _table.getColumnByRowName(ETRow_DischargePort);
		if theColumn &gt; 0 then
			//thePort := app.myRoot.allPorts[_theTI.dischargePort];
			thePort := app.myRoot.allPorts[_theTI.dischargePort];
			if thePort &lt;&gt; null then
				theColour := thePort.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Commodity
		theColumn := _table.getColumnByRowName(ETRow_Commodity);
		if theColumn &gt; 0 then
			theCommodity := app.myRoot.allCommodities[_theTI.commodity];
			if theCommodity &lt;&gt; null then
				theColour := theCommodity.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Commodity Group
		theColumn := _table.getColumnByRowName(ETRow_CommodityGroup);
		if theColumn &gt; 0 then
			theCommodityGrp := app.myRoot.allCommodityGroups[_theTI.commodityGroup];
			if theCommodityGrp &lt;&gt; null then
				theColour := theCommodityGrp.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Voyage
		theColumn := _table.getColumnByRowName(ETRow_VoyageCode);
		if theColumn &gt; 0 then
			if _theTI.myVoyage &lt;&gt; null then
				theColour := _theTI.myVoyage.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;

		// COLOUR UP THE Custom Export Delivery Number
		theColumn := _table.getColumnByRowName(ETRow_CustomExportEntryNumber);
		if theColumn &gt; 0 then
			theCell := _table.accessCell(_theRow, theColumn);
			if theCell.text = null then
				theColour := Red;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;

		// COLOUR UP THE Custom Export Hold
		theColumn := _table.getColumnByRowName(ETRow_CustomExportStop);
		if theColumn &gt; 0 then
			theCell := _table.accessCell(_theRow, theColumn);
			if theCell.text &lt;&gt; null then
				drwAtt := app.myRoot.allDrawingAttributes[PicTICustomHold];
				if drwAtt &lt;&gt; null then
					theCell.foreColor := drwAtt.colour;
					theCell.text := drwAtt.fontCharacter.Character;	
					theCell.fontName := drwAtt.fontName;
				endif;								
			endif;			
		endif;	
		// COLOUR UP THE 'Plnning State'
		theColumn := _table.getColumnByRowName(ETRow_PlanningStateLoadList);
		if theColumn &gt; 0 then
	
				if _theTI.state = TI_STATE_ONSHIP then
					theColour := xmlColourOnShip;
				elseif _theTI.myPrimaryPlannedLocation &lt;&gt; null then 
					theColour := xmlColourPlanned;
				elseif _theTI.myPrimaryPlannedLocation = null then
					theColour := xmlColourNonPlanned;
				else
					theColour := White;
				endif;	
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		
		// PAR #25371 start 
		// COLOUR UP THE Tranship Discharge Port
		theColumn := _table.getColumnByRowName(ETRow_TranshipDischargePort);
		if theColumn &gt; 0 then
			//if _theTI.myTranshipDetail &lt;&gt; null then													// PAR #25742
			if _theTI.myTranshipDetail &lt;&gt; null and _theTI.myTranshipDetail.myDischargePort &lt;&gt; null then	// PAR #25742
				thePort := app.myRoot.allPorts[_theTI.myTranshipDetail.myDischargePort.code];
			endif;
			if thePort &lt;&gt; null then
				theColour := thePort.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// COLOUR UP THE Tranship Voyage
		theColumn := _table.getColumnByRowName(ETRow_TranshipExportVoyage);
		if theColumn &gt; 0 then
			if _theTI.myExportVoyage &lt;&gt; null then
				theColour := _theTI.myExportVoyage.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		// PAR #25371 end

		// COLOUR UP THE carrier	TFS4209 MAP 8/6/17
		theColumn := _table.getColumnByRowName(ETRow_Carrier);
		if theColumn &gt; 0 then
			carrier := app.myRoot.allCarriers[_theTI.carrier];
			if carrier &lt;&gt; null then
				theColour := carrier.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;
		theColumn := _table.getColumnByRowName(ETRow_ReleaseCarrier);
		if theColumn &gt; 0 then
			carrier := app.myRoot.allCarriers[_theTI.releaseCarrier];
			if carrier &lt;&gt; null then
				theColour := carrier.colour;
			else
				theColour := White;
			endif;
			_table.accessCell(_theRow,theColumn).backColor := theColour;
			_table.accessedCell.foreColor := theColour.getInverseColour();
		endif;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doQueryInitFilter" id="f5d3f7f2-3a7a-4dfd-93eb-301d8787f875">
        <updating/>
        <source>doQueryInitFilter() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theFilter				: CMQF_ShipLoadListTIs;
begin

	// ### SET FILTER INITIALISE
	if self.myQuery = null then
		create theFilter transient;
		self.myQuery := theFilter;
	endif;
	theFilter := self.myQuery;
	theFilter.reset;	
	theFilter.allTerminals.add(self.myTerminal);
	if self.cmbVoyageNote.listIndex &gt; 0 then
		theFilter.allVoyages.add(self.cmbVoyageNote.itemObject[self.cmbVoyageNote.listIndex].CM_Voyage);
	endif;
	self.lstCargoTypes.allSelectedObjects.copy(theFilter.allCargoTypes);
	self.lstOperators.allSelectedObjects.copy(theFilter.allOperators);
	self.lstPorts.allSelectedObjects.copy(theFilter.allPortsDischarge);

	theFilter.isGroundPos := self.chkGroundPos.value;
	theFilter.isOverDiffVoy := self.chkOverDiffVoy.value;
	theFilter.isOverstowed := self.chkIsOverstowed.value;
	theFilter.topPosition := self.txtHeight.text.Integer;
	theFilter.useTopPosition := self.chkTopPos.value;
	// ### SET FILTER UNPLANNED
	theFilter.plannedToShip := false;
	theFilter.transhipOnly := false;	// CCMS 1011
	theFilter.tbaOnly := false; // TFS 45590

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuerySelectorDLR" id="c4320061-1ca6-4aa6-a02c-6567f81af546">
        <updating/>
        <source>doQuerySelectorDLR() updating;
// ---------------------------------------------------------------------------
// Created:		22 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	enqController		: CM_EnquiryController;
	queryDef			: CM_QueryDefinition;
	queryParams			: CM_QueryCriteriaLineHolder;
//	criteria 			: CM_SelectorCriteriaLine;
//	queryProperty,clonedProp			: CM_QueryProperty;
//	queryOperator,clonedOp			: CM_QueryOperator;
//	queryValue			: Any;
	anObject			: Any;
	trackedItemObj		: CM_TrackedItem;
//	idx					: Integer;
	numZeros			: Integer;
	partsInJob			: Integer;
	theDischargePort	: CM_Port;
	allSites			: IntegerArray;
	tmpWLE				: CM_WorkListEntry;
begin

	if self.tblDLR.rows &gt; self.tblDLR.fixedRows then
		return;
	endif;
	
	if self.cmbVoyageNote.listObject = null then
		app.msgBox(app.getErrorString(SHP_You_Must_Choose_A_Voyage), app.getErrorString(SHP_Query_Error), MsgBox_OK_Only);
		return;
	endif;
	
	self.tblDLRInfo.rows := 0;
	self.tblDLR.clearAllSelected();
	queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 0];//mode = 0 for TrackedItem mode
	
// cnwdad1 05/08/2008 - PAR #17609.
	if queryDef = null then
		return;
	endif;
	
	app.myQAFilter.createEnqControllerForMode(queryDef.mode, queryDef.type, enqController);
	
	create enqController.allObjects as CM_ObjectSet transient;
	create queryParams transient;
	queryParams.collectionBelongsTo := CM_Terminal.firstInstance;//don't need this?
	//create criteria
	self.doSetSelectorCriteria(queryParams,queryDef,'myTerminal', CM_QueryOperator.Operator_Equal,self.myTerminal);
	self.doSetSelectorCriteria(queryParams,queryDef,'site', CM_QueryOperator.Operator_Equal,TI_SITE_ONSHIP_str);
	create allSites transient;
	allSites.add(TI_SITE_ONSHIP); //TI_SITE_ONSHIP &amp; "," &amp; TI_SITE_ONSITE
	allSites.add(TI_SITE_ONSITE);
	self.doSetSelectorCriteria(queryParams,queryDef,'transitStatus', CM_QueryOperator.Operator_Equal,app.myRoot.allTransitStatuses[TI_TransitStatusDLR]);
	self.doSetSelectorCriteria(queryParams,queryDef,'voyageCode', CM_QueryOperator.Operator_Equal,self.myCurrentVoyage);
	self.doSetSelectorCriteria(queryParams,queryDef,'planningState', CM_QueryOperator.Operator_NotEqual,"Planned to Load");
	
	//execute query
	enqController.myCriteriaLineHolder := queryParams;
	enqController.doQuery(queryDef);
	partsInJob := enqController.allObjects.size;
	numZeros	:=	partsInJob.String.length();
	self.tblDLR.rows := self.tblDLR.fixedRows;
	
	foreach anObject in enqController.allObjects discreteLock do
		trackedItemObj	:=	anObject.CM_TrackedItem;
		
		// ### when the TIs DLRs are loaded (or not off ship yet but replanned) do not display, but check if they are being reworked.
		if trackedItemObj.planningState = LOADED_STATE  or trackedItemObj.planningState = PLANNED_DISCHARGE_STATE then
			tmpWLE	:=	trackedItemObj.getVoyageWLEUnactioned(false);
			
			if tmpWLE = null then
				continue;
			else
				tmpWLE	:=	trackedItemObj.getVoyageWLEUnactioned(true);
				
				if tmpWLE &lt;&gt; null then
					continue;
				endif;
			endif;
		endif;
		
		//### include basic query params
		
		// ### DISCHARGE PORT
		if not self.lstPorts.allSelectedObjects.isEmpty then
			//theDischargePort := app.myRoot.allPorts[trackedItemObj.dischargePort.trimBlanks];
			theDischargePort := app.myRoot.allPorts[trackedItemObj.dischargePort.trimBlanks];
			if theDischargePort &lt;&gt; null then
				if not self.lstPorts.allSelectedObjects.includes(theDischargePort) then
					continue;
				endif;
			endif;
		endif;
		// ### CARGO TYPE
		if not self.lstCargoTypes.allSelectedObjects.isEmpty then
			if trackedItemObj.myCargoType &lt;&gt; null then
				if not self.lstCargoTypes.allSelectedObjects.includes(trackedItemObj.myCargoType) then
					continue;
				endif;
			endif;
		endif;
		// ### OPERATOR
		if not self.lstOperators.allSelectedObjects.isEmpty then
			if trackedItemObj.myOperator &lt;&gt; null then
				if not self.lstOperators.allSelectedObjects.includes(trackedItemObj.myOperator) then
					continue;
				endif;
			endif;
		endif;
			
		self.updateTableItem(self.tblDLR, trackedItemObj); // 18/6/2007 Mohammad par#14231

		self.tblAll.allTableObjects.addObject(trackedItemObj);
	endforeach;
epilog
//	self.frmQuery.visible := ((self.tblDLR.rows = self.tblDLR.fixedRows));  annoying after a while
//	if self.mode &lt;&gt; self.Mode_SummarySelection then
	if self.allColumnFilters = null or self.allColumnFilters.isEmpty then	// 25 Jan 2012	NDL	Par 25297
		self.shtDLR.caption := app.getErrorString(SHP_DLR_Non_Planned) &amp; " (" &amp; (self.tblDLR.rows - self.tblDLR.fixedRows).String &amp; ")";
	endif;
	
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	
	delete enqController;
	delete queryParams;
	delete allSites;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="5858ac7b-adf4-4067-8955-2b9b323116c1">
        <updating/>
        <source>doRefresh() updating, protected;
//--------------------------------------------------
// Created:	05 November 2003 By: cnwgd1
// 24/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
//--------------------------------------------------
vars
	
begin
	inheritMethod();
	
	//25 Jan 2012	NDL	Par 25297
	self.clearAllFilters();
	
//	self.doQuery();// ### PAR 13388 15FEB2007 

	self.tblDLR.rows := self.tblDLR.fixedRows;
	
	if self.fldMain.topSheet = self.shtDLR then
		self.doQuerySelectorDLR();
	endif;
	
	self.tblAll.rows := self.tblAll.fixedRows;
	
	if self.fldMain.topSheet = self.shtAll then
		self.displayAllTable();
	endif;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="e7488531-352f-4f46-8195-11716c177b71">
        <source>doResetSearch();
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	self.lstOperators.setSelected(null);
	self.lstCargoTypes.setSelected(null);
	self.lstPorts.setSelected(null);
	self.chkGroundPos.value := false;
	self.chkIsOverstowed.value := false;
	self.chkOverDiffVoy.value := false;
	self.txtHeight.text := null;
	self.chkTopPos.value := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="c741ed7a-ef35-447c-8141-f8e3d84abd64">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		26 July 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpH : Integer;
begin
	tmpH := self.clientHeight - self.frmStatLine.clientHeight - self.frmToolbar.clientHeight-10;
	self.fldMain.width := self.clientWidth;
	self.fldMain.height := tmpH;
	self.topMargin := 0;
	
	inheritMethod();

	self.fldMain.top := self.frmToolbar.clientHeight+2;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="951a49ea-0f72-48b5-840b-d75a56e30def">
        <source>doSelectAll();
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     This method ticks all the checkbox's of the CargoType, Operators
//				or Ports tables on the Searcher Dialog
//			 
// ----------   ----------  --------------------------------------------------
vars
	sht					: CMUI_Sheet;
begin
	sht := self.fldQuery.topSheet.CMUI_Sheet;
	
	if sht = self.shtQuery2 then
		self.lstCargoTypes.setAllToTrue;
	elseif sht = self.shtQuery3 then
		self.lstOperators.setAllToTrue;
	elseif sht = self.shtQuery4 then
		self.lstPorts.setAllToTrue;
	endif;
	
end;

</source>
    </JadeMethod>
    <JadeMethod name="doSetFunctionPref" id="ad251e4d-a938-4a15-95cf-212fc3418924">
        <updating/>
        <source>doSetFunctionPref(_summaryObject: CMIF_LoadListSummaryObject) updating;
//----------------------------------------------------------------
//	Created:	16 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _summaryObject = null then
		self.myFunctionObject := null;
		return;
	endif;	
	
	self.chkRemember.enabled := true;
	self.chkRemember.value := false;
	self.optAskMe.visible := false;
	self.myFunctionObject := _summaryObject;
	
	self.lblPreference.caption := "What do you want to do?";
	self.frmPreferences.visible := true;
	self.frmPreferences.centreWindow();
	self.frmPreferences.zOrder(1);
end;</source>
        <Parameter name="_summaryObject" type="CMIF_LoadListSummaryObject"/>
    </JadeMethod>
    <JadeMethod name="doSetSelectorCriteria" id="dd612628-fb43-42d8-ba4b-78e7b264b287">
        <source>doSetSelectorCriteria(_queryParams: CM_QueryCriteriaLineHolder input;_queryDef	: CM_QueryDefinition;_property : String; _operator : String; _value : Any);


// NOT USED, MOVED TO ASSISTANT DELETE in 761



// ---------------------------------------------------------------------------
// Created:		22 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	criteria: CM_SelectorCriteriaLine;
	queryProperty,clonedProp			: CM_QueryProperty;
	queryOperator,clonedOp			: CM_QueryOperator;
	queryValue				: Any;
begin
	create criteria transient;
	queryProperty := _queryDef.allQueryProperties[_property];
	queryOperator := queryProperty.allAllowedOperators[_operator];
	queryValue := queryProperty.translateToSearchValue(_value); 
	clonedProp := queryProperty.cloneSelf(true);
	clonedOp := queryOperator.cloneSelf(true);

	clonedOp.setSearchValue(queryValue);	
	criteria.set(clonedProp, clonedOp, false);
	criteria.setMyCriteriaLineHolder(_queryParams);

end;</source>
        <Parameter name="_queryParams" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <Parameter name="_queryDef" type="CM_QueryDefinition"/>
        <Parameter name="_property" type="String"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doShowPopupInfo" id="b2eca2e3-0c4d-4678-a643-e1f31be23926">
        <updating/>
        <source>doShowPopupInfo(table: CM_DataTable input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		21 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theObject : Object;
	dataContainer : CM_DataContainer;
	theAttribs :	CMUI_GridAttributesArray;
	theAttrib : CMUI_GridAttributes;
	thePIC : CMIF_PopupInfoController;
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	if self.mnuContextHide.caption = self.MNU_MACRO_HIDE then // this means that the macro info is hidden
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if useTableInfo then

		theObject := table.accessRow(table.row).itemObject;
		if theObject = null then
			self.tblInfo.rows := 0;
			return;
		endif;
		if theObject.isKindOf(CM_WorkListEntry) then
			theObject := theObject.CM_WorkListEntry.myTrackedItem;
		endif;
		if not app.isDragging 
		and table.longLeftClick then
			create thePIC transient;
			thePIC.setForCreate(theObject.CM_Object, 0, self.frmPopupInfo,self.tblPopupInfo,self.frmToolBarPopup,
								self.frmPopupInfoPic1,self.picExtraInfoTI1,self.btnPopupEnq);
			self.showPopupInfoFrame(thePIC);
		endif;
	endif;
epilog
	app.isDragging := false;
	delete dataContainer;
	delete theAttrib;
	delete thePIC;
	delete theAttribs;
	self.mousePointer := Window.MousePointer_Default;


end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doSummaryContextMenu" id="9074f2f0-f84e-4755-957b-dcc29a27aa2a">
        <updating/>
        <source>doSummaryContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	
begin
		
	
	return self.showContextMenu(self.mnuSummary,cntrl,conwin,mouse,x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSummaryQuery" id="376a7cb0-c97f-41fa-86bc-a11148e95b89">
        <source>doSummaryQuery();
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	filter				: CMQF_VoyageLoadListSummary;
	allSummaryObjects	: CMIF_LoadListSumByImexDischISO;
	llSummaryObject		: CMIF_LoadListSummaryObject;
	tmpClock			: Integer;
begin
	
//	app.myPassport.myActivityCapture.startCaptureDebugMisc('Summary rebuild');
	
	if self.mySummaryReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'report group not found');
		return;
	endif;

	filter	:=	self.mySummaryFilter;
	self.resetSummaryCriteria();
	
	create allSummaryObjects transient;
	
	filter.filterObjects(allSummaryObjects, app.myPassport);

	self.mySummaryReport.reset();
	self.mySummaryReport.addGroupProperty(CMIF_LoadListSummaryObject::imexStatus.name, CMIF_LoadListSummaryObject::imexStatus.type);
	self.mySummaryReport.addGroupProperty(CMIF_LoadListSummaryObject::dischargePort.name, CMIF_LoadListSummaryObject::dischargePort.type);
	self.mySummaryReport.addGroupProperty(CMIF_LoadListSummaryObject::isoGroupingKey.name, CMIF_LoadListSummaryObject::isoGroupingKey.type);
	
	foreach llSummaryObject in allSummaryObjects do
		self.mySummaryReport.groupObject(llSummaryObject);
	endforeach;

	self.initSummaryTable();
	
	self.mySummaryReport.populateTable(self.tblSummary);
	
epilog
	delete allSummaryObjects;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="6b752b9c-950a-4315-994f-956899007973">
        <updating/>
        <source>doSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	05 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	ti : CM_TrackedItem;
	theRow : Integer;
	dataTbl		: CM_DataTable;
	ts : TimeStamp;
begin

	app.mousePointer	:=	Busy;
	inheritMethod(eventType, theObject, eventTag);

	if not theObject.isKindOf(CM_TrackedItem) then
		return;
	endif;
	if self.ignorePlanUnplanNotes then
		return;
	endif;
	
	ti := theObject.CM_TrackedItem; // TFS 45590
	if eventType = Object_Delete_Event then // TFS 45590
		self.handleDeletedTI(ti); // TFS 45590
		return;
	endif;

	// ### PAR 13388 15FEB2007. re begin the timer for each TI update. The TimerEvent will update the screen
	//self.endTimer(TI_Note_Tag);
	//self.beginTimer(500, Timer_OneShot, TI_Note_Tag);
	
	if ti  &lt;&gt; null then
		//self.doCentralisedTINoteUpdate(ti);
		self.doNotesStorageStartTimer(ti, null, null);
	endif;

epilog
	endLoad;
	app.mousePointer	:=	Idle;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDLRContextMenu" id="537498ea-8b5f-487f-a8ad-73ab2649f1d3">
        <updating/>
        <source>doTblDLRContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theRow : Integer;
	theTI : CM_TrackedItem;
	theLocationsController : CM_LocationsController;
begin

	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;
		
	self.mnuLoadListPlanLoad.visible := false;

	theRow := cntrl.CM_BaseTable.getRowFromY(y);
	if theRow &gt; cntrl.fixedRows then
		theTI := cntrl.accessRow(theRow).itemObject.CM_TrackedItem;

		self.mnuInspectObject.userObject := theTI;
		
		// #####################
		// PLANNING TO SHIP?
		// #####################
		if app.myMoveController &lt;&gt; null then
			if theTI &lt;&gt; null then
				if app.myMoveController.mySlotRequest &lt;&gt; null and app.myMoveController.mySlotRequest.myJob &lt;&gt; null then
					// YES!
					if app.myMoveController.mySlotRequest.isLoad 
					and app.myMoveController.mySlotRequest.isRehandle then
						if theTI &lt;&gt; null then
							app.myMoveController.setMyTrackedItem(theTI);
						endif;
						if app.myMoveController &lt;&gt; null then
							app.myMoveController.isDLRLoadWithOutDischarge := true;
						endif;
						self.mnuLoadListPlanLoad.userObject := cntrl;
						if cntrl.CM_DataTable.allSelectedObjects.size &gt; 1 then
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_Selected_Rehandle);
						else
							if cntrl.CM_DataTable.allSelectedObjects.isEmpty then
								cntrl.CM_DataTable.selectRow(theRow,false);
							endif;
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_DLR_Load_To) &amp; app.myMoveController.mySlotRequest.mySlotController.getFullId;
						endif;
				
						self.mnuLoadListPlanLoad.visible := true;
					endif;
				elseif app.myMoveController.myVoyageRequest &lt;&gt; null and app.myMoveController.myVoyageRequest.myJob &lt;&gt; null then
					// YES!
					if app.myMoveController.myVoyageRequest.isLoad 
					and app.myMoveController.myVoyageRequest.isRehandle then
						if theTI &lt;&gt; null then
							app.myMoveController.setMyTrackedItem(theTI);
						endif;
						if app.myMoveController &lt;&gt; null then
							app.myMoveController.isDLRLoadWithOutDischarge := true;
						endif;
						self.mnuLoadListPlanLoad.userObject := cntrl;
						if cntrl.CM_DataTable.allSelectedObjects.size &gt; 1 then
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_Selected_Rehandle);
						else
							if cntrl.CM_DataTable.allSelectedObjects.isEmpty then
								cntrl.CM_DataTable.selectRow(theRow,false);
							endif;
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_DLR_Load_To) &amp; app.myMoveController.myVoyageRequest.CM_RORORequest.myROROController.getFullId;
						endif;
				
						self.mnuLoadListPlanLoad.visible := true;
					endif;
				endif;
			endif;
		endif;
	endif;

	if self.fldMain.topSheet = self.shtNonplanned then
		if not self.splMain.getControlByName(self.tblInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtPlanned then
		if not self.splPlanned.getControlByName(self.tblPlannedInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtAll then
		if not self.splAll.getControlByName(self.tbAllInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtDLR then									// 30/9/19 MAP TFS 45590
		if not self.splDLR.getControlByName(self.tblDLRInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtTranship then							// 30/9/19 MAP TFS 45590
		if not self.splTranShip.getControlByName(self.tblTranShipInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtTBA then							// 30/9/19 MAP TFS 45590
		if not self.splTBA.getControlByName(self.tblTBAInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	else
		if not self.splAll.getControlByName(self.tbAllInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	endif;

		
	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x,y);


end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDLRMouseDown" id="9b20a004-f527-4ae4-b0d8-42ed8b27aad1">
        <updating/>
        <source>doTblDLRMouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2016	cnwdap1		Initial creation PAR #37289
//
vars

begin
	self.origXPos := x;
	self.origYPos := y;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDLRMouseMove" id="5064a1e9-6f52-4c3d-973b-a720eb6c4857">
        <updating/>
        <source>doTblDLRMouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose: for par 31672 			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2013	cnwrd1	Initial creation

*/

vars

	gridPoint	: CMUI_GridPoint;
	theTI		: CM_TrackedItem;
	root : CM_Root;
	lPicture : Picture;
	moveController : CMIF_MoveController;
begin

	self.tblDLR.mouseMoveForDragSelect(table, button, shift, x, y);	

	if self.tblDLR.row &lt;= self.tblDLR.fixedRows 
	or y &lt;= table.accessRow(self.tblDLR.fixedRows).height then 
		self.origXPos := x;
		self.origYPos := y;
		return;
	endif;
	
	if button = Window.MouseButton_Left 
	and	app.dragDetected(x, y, self.origXPos, self.origYPos) 
	and self.origYPos &gt; 20  // ###  may be doing a column resize!
	and not shift.isControlKeyPressed()
	and not shift.isShiftKeyPressed()
	and not shift.isAltKeyPressed() then
		theTI := self.tblDLR.accessRow(self.tblDLR.row).itemObject.CM_TrackedItem;
		if theTI &lt;&gt; null and theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRLoad) = null then   // 36291
			app.myDraggedTrackedItem := theTI;
			create moveController transient;
			
			moveController.setMyTrackedItem(theTI);
			delete app.myMoveController;
			app.myMoveController := moveController;
			app.isDragging := true;
			moveController.setMyOriginatingLocation(theTI.getPrimaryLocation(REAL_MODE));
			self.moveModeForm := PLANNING_MODE;
			moveController.setMoveMode(PLANNING_MODE);	
			app.myMoveController.isDLRLoadWithOutDischarge := true;  // 36291
			table.dragMode := DragMode_Drag;
			root := app.myRoot;

			create lPicture transient;
			self.setPictureDragCursor(lPicture);
			if lPicture.picture &lt;&gt; null then
				table.dragCursor := lPicture.picture;
			endif;

		endif;
	else
		//do we really need to do this on a mouse move?   Mouse up is enough
		//self.frmStatLine.caption := self.statusStub &amp; " " &amp; $SHP_Selected &amp; self.tblData.allSelectedObjects.size.asStringJMT;
	endif;
epilog
	if lPicture &lt;&gt; null then
		delete lPicture;
	endif;
	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDLRRowColumnChg" id="f3d030fd-71f3-415a-844d-f90d9c43852a">
        <updating/>
        <source>doTblDLRRowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		02 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	theVjob : CM_VoyageJob;
	theObject : Object;
	dataContainer : CM_DataContainer;
	theAttribs :	CMUI_GridAttributesArray;
	theAttrib : CMUI_GridAttributes;
begin
	self.doGetInfoTableData(self.tblDLR,self.tblDLRInfo);

return;






	self.mousePointer := Window.MousePointer_HourGlass;

	self.myCurrentTrackedItem := null;
	self.tblInfo.rows := 0;

	if table.row &lt;= table.fixedRows then
		return;
	endif;

	theObject := table.accessRow(table.row).itemObject;
	if (not global.isValidObject(theObject)) then
		return;
	endif;
	
	if CM_TrackedItem.hasInstance(theObject) then
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;	
	elseif CM_WorkListEntry.hasInstance(theObject) then
		theObject := theObject.CM_WorkListEntry.myTrackedItem;
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;
	endif;
	
	if useTableInfo then

		if self.mnuContextHide.caption = self.MNU_MACRO_SHOW // this means that the macro info is hidden
		and not app.isDragging then
		else

			create dataContainer transient;
			dataContainer.headerColour := self.colorHeadingColumn;
			dataContainer.valueColour := self.colorValueColumn;
			
			if theObject &lt;&gt; null and theObject.isKindOf(CM_Object) then
				theObject.CM_Object.getExtraInfo(dataContainer);
				self.tblInfo.userObject := theObject;
			endif;
			self.showExtraInformation(dataContainer, self.tblDLRInfo, true, false, 4, 1, 1, 1, 1);
		endif;
	endif;
epilog
	delete dataContainer;
	delete theAttrib;
	delete theAttribs;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataClick" id="ab81b05d-1123-435e-bce7-e403bf0d466a">
        <updating/>
        <source>doTblDataClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// 11.7.2018	cnwma1	Bug 39371: SNO - RTS flag issue on TS containers
vars
	theColumn : Integer;
	theTI : CM_TrackedItem;
begin
	if table.row &lt;= table.CM_DataTable.fixedRows then
		theColumn := table.CM_DataTable.getColumnByRowName(ETRow_RowNumber);
		if theColumn = table.column then // no sort by this column
			return;
		endif;
		
		//self.sortByColumn := table.column;
		return;
	endif;
	theColumn := table.CM_DataTable.getColumnByRowName(ETRow_ReadyToShip);
	//changed by cnwyl1 27/7/2006 For PAR 12158
	if theColumn = table.column and table.CM_DataTable.allSelectedObjects.size &lt;&gt; 0 then
		self.doBtnRTSClick(table);
	endif;

	self.btnRTS.enabled := true;		// 30/9/19 MAP TFS45990
	/*
	theTI := table.CM_DataTable.accessRow(table.row).itemObject.CM_TrackedItem;
	//PAR13157 
	self.btnRTS.enabled := false ;  		 //11.7.2018 cnwma1	39371
	if theTI &lt;&gt; null and theTI.myPrimaryActualLocation &lt;&gt; null then
		self.btnRTS.enabled := theTI.myPrimaryActualLocation.isKindOf(CM_GridController);  
	endif;
	*/
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnRTS.enabled:= false;
		self.mnuLLReadyToShip.enabled:= false;
		self.btnEdit.enabled:= false;
		self.mnuContextTIEdit.enabled:= false;
		
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="4ff8e24f-a244-4aae-9790-5d70c979505e">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theRow : Integer;
	theTI : CM_TrackedItem;
begin
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;
	self.doContextMenuBuild();
	theRow := cntrl.CM_BaseTable.getRowFromY(y);
	if theRow &gt; cntrl.fixedRows then
		theTI := cntrl.accessRow(theRow).itemObject.CM_TrackedItem;
		self.mnuInspectObject.userObject := theTI;
		self.myAssistant.buildMnuGridLoadPlan(self.mnuLoadListPlanLoad, theTI,null,cntrl.CM_DataTable.allSelectedObjects);
		if self.mnuLoadListPlanLoad.visible then
			self.mnuLoadListPlanLoad.userObject := cntrl;
			if cntrl.CM_DataTable.allSelectedObjects.isEmpty then
				cntrl.CM_DataTable.selectRow(theRow,false);
			endif;
		endif;
	endif;

	if self.fldMain.topSheet = self.shtNonplanned then
		if not self.splMain.getControlByName(self.tblInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtPlanned then
		self.mnuLLUnplan.visible := true;
		if not self.splPlanned.getControlByName(self.tblPlannedInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtAll then
		if not self.splAll.getControlByName(self.tbAllInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtDLR then									// 30/9/19 MAP TFS 45590
		if not self.splDLR.getControlByName(self.tblDLRInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtTranship then							// 30/9/19 MAP TFS 45590
		if not self.splTranShip.getControlByName(self.tblTranShipInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	elseif self.fldMain.topSheet = self.shtTBA then							// 30/9/19 MAP TFS 45590
		if not self.splTBA.getControlByName(self.tblTBAInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	else
		if not self.splDLR.getControlByName(self.tblDLRInfo.name).visible then
			self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
		else
			self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
		endif;
	endif;

	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x,y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="7101ce5f-78c1-470e-880f-24d79d9cbb2e">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	theRow : Integer;
begin
	
	
	inheritMethod(table);
	
	theTI := table.accessRow(table.row).itemObject.CM_TrackedItem;
	if theTI &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);	
	endif;
end;</source>
