    <JadeMethod name="getAttrHazardous" id="7996a3e8-3a69-40c3-82e4-62f00c001984">
        <source>getAttrHazardous() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 December 2009	cnwas3	Initial creation
18/10/2010 	cnwmh5	#25626 - Add code to check either hazardous boolean or text
23 Nov 2011	cnwkpd1	PAR #28731 - fix transient leaks

*/

vars
	criteria 		: CM_YACriteria;	
	terminal		: CM_Terminal;			// 19/10/2010 cnwmh5 #25626
	
	hazardArray		: StringArray;			// 19/10/2010 cnwmh5 #25626
	
	isHazardous		: Boolean;				// 18/10/2010 cnwmh5 #25626
	value			: String;				// 19/10/2010 cnwmh5 #25626
	length			: Integer;				// 19/10/2010 cnwmh5 #25626
	intValue : Integer;
begin
	
	if self.useVoyageAllocations  then 
		// PAR 23263 criteria := self.allAllocations.last().CM_VoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsHazardous);
		criteria := self.getAttrByType(YACriteriaType_IsHazardous); // PAR 23263 
		if criteria &lt;&gt; null then
			intValue := criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;	//13 Apr 2015	NDL	Par 36032
			if intValue = CM_YADataBoolean.VALUE_TRUE then
				isHazardous := true;
			elseif intValue = CM_YADataBoolean.VALUE_FALSE or  intValue = CM_YADataBoolean.VALUE_EITHER then
				isHazardous := false; // do nothing here... try the other options
			endif;
		endif;
		// 18/10/2010 cnwmh5 #25626 - Start
		if not isHazardous then
			criteria := self.getAttrByType(YACriteriaType_Hazardous);
			if criteria &lt;&gt; null then
				// get the critiera into an array
				value := criteria.myYAData.getDataValue().String;
				hazardArray := value.getTokens();
				
				// get the terminal and includeLQasHazard
				terminal := self.myTerminal;
				if terminal = null or terminal.includeLQasHazardous() then
					isHazardous := true;
				else
					foreach value in hazardArray do
						length := value.trimBlanks().length;
						if length = 1 or (length &gt; 1 and value[length:1] &lt;&gt; "L") then
							isHazardous := true;
							break;
						endif;
					endforeach;
				endif;
			endif;
		endif;
		// 18/10/2010 cnwmh5 #25626 - End
	else
		isHazardous := self.hazardous;
	endif;
	return isHazardous;
epilog
	delete hazardArray;			// PAR #28731
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAttrHazardousList" id="3b0cf625-5654-422e-b805-41ba1b26624c">
        <source>getAttrHazardousList() : String;
// ---------------------------------------------------------------------------
// Created:     December 2014 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	criteria 		: CM_YACriteria;	
	value			: String;				
begin
	
	if self.useVoyageAllocations  then 
		criteria := self.getAttrByType(YACriteriaType_Hazardous);
		if criteria &lt;&gt; null then
			// get the critiera into an array
			value := criteria.myYAData.getDataValue().String;
			
			return value;
		endif;
	endif;
	return "";
epilog
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAttrHiCubed" id="2c165594-f195-4661-a4e5-97536fad54b8">
        <source>getAttrHiCubed() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 December 2009	cnwas3	Initial creation

*/

vars
	criteria : CM_YACriteria;	
	voyAlloc : CM_VoyageAllocation;
begin
	
	if self.useVoyageAllocations  then 
		voyAlloc := self.allAllocations.last().CM_VoyageAllocation;
		if voyAlloc = null then
			return false;
		else
			return voyAlloc.isHiCubed();
		endif;
	else
		return self.highCubed;
	endif;
	return false;
epilog

end;
</source>
        <ReturnType type="Boolean"/>
