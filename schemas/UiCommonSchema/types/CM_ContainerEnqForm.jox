    <JadeMethod name="clickArgShowAllSelected" id="eb6a9c1f-b1ed-47a7-9f18-c594648be652">
        <source>clickArgShowAllSelected( optionbutton: OptionButton input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2019	jlger1	Initial creation	TFS 47132

*/

vars

	tbl : CMUI_ListTable;
	checkBoxColumn : Integer;
	rowIndex : Integer;

begin

	tbl:= self.tblArgument;
	checkBoxColumn := tbl.getChkBoxColumn;

	if optionbutton = self.optAll and self.optAll.value
	or optionbutton = self.optSelected and not self.optSelected.value
	then
		//show all
		foreach rowIndex in 1 to tbl.rows do
			tbl.accessRow( rowIndex ).visible := true;
		endforeach;
	else
		//show only selected
		foreach rowIndex in 1 to tbl.rows do
			tbl.accessRow( rowIndex ).visible := tbl.accessCell( rowIndex, checkBoxColumn ).text = '1';
		endforeach;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
