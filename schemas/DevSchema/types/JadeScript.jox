    <JadeMethod name="dataDumpTestCT100Rec" id="4606c695-1bf0-415e-818a-2865617c1ff0">
        <source>dataDumpTestCT100Rec();
// June 2005 cnwrs1
// the script will update the last NUM entries of every class and then
// by running change tracker and data extract check that NUM rec per class are updated
constants
	DDxDefDescription = "mjcsql";
	NUM : Integer = 10;
vars
	class : Class;
	class1, class2: Class;
	classColl: ClassColl;
	classArray: ObjectArray;
	ddClass: CM_DataDumpExtractClass;
	objArray: ObjectArray;
	obj: Object;
	object: Object;
	ddExtractDef: CM_DataDumpExtractDef; 
	count,totalCount : Integer;
	finished: Boolean;
	dba: JadeDatabaseAdmin;
	updCount : Integer;
	num : Integer;
begin
	app.initialize;
	finished := false;
	if not self.tryLock(app.myRoot.allDataDumpClasses, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
		app.writeLog("Could not get Data Dump Extract lock. Data Extract must already be running retry later.",0);
		return;
	endif;	
	app.writeStatement(("Start. "&amp;CM_Terminal.firstInstance.name));
	app.writeLog("Start. "&amp;CM_Terminal.firstInstance.name,0);

	create classArray transient;
	create classColl transient;
	create objArray transient;
	// find all the base level classes extracted by DSS
	ddExtractDef := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	if ddExtractDef = null then
		app.writeLog("Could not find the Data Dump Extract details.",0);
		return;
	endif;
	foreach ddClass in ddExtractDef.allDataDumpExtractClasses do
		class1 := ddClass.myDataDumpClass.myClass;
		classColl.clear;
		class1.allSubclasses(classColl);
		if not class1.abstract then
			classArray.add(class1);
		endif;
		foreach class2 in classColl do
			if not class2.abstract then
				classArray.add(class2);
			endif;
		endforeach;
	endforeach;
	foreach obj in classArray do
		class := obj.Class;
		objArray.clear();
		count := 0;
		updCount := 0;
		app.writeStatement(class.name);
		class.allInstances(objArray,0,false);
		num := objArray.size;
		if num &gt; NUM then
			num := num-NUM;
		else
			num := 0;
		endif;
		beginTransaction;
		foreach object in objArray do
			count := count + 1;
			if count &gt; num then
				object.updateObjectEdition(object);	// par 30292
				updCount := updCount + 1;
			endif;
		endforeach;
		commitTransaction;
		totalCount := totalCount + updCount;
		app.writeStatement( class.name&amp;' '&amp;updCount.String);
	endforeach;

	create  dba transient;
	dba.closeCurrentLog;
	finished := true;
epilog
	self.unlock(app.myRoot.allDataDumpClasses);
	if finished then
		app.writeLog("Fin. updated="&amp;totalCount.String, 0);
		app.writeStatement(("Fin. updated="&amp;totalCount.String));
	else
		app.writeLog("Failed.", 0);
		app.writeStatement(("Failed."));
	endif;
	delete classArray;
	delete dba;
	delete objArray;
	delete classColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpTestCT1Rec" id="c9d0c151-7be7-4755-b457-4461fa0a689b">
        <source>dataDumpTestCT1Rec();
// June 2005 cnwrs1
// the script will mark the first entry of every class and then
// by running change tracker and data extract check that 1 rec per class is updated
 
constants
	DDxDefDescription = "Joe's Test SQL Native";
vars
	class : Class;
	class1, class2: Class;
	classColl: ClassColl;
	classArray: ObjectArray;
	ddClass: CM_DataDumpExtractClass;
	obj: Object;
	object: Object;
	ddExtractDef: CM_DataDumpExtractDef; 
	count : Integer;
	finished: Boolean;
	dba: JadeDatabaseAdmin;
begin
	app.initialize;
	finished := false;
	if not self.tryLock(app.myRoot.allDataDumpClasses, Reserve_Lock, Session_Duration, LockTimeout_Immediate) then
		app.writeLog("Could not get Data Dump Extract lock. Data Extract must already be running retry later.",0);
		return;
	endif;	
	app.writeStatement(("Start. "&amp;CM_Terminal.firstInstance.name));
	app.writeLog("Start. "&amp;CM_Terminal.firstInstance.name,0);

	create classArray transient;
	create classColl transient;
	// find all the base level classes extracted by DSS
	ddExtractDef := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	if ddExtractDef = null then
		app.writeLog("Could not find the Data Dump Extract details.",0);
		return;
	endif;
	foreach ddClass in ddExtractDef.allDataDumpExtractClasses do
		class1 := ddClass.myDataDumpClass.myClass;
		classColl.clear;
		class1.allSubclasses(classColl);
		if not class1.abstract then
			classArray.add(class1);
		endif;
		foreach class2 in classColl do
			if not class2.abstract then
				classArray.add(class2);
			endif;
		endforeach;
	endforeach;
	foreach obj in classArray do
		class := obj.Class;
		object := class.firstInstance;
		if object &lt;&gt; null then
			app.writeStatement( class.name);
			beginTransaction;
			object.updateObjectEdition(object);	// par 30292
			commitTransaction;
			count := count + 1;
		endif;
	endforeach;

	create  dba transient;
	dba.closeCurrentLog;
	finished := true;
epilog
	self.unlock(app.myRoot.allDataDumpClasses);
	if finished then
		app.writeLog("Fin. updated="&amp;count.String, 0);
		app.writeStatement(("Fin. updated="&amp;count.String));
	else
		app.writeLog("Failed.", 0);
		app.writeStatement(("Failed."));
	endif;
	delete classArray;
	delete dba;
	delete classColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpTestCTTestRecs" id="4a0883c4-6025-44c3-8331-199c87c3f922">
        <source>dataDumpTestCTTestRecs();

constants
	NUM : Integer = 100;
vars
	objArray1 : ObjectArray;
	objArray2 : ObjectArray;
	object : Object;
	count : Integer;
	updCount : Integer;
	delCount : Integer;
	num : Integer;
	finished : Boolean;
begin
	app.initialize;
	create objArray1 transient;
	create objArray2 transient;
	count := 0;
	updCount := 0;
	delCount := 0;
//	app.writeStatement(class.name);
	CM_Create.allInstances(objArray1, 0, false);
	CM_Move.allInstances(objArray2, 0, false);
	num := objArray1.size;
	if num &gt; NUM then
		num := num-NUM;
	else
		num := 0;
	endif;
	write 'Start '&amp;app.actualTimeServer.formatAsYYYYMMDDHHMMSSMMM;
			beginTransaction;
	foreach object in objArray1 do
		count := count + 1;
		if count &gt; num then
//			if count mod 2 = 0 then
			object.updateObjectEdition(object);	// par 30292
			updCount := updCount + 1;
//			else
//			delete object;
//			delCount := delCount + 1;
//			endif;
//			process.sleep(1000);
		endif;
	endforeach;
	commitTransaction;
	//abortTransaction;
	write 'Finish '&amp;app.actualTimeServer.formatAsYYYYMMDDHHMMSSMMM;
	num := objArray2.size;
	if num &gt; NUM then
		num := num-NUM;
	else
		num := 0;
	endif;
	count := 0;
	foreach object in objArray2 do
		count := count + 1;
		if count &gt; num then
			beginTransaction;
			object.updateObjectEdition(object);	// par 30292
			updCount := updCount + 1;
//			else
//			delete object;
//			delCount := delCount + 1;
//			endif;
	write object.String&amp;' '&amp;app.actualTimeServer.formatAsYYYYMMDDHHMMSSMMM;
//			if count mod 20 = 0 then
//				write "Halt";
//				process.debug;
//				abortTransaction;
//			else
			commitTransaction;
//			endif;
			process.sleep(1000);
		endif;
	endforeach;
	finished := true;
epilog
	if finished then
		app.writeLog("Fin. updated="&amp;updCount.String, 0);
		app.writeStatement("Fin. updated="&amp;updCount.String&amp;' deleted='&amp;delCount.String);
	else
		app.writeLog("Failed.", 0);
		app.writeStatement(("Failed."));
	endif;
	delete objArray1;
	delete objArray2;
end;
</source>
    </JadeMethod>
