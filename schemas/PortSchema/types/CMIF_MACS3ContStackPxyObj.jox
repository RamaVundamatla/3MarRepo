<Class name="CMIF_MACS3ContStackPxyObj" id="7e38b4c4-b699-49fe-a930-1983f1525f57">
    <superclass name="CMIF_MACS3WSProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="baseHeight" id="f857c96c-45db-4e69-82aa-3e04982374d1">
        <precision>23</precision>
        <scaleFactor>3</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <ImplicitInverseRef name="common" id="734efb51-4921-43c8-b955-812943a5e316">
        <embedded/>
        <type name="CMIF_MACS3ContCommonPxyObj"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="containerStackLengths" id="3ff830d1-d5c2-4997-b8f5-595e12a2f1a6">
        <memberTypeInverse/>
        <type name="CMIF_MACS3ContStackLenArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="heightLimit" id="c443716a-7e6a-41a9-87a9-55668d29b532">
        <precision>10</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <text>Matches Decimal CM_CellDefn::maxHeight[10,4]</text>
