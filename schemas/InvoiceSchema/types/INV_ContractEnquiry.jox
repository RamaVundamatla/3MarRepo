    <JadeMethod name="doNotableAdd" id="e79d2086-5a63-4401-9b95-2f410ef599df">
        <source>doNotableAdd(_anObject : Object);
/*
Purpose:			

Date		Who		Reason
13DEC2022	NAVAB1	TFS CR 55645 TASK 55662
*/
vars
	invalid : Boolean;
	ed : Integer;
begin
	if _anObject = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception,_anObject,invalid);
	ed := _anObject.edition;
	if invalid then
		return;
	endif;
	
	self.allNotableObjects.add(_anObject);
	beginNotification(_anObject, self.myTerminal.getTerminalEvent(Event_InvContractUpdate), Response_Continuous, null);
	beginNotification(_anObject, EventFileAdd, Response_Continuous, null);
	beginNotification(_anObject, EventFileDelete, Response_Continuous, null);

epilog

end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="be75e7ae-6714-4d67-a366-1ce167353a8c">
        <source>doNotableClear();
/*
Purpose:			

Date		Who		Reason
13 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars

	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		endNotification(anObject, self.myTerminal.getTerminalEvent(Event_InvContractUpdate));
		endNotification(anObject, EventFileAdd);
		endNotification(anObject, EventFileDelete);
	endforeach;
	
	self.allNotableObjects.clear;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="450c1337-50ba-4b7d-bcd6-398e76e1da48">
        <updating/>
        <source>doQuery() updating;
/*
Purpose:			

Date		Who		Reason
13 December 2022	navab1	TFS CR 55645 TASK 55662
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars
	contract : CM_InvoiceContract;
	tbl: CM_DataTable;
	cmqfIC : CMQF_InvoiceContract;
	detail : CM_InvoiceContractDetails;
	contractRteEntry	: CM_InvoiceContractRateEntry;
	contractRangeEntry  : CMIF_ContractRangeEntry;
	contractRangeEntryDates : CMIF_ContractRateEntryDates;
	rate : CM_InvoiceContractRate;	
	
begin
	
	create cmqfIC transient;						//14.10.2024 navlc30 #19508
	self.mousePointer := Window.MousePointer_HourGlass;
	self.tblData.rows := self.tblData.fixedRows;
	
	self.tblData.clearAllSelected();
	self.doNotableClear();
	
	tbl := self.tblData;
	
	// ### GET PARAMETERS
    self.setFilters();
	cmqfIC.setFilters(self);						//14.10.2024 navlc30 #19508
	
	// ### Dates for rate entries, use rate entry date collections
	if self.filterQueryRateFromStart.isValid()
		or self.filterQueryRateFromEnd.isValid()
		or self.filterQueryRateToStart.isValid()
		or self.filterQueryRateToEnd.isValid() then
		//self.getContractsForRateDates();			//14.10.2024 navlc30 #19508
		cmqfIC.getContractsForRateDates();			//14.10.2024 navlc30 #19508
	// ### Dates for contract details, use contract detail date collections
	elseif self.filterQueryDetailFromStart.isValid()
		or self.filterQueryDetailFromEnd.isValid()
		or self.filterQueryDetailToStart.isValid()
		or self.filterQueryDetailToEnd.isValid() then
		//self.getContractsForDetailDates();		//14.10.2024 navlc30 #19508
		cmqfIC.getContractsForDetailDates();		//14.10.2024 navlc30 #19508
	// ### Dates for contracts, use contract date collections
	elseif self.filterQueryContractFromStart.isValid()
		or self.filterQueryContractFromEnd.isValid()
		or self.filterQueryContractToStart.isValid()
		or self.filterQueryContractToEnd.isValid() then
		//self.getContractsForDates();				//14.10.2024 navlc30 #19508
		cmqfIC.getContractsForDates(); 				//14.10.2024 navlc30 #19508
	// ## Some debtors selected, use the collection of contracts on the debtors
	elseif self.allDebtors.isNotEmpty() then
		//self.getContractsForDebtors();			//14.10.2024 navlc30 #19508
		cmqfIC.getContractsForDebtors();			//14.10.2024 navlc30 #19508
	elseif self.filterQueryContract &lt;&gt; null then
		//self.getContractsForId();					//14.10.2024 navlc30 #19508
		cmqfIC.getContractsForId();					//14.10.2024 navlc30 #19508
	else
		// ### Default, use collection on bank by ID
		//self.getContractsForBU();					//14.10.2024 navlc30 #19508
		cmqfIC.getContractsForBU();					//14.10.2024 navlc30 #19508
	endif;

	//Load Contract Table
	foreach contract in cmqfIC.allContracts discreteLock do													//14.10.2024 navlc30 #19508
		self.addRowToTable(contract);
	endforeach;

	//Load Contract Details Table
	tbl := self.tblDetails;																					//14.10.2024 navlc30 #19508
	tbl.rows := tbl.fixedRows;
	foreach detail in cmqfIC.allContractDetails discreteLock do
		self.addRowToTblDetail(detail);
	endforeach;
	
	//Load Contract Rate Table																				//15.10.2024 navlc30 #19508
	tbl := self.tblRates;
	tbl.rows := tbl.fixedRows;	
	foreach contractRteEntry  in cmqfIC.allContractRateEntries discreteLock do								
		
		if rate = contractRteEntry.myInvoiceContractRate then
			continue;
		endif;
		
		rate := contractRteEntry.myInvoiceContractRate;
		
		if rate = null then
			continue;
		endif;
		
		create contractRangeEntry transient;
		contractRangeEntry.createCMIFRateEntryDates(rate);
		
		foreach contractRangeEntryDates in contractRangeEntry.allDateRanges do
			self.addRowToTblRates(contractRangeEntryDates);
		endforeach;		
		
		self.allTransientsToDelete.add(contractRangeEntry);
	endforeach;
	
	self.setLblTablDetail();
	
epilog
	self.mousePointer := Window.MousePointer_Default;
	delete cmqfIC;				//14.10.2024 navlc30 #19508
end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectorQuery" id="723d4dce-538d-4fad-85c7-ab78be309ef9">
        <source>doSelectorQuery();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2023	navmv20	TFS 55649 Task 56228: UI - Selector Dialog for Contracts

