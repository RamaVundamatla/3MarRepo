    <JadeMethod name="clearBayData" id="db3afd9a-ff51-4d5d-a4d9-140736e1e5bd">
        <updating/>
        <source>clearBayData()updating;
//--------------------------------------------------
// Created:	20 December 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	
	self.txt40FootBayID.text := null;
	self.txtBayID.text := null;
	self.txt40FootBayID.text := null;
	self.ckbAthwartships.value := false;
	self.ckbFortyFootOnly.value := false;
	self.ckbTwinLiftUD.value := true;
	self.ckbTwinLiftOD.value := true;
	
	self.txtUnderDeckCell.text := null;
	self.txtOnDeckCells.text := null;
	self.txtUnderDeckTier.text := null;
	self.txtOnDeckTier.text := null;
	self.txtUDCellsHiCub.text := null;
	
	self.cmbBayType.listIndex := -1; // zero based
	
	self.cmbDirOn.listIndex := 1;
	self.cmbDirOn40.listIndex := 1;
	self.cmbDirUnder.listIndex := 1;
	self.cmbDirUnder40.listIndex := 1;
	self.cmbOnShipCrane.listIndex := 1;
	
	self.txtMaxPileWt20IB.text := null;
	self.txtMaxPileWt20OB.text := null;
	self.txtMaxPileWt40IB.text := null;
	self.txtMaxPileWt40OB.text := null;
	self.txtMaxPileWtUD.text := null;
	self.txtRemarks.text := null;
	self.txtNumOfPlugs.text := null;
	
	
	// do not set the hold if from the template. The hold will have been auto set for the next bay
	self.cmbHolds.listIndex := -1;
	self.doBuildComboBay(self.cmbBayList);			
	self.ckbFortyFootBay.value := false;
	self.ckbForty5FootBay.value := false;

	self.cmbLashFrom.clear();
	self.cmbUnlashFrom.clear;

	self.currentBayEdition := null;
	
	self.shtBayDetails.caption := CaptionBay;
	self.shtBayLayout.caption := CaptionLayout;

	// Draw The Bay Layout
	self.doBuildComboBay(self.cmbBayLayout); // this will clear out the selected bays for hatch lid
	self.doDrawBay();
	
	self.displayAftBayEnableDisable(false);
	
	self.doLoadTblCellLimits();		//Par 25127	/ CCMS 1140
		
end;</source>
    </JadeMethod>
    <JadeMethod name="clearForm" id="eed76392-fcfe-4aa1-89c9-b328550a23a7">
        <updating/>
        <source>clearForm()updating;
//--------------------------------------------------
// Created:	29 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.picVesselBitmap.picture := null;
	self.txtBayOrder.text := null;
	self.ckb40BayIds.value := true; // default AKB2007FEB
	self.ckbISOHalfHeight.value := false;	

	self.cmbBayList.clear();
	self.displayBayDetails(null);
	self.setCaption(self.Caption);
	self.setNavigatorHeading(self.caption);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cmbBayLayout_click" id="98a14b83-a82c-4c0a-b394-386243b56bcd">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBayLayout_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	bayFrame : CMUI_GridAreaFrame;
	aPoint : CMUI_GridPoint;
	idx, ordinal : Integer;
	aHatchLid : CM_HatchLid; 
	aBay : CM_Bay;
	doAdd : Boolean;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	if combobox.listObject = null then
		return;
	endif;
	
	aBay := combobox.listObject.CM_Bay;
	
	// the lid points are part of the on deck bay area
	bayFrame := self.frmGridArea.getControl(ONDECK);
	if bayFrame &lt;&gt; null then
		aHatchLid := bayFrame.myGridArea.SHP_BayArea.getSelectedHatchLid().CM_HatchLid; 
	endif;
	if aHatchLid = null then
		return;
	endif;

	self.anythingChanged := true;
	doAdd := not aHatchLid.allBays.includes(aBay);
	aHatchLid.setProxyBay(aBay,doAdd);
	self.doBuildComboTableBays(aHatchLid.allBays);
	global.beep;
epilog
	app.mousePointer := Window.MousePointer_Default;


end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBayLayout_dropDown" id="ba79230f-7cfd-425a-a5a1-ef57e0c1e313">
        <controlMethod name="CMUI_ComboBox::dropDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBayLayout_dropDown(combobox: ComboBox input):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return true;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cmbBayList_click" id="9bbdf3a0-2ab8-47cf-b584-3ce7e3081cb6">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBayList_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		19 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	changes : Boolean;
begin

	if self.btnSaveBase.enabled then
		// changing bay views, in edit mode, may be some outstanding changes.
		self.doUpdateDeckCellProxies( self.tblOnCellDims, self.tblUnderCellDim, changes );	//19 Oct 2010	NDL	Par 26058
	endif;
	
	self.anythingChanged := false;
	self.anythingChangedBay := false;
	aBay := combobox.listObject.CM_Bay;
	
	self.displayBayDetails(aBay);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
