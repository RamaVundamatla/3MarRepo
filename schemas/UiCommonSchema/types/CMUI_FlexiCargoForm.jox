        <updating/>
        <source>initFromPackUnpackForm( _packUnpackForm : CM_BaseForm; _relatedObj : Object ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2013	cnwndl1	Initial creation	Par 32854

*/

vars

begin

	self.isMakeLCLForm := true;
	self.setParentForm( _packUnpackForm );
	self.myMainForm := _packUnpackForm;
	self.myPackUnpackObject := _relatedObj;
	
	self.myBulkRelease 			:= null;
	self.myReserveDetail 		:= null;
	self.myTI 					:= null;
	self.tiPrenoteEdition		:= 0;
	self.myBookingRefItem 		:= null;
	self.myCargoType			:= null;

	self.myPxyGTEEntity			:= null;
	self.myRealGTEEntity 		:= null;
