    <JadeMethod name="displayGrades" id="bc0764fd-401c-40f5-bceb-5b2463ce3923">
        <updating/>
        <source>displayGrades() updating, protected;
/*
Date		Who		Reason
28 Jan 2009	cnwcp2	Initial creation
19 Aug 2013 cnwer1	PAR 32261
*/

vars
	
begin
	
	tblGrades.rows := 0;
	
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.canSetAvailabilityGrade then
		self.getSessionAgent().loadGradesTable( self.tblGrades, self.myTrackedItem, self.selectedRow);
	endif;
	
	self.tblGrades.cnAdjustColumnWidths();
	
	self.setForView();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
