    <JadeMethod name="setToDoTaskComplete" id="ec97b7f9-0a64-474c-98d2-fe7d099933ab">
        <updating/>
        <source>setToDoTaskComplete(taskCode : Integer; _passport : CM_Passport input; _resourceUsageProxys : CM_ResourceTypeUsageSet; _wodtl: CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
19 May 2023			navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
*/

vars
	task 				: CM_ToDoTask;
	found 				: Boolean;
	wod					: CM_WodToDoWagon;
	eventType			: Integer;
	event, trans		: CM_Transaction;
	resourceUsageProxys	: CM_ResourceTypeUsageSet;
	tasksComplete		: Boolean;
	transType : CM_TransactionType;
begin
	tasksComplete := true;
	
	foreach task in self.allToDoTasksToDo where (task.toDoTaskDescCode = taskCode and _wodtl.allToDoTasks.includes(task)) do
		found := true;
		break;
	endforeach;
	
	create resourceUsageProxys transient;
	if _resourceUsageProxys &lt;&gt; null then
		_resourceUsageProxys.copy(resourceUsageProxys);
	endif;
	
	if found then
		wod := task.myWODetailToDo.CM_WodToDoWagon;
		task.setToDoTaskComplete(_passport, resourceUsageProxys);
		task.CM_WagonToDoTask.updateWagonComplete();
		trans := wod.createWOTransaction(wod.TRANS_COMPLETED, resourceUsageProxys, task);	 // ### JIRA 23013 16OCT2024 NAVAB1
		
		// ### JIRA 14793 24OCT2024 NAVAB1
		transType := task.toDoTaskDesc.myTransactionType;
		if transType &lt;&gt; null and transType.isForWorkOrder()    then // WO Trans Type
			trans := wod.createWOTransactionUserDefined(transType.trxType, resourceUsageProxys, task);
		
		else
			eventType := task.getToDoTaskCompleteEventInt;	
			if eventType &lt;&gt; null then
				event := self.createTransaction(app.actualTime, eventType, null, null, null, false, resourceUsageProxys, task, _wodtl); // ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
				/* // ### TFS CR 54345 TASK 54267 12JUN2023 NAVAB1
				if event &lt;&gt; null then																			//19.5.2023 navhl20 #56631[56185]
					event.addResourcesFromProxys(resourceUsageProxys);	
				endif;
				*/
			endif;
		endif;
		
		foreach task in self.allToDoTasksToDo do
			if task.myWODetailToDo = wod and task.status = STATUS_TODO then
				tasksComplete := false;	
			endif;
		endforeach;
		if tasksComplete then
			wod.allWagonsActioned.remove(self);
			wod.allWagonsCompleted.add(self);
		endif;
		self.updateObjectEdition(self);
	endif;
epilog
	delete resourceUsageProxys;
end;</source>
        <Parameter name="taskCode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
        <Parameter name="_wodtl" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="bea4fb14-9e33-477a-8e44-1dcb6c7ef483">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Sep 2024 Bug 65987: EUP - Error 1308 when loading Train enquiry screen

*/

vars

begin
	if _property = null or
	   _property.name = CM_Wagon::allReportTIsInwards.name or
	   _property.name = CM_Wagon::allReportTIsOutwards.name  then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="stub_GetDamageTerminal" id="915d0009-8c8c-4afa-a109-f9fe188d800f">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_DamageDetails::getDamageTerminal"/>
        </interfaceImplements>
        <source>stub_GetDamageTerminal(): CM_Terminal;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements for the IF_DamageDetails interface 
	*/
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2022	navak20	Initial creation

*/

vars

begin
	return self.myTerminal;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="tareWeight" id="6aefa71c-b14d-4f64-85dd-93f77365f32b">
        <methodInvocation>mapping</methodInvocation>
        <source>tareWeight(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2019	jlgndl1	Initial creation	TFS 4113
22 July	 2022	jlika1	TFS 54050 - EUP- Max Wagon Payload
*/

vars
	edition 			: Integer;
	invalidObject 		: Boolean;
	allowWagonWeights 	: Boolean;	
begin
	
	if not set then
	
		if self.myTerminal &lt;&gt; null then
			allowWagonWeights := self.myTerminal.getConfig(AllowWagonWeightsToBeUpd).Boolean;
		endif;
		
		if (allowWagonWeights) then
			if self.tareWeight &lt;&gt; null then
				_value := self.tareWeight;			
				return;
			endif;
		endif;
		
		if self.myWagonClass &lt;&gt; null then
			_value := self.myWagonClass.tareWeight;			
			return;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="unconfirmWagonInwards" id="32061027-3dee-4925-9d98-68fd818876d8">
        <updating/>
        <source>unconfirmWagonInwards(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jan 2011	cnwkpd1		PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------
vars
	iter 	: Iterator;
	lState 	: Integer;
	ti 		: CM_TrackedItem;
	allTIs	: CM_TIArray;
	railJob : CM_RailJob;
	term	: CM_Terminal;
begin

	if (not self.confirmed) then
		return;
	endif;
	
	//08 June 2011	NDL	Par 27411 - Don't allow unconfirm inwards if wagon has been worked in any way.
	self.validateUnConfirmWagonIn();
	
	self.unconfirmWagonOutwards(_passport);//can't be confirmed out if its not confirmed in
	
	term := self.getTerminal(); // PAR 21182
	
	create allTIs transient;
	self.getAllTrackedItems(true, allTIs, false);
	railJob := self.allRailJobs.first.CM_RailJob;
	
	iter  := allTIs.createIterator;
	lState := TI_STATE_NOTIFIED;
		
	while iter.back(ti) do
		ti.unconfirmWagon(_passport);
	endwhile;
	if railJob &lt;&gt; null then
		railJob.causeTerminalEvent(railJob.Event_Mode_Create);
		railJob.erase(NORMAL_ERASE);
	endif;
	
	self.confirmed := false;
	app.myEventManager.createSingleObjInfoNoteEvt(self, term.getTerminalEvent(Wagon_Create_Event), self);					
	
	
epilog
	delete allTIs;
	delete iter;		// PAR #26678
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unconfirmWagonOutwards" id="9c9135d7-549f-410e-bc75-cbb351d4164a">
        <updating/>
        <source>unconfirmWagonOutwards(_passport : CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	
	self.confirmedOutwards := false;
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.getTerminal().getTerminalEvent(Wagon_Create_Event), self);	 // PAR 21182

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateControllersTerminalArea" id="774c00f1-8ead-44a2-98ee-4c2c062a9082">
        <updating/>
        <source>updateControllersTerminalArea() updating;
//--------------------------------------------------
// Created:	04 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	lc : CM_WagonController;
	termArea : CM_TerminalArea;
begin

	if self.myRailLine &lt;&gt; null then
		termArea := self.myRailLine.myRailArea;
	endif;
	
	//foreach lc in self.allLocationsControllers do
	foreach lc in self.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
		lc.setMyTerminalArea(termArea);
	endforeach;
	
end;</source>
    </JadeMethod>
