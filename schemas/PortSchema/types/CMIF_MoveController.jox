    <JadeMethod name="setMyRotatableContainer" id="8d69377b-fdb0-4ba4-b7b9-361c4c34ca48">
        <updating/>
        <source>setMyRotatableContainer( _ti : CM_TrackedItem) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 October 2025		jlier1	Initial creation 36155
10 November 2025	jlizm1	MTN 36328 Rotabox Assign Release To Vessel

*/

vars

begin
	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	if _ti = null then
		return;
	endif;

	
	if not _ti.isRotatableContainer then
		return;
	endif;
	
	if _ti.getCargoTypeForContents = null then
		return;
	endif;
	
	if not self.myToPrimaryLocation.isKindOf(CM_GeneralCargoController) and not self.myToPrimaryLocation.isKindOf(CM_ShipBlockController) then
		return;
	endif;
	
	if _ti.weightCargo = 0 then
		app.raiseCMException(Cargo_weight_should_not_zero, null, null);
		return;
	endif;
	
	self.myRotatableContainer:=_ti;
	self.weight:=self.myRotatableContainer.weightCargo;
	//self.volume:=self.myRotatableContainer.getMyCargoVolume;
	self.myOriginatingLocation:=self.myRotatableContainer.myPrimaryActualLocation;
	self.myTrackedItem:=null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMyToPrimaryLocation" id="893cdeb8-7be8-49e3-be9a-bdb7d74dbfb3">
        <updating/>
        <source>setMyToPrimaryLocation(value: CM_LocationsController) updating;
/*
 ------------------------------------------------------------------------
Created:			24 September 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin

	if self.myToPrimaryLocation &lt;&gt; value then 
		self.myToPrimaryLocation := value;
		if value &lt;&gt; null then
			self.myToTerminal := value.myTerminal;
			
			//now
			if CM_VoyageController.hasInstance(value) then
				self.myToPrimaryLocationString :=  value.getFullIdTI(self.myTrackedItem);
			else
				// RBarr	24/7/2006	PAR 11955	Add indication of TI level in stack
				//self.myToPrimaryLocationString := value.getFullId();
				//self.myToPrimaryLocationString := value.getFullIdAndLevel(self.myTrackedItem,self.moveMode, false);
				
				self.myToPrimaryLocationString := self.getPrimaryLocationId();
			endif;
			//was self.myToPrimaryLocationString := value.getFullId;
		else
			self.myToPrimaryLocationString := null;
		endif;
		self.updateAllToLocations(null);
	endif;
	
//	if self.myToPrimaryLocation = null then
//		app.writeStatement("MoveTo location is NULL.  From: " &amp; self.myOriginatingLocation.String &amp; ", ID:" &amp; self.myTrackedItem.String);	
//	endif; 
end;</source>
        <Parameter name="value" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setMyToPrimaryLocationString" id="fa0606b0-15e3-46fb-b94b-dcd13b16e65e">
        <updating/>
        <source>setMyToPrimaryLocationString(value: String) updating;
/*
 ------------------------------------------------------------------------
Created:			24 September 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if self.myToPrimaryLocationString &lt;&gt; value then 
		self.myToPrimaryLocationString := value;
	endif;


end;</source>
        <Parameter name="value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyToPrimaryLocnFromString" id="208cdc8d-4668-45c3-823e-4cb290e6555e">
        <updating/>
        <source>setMyToPrimaryLocnFromString(term : CM_Terminal; str : String; mode : Integer) updating;
/*
 ------------------------------------------------------------------------
Created:			26 July 2001 by cnwdwq1
Purpose:			Takes the string, does a findLocation on it and also sets the toPrimaryLocation ref
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	foundLC : CM_LocationsController;
	atHeight : Integer;
begin
	if term = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(Err_Invalid_Terminal, "null!", null, null);
		return;
	endif;
	term.findLocationFromString(str, false, foundLC, atHeight);
	if foundLC = null then
		self.myToPrimaryLocation := null;
		self.myToPrimaryLocationString := null;
		return;	
	endif;
	self.moveMode := mode;
	self.myToPrimaryLocation := foundLC;
	self.myToPrimaryLocationString := str.trimBlanks; 
	self.myToTerminal := foundLC.myTerminal;
	self.updateAllToLocations(null);
end;</source>
        <Parameter name="term" type="CM_Terminal"/>
        <Parameter name="str" type="String"/>
        <Parameter name="mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyToSecondaryLocations" id="232d9009-0cec-4254-a2b6-3f6158711150">
        <updating/>
        <source>setMyToSecondaryLocations(array : CM_LCArray) updating;
/*
 ------------------------------------------------------------------------
Created:			13 September 2001 by cnwdwq1
Purpose:			Takes an array of secondary locations and sets to control object
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	lc			: CM_LocationsController;
	strTerms	: String;
begin
	self.myToSecondaryLocations.clear();
	if array = null or array.isEmpty then
		self.updateAllToLocations(null);
		return;
	endif;
	//----------------------
	//Check all secondaryLocations on same terminal
	//----------------------
	foreach lc in array do
		if lc = self.myToPrimaryLocation then
			//If they've supplied us with the primary location as well, ignore
			continue;
		endif;
		/* AKB2003MAY removed cos self.isRehandleMove must be set for the discharge to set the correct future move type on CM_FutureMove
			if this is a discharge then these will not be a slot controller
		if self.isRehandleMove then
			//---------------------
			//If a rehandle move, then each one of these MUST be a cm_slotController
			//---------------------
			if not lc.isKindOf(CM_SlotController) then
				app.setContinueCMExceptions(false);
				app.raiseCMException(ERR_INVALID_LCTYPE, null, null);
				return;
			endif;
		endif;
		*/
		if (lc.myTerminal &lt;&gt; self.myToTerminal) then	//Note these could be BOTH null! (e.g. a voyage)
			
			if lc.myTerminal = null then
				strTerms := "(null &lt;&gt; ";
			else
				strTerms := "(" &amp; lc.myTerminal.code &amp; " &lt;&gt; ";
			endif;
			if self.myToTerminal = null then
				strTerms := strTerms &amp; "null)";
			else
				strTerms := strTerms &amp; self.myToTerminal.code &amp; ")";
			endif;
			
			app.setContinueCMExceptions(false);
			app.raiseCMException1(Err_Invalid_Terminal, " does not match the  target location's Terminal reference " &amp; strTerms, null, null);
			return;		
		endif;
		self.myToSecondaryLocations.add(lc);
	endforeach;
	
	//	array.copy(self.myToSecondaryLocations); // AKB2003MAY moved to to an ADD in the loop 2 lines up, so that the primary location can be passed in as part of the secondary and be ignored
	self.updateAllToLocations(null);
	//----------------------
	//Validate that they all have the same parents
	//---------------------
	self.validateLCsHaveSameParent();
end;</source>
        <Parameter name="array" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="ef007cfd-bdb5-49a9-973b-acaf119e1b38">
        <updating/>
        <source>setMyTrackedItem(ti : CM_TrackedItem) updating;
/*
 ------------------------------------------------------------------------
Created:			26 July 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if ti = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam, class.name &amp; " " &amp; method.name, "Tracked Item Reference", null, null);
		return;
	endif;
	
	
	
	self.myTrackedItem := ti;
	/*if global.cnwer1 then
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isChild  and self.myPackToTI = null then
		self.myUnpackFromTI:=self.myTrackedItem.myParent;
	else
		self.myUnpackFromTI:=null;
	endif;
	endif;*/
	//---------------------
	//Set the primary originating location, we use it in the post move stuff
	//---------------------
	self.setMyOriginatingLocation(ti.getPrimaryLocation(REAL_MODE));
	//self.myOriginatingLocation := ti.getPrimaryLocation(REAL_MODE);
	
	self.myOriginalTI := null;	//26 Nov 2020	NDL	TFS 50422
	
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMyWorkListEntry" id="07364dcf-3635-49cc-8829-78a89e0e771e">
        <updating/>
        <source>setMyWorkListEntry(wle : CM_WorkListEntry)updating;
//FD for ISOType and TI Release Validation purpose
// 24/11/2010	cnwmh5		PAR 29396 - Change so only changes door direction if
//							needs to and doors forward, and tidy code up
// 21/05/2019	jlgzm1		TFS 42840 MSL Direct Release between Voyages and Rail
vars
	is20 : Boolean;
	localTrans : Boolean;
	packToTI 	: CM_TrackedItem;
begin
	self.myWorkListEntry := wle;

	if self.moveMode = QUEUE_MODE 
	and not self.validateOnly
	
	and self.myToPrimaryLocation &lt;&gt; null 
	and wle &lt;&gt; null 
	and wle.myRequest &lt;&gt; null 
	and wle.myRequest.checkDoorDirForJob()  and self.myTrackedItem &lt;&gt; null  then
		
		// reverse the door direction on the CONTAINER if going to the south side of an RTG reefer gantry
		is20 := self.myTrackedItem.isTwenty(); // CCMS 1029 not (self.myTrackedItem.isAttributeTrue(TI_Attrib_IsForty) or self.myTrackedItem.isAttributeTrue(TI_Attrib_IsFortyFive));
		// this will only update yard requests. CM_SlotRequest does not have a method 'setDoorDir' so does not update the slotReq's door dir
		// MUST NOT CHANGE CM_SlotRequest.DoorDirn
		
		// 24/11/2010 cnwmh5 #26396 - Start
		//self.myWorkListEntry.myRequest.setDoorDir(not self.myToPrimaryLocation.needReverseDoor(is20));
		if self.myToPrimaryLocation.needReverseDoor(is20) and self.myWorkListEntry.myRequest.CM_YardRequest.doorsForward then
			localTrans := (not process.isInTransactionState);
			if localTrans then
				beginTransaction;
			endif;
			self.myWorkListEntry.myRequest.setDoorDir(not self.myWorkListEntry.myRequest.CM_YardRequest.doorsForward);
			if localTrans then
				app.cmsCommitTransaction(self.myPassport);
				localTrans := false;
			endif;
		endif;
		// 24/11/2010 cnwmh5 #26396 - End
		
	endif;
	
	if self.moveMode = REAL_MODE and self.myWorkListEntry &lt;&gt; null then
		if self.myWorkListEntry.isReleaseToPack then
			packToTI:=self.myWorkListEntry.getTargetTIForPack();
			if packToTI &lt;&gt; null then
				self.setMyPackToTI(packToTI);
			endif;
		endif;
	endif;
	
	// TFS 42840 start
	// Direct Release
	if wle &lt;&gt; null then
		if wle.myFutureMove &lt;&gt; null then
			if wle.myFutureMove.myWorkListEntryDR &lt;&gt; null then
				self.myDDWorkListEntry := wle.myFutureMove.myWorkListEntryDR;
				self.myDDJob := wle.myFutureMove.myWorkListEntryDR.job;
			endif;
		elseif wle.myFutureMoveDR &lt;&gt; null then
			if wle.myFutureMoveDR.myWorkListEntry &lt;&gt; null then
				self.myDDWorkListEntry := wle.myFutureMoveDR.myWorkListEntry;
				self.myDDJob := self.myDDWorkListEntry.job;
			endif;
		endif;
	endif;
	// TFS 42840 end
	
epilog
	if localTrans then
		abortTransaction;
	endif;
end;</source>
        <Parameter name="wle" type="CM_WorkListEntry"/>
    </JadeMethod>
