    <JadeMethod name="showHazardousChildrenForm" id="40d34dfb-4253-4782-aa48-d51aa5cc80be">
        <source>showHazardousChildrenForm(_terminal : CM_Terminal; _isFromPackingForm, _isFromGateForm, _isFromPreNote : Boolean; _pxyTrackedItem : CM_TrackedItem; _pxyReceival : CMGTE_Receival; _booking : CM_BookingRef; _attachments : ObjectArray; _parentForm : CM_BaseForm; _masterMenuAction : CMUI_MenuAction);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
// 28/07/2016	cnwdap1		TFS #2384 Correct handling of attachments for new hazardous form
//
vars
	form : CMUI_HazardousChildrenForm;
	cargoType : CM_CargoBOLType;
	lclFound : Boolean;
	
begin
	// check LCL Cargo is an available cargo type for this terminal
	foreach cargoType in _terminal.allCargoBOLTypes do
		if cargoType.id = TI_CargoType_LCL then
			lclFound := true;
			break;
		endif;
	endforeach;
	if not lclFound then
		app.raiseCMException(LCL_Cargo_Reqd_For_Terminal, null, null);
		return;
	endif;
	
	form := app.loadForm(CMUI_HazardousChildrenForm, CMUI_Assistant, false, false, true , _terminal, _masterMenuAction).CMUI_HazardousChildrenForm;
	form.setMyMasterItems(_pxyTrackedItem, _pxyReceival, _booking);
	form.setParentForm(_parentForm);
	form.setFromForm(_isFromPackingForm, _isFromGateForm, _isFromPreNote);

	if _attachments &lt;&gt; null and _isFromGateForm then
		//_attachments.copy(form.allProxyChildReceivals);		// TFS #2384
		form.setAllProxyChildReceivals(_attachments);			// TFS #2384
	endif;
	
	form.showModal();
epilog
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_isFromPackingForm" type="Boolean"/>
        <Parameter name="_isFromGateForm" type="Boolean"/>
        <Parameter name="_isFromPreNote" type="Boolean"/>
        <Parameter name="_pxyTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_pxyReceival" type="CMGTE_Receival"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_attachments" type="ObjectArray"/>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
