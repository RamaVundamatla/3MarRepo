        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="583cd9a7-8af9-439f-b744-cf62890bdb60">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason	Par 23498

*/

vars
	lDetail : String;
	refStr : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := "Seal Number " &amp; self.sealNum;

			lDetail := lDetail &amp; " " &amp; self.urNumber.String;
			
			//03 Nov 2014	NDL	Par 35160
			self.appendReferenceString( lDetail );
			
			return lDetail;
			
		endif;
	elseif _attrName = 	ETRow_SealNum or
		   _attrName = ETRow_TransSealNum then
		return self.sealNum;
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="d8ac8eae-9fcc-46d8-bd5d-9f5de4689614">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
begin
	lDetail := inheritMethod();
	lDetail := lDetail &amp; "Seal Number " &amp; self.sealNum;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="03b00091-88be-443f-9d29-28aca80e6a56">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     28 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_tiTransCntrl, _passport);
	//th2 PAR 11962 - whoever implemented user defined todo tasks failed to consider
	//the fact that user may associate any TI transaction type to create along with it.
	//For toDoTasks the _tiTransCntrl is always just type CMIF_TITransactionController
	if CMIF_SealTransController.hasInstance(_tiTransCntrl) then
		self.sealNum := _tiTransCntrl.CMIF_SealTransController.sealNum;
	endif;
	
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setSealDetails" id="1213d737-ba24-435c-a0ef-9b9db94bc5f1">
        <updating/>
        <source>setSealDetails(_sealNum : String) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.sealNum := _sealNum;

end;</source>
        <Parameter name="_sealNum" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="08a1a546-27d5-4b2f-b72e-7555c7eaf003">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;

vars

begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	
	// After some internal discussion it was decided that creating/updating
	// a seal transaction should NOT update the actual seal number on the
	// tracked item.  This may need to be re-considered at some point.
	// The complications are that the transaction may be added in the past
	// (ie. before other seal transactions), editted (if allowed), and
	// the setting of the prevSealNum field on CM_Container (RJS 24/9/01)
	self.myTrackedItem.setSealDetails(null, self.dateTime, true);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
