    <JadeMethod name="exportCargoCSV" id="ea78844f-af44-47f0-8673-abec2bbb4897">
        <updating/>
        <source>exportCargoCSV(_file : File input; _line : String) updating;
// ---------------------------------------------------------------------------
// Created:		October 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
//24/05/2023 navkc1	 CR 57927 Task 57923: Jade - Transaction Map Export Import
// ---------------------------------------------------------------------------

vars
	tranMap : CM_TranMap;
	tmctig : CMIF_TranMapController;
	str,
	tmpString : String;
begin
	// 23659 add invoice mapping methods to extract, contract column for voyage, use .extractName instead of .itemName
	self.myTMCController.loadXMLDocument();
	self.myTMCController.getFullHeadings();

	if self.myTranMapCargo &lt;&gt; null then
		foreach str in self.myTMCController.fullMethodHeadings do
			tmpString := tmpString &amp; "," &amp; str;
		endforeach;
		// 29499 extra Grouping column
	//	_file.writeLine("TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line"&amp;tmpString); //13/02/2017 cnwma1 TFS #2901
		_file.writeLine("TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line"&amp;tmpString); //13/02/2017 cnwma1 TFS #2901 //TFS 41096 added transfer type
	elseif self.myTranMapEvent &lt;&gt; null then
		// 24/05/2023	navkc1	CR 57927 Task 57923
		_file.writeLine("TranMap Type,TranMap Name,Event,Resource,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line");
	elseif self.myTranMapWO &lt;&gt; null then // TFS 39236
		// 24/05/2023	navkc1	CR 57927 Task 57923
		_file.writeLine("TranMap Type,TranMap Name,Work Order,Resource,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line");  // TFS 39236 
	elseif self.myTranMapBOL &lt;&gt; null then // 31 Oct 2019	NDL	TFS 47100
		_file.writeLine("TranMap Type,TranMap Name,BOL Trx,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line");	// 31 Oct 2019	NDL	TFS 47100
	elseif self.myTranMapVTMIS &lt;&gt; null then
		_file.writeLine("TranMap Type,TranMap Name,Resource,Debtor,Quantity Type,Quantity Range,In Contract," &amp;
									"Cargo Type, Sub Type, Commodity," &amp; // ### TFS CR 65333 TASK 65334 06AUG2024 NAVAB1
									"Vessel Category,Transfer Type,Grouping,Invoice Line");		// 19/6/18 MAP TFS38899
	endif;

	tmpString := _line;
	if tmpString &lt;&gt; null then
		tmpString := tmpString &amp; "," &amp; self.extractName.csvEncode();
	else
		tmpString := self.myGroup.extractName.csvEncode() &amp; "," &amp; self.extractName.csvEncode();
	endif;
	foreach tmctig in self.allGroupMembers do
		tmctig.exportCargoCSV(_file, tmpString);
	endforeach;


	
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_line" type="String"/>
    </JadeMethod>
    <JadeMethod name="getCode" id="bb780058-8419-4262-9795-0d7b8a51b55b">
        <source>getCode(): String;
// ---------------------------------------------------------------------------
// Created:		April 2010	cnwjre1	par 23659
//
// Purpose:		return just the name, for the extract
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myTranMapCargo &lt;&gt; null then
		return self.myTranMapCargo.name;
	elseif self.myTranMapVTMIS &lt;&gt; null then
		return self.myTranMapVTMIS.name;
	elseif self.myTranMapEvent &lt;&gt; null then
		return self.myTranMapEvent.name;
	elseif self.myTranMapWO &lt;&gt; null then // TFS 39236
		return self.myTranMapWO.name; // TFS 39236
	elseif self.myTranMapBOL &lt;&gt; null then //31 Oct 2019	NDL	TFS 47100
		return self.myTranMapBOL.name; //31 Oct 2019	NDL	TFS 47100
	elseif self.myTranMapSSSummary &lt;&gt; null then
		return self.myTranMapSSSummary.name;
	elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then // PAR 35833
		return self.myCurrentMapTMCargoAllocation.name; // PAR 35833
	elseif self.myTranMapInventory &lt;&gt; null then  // ### TFS 51219 25MAY2021 NAVAB1
		return self.myTranMapInventory.name;  // ### TFS 51219 25MAY2021 NAVAB1
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
