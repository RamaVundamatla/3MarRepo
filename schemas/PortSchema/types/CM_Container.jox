/* ---------------------------------------------------------------------------
Created:	03 November 2010	by cnwvu1

Purpose:	#25592
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	contRange: CM_ContRange;
	
begin
	contRange := app.myRoot.lookupContainerRange(self.id);	

	if contRange &lt;&gt; null then
		return contRange.cubicMetres;
	endif;
	
	if self.myTiMaster &lt;&gt; null then
