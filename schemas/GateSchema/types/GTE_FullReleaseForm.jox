    <JadeMethod name="addObjectsToTable" id="52db3b19-a150-442f-b797-b59aed6468ac">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:  
// 11/07/2025		naviv1			MTN-35226 : MTN - Usage of Iterator.getCurrentKeys     
// ---------------------------------------------------------------------------
vars
    tiDict,	
    tiDict2,
	bolTiDict	:  CM_TIByIdCargoTypeDict;
	ti		: CM_TrackedItem;
	savePointer	: Integer;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
	operTerminal: CM_OperatorTerminal;
	pin		: CM_PinNo;
 	obj		: Object;
	iter	: Iterator;
	tmpId	: String;
	idLength	: Integer;
	idKey			: String;
	cargoTypeKey	: Integer;
	secondDict	:  CM_TIByIdCargoTypeDict; 


begin
	if (not self.isFirstActivateComplete) and self.myFilterVoyage = null then
		return;
	endif;

	savePointer := app.mousePointer;
	app.mousePointer := Window.MousePointer_HourGlass;

	tmpPassport := app.myPassport;

	app.setStatusLineCaption('Loading tracked items');

	//set the pin number column, must be done here as this is called when column ordering is changed
	self.columnPinNo := self.tblData.getColumnByRowName(ETRow_MyPinNo);				
	
	if self.filterPIN &lt;&gt; null then
		pin := self.myTerminal.allPinNos[self.filterPIN];
		if pin &lt;&gt; null then
			foreach obj in pin.allItems discreteLock do //+ cnwmd1 Par 25448 added dicreteLock
				if CM_TrackedItem.hasInstance(obj) and
		   	       self.includeObject(obj.CM_TrackedItem, tmpPassport) then
					self.addObjectToTable(obj.CM_TrackedItem, _numItems, breakOut);
				endif;
				if breakOut then
					break;
				endif;
			endforeach;
		endif;

		return;
	endif;
	
	if self.myFilterOperator &lt;&gt; null then
		operTerminal := self.myFilterOperator.allOperatorTerminals[self.myTerminal];
	endif;
	
	//22 July 2014	NDL	Par 34036
	if self.filterIncludeOnShip then
		create secondDict transient;
	endif;
	
	if operTerminal &lt;&gt; null then
		tiDict := operTerminal.allOnsiteTIsByIdCargoType;
		//22 July 2014	NDL	Par 34036
		if secondDict &lt;&gt; null then
			self.populateOnShipCargoFor( operTerminal, secondDict );
		endif;
	
	elseif self.myFilterVoyage &lt;&gt; null then
		tiDict := self.myFilterVoyage.allOnsiteTIsByIdCargoType;
		//22 July 2014	NDL	Par 34036
		if secondDict &lt;&gt; null then
			 self.myFilterVoyage.allOnshipTIsByIdCargoType.copy( secondDict );
		endif;
	
	elseif self.filterBOL &lt;&gt; null then
		create bolTiDict transient;
		
		// populate bolTiDict 
		if self.filterBOL &lt;&gt; null then
			self.getBOLsFromFilter(bolTiDict);
		endif;
		
		tiDict := bolTiDict;
	else
		tiDict := self.myTerminal.allOnsiteTIsByIdCargoType;
		//22 July 2014	NDL	Par 34036
		if secondDict &lt;&gt; null then
			self.populateOnShipCargoFor( self.myTerminal, secondDict );
		endif;
	endif;
	
	
	create tiDict2 transient;
	
	iter := tiDict.createIterator();
	
	tmpId := self.filterId;
	
	if tmpId &lt;&gt; null then
		tiDict.startKeyGeq(tmpId, 0, iter);
		idLength := tmpId.length;
	endif;
	
	while iter.next(ti) do
		iter.getCurrentKeys(idKey,cargoTypeKey); //MTN-35226
		if idKey[1 : idLength] &lt;&gt; tmpId then
			break;
		endif;
		if (not ti.isImport) then
			continue;
		endif;
		tiDict2.add(ti);
	endwhile;
	
	
	
	//22 July 2014	NDL	Par 34036
	if secondDict &lt;&gt; null then
		delete iter;
		iter := secondDict.createIterator();
		if tmpId &lt;&gt; null then
			secondDict.startKeyGeq(tmpId, 0, iter);
			idLength := tmpId.length;
		endif;
		
		while iter.next(ti) do
			iter.getCurrentKeys(idKey, cargoTypeKey); //MTN-35226
			if idKey[1 : idLength] &lt;&gt; tmpId then
				break;
			endif;
			if (not ti.isImport) then
				continue;
			endif;
			tiDict2.add(ti);
		endwhile;
	endif;
	
	/*
	foreach ti in tiDict where ti.isImport do
		tiDict2.add(ti);
	endforeach;	
	*/
	
	self.progressStart((tiDict2.size), app.getErrorString(Cancel), null, null, 'Loading Imports');
	
	foreach ti in tiDict2 discreteLock do //+ cnwmd1 Par 25448 added dicreteLock
		if self.includeObject(ti, tmpPassport) then
			self.addObjectToTable(ti, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;
	
epilog
	delete iter;
	delete tiDict2;
	delete bolTiDict;
	app.setStatusLineCaption('');
	app.mousePointer := savePointer;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addStopsColumns" id="156d4d54-06d0-4e31-af0b-0bc33dc80065">
        <updating/>
        <source>addStopsColumns() updating;
//-----------------------------------------
// Created: 20 November 2003 By: cnwgd1
//-----------------------------------------
vars
	aStopTable : CM_StopsTable;
	theUser : CM_User;
	term	: CM_Terminal;	
begin
	
	theUser := app.getMyUser();
	term := self.myTerminal;
	// Stops are in a class of their own now so add all of them AKB2002JUNE
	foreach aStopTable in app.myRoot.allStopsTable do
		if theUser.canViewStop(term, aStopTable) and aStopTable.isValidForTerminal(self.myTerminal) then
			// Create a transient entRow for this column
			self.zAddTransientEntTblRow(aStopTable.code, ETRow_Stops &amp; Tab &amp; aStopTable.id.String, Table.InputType_CheckBox);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="cd483aa5-219c-43cb-b24c-7c9421e779af">
        <source>addToolbarControls() protected;
//--------------------------------------------------
// Created:	04 December 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	if self.allowGeneratePin then
		self.frmToolbar.addButton(self.btnGeneratePin,	CMUI_Toolbar.Control_Alignment_Left);
		self.frmToolbar.addButton(self.btnDeletePin,	CMUI_Toolbar.Control_Alignment_Left);
	else
		self.btnGeneratePin.visible := false;
		self.btnDeletePin.visible := false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="e52161d6-4f6d-4200-b22e-3ddcb63ce06e">
        <source>armNotesForObject(_obj: Object);
// ---------------------------------------------------------------------------
// Created:     29 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.beginNotification(_obj, Object_Delete_Event, Response_Continuous, 0);
	self.beginNotification(_obj, Object_Update_Event, Response_Continuous, 0);

	// effectively a delete from the visible list
	self.beginNotification(_obj, self.myTerminal.getTerminalEvent(TIEvent_Terminal_Release), Response_Continuous, 0);

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
