    <JadeMethod name="click" id="a6f2f2b1-9b02-40e5-b260-9e7a69d0e0b2">
        <controlMethod name="CMUI_ToolbarButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>click(frame: CMUI_ToolbarButton input) updating;

//05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

vars
	btn			: CMUI_ButtonForToolbar;
	tmpStyle	: Integer;
	newValue	: Boolean;
	
begin
	if self.referenceType = self.ReferenceType_Button then
		btn := self.myBtnForToolbarTblFilter;
		tmpStyle := self.style;

		if tmpStyle = Button.Style_Auto2State then
			newValue := true;
			btn.value := newValue;
			self.resetButtonState(newValue);

		elseif tmpStyle = Button.Style_2State then
			newValue := (not btn.value);
			btn.value := newValue;
		endif;

		btn.click(self.myBtnForToolbarTblFilter);

		if tmpStyle = Button.Style_Auto2State then
			if newValue then
				self.myToolbar.resetButtonStateForParent(self, btn.parent);
			endif;
		elseif self.style = Button.Style_2State then
			self.resetButtonState(btn.value);
			if (not btn.value) then
				frame.drawButtonUp();
			endif;
		elseif (not btn.enabled) then
			frame.clearGraphics();
		endif;

	elseif self.referenceType = self.ReferenceType_MenuUserToolbar then
		self.myToolbar.doMenuUserToolbarClick(app.isControlKeyDown(), self.myMenuUserToolbar);
	endif;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="frame" type="CMUI_ToolbarButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="enabled" id="08173271-eb41-487a-9ab6-6f49b356b582">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>enabled(_set: Boolean; _value: Boolean io) updating, mapping;
//05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control
vars
	btn	:CMUI_ButtonForToolbar;
begin
	
	btn := self.myBtnForToolbarTblFilter;
	
	if btn = null or self.style = Button.Style_Normal then
		return;
	endif;
	
	if _set and _value then
		if btn.value then
			self.drawButtonDown;
		else
			self.drawButtonNormal;
		endif;
	endif;
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
