    </PrimAttribute>
    <PrimAttribute name="toDate" id="b355b69d-7498-435e-b659-3feddb823b90">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="e98aed42-43ef-4a06-a70b-3781ba71ea2b">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

begin

	self.allInventoryLines.purge();
	self.allThroughPutLines.purge();
	self.allThroughPutSummaryLines.purge();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="c6d27aa5-92c6-4516-8241-0cb0f3ad1cc2">
        <source>noOutputReturned(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

begin
	return 	self.allInventoryLines.isEmpty and 
			self.allThroughPutLines.isEmpty and
			self.allThroughPutSummaryLines.isEmpty;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
