    <JadeMethod name="includesCritName" id="bf6c3f08-84b0-4822-9cf6-0a7a939d11a7">
        <source>includesCritName(_criteria : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2024	navra1	Initial creation for BUG 63499 - FR | 53383 - Cargo Group Reservation - part III

*/

vars
	criteria : CM_YACriteria;
begin
	if self.myObjectMatchCriteria = null then
		return false;
	endif;	
	
	foreach criteria in self.myObjectMatchCriteria.allCriteria do
		if criteria.myYACriteriaType &lt;&gt; null then
			if criteria.myYACriteriaType.type = _criteria then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_criteria" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
