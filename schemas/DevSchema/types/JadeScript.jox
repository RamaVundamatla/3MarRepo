    <JadeMethod name="rh_TFS2983" id="bfc8351b-14ef-423c-9d59-eba49c7977dc">
        <source>rh_TFS2983();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 November 2016	cnwrh7	Initial creation

*/

vars
	invoiceQDef : CM_QDefInvoice;
	queryProp	: CM_QueryProperty;
begin
	app.initialize();
	beginTransaction;
	invoiceQDef  := CM_QDefInvoice.firstInstance;
	queryProp :=  invoiceQDef.allQueryProperties[CM_Invoice :: toDT.name];
	/*if queryProp &lt;&gt; null then
		write "queryProp is not null";
		delete queryProp;
		if invoiceQDef.allQueryProperties.includes (queryProp) then
			invoiceQDef.allQueryProperties.remove(queryProp);
		endif;
	endif;
	commitTransaction;
	*/
	if queryProp = null then
		write "queryProp is null";
		create queryProp as CM_QDateProperty persistent;
		queryProp.set("Invoice End Date",  CM_Invoice ::toDT.name, invoiceQDef.className);
		write "create queryProp";
		if not invoiceQDef.allQueryProperties.includes (queryProp) then
			invoiceQDef.allQueryProperties.add(queryProp);
			write "query Prop created in dictionary";
		else
			write "not created in dictionary";
		endif;
	endif;
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
