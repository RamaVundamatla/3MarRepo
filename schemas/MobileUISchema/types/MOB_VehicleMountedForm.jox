    <JadeMethod name="doIscaleWeightTasks" id="f568dac3-fcef-475b-93ba-9d2542f7ab1c">
        <updating/>
        <source>doIscaleWeightTasks() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2016	cnwrh7	Initial creation

*/

vars
	vmAgent														: VehicleMountedGenericAgent;
	dtoRTQueueEntryArray						: DTO_RTQueueEntryArray;
	firstDTOEntry,twinDTOEntry				: DTO_RTQueueEntry;
	firstTask,twinTask									: CM_RTQueueTask;
	taskTI 															: CM_TrackedItem;
	newLocation												: CM_LocationsController;
	moveController										: CMIF_MoveController;
	device															: CM_RadioTelemetryDevice;		
	isTwin,isCertified										: Boolean;
	weight															: Integer;
	
begin
	vmAgent := app.myVMAgent;
	app.myVMAgent.setVMInterface(self.IF_VehicleMountedDetails);
	device := app.myVMAgent.myRTDevice;	
	create  dtoRTQueueEntryArray transient;
	vmAgent.findWorkingDTORTEntries(dtoRTQueueEntryArray,null);
	firstDTOEntry:=dtoRTQueueEntryArray.first;
	firstTask:=firstDTOEntry.myRealQueueEntry.CM_RTQueueEntry.findTaskOfType(TASK_SETDOWN,TASK_WORKING);
	
	if dtoRTQueueEntryArray.size = 2 then
		twinDTOEntry:=dtoRTQueueEntryArray[2];
		if twinDTOEntry &lt;&gt; null then
			twinTask:=twinDTOEntry.myRealQueueEntry.CM_RTQueueEntry.findTaskOfType(TASK_SETDOWN,TASK_WORKING);
		endif;
	endif;
	
	taskTI := firstTask.ti;
	isTwin := twinTask &lt;&gt; null; 
	
	if device.canDoIScaleWeighting and  not isTwin and taskTI &lt;&gt; null  then
		weight :=self.getIScaleWeight();
		if vmAgent.myVMInterface &lt;&gt; null then
			isCertified := vmAgent.myVMInterface.isWeightCertified();
		endif;
		if weight &lt;&gt; 0 then							//Start Doing Complete Tasks and Auto Plan
			app.myTrxUA.trxUpdateWeightAutoplan(self.myMachine, firstTask, weight, isCertified, app.myPassport);	
			app.myPassport.initialiseTransaction;
			app.myPassport.finaliseTransaction(TRXStatus_Committed);
		else
			self.addInfoDisplay ("No weight data input");
			return;
		endif;
	endif;
	
	
epilog
	delete dtoRTQueueEntryArray;
	delete moveController;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doKeyDown" id="476a32b6-99dc-4920-aaa8-5406675be13f">
        <updating/>
        <source>doKeyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2010	cnwer1	Initial creation

*/

vars
	theActiveControl : Control;
	row,
	col : Integer;
begin
		
	self.doActionForFunctionKey(keyCode);
	
	if keyCode = J_key_F12 then
		if (app.isSpecial() or app.isDevelopmentSystem()) and shift.cnEcIsCtrlKey() then
			if shift.cnEcIsShiftKey() then
				self.cnEcShowContents();
			else
				self.cnEcShowGuiInfo();
			endif;
		endif;
	endif;
	//epr par 36977 18/11/15
	if keyCode = J_key_Tab then
		theActiveControl:=app.activeControl;
		if self.isSettingDown then
			if theActiveControl= self.btnGraphic then
				row :=self.myMoveTableDetails.findRowWithEntRowName(ETRow_TargetID);
				self.tblMoveEntry.row:=row;
				self.tblMoveEntry.column:=DataColumn;
			endif;
		endif;
	endif;
		

epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
