*/

vars
	voyage			: CM_Voyage;
	vesselArr		: StringArray;
	str				: String;
	invalidObject	: Boolean;
	edition			: Integer;
begin
	on Exception do app.handleDeletedObject(exception, voyage, invalidObject);
	create vesselArr transient;
	
	foreach voyage in self.allVoyages discreteLock do	//06.03.2025 navma1 #MTN-34179
		invalidObject := false;
		edition 	  := voyage.edition;
		
		if invalidObject then
			continue;
		endif;
		if voyage.vesselName &lt;&gt; null then
			vesselArr.add(voyage.vesselName);
		endif;
	endforeach;
	str := vesselArr.concatenate(Comma);
	return str;
epilog
	delete vesselArr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
