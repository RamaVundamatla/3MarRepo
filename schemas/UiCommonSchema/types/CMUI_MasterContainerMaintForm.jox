	//self.myAssistant.showDamageEntryForm(self, CMUI_DamageCodesForm.Mode_Update, self.myTerminal, null, self.myTiMaster, null, self.myMasterMenuAction);
 // ### TFS 55313 08NOV2022 NAVAB1	realTi := self.myTiMaster;
	
	/*	// 30/09/2022	navkc1	#54463
	form := app.loadForm (CMUI_DamageCodesAdvanceForm, CMUI_Assistant, false, false, true , self.myTerminal, null).CMUI_DamageCodesAdvanceForm;
	form.mode := Mode_Update;
	form.isParentFormUpdate := true;
	
		
	form.setMyMasterItems(ti, realTi);
	form.setParentForm(self);

	form.centreWindow();
	form.show();
	*/	// 30/09/2022	navkc1	#54463
	
 // ### TFS 55313 08NOV2022 NAVAB1	self.myAssistant.showDamageEntryForm(self, Mode_Update, self.myTerminal, ti, realTi, null, null, true); // 30/09/2022	navkc1	#54463
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doNext" id="5e061d70-7d34-4f18-95a2-a6efef310db8">
        <updating/>
        <source>doNext()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2008	cnwrd1	Initial creation

*/

vars

begin


	if self.doSave() then
	
		self.txtID.text				:= null;
