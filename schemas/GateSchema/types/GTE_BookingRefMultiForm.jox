    <JadeMethod name="setPxyBookingRefFromTables" id="02363fe7-87f6-4780-9d9b-9c794d9cca18">
        <updating/>
        <source>setPxyBookingRefFromTables(_bookingRef : CM_BookingRef io) updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// adm 160310 Par 22937 remove bolType
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
vars
	tmpPorts	: StringArray;
	assistant	: GTE_Assistant;
	strTemp		: String;
	rTemp		: Real;
	destPort,
	dischPort	: String;
	obj			: Object;
//	bolType,
	id			: Integer;
	theWeight	: Decimal[14,4]; //02.2.09 cnwrd1 par #18821 
	refStatus	: Integer;
	transhipPort: CM_Port;
	
begin
	assistant := self.myAssistant.GTE_Assistant;
	
	create tmpPorts transient;
	assistant.saveListTablePorts(lstDischarge, tmpPorts);

	//new port stuff
	obj	:= self.cmbDestination.listObject;
	if obj &lt;&gt; null then
		destPort :=obj.CM_Port.code;
	endif;
	
	obj	:= self.cmbTranship.listObject;
	if obj &lt;&gt; null then
		transhipPort :=obj.CM_Port;
	endif;
	
	obj	:= self.cmbDischarge.listObject;
	if obj &lt;&gt; null then
		dischPort :=obj.CM_Port.code;
	endif;
	
	strTemp := assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_CarriageTempC).String.trimBlanks;
	if strTemp = null then
		rTemp := NULL_TEMPERATURE;
	else
		rTemp := strTemp.Real;
	endif;
	
//	if cmbBOLType.listObject.CM_BOLType &lt;&gt; null then
//		bolType := cmbBOLType.listObject.CM_BOLType.id;
//	endif;
	
	if cmbTiType.listObject.CM_CargoBOLType &lt;&gt; null then
		id := cmbTiType.listObject.CM_CargoBOLType.id;
	endif;
	// 27492 cnwjre1 May 2011 cmbTiType is not always visible (is control for row 'Cargo Type', not in all views), use the existing value
	if id = 0 then
		id := _bookingRef.cargoType;
	endif;
	
	//epr par 12707 10/10/06 theres two different etrow for weights that are visible/invisible depending on the cargo type - save the one that's visible
	if tblMain.isRowVisible(ETRow_WeightTotal) or tblExtra.isRowVisible(ETRow_WeightTotal) then
		theWeight:=assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_WeightTotal).Decimal;  //02.2.09 cnwrd1 par #18821 
	else
		theWeight:=assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyWeight).Decimal; //02.2.09 cnwrd1 par #18821 
	endif;
	
	refStatus	:=	app.bookingRefStatusStringToEnum(assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_StatusDesc).String);
	
	self.myInterfaceBookingRef.setProxy(assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_BookingReference).String,
										refStatus,
										id,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Clean).Boolean,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Commodity).String,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_ConsignorReference).String, // AKB June 2001 was NULL
										//	 null,	// RJS - need to determine this : consignorRef
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Description).String,
										destPort,
										dischPort,
										transhipPort,
										tmpPorts,
										self.lstHazardList.allSelectedObjects,	//CCMS 1203 JC - careful not to delete these with proxy
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Humidity).Decimal,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Inspected).Boolean,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_IsoType).String,
										assistant.getConsignFromCombo(assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_ConsignorCode).String),
										cmbConsignee.listObject.CM_ConsigneeConsignor,
										app.myRoot.allOperators[assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_OperatorCode).String],
										self.myTerminal.lookupVoyage(assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_VoyageCode).String, null, false),
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Quantity).Integer,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_BookingRefRemarks).String,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Remarks).String,
										rTemp,// JC 29/01/04 assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_CarriageTempC).Real,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_Ventilation).Decimal, //par19252 cnwrs1 may 2009
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyHeight).Decimal, //02.2.09 cnwrd1 par #18821 
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyLength).Decimal, //02.2.09 cnwrd1 par #18821 
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyWidth).Decimal, //02.2.09 cnwrd1 par #18821 
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyHeightString).String,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyLengthString).String,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyWidthString).String,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyType).String,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyDensity).Integer,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyVolume).Real,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyQuantity).Integer,
										theWeight,//assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyWeight).Integer,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_CubicMetres).Real,
										self.myTerminal,
										cmbProduct.listObject.CM_Product,
										null,	// //05 Nov 2012	NDL	Par 29859 assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MultiItem).Boolean,  // dh 31/1/2008 ccms 1618
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_IsStockBookingRef).Boolean,  // aer 29/05/2008 ccms 1618
										_bookingRef.myEDIBookingRefTI, _bookingRef.rawEDIData,
										assistant.mainExtraGetValue(tblMain, tblExtra, ETRow_ShippingReference).String,
										assistant.mainExtraGetValue (tblMain, tblExtra, ETRow_CarrierReference).String,	// par 27460 cnwcs5
										assistant.mainExtraGetValue (tblMain, tblExtra, ETRow_IsDirectDelivery).Boolean
										);
epilog
	delete tmpPorts;
end;</source>
        <Parameter name="_bookingRef" type="CM_BookingRef" usage="io"/>
    </JadeMethod>
