    </JadeMethod>
    <JadeMethod name="initFormBays" id="e4590d75-03c8-44f1-a336-18c9d8214d93">
        <updating/>
        <source>initFormBays() updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/
constants
	FrameGap = 3;
	FrameWidth = 15;
	FrameHeight = 15;
vars
	row, col, x1, y1 , more, colNum, rowNum: Integer;
	tmpFrame : Frame;
	tmpPoint : IntegerArray;
begin
	
	self.backColor := White;
	colNum := 28;
	rowNum := 30;
	// ### Left Right Group of frames
	self.grpLocnLR.left := FrameGap;
	self.grpLocnLR.top := FrameGap;
	self.grpLocnLR.backColor := White;
	// PAR 27493
	self.grpLocnLR.ignoreSkin := true;
	self.frmLocn.visible := false;
	self.frmLocn.ignoreSkin := true;
	
	y1 := 50;
	more := -2;
	foreach row in 1 to 15 do
		x1 := 50;
		

		tmpFrame := self.frmLocn.cloneSelf(true);
		self.addControl(tmpFrame);		
		tmpFrame.borderColorSingle := Black;
		tmpFrame.backColor := White;
		tmpFrame.foreColor := White;
		tmpFrame.parent := self.grpLocnLR;
		tmpFrame.left := x1 - 30;
		tmpFrame.top := y1;
		tmpFrame.width := FrameWidth;
		tmpFrame.height := FrameHeight;
		tmpFrame.visible := true;
		tmpFrame.drawTextAlign := Frame.DrawTextAlign_Center;
		tmpFrame.autoRedraw := true;
		tmpFrame.drawFontSize := 6;
		tmpFrame.drawTextAt(rowNum.padLeadingWith("0",2), 7,0, Black);
		rowNum := rowNum - 2;

		
		
		foreach col in 1 to 29 do
			if row = 1 then
				tmpFrame := self.frmLocn.cloneSelf(true);
				self.addControl(tmpFrame);		
				tmpFrame.borderColorSingle := Black;
				tmpFrame.backColor := White;
				tmpFrame.foreColor := White;
				tmpFrame.parent := self.grpLocnLR;
				tmpFrame.left := x1;
				tmpFrame.top := y1 - 30;
				tmpFrame.width := FrameWidth;
				tmpFrame.height := FrameHeight;
				tmpFrame.visible := true;
				tmpFrame.drawTextAlign := Frame.DrawTextAlign_Center;
				tmpFrame.autoRedraw := true;
				tmpFrame.drawFontSize := 6;
				tmpFrame.drawTextAt(colNum.padLeadingWith("0",2), 7,0, Black);
				colNum := colNum + more;
				if colNum &lt; 0 then
					colNum := 1;
					more := 2;
				endif;
			endif;
			
			tmpFrame := self.frmLocn.cloneSelf(true);
			self.addControl(tmpFrame);		
			tmpFrame.borderColorSingle := SkyBlue;
			tmpFrame.backColor := White;
			tmpFrame.foreColor := White;
			tmpFrame.parent := self.grpLocnLR;
			tmpFrame.left := x1;
			tmpFrame.top := y1;
			tmpFrame.width := FrameWidth;
			tmpFrame.height := FrameHeight;
			tmpFrame.visible := true;
			tmpFrame.autoRedraw := true;
			create tmpPoint transient;
			tmpPoint[1] := row; tmpPoint[2]:= col;
			tmpFrame.userObject := tmpPoint;
			tmpFrame.caption := "Horizontal (" &amp; row.String &amp; " X " &amp; col.String &amp; ")";
			self.allControlsByName.add(tmpFrame);
			
			x1 := (x1 + FrameWidth + FrameGap).Integer;
		endforeach;
		y1 := (y1 + FrameHeight + FrameGap).Integer;
	endforeach;
	
	self.grpLocnLR.width := x1 + FrameGap;
	self.grpLocnLR.height := y1 + FrameGap;
	// PAR 27493
	self.frmLocnLR.ignoreSkin := true;
	self.frmLocnLR.transparent := true;
	self.frmLocnLR.move(0,0,self.grpLocnLR.width, self.grpLocnLR.height);
	self.frmLocnLR.zOrder(0);
	
	// ### Up Down Group of frames
	self.frmLocn.visible := false;
	self.frmLocnUD.visible := false;
	self.grpLocnUD.visible := false;
	
	self.grpLocnLR.top := 45;
	self.width := self.grpLocnUD.left + self.grpLocnUD.width + 20;
	self.height := self.grpLocnUD.top + self.grpLocnUD.height + 45;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initFormLanes" id="f5137036-f14d-437d-a4be-46fdf21130cd">
        <updating/>
        <source>initFormLanes() updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/
constants
	FrameGap = 3;
	FrameWidth = 250;
	FrameHeight = 15;
vars
	row, col, x1, y1 : Integer;
	tmpFrame : Frame;
	tmpPoint : IntegerArray;
begin
	
	self.backColor := White;
	
	// ### Left Right Group of frames
	self.grpLocnLR.left := FrameGap;
	self.grpLocnLR.top := FrameGap;
	self.grpLocnLR.backColor := White;
	self.frmLocn.visible := false;
	// PAR 27493
	self.frmLocn.ignoreSkin := true;
	self.grpLocnLR.ignoreSkin := true;
	self.lblInfo.top := 5; self.lblInfo.left := 5;
	self.grpLocnLR.top := self.lblInfo.top + self.lblInfo.height + 5;
	
	y1 := FrameGap;
	
	foreach row in 1 to 8 do
		x1 := FrameGap;
		foreach col in 1 to 1 do
			tmpFrame := self.frmLocn.cloneSelf(true);
			self.addControl(tmpFrame);		
			tmpFrame.borderColorSingle := SkyBlue;
			tmpFrame.backColor := White;
			tmpFrame.foreColor := White;
			tmpFrame.parent := self.grpLocnLR;
			tmpFrame.left := x1;
			tmpFrame.top := y1;
			tmpFrame.width := FrameWidth;
			tmpFrame.height := FrameHeight;
			tmpFrame.visible := true;
			tmpFrame.autoRedraw := true;
			create tmpPoint transient;
			tmpPoint[1] := row; tmpPoint[2]:= col;
			tmpFrame.userObject := tmpPoint;
			tmpFrame.caption := row.String &amp; " Lanes";
			self.allControlsByName.add(tmpFrame);
			
			x1 := (x1 + FrameWidth + FrameGap).Integer;
		endforeach;
		y1 := (y1 + FrameHeight + FrameGap).Integer;
	endforeach;
	
	self.grpLocnLR.width := x1 + FrameGap;
	self.grpLocnLR.height := y1 + FrameGap;
	// PAR 27493
	self.grpLocnLR.ignoreSkin := true;
	self.frmLocnLR.ignoreSkin := true;
	self.frmLocnLR.transparent := true;
	self.frmLocnLR.move(0,0,self.grpLocnLR.width, self.grpLocnLR.height);
	self.frmLocnLR.zOrder(1);
	
	self.grpLocnUD.visible := false;
	self.width := self.frmLocnLR.left + self.frmLocnLR.width + 20;
	self.height := self.frmLocnLR.top + self.frmLocnLR.height + 100;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initFormLocations" id="7eef6960-f7c1-4e69-9ea2-18f1d125be39">
        <updating/>
        <source>initFormLocations() updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/
constants
	FrameGap = 3;
	FrameWidth = 35;
	FrameHeight = 15;
vars
	row, col, x1, y1 : Integer;
	tmpFrame : Frame;
	tmpPoint : IntegerArray;
begin
	
	self.backColor := White;
	
	// ### Left Right Group of frames
	self.grpLocnLR.left := FrameGap;
	self.grpLocnLR.top := FrameGap;
	self.grpLocnLR.backColor := White;
	// PAR 27493
	self.grpLocnLR.ignoreSkin := true;
	self.frmLocn.visible := false;
	self.frmLocn.ignoreSkin := true;
	
	y1 := FrameGap;
	
	foreach row in 1 to 8 do
		x1 := FrameGap;
		foreach col in 1 to 8 do
			tmpFrame := self.frmLocn.cloneSelf(true);
			self.addControl(tmpFrame);		
			tmpFrame.borderColorSingle := SkyBlue;
			tmpFrame.backColor := White;
			tmpFrame.foreColor := White;
			tmpFrame.parent := self.grpLocnLR;
			tmpFrame.left := x1;
			tmpFrame.top := y1;
			tmpFrame.width := FrameWidth;
			tmpFrame.height := FrameHeight;
			tmpFrame.visible := true;
			tmpFrame.autoRedraw := true;
			create tmpPoint transient;
			tmpPoint[1] := row; tmpPoint[2]:= col;
			tmpFrame.userObject := tmpPoint;
			tmpFrame.caption := "Horizontal (" &amp; row.String &amp; " X " &amp; col.String &amp; ")";
			self.allControlsByName.add(tmpFrame);
			
			x1 := (x1 + FrameWidth + FrameGap).Integer;
		endforeach;
		y1 := (y1 + FrameHeight + FrameGap).Integer;
	endforeach;
	
	self.grpLocnLR.width := x1 + FrameGap;
	self.grpLocnLR.height := y1 + FrameGap;
	// PAR 27493
	self.frmLocnLR.ignoreSkin := true;
	self.frmLocnLR.transparent := true;
	self.frmLocnLR.move(0,0,self.grpLocnLR.width, self.grpLocnLR.height);
	self.frmLocnLR.zOrder(1);
	
	// ### Up Down Group of frames
	self.grpLocnUD.left := self.grpLocnLR.left + self.grpLocnLR.width + FrameGap;
	self.grpLocnUD.top := FrameGap;
	self.grpLocnUD.backColor := White;
	self.grpLocnUD.ignoreSkin := true;
	self.frmLocn.visible := false;
	
	y1 := FrameGap;
	
	foreach row in 1 to 8 do
		x1 := FrameGap;
		foreach col in 1 to 8 do
			tmpFrame := self.frmLocn.cloneSelf(true);
			self.addControl(tmpFrame);		
			tmpFrame.borderColorSingle := SkyBlue;
			tmpFrame.backColor := White;
			tmpFrame.foreColor := White;
			tmpFrame.parent := self.grpLocnUD;
			tmpFrame.left := x1;
			tmpFrame.top := y1;
			tmpFrame.width := FrameHeight;
			tmpFrame.height := FrameWidth;
			tmpFrame.visible := true;
			create tmpPoint transient;
			tmpPoint[1] := row; tmpPoint[2]:= col;
			tmpFrame.userObject := tmpPoint;
			tmpFrame.caption := "Vertical (" &amp; row.String &amp; " X " &amp; col.String &amp; ")";
			tmpFrame.autoRedraw := true;
			self.allControlsByName.add(tmpFrame);
			
			x1 := (x1 + FrameHeight + FrameGap).Integer;
		endforeach;
		y1 := (y1 + FrameWidth + FrameGap).Integer;
	endforeach;
	
	self.grpLocnUD.width := x1 + FrameGap;
	self.grpLocnUD.height := y1 + FrameGap;
	self.frmLocnUD.ignoreSkin := true;
	self.frmLocnUD.transparent := true;
	self.frmLocnUD.move(0,0,self.grpLocnUD.width, self.grpLocnUD.height);
	self.frmLocnUD.zOrder(1);
	
	self.grpLocnLR.top := ((self.grpLocnUD.height - self.grpLocnLR.height) /2);
	self.width := self.grpLocnUD.left + self.grpLocnUD.width + 20;
	self.height := self.grpLocnUD.top + self.grpLocnUD.height + 45;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="af936713-3900-4895-9d94-2cd9ea3e3d40">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/

vars

begin
	inheritMethod();
	
	
	self.myPointDrawingFrame.doBtnClearClick(true);

	if self.polyType = DeckItemLayoutType_Locn then
		self.initFormLocations();
	elseif self.polyType = DeckItemLayoutType_Lane then
		self.initFormLanes();
	elseif self.polyType = DeckItemLayoutType_Slot then
		self.initFormBays();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a59099e7-ff3a-4049-bdd2-d3faf770eca7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016113, locale);
end;</source>
    </JadeMethod>
</GUIClass>
