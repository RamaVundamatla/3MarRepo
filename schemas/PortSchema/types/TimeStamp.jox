    <JadeMethod name="addSecondsInterval" id="3dba6c73-84e2-4b60-b4ca-65feb9085eb0">
        <updating/>
        <source>addSecondsInterval(seconds: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		19 May 2003 by cnwsgp1
//
// Purpose:		Used to add to or subtract from a timestamp
// ---------------------------------------------------------------------------
vars
	numberOfDays: Integer;
	numberOfSeconds: Integer;
	
begin
	if (seconds &lt; 0) then
		numberOfSeconds:= seconds - (SecondsPerDay - (self.time.Integer div MillisecondsPerSecond)) ;
	else
		numberOfSeconds:= seconds + (self.time.Integer div MillisecondsPerSecond);
	endif;
	numberOfDays:= numberOfSeconds div SecondsPerDay;
	self.setDate(self.date + numberOfDays);
	self.setTime(((numberOfSeconds mod SecondsPerDay) * MillisecondsPerSecond).Time);
end;</source>
        <Parameter name="seconds" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSecondsInterval64" id="28efda89-ad64-4784-9fc7-2f2197b1b45d">
        <updating/>
        <source>addSecondsInterval64(seconds: Integer64) updating;
/*
Purpose:			

Date		Who		Reason
01JUL2022	NAVAB1	TFS 53105
*/

constants
	SecondsPerDay64 : Integer64=86400;
vars
	numberOfDays: Integer64;
	numberOfSeconds: Integer64;
	newDate : Date;
begin
	if (seconds &lt; 0) then
		numberOfSeconds:= seconds - (SecondsPerDay64 - (self.time.Integer div MillisecondsPerSecond)) ;
	else
		numberOfSeconds:= seconds + (self.time.Integer div MillisecondsPerSecond);
	endif;
	numberOfDays:= numberOfSeconds div SecondsPerDay64;
	
	newDate :=self.date + numberOfDays.Integer;
 
	self.setDate(newDate);
	self.setTime(((numberOfSeconds mod SecondsPerDay64) * MillisecondsPerSecond).Time);
end;</source>
        <Parameter name="seconds" type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="addYears" id="bc284d27-3bd0-4065-b616-559ac0922cc5">
        <source>addYears(_amountToAdd: Integer):TimeStamp;
//----------------------------------------------------------------
//	Created:	25 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	currentTimestamp	: TimeStamp;
	
begin
	currentTimestamp	:=	self;
	currentTimestamp.setDate(self.date.cnEcAddYears(_amountToAdd));
	
	return currentTimestamp;
end;</source>
        <Parameter name="_amountToAdd" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="asEpochFormat" id="0cf539b2-a20c-42a3-818d-5c2538fad3f0">
        <source>asEpochFormat():Integer64;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	ts1 	  : TimeStamp;
	formatted : Integer64;
begin
	if not self.isValid then
		return null;
	endif;
	ts1.setDate("01/01/1970".Date);
	ts1.setTime("00:00:00".Time);
	
	// Changed to getDifference so timestamp is in milliseconds
	formatted := self.localToUTCTime.getDifference(ts1).Integer64;
	return formatted;
epilog

end;</source>
        <ReturnType type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="asJSONFormat" id="fabbd520-5dff-45d6-86d6-a9e19b819630">
        <source>asJSONFormat() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars

begin
    if not self.date.isValid() then
        return null;
    endif;
    
	return self.date().format('yyyy-MM-dd') &amp; 'T' &amp; self.time().formatAsHHMMSSmmm() &amp; 'Z';
    
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringForWebInterface" id="efcbd2d7-f810-44ee-bed8-f3c5d953f27a">
        <source>asStringForWebInterface():String;
/*

Purpose:			The RIA may be running on a server that uses a different LOCALE than
					the client.  Convert to known format at both ends.

Parameters:			

Return Value:		

Date		Who		Reason
26 Oct 2012	cnwndl1	Initial creation	Par 30622
17 May 2017	cnwkpd1	TFS 4469 - return null string for null timestamps

*/

vars

	str : String;

begin
	if self.isValid() then
		str := self.date.asStringForWebInterface();
		
		str := str &amp; " " &amp; self.time.asStringForWebInterface();
	endif;
	return str;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
