	if not provider.sendMsgWithParams(JMTSecureService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTSecureService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;

	// These are the real methods that should be whitelisted
	
	// JMTUserInterfaceService
	methodName := JMTUserInterfaceService::getUserLocale.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTUserInterfaceService::getTerminals.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	methodName := JMTUserInterfaceService::getCurrentTerminal.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
