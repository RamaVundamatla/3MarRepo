    <JadeMethod name="isBerthageOnContract" id="f6126e15-86fc-4f16-9867-aca6147c8537">
        <source>isBerthageOnContract() : Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ves : CM_Vessel;
	aRes, tmpRes : HMS_Resource;
	move : HMS_VoyageMovement;
	tmpType : HMS_ResourceType;
	vdh :	HMS_VesselDataHarbour;
	rtfm : HMS_ResourceTypeForMovement;
begin
	ves := self.getMyVessel();
	
	if ves = null then
		return false;
	endif;

//ove := self.myHMSVoyageData.getMovementForMoveType($HMSMovementTypeDeparture);
//Res := move.myBerth.myWharf.getResourceForHarbourMovement(move.moveType,HMS_Wharf.First_Resource);
	move := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeArrival);
	aRes := move.getMyWharf.getResourceForHarbourMovement(HMSMovementTypeDeparture,HMS_Wharf.First_Resource);
	
	if aRes = null then
		return false;
	endif;
	
	if aRes.isResourceForClass(HMS_ResourceForWharf) then
		vdh := ves.myHMSVesselData.allVesselDataForHarbour[move.myHarbour];
		if vdh = null then
			return false;
		endif;
		
		rtfm := vdh.allMovementResourcesByMovement[HMSMovementTypeDeparture];
		if rtfm = null then
			return false;
		endif;
		foreach tmpType in rtfm.allResourceTypes do
			if tmpType = aRes.myResourceType then
				return true;
			endif;
		endforeach;
		
	endif;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCancelled" id="5a8b3b79-720c-4577-9417-d94cd9c2667d">
        <source>isCancelled() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
05 October 2021		jlier1	Initial creation TFS 51963
29 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars

begin
	return self.status = Voyage_Status_Cancelled 
		or self.status = Voyage_Status_VoyCancelled
		or self.status = Voyage_Status_EUP_Cancelled
		or self.status = Voyage_Status_EUP_VoyReqRej;
	
epilog

end;</source>
