<Class name="CM_YATypeOutboundShipOperator" id="0137a998-5934-4005-962b-290a306dec89">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>TFS 3285 AAT  Invoicing Tranship Cargo Based on the Operators of both the Inbound and Outbound Voyage</text>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="e41aa939-eecf-40bf-b1cb-d9926b6fdb34">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// TFS 3285
vars

	operator	: CM_Operator;
	failedDAC	: CM_DataAccessController;
	
begin

	foreach operator in app.myRoot.allOperators do

		if not operator.canUserAccessSelf( null, failedDAC, app.myPassport ) 
		or operator.isNotAvailableForEntry 
		then
			// Not normally going to show this one, but if its already there, let it be included.
			if _allDependentObjs = null or not _allDependentObjs.includes( operator ) then
				continue;
			endif;
		endif;
		
		_allCriteriaValues.addNoDuplicates( operator , false );

	endforeach;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="67a98dcb-b839-4f1c-ada6-8eaee5cb61e6">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
// TFS 3285 Invoicing cargo based on inbound and outbound voyage operators
vars

begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;
</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="0af1f7ff-3921-414e-9198-f18ca11ce7e9">
        <source>getDisplay(dataObj: Object): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jun 2017	cnwma1 TFS #4498 JMT - Cargo Allocation Fix Up Export Script

*/

vars

begin
	return dataObj.CM_Operator.code;

epilog

end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="4b6cf720-d5da-4922-afd6-b20f3556a0e7">
        <source>getObjects(objects: ObjectLongNameDict input);
// TFS 3285
vars
	operator: CM_Operator;
begin
	foreach operator in app.myRoot.allOperators do
		objects[operator.getYAIdentifier] := operator;
	endforeach;

end;
</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="938ae329-63f4-411f-a8bf-17d19b315793">
        <source>getTypeName(): String;
// TFS 3285
vars

begin
	return "Outbound Ship Operator";
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="ba8823e2-9d81-4016-871f-dbd5add5c4bf">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// TFS 3285
vars

begin
	return _cmifAutoPlan.isOutboundShipOperator_Match(_yaData);

end;
</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="887c2a79-9225-46fc-b563-772defbddf4a">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
// TFS 3285
vars

begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	if _criteria.myYAData.CM_YADataString.value = _propertyValue or
	   _criteria.myYAData.CM_YADataString.value = null then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
