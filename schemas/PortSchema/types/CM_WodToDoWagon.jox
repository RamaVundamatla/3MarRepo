    <JadeMethod name="getTrains" id="abdd10c7-ef66-4fb1-9cd9-cde5616182d3">
        <source>getTrains(_allTrains: CM_TrainSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	wagon	: CM_Wagon;
	train	: CM_Train;
begin
	
	foreach wagon in self.allWagons discreteLock do
		// Inwards Train
		train := wagon.myTrainInwards;
		if train &lt;&gt; null then
			_allTrains.tryAdd(train);
		endif;
		
		// Outwards Train
		train := wagon.myTrainOutwards;
		if train &lt;&gt; null then
			_allTrains.tryAdd(train);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_allTrains" type="CM_TrainSet" usage="input"/>
    </JadeMethod>
