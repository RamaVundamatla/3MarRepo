    <JadeMethod name="doMnuStops" id="37b29dc5-d628-4b47-88bb-cffa794e10b1">
        <updating/>
        <source>doMnuStops( menuItem : MenuItem input ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/01/2010	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
// 16/06/2010	cnwcs5		par 24342 - new form for maintaining stops
// ---------------------------------------------------------------------------
	
vars
	lTI			: CM_TrackedItem;
begin
	// just maintains the last ti selected
	lTI := menuItem.userObject.CM_TrackedItem;
	
	self.myAssistant.showStopsForm_TI (lTI, null, app.getMyUser.canUpdateStops( self.myTerminal) );	//cnwrd1 par 29440 27.4.2012
	
	return;
/*	app.mousePointer	:= Busy;						// cnwrl1 27/01/2010 PAR 21889
	
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuStops then
		return;
	endif;
	
	// cnwrl1 27/01/2010 PAR 21889 - start of coding
	// NOTE: This reproduces the release 7.7.3 behaviour - ie it only handles the last TrackedItem clicked on.
	create tiSet transient;
	stopsTable	:= app.myRoot.allStopsTable[ menuItem.index ];
	while true do : update_TrackedItems
		self.myAssistant.contextMenuTIsStop( stopsTable, lTI, tiSet );
		
		if app.myPassport.noErrors then
			self.clearErrorWarnings();
			return;
		endif;
		result	:= app.showErrorWarningDialog(	app.getString( EWD_Cannot_Continue, app.getString( HeadingSaved ) ),
												app.myPassport,
												ErrWarnMode_Add + ErrWarnMode_CanAckWarnings );
		if app.myPassport.noErrors and result = IDOK then
			app.myPassport.warningsAcknowledged	:= true;
			continue update_TrackedItems;
		endif;
		self.setAllErrorWarnings( app.myPassport );	// copies errors to this form and shows in err/warnings window
		return;
	endwhile update_TrackedItems;*/
	// cnwrl1 27/01/2010 PAR 21889 - end of coding
	
	/* cnwrl1 28/01/2010 PAR 21889 - what it was
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuStops then
		return;
	endif;
	
	create lStops transient;
	create tiSet transient;
	
	lStops.add(menuItem.index);
//	if lTI.getStopByID(menuItem.index) = null then	// cnwrl1 14/12/2009 PAR 21889 - what it was
	if not lTI.isStopSet( menuItem.index ) then
		tiSet.add( lTI );
		app.myTrxCA.trxCreateStopsForTIs( tiSet, lStops, app.myPassport );
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog(app.getErrorString(Grid_area_formMM), app.myPassport, ErrWarnMode_Add);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	else
//		stopTable := lTI.getStopByIDAsAtDate(menuItem.index).myStopsTable;	// cnwrl1 11/01/2010 PAR 21889 - what it was
		stopTable := lTI.getStopByIDAsAtDate( menuItem.index, null ).myStopsTable;
		if stopTable.requiresInfo then
			self.processStopInfo(lTI, stopTable, lStops);
		else
			app.myTrxDA.trxDeleteStops(lTI, lStops, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog(app.getErrorString(Cargo_Enquiry), app.myPassport, ErrWarnMode_Update);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	endif;
	
	menuItem.checked := not menuItem.checked;
	
epilog
	delete lStops;
	delete tiSet;
	mousePointer := MousePointer_Default;
end;
	cnwrl1 28/01/2010 PAR 21889 - end of what it was */
	
epilog
		
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskAdd" id="67cc933e-e94f-4cdc-bfd6-2b898a240259">
        <updating/>
        <source>doMnuTaskAdd(menuItem : MenuItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lTI	: CM_TrackedItem;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

begin
	if menuItem = mnuTaskAdd then
		return;
	endif;
	
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskAdd(lTI, menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Todo_task_ADDd), app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	//refresh table
	self.displayExtraInfoForObj(lTI);
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskComplete" id="76617521-401e-42cb-ac4a-51e732466417">
        <updating/>
        <source>doMnuTaskComplete(menuItem : MenuItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lTI	: CM_TrackedItem;
	realTiSet : CM_TISet;
	pxyTiSet : CM_TISet;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	toDoTaskDesc : CM_ToDoTaskDesc;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuTaskComplete then
		return;
	endif;
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[menuItem.index];
	
	create realTiSet transient;
	realTiSet.add(lTI);

	//+cnwml2 MSL CCMS 1017
	create pxyTiSet transient;
	
	//31 Dec 2009 NDL CCMS MES 1006	- Common code migrated up to assistant
	if not self.myAssistant.doTaskProxySetForComplete( menuItem.index, pxyTiSet, lTI, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Complete To Do Task', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	//refresh table
	self.displayExtraInfoForObj(lTI);
	
epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskRemoveClick" id="094424b7-dd19-4ad8-ac1c-a147e3f3daca">
        <updating/>
        <source>doMnuTaskRemoveClick(_menuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	lTI		: CM_TrackedItem;
	answer	: Integer;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	lTI := _menuItem.userObject.CM_TrackedItem;
	if lTI = null or 
	   _menuItem = self.mnuTaskRemove then
		return;
	endif;

	answer := app.msgBox(app.getErrorString(TaskRemoveConfirm), app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if answer = MsgBox_Return_No then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskRemove(lTI, _menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Remove_Task), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

	//refresh table
	self.displayExtraInfoForObj(lTI);
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuUnconfirmOutClick" id="61c67fa0-5ec6-4c42-902c-a32daa201ac7">
        <updating/>
        <source>doMnuUnconfirmOutClick(_menuItem : MenuItem) protected, updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	wagon		: CM_Wagon;
	theReturn			: Integer;
begin
	wagon := _menuItem.userObject.CM_Wagon;
	if wagon = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWagonConfirmOut(null, wagon, false, app.myPassport);

		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Outward_wagon_CONFIRMmm), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

end;




</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuUnplanClick" id="96672889-4dd3-4979-8b75-8b35f0caa9ae">
        <updating/>
        <source>doMnuUnplanClick(_menuItem : MenuItem input) updating, protected; 
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _menuItem.helpKeyword = self.UnplanMenu_TypeMain then
		return;
	endif;
	if _menuItem.helpKeyword = self.UnplanMenu_TypeRehandle then
		 return;
	endif;

	if _menuItem.userObject.isKindOf(CM_TrackedItem) then
		if _menuItem.userObject.CM_TrackedItem.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then 
			doUnqueueTI(_menuItem.userObject.CM_TrackedItem);
		else
			doUnplanTI(_menuItem.userObject.CM_TrackedItem,(_menuItem.helpKeyword = "LOAD")); // DO NOT TRANSLATE
		endif;
	elseif _menuItem.userObject.isKindOf(CM_FutureMove) then
		self.doUnqueueTIbyFM(_menuItem.userObject.CM_FutureMove);
	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
