    <JadeMethod name="populateListBox" id="1dbfeebd-a6af-4613-9676-1afe9e204878">
        <updating/>
        <source>populateListBox( _term : CM_Terminal ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation

*/

vars

	selectorQueryAccess : CM_SelectorQueryAccess;
	userQuery : CM_MenuUserQuery;
	index : Integer;
	msg : String;
	entDef : EntTableDef;
	entRow : EntTableRow;
	heading : String;

begin

	if isInPainter then
		return;
	endif;

	self.lstQueries.clear();
	
	selectorQueryAccess := _term.getConfig(GridAreaSelectorSet).CM_SelectorQueryAccess;
	if selectorQueryAccess = null then
		self.lstQueries.addItem( app.getErrorString(NO_Data) );
		self.enabled := false;
		
		entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalSettings];
		if entDef &lt;&gt; null then
			entRow := entDef.getEntTableRow(ETRow_GridAreaSelectorSet);
			if entRow &lt;&gt; null then
				heading := entRow.getHeading(null, null, app.myCurrentLocale);
			endif;
		endif;
		if heading = null then
			heading := "Grid Area Selector Set";
		endif;
		
//		msg := app.getErrorString1( Need_termina_config_first, heading );
//		app.msgBox(msg,app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		
		return;
	endif;
	
	self.enabled := true;
	foreach userQuery in selectorQueryAccess.allSelectedQueries do
		index := self.lstQueries.addItem( userQuery.heading );
		self.lstQueries.itemObject[index] := userQuery;
	endforeach;

epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="refresh" id="946adc34-e2dd-404d-af4a-5e7ca66ffd56">
