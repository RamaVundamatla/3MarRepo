    <JadeMethod name="isAllCRCreditApproved" id="d28b70d8-ff8d-48b0-930b-4b6923a399b2">
        <source>isAllCRCreditApproved():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces

*/

vars
	result : Boolean;
	cashRec : CM_CashReceipt;
begin
	foreach cashRec in self.allCashReceipts do
		
		if cashRec.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED then
			result  := true;
			continue;
		endif;
		result := false;
		return result;
	endforeach;
	
	
	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAllTasksWithStatus" id="f66113b4-b60c-47ad-a577-f89d1a9b6017">
        <source>isAllTasksWithStatus(_taskStatus : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Feb 2023 navma1 ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]

*/

vars
	wod : CM_WorkOrderDtl;
begin
	foreach wod in self.allWoDtls do
		if wod.status &lt;&gt; _taskStatus  then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
