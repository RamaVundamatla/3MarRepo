<Class name="CMIF_WorkOrderAction" id="b017108c-b0a5-4ecc-a408-85ac5d7125f6">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>AllRBTActionValues array should be in step with AllRBTObjects</text>
    <DbClassMap file="workorder"/>
    <CompAttribute name="allRBTActionValues" id="a8c279e1-d317-48f1-bf59-5df8fc3d645c">
