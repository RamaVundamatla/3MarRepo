    <JadeMethod name="setProxy" id="89f00f48-d90b-490d-b080-796961798dca">
        <updating/>
        <source>setProxy(_dtl : CM_KPIVoyageMoveDtl_GC) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2025	navcs2	MTN-36746 MTN | KPI REST APIs - Voyage [1]

*/

vars

begin
	self.area 				:= _dtl.area;
	self.cargoTypeCode		:= _dtl.myCargoType.abbreviation;
	self.cargoTypeDesc		:= _dtl.myCargoType.description;
	self.linearMetres		:= _dtl.linearMetres;
	self.quantity			:= _dtl.quantity;
	self.totalWeight		:= _dtl.totalWeight;
	self.volume				:= _dtl.volume;
epilog

end;</source>
