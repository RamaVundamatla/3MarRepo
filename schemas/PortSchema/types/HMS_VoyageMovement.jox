    <JadeMethod name="isMovementChargeable" id="5693149e-8fee-47fd-b6d3-faab4abcdb66">
        <source>isMovementChargeable(_move : HMS_VoyageMovement) : Boolean;
// ---------------------------------------------------------------------------
// Created:		29 March 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aWharf : HMS_Wharf;
	aRes : HMS_Resource;
begin
	if _move = null then // PAR 14157
		return false;
	endif;
	aWharf := self.getMyBerth().myWharf;
	
	if aWharf = null then
		return false;
	endif;
	aRes := aWharf.getResourceForHarbourMovement(_move.moveType,HMS_Wharf.First_Resource);
	
	return (aRes &lt;&gt; null);
		
end;</source>
