    <JadeMethod name="maBGP1" id="027d45da-c8ed-4064-8138-61f73b16fef1">
        <source>maBGP1();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2020	jlgma1	Initial creation

*/

vars
	bgpRequest : BGP_Request;
	bgpController : BGP_Controller;
begin
	app.initialize();
	app.setIsBackGroundApp(true);
	/*
	foreach bgpController in BGP_ExternalWSController.instances do
		if global.isValidObject(bgpController.myExternalWSDef) and
		   bgpController.myExternalWSDef.isKindOf(CM_OpsViewServiceDef) then
			break;
		endif;
	endforeach;
	*/
	bgpController  := BGP_DeferredChargingController.instances.first.BGP_Controller;
	
	bgpController.initApp();
	bgpRequest 	   := BGP_DeferredChargingRequest.instances.last.BGP_Request;
	process.profiler.methodCount := 50;
	process.profiler.start();
	app.myTrxUA.trxUpdateBGPControllerPre(bgpController, app.actualTimeServer, bgpRequest, app.myPassport);
	app.myBGPObject := bgpController;

	bgpRequest.action();
	process.profiler.stop();
	process.profiler.report();
	app.myTrxUA.trxUpdateBGPControllerPost(bgpController, app.myPassport);
epilog
	app.setIsBackGroundApp(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="maBGPRun" id="37a77dac-6f7c-4e86-bd19-82f0d58ca8c6">
        <source>maBGPRun();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 October 2018	jlgma1	Initial creation

*/

vars
	task			: CM_AutoTask;
	tmpClass		: Class;
	request			: BGP_Request;
	term			: CM_Terminal;
begin

	app.initialize();
/*
	if app.myPassport.myTerminal = null then 
		term := CM_Root.firstInstance.allTerminals['T01'];
		app.myPassport.setMyTerminal(term);
	endif;
*/
	//task := CM_AutoTaskStorageProcessor.firstInstance;	// or any other suitable instance
	/*
	foreach task in CM_AutoTaskSapPerformance.instances do
		//if task.description = "TEST CCMS 1043" then
		if task.description = "MONELT KINERJA" then
			write " found " &amp; task.String;
			break;
		endif;
	endforeach;
	*/
	task := CM_AutoTaskSapTPP.firstInstance;
	write 'Processing task (' &amp; task.description &amp; ')';
	tmpClass := self.getClass(task.requestClassName);
	if tmpClass = null then
		// Class has not been correctly setup.
		write task.requestClassName &amp; ' Request class not found';
		return;
	endif;

	create request as tmpClass transient;
	request.initRequestFromTask(task);
	if process.isInTransactionState then
		commitTransaction;
	endif;

	request.action();

	self.unlock(task);
	write method.name&amp;" completed";	
	
epilog	
	write method.name&amp;" epilog";	
	if task &lt;&gt; null then
		self.unlock(task);
	endif;
	delete request;
end;</source>
    </JadeMethod>
    <JadeMethod name="maCargoChain" id="70407dbb-16f3-4e2e-9823-f15742484cfa">
        <source>maCargoChain();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2019	jlgma1	Initial creation

*/

vars
	term : CM_Terminal;
	ti   : CM_TrackedItem;
	agent : CM_ManualInvoiceLineAgent;
	invLineDesc : CM_InvoiceLineDesc;
	jsonStr :String;
		xml					: JadeXMLDocument;
			jsonHelper			: CMIF_JsonHelper;
			xmlHelper		: CM_XmlHelperAgent;
begin
	app.initialize();
	
	term := app.myRoot.allTerminals["BT01"]; //BT01
	app.setMyTerminal(term);
	
	
	
	if term &lt;&gt; null then
		foreach ti in term.allOnsiteTIsByCargoTypeId discreteLock do
			if ti.externalProfileID = null then
				continue;
			endif;	
			write ti.id &amp; Tab &amp; ti.getOidString &amp; Tab &amp; ti.externalProfileID  &amp; Tab &amp;"****"&amp;  ti.externalProfileSecret;
		endforeach;
	endif;
	
	/*
	ti := "2367.23709444".asOid.CM_TrackedItem;
	create agent transient;
	invLineDesc := agent.getDetails(ti);
	if invLineDesc &lt;&gt; null then
		agent.createInvoiceLine(ti,132.5,invLineDesc);
	endif;
	*/
		create jsonHelper transient;
	create xmlHelper transient;
	create xml transient;

	
	
	//xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(jsonResponse), xml);
	app.finalize();
epilog
	delete agent;
end;</source>
    </JadeMethod>
