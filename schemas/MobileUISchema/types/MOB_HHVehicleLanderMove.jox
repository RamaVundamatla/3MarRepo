    <JadeMethod name="populateTrackedItem" id="65366675-27ae-4678-95a5-124793046650">
        <source>populateTrackedItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	desc1 : String;
	desc2 : String;
	rowIndex : Integer;
	colIndex : Integer;

begin

	if self.myTrackedItem = null then
		self.txtCargoId.text := lblCargoId.caption.toUpper;
		self.txtCargoId.setFocus();
		self.lblCargoType.caption := null;
		self.lblCargoDesc.caption := null;
		self.txtLocation.text := null;
		self.txtLocation.visible := false;
		self.lblNoDamage.visible := false;
		self.tblDamage.visible := false;
		
	else
		self.txtCargoId.text := self.myTrackedItem.id;
		self.myTrackedItem.getShortDescriptions( desc1, desc2 );
		self.lblCargoType.caption := desc1;
		self.lblCargoDesc.caption := desc2;
		
		if self.myTrackedItem.allDamageInstances.isEmpty then
			self.lblNoDamage.visible := true;
			self.tblDamage.visible := false;
		else
			self.lblNoDamage.visible := false;
			self.tblDamage.visible := true;
			self.tblDamage.initCombos(self.myTrackedItem.IF_DamageDetails);
			self.tblDamage.setTableFromDamageInterface(self.myTrackedItem.IF_DamageDetails);
			foreach rowIndex in 2 to self.tblDamage.rows do
				foreach colIndex in 1 to self.tblDamage.columns do
					self.tblDamage.accessCell(rowIndex,colIndex).enabled := false;
				endforeach;
			endforeach;
		endif;
		
		self.txtLocation.visible := true;
		
		//25 May 2016	NDL	TFS 1593
		if self.myTrackedItem.myPrimaryQueuedLocation = null and self.myTrackedItem.myPrimaryPlannedLocation = null then
			self.doAutoPlan();
		endif;
		
		if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
			self.txtLocation.text := app.getErrorString(MOVE_TYPE_Queued) &amp; " - " &amp; self.myTrackedItem.myPrimaryQueuedLocation.getFullId;
		elseif self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then
			self.txtLocation.text := app.getErrorString(MOVE_TYPE_Planned) &amp; " - " &amp; self.myTrackedItem.myPrimaryPlannedLocation.getFullId;
		else
			self.txtLocation.text := self.lblLocation.caption;
		endif;
		
		app.myMobileCargoFindAgent.clearHistory(true);
		
	endif;
	
	self.setButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="a8def010-d575-45d0-8801-40144063a58f">
        <updating/>
        <source>selectCargoItem( manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	trackedItems : CM_TIArray;	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;	
	location: CM_LocationsController;
	
begin

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;

	if self.myTrackedItem &lt;&gt; null then
		if self.myTrackedItem.id &lt;&gt; cargoId then
			self.myMobileGenericAgent.setSplitValues( 0, 0, null );
		endif;
	endif;

	self.setMyTrackedItem(	null );	
	self.lblCargoType.caption := null;
	self.lblCargoDesc.caption := null;	
	
	term := self.myMobileDataAgent.myTerminal;
	voyage := self.myMobileGenericAgent.myVoyage;
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;	
		
		firstTi := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then
			iter := voyage.allOnshipTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	
		//Try reverse 'cargoId' as any piece of the id
		if tiArray.isEmpty then
			firstTi := voyage.allOnshipTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
			if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
				iter := voyage.allOnshipTIsByIdCargoTypeRev.createIterator;
				iter.startAtObject(firstTi);
				while iter.next( ti ) do
					if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
						break;
					endif;
					tiArray.addExclusive(ti);
				endwhile;
				delete iter;
			endif;
		endif;
			
		if tiArray.isEmpty then
			
			self.findTIsInMyWorkPoint(cargoId,tiArray);
			
		endif;
		
	endif;
		
	if not manual and tiArray.isEmpty then
		return;
		
	elseif tiArray.size = 1 then
		self.setMyTrackedItem(	tiArray.first );	
		populateTrackedItem();
		return;
		
	else
		// more than one found.
		app.myMobileCargoFindAgent.setMyVoyage( self.myMobileGenericAgent.myVoyage );
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setStringField1( self.txtLocation.text );
		app.myMobileCargoFindAgent.setDoSearchImmediate(true);
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSHIP);
		
	
		self.myMobileGenericAgent.setMyNextTiToAction(null);
		self.getSessionAgent().setMySelectedTI( null );
		self.gotoForm( MOB_HHCargoFind, false );
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete trackedItems;
	delete revDict;

end;</source>
        <Parameter name="manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setButtons" id="5d9c2740-5e66-4538-8886-527d49e1bf08">
        <source>setButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation

*/

vars

	plannedLc : CM_LocationsController;
	isAtWorkPoint : Boolean;
	isPlannedToYard : Boolean;
	isOnShip : Boolean;

begin

	self.btnLabel.caption := app.getErrorString(Heading_Label);
	self.btnDamage.caption := app.getErrorString(Damage);
	self.btnDirty.visible := true;	//26 May 2016	NDL	TFS 1593

	if self.myTrackedItem = null then
		self.btnOne.enabled := false;
		self.btnTwo.enabled := false;
		self.btnDamage.enabled := false;
		self.btnDirty.enabled := false;
		self.btnLabel.enabled := false;
		return;
	endif;
	
	isOnShip := ( self.myTrackedItem.myPrimaryActualLocation &lt;&gt; null and self.myTrackedItem.myPrimaryActualLocation.isVoyageController );
	isAtWorkPoint := ( self.myTrackedItem.myPrimaryActualLocation = here );
	
	plannedLc := self.myTrackedItem.myPrimaryQueuedLocation;
	if plannedLc = null then
		plannedLc := self.myTrackedItem.myPrimaryPlannedLocation;
	endif;
	isPlannedToYard := ( plannedLc &lt;&gt; null and plannedLc.isYardLocation );

//	self.btnOne.enabled := ( isAtWorkPoint and isPlannedToYard );	// Complete allowed if - Has to be in the workpoint and planned to the yard
	self.btnOne.enabled := isPlannedToYard;	// New rules 25 May 2016	NDL TFS 1593
	self.btnTwo.enabled := ( isOnShip or not isPlannedToYard );	// Process allowed if - still on the ship or not planned to the yard.
	
	self.btnDirty.enabled := self.showDirtyButton();
//	self.btnDamage.enabled := not self.btnOne.enabled;
	self.btnDamage.enabled :=true;		// New rules 25 May 2016	NDL TFS 1593
	self.btnLabel.enabled := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="1d4ebeef-0178-4a20-8826-60f6644def1c">
