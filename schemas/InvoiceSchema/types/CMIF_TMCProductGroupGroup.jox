    <JadeMethod name="getPicture" id="067334f1-8e0d-48fd-a6bb-939b94ef407d">
        <source>getPicture(form: INV_TransactionMap): Picture;

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picProdGroup;

end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="getRealMapObject" id="5ae992f2-8c36-48c2-8a97-4e2538d75a6a">
