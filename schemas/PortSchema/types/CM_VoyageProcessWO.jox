    <JadeMethod name="getInvoiceReportForInvoice" id="ae97bed4-83a8-4967-a699-5b2b89da5995">
        <source>getInvoiceReportForInvoice(_invoice: CM_Invoice): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
xx October 2018		cnwab1	Initial creation TFS 41539	
15 September 2021	jlizm1	TFS 51963 SAL Voyage Request Changes - copied method from voyageProcessPEL1

*/

vars

begin
	if _invoice = null then
		return "";
	endif;
	
	if _invoice.status = CM_Invoice.INVOICE_PREPEND then
		return self.reportInvoicePreinvoice;
	endif;

	
	if _invoice.status.isOneOf(CM_Invoice.INVOICE_PENDING, CM_Invoice.INVOICE_POSTED) then
		return self.reportInvoiceTaxinvoice;
	endif;

	return "";
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceReportForStatus" id="bcb6027c-4a34-46c0-95b3-c8c4972dd97e">
        <source>getInvoiceReportForStatus(_voyage: CM_Voyage): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
14 May 2018		jlger1	Initial creation 38530
11/09/2018		jlgdap1	TFS 40030 PEL1 Multiple Estimates and Invoices
15/09/2021		jlizm1	TFS 51963 SAL Voyage Request Changes - copied method from VoyageProcessPEL1
*/

vars
	currentStatus : Integer;
begin
	if _voyage &lt;&gt; null then															// TFS 38214
		currentStatus := _voyage.status;											// TFS 38214
	endif;																			// TFS 38214
	
	if currentStatus = null then
		return null;
	
	endif;
	
	if currentStatus = Voyage_Status_InitSerRequested or currentStatus = Voyage_Status_CargoRequested then		// TFS 40030
		return self.reportInvoiceEstimate;
		
	elseif currentStatus = Voyage_Status_CargoPreInvGen or currentStatus = Voyage_Status_ServPreInvGen  then
		return self.reportInvoicePreinvoice;
		
	elseif currentStatus = Voyage_Status_CargoTaxInvGen or currentStatus =Voyage_Status_ServTaxInvGen then
		return self.reportInvoiceTaxinvoice;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextValidStatuses" id="fbbe72d2-3988-41b0-8f2c-c1fd2318bdbe">
        <source>getNextValidStatuses(_voyage: CM_Voyage; _nextStatuses: CM_VoyageStatusByPriority input; _includeAll: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16/03/2018			jlgdap1	Initial creation TFS 37540 PEL1 Voyage Statuses Pelindo 1
11/04/2018			jlgdap1	TFS 37966 new Vessel Archived status
23/04/2018			jlgdap1	TFS 38214 PEL1 Voyage Status Changes
06/06/2018			jlgdap1	TFS 38851 PEL1 Voyage Statuses for INAPORTNET
28/06/2018			jlgdap1	TFS 39303 PEL1 Voyage Status Additional Potential Status
08/08/2019			jlgka1	TFS 45921 PEL1 - Cannot make IMSR after Completing WO Permit Request - Manual Etmal IMSR
15/09/2021			jlizm1	TFS 51963 SAL Voyage Request Changes - copied method from VoyageProcessPEL1

*/
vars
	status, nextStatus : CM_VoyageStatus;
	currentStatus : Integer;						// TFS 38214

begin

	if _includeAll then	//21 Jun 2018	NDL	TFS 39216
		self.allStatuses.copy(_nextStatuses);
		//jlgka1 TFS 45921 --&gt;
		if _voyage = null then	
			return;
		endif;
		//jlgka1 TFS 45921 &lt;--
		if _voyage.myHMSVoyageData = null or _voyage.myHMSVoyageData.myHarbour = null then		// 2/9/19 MAP TFS45926
			//remove statius to do with harbour 
			_nextStatuses.remove(self.allStatusesById[Voyage_Status_ServicesPending]);
			_nextStatuses.remove(self.allStatusesById[Voyage_Status_InitSerRequested]);
			_nextStatuses.remove(self.allStatusesById[Voyage_Status_ApprovalPending]);
			_nextStatuses.remove(self.allStatusesById[Voyage_Status_ApprovalRejected]);
		endif;
		
		return;
	endif;
	
	if _voyage &lt;&gt; null then															// TFS 38214
		currentStatus := _voyage.status;											// TFS 38214
	endif;																			// TFS 38214
	
	if currentStatus = null then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyRequested]);
	else
		if app.myRoot.allVoyageStatuses[currentStatus] &lt;&gt; null then
			_nextStatuses.add(app.myRoot.allVoyageStatuses[currentStatus]);
		endif;
	endif;
	
	if currentStatus = Voyage_Status_VoyRequested then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyReqSubmitted]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyReqRejected]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_CargoReqPending]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_VoyReqSubmitted then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyReqRejected]);
		// TFS 38214 If the voyage has no Holds then there is no cargo
		// - next status is ServicesPending	not CargoReqPending	
		if _voyage &lt;&gt; null and _voyage.myGeneralCargoVoyage = null then	
			if _voyage.myHMSVoyageData = null then
				_nextStatuses.add(self.allStatusesById[Voyage_Status_ApprovalPending]);
			else
				_nextStatuses.add(self.allStatusesById[Voyage_Status_ServicesPending]);
			endif;
		else
			_nextStatuses.add(self.allStatusesById[Voyage_Status_CargoReqPending]);
		endif;
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_VoyReqRejected then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_CargoReqPending]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_CargoReqPending then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_CargoRequested]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_CargoRequested then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_CargoReqRejected]);
		if _voyage.myHMSVoyageData = null then
			_nextStatuses.add(self.allStatusesById[Voyage_Status_ApprovalPending]);
		else
			_nextStatuses.add(self.allStatusesById[Voyage_Status_ServicesPending]);
		endif;
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_CargoReqRejected then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ServicesPending]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_ServicesPending then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_InitSerRequested]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_CargoReqPending]);			// TFS 39303
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_InitSerRequested then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ApprovalPending]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ApprovalRejected]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_ApprovalPending then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyageApproved]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_ApprovalRejected then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ApprovalPending]);
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyCancelled]);	//02 Aug 2018	NDL	TFS 39924
		
	elseif currentStatus = Voyage_Status_VoyageApproved then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VoyageArrived]);
		
	elseif currentStatus = Voyage_Status_VoyageArrived then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_CargoPreInvGen]);
		
	elseif currentStatus = Voyage_Status_CargoPreInvGen then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_CargoTaxInvGen]);
		
	elseif currentStatus = Voyage_Status_CargoTaxInvGen then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_DepServPending]);
		
	elseif currentStatus = Voyage_Status_DepServPending then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_DepServRequested]);
		
	elseif currentStatus = Voyage_Status_DepServRequested then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_DepServApproved]);
		
	elseif currentStatus = Voyage_Status_DepServApproved then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ServPreInvGen]);
		
	elseif currentStatus = Voyage_Status_ServPreInvGen then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_ServTaxInvGen]);
		
	elseif currentStatus = Voyage_Status_ServTaxInvGen then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VesselDeparted]);
		
	elseif currentStatus = Voyage_Status_VesselDeparted then
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VesselArchived]);
		
	elseif currentStatus = Voyage_Status_VoyCancelled then	//02 Aug 2018	NDL	TFS 39924
		_nextStatuses.add(self.allStatusesById[Voyage_Status_VesselArchived]);
		
	endif;
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_nextStatuses" type="CM_VoyageStatusByPriority" usage="input"/>
        <Parameter name="_includeAll" type="Boolean"/>
    </JadeMethod>
