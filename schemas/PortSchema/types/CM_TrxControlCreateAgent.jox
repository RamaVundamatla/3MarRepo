    <JadeMethod name="trxCreateInvoiceWeb" id="821dabd5-ae27-4c11-a04d-e642b32dd03c">
        <updating/>
        <source>trxCreateInvoiceWeb(_proxyInvoice:CM_Invoice input; _newInvoice:CM_Invoice output; _pxyInvoiceLines: CM_InvoiceLineSet input; _passport : CM_Passport input) updating;
/*

Purpose:		

	TRX method to create a new TAS invoice by calling the UTL

Parameters:			

	pProxyInvoice 	: The proxy invoice to set the values for the real invoice
	pNewInvoice		: The new real invoice to be set and created from the proxy invoice
	_passport		: The passport

Return Value:	

	None

Date		Who		Reason
07/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes

*/

vars
	pxyInvoiceLine,
	realInvoiceLine	: CM_InvoiceLine;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateInvoiceWeb(_proxyInvoice, _newInvoice, _passport);
	foreach pxyInvoiceLine in _pxyInvoiceLines do
		pxyInvoiceLine.setInvoice(_newInvoice);
		app.myUtilityCA.utlCreateInvoiceLineWeb(pxyInvoiceLine, realInvoiceLine, _passport);
	endforeach;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyInvoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_newInvoice" type="CM_Invoice" usage="output"/>
        <Parameter name="_pxyInvoiceLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
