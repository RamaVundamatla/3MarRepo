    <JadeMethod name="getMoveTypeDescr" id="346a702c-b033-4e8d-8a50-2cc1149a0a43">
        <source>getMoveTypeDescr() : String;
/* ---------------------------------------------------------------------------
Created:     08 July 2010 by cnwrs2

