<Class name="ParentClass" id="9ca1db41-2f26-4be7-907f-8ac2523e96fa">
    <superclass name="PersistentModel"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="testlocking"/>
    <ExplicitInverseRef name="allChildren" id="43b186f3-91c7-46d0-90db-2a146b125c84">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="ChildClassArray"/>
        <Inverse name="ChildClass::myParent"/>
    </ExplicitInverseRef>
    <PrimAttribute name="name" id="f8a02297-52cc-42e9-b895-7209e21fea16">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="create" id="9e0ebcca-89a3-4998-bc83-df1fc955910e">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	f				: Form;
	
begin
	f := app.activeForm();
	if f &lt;&gt; null then
		f.logMsg(method.qualifiedName &amp; " " &amp; self.String &amp; " created");
	else
		self.logMsg(method.qualifiedName &amp; " " &amp; self.String &amp; " created");
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="72878d81-b81a-407f-878d-4340015db45f">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	f				: Form;
	
begin
	f := app.activeForm();
	if f &lt;&gt; null then
		f.logMsg(method.qualifiedName &amp; " " &amp; self.String &amp; " deleted");
	else
		self.logMsg(method.qualifiedName &amp; " " &amp; self.String &amp; " deleted");
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDescription" id="9192980c-f164-45d7-9d1f-034707aa3aa7">
        <source>getDescription() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	s				: String;
	children		: ChildClassArray;
	child			: ChildClass;
	invalid			: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, child, invalid);
//	children := self.allChildren.cloneSelf(true);
//	foreach child in self.allChildren discreteLock do
	child := self.allChildren.first();
	if child &lt;&gt; null then
		s := s &amp; ", " &amp; child.name;
	endif;
//	endforeach;
	
	return self.name &amp; s;
	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionIsValidObj" id="97feb176-acae-44f4-98ad-9cf53050b29d">
        <source>getDescriptionIsValidObj() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	s				: String;
	children		: ChildClassArray;
	child			: ChildClass;
	invalid			: Boolean;
	
begin
	children := self.allChildren.cloneSelf(true);
	foreach child in children where app.isValidObject(child) do
		s := s &amp; ", " &amp; child.name;
	endforeach;
	
	return self.name &amp; s;
	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
