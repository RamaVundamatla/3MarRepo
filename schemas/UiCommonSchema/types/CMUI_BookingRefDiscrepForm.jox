    <JadeMethod name="doQuery" id="e2c5b841-e81a-40cf-9981-5ae64fb248b4">
        <updating/>
        <source>doQuery() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/09/2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
27/10/2011	cnwdap1	PAR #28524 CCMS POL 2096 Added "Closed" filter to searcher
// 16 Feb 2018	jlgrs1	TFS 37036 Booking Discrepancy Query does not filter the state correctly
*/

vars

	filterCargoType : CM_CargoType;
	filterVoyage : CM_Voyage;
	filterOperator : CM_Operator;
	filterBookingRef : String;
	filterCargoId : String;
	filterDateFrom : Date;
	filterDateTo : Date;
	filterStatus : String;
	filterUser : CM_User;
	filterIgnoreClosed : Boolean;			// PAR #28524
	
	iter : Iterator;
	firstObject : CM_EventTransaction;
	event : CM_EventTransaction;
	booking : CMEVT_BookingRefDiscrep;
	checkEventType : Boolean;
	rowIdx : Integer;
	coll : CM_EventTransactionSet;
	ti : CM_TrackedItem;
	
begin

	self.myCMEVT_BookingRefDiscrep := null;
	self.tblData.allSelectedObjects.clear;
	self.allTableObjects.clear();
	self.tblData.rows := self.tblData.fixedRows;
	
	inheritMethod();
	
	if not self.frmQuery.visible then
		return;
	endif;
	
	filterCargoType := self.cmbCargoType.listObject.CM_CargoType;
	filterVoyage := self.cmbVoyage.listObject.CM_Voyage;
	filterOperator := self.cmbOperator.listObject.CM_Operator;
	//filterBookingRef := self.tblSearcher.getValueByName(ETRow_BookingRef).String.toUpper.trimBlanks;
	filterBookingRef := self.tblSearcher.getValueByName(ETRow_Booking).String.toUpper.trimBlanks;	//PAR 21578 Nov 2009
	filterCargoId := self.tblSearcher.getValueByName(ETRow_CargoId).String.toUpper.trimBlanks;
	filterDateFrom := self.tblSearcher.getValueByName(ETRow_DateFrom).Date;
	filterDateTo := self.tblSearcher.getValueByName(ETRow_DateTo).Date;
	filterStatus := self.cmbStatus.text.trimBlanks;
	filterUser := self.cmbUser.listObject.CM_User;
	filterIgnoreClosed := self.tblSearcher.getValueByName(ETRow_IgnoreClosed).Boolean;		// PAR #28524

	if not self.passedInTrackedItems.isEmpty then
		create coll transient;
		foreach ti in self.passedInTrackedItems do
			foreach booking in ti.allBookingRefDiscreps do
				coll.add(booking);
			endforeach;
		endforeach;
		iter := coll.createIterator;
		
	elseif self.myCM_BookingRef &lt;&gt; null then
		iter := self.myCM_BookingRef.allBookingRefDiscreps.createIterator;
		
	elseif self.myTerminal &lt;&gt; null then
		iter := self.myTerminal.allEventsByTypeDateTime.createIterator;
		firstObject := self.myTerminal.allEventsByTypeDateTime.getAtKeyGeq(EVT_BookingRefDiscrep,filterDateFrom.TimeStamp);
		if firstObject = null or firstObject.myEventType.type &lt;&gt; EVT_BookingRefDiscrep then
			return;
		endif;
		iter.startAtObject(firstObject);
		checkEventType := true;
	else
		iter := app.myRoot.allEventsByTypeDateTime.createIterator;
		firstObject := app.myRoot.allEventsByTypeDateTime.getAtKeyGeq(EVT_BookingRefDiscrep,filterDateFrom.TimeStamp);
		if firstObject = null or firstObject.myEventType.type &lt;&gt; EVT_BookingRefDiscrep then
			return;
		endif;
		iter.startAtObject(firstObject);
		checkEventType := true;
	endif;
	
	while iter.next(event) do
		if checkEventType then
			if event.myEventType.type &lt;&gt; EVT_BookingRefDiscrep then
				break;
			endif;
		endif;
		booking := event.CMEVT_BookingRefDiscrep;
		
		if filterVoyage &lt;&gt; null then
			if not booking.isForVoyage(filterVoyage) then
				continue;
			endif;
		endif;
		if filterOperator &lt;&gt; null then
			if not booking.isForOperator(filterOperator) then
				continue;
			endif;
		endif;
		if filterCargoType &lt;&gt; null then
		//	if booking.getValueFromBookingRef(booking.myBookingRef, null, ETRow_CargoType) &lt;&gt; filterCargoType.description then
			if not booking.isForCargoType(filterCargoType) then
				continue;
			endif;
		endif;
		if filterBookingRef &lt;&gt; null then
			if not booking.hasBookingRef( filterBookingRef ) then
				continue;
			endif;
		endif;
		if filterCargoId &lt;&gt; null then
			if not booking.hasCargoId( filterCargoId ) then
				continue;
			endif;
		endif;
		if filterDateFrom.isValid then
			if booking.dateTime.Date &lt; filterDateFrom then
				continue;
			endif;
		endif;
		if filterDateTo.isValid then
			if booking.dateTime.Date &gt; filterDateTo then
				continue;
			endif;
		endif;
		if filterStatus &lt;&gt; null then
			if booking.getStateString &lt;&gt; filterStatus then
				continue;
			endif;
		endif;
		if filterUser &lt;&gt; null then
			if booking.userCode &lt;&gt; filterUser.code then
				continue;
			endif;
		endif;
		if filterIgnoreClosed and booking.isClosed then	// PAR #28524
			continue;									// PAR #28524
		endif;											// PAR #28524
	
		// 18/12/2013 cnwar2 #33120
		if booking.myTrackedItem &lt;&gt; null and booking.myTrackedItem.isChild then
			continue;
		endif;
	
		self.tblDataAddItem( booking );
		
	endwhile;
	
	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.frmQuery.visible := false;
	else
		// no data has been found, check reason
		if filterOperator &lt;&gt; null then
			self.validateOperatorSetup(filterOperator);
		elseif self.myCM_BookingRef &lt;&gt; null then
			self.validateOperatorSetup(self.myCM_BookingRef.myOperator);
		endif;
	endif;

epilog

	self.resetButtons();
	delete iter;
	delete coll;
	
end;</source>
    </JadeMethod>
