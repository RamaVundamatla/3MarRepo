    <JadeMethod name="mnuFileOpenCurrent_click" id="661c6447-90bc-4a1e-b303-5981c8d7b363">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileOpenCurrent_click(menuItem: MenuItem input) updating;

vars
	errNo, result : Integer;
	errTxt : String;
	
begin
	if not self.isLastSaveFileTypeValid then
		app.msgBox("The most recently saved filename is of an unknown type." &amp; CrLf &amp;
			CrLf &amp; "It cannot be opened automatically from the controller.", "Cannot Open",
			MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
	
	if app.isUnicode then
		result := call winShellExecuteW(self.hwnd, "open", self.lastSaveFileName, null, null, 1);
	else
		result := call winShellExecuteA(self.hwnd, "open", self.lastSaveFileName, null, null, 1);
	endif;

	if errNo &lt;&gt; 0 then
		app.msgBox("Error opening file: " &amp; self.lastSaveFileName &amp; CrLf &amp; CrLf &amp;
			'[' &amp; errNo.String &amp; "] " &amp; errTxt, "Error Opening File",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if result &lt;= 32 then
		app.msgBox("Error opening file: " &amp; self.lastSaveFileName &amp; CrLf &amp; CrLf &amp;
			"Windows error code: " &amp; result.String, "Error Opening File",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
