	endif;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getInvUnitsUsed" id="056438a2-c97d-43f0-8dd8-30a2f3fb3e00">
        <source>getInvUnitsUsed(): Real;
/*

Purpose:			TFS 39237

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2018	jlgab1	Initial creation

