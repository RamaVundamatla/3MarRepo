    <JadeMethod name="updateRailRakeArea" id="8e440477-6e97-485b-bc66-08006661577e">
        <updating/>
        <source>updateRailRakeArea(_rail : CM_Rail)updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
