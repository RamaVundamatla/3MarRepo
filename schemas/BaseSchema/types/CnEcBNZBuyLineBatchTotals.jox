    <DbClassMap file="basemsg"/>
    <JadeMethod name="buildMessage" id="3b9679be-8c7b-4948-8b7a-83b1ed47f125">
        <source>buildMessage(pMessage: String io): String;

vars
	errorMessage	: String;
	
begin
	errorMessage := self.checkData();
	
	if errorMessage &lt;&gt; "" then
		return errorMessage;
	endif;
	
	pMessage := self.messType &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.oPSId.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.settleNum.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.password;
	
	return null;
end;</source>
        <Parameter name="pMessage" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkData" id="c5b5c213-e397-4a9b-a1b6-01a0476683d0">
        <source>checkData(): String;

vars
	errorMessage : String;
	
begin
	errorMessage := errorMessage &amp; checkOPSId();
	errorMessage := errorMessage &amp; checkSettleNum();
	errorMessage := errorMessage &amp; checkPassword();
epilog
	return errorMessage;	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="a6ccc604-693c-4f50-b5ea-952b3c6dde7c">
        <updating/>
        <source>create() updating;

begin
	self.messType := "T";
	
	self.setMyMgr();
	self.setOPSId();
	self.setPassword();
	self.setSettleNumber();
end;</source>
    </JadeMethod>
    <JadeMethod name="getTrxString" id="20305a29-8553-4cee-b663-4cb5f10c3143">
        <source>getTrxString(): String;

begin
	return "Batch Totals";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
