    <JadeMethod name="initializeForActivityPrefix" id="1b02a725-4c6b-4a62-89d6-0947178209a7">
        <updating/>
        <source>initializeForActivityPrefix(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables; _prefix : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2022	navsp1	Initial creation TFS#53569

*/

vars
	n4TrainVisit	: CMIF_RailTrainVisitDetails;
	visitDetails : CMIF_ArgoVisitDetails;
	carrierVisit : CMIF_ArgoCarrierVisit;

begin
	if _opsViewTable.isKindOf(CMIF_ArgoVisitDetails) then
		visitDetails := _opsViewTable.CMIF_ArgoVisitDetails;
		
		visitDetails.tableName := visitDetails.Argo_visit_details;
		visitDetails.gkey := visitDetails.generateFullGKey(self,_prefix);
		visitDetails.eta := self.scheduledArrivalDT.asEpochFormat();
		visitDetails.etd := self.scheduledDepartureDT.asEpochFormat();
		visitDetails.service := visitDetails.generateFullGKey(self.myCarrier, "");
		
	
	elseif _opsViewTable.isKindOf(CMIF_ArgoCarrierVisit) then
		carrierVisit :=  _opsViewTable.CMIF_ArgoCarrierVisit;

		carrierVisit.tableName := carrierVisit.Argo_carrier_visit;
		carrierVisit.gkey := carrierVisit.generateFullGKey(self, _prefix);
		carrierVisit.cvcvd_gkey := carrierVisit.generateFullGKey(self,_prefix);
		
		if self.hasDeparted() then
			carrierVisit.atd := self.departureDT.asEpochFormat();
		else
			carrierVisit.atd := null;
		endif;
		
		if self.hasArrived() then
			carrierVisit.ata := self.arrivalDT.asEpochFormat();
		else
			carrierVisit.ata := null;
		endif;
		
		carrierVisit.carrier_mode  := carrierVisit.Carrier_mode_Train;
		carrierVisit.cpx_gkey := carrierVisit.generateCpxGKey();
		carrierVisit.fcy_gkey := carrierVisit.generateFullGKey(self.myTerminal, "");
		carrierVisit.id  := self.code &amp; _prefix;
		carrierVisit.operator_gkey := carrierVisit.generateFullGKey(self.myCarrier, "");
		carrierVisit.phase := carrierVisit.n4TrainStatus(self, (_prefix = CMIF_OpsViewTables.Prefix_Inbound));
	
		// VISIT DETAILS
		create visitDetails transient;
		visitDetails.termOid := carrierVisit.termOid;
		visitDetails.oid := carrierVisit.oid;
			
		self.initializeForActivityPrefix(_ewsOpsView, visitDetails, _prefix); 
		carrierVisit.argoVisitDetails := visitDetails;
		
		// TRAIN VISIT DETAILS
		create n4TrainVisit transient;
		n4TrainVisit.termOid := carrierVisit.termOid;
		n4TrainVisit.oid := carrierVisit.oid;

		self.initializeForActivityPrefix(_ewsOpsView, n4TrainVisit, _prefix); 
		carrierVisit.railTrainVisitDetails := n4TrainVisit; 
		
	elseif _opsViewTable.isKindOf(CMIF_RailTrainVisitDetails) then
		n4TrainVisit				:= _opsViewTable.CMIF_RailTrainVisitDetails;

		n4TrainVisit.tableName := n4TrainVisit.Rail_train_visit_details;
		n4TrainVisit.gkey 			:= n4TrainVisit.generateFullGKey(self, _prefix);
		if _prefix = CMIF_OpsViewTables.Prefix_Inbound then
			n4TrainVisit.direction	:= CMIF_OpsViewTables.Train_Direction_In;
		elseif _prefix = CMIF_OpsViewTables.Prefix_Outbound then
			n4TrainVisit.direction	:= CMIF_OpsViewTables.Train_Direction_Out;
		else
			n4TrainVisit.direction	:= CMIF_OpsViewTables.Train_Direction_In;
		endif;
		n4TrainVisit.name 			:= self.code &amp; _prefix;
		
		if self.cargoExchangeEndTS.isValid() then
			n4TrainVisit.end_work	:= self.cargoExchangeEndTS.asEpochFormat();
		else
			n4TrainVisit.end_work	:= self.departureDT.asEpochFormat();
		endif;
		n4TrainVisit.max_length_cm 	:= 9999999999; // MTN does not have a max length		
		n4TrainVisit.max_weight_kg	:= self.maxWeight;
		n4TrainVisit.rr_gkey 		:= n4TrainVisit.generateFullGKey(self,"");
		if self.cargoExchangeStartTS.isValid() then
			n4TrainVisit.start_work := self.cargoExchangeStartTS.asEpochFormat();
		else
			n4TrainVisit.start_work := self.arrivalDT.asEpochFormat();
		endif;
		n4TrainVisit.track 			:= "";//Empty in mapperTrain()
		
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
        <Parameter name="_prefix" type="String"/>
    </JadeMethod>
    <JadeMethod name="isBeingWorked" id="34fd8881-d36f-4428-9e61-9e5ed6e6520e">
        <source>isBeingWorked() : Boolean;
// ---------------------------------------------------------------------------
// Created:     06 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tis : CM_TIArray;
	theTI : CM_TrackedItem;
	job : CM_Job;
begin
	create tis transient;
	
	self.getAllTrackedItems(true, tis);
	foreach theTI in tis discreteLock do
		job := theTI.jobRailReceive;
		if job &lt;&gt; null and job.isJobComplete() then
			return true;
		endif;
	endforeach;

	self.getAllTrackedItems(false, tis);
	foreach theTI in tis discreteLock do
		job := theTI.jobRailReceive;
		if job &lt;&gt; null and job.isJobComplete() then
			return true;
		endif;
	endforeach;
	
	return false;
epilog
	delete tis;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isComplete" id="cccffbfe-8389-45be-a5c1-a959d8417226">
        <source>isComplete(_inwards : Boolean) : Boolean;
/*
Purpose:			

Date		Who		Reason
10 December 2021	navab1	TFS 51853
### TFS 52914 02MAR2022 NAVAB1 changed to use WLEs, the train's job sheet has no jobs
*/

vars
	job : CM_Job;
	hasWorked, hasNonWorked : Boolean;
	wagon : CM_Wagon;
	wle : CM_WorkListEntry;
	wagonarray : CM_WagonArray;
begin

	if _inwards then
		wagonarray := self.allWagonsByOrderInward;
	else
		wagonarray := self.allWagonsByOrderOutward;

	endif;

	foreach wagon in wagonarray discreteLock do
		foreach job in wagon.allRailJobs discreteLock do
			foreach wle in job.workListEntries discreteLock do
				if wle.status = WLE_UNACTIONED then
					hasNonWorked := true;
				elseif wle.status = WLE_PART_COMPLETE
				or wle.status = WLE_COMPLETED then
					hasWorked := true;
				endif;
			endforeach;
		endforeach;
	endforeach;

	return (not hasNonWorked and hasWorked);
epilog

end;</source>
        <Parameter name="_inwards" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCompletelyConfirmed" id="8e0e964a-24f5-4cf2-bab2-3f812a010339">
        <source>isCompletelyConfirmed(_outwards : Boolean) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagon 	: CM_Wagon;
begin

	if not _outwards then
		// inwards
		foreach wagon in self.allWagonsByIdInward discreteLock do
			if (not wagon.confirmed) then
				return false;
			endif;
		endforeach;
		
	elseif _outwards then
		//outwards
		foreach wagon in self.allWagonsByIdOutward discreteLock do
			if (not wagon.confirmedOutwards) then
				return false;
			endif;
		endforeach;
		
	endif;

	return true;

end;



</source>
        <Parameter name="_outwards" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
