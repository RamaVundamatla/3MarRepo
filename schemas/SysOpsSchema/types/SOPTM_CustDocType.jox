    <JadeMethod name="doDelete" id="9d47a4ae-65a2-4a02-8e4f-83044cc56300">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
/*
Purpose:			

Date		Who		Reason
04 August 2023	navab1	CR 56093 TASK 59625
*/

vars
	theForm 				: SOP_TableMaintForm;
	term : CM_Terminal;
begin
	theForm := self.myForm;
	term := theForm.myTerminal;
	app.myTrxDA.trxDeleteCustDocType(pObj.CM_CustomDocumentType , app.myPassport);
	if app.myPassport.trxCompletedOK then
		// remove doc type from available doc types
		self.setupMultiSelect3("Next Document Types",term.allCustomDocumentTypes,SOP_TableMaintForm::displayEntryCustDocType.name);
	endif;
epilog

end;</source>
        <Parameter name="pObj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="82261a86-d570-4645-bfa8-7139d3b8d56f">
        <updating/>
        <source>doSave(): Boolean updating;
/*
Purpose:			

Date		Who		Reason
04 August 2023	navab1	CR 56093 TASK 59625
01/09/2023	navkc1	CR 59937 Task 59939: UI - Cust Doc Mandatory Fields
05/09/2023	navkc1	CR 60156  Task 60157: UI - Cust Doc Type Colour
10 September 2023 navmv20 Bug 61351: Custom Document Type - Editing "Direction" Field Throws Exception
*/

vars
	theForm 				: SOP_TableMaintForm;
	tbl						: CM_EntryTable;
	code,
	description			    : String;
	categoryContext			: Integer;
	pxyCustDocType,
	realCustDocType		: CM_CustomDocumentType;
	terminal				: CM_Terminal;
	hasAuto, nafe				: Boolean;
	term : CM_Terminal;
	theResult : Integer;
	stopsApply, stopsClear : CM_StopsTableSet;
	docTypes : CM_CustomDocumentTypeByCode;
	custLic : CM_CustomLicenseByCode;
	etrows			: ObjectArray;
	etrow			: EntTableRow;
	mandatoryAttr	: StringArray;
	colour			: Integer;
	direction,
	index			: Integer; //10/11/2023 navmv20 Bug 61351
begin
	theForm := self.myForm;
	tbl := theForm.tblInput1;
	term := theForm.myTerminal;
	
	code := tbl.getValueByName(ETRow_Code).String;
	description := tbl.getValueByName(ETRow_Description).String;
	terminal	    := self.myForm.myTerminal;
	hasAuto		:= tbl.getValueByName(ETRow_HasAutoId).Boolean;
	nafe		:= tbl.getValueByName(ETRow_Nafe).Boolean;
	colour		:= tbl.getValueByName(ETRow_Colour).Integer; //05/09/2023	navkc1	CR 60156  Task 60157
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_CustomDocumentType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object null for update');
			return false;
		endif;
	endif;
	
	
	create docTypes transient;
	theForm.mulSelect3.getSelected(docTypes);
	
	create stopsApply transient;
	theForm.mulSelect2.getSelected(stopsApply);
	
	create stopsClear transient;
	theForm.mulSelect1.getSelected(stopsClear);
	
	create custLic transient;
	theForm.mulSelect6.getSelected(custLic);
	
	//01/09/2023	navkc1	CR 59937 Task 59939
	create etrows transient;
	create mandatoryAttr transient;	
	theForm.mulSelect7.getSelected(etrows);
	foreach etrow in etrows as EntTableRow do
		mandatoryAttr.add(etrow.name);
	endforeach;
	
	pxyCustDocType := theForm.myProxyObject.CM_CustomDocumentType;
	
	//10/11/2023 navmv20 Bug 61351 - start
	index := theForm.cmbDirection.listIndex;
	if index &lt;&gt; -1 then
		direction := theForm.cmbDirection.itemData[index];
	endif;
	
	//05/09/2023	navkc1	CR 60156  Task 60157
	//pxyCustDocType.setProxy(code,description,theForm.cmbDirection.itemData[theForm.cmbDirection.listIndex],hasAuto,nafe,term,docTypes,stopsApply,stopsClear, custLic, mandatoryAttr, colour);
	pxyCustDocType.setProxy(code,description,direction,hasAuto,nafe,term,docTypes,stopsApply,stopsClear, custLic, mandatoryAttr, colour);
	//10/11/2023 navmv20 Bug 61351 - end
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCustDocType(pxyCustDocType, realCustDocType, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// add new doc type to available doc types
			self.setupMultiSelect3("Next Document Types",term.allCustomDocumentTypes,SOP_TableMaintForm::displayEntryCustDocType.name);
		
		endif;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCustDocType(pxyCustDocType, app.myPassport);
	endif;

	return app.myPassport.trxCompletedOK;
epilog
	delete stopsApply;
	delete stopsClear;
	delete custLic;
	delete docTypes;
	delete etrows;
	delete mandatoryAttr;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="cac778ef-ae63-4029-9ab6-7bf0bb1ec712">
        <source>getCollection(): Collection;
/*
Purpose:			

Date		Who		Reason
04 August 2023	navab1	CR 56093 TASK 59625
*/

vars

	terminal				: CM_Terminal;
begin
	terminal	    := self.myForm.myTerminal;

	return terminal.allCustomDocumentTypes;

epilog

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
