vars

begin
	return ETDef_EDITIDriver;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVehicles" id="baaea22d-197b-421a-a9a1-39d9f54f503e">
        <source>getVehicles(_allVehicles : CM_VehicleSet input);
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	vehicleState : StringArray;
	vehicleRegs : StringArray;
	vehicleReg : String;
	vehicle : CM_Vehicle;
	terminal : CM_Terminal;
begin
	if _allVehicles = null then
		return;
	endif;
	
	create vehicleRegs transient;
	self.vehicles.getTokensForDelimiter("|",vehicleRegs);
	
	terminal := self.getMyTerminal();
	
	create vehicleState transient;
	
	foreach vehicleReg in vehicleRegs do
		vehicleState.clear;
		vehicleReg.getTokensForDelimiter("/",vehicleState);
		
		if vehicleState.size = 2 then
			vehicle:=terminal.vehicles[vehicleState[2].trimBlanks,vehicleState[1].trimBlanks];
		else
			vehicle:=terminal.vehicles[vehicleReg.trimBlanks,null];
		endif;
		if vehicle &lt;&gt; null then
			_allVehicles.addNoDuplicates(vehicle,false);
		endif;
	endforeach;
	
epilog
	delete vehicleRegs;
	delete vehicleState;

end;</source>
        <Parameter name="_allVehicles" type="CM_VehicleSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="f8943b8d-004d-4dbb-80bb-77a5d74c04fc">
        <source>loadDB(_validateOnly : Boolean; _passport : CM_Passport input);
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	realDriver,
	proxyDriver : CM_DriverDetails;
begin
	
	self.verifySelf();
	
	if _validateOnly then
		return;
	endif;
	
	if self.action = self.EDI_ACTION_ADD then
		proxyDriver:=self.createProxy();
		app.myUtilityCA.utlCreateDriverDetails(proxyDriver, realDriver, _passport);
	elseif self.action = self.EDI_ACTION_UPDATE then
		proxyDriver:=self.createProxy();
		app.myUtilityUA.utlUpdateDriverDetails(proxyDriver,_passport);
	elseif self.action = self.EDI_ACTION_DELETE then
		realDriver:=self.getDriverDetails();
		app.myUtilityDA.utlDeleteDriverDetails(realDriver,_passport);
	endif;
epilog
	delete proxyDriver;
end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1fdd0607-2f20-4a95-990a-f7953e5aa1bf">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Date		Who		Reason
11 June 2015	cnwer1	Initial creation PAR 36435

*/

vars

begin
	inheritMethod(_proxyEDITI);
	self.action:=_proxyEDITI.action;
	self.code:=_proxyEDITI.code;
	self.driverStatus:=_proxyEDITI.driverStatus;
	self.name:=_proxyEDITI.name;
	self.secondaryCode:=_proxyEDITI.secondaryCode;
	self.carriers:=_proxyEDITI.carriers;
	self.vehicles:=_proxyEDITI.vehicles;
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="5668faf9-2b78-4dc5-bb05-6abe1cdaba76">
        <source>verifySelf();
/*

Date				Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304
21 Jun 2024			jlizm1	TFS 63908 Allow duplicate driver names

*/

vars
	terminal	 	: CM_Terminal;
	driverName,
	driverCode 			: CM_DriverDetails;
begin
	
	if self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD 
			and self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE
			and self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE then
			app.raiseCMException1(EDI_Action_Is_Invalid, action, ETRow_Action, self);
			return;
	endif;
	
	terminal:=self.getMyTerminal();
	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	else
		driverCode:=terminal.allDriversByCode[self.code];
		if action  = CM_EDITrackedItem.EDI_ACTION_ADD then
			if driverCode &lt;&gt; null then
				app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
			endif;
		elseif action = CM_EDITrackedItem.EDI_ACTION_UPDATE then
			if driverCode = null then
				app.raiseCMException2(Does_not_exist_cannot_update,app.getErrorString(Driver), self.code, null, null);
			endif;
		elseif action = CM_EDITrackedItem.EDI_ACTION_DELETE then
			if driverCode = null then
				app.raiseCMException2(Object_DoesNotExist_Too_Delete,app.getErrorString(Driver), self.code, null, null);
			endif;
		endif;
	endif;
	
	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Name', null, null);
		app.raiseCMException(Input_required_field_name, null, null); // cnwdb2	PAR 35364
	else
		driverName:=terminal.allDriversbyName[self.name];
		
		if action  = CM_EDITrackedItem.EDI_ACTION_ADD then
			if driverName &lt;&gt; null and not terminal.getConfig(AllowDupDriverNames).Boolean then
				app.raiseCMException1(VB_DUPLICATED_ITEM, self.name, null, null);
			endif;
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
