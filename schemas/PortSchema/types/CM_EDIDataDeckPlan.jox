        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="0d449ad5-ae48-4c14-9e1b-664b4ef93ad9">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
// ---------------------------------------------------------------------------
// Created:     13 seopt 2011 cnwrs1 
// Purpose:     CCMS 1150 RORO Ship manifest  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
// ---------------------------------------------------------------------------
vars

	cmifDeckPlan : CMIF_EDIDeckPlan;
//	cmifDeckPlanGCCargo : CMIF_DeckPlanGCCargo;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
//	app.setContinueCMExceptions(false);	//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
	
	create cmifDeckPlan transient;
	cmifDeckPlan.myEDIData := self;
	self.setupProxiesCargo(Loading_EDI_Data_Total, cmifDeckPlan, _passport); 
	if _passport.hasErrors then 
		return _passport.allErrors.size;
	endif;
	
	app.myTrxCA.trxCreateEDIDeckPlan(true,  self, cmifDeckPlan, _passport);
epilog
	cmifDeckPlan.cleanUpProxies();
	delete cmifDeckPlan;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
