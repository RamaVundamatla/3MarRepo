    <DbClassMap file="workorder"/>
    <ExplicitInverseRef name="allVoyages" id="5c7fee5a-dc35-4bf5-97a9-93affb1de199">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_VoyageSet"/>
