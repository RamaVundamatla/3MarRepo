    <JadeMethod name="processFile" id="f20eaddf-b782-4250-a1a4-30782eed2d38">
        <updating/>
        <source>processFile(_ediFile : CM_EDIFile input) updating, protected;

/*
Purpose:		Process the EDI file that contains the IFTMIN message.
				The IFTMIN message can have any of 43 different segment groups,
				of which currently (01/05/2009) only 14 are really being used to extract data from.

Date				Who		Reason
23 April 2009		cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812
01 July 2009		cnwrl1	PAR 20166 - Process extra data formats.
10/07/2009			cnwrl1	PAR 20247 - CCMS 1859 - Add the PAR 20239 code
14/07/2009			cnwrl1	PAR 20247 - CCMS 1859 - Remove the PAR 20239 code and replace with permanent solution.
22/07/2009			cnwrl1	PAR 20319 - altered to stop UE 1090 when records are received in order not expected.
11/02/2010			cnwrl1	PAR 22304 = Lloyds and Call Sign numbers in IFTMIN
//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
03 Apr 2013			cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
*/
// 20 Sep 2013 cnwah9 removed error messages and unnecessary code
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//11 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	message					: String;
	sealNumberStr			: String;
	haz						: String;
	undg					: String;
	messageMode				: String;
	lloydsNumber			: String;				// cnwrl1 11/02/2010 PAR 22304
	callSign				: String;				// cnwrl1 11/02/2010 PAR 22304
	msgCount				: Integer;
	numMsgs					: Integer;
	monitorCount			: Integer;
	temperature				: Real;
	container_temp			: CM_EDIPrenoteTI;			// use this to temporarily store file data.
	container_EDIPrenoteTI	: CM_EDIPrenoteTI;
	passport				: CM_Passport;
	msgHelper				: CMIF_EDIFACTHelper;
//	binaryLine				: Binary;
	stringPin				: String; //cnwgb1 PAR 22349 28.6.2010
    tempConsignee           : String; //cnwgb1 PAR 27580 31.5.2011
	untCount : Integer;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
	foundMatch				: Boolean;
	theLines : HugeStringArray;
	rawSenderCode : String;
	creationTS : TimeStamp;
	sequence : String;
	fileType : String;
	version : String;
	recipientCode : String;
	operatorSenderCode : String;
	operatorSender : CM_Operator;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	monitorCount	:= 20;
	passport		:= app.myPassport;
	// initialise all of the class data from previous run.
	app.getTerminalDefCmdty( self.mtCmdty, self.defCmdty, self.refCmdty, self.hazCmdty );	// cnwrl1 10/07/2009 PAR 20247 - CCMS 1859
	// cnwrl1 22/07/2009 PAR 20319 - start of coding
	resetTranslationStrings;
	self.containerId			:= null;
	self.generatedContainerNo	:= null;
	self.myCM_Operator			:= null;
	// cnwrl1 22/07/2009 PAR 20319 - end of coding
	
	create container_temp transient;
	self.clearContainerOnlyValues( container_temp );		// cnwrl1 22/07/2009 PAR 20319
	container_temp.setMyEDIData(_ediFile.ediData);
	create msgHelper transient;
	msgHelper.setEDIFile( _ediFile );

	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach tempStr in theLines do :processFileLines
		msgCount	:= msgCount + 1;
		untCount := untCount + 1;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		msgHelper.setNextMessage( tempStr );		// set the current message
		message	:= msgHelper.currentMessage;		// get current
		// Now handle each of the possible records.
//BGM
		if msgHelper.currentTag = self.BGM then			// Beginning of message
			self.group := 0;					// initalise ready to process the next message
			resetTranslationStrings;
			msgHelper.setNextField;		// eg 340 = Shipping Instructions, 610 = Forwarding Instr, 705 = BOL - Bill of Lading
			msgHelper.setNextField;		// Message (Document) Id
			msgHelper.setNextField;		// Message Function Code
			tempStr	:= msgHelper.currentField.trimBlanks;
			if tempStr = self.EDI_DELETE then
				messageMode := CM_EDITrackedItem.EDI_ACTION_DELETE;
			elseif tempStr = self.EDI_UPDATE then
				messageMode := CM_EDITrackedItem.EDI_ACTION_UPDATE;
			elseif tempStr = self.EDI_ADD then
				messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
			else
				// Behaviour as previous
				messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
			endif;
//CNT
	
//COM
		
//CPI
		
//CTA
		
//CUX
		
//DGS
		elseif msgHelper.currentTag = self.DGS then		// Dangerous Goods
			self.group := 32;
			msgHelper.setNextField;					// Dangerous Goods Regulations Code
			if msgHelper.currentField.trimBlanks = "IMD" then	// IMO IMDG code
				// Regulations regarding the transportation of dangerous goods on
				// ocean-going vessels issued by the International Maritime Organization.
				msgHelper.setNextField;				// Hazardous Code
				haz		:= msgHelper.currentSubItem.trimBlanks;
				msgHelper.setNextField;				// United Nations Dangerous Goods Information
				undg := msgHelper.currentSubItem;	//par26798 cnwrs1 25 Jan 2011
				container_temp.imCodes.add( haz &amp; ":+" &amp; undg );
				// cnwrl1 10/07/2009 PAR 20247 - CCMS 1859 - start of coding
//				container_temp.imCodes.copy( container_EDIPrenoteTI.imCodes );	// cnwrl1 22/07/2009 PAR 20319 - what it was
//				if container_temp.commodity = self.defCmdty then
//					container_temp.commodity	:= self.hazCmdty;		// hazardous container
//				endif;
//				container_EDIPrenoteTI.commodity	:= container_temp.commodity;	// cnwrl1 22/07/2009 PAR 20319 - what it was
				// cnwrl1 10/07/2009 PAR 20247 - CCMS 1859 - end of coding
				// cnwrl1 22/07/2009 PAR 20319 - start of coding
				if container_EDIPrenoteTI &lt;&gt; null then
					container_temp.imCodes.copy( container_EDIPrenoteTI.imCodes );
//					container_EDIPrenoteTI.commodity	:= container_temp.commodity;
				endif;
				// cnwrl1 22/07/2009 PAR 20319 - end of coding
			endif;
//DIM
		elseif msgHelper.currentTag = self.DIM then		// Dimensions
			// Dimensions are in group 21 and 37 but are not mentioned in Gdansk document.
			msgHelper.setNextField;					// Dimension Type Code
			msgHelper.setNextField;					// Dimension
			tempStr	:= msgHelper.currentSubItem.trimBlanks;
			if tempStr = "CMT" or tempStr = "CM" then		// ie centimeters
				// valid baplie 1 still used by some systems
				msgHelper.setNextSubItem;
				container_temp.length	:= msgHelper.currentSubItem.trimBlanks.Integer;
				msgHelper.setNextSubItem;
				container_temp.width	:= msgHelper.currentSubItem.trimBlanks.Integer;
				msgHelper.setNextSubItem;
				container_temp.height	:= msgHelper.currentSubItem.trimBlanks.Integer;
				// cnwrl1 22/07/2009 PAR 20319 - start of coding
				if container_EDIPrenoteTI &lt;&gt; null then
					container_EDIPrenoteTI.length	:= container_temp.length;
					container_EDIPrenoteTI.width	:= container_temp.width;
					container_EDIPrenoteTI.height	:= container_temp.height;
				endif;
				// cnwrl1 22/07/2009 PAR 20319 - end of coding
			
			endif;
//DOC
		
//DTM
	
//EQA
		
//EQD
		elseif msgHelper.currentTag = self.EQD then	// Equipment Details: Most of the essential stuff
			// The container id might be on either or both of the SGP and EQD records
			self.processGroupEQD(	_ediFile,
									container_temp,
									msgHelper,
									container_EDIPrenoteTI,
									lloydsNumber,		// cnwrl1 11/02/2010 PAR 22304
									callSign);			// cnwrl1 11/02/2010 PAR 22304
			container_EDIPrenoteTI.messageMode := messageMode; //par 23541
//EQN
		
//FTX
		elseif msgHelper.currentTag = self.FTX then		// Free text
			msgHelper.setNextField;					// Text subject Code Qualifier
			if msgHelper.currentField.trimBlanks = "AAA" then	// Goods Description ie the Commodity
				msgHelper.setNextField;				// Text Function
				msgHelper.setNextField;				// Text Reference
				msgHelper.setNextField;				// Text Literal
				self.commodityStr	:= msgHelper.currentField.trimBlanks;
				container_temp.commodityDescription	:= self.commodityStr[ 1 : CM_EDIPrenoteTI::commodityDescription.getLengthForString ];
				container_temp.setDescription( self.commodityStr );			// cnwrl1 14/07/2009 PAR 20247 - CCMS 1859
			endif;
//GDS
	
//GID
		elseif msgHelper.currentTag = self.GID then		// Goods Item Details
			self.group := 18;					// GID
			// Currently no data required from this group
//GIN
		
//GOR
	
//HAN
		
//LOC
		elseif msgHelper.currentTag = self.LOC then		// Place/location identification
			if self.group = 0 then
				self.group := 1;
			endif;
			if self.group &lt;&gt; 1 and self.group &lt;&gt; 8 then	/*	// LOC or TDT*/
				continue processFileLines;
			endif;
			
			msgHelper.setNextField;
			tempStr := msgHelper.currentField.trimBlanks;
//			if tempStr = "11" or tempStr = "12" or tempStr = "62" or tempStr = "64" or tempStr = "65" then	// cnwrl1 26/06/2009 PAR 20104 - what it was
			if tempStr = "11" or tempStr = "12" or tempStr = "61" or tempStr = "62" or tempStr = "64" or tempStr = "65" then
				// These codes are synonymous with discharge port - 11 = Place/port of discharge, 12 = Port of discharge, 61 = Next Port of Call
				// 62 = On-carriage port, 64 = First optional place of discharge, 65 = Final port or place of discharge
				msgHelper.setNextField;
				self.dischargePortStr	:= msgHelper.currentSubItem.trimBlanks;	// used in translation later
			elseif tempStr = "9" then
				// Load Port
				msgHelper.setNextField;
				self.loadPortStr	:= msgHelper.currentSubItem.trimBlanks;			// used in translation later
			elseif tempStr = "7" or tempStr = "8" then
				// These codes are synonymous with destination - 7 = Place of delivery, 8 = Place of destination
				msgHelper.setNextField;
				self.destinationPortStr	:= msgHelper.currentSubItem.trimBlanks;	// used in translation later
			endif;
//MEA
		elseif msgHelper.currentTag = self.MEA then		// Measurements
//			self.processGroupMEA( _ediFile, container_temp, msgHelper );	// cnwrl1 22/07/2009 PAR 20319 - what it was
			self.processGroupMEA( _ediFile, container_temp, msgHelper, container_EDIPrenoteTI );
//MOA
		
//NAD
		elseif msgHelper.currentTag = self.NAD then		// Name and address
            if self.group &lt; 18 then //cnwgb1 31.5.2011 PAR 27580 
                self.group := 11;
            endif;
			msgHelper.setNextField;						// Party Function Code Qualifier
			tempStr	:= msgHelper.currentField.trimBlanks;
			if tempStr = "CN" or tempStr = "ST" then	// Consignee (Ship To)
				msgHelper.setNextField;
				tempConsignee	:= msgHelper.currentField.trimBlanks;	// used in translation later
                if tempConsignee = null then //cnwgb1 PAR 27580 31.5.2011
                    msgHelper.setNextField;
                    msgHelper.setNextField;
                    tempConsignee := msgHelper.currentSubItem;
                endif;
                if self.group = 11 then //cnwgb1 PAR 27580 31.5.2011
                    self.consigneeStr := tempConsignee;
                elseif container_EDIPrenoteTI &lt;&gt; null then
                    container_EDIPrenoteTI.consignee := tempConsignee;
                endif;
                
			elseif tempStr = "CZ" or tempStr = "SF" then	// Consignor (Ship From)
				msgHelper.setNextField;
				self.consignorStr	:= msgHelper.currentField.trimBlanks;	// used in translation later
			elseif tempStr = "CF" or tempStr = "OP" then
				// if have already obtained the operator then skip this.
				if self.myCM_Operator &lt;&gt; null then
					continue processFileLines;
				endif;
				msgHelper.setNextField;
				tempStr			:= msgHelper.currentField.trimBlanks;
				// check the translations
			//	tempStr			:= app.myRoot.getXlationSystemCode( tempStr, XLATION_TYPE_OPERATOR );
				tempStr := app.myRoot.getXlationSystemOperatorCode( self.myCM_Operator, tempStr, foundMatch ); // cnwrd1 par 19675 14.5.09
				container_temp.operatorCode	:= tempStr[ 1 : CM_EDIPrenoteTI::operatorCode.getLengthForString ];
				self.myCM_Operator	:= app.myRoot.allOperators[ container_temp.operatorCode ];
			// cnwrl1 01/07/2009 PAR 20166 - start of coding
			elseif tempStr = "MS"  then // Prenote Freight Forwarder is the Message Sender?? Gdansk specification.
				msgHelper.setNextField;
				self.freightForwarderStr	:= msgHelper.currentField.trimBlanks;	// used in translation later
			// cnwrl1 01/07/2009 PAR 20166 - end of coding
			elseif tempStr = "FW"  then	// cnwgb1 PAR 21881 CCMS DCTG 1906 15.12.2009 Freight Forwarder
				msgHelper.setNextField;
				msgHelper.setNextField; // cnwgb1 PAR 21881 CCMS DCTG 1906 15.12.2009 Use the description field (Guess)
				self.freightForwarderStr	:= msgHelper.currentSubItem.trimBlanks;	// used in translation later
			// cnwrl1 01/07/2009 PAR 20166 - end of coding
			endif;
//PCD
		
//PCI
		
//PIA
		
//PRI
		
//QTY
		
//RFF
		elseif msgHelper.currentTag = self.RFF then		// Reference
			msgHelper.setNextField;					// Reference function code
			tempStr	:= msgHelper.currentSubItem.trimBlanks;
			if tempStr = "BM" then					// BOL - Bill of Lading number
				msgHelper.setNextSubItem;
//				container_temp.bol	:= msgHelper.currentSubItem[ 1 : CM_TrackedItem::billOfLading.getLengthForString ].trimBlanks;	// cnwrl1 16/03/2010 PAR 23186 - what it was
				container_temp.bol	:= msgHelper.currentSubItem.trimBlanks;
				// cnwrl1 22/07/2009 PAR 20319 - start of coding
				if container_EDIPrenoteTI &lt;&gt; null then
					container_EDIPrenoteTI.bol	:= container_temp.bol;
				endif;
				// cnwrl1 22/07/2009 PAR 20319 - end of coding
			elseif tempStr = "RE" then	// cnwgb1 PAR 21881 for DCTGdansk 1906 14.12.2009
				msgHelper.setNextSubItem;
				stringPin := msgHelper.currentSubItem.trimBlanks; //cnwgb1 PAR 22349 28.6.2010
				if stringPin = null then
					stringPin := NULLImportPin; //cnwgb1 PAR 22349 28.6.2010
				endif;
				container_temp.setOperatorImportReleasePIN(stringPin);
				if container_EDIPrenoteTI &lt;&gt; null then
					container_EDIPrenoteTI.setOperatorImportReleasePIN(stringPin);
				endif;
			elseif tempStr = "BN" then					// Booking reference number
				msgHelper.setNextSubItem;
				container_temp.bookingRef	:= msgHelper.currentSubItem[ 1 : CM_EDIPrenoteTI::bookingRef.getLengthForString ].trimBlanks;
				if container_EDIPrenoteTI &lt;&gt; null then
					container_EDIPrenoteTI.bookingRef	:= container_temp.bookingRef;
				endif;
			endif;
//RNG
		
//SEL
		elseif msgHelper.currentTag = self.SEL then		// SEAL Number
			if self.group = 37 then					// EQD
				// get the seal number and save it then establish exactly who the seal is for.
				msgHelper.setNextField;			// Actual Seal Number
				sealNumberStr	:= msgHelper.currentField[ 1 : CM_EDIPrenoteTI::sealNum.getLengthForString ].trimBlanks;
				msgHelper.setNextField;			// Seal Issuer
				tempStr	:= msgHelper.currentField.trimBlanks;
				if tempStr = 'CA' or tempStr = null then			// Carrier
					container_temp.sealNum		:= sealNumberStr;
				elseif tempStr = 'CU' then			// Customs
					container_temp.customsSeal	:= sealNumberStr;
				elseif tempStr = 'SH' then		// Shipper
					container_temp.sealShipper	:= sealNumberStr;
				elseif tempStr = 'TO' then
					container_temp.sealTerminalOperator := sealNumberStr;
				else
					// only save the other seals if do not already have a carrier seal
//					if container_temp.sealNum = null then
						container_temp.sealUnknown	:= sealNumberStr;
//					endif;
				endif;
				// cnwrl1 22/07/2009 PAR 20319 - start of coding
				if container_EDIPrenoteTI &lt;&gt; null then
					container_EDIPrenoteTI.sealNum		:= container_temp.sealNum;
					container_EDIPrenoteTI.customsSeal	:= container_temp.customsSeal;
					container_EDIPrenoteTI.sealShipper	:= container_temp.sealShipper;
				endif;
				// cnwrl1 22/07/2009 PAR 20319 - end of coding
			endif;
//SGP
		elseif msgHelper.currentTag = self.SGP then		// Split Goods Placement
			// The container id might be on either or both of the SGP and EQD records
			self.processGroupSGP(	_ediFile,
									container_temp,
									msgHelper,
									container_EDIPrenoteTI,
									lloydsNumber,		// cnwrl1 11/02/2010 PAR 22304
									callSign);			// cnwrl1 11/02/2010 PAR 22304
//TCC
		elseif msgHelper.currentTag = self.TCC then		// Transport charge/rate calculations
			self.group := 31;						// TCC
			// Currently no data required from this group
//TDT
		elseif msgHelper.currentTag = self.TDT then		// Details of transport
			self.processGroupTDT(	_ediFile,
									lloydsNumber,			// cnwrl1 11/02/2010 PAR 22304
									callSign,				// cnwrl1 11/02/2010 PAR 22304
									container_temp,
									msgHelper );
//TMD
		
//TMP
		elseif msgHelper.currentTag = self.TMP then		// Temperature
			// can only be group 18 or 37
			if self.group = 18 or self.group = 37 then	// GID or EQD
				msgHelper.setNextField;
				tempStr := msgHelper.currentField.trimBlanks;
				if tempStr = "1" or tempStr = "2" or tempStr = "3" then	//Storage, transport and cargo handling temps
					msgHelper.setNextField;
					temperature := msgHelper.currentSubItem.trimBlanks.asEDIReal();
					msgHelper.setNextSubItem;
					tempStr	:= msgHelper.currentSubItem.trimBlanks;
					if tempStr = "CEL" then				// Celsius
						container_temp.temperature := temperature;
					elseif tempStr = "FAH" then			// Fahrenheit
						container_temp.temperature := app.temperatureConversion( false, temperature );
					endif;
					// cnwrl1 10/07/2009 PAR 20247 - CCMS 1859 - start of coding
//					container_EDIPrenoteTI.temperature	:= container_temp.temperature;	// cnwrl1 22/07/2009 PAR 20319 - what it was
//					if container_temp.commodity = self.defCmdty then
//						container_temp.commodity	:= self.refCmdty;		// reefer container
//					endif;
//					container_EDIPrenoteTI.commodity	:= container_temp.commodity;	// cnwrl1 22/07/2009 PAR 20319 - what it was
					// cnwrl1 10/07/2009 PAR 20247 - CCMS 1859 - end of coding
					// cnwrl1 22/07/2009 PAR 20319 - start of coding
					if container_EDIPrenoteTI &lt;&gt; null then
						container_EDIPrenoteTI.temperature	:= container_temp.temperature;
//						container_EDIPrenoteTI.commodity	:= container_temp.commodity;
					endif;
					// cnwrl1 22/07/2009 PAR 20319 - end of coding
				endif;
			endif;
//TOD
		
//TPL
		
//TSR
		
//UNA

//UNB
		elseif msgHelper.currentTag = self.UNB then
			self.getUNB_ElementData(	msgHelper,
										operatorSenderCode,
										operatorSender, rawSenderCode, recipientCode, creationTS, sequence);
			_ediFile.ediData.setXlationOperator(operatorSender);

//UNH
		elseif msgHelper.currentTag = self.UNH then		// message header
			untCount := 1;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
			self.getUNHData(_ediFile.ediData, msgHelper, fileType, version);
			if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and
			   not self.processSenderRecipientSeq(rawSenderCode, recipientCode, fileType, version, _ediFile.ediData.fileName, creationTS, sequence, _ediFile.ediData, passport.myTerminal) then
				_ediFile.ediData.status := CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE;
			endif;
			// Currently no data required from this group
//UNT
		elseif msgHelper.currentTag = self.UNT then		// Message trailer
			msgHelper.setNextField;

//UNZ
		endif;
	endforeach processFileLines;
	
//	self.doTranslations (_ediFile, null);
epilog
	delete msgHelper;
	delete container_temp;
	delete theLines;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processGroupEQD" id="e86d2a0b-ef84-4b0c-8e63-ed124452ae9f">
        <updating/>
        <source>processGroupEQD(
	_ediFile				: CM_EDIFile input;
	_container_temp			: CM_EDIPrenoteTI io;
	_msgHelper				: CMIF_EDIFACTHelper io;
	_container_EDIPrenoteTI	: CM_EDIPrenoteTI io;
	_lloydsNumber			: String;
	_callSign				: String) updating, protected;

/*
Date				Who		Reason
29 April 2009		cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812
20 Sep 2013 cnwah9 removed error messages and unnecessary code
//01 Dec 2016	cnwrs1	TFS 2987 if no cooling type check with container Range
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
	
vars
	tiCargoType				: Integer;
	contRange : CM_ContRange;
begin
	self.group := 37;
	_msgHelper.setNextField;			// Cargo Type
	tempStr	:= _msgHelper.currentField.trimBlanks;
	if tempStr = "CN" or			// Container
	   tempStr = "AJ" or			// Flat Rack
	   tempStr = "AM" or			// Reefer (Refrigerated Container)
	   tempStr = null then			// No info: set as default
		tiCargoType	:= TI_CargoType_Container;
	elseif tempStr = "RG" then		// Reefer Generator
		tiCargoType := TI_CargoType_Generator;
	else
		// There are a lot of other cargo codes, lump them in as BB type
		tiCargoType := TI_CargoType_BreakBulk;
	endif;
	
	// The containerId might be already set via a SGP record or on the EQD record itself.
	_msgHelper.setNextField;
	tempStr	:= _msgHelper.currentField.trimBlanks;	// The one on the EQD record
	if tempStr.length &gt; 11 then
		tempStr	:= tempStr[1:4] &amp; tempStr[6:7];
	endif;
	// if this one is not null and not equal to the one passed in then use this one.
	if tempStr &lt;&gt; null and tempStr &lt;&gt; self.containerId then
		self.containerId	:= tempStr;
	endif;
	
	// Now if still have no valid containerId generate one here
	/*if self.containerId = null then
		self.generatedContainerNo	:= self.generatedContainerNo + 1;
		self.containerId			:= self.generatedContainerNo.display;
		msgStr	:=	'Container has no id, using generated number ' &amp; self.containerId.display &amp; Tab &amp;
					self.group.display &amp; Tab &amp; _msgHelper.currentMessage;
	endif;*/
//	self.clearContainerOnlyValues( _container_temp );	// cnwrl1 22/07/2009 PAR 20319 - what it was
	if _container_temp.id &lt;&gt; null then		// clear the previous container details
		self.clearContainerOnlyValues( _container_temp );
	endif;
	_container_temp.setId(self.containerId);
	contRange := _container_temp.getContRange();
	
	_msgHelper.setNextField;			// ISO Type
	self.isoTypeStr	:= _msgHelper.currentSubItem.trimBlanks;		// used in translation later
	if contRange &lt;&gt; null then
		if self.isoTypeStr = null then
			self.isoTypeStr := contRange.isoType;
		endif;
		_container_temp.coolingType := contRange.coolingType;
	endif;
	_msgHelper.setNextField;			// Equipment Supplier
	_msgHelper.setNextField;			// IMEX Status
	tempStr	:= _msgHelper.currentField.trimBlanks;
	if tempStr = "3" then //cnwgb1 PAR 21881 CCMS DCTG 1906
		_container_temp.imexStatus:= "Import";
	elseif tempStr = "2" or tempStr = null then
		_container_temp.imexStatus := "Export";
	else
		_container_temp.imexStatus  := null; // cnwgb1 PAR 21881 14.12.2009 Just Guessing
	endif;
	
	_msgHelper.setNextField;			// Commodity - Full or Empty
	tempStr	:= _msgHelper.currentField.trimBlanks;
	if tempStr = "4" then
		_container_temp.fullOrMT	:= "E";
//		_container_temp.commodity	:= _passport.myTerminal.getDefaultEmptyCommodity();	// Default may be overwritten	// cnwrl1 22/07/2009 PAR 20319 - what it was
	//	_container_temp.commodity	:= self.mtCmdty;		// Default may be overwritten later
	elseif tempStr = "5" then
		_container_temp.fullOrMT	:= "F";
	endif;
	
	if _container_temp.transportMode = null then
		_container_temp.transportMode	:= TI_TRANSMODE_ROAD_STR;		// default
	endif;
	
	self.setupPrenoteTI(	_ediFile,
							_container_temp,
							_container_EDIPrenoteTI,
							tiCargoType,		// might be overriden via the SGP record
							_lloydsNumber,
							_callSign);
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_container_temp" type="CM_EDIPrenoteTI" usage="io"/>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_container_EDIPrenoteTI" type="CM_EDIPrenoteTI" usage="io"/>
        <Parameter name="_lloydsNumber" type="String"/>
        <Parameter name="_callSign" type="String"/>
    </JadeMethod>
    <JadeMethod name="processGroupMEA" id="c7a8ada2-142f-4f24-95c8-1aa601d727ee">
        <updating/>
        <source>processGroupMEA(
	_ediFile				: CM_EDIFile input;
	_container_temp			: CM_EDIPrenoteTI io;
	_msgHelper				: CMIF_EDIFACTHelper io;
	_container_EDIPrenoteTI	: CM_EDIPrenoteTI io ) updating, protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
29 April 2009		cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812
22/07/2009			cnwrl1	PAR 20319
*/
	
vars
	
begin
	// get the Net Weight, Gross Volume, Volume and Gross Weight
	_msgHelper.setNextField;			// Measurement Code
	tempStr	:= _msgHelper.currentField.trimBlanks;	// These codes represent weight
	if tempStr = "AAE" or			// Measurement
	   tempStr = "AAI" or			// Item Weight
	   tempStr = "CHW" or			// Chargeable Weight
	   tempStr = "WT" then			// Weights
		_msgHelper.setNextField;		// Measurement Details
		tempStr	:= _msgHelper.currentField.trimBlanks;
		if tempStr = 'AAL' or		// Nett Weight aka Tare
		   tempStr = 'AAW' or		// Gross Volume
		   tempStr = 'ABJ' or		// Volume
		   tempStr = 'G' then		// Gross Weight
			// get the actual weight value
			_msgHelper.setNextField;
			if _msgHelper.currentSubItem.trimBlanks = "KGM" then
				// Look for weight field
				_msgHelper.setNextSubItem;
				_container_temp.weight	:= _msgHelper.currentSubItem.trimBlanks.Decimal;
				if _container_EDIPrenoteTI &lt;&gt; null then		// cnwrl1 22/07/2009 PAR 20319
					_container_EDIPrenoteTI.weight	:= _container_temp.weight;
				endif;
			elseif _msgHelper.currentSubItem.trimBlanks = "MTQ" then
				// Look for volume field
				_msgHelper.setNextSubItem;
				_container_temp.volume	:= _msgHelper.currentSubItem.trimBlanks.Decimal;
				if _container_EDIPrenoteTI &lt;&gt; null then		// cnwrl1 22/07/2009 PAR 20319
					_container_EDIPrenoteTI.volume	:= _container_temp.volume;
				endif;
			endif;
		elseif tempStr = 'AAO' then	// Humidity
			// get the actual value
			_msgHelper.setNextField;
			_msgHelper.setNextSubItem;
			_container_temp.setHumidity( _msgHelper.currentSubItem.trimBlanks.asDecimalJMT );
			if _container_EDIPrenoteTI &lt;&gt; null then		// cnwrl1 22/07/2009 PAR 20319
				_container_EDIPrenoteTI.setHumidity( _container_temp.getHumidity );
			endif;
		elseif tempStr = 'AAS' then	// Air Flow - ie Vent
			// get the actual value
			_msgHelper.setNextField;
			_msgHelper.setNextSubItem;
			_container_temp.vent		:= _msgHelper.currentSubItem.trimBlanks.asEDIReal;
			if _container_EDIPrenoteTI &lt;&gt; null then		// cnwrl1 22/07/2009 PAR 20319
				_container_EDIPrenoteTI.vent	:= _container_temp.vent;
			endif;
		elseif tempStr = 'ZO' then	// Oxygen
			// get the actual value
			_msgHelper.setNextField;
			_msgHelper.setNextSubItem;
			_container_temp.setOxygen( _msgHelper.currentSubItem.trimBlanks.asDecimalJMT );
			if _container_EDIPrenoteTI &lt;&gt; null then		// cnwrl1 22/07/2009 PAR 20319
				_container_EDIPrenoteTI.setOxygen( _container_temp.getOxygen );
			endif;
		// cnwrl1 22/07/2009 PAR 20319 - start of coding
		elseif tempStr = 'CD' then	// CarbonDioxide 
			// get the actual value
			_msgHelper.setNextField;
			_msgHelper.setNextSubItem;
			_container_temp.setCarbonDioxide( _msgHelper.currentSubItem.trimBlanks.asDecimalJMT );
			if _container_EDIPrenoteTI &lt;&gt; null then
				_container_EDIPrenoteTI.setCarbonDioxide( _container_temp.getCarbonDioxide );
			endif;
		endif;
		// cnwrl1 22/07/2009 PAR 20319 - end of coding
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_container_temp" type="CM_EDIPrenoteTI" usage="io"/>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_container_EDIPrenoteTI" type="CM_EDIPrenoteTI" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processGroupSGP" id="e61e1c3f-edcf-41df-bc4f-5fc185990604">
        <updating/>
        <source>processGroupSGP(
	_ediFile				: CM_EDIFile input;
	_container_temp			: CM_EDIPrenoteTI io;
	_msgHelper				: CMIF_EDIFACTHelper io;
	_container_EDIPrenoteTI	: CM_EDIPrenoteTI io;
	_lloydsNumber			: String;
	_callSign				: String) updating, protected;

/*
Date				Who		Reason
01 May 2009			cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812
*/
// 20 Sep 2013 cnwah9 removed error messages and unnecessary code
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	tiCargoType				: Integer;
	
begin
	if self.group = 18 then					// GID
		self.group := 29;					// SGP
	elseif self.group = 32 then				// DGS
		self.group := 35;					// SGP
	else
		return;
	endif;
	
	// The containerId might be already set via an EQD record or on the SGP record itself.
	_msgHelper.setNextField;
	tempStr	:= _msgHelper.currentField.trimBlanks;	// The one on the SGP record
	if tempStr.length &gt; 11 then
		tempStr	:= tempStr[1:4] &amp; tempStr[6:7];
	endif;
	// if this one is not null and not equal to the one passed in then use this one.
	if tempStr &lt;&gt; null and tempStr &lt;&gt; self.containerId then
		self.containerId	:= tempStr;
	endif;
	
	// Now if still have no valid containerId generate one here
	/*if self.containerId = null then
		self.generatedContainerNo	:= self.generatedContainerNo + 1;
		self.containerId			:= self.generatedContainerNo.display;
	endif;*/
//	self.clearContainerOnlyValues( _container_temp );	// cnwrl1 22/07/2009 PAR 20319 - what it was
	if _container_temp.id &lt;&gt; null then		// clear the previous container details
		self.clearContainerOnlyValues( _container_temp );
	endif;
	
	tiCargoType	:= TI_CargoType_Container;
	
	self.setupPrenoteTI(	_ediFile,
							_container_temp,
							_container_EDIPrenoteTI,
							tiCargoType,			// might be overriden via the EQD record
							_lloydsNumber,
							_callSign);
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_container_temp" type="CM_EDIPrenoteTI" usage="io"/>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_container_EDIPrenoteTI" type="CM_EDIPrenoteTI" usage="io"/>
        <Parameter name="_lloydsNumber" type="String"/>
        <Parameter name="_callSign" type="String"/>
    </JadeMethod>
    <JadeMethod name="processGroupTDT" id="1b384d8d-10e7-4c40-a92a-f72f11781c1b">
        <updating/>
        <source>processGroupTDT(
	_ediFile		: CM_EDIFile input;
	_lloydsNumber	: String io;				// cnwrl1 11/02/2010 PAR 22304
	_callSign		: String io;				// cnwrl1 11/02/2010 PAR 22304
	_container_temp	: CM_EDIPrenoteTI io;
	_msgHelper		: CMIF_EDIFACTHelper io ) updating, protected;

/*
Date				Who		Reason
29 April 2009		cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812
11/02/2010			cnwrl1	PAR 22304 = Lloyds and Call Sign numbers in IFTMIN
*/
// 26 Jul 2013 cnwah9 removed error messages and unnecessary code	
vars
	operatorVoyageCode	: String;			// cnwrl1 19/07/2010 PAR 25046
	vesselName			: String;			// cnwrl1 19/07/2010 PAR 25046
	
begin
	self.group := 8;
	_msgHelper.setNextField;		// Transport Stage Code Qualifer
	tempStr	:= _msgHelper.currentField.trimBlanks;
	/*if tempStr &lt;&gt; "1" and tempStr &lt;&gt; "20" then
		// ignore any others
		return;
	endif;*/
	if tempStr = "20" then
		/* cnwrl1 19/07/2010 PAR 25046 - what it was
		// 20 = The main carriage transport so we assume that the sender means voyage.
		_msgHelper.setNextField;		// voyage code
		self.voyageCodeStr	:= _msgHelper.currentField.trimBlanks;	// used in translation later
		_msgHelper.setNextField;		// mode of transport (Note gets defaulted later!)
		_msgHelper.setNextField;		// transport means
		_msgHelper.setNextField;		// Operator code is first sub-item
		tempStr	:= _msgHelper.currentSubItem.trimBlanks;
		// check the translations
		tempStr := app.myRoot.getXlationSystemOperatorCode( self.myCM_Operator, tempStr ); // cnwrd1 par 19675 14.5.09
		_container_temp.operatorCode	:= tempStr[ 1 : CM_EDIPrenoteTI::operatorCode.getLengthForString ];
		self.myCM_Operator	:= app.myRoot.allOperators[ _container_temp.operatorCode ];
		_msgHelper.setNextField;		// Excess Transportation Info
		_msgHelper.setNextField;		// Transportation Id
		_msgHelper.setNextField;		// Excess Transportation Info
		// cnwrl1 11/02/2010 PAR 22304 - start of coding
		_lloydsNumber		:= _msgHelper.currentSubItem;
		_msgHelper.setNextSubItem;	// Code List Id Code
		if _msgHelper.currentSubItem = '103' then	// call sign
			_callSign		:= _lloydsNumber;
			_lloydsNumber	:= null;
		endif;
		// cnwrl1 11/02/2010 PAR 22304 - end of coding
		_msgHelper.setNextSubItem;	// Code List Responsible Agency
		_msgHelper.setNextSubItem;	// Vessel name
		_container_temp.vesselName	:= _msgHelper.currentSubItem[ 1 : CM_EDIPrenoteTI::vesselName.getLengthForString ].trimBlanks;
		cnwrl1 19/07/2010 PAR 25046 - end of what it was */
		self.getVoyageDetailsFromTDT(	_msgHelper,
										self.voyageCodeStr,
										operatorVoyageCode,
										self.myCM_Operator,			// cnwrl1 26/07/2010 PAR 25093
										vesselName,
										_lloydsNumber,
										_callSign );
		_container_temp.operatorCode	:= operatorVoyageCode;
		_container_temp.vesselName		:= vesselName[ 1 : CM_EDIPrenoteTI::vesselName.getLengthForString ].trimBlanks;
	else	// _msgHelper.currentField = "1" ie inland
		_msgHelper.setNextField;		// voyage code
		_msgHelper.setNextField;		// mode of transport eg 1 = sea
		tempStr	:= _msgHelper.currentField.trimBlanks;
		if tempStr = '2' then		// Rail
			_container_temp.transportMode	:= TI_TRANSMODE_RAIL_STR;
		else						// assume Road
			_container_temp.transportMode	:= TI_TRANSMODE_ROAD_STR;
		endif;
		_msgHelper.setNextField;		// transport means
		_msgHelper.setNextField;		// carrier code is second sub-item
		_msgHelper.setNextSubItem;
		self.carrierCodeStr	:= _msgHelper.currentSubItem.trimBlanks;	// used in translation later
		_msgHelper.setNextField;		// Excess Transportation Info
		_msgHelper.setNextField;		// Transportation Id
		_msgHelper.setNextField;		// Excess Transportation Info
		tempStr	:= _msgHelper.currentSubItem.trimBlanks;
		if _container_temp.transportMode = TI_TRANSMODE_RAIL_STR then
			_container_temp.wagonNumber	:= tempStr[ 1 : CM_EDIPrenoteTI::wagonNumber.getLengthForString ];
		else						// assume Road
			_container_temp.vehicle		:= tempStr[ 1 : CM_EDIPrenoteTI::vehicle.getLengthForString ];					
		endif;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_lloydsNumber" type="String" usage="io"/>
        <Parameter name="_callSign" type="String" usage="io"/>
        <Parameter name="_container_temp" type="CM_EDIPrenoteTI" usage="io"/>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
    </JadeMethod>
    <JadeMethod name="resetTranslationStrings" id="9eaa0780-46c9-4872-8e52-2a607d9fef26">
        <updating/>
        <source>resetTranslationStrings() updating, protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
01 May 2009			cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812
10/07/2009			cnwrl1	PAR 20247 - CCMS 1859
*/
	
vars
	
begin
	self.carrierCodeStr			:= null;
	self.commodityStr			:= self.defCmdty;		// cnwrl1 20/07/2009 PAR 20247 - CCMS 1859
	self.consigneeStr			:= null;
	self.consignorStr			:= null;
	self.destinationPortStr		:= null;
	self.dischargePortStr		:= null;
	self.freightForwarderStr	:= null;	// cnwrl1 10/07/2009 PAR 20247 - CCMS 1859
	self.isoTypeStr				:= null;
	self.loadPortStr			:= null;
	self.voyageCodeStr			:= null;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupPrenoteTI" id="b5adf213-f173-4735-9ea2-809c9d2d2448">
        <updating/>
        <source>setupPrenoteTI(
	_ediFile				: CM_EDIFile input;
	_container_temp			: CM_EDIPrenoteTI input;
	_container_EDIPrenoteTI	: CM_EDIPrenoteTI io;
	_tiCargoType			: Integer;
	_lloydsNumber			: String;
	_callSign				: String) updating, protected;

/*
Date				Who		Reason
01 May 2009			cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
	
vars
	
begin
	// Do the required translations now, since this is the time the operator might exist.
//	self.translatePrenoteFields( _container_temp );	// cnwrl1 11/02/2010 PAR 22304 - what it was
	self.translatePrenoteFields( _container_temp, _lloydsNumber, _callSign );
	
	// Now create the EDI TI and set basic details, then copy the transient values to the persistent object
	_ediFile.ediData.CM_EDIDataPrenote.createPrenoteTI(_container_EDIPrenoteTI, self.containerId);
	self.copyDetailsToPrenoteTI( _container_temp, _container_EDIPrenoteTI, _tiCargoType );
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_container_temp" type="CM_EDIPrenoteTI" usage="input"/>
        <Parameter name="_container_EDIPrenoteTI" type="CM_EDIPrenoteTI" usage="io"/>
        <Parameter name="_tiCargoType" type="Integer"/>
        <Parameter name="_lloydsNumber" type="String"/>
        <Parameter name="_callSign" type="String"/>
    </JadeMethod>
    <JadeMethod name="translatePrenoteFields" id="6c7d4ec7-5c3d-4bd6-9a2a-e0721c947eb5">
        <source>translatePrenoteFields(_prenote	: CM_EDIPrenoteTI input; _lloydsNumber	: String; _callSign : String ) protected;
/*
Purpose:		Do the required translations that are possible and update the relevent Container Prenote field.

Date				Who		Reason
28 April 2009		cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812
11/02/2010			cnwrl1	PAR 22304 = Lloyds and Call Sign numbers in IFTMIN
12/03/2013			cnwcs5	CCMS POL 2097 / par 31259 - translation criteria.  Remove commodity xlations as we dont have temperature here
*/
	
vars
	operator	: CM_Operator;
begin
	operator	:= self.myCM_Operator;
	
	_prenote.carrierCode	:= self.getOperatorTranslation(	self.carrierCodeStr, operator, XLATION_TYPE_CARRIER_BYOP, CM_EDIPrenoteTI::carrierCode.getLengthForString );
	
	_prenote.consignee			:= self.getOperatorTranslation(self.consigneeStr,operator, XLATION_TYPE_CONSIGNEE_BYOP, CM_EDIPrenoteTI::consignee.getLengthForString );
	
	_prenote.consignor			:= self.getOperatorTranslation(self.consignorStr,operator, XLATION_TYPE_CONSIGNEE_BYOP, CM_EDIPrenoteTI::consignor.getLengthForString );
	
	_prenote.isoType			:= self.getOperatorTranslation(self.isoTypeStr,operator, XLATION_TYPE_ISOTYPE_BYOP, CM_EDIPrenoteTI::isoType.getLengthForString );
	
	_prenote.destinationPort	:= self.getOperatorTranslation(self.destinationPortStr,operator, XLATION_TYPE_PORT_BYOP, CM_EDIPrenoteTI::destinationPort.getLengthForString );
	
	_prenote.dischargePort		:= self.getOperatorTranslation(self.dischargePortStr,operator, XLATION_TYPE_PORT_BYOP, CM_EDIPrenoteTI::dischargePort.getLengthForString );
	
	_prenote.loadPort			:= self.getOperatorTranslation(self.loadPortStr,operator, XLATION_TYPE_PORT_BYOP, CM_EDIPrenoteTI::loadPort.getLengthForString );
	
	_prenote.setVoyageCode( self.getXlationOperatorVoyageCode(operator, operator, self.voyageCodeStr, _prenote.vesselName, _lloydsNumber, _callSign ) );
	
	// cnwrl1 10/07/2009 PAR 20247 - CCMS 1859 - start of coding
	_prenote.freightForwarder	:= self.getOperatorTranslation(self.freightForwarderStr, operator, XLATION_TYPE_CONSIGNEE_BYOP, CM_EDIPrenoteTI::freightForwarder.getLengthForString );
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_prenote" type="CM_EDIPrenoteTI" usage="input"/>
        <Parameter name="_lloydsNumber" type="String"/>
        <Parameter name="_callSign" type="String"/>
    </JadeMethod>
</Class>
