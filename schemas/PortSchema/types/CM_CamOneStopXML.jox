        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_trxTs" type="TimeStamp"/>
        <Parameter name="_messHdrEventType" type="String"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
