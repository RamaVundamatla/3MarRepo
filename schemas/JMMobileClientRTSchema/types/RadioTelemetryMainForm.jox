    </JadeMethod>
    <JadeMethod name="queryResultTableReInitialize" id="fb5ea499-7467-4f66-b572-d1fec14e6897">
        <source>queryResultTableReInitialize();
// -------------------------------------------
// Created 09 May 2008 by cnwvu1
// -------------------------------------------

vars

begin

//	tblResults.backColor	:= self.getSystemColor(Window.Color_Window);
//	tblResults.foreColor	:= self.getSystemColor(Window.Color_WindowText);
	self.tblResults.rows	:= 1;
