    <JadeMethod name="keyDown" id="c1f88cc7-2c94-4813-a73d-30febabe40ef">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		28 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if keyCode = CMUI_Key_F3 then
		return;
	endif;
	
	inheritMethod(keyCode, shift);
	if keyCode = CMUI_Key_Esc then
		self.doUndoDrag(self.tblData);
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="7e7dc5c7-75a8-4711-93ad-0705bfae1a54">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	regKeys					: IntegerArray;
	shipSLiftIfTLWgtExced	: Boolean;
	shipSLiftIfDiffHeights	: Boolean;
	
begin
	if self.xmlColourRow = 0 then
		self.setColours();
	endif;

	self.frmUserColours.visible := false;
	self.doLstCranesBuild(); 
	self.initDataTable();
	self.initROROTable();
	self.frmHeading.left := 0;
	self.frmHeading.top := self.frmToolbar.clientHeight + 1;
	
	create regKeys transient;
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);

	self.doCmbVoyageBuild();
	self.initThePoints();
	shipSLiftIfTLWgtExced := self.myTerminal.getConfig(ShipSLiftIfTLWgtExced).Boolean; // 'Make S/Lift if crane twin lift weight exceeded'
	shipSLiftIfDiffHeights := self.myTerminal.getConfig(ShipSLiftIfDiffHeights).Boolean;
	self.chkShipTLHeight.value := shipSLiftIfDiffHeights;
	self.chkShipTLWeight.value := shipSLiftIfTLWgtExced;
	
epilog
	delete regKeys;
end;</source>
        <access>protected</access>
    </JadeMethod>
