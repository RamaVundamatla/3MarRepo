    <JadeMethod name="voltageTypeENumToString" id="fd34f791-e216-4610-917a-f1cdbac08dca">
        <source>voltageTypeENumToString(_voltageType : Integer; _short : Boolean):String;
//--------------------------------------------------
// Created:	2 June 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _voltageType = ContainerDualVolt then
		if _short then
			return 'DV';
		else
			return ContainerDualVoltStr;
		endif;
	elseif _voltageType = ContainerSingleVolt then
		if _short then
			return 'SV';
		else	
			return ContainerSingleVoltStr;
		endif;
	elseif _voltageType = ContainerVoltNull then
		return ContainerVoltNullStr;		
	else
		return app.getErrorString(Unknown);
	endif;		

end;</source>
        <Parameter name="_voltageType" type="Integer"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="voltageTypeENumToStringObj" id="0dff55e9-2af9-4e12-8d18-aa66fc052b92">
        <source>voltageTypeENumToStringObj(_value: Integer): CM_String;
//-----------------------------------------
// Created: October 2005 By: cnwgd1
//-----------------------------------------
vars
	cmString	: CM_String;
begin
	//must be cleaned up else where - maybe use _tbl.purgeTableObjects() if going into a table
	create cmString transient;
	cmString.string := self.voltageTypeENumToString(_value, false);

	return cmString;
	
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="CM_String"/>
    </JadeMethod>
