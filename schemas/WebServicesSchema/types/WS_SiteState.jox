<Class name="WS_SiteState" id="275243f9-6cea-4a95-8d6d-97480e4b8ae8">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Repressents Site/State of the cargo in the system</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="c76baa4a-6b87-4c06-be5c-9ede27e5e51b">
        <type name="String"/>
        <access>readonly</access>
        <text>Site/State Description ex. 1= On Site, 2 = Off Site , 3 = On Ship , 4 = Site TBA</text>
    </PrimAttribute>
    <PrimAttribute name="id" id="1ba60ce4-34ff-4e7b-ba5c-eff1fd9be590">
        <type name="String"/>
        <access>readonly</access>
        <text>Site/State ID ex.1</text>
    </PrimAttribute>
    <JadeMethod name="setDetails" id="3298b045-9d0e-4478-bbd2-ca58e8a09403">
        <updating/>
        <source>setDetails(_state : Integer) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 16 December 2019
TFS#		: 46888
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin	
	self.id := _state.asStringJMT();
	self.cmObjectId := self.id;
	self.description := app.stateEnumToString(_state);
	
	if _state = TI_STATE_NORMAL  then
		self.description := "On Site";
	endif;
	
	if _state = TI_STATE_TRANSFER_FROM then 
		self.description := "Inter Terminal Transfer In Coming";
	endif;
	
	if _state = TI_STATE_TRANSFER_TO then 
		self.description := "Inter Terminal Transfer Out Going";
	endif;
	
	if _state = TI_STATE_NOTIFIED then 
		self.description := "Notified";
	endif;
end;</source>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromDesc" id="fddc4bdd-8d15-4f7c-b69a-cdf7219d7497">
        <updating/>
        <source>setDetailsFromDesc(_desc:String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 August 2010	#cnwdz2	 par25524

*/

vars

begin
	self.description := _desc;
	self.id := app.siteStringToEnum(_desc).String;
	self.cmObjectId := self.id;
epilog

end;</source>
        <Parameter name="_desc" type="String"/>
    </JadeMethod>
</Class>
