    <JadeMethod name="getAllLcs" id="802fe265-f8f9-45f4-84a7-156fbeb0b1dc">
        <source>getAllLcs( _inward : Boolean; _allLCs : CM_LCSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS	50906 

*/

vars

	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	invalid : Boolean;

begin

	if vehicle = null then
		return;
	endif;
	
	_allLCs.add( vehicle.locationsController );
	
	if _inward then
		if self.myInCMGTE_Chassis &lt;&gt; null then
			ti := self.myInCMGTE_Chassis.myTrackedItem;
		endif;
	else
		if self.myOutCMGTE_Chassis &lt;&gt; null then
			ti := self.myOutCMGTE_Chassis.getTI;
		endif;
	endif;
	
	on Exception do app.handleDeletedObject( exception, ti, invalid ); //01 Sep 2021	NDL	TSF 51864
	
	if ti &lt;&gt; null and ti.isKindOf( CM_TILC ) then
		foreach lc in ti.CM_TILC.allLCs do
			_allLCs.addNoDuplicates( lc, false );
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_allLCs" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllLoadedCargo" id="e5585554-cebe-4e23-8b8b-668bf9745ad9">
        <source>getAllLoadedCargo( _tiSet : CM_TISet input );
/*
Date		Who		Reason
11 January 2013	cnwndl1	Initial creation	Par 30921

*/
vars
	iter : Iterator;
	detail : CM_VehicleVisitRecordDetail;
	ti : CM_TrackedItem;
begin

	iter := self.allVehicleVisitRecordDetails.createIterator;
	
	while iter.next( detail ) do
		//25 Nov 2014	NDL	Par 35290 - rewrite
		if detail.recordType = VisitRecord_CargoPlaced then
			// this is a cargo load record...
			ti := detail.getExtraInfo_TrackedItem();
			
			if ti = null then
				continue;
			endif;
			
			if not _tiSet.includes( ti ) then
				_tiSet.add( ti );
			endif;
			
		elseif detail.recordType = VisitRecord_CargoRemoved then
			// this is a cargo UNload record...
			ti := detail.getExtraInfo_TrackedItem();
			
			if ti = null then
				continue;
			endif;
			
			if _tiSet.includes( ti ) then
				_tiSet.remove( ti );
			endif;
		endif;
		
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllReceivedReleasedTIs" id="33f2e625-3746-42f4-87dd-c3253d714d4d">
        <source>getAllReceivedReleasedTIs() : CM_TISet;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/11/2011	cnwdap1	Initial creation CCMS SFW 1261 PAR #28733
*/
vars
	allTIs : CM_TISet;

begin
	create allTIs transient;
	self.allReceivedTrackedItems.copy(allTIs);
	//self.allReleasedTrackedItems.copy(allTIs);
	self.allReleasedTrackedItems.copyNoDupsToCol(allTIs, false);	//01 May 2018	NDL	TFS 38319
	return allTIs;
epilog

end;</source>
        <ReturnType type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="getAllReleaseContainerEntities" id="866d50c5-7cd5-4289-b530-6c2f4e70d127">
        <source>getAllReleaseContainerEntities(_releaseContainers : ObjectSet input);
/*

Date		Who		Reason
14 July 2014	cnwer1	Initial creation PAR

*/

vars
	gteEntity : CMGTE_Entity;
begin
	if _releaseContainers = null then
		return;
	endif;
	
	foreach gteEntity in self.allGateEntities where gteEntity.isKindOf(CMGTE_Release) do
		if gteEntity = self.myOutCMGTE_Chassis then
			continue;
		endif;
		
		if gteEntity.isContainer then
			_releaseContainers.add(gteEntity);
		endif;		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_releaseContainers" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getArrivalAGateVRD" id="cea4fc14-529f-4e84-9201-3c850d6236c8">
        <source>getArrivalAGateVRD():CM_VehicleVisitRecordDetail;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	cnwrd1	Initial creation

*/


// ---------------------------------------------------------------------------
// Created:     19 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  None
// Returns:     The last VVRD with record type VehicleVisit_GateOut
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Apr 2025  navma1  	MTN-34621 MTN - 1081 dead lock on CM_EIRNumberDict
// ---------------------------------------------------------------------------
vars
	detail	: CM_VehicleVisitRecordDetail;
begin
	foreach detail in self.allVehicleVisitRecordDetails discreteLock do
		if detail.recordType = VisitRecord_Arrive_AGate then
			return detail;
		endif;
	endforeach;
	
	return null;
epilog
end;</source>
