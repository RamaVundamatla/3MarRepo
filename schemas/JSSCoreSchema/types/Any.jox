<PrimType name="Any">
    <JadeMethod name="jssIsBetween" id="ed0b0734-30bb-47ae-ab19-2644c43c9745">
        <source>jssIsBetween(pLowCriteria:Any; pHighCriteria:Any):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.jssIsGreaterThanOrEqual(pLowCriteria) and self.jssIsLessThanOrEqual(pHighCriteria));
end;</source>
        <text>___________________________________________________________________________

