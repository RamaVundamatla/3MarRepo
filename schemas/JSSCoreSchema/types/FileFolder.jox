<Class name="FileFolder">
    <JadeMethod name="jssCopy" id="c95f43d4-93c7-4e1d-9d80-8d34ae89b9bc">
        <updating/>
        <source>jssCopy(pTarget: String):Boolean updating;
// -----------------------------------------------------------------------------
// Created:		17 January 2002 by cnwdad1
//
// Purpose:		Copies the receiver's file directory to the specified file name.
//				The entire contents of the directory will also be copied.
//
// Parameters:	pTarget - The name of the direcory to copy the receiver to.
//
// Returns:		True if the copy was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	directoryObj	: FileFolder;
	fileNodeObj		: FileNode;
	allFiles		: FileNodeArray;
	isSuccessful	: Boolean;
	
begin
	isSuccessful	:=	false;
	
	create directoryObj transient;
	
	directoryObj.fileName	:=	pTarget;
	directoryObj.make();
	
	if directoryObj.isAvailable() then
		allFiles	:=	self.files();
		
		foreach fileNodeObj in allFiles do
			isSuccessful	:=	fileNodeObj.jssCopy(pTarget &amp; global.jssGetFileSeparator() &amp; fileNodeObj.name);
			
			if (not isSuccessful) then
				break;
			endif;
		endforeach;
	endif;
epilog
	delete directoryObj;
	
	return isSuccessful;
end;</source>
        <Parameter name="pTarget" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssGetAllFileNames" id="73d4f4c1-9bd0-480e-b25e-c025d604e144">
        <updating/>
        <source>jssGetAllFileNames(pFileNameArray:JSSArray io; pIsIncludeSubdirectories:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		11 October 2000 by cnwdad1
//
// Purpose:		This method will return a list of all file names contained within
//				the receiver (recursively if subdirectories are to be included).
//
// Parameters:	pFileNameArray - The array of file names.
//				pIsIncludeSubdirectories - If true, then subdirecorties will also
//					be scanned.
//
// Returns:		The IO pFileNameArray parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileNodeObj	: FileNode;
	allFiles	: FileNodeArray;
	
begin
	allFiles	:=	self.files();
	
	foreach fileNodeObj in allFiles do
		if fileNodeObj.isKindOf(File) then
			pFileNameArray.addString(fileNodeObj.File.fileName);
		elseif fileNodeObj.isKindOf(FileFolder) and pIsIncludeSubdirectories then
			fileNodeObj.FileFolder.jssGetAllFileNames(pFileNameArray, pIsIncludeSubdirectories);
		endif;
	endforeach;
end;</source>
        <Parameter name="pFileNameArray" type="JSSArray" usage="io"/>
        <Parameter name="pIsIncludeSubdirectories" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssGetAttributes" id="db1c1924-8b20-4f7b-bdc1-877925b95b64">
        <source>jssGetAttributes(): String;
// -----------------------------------------------------------------------------
// Created:		18 January 2002 by cnwdad1
//
// Purpose:		Reimplementation of superclass method.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	fileResult	: Integer;

begin
	if app.isUnicode() then
		fileResult	:=	call jssGetFileAttributesW(self.fileName);
	else
		fileResult	:=	call jssGetFileAttributesA(self.fileName);
	endif;
epilog
	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssIsFolder" id="c53a5890-84ef-4572-9534-b411f3238950">
        <source>jssIsFolder(): Boolean;
// -----------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		Reimplementation of superclass method.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssMove" id="2f4139f7-7d72-4523-9ef5-d0a1a1122207">
        <updating/>
        <source>jssMove(pTarget: String): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		17 January 2002 by cnwdad1
//
// Purpose:		Moves the receiver's file directory to the specified directory
//				name.  The entire contents of the directory will also be moved.
//
// Parameters:	pTarget - The name of the direcory to move the receiver to.
//
// Returns:		True if the move was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	isSuccessful	: Boolean;
	
begin
	isSuccessful	:=	false;
	isSuccessful	:=	self.jssCopy(pTarget);
	
	if isSuccessful then
		isSuccessful	:=	self.jssRemove();
	endif;
epilog
	return isSuccessful;
end;</source>
        <Parameter name="pTarget" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssRemove" id="6bccf46e-6b91-42e9-ad0e-cc23904df9b9">
        <updating/>
        <source>jssRemove():Boolean updating;
// -----------------------------------------------------------------------------
// Created:		17 January 2002 by cnwdad1
//
// Purpose:		Deletes the receiver's file directory from disk.  The entire
//				contents of the directory will also be deleted.  The directory
//				and its contents are physically deleted, and so cannot be restored
//				from the Windows' Recycle Bin.
//
// Parameters:	None.
//
// Returns:		True if the delete was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	fileNodeObj		: FileNode;
	allFiles		: FileNodeArray;
	isSuccessful	: Boolean;
	
begin
	isSuccessful	:=	false;
	allFiles		:=	self.files();
	
	if allFiles.isEmpty() then
		self.purge;
		isSuccessful	:=	true;
	else
		foreach fileNodeObj in allFiles do
			isSuccessful	:=	fileNodeObj.jssRemove();
			
			if (not isSuccessful) then
				break;
			endif;
		endforeach;
		
		if isSuccessful then
			isSuccessful	:=	false;
			self.purge;
			isSuccessful	:=	true;
		endif;
	endif;
epilog
	return isSuccessful;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
