    <JadeMethod name="doOK" id="5c10c95b-d0c5-4f4c-9b85-7923135d3a5a">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2010	cnwer1	Initial creation

*/

vars
	viewName : String;
	isSystem	: Boolean;
begin

	viewName:=self.getViewName();
	isSystem:=self.getIsSystem();
	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	self.myTAViewInterface.validateNewView(viewName,isSystem);
	
	self.myTAViewInterface.addNewView(viewName,isSystem);
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="enablePrivate" id="db9e7b73-e474-42c6-8e84-eb0fa2a93df8">
        <source>enablePrivate(_enable : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwer1	Initial creation

*/

vars

begin
	self.optPrivate.enabled:=_enable;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getIsSystem" id="5483b9d6-b842-4457-931d-252113e237e1">
        <source>getIsSystem() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2010	cnwer1	Initial creation

*/

vars

begin
	return self.optSystem.value;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
