    </JadeMethod>
    <JadeMethod name="setTrxTest" id="2c6f26a4-ef6e-44ea-a84c-70824d72daf1">
        <source>setTrxTest();
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myTrxTest.createValidationExceptions	:= chkValError.value;
	self.myTrxTest.createValidationWarnings1	:= chkValWarnA.value;
	self.myTrxTest.createValidationWarnings2	:= chkValWarnB.value;
	self.myTrxTest.createValidationJadeException:= chkValJadeEx.value;
	self.myTrxTest.lockValidationA				:= chkValLockA.value;
	self.myTrxTest.lockValidationB				:= chkValLockB.value;

	self.myTrxTest.createUpdateJadeException	:= chkUpdJadeEx.value;
	self.myTrxTest.lockUpdateA		:= chkUpdLockA.value;
	self.myTrxTest.lockUpdateB		:= chkUpdLockB.value;
	self.myTrxTest.createUpdateWarnings1		:= chkUpdGenWarn1.value;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f190bd54-5807-48cf-8c39-e4214d1fc023">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008236, locale);
	btnAddAck.translateCaption(Xlat_0001089, locale);
	btnAddSimple.translateCaption(Xlat_0001090, locale);
	btnBackground.translateCaption(Xlat_0001091, locale);
	btnClose.translateCaption(Xlat_0001092, locale);
	btnDeleteAck.translateCaption(Xlat_0001093, locale);
	btnDeleteSimple.translateCaption(Xlat_0001087, locale);
	btnSavePreTrxVal.translateCaption(Xlat_0001086, locale);
	btnUpdateAck.translateCaption(Xlat_0001094, locale);
	btnUpdateSimple.translateCaption(Xlat_0001088, locale);
	chkExCM.translateCaption(Xlat_0001095, locale);
	chkExJade.translateCaption(Xlat_0001096, locale);
	chkLockA.translateCaption(Xlat_0001097, locale);
	chkLockB.translateCaption(Xlat_0001098, locale);
	chkUpdGenWarn1.translateCaption(Xlat_0001099, locale);
	chkUpdJadeEx.translateCaption(Xlat_0001100, locale);
	chkUpdLockA.translateCaption(Xlat_0001101, locale);
	chkUpdLockB.translateCaption(Xlat_0001102, locale);
	chkValError.translateCaption(Xlat_0001103, locale);
	chkValJadeEx.translateCaption(Xlat_0001104, locale);
	chkValLockA.translateCaption(Xlat_0001105, locale);
	chkValLockB.translateCaption(Xlat_0001106, locale);
	chkValWarnA.translateCaption(Xlat_0001107, locale);
	chkValWarnB.translateCaption(Xlat_0001108, locale);
	chkWarningsAck.translateCaption(Xlat_0001109, locale);
	grpExHandler.translateCaption(Xlat_0001110, locale);
	grpLocks.translateCaption(Xlat_0001111, locale);
	grpProfiles.translateCaption(Xlat_0001112, locale);
	grpSaveAck.translateCaption(Xlat_0001113, locale);
	grpSaveSimple.translateCaption(Xlat_0001114, locale);
	grpUpdate.translateCaption(Xlat_0001115, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="05f993e9-bbaa-44b1-99e7-05dd7b13fff4">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:     12 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myTestLockObjectA &lt;&gt; null then
		unlock(self.myTestLockObjectA);
	endif;
	if self.myTestLockObjectB &lt;&gt; null then
		unlock(self.myTestLockObjectB);
	endif;
	
	delete self.myTrxTest;
	
	inheritMethod;

end;</source>
    </JadeMethod>
