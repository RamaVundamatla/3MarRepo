    </JadeMethod>
    <JadeMethod name="canTwinLiftWithLocation" id="555ce3a8-f079-4360-92d5-e5cf6de228a9">
        <source>canTwinLiftWithLocation(_nextLocation: CM_LocationsController; 
						_myTrackedItem: CM_TrackedItem; 
						_nextLocationTrackedItem: CM_TrackedItem;
						_mode		: Integer;
						_direction  : Integer output;
						_errorString : String io): Boolean;
/*

Purpose:			

Parameters:		the _mode flag is only relevant for grid controllers basically if queue_mode of _tis are null 
					will get numTis + getAllPickedUpQueuedMoves but we need to pass in tis to make sure the picked up or queued moves for these tis are not counted
					
				Real mode just checks the position of the tis in the stack

Return Value:		


Date		Who		Reason
05 February 2009	cnwer1	Initial creation

*/

vars
	myTIHeight,
	nextTIHeight : Real;
	isPrev		 : Boolean;
begin

	if not inheritMethod(_nextLocation,_myTrackedItem,_nextLocationTrackedItem,_mode,_direction,_errorString) then
		return false;
	endif;
	
	_direction:=CM_RTQueueEntry.TWIN_NONE;
	
	
	if not _nextLocation.isKindOf(CM_GridController) then
		_errorString:=app.getErrorString(Next_locatio_gridded_locatio);
		return false;
	endif;
	
	//need to check the currentSourceLC previous controller is equal to the priorSource LC
	
	/*if process.isRJD or app.cnwkpd1_IsUser then*/

	if _myTrackedItem = null then
		//we have a director task can twin
		_direction:=CM_RTQueueEntry.TWIN_BOTH;	
		return true;
	endif;
	
	
	if _myTrackedItem &lt;&gt; null and _nextLocationTrackedItem &lt;&gt; null then
		if  self.myNextController &lt;&gt; _nextLocation and self.myPreviousController &lt;&gt; _nextLocation then
			//write "myNext controller &lt; &gt; next Loc";
			_errorString:=app.getErrorString(Next_location_adjacent);
			return false;
		endif;
	endif;
/*	else
		if self.myNextController &lt;&gt; _nextLocation and self.myPreviousController &lt;&gt; _nextLocation then
			//write "myNext controller &lt; &gt; next Loc";
			_errorString:=app.getErrorString(Next_location_adjacent);
			return false;
		endif;
	endif;*/
	
	isPrev:=  self.myPreviousController = _nextLocation;
	
	
	if not self.isKindOf(CM_GantryICAreaLaneController) then
		if isPrev then
			if not self.canTwinLiftWithPrevController then
				_errorString:=app.getErrorString(Twin_lift_with_prior_gridd_loc);
				return false;
			endif;
				
				
			if not _nextLocation.CM_GridController.canTwinLiftWithNextController then
				_errorString:=app.getErrorString(Secon_locat_twin_lift_with_nex);
				return false;
			endif;
		
		else
		
			if not self.canTwinLiftWithNextController then
				_errorString:=app.getErrorString(Twin_lift_with_next_gridd_loca);
				return false;
			endif;
				
				
			if not _nextLocation.CM_GridController.canTwinLiftWithPrevController then
				_errorString:=app.getErrorString(Next_locat_twin_lift_with_prio);
				return false;
			endif;
		
		endif;
	endif;

	if _myTrackedItem &lt;&gt; null and _mode = REAL_MODE then
		
		if self.allTrackedItems.indexOf( _myTrackedItem) = 0 then
			_errorString:=app.getErrorString1(Container_this_location,_myTrackedItem.id);
			return false;
		endif;
		
		myTIHeight:=self.getActualStackHeightOfTI(_myTrackedItem);
	elseif _mode = QUEUE_MODE then
		myTIHeight:=self.getActualHeight + self.getActualHeightOfPickupQdMoves(_myTrackedItem);
	endif;
	
	
	if _nextLocationTrackedItem &lt;&gt; null and _mode = REAL_MODE  then
		
		if _nextLocation.allTrackedItems.indexOf(_nextLocationTrackedItem) = 0 then
			_errorString:=app.getErrorString1(Container_next_location,_nextLocationTrackedItem.id);
		//	write "height = 0 ";
			return false;
		endif;
		nextTIHeight:=_nextLocation.CM_GridController.getActualStackHeightOfTI(_nextLocationTrackedItem);
	elseif _mode = QUEUE_MODE then
		nextTIHeight:=_nextLocation.CM_GridController.getActualHeight + _nextLocation.getActualHeightOfPickupQdMoves(_nextLocationTrackedItem);
	endif;
	

	if _nextLocationTrackedItem &lt;&gt; null and  myTIHeight &lt;&gt; nextTIHeight then
		_errorString:=app.getErrorString(Contain_stack_heights_differe);
		return false;
	endif;
	
	if isPrev then
		_direction:=CM_RTQueueEntry.TWIN_PREV;
	else
		_direction:=CM_RTQueueEntry.TWIN_NEXT;
	endif;
	return true;

epilog

end;</source>
        <Parameter name="_nextLocation" type="CM_LocationsController"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_nextLocationTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_direction" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeTrackedItemSize" id="2bf5a3a3-1594-4218-bfd6-757e05773a03">
        <updating/>
        <source>changeTrackedItemSize(moveMode: Integer; ti: CM_TrackedItem input; 
					originalHeight, originalLength : Integer;
					_passport : CM_Passport input) updating;
/*
 ------------------------------------------------------------------------
Created:			03 December 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	isTopTI : Boolean;
	control : CMIF_MoveController;
	newHeight	: Integer;
	newLength 	: Real;
	overstowingTIs : CMIF_RTSortByPosDict;
	nextHeight : Integer;
	thisStackHeight : Integer;
	tiSort		: CMIF_RTSort;
begin

	inheritMethod(moveMode, ti, originalHeight, originalLength, _passport);
	
	// PAR 16415 CCMS 1029
	//	newLength := ti.getLengthInUnits();
	newLength := ti.getActualLength();
	
	newHeight := ti.getHeightOfTI();
	isTopTI := self.isTopTI(ti, moveMode);
	//----------------------
	// If there is no height or length size change then ...nothing to do...
	//----------------------
	if ( (newHeight = originalHeight) and (newLength = originalLength) ) then
		return;
	endif;
	//-----------------------------
	// See if height attribute has changed...
	//-----------------------------
	if originalHeight &lt;&gt; newHeight then
		//---------------
		// Check to see if we have overstowed items...
		//---------------
		if isTopTI = false then
			create overstowingTIs transient;
			self.getOverstowedByTIs(moveMode, ti, overstowingTIs, false);
			//------------------
			//That are connected..
			//------------------
			foreach tiSort in overstowingTIs do
				if tiSort.myTi.isAttributeTrue(TI_Attrib_IsConnected) then
					app.setContinueCMExceptions(false);
					app.raiseCMException(ERR_MORPH_OS_CONNECTED, null, null);
					return;
				endif;
			endforeach;
		endif;
		//------------------
		// Check to see that our new height will not burst out the top of the stack.
		//------------------
		if (newHeight &gt; originalHeight) then
			if (self.getStackHeightOfTIs(moveMode, null) + newHeight - originalHeight) &gt; self.myGridArea.heightOfStack  then
				app.setContinueCMExceptions(false);
				app.raiseCMException(ERR_MORPH_STACK_FULL, null, null);
				return;
			endif;
		endif;
	endif;		
	//-----------------------------------------------------------------------
	// See if length attribute has changed...
	//-----------------------------------------------------------------------
	create control transient;
	control.setMyTrackedItem(ti);
	control.setMyToPrimaryLocation(self);
	control.setMoveMode(moveMode);
	control.setMyOriginatingLocation(self);
	control.isSystemMove := true;
	control.isResizing := true;
	//cnwth2a added this to ignore same position warning
	control.isForcedMove := true;
	
	if not self.getSpannedToLCs(control) then
		//Not enough space!
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_MORPH_40_NO_PAD,  null, null);
		return;	
	endif;
	
	if newLength &gt; originalLength then
		//--------------------
		//Expanding TI
		//--------------------
		if newLength &gt; 20 then // PAR 16415 CCMS 1029 was 2
			//---------------------
			//Make sure the stack in the SAME position next door is MT
			//---------------------
			nextHeight := self.myNextController.getStackHeightOfTIs(moveMode, ti); // PAR 16415 CCMS 1029 added 'ti'
			if nextHeight = 0 then
				//--------------------
				//Next is MT, this is OK provided WE are NOT &gt; the original height
				//--------------------
				if newHeight &gt; originalHeight then
					//--------------------
					//This message is not strictly right, its the FRONT end thats bad.
					//--------------------
					app.setContinueCMExceptions(false);
					app.raiseCMException(ERR_MORPH_40_FLOATING, null, null);			
					return;
				endif;
			endif;
			thisStackHeight := self.getStackHeightOfTIs(moveMode, null);
			thisStackHeight := thisStackHeight - ti.getHeightOfTI();	//Deduct the height of ME
			
			if nextHeight &gt; thisStackHeight then
				app.setContinueCMExceptions(false);
				app.raiseCMException(ERR_MORPH_40_OCCUPIED, null, null);			
				return;
			elseif nextHeight &lt; thisStackHeight then
				app.setContinueCMExceptions(false);
				app.raiseCMException(ERR_MORPH_40_FLOATING, null, null);			
				return;
			else
				//they are ==, this is Fine.
			endif;
		endif;
	else
		//------------------
		//Contracting in size. Check if overstowed...
		//------------------
		if ti.isOverStowed(moveMode) then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_MORPH_40_OVERSTOWED, null, null);
			return;
		endif;
	endif;
	//----------------
	//Do the move.	
	//----------------
	control.warningsHaveBeenAcknowledged := true;
	control.executeMove(_passport);

epilog
	delete overstowingTIs;
	delete control;
end;</source>
        <Parameter name="moveMode" type="Integer"/>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="originalHeight" type="Integer"/>
        <Parameter name="originalLength" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkBackEndsOK" id="e182cfb0-2338-42fd-845b-6570e03466d3">
        <updating/>
        <source>checkBackEndsOK(length : Integer) : Boolean updating;
/*

Purpose:		Checks where any backends finish so we know if we can fit in another
				container

Parameters:		Length of containert we are testing for 	

Return Value:	True if container can start here else false	


Date		Who		Reason
29 August 2008	conkc1	Initial creation

*/
vars
	container               : CM_Container;
	trackedItem             : CM_TrackedItem;

begin

	trackedItem := self.allTrackedItemOSBackEnds.first;
	if trackedItem = null then
		return true;
	endif;
	if trackedItem.isKindOf(CM_Container) = false then
		return false;
	endif;
	
	container := trackedItem.CM_Container;
	if length = 30 then
		if container.is30 then
			return true;
		else
			if container.is53 = true and self.offset53 = -1 then
				return false;
			endif;
			if self.offset30 &gt;= self.offset45 and self.offset30 &gt;= self.offset53 then
				return true;
			else
				return false;
			endif;
		endif;	
	endif;

	if length = 45 then
		if container.is45 then
			return true;
		else
			if container.is30 = true and self.offset30 = -1 then
				return false;
			endif;
			if container.is53 = true and self.offset53 = -1 then
				return false;
			endif;
			if self.offset45 &gt;= self.offset30 and self.offset45 &gt;= self.offset53 then
				return true;
			else
				return false;
			endif;
		endif;	
	endif;

	if length = 53 then
		if container.is53 then
			return true;
		else
			if container.is30 = true and self.offset30 = -1 then
				return false;
			endif;
			if container.is45 = true and self.offset45 = -1 then
				return false;
			endif;
			if self.offset53 &gt;= self.offset30 and self.offset53 &gt;= self.offset45 then
				return true;
			else
				return false;
			endif;
		endif;	
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="length" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkFor4Controller53Footer" id="2ad886e5-1d97-403b-99dd-655ea0f16bac">
        <updating/>
        <source>checkFor4Controller53Footer(length : Integer) : Boolean updating;
/*

Purpose:		Checks if a 53 foot container is across 4 controllers
				The last of these controllers knows nothing of this so we need to
				get the prior controller and check

Parameters:			

Return Value:	True if Ok to store container, False if not	


Date		Who		Reason
02 September 2008	conkc1	Initial creation

*/

vars
	priorGC     : CM_LocationsController;
	trackedItem : CM_TrackedItem;

begin
	if self.is53ft = false then
		return true;
	endif;
	//
	// Special code to handle a 53 foot which offset into this LC is 6
	//
	if self.offset53 = 6 then
		priorGC := self.myPreviousController;
		if priorGC &lt;&gt; null then
			if priorGC.is53ft = true then
				trackedItem := priorGC.CM_GridController.allTrackedItemOSBackEnds.first;
				if trackedItem = null then
					return true;
				endif;
				if trackedItem.isKindOf(CM_Container) and trackedItem.CM_Container.is53 = true then
					//
					// 30 and 45 foot containers must start after offset (6)
					//
					if (length = 45 and self.offset45 &gt;= self.offset53) or 
					   (length = 30 and self.offset30 &gt;= self.offset53) then
						return true;
					else
						return false;
					endif;
				else
					return true;
				endif;
			endif;
		endif;
	else
		return true;
	endif;
epilog

end;</source>
        <Parameter name="length" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkMyEndsOK" id="f220b212-cdba-418e-9ed4-56e4994d3b8a">
        <updating/>
        <source>checkMyEndsOK(length : Integer; container : CM_Container) : Boolean updating;
/*

Purpose:			Called for 30 and 45 foot containers to check if the end
					of this container does not overlap the next one

Parameters:			length - length of the source container, 
					container - source container

Return Value:		


Date		Who		Reason
01 September 2008	conkc1	Initial creation

*/
vars

begin
	if length = 30 then
		if container.is30 then
			return true;
		endif;
		if self.offset30 = -1 then 
			return false;  // needs all the LC so get out
		endif;
		if container.is45 then
			if self.offset30 &lt;= self.offset45 then
				return true;
			else
				return false;
			endif;
		else
			if self.offset30 &lt;= self.offset53 then
				return true;
			else
				return false;
			endif;
		endif;
	elseif length = 45 then
		if container.is45 then
			return true;
		endif;
		if self.offset45 = -1 then 
			return false;  // needs all the LC so get out
		endif;
		if container.is30 then
			if self.offset45 &lt;= self.offset30 then
				return true;
			else
				return false;
			endif;
		else
			if self.offset45 &lt;= self.offset53 then
				return true;
			else
				return false;
			endif;
		endif;
	else
		return false;
	endif;
epilog

end;</source>
        <Parameter name="length" type="Integer"/>
        <Parameter name="container" type="CM_Container"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="column" id="ca4e4b12-4103-43ae-8d16-ec5669c8b6ea">
        <methodInvocation>mapping</methodInvocation>
        <source>column(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.myGridColumn &lt;&gt; null then
		_value := self.myGridColumn.column;
	else
		_value := 0;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createTALocationsAudits_Avail" id="d4063dab-c907-4934-8631-acd153f412e6">
        <updating/>
        <source>createTALocationsAudits_Avail(_proxy :SelfType; _ta :CM_GridArea) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 March 2011 by cnwcs5 CCMS CPL 2027 / PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oldValue, newValue	:Boolean;
begin 
	self.raiseExceptionIfTransient (method);
		
	oldValue := self.amIAvailable;
	newValue := _proxy.amIAvailable;
	
	if oldValue = newValue then
		return;
	endif;

	if newValue then 
		// has become available
		app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_LocationAvail, 
														AuditCreated, CM_AuditTALocations.AuditDetail_FullyAvailable);
	else 
		app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_LocationUnavail, 
														AuditCreated, CM_AuditTALocations.AuditDetail_NotAvailable);
	endif;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_ta" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="createTALocationsAudits_Twin" id="793d1ef6-f1e9-4c15-b562-f74420a04c75">
        <updating/>
        <source>createTALocationsAudits_Twin(_proxy :SelfType; _ta :CM_GridArea) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 March 2011 by cnwcs5 CCMS CPL 2027 / PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newValue, oldValue	:Boolean;
begin 
	self.raiseExceptionIfTransient (method);
	
	oldValue := self.canTwinLiftWithNextController;
	newValue := _proxy.canTwinLiftWithNextController;
	
	if oldValue &lt;&gt; newValue then 
		if newValue then 
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_TwinLiftDefn, 
														AuditCreated, CM_AuditTALocations.AuditDetail_TwinWithNext);
		else 
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_TwinLiftDefn, 
														AuditDeleted, CM_AuditTALocations.AuditDetail_TwinWithNext);
		endif;	
	endif;
	
	oldValue := self.canTwinLiftWithPrevController;
	newValue := _proxy.canTwinLiftWithPrevController;
	
	if oldValue &lt;&gt; newValue then 
		if newValue then 
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_TwinLiftDefn, 
														AuditCreated, CM_AuditTALocations.AuditDetail_TwinWithPrev);
		else 
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_TwinLiftDefn, 
														AuditDeleted, CM_AuditTALocations.AuditDetail_TwinWithPrev);
		endif;	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_ta" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="createTALocationsAudits_Usage" id="d9ae9a74-986e-4e5a-b02e-37e6014c5fd4">
        <source>createTALocationsAudits_Usage(_proxy :SelfType; _ta :CM_GridArea)protected;
// ---------------------------------------------------------------------------
// Created:     09 March 2011 by cnwcs5 CCMS CPL 2017/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oldValue, newValue :Integer;
begin
	self.raiseExceptionIfTransient (method);

	oldValue	:= self.getUsage;
	newValue	:= _proxy.getUsage;
	
	if oldValue = newValue then
		return;
	endif;
	
	if oldValue = REEFERGANTRY_USE then
		// must have removed Reefer Gantry
		app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_ReeferGantry, 
																	AuditDeleted, null);
	elseif newValue = REEFERGANTRY_USE then
		// must have added Reefer Gantry
		app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_ReeferGantry, 
																	AuditCreated, null);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_ta" type="CM_GridArea"/>
    </JadeMethod>
