		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(temperatureReading) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased temperatureReading: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;temperatureReading.String&amp;" "&amp;temperatureReading.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		temperatureReading.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " temperatureReading erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deleteTowerTransactions" id="65faadac-5ea2-4f35-ba4e-c5b2f209c37d">
        <updating/>
        <source>deleteTowerTransactions(_setTime : TimeStamp) updating;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count1,count2,count3 : Integer;
	tower : CM_Tower;
	iter : Iterator;
	size1, size2 : String;
	ti : CM_TrackedItem;
	trans : CM_TITransaction;
    array : CM_TIArray;
    transDict : CM_TransactionArray;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Towers..."); 
	if self.abortStatus = true then
		return;			
	endif;

	create array transient;
	create transDict transient;

	CM_Tower.allInstances(array,0,true); 
	//iter := array.createIterator;
	size1 := array.size.userNumberFormat($CNEC_NO_DECIMALS);
	count1 := 0;
	self.monitor("Checking " &amp; size1 &amp; " Towers for transactions to delete...");
	if self.abortStatus = true then
		return;			
	endif;
    on Exception do self.tiEraseExceptionHandler(exception);
	foreach ti in array do
		beginTransaction;
        tower := ti.CM_Tower;
		count1 := count1 + 1;
		//Sorry, but it is 10x faster to do it this way than have a cleanup
        //method on the tower object.....
		transDict.clear;
		delete iter;			// PAR #26678
        iter := tower.allTransactions.createIterator;
        count2 := 0;
		lastCommit := app.relativeMachineTime();
		while iter.next(trans) do
			if trans.dateTime &lt; _setTime then
				if trans.class = CM_Connect or 
				   trans.class = CM_ConnectPower or
				   trans.class = CM_ConnectTower or 
				   trans.class = CM_DisconnectPower or
				   trans.class = CM_DisconnectTower then
					transDict.add(trans);
					count2 := count2 + 1;
//					if count2 mod 1000  = 0 then
					now := app.relativeMachineTime();
					if now - lastCommit &gt; MaxTransactionTime then
						lastCommit := app.relativeMachineTime();
						self.monitor("Tower trans checked: " &amp; count2.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size1
							&amp; ". Tower trans to erase: " &amp; transDict.size.userNumberFormat($CNEC_NO_DECIMALS));
						if self.abortStatus = true then
							return;							//Exits here can just go straight back
						endif;
					endif;
				endif;
			elseif trans.dateTime &gt; _setTime then	//No point checking the rest
				break;
			endif;
		endwhile;

		delete iter;			// PAR #26678
		iter:= transDict.createIterator;
		size2 := transDict.size.userNumberFormat($CNEC_NO_DECIMALS);
		count3 :=  0;
		lastCommit := app.relativeMachineTime();
		while iter.next(trans) do
//			if count3 mod 100 = 0 then
			now := app.relativeMachineTime();
			if now - lastCommit &gt; MaxTransactionTime then
				lastCommit := app.relativeMachineTime();
				commitTransaction;		//Commit every 50 items
				self.monitor("Erased Tower trans deleted: " &amp; count3.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size2);
				if self.abortStatus = true then
					return;
				endif;
				beginTransaction;
			endif;
//			app.writeLog("Deleting "&amp;trans.myTrackedItem.id&amp;" "&amp;trans.String,0); 
			if not process.isInTransactionState then
				beginTransaction;
			endif;
			trans.erase(NORMAL_ERASE);
			if process.isInTransactionState then
				count3 := count3 + 1;
			endif;
		endwhile;

//		self.monitor("Cleaning up " &amp; tower.id &amp; " : " &amp; transDict.size..userNumberFormat($CNEC_NO_DECIMALS) &amp; " transactions removed"); 

	 	commitTransaction;
 		//abortTransaction;
		self.monitor("Towers: " &amp; count1.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size1
			&amp; " have been processed");
		if self.abortStatus = true then
			return;			
		endif;
	endforeach;

epilog
	delete iter;
	delete array;
	delete transDict;
	on Exception do null;	
	
end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deleteUnusedVessels" id="4611fb19-6f19-4b0e-8bf1-e571c1086d93">
        <updating/>
        <source>deleteUnusedVessels() updating;

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	vessel : CM_Vessel;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Vessel..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	CM_Vessel.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " Vessel for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach obj in objArray do
		vessel := obj.CM_Vessel;
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("Vessel checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". Vessel to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if vessel.allVoyageGlobals.size = 0 and
		   vessel.myRootForVesselClass = null and
		   vessel.myHMSVesselData = null then
			dict.add(vessel);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(vessel) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased Vessel: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
		app.writeLog("Deleting "&amp;vessel.String&amp;" "&amp;vessel.String,0); 
//		vessel.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " Vessel erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteVehicleVisitRecord" id="a0d0df64-d4cf-4624-9eec-d1c73069f53e">
