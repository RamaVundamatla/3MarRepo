    <JadeMethod name="doBuildMTypesCombo" id="6e92c295-b718-49ef-98f4-42208177203d">
        <updating/>
        <source>doBuildMTypesCombo() updating;
/*
Purpose:			

Date		Who		Reason
15 July 2021	navab1	TFS 51515
*/

vars
	measureType : CM_MeasurementType;
	default, idx : Integer;
begin
	self.cmbMeasurementTypes.clear;
	self.cmbMeasurementTypes.sorted := true;
	
	foreach measureType in app.myRoot.allMeasurementTypesByShortName where measureType.isAvailableForEntry and measureType.isDisplay and measureType.isWeight do
		idx := self.cmbMeasurementTypes.addItem(measureType.measurementType &amp; " - " &amp; measureType.shortName);
		self.cmbMeasurementTypes.itemObject[idx] := measureType;
		if measureType.isDefault then
			default := idx;
		endif;
	endforeach;

	if default &gt; 0 then
		self.cmbMeasurementTypes.listIndex := default;
		self.filterWeightMeasType := self.cmbMeasurementTypes.listObject.CM_MeasurementType;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEdit" id="1ff164dd-9cf3-4094-81ea-4e01fead9c5c">
        <source>doEdit();
/*
Purpose:			

Date		Who		Reason
03JUN2021	NAVAB1	TFS 51219
*/

vars

	form : CMUI_LocationActivityMaint;
	rowIndex : Integer;
	obj : Object;
	edition : Integer;
	invalid : Boolean;
	locActivity : CMEVT_LocationActivity;

begin

	on Exception do app.handleDeletedObject( exception, obj, invalid );

	rowIndex := self.tblLocActivity.row;
	if rowIndex &lt;= self.tblLocActivity.rows then
		obj := self.tblLocActivity.accessRow( rowIndex ).itemObject;
		if obj &lt;&gt; null then
			edition := obj.edition;
			if invalid then
				return;
			endif;
			locActivity := obj.CMEVT_LocationActivity;
			if not locActivity.isAbleToBeEdited then
				return;
			endif;
		endif;
	endif;
	
	if locActivity &lt;&gt; null then
		create form transient;
		form.setMyTerminal( self.myTerminal );
		form.setMyLocationActivity( locActivity );
		form.setParentForm(self);  // ### TFS 51515 13JUL2021 NAVAB1
		form.centreOverParent(0); // ### TFS 51515 13JUL2021 NAVAB1
		form.showModal();
	endif;

epilog

	delete form;

end;</source>
    </JadeMethod>
    <JadeMethod name="doFind" id="345f3639-c83d-4a0c-82fd-d0fd39978b1c">
        <updating/>
        <source>doFind() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	startDate : Date;
	endDate : Date;
	nomalStartTime : Time;
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	
	startTimeStamp : TimeStamp;
	
	user : CM_User;
	
	qDef : CM_QueryDefinition;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerLocationAct;
	dateArray : DateArray;
	criteriaLine : CM_SelectorCriteriaLine;
	locActivity : CMEVT_LocationActivity;
	atLimit : Boolean;
	
	msg : String;

begin

	self.allLocationActivityByDate.clear();
	self.allLocationActivitySet.clear();
	self.numItemsShown := 0;
	self.filterWeightMeasType := self.cmbMeasurementTypes.listObject.CM_MeasurementType; // ### TFS 51515 13JUL2021 NAVAB1
	
	user 	 := app.getMyUser();

	startDate := self.txtOpenDate.getDate;
	endDate := self.txtCloseDate.getDate;
	if self.cmbTerminalArea.listIndex &gt; 0 then
		ta := self.cmbTerminalArea.itemObject[ self.cmbTerminalArea.listIndex ].CM_TerminalArea;
	endif;
	if self.cmbLocation.listIndex &gt; 0 then
		lc := self.cmbLocation.itemObject[ self.cmbLocation.listIndex ].CM_LocationsController;
	endif;
	if self.cmbCargoType.listIndex &gt; 0 then
		cargoType := self.cmbCargoType.itemObject[ self.cmbCargoType.listIndex ].CM_CargoType;
	endif;
	if self.cmbOperator.listIndex &gt; 0 then
		operator := self.cmbOperator.itemObject[ self.cmbOperator.listIndex ].CM_Operator;
	endif;
		
	
	if ta = null then
		msg := app.getErrorString( Input_Required_For_TA );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbTerminalArea.setFocus();
		return;
	endif;
	
	if not app.isSpecial() then
	// ### TFS 51515 13JUL2021 NAVAB1
	if cargoType = null then
		msg := app.getErrorString( Input_required_field_cargoType );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbTerminalArea.setFocus();
		return;
	endif;
	
	// ### TFS 51515 13JUL2021 NAVAB1
	if operator = null then
		msg := app.getErrorString( Input_required_field_operator );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbTerminalArea.setFocus();
		return;
	endif;
	endif;

	
	//create the selector query object.
	create myEnqController;
	create myEnqController.allObjects as  CMEVT_LocationActivitySet transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	//add the criteria
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Transaction_Query_Type,CM_QueryDefinition.Location_Activity_Query_Mode];
	
	//terminal
	criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);
	criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	
	//dates
	if startDate.isValid and endDate.isValid then
		create dateArray transient;
		dateArray.add( startDate );
		dateArray.add( endDate );
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::dateTime.name, CM_QDateRange.Operator_Between, dateArray );
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	elseif startDate.isValid then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::dateTime.name, CM_QDateRange.Operator_GreaterThan, startDate.cnEcAddDays( -1 ) ); //16 Jun 2021	NDL	TFS 51321
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	elseif endDate.isValid then
		create dateArray transient;
		startDate := app.actualTimeAppServer.date.cnEcAddDays( ( self.myTerminal.getLocationActivityMaxDays() * -1 ) );
		dateArray.add( startDate );
		dateArray.add( endDate );
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::dateTime.name, CM_QDateRange.Operator_Between, dateArray );
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	//CargoType
	if cargoType &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType );
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	//Operator
	if operator &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::operatorCode.name, CM_QueryOperator.Operator_Equal, operator);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	//Terminal Area
	if ta &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::getTerminalAreaIds.name, CM_QStringLookup.Operator_Equal, ta.id);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	if lc &lt;&gt; null then
		criteriaLine := qDef.createCriteriaLine(CMEVT_LocationActivity::getYardLocationIds.name, CM_QStringLookup.Operator_Equal, lc.getFullId);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	// run the query
	myEnqController.doQuery( qDef );
	
	
	//Add the data to the local collection
	foreach locActivity in myEnqController.allObjects.CMEVT_LocationActivitySet discreteLock do
		atLimit := self.addObjectToCollection(locActivity, user);
		if atLimit then
			break;
		endif;
	endforeach;
	
	if not self.doMaxTableSizeCheck(self.numItemsShown, null) then
		return;
	endif;
	
	self.populateLocActivityTable();
	
epilog

	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	
	delete myEnqController;
	delete dateArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="doRecalculate" id="92be8ecd-02e6-44ee-9c28-361e0d93b0b3">
        <updating/>
        <source>doRecalculate()protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	agent : CM_LocationActivityAgent;
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	msg : String;
	locact : CMEVT_LocationActivity;
	earliestRecalcTS : TimeStamp;
	nomalStartTime : Time;
	dateAgent : CM_LocationActivityUpdateAgent;
begin

	if self.cmbTerminalArea.listIndex &gt; 0 then
		ta := self.cmbTerminalArea.itemObject[ self.cmbTerminalArea.listIndex ].CM_TerminalArea;
	endif;
	if self.cmbLocation.listIndex &gt; 0 then
		lc := self.cmbLocation.itemObject[ self.cmbLocation.listIndex ].CM_LocationsController;
	endif;
	if self.cmbCargoType.listIndex &gt; 0 then
		cargoType := self.cmbCargoType.itemObject[ self.cmbCargoType.listIndex ].CM_CargoType;
	endif;
	if self.cmbOperator.listIndex &gt; 0 then
		operator := self.cmbOperator.itemObject[ self.cmbOperator.listIndex ].CM_Operator;
	endif;
	
	if ta = null then
		msg := app.getErrorString( Input_Required_For_TA );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbTerminalArea.setFocus();
		return;
	endif;
	

	
	
	create agent transient;
	agent.setBaseDataFromForm( 	self.myTerminal,	//_myTerminal : CM_Terminal;
								ta,	//_myTerminalArea : CM_TerminalArea;
								lc,	//_myLocation : CM_LocationsController;
								cargoType,	//_myCargoType : CM_CargoType;
								operator	//_myOperator : CM_Operator
								);
								
	// get the earliest BALANCE that needs recalc using a null date
	earliestRecalcTS := agent.earliestRecalcTS; // ### TFS 51515 20JUL2021 NAVAB1
	
	msg := app.getErrorString4(Recal_daily_balan_FromDate,ta.id, cargoType.description, operator.description,
				earliestRecalcTS.localToSystemTimeUsingObject(self.myTerminal).asStringJMT() ); // ### TFS 51515 13JUL2021 NAVAB1
	msg := msg &amp; CrLf &amp; CrLf &amp; app.getErrorString(DoYouWantToContinue);
	if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
								
	agent.doProcess();
	
	self.doFind();

epilog
	delete dateAgent;
	delete agent;

end;</source>
        <access>protected</access>
    </JadeMethod>
