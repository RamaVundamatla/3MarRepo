    <JadeMethod name="btnPrint_click" id="7e0ce158-2936-4a97-8a31-191f4e20d96f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPrint_click(btn: Button input) updating;
// -----------------------------------------------------------------------------
// Created:		14 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

begin
	app.mousePointer := MousePointer_HourGlass;
	self.tblParameter.lostFocus(self.tblParameter);

	if self.myReportAgent.state = self.myReportAgent.STATE_BGR_EDIT then
		self.updateBGR();
	else
	//app.myPassport.myActivityCapture.startCaptureDebugMisc(method.name);
		self.doReport();
	//	app.myPassport.myActivityCapture.stopCaptureDebugMisc();
	endif;
	
epilog
	app.mousePointer := MousePointer_Default; 	

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbActualVoy_click" id="322bce88-bbab-4740-96de-0d641c5c95f9">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbActualVoy_click(combobox: ComboBox input) updating;

vars
	globalVoy			: CM_VoyageGlobal;
begin

	self.tblParameter.setValueByName(ETRow_LogLot, null);
	self.tblParameter.setValueByName(ETRow_Lot, null);	//11 Dec 2012	NDL Par 30696
	self.tblParameter.setValueByName(ETRow_SelectAll, null);
	
	self.lstTblLogLot.clearSelected();
	globalVoy := combobox.listObject.CM_VoyageGlobal;
	self.myReportAgent.doLoadListTableLogLot(self.lstTblLogLot, globalVoy);
	self.myReportAgent.doLoadLotHatchPlace(globalVoy);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbActualVoy_lostFocus" id="97cd7f02-9481-466d-8e5b-fae6e64ae2ba">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbActualVoy_lostFocus(combobox: ComboBox input) updating;

vars
	obj : CM_VoyageGlobal;
begin
	if combobox.listObject &lt;&gt; null then
		//12463 06/09/2006 cnwmo1 Changed to include vessel name in combo display.
		obj := combobox.listObject.CM_VoyageGlobal;
		self.tblParameter.setValueByName(ETRow_VoyageActual, obj.code &amp; ' ' &amp; obj.vesselName);
	else
		self.tblParameter.setValueByControlName(combobox.name, combobox.text);
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
