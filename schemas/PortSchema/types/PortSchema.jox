    <JadeMethod name="helpIsHTMLFormat" id="d0deccf4-23fd-46b5-9077-3fb5bb24b70b">
        <source>helpIsHTMLFormat() : Boolean;
/*

Purpose:			Return true if the current session is using HTML help

Parameters:			None

Return Value:		True if HTML help is enabled

Date		Who		Reason
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation

*/

vars

begin
	return self.getHelpFileFormat() = HelpFile_TypeHTML;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
