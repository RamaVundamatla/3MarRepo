    <JadeMethod name="pxyCreateUpdateProxy" id="1da12a03-f621-44d2-8e6c-8f7d60b131db">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 May 2019		jlgmd1	Initial creation TFS 39667 - JMT - API Documentation

*/

vars
	proxyObj	: SelfType;
	completedOk	: Boolean;
	
	child,
	pxyChild	: DEV_REOWsdlClass;
	feature,
	pxyFeature	: DEV_REOWsdlFeature;
begin
	proxyObj := inheritMethod();
	
	completedOk := true;
	return proxyObj;
epilog
	if not completedOk then
		delete proxyObj;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="set" id="451426cb-ffa5-407d-a2f9-91a832c26868">
        <updating/>
        <source>set(_name : String; _parent : DEV_REOWsdlClass) updating;
/*

Purpose:			Keep a record of the past WSDL classes to be used to compare with what now exists and create a difference doc

Parameters:			

Return Value:		

Date			Who		Reason
13 May 2019		jlgmd1	Initial creation TFS 39667 - JMT - API Documentation

*/

vars

begin
	self.name := _name;
	
	self.myParent := _parent;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_parent" type="DEV_REOWsdlClass"/>
    </JadeMethod>
    <JadeMethod name="updateFromProxy" id="b7949715-014e-4d49-aa2d-ee4a7d78b5d2">
        <updating/>
        <source>updateFromProxy(_pxy : SelfType) updating;
/*

Purpose:			Update ourselves based on the given proxy

Parameters:			

Return Value:		

Date			Who		Reason
13 May 2019		jlgmd1	Initial creation TFS 39667 - JMT - API Documentation

*/

vars
	newMeth,
	pxyMeth,
	newProp,
	pxyProp		: DEV_REOWsdlFeature;
begin
	
	// Has our parent changed ?
	if self.myParent.isTransient and self.myParent &lt;&gt; _pxy.myParent then	
		self.myParent := _pxy.myParent;
	endif;
	
	// Has any of our methods changed ?
	foreach pxyMeth in _pxy.allMethods do
		newMeth := self.allMethods[pxyMeth.name];
		if not pxyMeth.deleted then
			if newMeth = null then
				create newMeth persistent;
			endif;
			newMeth.setForUpdateFromProxy(pxyMeth, app.myPassport);
			newMeth.setWSDLClass(self);
		else
			delete newMeth;
		endif;
	endforeach;
	
	// Has any of our properties changed ?
	foreach pxyProp in _pxy.allProperties do
		newProp := self.allProperties[pxyProp.name];
		if not pxyProp.deleted then
			if newProp = null then
				create newProp persistent;
			endif;
			newProp.setForUpdateFromProxy(pxyProp, app.myPassport);
			newProp.setWSDLClass(self);
		else
			delete newProp;
		endif;
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
</Class>
