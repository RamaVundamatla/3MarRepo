        <source>setCMIF(_cmif : CMIF_BGPManagerChildren input);

// cnwdvb1 10 December 2002 

vars

begin

	if global.isValidObject(self.myUser) then
		_cmif.myUser := self.myUser;
	else
		_cmif.myUser := null;
	endif;
