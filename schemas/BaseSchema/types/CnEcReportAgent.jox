// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for updating a Report Category.
//
// Parameters:	The object's (changeable) properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trimmedName			: String;
	reportCategoryObj	: CnEcReportCategory;
	baseRootObj			: CnEcBaseRoot;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pReportCategoryObj = null then
		return self.agentSetError("The Report Category being updated is either null or is not valid.");
	endif;

	trimmedName	:=	pCategoryName.trimBlanks;
	if trimmedName = null then
		return self.agentSetError("The Category name cannot be null.");
	endif;

	// If object is invalid, we want our handlers to return an invalid object message.
	self.agentRegisterObjectAndError(pReportCategoryObj, "The Report Category being updated is either null or is not valid.");

	sharedLock(pReportCategoryObj);
	// If the above operation gets an exception, our handler will resume to here
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	baseRootObj	:=	pReportCategoryObj.myBaseRoot;
	if baseRootObj = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	// If BaseRoot is invalid, we want our exception handlers to return a message saying so.
	self.agentRegisterObjectAndError(baseRootObj, "The BaseRoot object is missing or not set.");

	reportCategoryObj	:=	baseRootObj.allReportCategories[trimmedName];
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	if reportCategoryObj &lt;&gt; null and reportCategoryObj &lt;&gt; pReportCategoryObj then
		return self.agentSetError("A Report Category already exists with this name (" &amp; trimmedName &amp; ").");
	endif;

	return null;
epilog
	// Release our locks in the epilog so that we'll release them even if we exit via an
	// exception. If we don't have an object locked, the unlock does nothing. If we're
	// in transaction state, transaction duration locks won't be released until the next
	// commit or abort transaction (even if we explicitly unlock them). That allows a
	// method to be well behaved and release its locks without having to be aware of the
	// transaction state of the process.
	if pReportCategoryObj &lt;&gt; null then
		unlock(pReportCategoryObj);
	endif;
end;</source>
