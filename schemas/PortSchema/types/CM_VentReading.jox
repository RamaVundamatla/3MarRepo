<Class name="CM_VentReading" id="2a0bcfc5-f7b0-48e4-a664-a3e7c584b7d6">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tempreading"/>
    <PrimAttribute name="dateTime" id="00f77489-5eb1-432b-8e0d-6bf6aa65cb6d">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTIReeferProperties" id="e0f6d02a-243b-4687-8c9b-0c696c615ebc">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TIReeferProperties"/>
        <access>readonly</access>
        <Inverse name="CM_TIReeferProperties::allVentilationReadings"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myVentilationReading" id="f6425bb3-0cee-41a9-8014-41c3c2c6b325">
        <embedded/>
        <type name="CM_VentilationReading"/>
        <access>readonly</access>
        <Inverse name="CM_VentilationReading::myVentReading"/>
    </ExplicitInverseRef>
    <PrimAttribute name="userId" id="3af9998d-117a-477b-9987-0fd7c07b0a03">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="ventilation" id="ab6efa3d-de7b-4271-a9bc-6cb1fa0a6b17">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="cloneForTrackedItemRefs" id="8f67fbce-1900-497c-b290-a9e518b60285">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti : CM_TrackedItem) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	self.myTIReeferProperties := _ti.myReeferProperties;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getDisplayVentilation" id="2cdf0397-1603-4af6-a6ca-e85ced814e83">
        <source>getDisplayVentilation() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars
	ventType : CM_MeasurementType;

begin
	if self.ventilation = NULL_VENTILATION then
		return "null";
	else
		ventType := app.getDefaultMeasurementForType(Type_Displacement);
		return app.convertMeasurementForDisplay(ventType.shortName, self.ventilation.Decimal) &amp; Space &amp; ventType.shortName;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayVentilationValue" id="7c3dd395-75d0-43da-8306-761e7c2289c4">
        <source>getDisplayVentilationValue() : String;
//
// Purpose:			Return just the value of the latest reading as a string
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars
	ventType : CM_MeasurementType;

begin
	if self.ventilation = NULL_VENTILATION then
		return null;
	else
		ventType := app.getDefaultMeasurementForType(Type_Displacement);
		return app.convertMeasurementForDisplay(ventType.shortName, self.ventilation.Decimal);
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="55c7ac78-f697-4169-8bbc-ac16c49f2734">
        <updating/>
        <source>setForCreate(_ventParams : CMIF_VentReading) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars
	ti		: CM_TrackedItem;

begin
	self.dateTime := _ventParams.dateTime;
	self.ventilation := _ventParams.ventilation;
	
	ti := _ventParams.myTrackedItem;
	ti.createReeferPropertiesIfReqd(self.dateTime);
	self.myTIReeferProperties := ti.myReeferProperties;
	
	self.userId := _ventParams.userId;

epilog

end;</source>
        <Parameter name="_ventParams" type="CMIF_VentReading"/>
    </JadeMethod>
</Class>
