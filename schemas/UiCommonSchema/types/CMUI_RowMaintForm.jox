    <JadeMethod name="doComboPositions" id="32445b4e-5289-4cfb-9212-0016f90e62c7">
        <source>doComboPositions() ;
// ---------------------------------------------------------------------------
// Created:     16 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars

begin
	if app.isDevelopmentSystem then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  WARNING - you need to reimpliment this method in your own form.');
	endif;
