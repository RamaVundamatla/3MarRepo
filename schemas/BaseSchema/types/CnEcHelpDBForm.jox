        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnList_Remove_click(btn: Button input) updating;

vars
	msg_return	: Integer;

begin
	if self.aMyHelp = null then
		btn.enabled := false;
		return;
	endif;

	msg_return := app.msgBox(	"Do you wish to remove " &amp; self.aMyHelp.name &amp; " ?",
								"Remove List",
								MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);

	if msg_return = MsgBox_Return_Yes then
		beginTransaction;
			self.aMyHelp.remove();
			delete self.aMyHelp;
		commitTransaction;
		
		self.populateCnEcHelp();
		self.setCnEcHelp(self.aMyHelp);
	endif;
end;</source>
