    <JadeMethod name="loadDataForFirstTime" id="6bec9166-50ec-4390-8ae5-693c06116f15">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:
// Date				Who		Reason
// 9 January 2023	navmk20	Bug 56047: MTN - Ship Graphic form button placement issue
// ---------------------------------------------------------------------------

vars

	theGraphic : CM_VoyageLayoutGraphic;
	theNullVoyage : CM_Voyage;
	theTerminal : CM_Terminal;
begin
	theTerminal := app.myPassport.myTerminal;
	if theTerminal = null then
		theTerminal := self.myTerminal;
	endif;
	drawFlipped := false;
	
	if self.mode = Mode_Ship then
		if theTerminal &lt;&gt; null then
			theNullVoyage := theTerminal.getNullVoyage();
			if theNullVoyage &lt;&gt; null then
				theGraphic := theNullVoyage.myLayoutGraphic;
				if theGraphic = null then
					theNullVoyage.createGraphicForNullVoyage();
					theGraphic := theNullVoyage.myLayoutGraphic;
				endif;
			endif;
		endif;
		self.myGraphic := theGraphic;
		self.caption := "Ship Graphic";
	elseif self.mode = Mode_TIBehaviour then
		self.caption := "TI Behaviour Graphic";
	endif;
	
	inheritMethod();
	self.addToolbarControls();
	self.frmPolygon.caption := null;
	self.frmPolygon.top := 2;
	self.frmPolygon.borderStyle := Frame.BorderStyle_None;
	self.frmPolygon.autoRedraw := true;
	self.initTableDimensions();
	self.lblColour.backColor := White;
	self.lblColour.foreColor := Black;
	self.doBuildComboGraphics();
	self.doBuildComboType();
	self.zoomScale := 1;
	
	//cnwjo3.  blame me.  its a quick fix to a simple program that people won't use
	//self.btnLoadFromCSV.top := self.lblColour.top;										//9.1.2023 navmk20 TFS 56047
	//self.btnLoadFromCSV.left := self.lblColourFill.left + self.lblColourFill.width + 230;	//9.1.2023 navmk20 TFS 56047
	//self.btnLoadFromCSV.zOrder(1000);														//9.1.2023 navmk20 TFS 56047
end;</source>
        <access>protected</access>
    </JadeMethod>
