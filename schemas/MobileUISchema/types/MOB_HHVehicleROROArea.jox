    <JadeMethod name="setupForm" id="ea97711c-3119-420f-bdaa-e56714d6669f">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2016	cnwndl1	Initial creation

*/

vars

begin
	
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Menu), null, null, null );
	
	inheritMethod();
	
	self.setupControls();

epilog

end;</source>
