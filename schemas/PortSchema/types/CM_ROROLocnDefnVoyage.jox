    <JadeMethod name="setOrdinal" id="95538b01-ee5f-4633-97c7-3d36b6466861">
        <updating/>
        <source>setOrdinal(_ord: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	slotDefn : CM_ROROSlotDefn;
begin
	inheritMethod(_ord);
	// PAR 27749
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotDefn.CM_ROROSlotDefnVoyage.mySlotController.setFromROROSlotDefn();
	endforeach;
epilog

end;</source>
        <Parameter name="_ord" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPointsOnRequests" id="7ab8cb59-a8db-4b20-aeef-952de0519c4a">
        <source>setPointsOnRequests(_isLoad : Boolean);
/*  // PAR 28879
Purpose:	This location has a collection of slots, each of these can be colour coded, if this happens each request has its own layout. 
				If this is an OOTL it can be moved. If this happens we have to 'move' all the layouts for all the slots to be the same as the locations layout.
Date		Who		Reason
22 December 2011	cnwab1	Initial creation
*/

vars

	slot : CM_ROROSlotDefn;
	req : CM_RORORequest;
begin

	foreach slot in self.allROROSlotDefnByOrdinal discreteLock do
		if _isLoad then
			req := slot.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad;
		else
			req := slot.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge; // PAR 28886 this said LOAD
		endif;

		if req &lt;&gt; null then
			req.myLayout.setPointsPolygonCMs(self.myLayout.myPolygonCMs);
			
			if (not self.isOOTL 
				or (self.isOOTL and not self.hasAlreadyCovered(true, DeckItemLayoutType_CCLoad))) then
				self.myDeck.myDeckLayout.hideContainerPositionsUnderGC(req.myLayout); // PAR 27749
			endif;

		endif;
		
		
	endforeach;



epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="aeceb5d1-e3a0-4868-98ed-3abb8f9a4db3">
