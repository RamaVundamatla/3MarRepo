    <JadeMethod name="doEditTask" id="022893ad-d0ef-4d75-9918-62f1533c5122">
        <updating/>
        <source>doEditTask() protected, updating;

// cnwdvb1 23 January 2003 

vars



begin

	//20 May 2011	NDL	Par 27577
	if self.mySelectedAutoTask = null then
		app.msgBox(app.getErrorString(Please_select_task),app.getErrorString(Error),MsgBox_OK_Only);
		self.state := self.State_View;
		return;
	endif;

	delete self.myProxyAutoTask;
	self.myProxyAutoTask := app.createUpdateProxy(self.mySelectedAutoTask).CM_AutoTask;
	tblTaskCreation.userInputEnabled := true;
	self.tblTaskCreation.disableRowByName(ETRow_BgpAutoTaskType);
	self.tblTaskCreation.disableRowByName(ETRow_CsvFileName);
	self.doLoadTaskTable(self.myProxyAutoTask);
	self.tblTaskCreation.moveFirst();
	self.tblTaskCreation.setFocus();


end;</source>
        <access>protected</access>
