    <JadeMethod name="translateForm" id="cbce27aa-c74e-40c8-960a-b7910318ebe1">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 March 2017 09:30:25.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021404, locale);
	btnDocActions.translateCaption(Xlat_0021921, locale);
	btnStoredTemp.translateCaption(Xlat_0021405, locale);
	btnToCompTemp.translateCaption(Xlat_0021406, locale);
	frmStored.translateCaption(Xlat_0021407, locale);
	frmToComplete.translateCaption(Xlat_0021408, locale);
	lblBookings.translateCaption(Xlat_0021409, locale);
	lblCargoId.translateCaption(Xlat_0021410, locale);
	lblNoStored.translateCaption(Xlat_0021411, locale);
	lblNoToComplete.translateCaption(Xlat_0021412, locale);
	lblTargetLoc.translateCaption(Xlat_0021413, locale);
	shtStored.translateCaption(Xlat_0021414, locale);
	shtToComplete.translateCaption(Xlat_0021415, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
