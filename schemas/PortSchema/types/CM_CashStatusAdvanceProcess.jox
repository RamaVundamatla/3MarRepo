    <JadeMethod name="setMyCashReceipt" id="dfc2763c-e416-428b-b3cf-c46a96d71b16">
        <updating/>
        <source>setMyCashReceipt(_cashReceipt : CM_CashReceipt) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/09/2018	jlgdap1		Initial creation TFS 40202 PEL1 Estimation SAP Integration
// 22/01/2019	jlgdap1		TFS 42925 PEL1 Container Services - Estimation Approval Countdown
//
vars

begin
	self.myCashReceipt := _cashReceipt;
	self.myParentObject := _cashReceipt;
	self.myRoot := app.myRoot;					// TFS 42925
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
    </JadeMethod>
