    <JadeMethod name="handleOK" id="8df40eff-ebfc-48f0-a556-a272c1025f1f">
        <updating/>
        <source>handleOK()updating;
// ---------------------------------------------------------------------------
// Created:     23 April 2008 by cnwaer1
//
// Purpose:     
// adm 270509 Par 19483 myTerminal
vars
	strError 	: String;
	result 		: Integer;
	location		: String;
	term 		: CM_Terminal;
	strTermArea 	: String;

begin
	location:= txt_TextBox1.text;

	term := self.myTerminal;
	myLocation := self.myMobileDataAgent.findLocationByID(txt_TextBox1.text.toUpper);
	if myLocation = null then
		app.msgBox("Not a valid location.",'',MsgBox_OK_Only);
		modalResult := ModalResultError;
		return;
	endif;
	modalResult := ModalResultOK;
	unloadForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCaption" id="e2c40aab-439f-44fd-a11e-0a5c4e37bb49">
        <updating/>
        <source>setCaption(str : String) updating;
/*
	Created on 23 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	self.lbl_Title.caption := str;
end;</source>
        <Parameter name="str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1b6f0fe5-3243-4d99-a91d-bb9894599adf">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.lbl_Label1.caption := app.getErrorString(NewLocation);
	self.btn_ButtonLeft.caption := 'OK';
	self.btn_ButtonLeft.default  := true;
	self.btn_ButtonRight.caption := app.getErrorString(Cancel);
	self.btn_ButtonRight.cancel := true;
	self.caption:= '';
	self.txt_TextBox1.case := txt_TextBox1.Case_Upper;
	modalResult := ModalResultCancel;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6be7dfe8-e8d5-4cc3-b508-a3df5d8aba55">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018479, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
