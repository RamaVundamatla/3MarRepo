    <JadeMethod name="getProfileStringMyIni" id="db50e602-b85d-4f1b-8d58-3bc2b0a5e584">
        <source>getProfileStringMyIni(section, keyName, default : String) : String;
// ---------------------------------------------------------------------------
// Created:     04 December 2002 by cnwrs2
