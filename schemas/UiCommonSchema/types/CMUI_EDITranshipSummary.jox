    <JadeMethod name="buttonsOffOn" id="a0bfbe1a-3618-441e-8aeb-7bf3bee63c7b">
        <source>buttonsOffOn(_value : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     September 2007 cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

