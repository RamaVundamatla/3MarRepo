    <JadeMethod name="doResize" id="ae16e92e-69d5-4702-9834-ee7d2609f017">
        <updating/>
        <source>doResize() updating;
/*
Purpose:			
Date		Who		Reason
17 May 2016	cnwab1	Initial creation
*/

vars

begin
	self.grpMachTypeGrp.top := self.frmToolbar.height; // JMT METRO CNWAB1 MAT 2016
	self.dkcMain.top := (self.grpMachTypeGrp.top + self.grpMachTypeGrp.clientHeight); // JMT METRO CNWAB1 MAT 2016
	self.dkcMain.height := self.clientHeight - self.frmToolbar.height - self.grpMachTypeGrp.clientHeight; // JMT METRO CNWAB1 MAT 2016
	
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSysNotify" id="3e2deb5e-b12f-43c7-879d-57d85cd53b32">
        <updating/>
        <source>doSysNotify(eventType: Integer; theObject: Object; eventTag: Integer) protected, updating;

// Created by cnwdvb1 on 30 June 2006
// Nov 2011 28591 check the terminal of the rule and exit if different - excp handler for deletes (theObject will be invalid) which will go through the code
//   anyway but not find anything for a different terminal
vars
	invalidObject	: Boolean;
	rule	: CM_RTQueueMultiRule;
	ruleTerminal	: CM_Terminal;
begin
	on Exception do app.handleDeletedObject(exception, rule, invalidObject);

	rule := theObject.CM_RTQueueMultiRule;
	ruleTerminal := rule.myTerminal;	// get an exception for a deletion notification
	
	if not invalidObject and
	   ruleTerminal &lt;&gt; self.myTerminal then
		return;
	endif;

	if not self.updateObjectInTable(eventType, theObject.CM_RTQueueMultiRule, self.tblTATypes) then
		self.updateObjectInTable(eventType, theObject.CM_RTQueueMultiRule, self.tblTAMaster);
	endif;
	
	
	
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="850c3b1a-68f4-4994-827e-a12b245e31a8">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars

	xmlStr				: String;
begin

	xmlStr := inheritMethod();
	xmlStr := xmlStr &amp; self.tblTATypes.getXmlStrForColumns(true) &amp; 
			self.tblTAMaster.getXmlStrForColumns(true) &amp;
			global.formatAsXML(self.XML_FORK,self.chkFork.value.String) &amp;
			global.formatAsXML(self.XML_RTG,self.chkRTG.value.String) &amp;
			global.formatAsXML(self.XML_STRADDLE,self.chkStrad.value.String) &amp;
			global.formatAsXML(self.XML_IMV,self.chkIMV.value.String) &amp;
			global.formatAsXML(self.XML_MAFI,self.chkMAFI.value.String) &amp;
			global.formatAsXML(self.XML_TRACTOR,self.chkTractor.value.String);
	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="af455925-7d81-4269-a505-aed30700573a">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2010	cnwer1	Initial creation

*/

vars
	theXML,
	theXMLValue: String;
begin
	inheritMethod(_userWindow);

	
	
	self.chkFork.value:=true;
	self.chkIMV.value:=true;
	self.chkRTG.value:=true;
	self.chkStrad.value:=true;
	
	
	theXML:= _userWindow.xmlInfo;


 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_RTG);
 	if theXMLValue &lt;&gt; null then
 		self.chkRTG.value:= theXMLValue.Boolean;
 	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_STRADDLE);
 	if theXMLValue &lt;&gt; null then
 		self.chkStrad.value:= theXMLValue.Boolean;
 	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_IMV);
 	if theXMLValue &lt;&gt; null then
 		self.chkIMV.value:= theXMLValue.Boolean;
 	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_FORK);
 	if theXMLValue &lt;&gt; null then
 		self.chkFork.value:= theXMLValue.Boolean;
 	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_MAFI);
 	if theXMLValue &lt;&gt; null then
 		self.chkMAFI.value:= theXMLValue.Boolean;
 	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TRACTOR);
 	if theXMLValue &lt;&gt; null then
 		self.chkTractor.value:= theXMLValue.Boolean;
 	endif;
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblData" id="fc0b80e9-d10d-4b03-bf16-785401c9eb93">
        <source>initTblData();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.tblTATypes.setTblDataEntRowsFromDef(app.myController.getEntTableDef((ETDef_MachineRulesTAType)));	

	self.tblTATypes.setMyDataClass(CM_RTQueueMultiRule);
	self.tblTATypes.userInputEnabled := false;
	self.tblTATypes.selectMode := Table.SelectMode_CurrentRow;
	self.tblTATypes.selectionType := CM_DataTable.SelectionType_Row;
	self.tblTATypes.multiSelect := self.tblTATypes.MultiSelect_Simple;


	self.tblTAMaster.setTblDataEntRowsFromDef(app.myController.getEntTableDef((ETDef_MachineRulesTAMaster)));	

	self.tblTAMaster.setMyDataClass(CM_RTQueueMultiRule);
	self.tblTAMaster.userInputEnabled := false;
	self.tblTAMaster.selectMode := Table.SelectMode_CurrentRow;
	self.tblTAMaster.selectionType := CM_DataTable.SelectionType_Row;
	self.tblTAMaster.multiSelect := self.tblTATypes.MultiSelect_Simple;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="334da735-18a1-4563-a1a3-8e9cf64717dc">
        <updating/>
