    <JadeMethod name="addObjectToTableAllClasses" id="9d9ce0df-5270-4b28-b336-e2dd09afd898">
        <updating/>
        <source>addObjectToTableAllClasses(_numItems: Integer io) updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
17 Mar 2008	cnwkpd1	PAR #16145 - removed write statement
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
12 Sep 2023 navhl20 ChangeRequest 60432: MTN - Add time filter to Audit Enquiry screen.
*/

vars
	iter	: Iterator;
	tmpAO	: CM_AuditObject;
	fromDate,
	toDate	: TimeStamp;
	dict	: CM_AuditObjectDictByTimestamp;
	useDate,
	breakOut	: Boolean;
	tmpAC	: CM_AuditConfig;

begin

	if self.filterFromDate.isValid then
		useDate := true;
		//fromDate := self.filterFromDate.TimeStamp;											//15.9.2023 navhl20 #60432						
		fromDate := (self.filterFromDate.String &amp; ", " &amp; filterFromTime.String).TimeStamp;		//12.9.2023 navhl20 #60432
		if self.filterToDate.isValid then
			//toDate := (self.filterToDate + 1).TimeStamp;										//15.9.2023 navhl20 #60432				
			toDate := (self.filterToDate.String &amp; ", " &amp; filterToTime.String).TimeStamp;		//15.9.2023 navhl20 #60432
		else
			toDate := (app.actualTimeServer.date + 1).TimeStamp;
		endif;
	endif;
	
	foreach tmpAC in app.myRoot.allAuditConfigs discreteLock do
		delete iter;
		iter := tmpAC.allAuditObjects.createIterator();
		if useDate then
			tmpAC.allAuditObjects.startKeyGeq(fromDate, iter);
		endif;
		
		while iter.next(tmpAO) do
			if tmpAO.timestamp &gt; toDate then
				break;
			endif;
			if includeObject(tmpAO,app.myPassport) then
				self.addObjectToTable(tmpAO, _numItems, breakOut);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
		if breakOut then	//14 Jul 2016	NDL	TFS 2220
			break;
		endif;
	endforeach;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="e3f4a012-a50d-496e-ac0e-134c29924285">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
13 Jun 2016	cnwns1	TFS 488 - Multi Timezone Support
09 Aug 2015	cnwrs1	Par 38117 TFS 2491 - If an Audit Object is passed in as auditted Object then display it
12 Sep 2023 navhl20 ChangeRequest 60432: MTN - Add time filter to Audit Enquiry screen.
19 Sep 2023 navsaa30 Defect 60522: MTN - Release Request Audits - No longer automatically displaying
*/
vars
	iter	: Iterator;
	tmpAO	: CM_AuditObject;
	fromDate,
	toDate	: TimeStamp;
	dict	: CM_AuditObjectDictByTimestamp;
	breakOut	: Boolean;

begin
	//epr TFS 43546 27/2/19
	if self.isUsingDefinedObject then
		dict := self.myAudittedObject.getAllAuditObjects;
	elseif self.filterUser &lt;&gt; null then
		dict := self.filterUser.allAuditObjectChangesByMe;

	elseif self.myCurrentAuditConfig &lt;&gt; null then
		dict := self.myCurrentAuditConfig.allAuditObjects;
	
	else
		// handle search thrrough all objects
		self.addObjectToTableAllClasses(_numItems);
		return;
	endif;
	
	if dict = null then
		if self.myAudittedObject.isKindOf(CM_AuditObject) then
			self.addObjectToTable(self.myAudittedObject, _numItems, breakOut);
		endif;
		return;
	endif;
				
	if self.filterFromDate.isValid then
		fromDate := self.filterFromDate.TimeStamp;
		if self.filterToDate.isValid then
			toDate := (self.filterToDate + 1).TimeStamp;
		else
			toDate := (app.actualTimeServer.date + 1).TimeStamp;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;

		iter := dict.createIterator();
		dict.startKeyGeq(fromDate, iter);
		
		while iter.next(tmpAO) do
			if tmpAO.timestamp &gt; toDate then
				break;
			endif;
			if includeObject(tmpAO,app.myPassport) then
				self.addObjectToTable(tmpAO, _numItems, breakOut);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
	else
		iter := dict.createIterator();
		while iter.next(tmpAO) do
			if includeObject(tmpAO,app.myPassport) then
				self.addObjectToTable(tmpAO, _numItems, breakOut);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
	endif;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addThumbnailChildHeader" id="c4a61152-6972-4d54-8404-ae1545b486d1">
        <source>addThumbnailChildHeader(_name : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2019	jlger1	Initial creation 43546

*/

vars
	row : Integer;
begin
	row:=self.tblThumb.addItem(_name);
	self.tblThumb.stretch 							:= Table.Stretch_None_Picture_First;
	self.tblThumb.accessCell (row, 1).alignment 		:= Table.Alignment_Left_Middle;
	self.tblThumb.accessRow (row).marginLeft			:= 1;
	self.tblThumb.accessedRow.marginRight 			:= 1;
	self.tblThumb.accessedRow.marginTop 				:= 1;
	self.tblThumb.accessedRow.marginBottom			:= 2;	
	self.tblThumb.accessCell(row, 1).picture 	:= app.myRoot.getConfig(PicYAMCollapse).Binary;
	self.tblThumb.accessCell (row, 1).mergeCells 		:= Table.MergeCells_Merge;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="3fc5a7e9-f208-4af1-8e8c-6c8861a2bd9c">
        <source>addToolbarControls() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2021	jlgndl1	Initial creation	TFS 50152

04 March 2022 navtnr20 Audit Maintenance Filter  TFS #52944
*/

vars

	toolbar			: CMUI_Toolbar;

begin

	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAuditConfig, CMUI_Toolbar.Control_Alignment_Left);
	/* //25/06/2024	navkc1 CR 64823 Task 64824
	//Start  04.Mar.2022 navtnr20 TFS #52944
	self.frmToolbar.addFrame(self.frmFilter,CMUI_Toolbar.Control_Alignment_Left);
	self.txtFilterBox.parent 	:= self.frmFilter;
	self.txtFilterBox.visible 	:= true;
	self.txtFilterBox.left 		:= 0;
	self.txtFilterBox.top 		:= 2;
	self.frmToolbar.addButton(self.btnClearFilter,CMUI_Toolbar.Control_Alignment_Left);
	//04.Mar.2022 navtnr20 TFS #52944   END
	*/
	//25/06/2024	navkc1 CR 64823 Task 64824
	self.frmToolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
