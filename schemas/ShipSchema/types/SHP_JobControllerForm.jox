    <JadeMethod name="setupForm" id="d477987d-df27-46cb-b6d9-7f54d13a6fef">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	frameObj : CMUI_ScrollableFrame;
	vLabelsFrm, hLabelsFrm : CMUI_ScrollableLabelsFrame;
	//myDrawCellVoyage : CMUI_DrawCellVoyageOverview;
	voyage : CM_Voyage;
	allBays : CMUI_BayOverviewByBayId;
	bayOverviewObject :  CMUI_BayOverviewObject;
	now,
	startTime,
	endTime: TimeStamp;
begin
	inheritMethod();
	self.setFormCaption();
	self.txtJobBubble.ignoreSkin:=true;
	self.frmCranesNew.ignoreSkin:=true;
	self.getXMLSettingsForSetup();
	

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.addSearchToolbarControls;
	self.frmSearcher.centreWindow();
	self.txtSearchErrors.visible:=false;
	self.frmSearcher.height:=self.frmSearcher.height - self.txtSearchErrors.height;
	self.frmScrollablMain.visible:=false;
	self.txtCranes.scrollBars:=Window.ScrollBars_Vertical;

		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveBase.enabled:= false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupJobContextMenu" id="ea7080ea-664f-479c-ac3a-b3a35c529a2a">
        <source>setupJobContextMenu(_job : CM_VoyageJob input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
03 May 2007	cnwer1	Initial creation - PAR#xxxx
17 Dec 2019	jlgdap1	TFS 47144 JMT Refactor OOW Job Split Tansfer
*/
vars
	clonedMenu : MenuItem;
	subMenu : MenuItem;
	canMaint : Boolean;
begin
	canMaint :=  app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1

	


	if _job = null then
		return;
	endif;
			
	// -------------Job mnu items -----------------------------//
	clonedMenu:=self.mnuJobMaintenance.loadMenu(self.allJobContMenuItems.size + 1);
	clonedMenu.visible:=true;
	clonedMenu.caption:=app.getErrorString(Job) &amp; " " &amp; _job.id.asStringJMT;
	clonedMenu.userObject:=_job;
	self.allJobContMenuItems.add(clonedMenu);
	//bring to front
	subMenu:=clonedMenu.loadSubMenu(self.allJobContMenuItems.size + 1);
	subMenu.caption:=app.getErrorString(Bring_front);
	subMenu.setEventMapping(MenuItem::click.name,SHP_JobControllerForm::doMnuJobToFront_click.name);
	subMenu.visible:=true;
	subMenu.userObject:=_job;
	self.allJobContMenuItems.add(subMenu);
	
	subMenu:=clonedMenu.loadSubMenu(self.allJobContMenuItems.size + 1);
	subMenu.caption:=app.getErrorString(Send_back);
	subMenu.setEventMapping(MenuItem::click.name,SHP_JobControllerForm::doMnuJobSendToBack_click.name);
	subMenu.visible:=true;
	subMenu.userObject:=_job;
	self.allJobContMenuItems.add(subMenu);
		
	//job edit
	subMenu:=clonedMenu.loadSubMenu(self.allJobContMenuItems.size + 1);
	subMenu.caption:=self.mnuJobEdit.caption;
	subMenu.setEventMapping(MenuItem::click.name,SHP_JobControllerForm::doMnuJobEdit_click.name);
	subMenu.visible:=canMaint;
	subMenu.userObject:=_job;
	self.allJobContMenuItems.add(subMenu);
	
	//start &amp; complete job
	if _job.myUserJobType &lt;&gt; null then
		subMenu:=clonedMenu.loadSubMenu(self.allJobContMenuItems.size + 1);
		subMenu.caption:=self.mnuJobStart.caption;
		subMenu.setEventMapping(MenuItem::click.name,SHP_JobControllerForm::doMnuJobStart_click.name);
		subMenu.visible:=canMaint;
		subMenu.userObject:=_job;
		self.allJobContMenuItems.add(subMenu);
		
		subMenu:=clonedMenu.loadSubMenu(self.allJobContMenuItems.size + 1);
		subMenu.caption:=self.mnuJobComplete.caption;
		subMenu.setEventMapping(MenuItem::click.name,SHP_JobControllerForm::doMnuJobComplete_click.name);
		subMenu.visible:=canMaint;
		subMenu.userObject:=_job;
		self.allJobContMenuItems.add(subMenu);
	endif;
	
	//epr par 25988 30/5/2011 split or transfer jobs
	subMenu:=clonedMenu.loadSubMenu(self.allJobContMenuItems.size + 1);
	subMenu.caption:=self.mnuSplitWork.caption;
	//subMenu.setEventMapping(MenuItem::click.name,SHP_JobControllerForm::doOpenSplitOrTransWorkCraneFrm.name);	// TFS 47144
	subMenu.setEventMapping(MenuItem::click.name,SHP_JobControllerForm::doOpenSplitWorkCraneFrm.name);			// TFS 47144
	subMenu.visible:=canMaint;
	subMenu.userObject:=_job;
	subMenu.enabled := not _job.status = JOB_UNACTIONED;														// TFS 47144
	self.allJobContMenuItems.add(subMenu);
	// TFS 47144 Transfer menu
	subMenu := clonedMenu.loadSubMenu(self.allJobContMenuItems.size + 1);
	subMenu.caption := self.mnuTransferWork.caption;
	subMenu.setEventMapping(MenuItem::click.name, SHP_JobControllerForm::doOpenTransferWorkCraneFrm.name);
	subMenu.visible := canMaint;
	subMenu.userObject := _job;
	subMenu.enabled := _job.status = JOB_UNACTIONED;
	self.allJobContMenuItems.add(subMenu);
	// TFS 47144 end
	
	//epr par 25988 30/5/2011 move cargo
	if  app.getMyUser.canDo(self.myTerminal,PmAdmMoveCargoFromJob) and _job.isDischarge then
		subMenu:=clonedMenu.loadSubMenu(self.allJobContMenuItems.size + 1);
		subMenu.caption:=self.mnuMoveCargoFromJob.caption;
		subMenu.setEventMapping(MenuItem::click.name,SHP_JobControllerForm::doOpenMoveCargoFromJobForm.name);
		subMenu.visible:=canMaint;
		subMenu.userObject:=_job;
		self.allJobContMenuItems.add(subMenu);
	
	endif;

	//cargo enq
	subMenu:=clonedMenu.loadSubMenu(self.allJobContMenuItems.size + 1);
	subMenu.caption:=app.getErrorString(Cargo_Enquiry);
	subMenu.setEventMapping(MenuItem::click.name,SHP_JobControllerForm::doMnuCargoEnquiry_click.name);
	subMenu.visible:=true;
	subMenu.userObject:=_job;
	self.allJobContMenuItems.add(subMenu);
	
	// Opent in Job Operations 
	subMenu:=clonedMenu.loadSubMenu(self.allJobContMenuItems.size + 1);
	subMenu.caption:=self.mnuShowJobInOps.caption;
	subMenu.setEventMapping(MenuItem::click.name,SHP_JobControllerForm::doMnuShowJobInOps_click.name);
	subMenu.visible:=true;
	subMenu.userObject:=_job;
	self.allJobContMenuItems.add(subMenu);
	

	self.mnuDelayAdd.visible :=_job &lt;&gt; null;//or _delay &lt;&gt; null;
	self.mnuDelayAdd.userObject:=_job;

epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageJob" usage="input"/>
    </JadeMethod>
