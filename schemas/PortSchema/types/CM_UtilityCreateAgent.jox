    <JadeMethod name="zUtlCreateVoyage" id="51bc1429-ee2f-4208-9546-9b0ee7f46d91">
        <source>zUtlCreateVoyage(_proxyVoyage:CM_Voyage; _newVoyage:CM_Voyage output;
			_realVessel : CM_Vessel input; _realVoyGlobal : CM_VoyageGlobal;
			_createSPS : Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     14 September 2006 by cnwrs2
//
// Purpose:     Need to access create voyage from 2 places (single and global)
// 21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	jpController : CMIF_JobPriorityController;
begin
	
	if _realVessel &lt;&gt; null then
		// Ask the vessel for a voyage - Sets base data from the vessel
		_newVoyage := _realVessel.createVoyage(_proxyVoyage, _passport);
	else //Log Voyages don't have a vessel relationship, just a vessel name string that could be anything
		create _newVoyage as _proxyVoyage.class persistent;
	endif;

	if _newVoyage &lt;&gt; null then
		_newVoyage.setForCreate(_proxyVoyage, _realVoyGlobal, _createSPS);
	else
		return;
	endif;
	
	// we have created the voyage and it should have a global voyage.
	// now, we go into the global voyage and using the route segments
	// create other CM_Voyages for the other terminals this voyage calls to.
	
	// we assume we have to do NO validation on the "other" CM_Voyage legs of the 
	// CM_VoyageGlobal - simply create them with the same data except the terminal
	// and arrival dates etc.
	

	if _passport.noErrors then
		create jpController transient;
		jpController.init(false,_newVoyage,CM_JobPriorityVoyage);
		jpController.populateDefaults();
		
		app.myUtilityCA.utlCreateVoyageJobPriority(jpController,  _passport);
	endif;
	
	if _passport.noErrors then
		_newVoyage.createVoyageInlandTerminals();
	endif;
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newVoyage);
	endif;
	
	if _passport.noErrors then
		_newVoyage.causeEvent(_newVoyage.myTerminal.getTerminalEvent(Voyage_Create_Event), false, _newVoyage);
		//21.09.2020 cnwma1 TFS #49906
		if _passport.isOpsViewEnabled(_newVoyage.myTerminal) then
			_newVoyage.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
											   BGP_OpsViewWSRequest.OPS_TYPE_VOYAGE,
											   _newVoyage);
		endif;
		//21.09.2020 cnwma1 TFS #49906
	endif;
epilog
	if jpController &lt;&gt; null then
		jpController.allJobPriorities.purge; // proxies
		delete jpController;
	endif;

end;</source>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
        <Parameter name="_newVoyage" type="CM_Voyage" usage="output"/>
        <Parameter name="_realVessel" type="CM_Vessel" usage="input"/>
        <Parameter name="_realVoyGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_createSPS" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
