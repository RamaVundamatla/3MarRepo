    <JadeMethod name="addOutput" id="e1042de7-3e4c-4429-afa9-0e8b7c91b645">
        <source>addOutput( _source : Method; _str : String; _logLevelStr : String );
/*

Purpose:			

Parameters:			Note This method is called by 'sendMsgWithParamters' = see app.doFormLogging

Return Value:		


Date		Who		Reason
16 May 2011	cnwndl1	Initial creation
29/06/2011	cnwmh5	#27179 - Add logging for CM_RTQueueArbiter
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars

	localString : String;
	textLengthChanged : Boolean;
	length : Integer;
	sourceIndicator : String;
begin

	localString := _str;
	length := self.txtOutput.text.length;

	if _source.name = CM_User::canDo.name then
		// Permission checks
		sourceIndicator := "1. ";
		if self.chkPermissions.value then
			self.txtOutput.text := self.txtOutput.text &amp; CrLf &amp; sourceIndicator &amp; addTimeStampIfRequested() &amp; localString &amp; addStackIfRequested( sourceIndicator );
		endif;
		return;
		
	elseif _source.name = CM_Terminal::getConfig.name or _source.name = CM_Terminal::setConfig.name then
		//Configuration calls only
		sourceIndicator := "2. ";
		if self.chkConfig.value then
			self.txtOutput.text := self.txtOutput.text &amp; CrLf &amp; sourceIndicator &amp; addTimeStampIfRequested() &amp; localString &amp; addStackIfRequested( sourceIndicator );
		endif;
		return;
		
	elseif _source.name = CM_YAAutoplanAgent::addLogEntry.name or
		   _source.name = CM_YAAutoplanAgent::sourceTisForRequestYA.name or
		   _source.name = CM_YAAutoplanAgent::searchAllocationIn.name then
		//Auto planning messages only
		sourceIndicator := "3. ";
		if self.chkAutoPlan.value then
			self.txtOutput.text := self.txtOutput.text &amp; CrLf &amp; sourceIndicator &amp; addTimeStampIfRequested() &amp; localString &amp; addStackIfRequested( sourceIndicator );
		endif;
		return;
			
	elseif _source.name = PortSchema::writeCnLog.name then
		//cnLog messages only
		sourceIndicator := "4. ";
		if self.chkCardLog.value then
			self.txtOutput.text := self.txtOutput.text &amp; CrLf &amp; sourceIndicator &amp; addTimeStampIfRequested() &amp; localString &amp; addStackIfRequested( sourceIndicator );
		endif;
		return;
		
	elseif _source.name = CM_TrxControlAgent::initialiseActivityWithPassport.name then
		// Trx used messages only
		sourceIndicator := "6. ";
		if self.chkTrxMethods.value then
			self.txtOutput.text := self.txtOutput.text &amp; CrLf &amp; sourceIndicator &amp; addTimeStampIfRequested() &amp; localString &amp; addStackIfRequested( sourceIndicator );
		endif;
		return;
		
	elseif _source.name = CM_Passport::addErrorFull.name then
		// Trx errors only
		sourceIndicator := "7. ";
		if self.chkTrxError.value then
			self.txtOutput.text := self.txtOutput.text &amp; CrLf &amp; sourceIndicator &amp; addTimeStampIfRequested() &amp; localString &amp; addStackIfRequested( sourceIndicator );
		endif;
		return;
		
	elseif _source.name = PortSchema::invLog.name then // navlw1 #JIRA-33107
		sourceIndicator := "5. ";
		// Start navlw1 #JIRA-33107
/* // ### JIRA 34497 28MAR 2025 NAVAB1
		sourceIndicator := "5. ";
		// Start navlw1 #JIRA-33107
		if _logLevelStr &lt;&gt; null then
			if app.logLevel &lt;&gt; _logLevelStr.Integer then
				return;
			endif;
		endif;
		*/
		if _logLevelStr &lt;&gt; null then
			sourceIndicator := _logLevelStr;  // ### JIRA 34497 28MAR 2025 NAVAB1 add the logging level to the output.
			if app.logLevel &gt; _logLevelStr.Integer then
				return;
			endif;
		endif;

		// End navlw1 #JIRA-33107
		if self.chkInvoice.value then
			self.txtOutput.text := self.txtOutput.text &amp; CrLf &amp; sourceIndicator &amp; " - " &amp;  addTimeStampIfRequested() &amp; localString &amp; addStackIfRequested( sourceIndicator );
		endif;
		return;
		
	else
		// Anywhere else...
		sourceIndicator := "8. ";
		if not self.chkGeneral.value then
			return;
		endif;
		
		if _logLevelStr &lt;&gt; null then
			if allSelectedLevels.isEmpty or not allSelectedLevels.includes(_logLevelStr) then
				return;
			endif;
		endif;
		
	endif;

	self.txtOutput.text := self.txtOutput.text &amp; CrLf &amp; sourceIndicator &amp; addTimeStampIfRequested() &amp; _source.qualifiedName &amp; "  "  &amp; localString &amp; addStackIfRequested( sourceIndicator );
	
epilog

	self.setButtons();
	textLengthChanged := length &lt;&gt; self.txtOutput.text.length;
	
	if textLengthChanged then
		self.txtOutput.selStart := self.txtOutput.text.length;
		self.txtOutput.selLength := 0;
	endif;

end;</source>
        <Parameter name="_source" type="Method"/>
        <Parameter name="_str" type="String"/>
        <Parameter name="_logLevelStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="addStackIfRequested" id="14018c98-2c98-4815-a329-8c132edebe9f">
        <source>addStackIfRequested( _sourceIndicator : String ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2011	cnwndl1	Initial creation

*/

vars

	pc : ProcessStackArray;
	md : MethodCallDesc;
	meth : Method;
	str : String;
	stackStr : String;
	count : Integer;

begin

	if chkStack.value then	//The user wants a stack call against every entry returned.
		create pc transient;
		process.currentStack(pc);
	
		foreach md in pc do
			count := count + 1;
			if count &lt;= 5 then
				// the first five are the calls to log the data.
				continue;
			endif;
			meth := md.method;
			str := _sourceIndicator &amp; md.display &amp; '  (' &amp; meth.class.name &amp; ')';
			stackStr := stackStr &amp; CrLf &amp; str;
		endforeach;
		
		return stackStr;
		
	endif;
	
	return null;

epilog

	if pc &lt;&gt; null then		
		pc.purge();
		delete pc;
	endif;

end;</source>
        <Parameter name="_sourceIndicator" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="addTimeStampIfRequested" id="66f657b8-ef9b-49ee-ba2f-9d5f86d560e6">
        <source>addTimeStampIfRequested():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2011	cnwndl1	Initial creation
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	time : Time;

begin

	if chkTime.value then	//The user wants a TimeStamp entry against every line.
		
		time := app.actualTimeServer.time;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		return time.userFormat($CnHHMMSS) &amp; "." &amp; time.milliSecond().String.padLeadingZeros(3) &amp; " - ";
		
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
