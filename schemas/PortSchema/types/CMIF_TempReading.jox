    <JadeMethod name="initialise" id="7ebba567-51f0-4b5a-9c72-e687a555f133">
        <updating/>
        <source>initialise( _reefer : CM_TrackedItem;
			_defaultNoChargeValue : Boolean;
			_dateTime : TimeStamp;				// TFS 52081
			_temperature : Real ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Sep 2021	navndl1	Initial creation	TFS 51874
27 Sep 2021	navdap1	TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
*/

vars

	reeferToUse : CM_TrackedItem;

begin

	//self.dateTime := app.actualTimeServer;		// TFS 52081
	self.dateTime := _dateTime;						// TFS 52081
	self.isRefConAlarm := false;
	self.isRefConReading := false;
	if _reefer &lt;&gt; null then
		self.myTerminal := _reefer.myTerminal;
	else
		self.myTerminal := app.myPassport.myTerminal;
	endif;
	self.myTrackedItem := _reefer;
	if _reefer &lt;&gt; null then
		reeferToUse := _reefer;
		if _reefer.isTransient then
			//proxy doesn't get readings populated, so wont know its a second reading or not.
			reeferToUse := _reefer.pxyGetRealObject();
		endif;
		self.noCharge := reeferToUse.noChargeForTemperature( _defaultNoChargeValue, self.dateTime );
	else	
		self.noCharge := _defaultNoChargeValue;
	endif;
	self.refConRawData := null;
	self.temperature := _temperature;
	self.userId := app.getMyUserCode();
	
	

epilog

end;</source>
        <Parameter name="_reefer" type="CM_TrackedItem"/>
        <Parameter name="_defaultNoChargeValue" type="Boolean"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_temperature" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setConnectAttribs" id="3cc283d3-dda8-4348-a9ec-6d7b57728f80">
