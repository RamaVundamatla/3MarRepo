    <JadeMethod name="parseColString" id="6bb3a392-f7b7-4457-95ca-1ac878cce5a1">
        <source>parseColString(_colText : String; _colFrom, _colTo : String output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	pos, textLength : Integer;
	firstCol, lastCol : String;
	lc : CM_LocationsController;
	group : CM_GeneralCargoAllocGroup;

begin
	if _colText = null then
		return;
	endif;
	
	pos := 1;
	textLength := _colText.length;
	
	_colFrom := _colText.scanUntil(" -", pos);
	
	if pos &lt;&gt; 0 and pos &lt; textLength and _colText[pos] = "-" then
		// assume start and end columns
		pos := pos + 1;
		_colTo := _colText.scanUntil(" ", pos);
	else
		_colTo := _colFrom;
	endif;
	
epilog

end;</source>
        <Parameter name="_colText" type="String"/>
        <Parameter name="_colFrom" type="String" usage="output"/>
        <Parameter name="_colTo" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ac59ff17-e389-4183-a3d3-61aabd7abd3f">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	proxy : SelfType;
	lc, rowLc : CM_LocationsController;
	group, pxyGroup : CM_GeneralCargoAllocGroup;
	completedOK : Boolean;

begin
	proxy := inheritMethod();
	
	foreach lc in self.allRowControllersById discreteLock do
		group := lc.CM_GeneralCargoAllocGroup;
		pxyGroup := group.pxyCreateUpdateProxy();
		pxyGroup.setDetails(pxyGroup.locationId, proxy);
	endforeach;
	completedOK := true;
	
	return proxy;
epilog
	if not completedOK then
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="repositionTIs" id="d1bc055e-5551-434c-8b79-aed24579d1b1">
        <updating/>
        <source>repositionTIs(_tis : CM_TIArray; _newGroups : StringArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/12/2020	jlgdap1		Initial creation TFS 50110 ASPA General Cargo Allocation Row - Label
//
vars
	idx : Integer;
	ti : CM_TrackedItem;
	group : CM_GeneralCargoAllocGroup;
	lc : CM_LocationsController;
	locationsToRemove : CM_LCArray;
	information : StringArray512;
	oldTILocation : String;
	yas : CM_YardAllocationArray;
	ya : CM_YardAllocation;
	location : String;

begin
	if _tis = null then
		return;
	endif;
	
	create locationsToRemove transient;	//07 Apr 2021	NDL	TFS 49912
	
	foreach idx in 1 to _tis.size do
		ti := _tis[idx];
		if ti.locationId &lt;&gt; _newGroups[idx] then
			group := self.allRowControllersById[_newGroups[idx]].CM_GeneralCargoAllocGroup;
		//	create locationsToRemove transient;		//07 Apr 2021	NDL	TFS 49912 moved uout of loop
			oldTILocation := ti.locationId;
			// Change the TI's location ID
			ti.setLocationId(group.getFullId);
			// Take all CM_GeneralCargoAllocControllers out of allLocations
			locationsToRemove.clear;
			foreach lc in ti.allLocations where lc.isKindOf(CM_GeneralCargoAllocController) do
				locationsToRemove.add(lc);
			endforeach;
			foreach lc in locationsToRemove do
				ti.allLocations.remove(lc);
			endforeach;
			// Add all the location controllers from the actual lcoation's group into the TI's allLocations
			foreach lc in group.allLocations do
				ti.allLocations.add(lc);
			endforeach;
			// and change the actual primary location
			ti.refreshMyFutureLocations(REAL_MODE, null);
			// Create an Info transaction to record the change in location
			create information transient;
			create yas transient;
			if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.myTerminalArea &lt;&gt; null then
				ti.myPrimaryActualLocation.myTerminalArea.allYardAllocations.copy(yas);
				location := ti.myPrimaryActualLocation.myTerminalArea.id;
			endif;
			information.add("Old Location: " &amp; oldTILocation);
			information.add("New Location: " &amp; ti.locationId);
			information.add("Allocations over area " &amp; location);
			foreach ya in yas do
				information.add(ya.code);
			endforeach;
			ti.createInfomationTransaction(	ti.id &amp; " location changed", information, null, app.myPassport );
			delete information;
			delete yas;
		endif;
	endforeach;
	
epilog
	delete locationsToRemove;
end;</source>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_newGroups" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="restoreGroupLabels" id="ce8a1583-a937-47d9-a972-6768f520ec42">
        <updating/>
        <source>restoreGroupLabels(_groupLabels : StringArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/07/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	groupLabel, colKey : String;
	pos : Integer;
	realLCs : CM_LCByIdExtKeyDict;
	lc : CM_LocationsController;
	group : CM_GeneralCargoAllocGroup;

begin
	create realLCs transient;	//07 Apr 2021	NDL	TFS 49912 - moved out of loop transient leak;
	
	if not _groupLabels.isEmpty then
		foreach groupLabel in _groupLabels do
			pos := 1;
			colKey := groupLabel.scanUntil("|", pos);
		//	create realLCs transient;
			realLCs.clear();	//07 Apr 2021	NDL	TFS 49912 - transient leak;
			self.getAllLocationsControllersById(realLCs);
			lc := realLCs.getAtKey(colKey);
			if lc &lt;&gt; null then
				group := lc.CM_GeneralCargoAllocController.myGroup;
				group.updateRangeLabel(groupLabel[pos+1:end]);
			endif;
		endforeach;
	endif;

epilog
	delete realLCs;
end;</source>
        <Parameter name="_groupLabels" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="417d7818-86f1-49f7-9774-0bf34ffe01e1">
        <updating/>
        <source>setForCreate(_proxy: CM_GeneralCargoAllocRowArea input; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars

begin
	inheritMethod(_proxy, _passport);
	
	self.createFromProxy(_proxy);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_GeneralCargoAllocRowArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateAllocArea" id="ab636ac1-5ecb-495c-987a-ed205714fe01">
        <updating/>
        <source>setForUpdateAllocArea(_proxy: CM_GeneralCargoAllocRowArea; _tis : CM_TIArray; _newGroups : StringArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/12/2020	jlgdap1		Initial creation TFS 50110 ASPA General Cargo Allocation Row - Label
//								Needed new parameters to setForUpdate so created a new method rather
// 								than changing all CM_TerminalArea setForUpdate methods
//
vars
	row : CM_RowAreaRow;
	rowLC : CM_RowController;
	pxyGroup, realGroup, lastGroup : CM_GeneralCargoAllocGroup;
	pxyLC, realLC, otherLC : CM_GeneralCargoAllocController;
	groupsToDelete : CM_LCArray;
	dividersChanged : Boolean;
	pos : Integer;
	allTIs : CM_TIArray;
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	realLCs, proxyLCs : CM_LCByIdExtKeyDict;
	locationsToRemove : CM_LCArray;
	oldTILocation : String;
	information : StringArray512;
	yas : CM_YAByPriorityDict;
	ya : CM_YardAllocation;
	groupLabels : StringArray;
	terminal : CM_Terminal;

begin
	self.setForUpdate(_proxy);
	
	// Retain any group labels and the first column in the group, so we can reassign the label later
	create groupLabels transient;
	// TFS 50110 this should have been working off the proxies, not the real objects
	//foreach lc in self.allRowControllersById do
		//realGroup := lc.CM_GeneralCargoAllocGroup;
		//if realGroup.rangeLabel &lt;&gt; null then
		//	groupLabels.add(realGroup.allLocations.first.CM_GeneralCargoAllocController.id &amp; "|" &amp; realGroup.rangeLabel);
		//endif;
	foreach lc in _proxy.allRowControllersById do
		pxyGroup := lc.CM_GeneralCargoAllocGroup;
		if pxyGroup.rangeLabel &lt;&gt; null then
			if lastGroup &lt;&gt; null and lastGroup.rangeLabel = pxyGroup.rangeLabel then
				groupLabels.removeAt(groupLabels.size);
			endif;
			groupLabels.add(pxyGroup.allLocations.first.CM_GeneralCargoAllocController.id &amp; "|" &amp; pxyGroup.rangeLabel);
		endif;
		lastGroup := pxyGroup;
		// TFS 50110 end 
	endforeach;
	
	// Are there any tracked items or yard allocations here? If not, just purge everything and start again
	create allTIs transient;
	self.getAllTrackedItems(allTIs);
	self.getAllPlannedQueuedTIs(allTIs);
	if allTIs.isEmpty and self.allYardAllocations.isEmpty then
		self.createFromProxy(_proxy);
		// Restore group labels if we can
		self.restoreGroupLabels(groupLabels);
		return;
	endif;
	
	// If we do have TIs in the area, we know that the only thing we can be changing is the dividers between groups
	// For each group, if the number of locations in the group hasn't changed, there's nothing to do
	// If the number of locations has changed, then create new / delete old
	foreach rowLC in _proxy.allRowControllersById do
		pxyGroup := rowLC.CM_GeneralCargoAllocGroup;
		realGroup := self.allRowControllersById[pxyGroup.id].CM_GeneralCargoAllocGroup;
		if realGroup = null then
			dividersChanged := true;
		else
			realGroup.setProductMinMax( rowLC );	//30 Mar 2021	NDL	TFS 49912 - updates of product min maxs for existing location controllers
		endif;
	endforeach;
	
	create groupsToDelete transient;
	if dividersChanged then
		// Find the groups that no longer match on ID
		foreach rowLC in self.allRowControllersById do
			realGroup := rowLC.CM_GeneralCargoAllocGroup;
			if _proxy.allRowControllersById[realGroup.id] = null then
				groupsToDelete.add(realGroup);
			endif;
		endforeach;
	endif;
	
	// Create new groups
	foreach rowLC in _proxy.allRowControllersById where self.allRowControllersById[rowLC.CM_GeneralCargoAllocGroup.id] = null do
		create realGroup persistent;
		realGroup.setDetails(rowLC.CM_GeneralCargoAllocGroup.id, self);
		realGroup.setProductMinMax( rowLC );	//30 Mar 2021	NDL	TFS 49912 - creates of product min maxs for new location controllers
	endforeach;
	
	// Get all the real and proxy locations controllers - these are the rows under the group levels
	create realLCs transient;
	create proxyLCs transient;
	self.getAllLocationsControllersById(realLCs);
	_proxy.getAllLocationsControllersById(proxyLCs);
	
	// Move the row controllers to the correct groups
	foreach lc in realLCs do
		pos := pos + 1;
		realLC := lc.CM_GeneralCargoAllocController;	
		// This is a real row - connect it to the appropriate row area row 
		if pos &lt;= self.allRows.size then
			row := self.allRows[pos];
			otherLC := row.allRowControllers.first.CM_GeneralCargoAllocController;
			if otherLC &lt;&gt; null and otherLC &lt;&gt; realLC then
				row.allRowControllers.remove(otherLC);
			endif;
			if not row.allRowControllers.includes(realLC) then
				row.allRowControllers.add(realLC);
			endif;
		endif;
		
		// Now see if we need to change the group this row belongs to
		pxyLC := proxyLCs[realLC.ident].CM_GeneralCargoAllocController;
		if pxyLC.myGroup.id = realLC.myGroup.id then
			continue;
		endif;
		
		realGroup := self.allRowControllersById[pxyLC.myGroup.id].CM_GeneralCargoAllocGroup;
		// Should always be one because we should have created it above
		realLC.setDetails(realLC.id, realGroup);		
	endforeach;
	
	// Now delete the groups we no longer need
	groupsToDelete.purge;
	
	// Restore group labels if we can
	self.restoreGroupLabels(groupLabels);
	
	// and move any TIs we need to move
	self.repositionTIs(_tis, _newGroups);
	
	// Tell the Satellite View screen we've changed
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_TerminalAreaUpdate), false, self);
	
epilog
	delete allTIs;
	delete groupsToDelete;
	delete locationsToRemove;
	delete information;
	delete yas;
	delete groupLabels;
	
	delete realLCs;	//07 Apr 2021	NDL	TFS 49912 transient leak;
	delete proxyLCs; 	//07 Apr 2021	NDL	TFS 49912 transient leak;
end;</source>
        <Parameter name="_proxy" type="CM_GeneralCargoAllocRowArea"/>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_newGroups" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="bf06f74c-d1a9-4cdc-b729-f8c491f986b2">
        <updating/>
        <source>setProxy(_id: String; _comment: String; _type: Integer; _length: Integer; _width: Integer; _releasePoint: Boolean; _terminal: CM_Terminal; _isGapManaged: Boolean; _isMarkedUp: Boolean; _labels: String; _autoRestrictions: Boolean; _stockControlled: Boolean; _hideFromOverView: Boolean; _allInterchangeAreas: CM_InterchangeAreaArray; _defaultInterchangeArea: CM_InterchangeArea) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars

begin
	inheritMethod(_id, _comment, _type, _length, _width, _releasePoint, _terminal, _isGapManaged, _isMarkedUp, _labels, _autoRestrictions, _stockControlled, _hideFromOverView, _allInterchangeAreas, _defaultInterchangeArea);
	
	self.widthOfArea := _width;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
