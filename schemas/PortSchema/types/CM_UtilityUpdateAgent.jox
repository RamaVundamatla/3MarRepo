    <JadeMethod name="utlUpdateAllTradeVoyagesPoC" id="53eb2ce0-886c-4174-9665-4d253274b616">
        <source>utlUpdateAllTradeVoyagesPoC(	_pxyTrade : CM_Trade;
								_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2009	cnwer1	Initial creation
23 September 2025	navhn30	MTN-36045: LNX | Trades table update only with active voyages.
*/

vars
	voyage : CM_Voyage;
	realTrade : CM_Trade;
	checkDT	: TimeStamp;
	allowActiveTrades	:  Boolean;
begin
	self.initialiseActivity();
	
	_pxyTrade.raiseExceptionIfNotProxy(method);
	realTrade:=_pxyTrade.pxyGetRealObject;
	if realTrade = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyTrade.code, null, null);
	endif;
	
	allowActiveTrades := app.myRoot.getConfig(AllowActiveDefaultTrade).Boolean;						//23.09.2025	navhn30 	MTN-36045
	checkDT	:=	app.actualTimeServer();
																	
	foreach voyage in realTrade.allVoyages do														//23.09.2025	navhn30 	MTN-36045

		if allowActiveTrades then
			if voyage.isActiveDisplay(checkDT) then	   // updates only active voyages PortsOfcall
				voyage.setForUpdatePortsOfCall(_pxyTrade.allPortRotations);
			endif;
		else
			voyage.setForUpdatePortsOfCall(_pxyTrade.allPortRotations);
		endif;
		
		if _passport.hasErrors then
			break;
		endif;		
			
	endforeach;

epilog

end;</source>
        <Parameter name="_pxyTrade" type="CM_Trade"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateAttach" id="5f51aac9-bc0a-4632-9921-f6c0d5963205">
        <updating/>
        <source>utlUpdateAttach(_theConnectParams : CMIF_ConnectParams io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		The proxy TI is stored in the connect Parameters
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realTrackedItem, aProxyTI:CM_TrackedItem;
	expectedEdition:Integer;
	tmpLC : CM_LocationsController;
	tmpTA : CM_TerminalArea;
	tmpTerm : CM_Terminal;
begin

	self.initialiseActivity();
	
	aProxyTI := _theConnectParams.myTrackedItem;
	
	aProxyTI.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	aProxyTI.pxyGetRealObjectAndEdition(realTrackedItem, expectedEdition);
	
	if realTrackedItem = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return;
	endif;

	app.myValUA.valAttach(realTrackedItem, _theConnectParams);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realTrackedItem);

	if _passport.noErrors and realTrackedItem.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'realTrackedItem', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrackedItem, true);
	endif;
	
	if _passport.noErrors then
		_theConnectParams.myTrackedItem := realTrackedItem;
		realTrackedItem.setForAttach(_theConnectParams, _passport);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrackedItem, false);
	endif;

end;</source>
        <Parameter name="_theConnectParams" type="CMIF_ConnectParams" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateAttachTIs" id="17bc0d17-7ef5-422b-a75b-02a50ac59ff6">
        <updating/>
        <source>utlUpdateAttachTIs(control : CMIF_TIUpdateController input; 
					//_masterContainer : CM_Container input;
					_masterTI : CM_TrackedItem input;			//+cnwml2 PAR23045
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     18 November 2003	cnwth2
//
// Purpose:     The parent container weight field is reduced by the weight of all children being
//				attached here. This is because when the container is received, the value entered
//				against the weight filed is in fact the totalWeight of the container plus
//				whatever is in it, not the container's empty weight.
//
//				#26662 11/01/2011. Now, totalWeight and cargoWeight are edited manualy.
//				totalWeight can be certified by a user, when weighing etc.
//				cargoWeight is calculated automatically when packing/unpacking only.
// 09/09/2013	cnwdap1		PAR #31196 if the master TI is a Tranship, make sure the
//							child is set up properly, removed lots of commented-out code 
// 20/11/2019	jlgzm1		TFS 47222 Remove All Import stops is redundant
// ----------   ----------  --------------------------------------------------
vars
	persistentTI			: CM_TrackedItem;
	proxyChild				: CM_TrackedItem;				// PAR #31196
	transhipInterface		: CMIF_TranshipTIController;	// PAR #31196
	deleteSet				: CM_TISet;						// PAR #31196
begin
	
	if _masterTI = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Master container passed in was null');
		return;
	endif;
	
	app.myValUA.valAttachTIWeightVolume(_masterTI, control);
	
	create deleteSet transient;																			// PAR #31196
	
	foreach persistentTI in control.allPersistentTIs do
		_masterTI.attachChild(persistentTI, _passport);
		
		// PAR #31196 make the child a proper tranship if the parent is a tranship						// PAR #31196
		if _masterTI.isTranshipItem then																// PAR #31196
			create transhipInterface transient;															// PAR #31196
			transhipInterface.myExportDestPort 	:= app.myRoot.allPorts[_masterTI.destinationPort];		// PAR #31196
			transhipInterface.myExportVoyage	:= _masterTI.myExportVoyage;							// PAR #31196
			transhipInterface.myTranshipToPort	:= _masterTI.myTranshipToPort;							// PAR #31196
			transhipInterface.remarks			:= _masterTI.remarksTranship;							// PAR #31196
			// TFS 2122 add null test
			if _masterTI.myTranshipDetail &lt;&gt; null then
				transhipInterface.myExportDisPort	:= _masterTI.myTranshipDetail.myDischargePort;			// PAR #31196
				transhipInterface.bookingRef		:= _masterTI.myTranshipDetail.exportBookingReference;	// PAR #31196
				transhipInterface.billOfLading		:= _masterTI.myTranshipDetail.exportBOL;				// PAR #31196
			endif;
			proxyChild := persistentTI.pxyGetRealObject();												// PAR #31196
			if proxyChild = null then																	// PAR #31196
				proxyChild := app.createUpdateProxy(persistentTI).CM_TrackedItem;						// PAR #31196
				deleteSet.add(proxyChild);																// PAR #31196
			endif;																						// PAR #31196
			proxyChild.setPxyFromCMIF_TranShip(transhipInterface, persistentTI);						// PAR #31196
			persistentTI.setMyVoyage(_masterTI.myImportVoyage, _passport);								// PAR #31196
			persistentTI.setTranship(proxyChild, _passport, true);										// PAR #31196
			delete transhipInterface;																	// PAR #31196
		endif;																							// PAR #31196
		
		if (not _passport.noErrors) then
			break;
		endif;
	endforeach;
	
epilog
	deleteSet.purge;																					// PAR #31196
	delete deleteSet;																					// PAR #31196
	delete transhipInterface;																			// PAR #31196
end;</source>
        <Parameter name="control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_masterTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
