    <JadeMethod name="drawTerminalAreaView" id="6c6c3857-afde-48d1-9ddc-5411ad74b0cb">
        <updating/>
        <source>drawTerminalAreaView() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Nov 2010	cnwer1	Initial creation
*/

vars

	cdc : YRD_ContainerDrawingController;
	ydb : YRD_ContainerGridAreaDockBar;
	tmpScrollableFrame	: CMUI_ScrollableFrame;
	viewMode : Integer;

begin
	self.visible:=false;
	self.getDefaultViewMode(viewMode);
	
	self.dkbGridArea.visible := false;
	self.dkcGridArea.visible := true;
	self.dkbGridArea.isForEndView := false;
	self.dkbGridArea.isForOverview := true;
	
	// NOTE. the create of YDB creates the frames etc.
	ydb := self.dkbGridArea.cloneSelf(true);
	self.allDockBars.add(ydb);
	self.addControl(ydb);
	ydb.parent := self.dkcGridArea;

	ydb.visible := true;
	ydb.postCreate();
	ydb.myDrawingController.YRD_GridOViewDrawingController.myGridOverviewForm := self;
	ydb.left := 1;

	self.myDrawingFrame := ydb.myDrawingFrame; //self.frmScrollBackgrd;
	self.myDrawingFrame.doAutoScrolling := true;
	cdc := ydb.myDrawingController;
	self.initialiseDrawerController(cdc);
	
	cdc.showDrawingFrame(false);

	self.myDrawingFrame.changeBackColor(self.defYardBackColSelected);

	ydb.setScrolledCallbackMethod(YRD_GridAreasOverviewForm::handleGridAreaScrolledEvent.name);
	ydb.myScrollableFrame.height:=ydb.clientHeight;
	//ydb.myScrollableFrame.parentAspect:=Frame.ParentAspect_StretchBoth;
	ydb.setHLabelDetails(0, false);
	ydb.setVLabelDetails(0, false);
	// when able add labels as virtual to CMUI_GridAreaDockBar and

	tmpScrollableFrame := ydb.myScrollableFrame;
	tmpScrollableFrame.labels := self.showLabels();
	cdc.setScale(self.xmlZoomFactor, true, true); 

	cdc.setFlip(false,false);
	cdc.moveMode := self.moveModeForm;
	
	cdc.initALL(null);
	cdc.setViewMode(viewMode);
	//epr par 33594 24/3/15
	cdc.YRD_GridOViewDrawingController.setShowMachineWorkzones(not self.xmlHideRTG);
	cdc.YRD_GridOViewDrawingController.setHeightRestrictionOption(self.xmlHeightRestrict);
	cdc.YRD_GridOViewDrawingController.setMyTerminalAreaView(self.myTerminalAreaView);
	cdc.YRD_GridOViewDrawingController.setShowDirections(not self.xmlDirections);
	cdc.drawSelfALL();
	
//	self.myDrawingFrame.myOverlayViewingFrame.visible:=true;
//	self.myDrawingFrame.myOverlayViewingFrame.init;
	
	// 19 Jan 2012	NDL	Par 28901
	if not cdc.YRD_GridOViewDrawingController.getOverlayViewFrame.transparent then
		cdc.YRD_GridOViewDrawingController.getOverlayViewFrame.visible:=true;
		cdc.YRD_GridOViewDrawingController.getOverlayViewFrame.slimGraphics();
		cdc.YRD_GridOViewDrawingController.getOverlayViewFrame.transparent:=true;
		cdc.YRD_GridOViewDrawingController.getOverlayViewFrame.zOrder(1);
	endif;
	
	ydb.myDrawingFrame.myDragSelectFrame.visible := true;

	//ydb.cnEcResizeContents();

	self.setMyCurrentDrawingController(ydb.myDrawingController, false);

	self.doNotesForLegendStartStop(self.myCurrentDrawingController.viewMode,self.myCurrentDrawingController);


	self.doResizeBars();

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAddYA.enabled:= false;
		self.btnDeleteYA.enabled:= false;
		self.btnEditYA.enabled:= false;
		self.tblYAM.userInputEnabled := false;
		self.tblYAM.readOnly := true;
		self.dkbGridArea.myDrawingFrame.myDragSelectFrame.enabled := false;
	endif;
	
epilog
	self.visible:=true;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="findCargoFromObject" id="00c871bd-4d8a-4e90-bccd-3a373dc25b6b">
        <updating/>
        <source>findCargoFromObject( _object : Object; _objArray : CM_ObjectArray io ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2011	cnwndl1	Initial creation	Par 28236
*/

vars

	termArea 	: CM_TerminalArea;
	gridObject 	: CM_GridObject;
	obj 		: Object;
	ti 			: CM_TrackedItem;
	irrBlockCont : CM_IrregularBlockController;
	shelf : CM_RackShelfController;

begin

	if _object = null then
		if self.allSelectedRegionLocs.isEmpty then
			return;
		endif;
		foreach obj in self.allSelectedRegionLocs discreteLock do
			if obj.CM_LocationsController.isRack then	//27 Aug 2013	NDL	Par 32308
				foreach shelf in obj.CM_IrregularBlockController.allSubLocations do
					foreach ti in shelf.allTrackedItems discreteLock do
						_objArray.addExclusive(ti);
					endforeach;
				endforeach;
			else
				foreach ti in obj.CM_LocationsController.allTrackedItems discreteLock do
					_objArray.addExclusive(ti);
				endforeach;
			endif;
		endforeach;
		return;
		
	else
		if _object.isKindOf(CM_TerminalArea) then
			termArea := _object.CM_TerminalArea;
		elseif _object.isKindOf(CM_GridObject) then
			gridObject := _object.CM_GridObject;
		elseif _object.isKindOf(CM_IrregularBlockController) then
			irrBlockCont := _object.CM_IrregularBlockController;
		else
			return;
		endif;
	
	endif;
	
	create self.locationControllerArray transient;
	
	if termArea &lt;&gt; null then
		termArea.getAllLCsWithCargo(self.locationControllerArray);
	elseif gridObject &lt;&gt; null then
		gridObject.getAllLocationsControllers(self.locationControllerArray, true);
	elseif irrBlockCont &lt;&gt; null then
		if irrBlockCont.isRack then
			irrBlockCont.allSubLocations.copy(self.locationControllerArray);
		else
			self.locationControllerArray.add(irrBlockCont);
		endif;
	endif;
	
	if self.locationControllerArray.isEmpty  then
		return;
	endif;
	
	foreach obj in self.locationControllerArray discreteLock do
		foreach ti in obj.CM_LocationsController.allTrackedItems discreteLock do
			_objArray.addExclusive(ti);
		endforeach;
	endforeach;

epilog

	delete self.locationControllerArray;

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_objArray" type="CM_ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findLocationsFromObject" id="509dfb32-0f11-4baa-bbe6-713dffb7fd75">
        <updating/>
        <source>findLocationsFromObject( _object : Object; _objArray : CM_ObjectArray io ) protected, updating;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

begin
	self.myAssistant.findLocationsFromObject(_object, _objArray);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_objArray" type="CM_ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findOATisFromObject" id="320cc7c6-fea3-4f30-8145-06120f45f9a2">
        <updating/>
        <source>findOATisFromObject( _object : Object; _objArray : CM_TIArray io ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars
	
	allCargoForObject : CM_ObjectArray;
	termAreas : CM_TerminalAreaMasterSet;
	termArea : CM_TerminalArea;
	obj : Object;
	ti : CM_TrackedItem;
	locCont : CM_LocationsController;
	outOfAllocTis : CM_TIByIdDict;
	intersectTis : CM_TIArray;

begin
	
	if _object = null then
		if self.allSelectedRegionLocs.isEmpty then
			return;
		endif;
	elseif _object.isKindOf(CM_TerminalArea) then
		// OK we know how to handle Terminal Areas
	elseif _object.isKindOf(CM_GridRow) then
		// OK we know how to handle Grid Rows
	elseif _object.isKindOf(CM_GridColumn) then
		// OK we know how to handle Grid Rows
	elseif _object.isKindOf(CM_IrregularBlockController) then
	// OK we know how to handle Wharehouse areas
	else
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR,class.name, method.name,"Input type of " &amp; _object.class.name &amp; " not coded for!", null, null);
		return;
	endif;
	
	//find all cargo in the 'area' the user could be interested in.
	create allCargoForObject transient;
	self.findCargoFromObject( _object, allCargoForObject );
	if allCargoForObject.isEmpty then
		return;
	endif;
	
	//find the areas we are interested in.
	create termAreas transient;
	foreach obj in allCargoForObject discreteLock do
		ti := obj.CM_TrackedItem;
		locCont := ti.myPrimaryActualLocation;
		if locCont &lt;&gt; null then
			termArea := locCont.myTerminalArea;
			if termArea &lt;&gt; null then
				termAreas.addNoDuplicates(termArea,false);
			endif;
		endif;
	endforeach;
	
	if termAreas.isEmpty then
		return;
	endif;
	
	// get a collection of the cargo within the terminal areas that is 'out of allocation'
	create outOfAllocTis transient;
	self.findOutOfAllocationTisFor( termAreas,  outOfAllocTis );
	if outOfAllocTis.isEmpty then
		return;
	endif;
	
	//find the intersection of the two cargo collections
	create intersectTis transient;
	foreach ti in outOfAllocTis do
		if allCargoForObject.includes(ti) then
			intersectTis.addExclusive(ti);
		endif;
	endforeach;	
	if intersectTis.isEmpty then
		return;
	endif;
	
	intersectTis.copy(_objArray);

epilog

	delete allCargoForObject;
	delete termAreas;
	delete outOfAllocTis;
	delete intersectTis;

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_objArray" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findOutOfAllocationTisFor" id="70eb749d-da39-4881-af70-488c38af074c">
        <source>findOutOfAllocationTisFor( _termAreas : CM_TerminalAreaMasterSet; _tiDict : CM_TIByIdDict io ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	cmifMonitor : CMIF_Monitor;
	qryAgent : CMIF_SpaceUtilisationQryAgent;

begin

	if _termAreas = null or _termAreas.isEmpty then
		return;
	endif;

	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		cmifMonitor := app.myPassport.myCMIFMonitor;
		app.myPassport.setMyCMIFMonitor( null );
		delete cmifMonitor;
	endif;
	
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	app.myPassport.setMyCMIFMonitor( cmifMonitor );
	
	create qryAgent transient;
	qryAgent.init();
	qryAgent.myTerminal := self.myTerminal;
	qryAgent.setAgentsBooleans(false, false, false, false, false, false, false, false, true, false, true);
	_termAreas.copy(qryAgent.allQryTerminalAreas);
	qryAgent.doQuery();
	
	if qryAgent.allNonMatchTIsYA.isEmpty then
		return;
	endif;
	
	qryAgent.allNonMatchTIsYA.copy(_tiDict);

epilog
	
	delete qryAgent;
	app.myPassport.setMyCMIFMonitor( null );
	delete cmifMonitor;

end;</source>
        <access>protected</access>
        <Parameter name="_termAreas" type="CM_TerminalAreaMasterSet"/>
        <Parameter name="_tiDict" type="CM_TIByIdDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findRegionGridLocs" id="b951d25f-0e0a-4186-bcb6-d864f31f05a0">
        <updating/>
        <source>findRegionGridLocs( _objArray : CM_ObjectArray io; _breakOnFirst : Boolean; _includeNonGridShowable : Boolean ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	locCont : CM_LocationsController;
	invalidObj : Boolean;

begin

	if self.allSelectedRegionLocs.isEmpty then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, locCont, invalidObj );

	foreach locCont in self.allSelectedRegionLocs discreteLock do
		//if locCont.isKindOf(CM_GridController) then
		if locCont.isKindOf(CM_GridController) or locCont.isRack then	//27 Aug 2013	NDL Par 32308
			_objArray.addExclusive( locCont );
			if _breakOnFirst then
				return;
			endif;
			
		//20 Jan 2012	NDL	Par 28901
		elseif _includeNonGridShowable then
			if locCont.isKindOf(CM_RoRoController) then
				_objArray.addExclusive( locCont );
				if _breakOnFirst then
					return;
				endif;
			endif;
			
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_objArray" type="CM_ObjectArray" usage="io"/>
        <Parameter name="_breakOnFirst" type="Boolean"/>
        <Parameter name="_includeNonGridShowable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findRegionTis" id="e1c1a60a-a0a2-415b-be17-5f953290a53b">
        <updating/>
        <source>findRegionTis( _objArray : CM_TIArray io; _breakOnFirst : Boolean ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	locCont : CM_LocationsController;
	invalidObj : Boolean;
	ti : CM_TrackedItem;
	shelf : CM_RackShelfController;

begin

	on Exception do app.handleDeletedObject( exception, locCont, invalidObj );

	foreach locCont in self.allSelectedRegionLocs discreteLock do
		if locCont.isRack then
			foreach shelf in locCont.CM_IrregularBlockController.allSubLocations do
				foreach ti in shelf.allTrackedItems discreteLock do
					_objArray.addExclusive(ti);
					if _breakOnFirst then
						return;
					endif;
				endforeach;
			endforeach;
		else
			foreach ti in locCont.allTrackedItems discreteLock do
				_objArray.addExclusive(ti);
				if _breakOnFirst then
					return;
				endif;
			endforeach;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_objArray" type="CM_TIArray" usage="io"/>
        <Parameter name="_breakOnFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAlert" id="6c57bbc6-ebb1-463c-9f4b-b4b2c20648d7">
        <source>getAlert():CM_SystemAlert protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2012	cnwndl1	Initial creation	Par 28953

*/

vars

	anAlert : CM_SystemAlert;

begin

	if self.fldFailAutoPlan.topSheet = self.shtFailAutoPlan then

		anAlert := self.tblFailAutoPlan.getSelectedObject().CM_SystemAlert;
		
	elseif self.fldFailAutoPlan.topSheet = self.shtFailRequest then
	
		anAlert := self.tblFailRequest.getSelectedObject().CM_SystemAlert;
		
	endif;
	
	return anAlert;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_SystemAlert"/>
    </JadeMethod>
