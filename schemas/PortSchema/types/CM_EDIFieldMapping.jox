    <JadeMethod name="setForUpdate" id="7234570b-e2e4-46ba-a94d-687cef1ea508">
        <updating/>
        <source>setForUpdate(_proxy : CM_EDIFieldMapping; _pxyType : CM_EDIFieldMappingType) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 August 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
23/04/2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
*/
vars

begin
	self.fieldNum 				:= _proxy.fieldNum;
	self.myEDIFieldMappingType 	:= _pxyType;
	self.userDesc 				:= _proxy.userDesc;
	self.fieldDescr 			:= _proxy.fieldDescr;
	self.propName				:= _proxy.propName;
	self.length					:= _proxy.length;
	
	self.allStripChars.clear();
	
	_proxy.allStripChars.copy(self.allStripChars);
	
	self.myMeasurementType		:= _proxy.myMeasurementType;				// PAR #33005
end;</source>
        <Parameter name="_proxy" type="CM_EDIFieldMapping"/>
        <Parameter name="_pxyType" type="CM_EDIFieldMappingType"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementType" id="b3b23782-a09a-4f89-ab35-64042041e74e">
        <updating/>
        <source>setMeasurementType(_measure : CM_MeasurementType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2014	cnwdap1		Initial creation PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//
vars

begin
	self.myMeasurementType := _measure;
epilog

end;</source>
        <Parameter name="_measure" type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ac54423a-738e-4d77-b1f9-c26897d822ac">
        <updating/>
        <source>setProxy(_fieldMappingType 		: CM_EDIFieldMappingType;
		_fieldNum 			: Integer;
		_ediDataType : Integer;
		_userDescr,
		_fieldDescr,
		_propName,
		_stripChars 		: String;
		_fieldLength		: Integer;
		_usePreviousValueifNull	: Boolean;
		_measurementType : CM_MeasurementType) updating;				// PAR #33005
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
23/04/2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
*/
vars
	len,
	pos			: Integer;
	char		: Character;
begin
	self.myEDIFieldMappingType 	:= _fieldMappingType; //ccms1008 messina  cnwrs1 Sept 2009
	self.fieldNum 			:= _fieldNum;
	self.fieldDescr			:= _fieldDescr;
	self.propName			:= _propName;
	self.userDesc			:= _userDescr;
	self.length 			:= _fieldLength;
	self.usePreviousValueIfNull := _usePreviousValueifNull;
	len := _stripChars.length;
	self.allStripChars.clear();
	//pos := 1;
	foreach pos in 1 to len do
		self.allStripChars.add(_stripChars[pos].Character);
	endforeach;
	
	self.myMeasurementType := _measurementType;							// PAR #33005
end;</source>
        <Parameter name="_fieldMappingType" type="CM_EDIFieldMappingType"/>
        <Parameter name="_fieldNum" type="Integer"/>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_userDescr" type="String"/>
        <Parameter name="_fieldDescr" type="String"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_stripChars" type="String"/>
        <Parameter name="_fieldLength" type="Integer"/>
        <Parameter name="_usePreviousValueifNull" type="Boolean"/>
        <Parameter name="_measurementType" type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="setStringValue" id="1fce4ae8-63c2-4cd9-a076-6533cd963c87">
        <source>setStringValue(_ediTI : CM_EDITrackedItem input; _propName, _value : String) protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 August 2007 By cnwth2

Purpose:	CCMS 1565 - concatinate value up to max length

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
// 14 Dec 2010  cnwrs1      ccms 1976 - need to keep XML and CSV EDI Files types working the same so this method 
//                          is in CM_EDIFieldMapping and in CM_EDITrackedItem they both must be kept in step in 782 the CM_EDIFieldMapping method will be removed in 791	
//
// cnwrs1 this hould be replaced by CM_EDITrackedItem::setStringValue in 791
//
vars
	origValue				: String;
	lenRemaining			: Integer;
	prop					: Attribute;
begin
	prop := _ediTI.class.getPropertyInHTree(_propName).Attribute;
	if prop  = null then
		return;
	endif;
	
	if prop.length &gt; 0 then//if it's a max length string the length integer value here will be -1
		//N.B the length integer value of a string attribute is always 1 more than what you see
		//in the IDE - hence the subtraction of 1 below
		_ediTI.setPropertyValue(_propName, _value[1:prop.length - 1]);
	else//it's max length
		_ediTI.setPropertyValue(_propName, _value);
	endif;
	
	/*
		uncomment once CCMS 1565 once approved and remove above - this has been somewhat tested - see th2
		origValue := _ediTI.getPropertyValue(_propName).String;
		if prop.length &gt; 0 then//if it's a max length string the length integer value here will be -1
			//N.B the length integer value of a string attribute is always 1 more than what you see
			//in the IDE - hence the subtraction of 1 below
			lenRemaining := (prop.length - 1) - origValue.length;
			if lenRemaining &lt; 2 then
				return;
			endif;
			
			_ediTI.setPropertyValue(_propName, origValue &amp; _value[1:lenRemaining]);
		else
			_ediTI.setPropertyValue(_propName, origValue &amp; _value);//it's a max length string
		endif;	
	endif;
	*/
	
end;


</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a7ee9541-1d53-4eb0-a7b9-8e1b952ca693">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if self.fieldNum = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'mapping field num is null');
	endif;
	
	if self.fieldDescr = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Mapping field type for field ' &amp; self.fieldNum.String, ETRow_Name, null);
		app.raiseCMException1(Input_required_field_mapFldTyp, self.fieldNum.String, ETRow_Name, null); // cnwdb2	PAR 35364


	endif;
	
	if self.propName = null then
		app.raiseCMException1(Prope_name_been_speci_must_spe,self.fieldNum.String, null, null);
	endif;
	
	if self.myEDIFieldMappingType.myEDIFileTypeUser.fileType = CM_EDIFileTypeUser.FORMAT_FIXEDLENGTH and 
	   self.length &lt; 1 and
	   (not self.doIgnore) then
		app.raiseCMException1(Field_lengt_speci_field_numbe_, self.fieldNum.String,null, null);
	endif;
end;</source>
    </JadeMethod>
</Class>
