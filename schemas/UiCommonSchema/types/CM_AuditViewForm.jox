    <JadeMethod name="displaySelectorResults" id="bbe9cd09-95fc-4c06-b3d6-2016d10665bc">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlgmp6	Initial creation	TFS39243

*/

vars
	object: Any;
	audit: CM_AuditObject;
	breakOut: Boolean;
	obj: Object;
	idx,
	startRow,
	endRow,
	numItems: Integer;
	intRow: Integer;
begin
	self.zHideSearcher();

	foreach object in _resultCollection do
		audit := object.CM_AuditObject;
		self.addObjectToTable(audit, numItems, breakOut);
		if breakOut then
			break;
		endif;
	endforeach;

	if self.isSearcherFloating then
		self.searcherShowHideControls(true);
		self.frmSearch.visible := false;
		self.isSearcherVisible := false;
	endif;
	self.mode := self.Mode_View;

	//show something
	intRow := self.tblData.fixedRows + 1;
	if intRow &lt;= self.tblData.rows then
		self.tblData.clearAllSelected();
		self.myCurrentObject := self.tblData.accessRow(intRow).itemObject.CM_Object;
		self.tblData.accessedRow.selected := true;
		self.showThumbnailData(self.myCurrentObject.CM_Object);
	endif;
	
	self.numItemsShown	:= numItems;
	if self.useNumRowsShown then
		self.showNumRowsShown();
	endif;

	startRow	:= self.tblData.fixedRows + 1;
	endRow		:= self.tblData.rows;
	
	foreach idx in startRow to endRow do
		if (idx mod 2 = 0) then
			self.tblData.accessRow(idx).backColor := self.colorRow1;
		else
			self.tblData.accessRow(idx).backColor := self.colorRow2;
		endif;
		obj := self.tblData.accessedRow.itemObject;
		self.tblDataShowDataSpecial(idx, obj);
	endforeach;
epilog

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="3af18859-1c45-4aff-907f-df071909266a">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2022	navtnr20	Initial creation	TFS 52944
28 March 2022   navsrk20    TFS 53182 Previously filter property details displaying at right side for empty table
05 April 2022   navhl20     TFS 53292 Audit Maintenance filter is not working properly when we enter updated record After details
*/

vars
	filterText		    : String;
	rowIdx,
	start,
	colIndex 			: Integer;
	cellText,
	auditTextStr,
	postAuditTextStr    : String;
	methodStartTime	    : TimeStamp;
	obj 			    : Object;
	filteredRowCount    : Integer;
	firstFilteredRow	: Integer;
	
begin
	filteredRowCount := 0;
	//filterText 		 := self.txtFilterBox.text.toUpper;
	filterText := self.frmTableFilter.txtFilterBox.text.toUpper(); //25/06/2024	navkc1 CR 64823 Task 64824
	
	if filterText = "" then
		//self.clearFilter();
		self.tblData.clearAllSelected();
		self.myCurrentObject := self.tblData.accessRow(self.tblData.fixedRows + 1).itemObject.CM_Object;
		self.tblData.accessedRow.selected := true;
		self.showThumbnailData(self.myCurrentObject.CM_Object);
		self.numItemsShown:=self.frmTableFilter.numOfRowVisible; //15/01/2025	navkc1 JIRA Defect Sub-task MTN-33784
		self.showNumRowsShown();	//15/01/2025	navkc1 JIRA Defect Sub-task MTN-33784
		return;
	else
		//self.btnClearFilter.enabled := true;
		self.frmTableFilter.btnClearFilter.enabled := true; //25/06/2024	navkc1 CR 64823 Task 64824
	endif;
	
	start := self.tblData.fixedRows + 1;
	colIndex := self.tblData.getColumnByRowName(ETRow_SubjectIdString);
	
	//01/08/2024	navkc1 Bug 65204 bring this back to do custom filtering
	foreach rowIdx in start to self.tblData.rows do	: rowLoop
			obj 	 := self.tblData.accessRow(rowIdx).itemObject;
			//Start TFS 53292
			auditTextStr := obj.CM_AuditObject.auditText.toUpper;
			postAuditTextStr := obj.CM_AuditObject.postAuditText.toUpper;
			cellText := self.tblData.accessCell(rowIdx, colIndex).text.toUpper;
			//End TFS 53292
			if auditTextStr.length &gt; 0 and auditTextStr.pos(filterText, 1) &gt; 0 then
				if firstFilteredRow = null then
					firstFilteredRow := rowIdx;
				endif;
				self.tblData.accessedRow.visible := true;
				filteredRowCount				 := filteredRowCount + 1;
				continue rowLoop;
			//Start TFS 53292
			elseif postAuditTextStr.length &gt; 0 and postAuditTextStr.pos(filterText, 1) &gt; 0 then
				if firstFilteredRow = null then
					firstFilteredRow := rowIdx;
				endif;
				self.tblData.accessedRow.visible := true;
				filteredRowCount				 := filteredRowCount + 1;
				continue rowLoop;
			//End TFS 53292
			elseif cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				if firstFilteredRow = null then
					firstFilteredRow := rowIdx;
				endif;
				self.tblData.accessedRow.visible := true;
				filteredRowCount				 := filteredRowCount + 1;
				continue rowLoop;
			else
				self.tblData.accessedRow.visible := false;
			endif;
	endforeach;
	
	//25/06/2024	navkc1 CR 64823 Task 64824
	//if self.frmTableFilter.numOfRowVisible &gt; 0 then 
	if filteredRowCount &gt; 0 then	//15/01/2025	navkc1 JIRA Defect Sub-task MTN-33784
		foreach rowIdx in start to self.tblData.rows do
			if self.tblData.accessRow(rowIdx).visible then
				firstFilteredRow := rowIdx;
				break;
			endif;
		endforeach;
	endif;
	if  firstFilteredRow &gt; self.tblData.fixedRows then
		self.tblData.clearAllSelected();
		self.myCurrentObject := self.tblData.accessRow(firstFilteredRow).itemObject.CM_Object;
		self.tblData.accessedRow.selected := true;
		self.showThumbnailData(self.myCurrentObject.CM_Object);
	endif;
	
	//filteredRowCount := self.frmTableFilter.numOfRowVisible; //15/01/2025	navkc1 JIRA Defect Sub-task MTN-33784
	self.numItemsShown:=filteredRowCount;
	self.showNumRowsShown();
	
	if filteredRowCount = 0 then                        // TFS 53182 
	   self.tblThumb.rows := 0;                         // TFS 53182
	endif;                                              // TFS 53182
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="6ac1c49b-308e-48f3-bf4c-5f7bccb9037e">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:     30 October 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	gtpTable		: CM_GenericTablePrint;
	pd				: CMS_Progress;
	now				: TimeStamp;
	obj				: Object;
	prntTbl			: Table;
	tmpStr			: String;
	dtlStr			: String;
	aoi				: CM_AuditObjectImage;
	api				: CM_AuditPropertyImage;
	firstTime		: Boolean;
	numRows			: Integer;
	idx				: Integer;
	tmpJadeReport	: JadeReport;//changed by cnwyl1 29/06/2006 for par 119**
	startRow		: Integer;

begin
	app.mousePointer := MP_HOURGLASS;

	if true /*preview*/ then
		create tmpJadeReport transient;//changed by cnwyl1 29/06/2006 for par 119**
		tmpJadeReport.description := "Audit Enquiry Details";//changed by cnwyl1 29/06/2006 for par 119**
//		app.printer.printPreview := true;
		app.printer.setReport(tmpJadeReport);//changed by cnwyl1 29/06/2006 for par 119**
	endif;

	app.printer.suppressDialog := true;

	create gtpTable;
	create pd;
	pd.show();
	pd.raiseExceptionOnAbort := false;
	pd.setAction("Printing Audit Details");

	app.printer.setMargins(Print_Landscape,0,0,10,10);

	numRows := self.tblData.rows;// - self.tblData.fixedRows; cnwdad1 07/08/2008 - PAR #17673.
	pd.progress.partsInJob := numRows;

	// setup header information

	// set header
	gtpTable.frHeader.width := app.printer.pageWidth;
	
	if self.myAudittedObject &lt;&gt; null then
		gtpTable.lblHeader1.caption := "Audit Enquiry Details for " &amp; self.myAudittedObject.auditIdDisplay();					
	else
		gtpTable.lblHeader1.caption := "Audit Enquiry Details";
	endif;
	
	gtpTable.lblHeader1.visible := true;
	gtpTable.lblHeader1.centreHorizontallyInParent();
	app.printer.setHeader(gtpTable.frHeader);
	
	//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	now := app.actualTimeServer();
	// set footer
	gtpTable.frFooter.width := app.printer.pageWidth;
	gtpTable.lblTheUser.caption := app.getMyUserCode;
	gtpTable.lblTheDatePrinted.caption := self.systemToLocalTime(now).String;	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	app.printer.setFooter(gtpTable.frFooter);

	// RJS - new stuff to load table
	prntTbl := gtpTable.table;
	prntTbl.columns := 7;
	
	if self.myAudittedObject &lt;&gt; null then
		// hide the first column as this is the id of myObject and
		// will be the same for each row
		prntTbl.columnVisible[1] := false;
	endif;
	
	prntTbl.rows := 0;
// cnwdad1 07/08/2008 - PAR #17673 (allow for column organiser rearranging columns).
//	gtpTable.addRowToTable('Description' &amp; Tab &amp; 'Type' &amp; Tab &amp;
//						   'Date/Time' &amp; Tab &amp; 'User' &amp; Tab &amp; 
//						   'Property' &amp; Tab &amp; 'Value' &amp; Tab &amp;
//						   'Value After');
	gtpTable.addRowToTable(	tblData.getHeadingsString(Tab) &amp;
							Tab &amp; "Property" &amp;
							Tab &amp; "Value After");
	
	prntTbl.fixedRows := 1;
	startRow	:=	self.tblData.fixedRows + 1;
	
	foreach idx in startRow to numRows do
		obj := self.tblData.accessRow(idx).itemObject;
		
		if obj = null then
			continue;
		endif;

		pd.progress.partsDone := idx;
		pd.doWindowEvents(0);
		
		if pd.aborted = true then
			break;
		endif;

		tmpStr := self.tblDataDisplayRow(null, obj);
		
		if tmpStr = null then
			continue;
		endif;
		
		// Get the change data
		aoi := obj.CM_AuditObject.getAuditObjectImage();
		
		if aoi = null and aoi.hasPropertyImages() then
			gtpTable.addRowToTable(tmpStr);
		else
			firstTime := true;
			
			foreach api in aoi.allPropertyImages do
				dtlStr := api.getDisplayString();
				
				if firstTime then
					firstTime := false;
					tmpStr := tmpStr &amp; Tab &amp; dtlStr;
				else
					tmpStr := Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; dtlStr;
				endif;
				
				gtpTable.addRowToTable(tmpStr);
			endforeach;
		endif;
		
	endforeach;
	
	gtpTable.printTable(null, false, pd);

	if pd.aborted then
		app.printer.abort();
		return;
	endif;
	
	pd.unloadForm();

	app.printer.close();
	if true then // if print preview call method //changed by cnwyl1 29/06/2006 for par 119**
		app.printPreview(tmpJadeReport, true);//changed by cnwyl1 29/06/2006 for par 119**
	endif;//changed by cnwyl1 29/06/2006 for par 119**
epilog
	app.printer.close();
	delete pd;
	delete gtpTable;
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="doThumbnailClick" id="1631c60e-7480-46fb-b95d-af825afcb52f">
        <updating/>
        <source>doThumbnailClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2019	jlger1	Initial creation 43546

*/

vars
	doExpand : Boolean;
	int, currentRow  : Integer;
begin
	
	currentRow:=self.tblThumb.row;
	if  self.tblThumb.hasPicture and currentRow &lt;&gt; self.tblThumb.rows then
		doExpand 	:= self.tblThumb.accessCell(currentRow, 1).picture = app.myRoot.getConfig(PicYAMExpand).Binary;
		foreach int in currentRow + 1 to  self.tblThumb.rows do
			if self.tblThumb.accessCell(int,1).text = null then
				// reached next group with same or higher level
				break;
			endif;
			// this is a sub-ordinate entry
			if doExpand then
				// we are expanding
				self.tblThumb.accessRow (int).visible := true;
			else
				// we are collapsing
				self.tblThumb.accessRow (int).visible := false;
			endif;
		endforeach;
		if doExpand then
			self.tblThumb.accessCell(currentRow, 1).picture := app.myRoot.getConfig(PicYAMCollapse).Binary;
		else
			self.tblThumb.accessCell(currentRow, 1).picture := app.myRoot.getConfig(PicYAMExpand).Binary;
		endif;
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditChildSubjStr" id="26d3db44-e20a-4dfa-9467-12feca391ebb">
        <source>getAuditChildSubjStr(_aud : CM_AuditObject; _strArr : StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2023 navhl20 Defect 59936: MTN - Displaying only the first tracked item on the Audit Enquiry for the Vehicle Booking Time Slot
30 Jan 2023 navhl20 Bug 57592: MTN - WO - Audits for Work Order Delete is not registered correctly
*/

vars
	strArr,
	strArr1		: HugeStringArray;
 	audStr,
	audStr1,
	cmpStr,
	str,
	str1		: String;
	type		: CM_WorkOrderDetailType;
	typeArr		: HugeStringArray;
begin
	create strArr transient;
	create strArr1 transient;
	create typeArr transient;													//19.02.2024 navhl20 #57592
	_aud.auditText.asStringHugeArrayByDelimiter(strArr1,"^^");
	foreach audStr1 in strArr1 do
		audStr1.asStringHugeArrayByDelimiter(strArr,"^");
	endforeach;
	
	foreach type in app.myRoot.allWorkOrderTaskTypes do							//19.02.2024 navhl20 #57592
		typeArr.add(type.description);
	endforeach;
	
	if _aud.myAuditConfig.className = CM_VehicleBookingTimeSlot.name then		//30.01.2023 navhl20 #57592
		cmpStr := CM_VehicleBookingTimeSlotItem.getNiceName();
	else
		foreach str in typeArr do
			foreach str1 in strArr do
				if str1.cnContains(str) then
					cmpStr := str;
					break;
				endif;
			endforeach;
			if cmpStr &lt;&gt; null then
				break;
			endif;
		endforeach;
	endif;
	
	foreach audStr in strArr do
		if audStr.cnContains(cmpStr) and not _strArr.includes(audStr) then
			_strArr.add(audStr);
		endif;
	endforeach;
epilog
	delete strArr;
	delete strArr1;
	delete typeArr;
end;</source>
        <Parameter name="_aud" type="CM_AuditObject"/>
        <Parameter name="_strArr" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="7b18720c-a36d-43b4-bbb2-61cba008dd2f">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Date		Who		Reason
22 July 2016	cnwer1	Initial creation TFS
28 May 2024	navnk30	ChangeRequest 63897: Jade - Invoice Cargo Allocation Audits

*/

constants
	One_Minute				: Integer = 1;
vars
	aud	: CM_AuditObject;
	auditDateTime,
	filterFromDateTime,
	filterToDateTime		: TimeStamp;
	inclusiveEndTime		: Time;
begin
	aud := _obj.CM_AuditObject;

	//User filter is done in copyCollectionToDynaDict

	if self.filterType &lt;&gt; AuditAny then		
		if aud.type &lt;&gt; self.filterType then
			return false;
		endif;
	endif;
	
	/*
		Date		  Who		Reason
	  1 July 2008	 cnwdz2	    Par17349 - Search results should also be based on the selected user code.
	*/
	if self.filterUserCode &lt;&gt; null and aud.userCode &lt;&gt; self.filterUserCode then
		return false;
	endif;
		
	if self.myCurrentAuditConfig &lt;&gt; null and
	   self.myCurrentAuditConfig.className &lt;&gt; aud.myAuditConfig.className then
		return false;
	endif;
	
	//28.05.2024 navnk30 #63897 START
	/*auditDate := aud.timestamp.date;
	if self.filterFromDate &lt;&gt; null then
		if auditDate &lt; self.filterFromDate then	//Includes the actual date
			return false;
		endif;
	endif;
	
	if self.filterToDate &lt;&gt; null then
		if auditDate &gt; self.filterToDate then	//Includes the actual date
			return false;
		endif;
	endif;
	
	return true;*/
	
	auditDateTime := aud.timestamp;
	filterFromDateTime.setDate(self.filterFromDate);
	filterFromDateTime.setTime(self.filterFromTime);
	
	if self.filterToDate &lt;&gt; null then
		filterToDateTime.setDate(self.filterToDate);
	endif;
	
	if self.filterToTime &lt;&gt; null then
		inclusiveEndTime.setTime(self.filterToTime.hour,
				self.filterToTime.minute() + One_Minute,
				self.filterToTime.second,
				self.filterToTime.milliSecond);
		filterToDateTime.setTime(inclusiveEndTime);
	endif;
	
	return auditDateTime &gt;= filterFromDateTime and auditDateTime &lt;= filterToDateTime;
	//28.05.2024 navnk30 #63897 END
	

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initComboObjectType" id="2abf049a-7835-4325-9f51-390326c8088c">
        <updating/>
        <source>initComboObjectType() updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 September 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpAC	: CM_AuditConfig;
begin

	// CNWRS2 16 Nov 2010 - changed to sort items in combo
	cmbObjectType.sorted := true;

//	cmbObjectType.addItem(app.getErrorString(AddAnyToSortedComboBox));
	cmbObjectType.addItemObject(Any_String, null);
		
	foreach tmpAC in app.myRoot.allAuditConfigs discreteLock do
		if tmpAC.className = CM_DocketError.name
		or tmpAC.className = CM_EventRequest.name
		or tmpAC.className = CM_FileFormatEDI.name
		or tmpAC.className = "CM_TIMasterGroup"
		then	//29 Jan 2021	TFS 50152
			//These were never set up correctly so look to be able to be deleted
			if tmpAC.allAuditObjects.isEmpty then
				continue;
			endif;
		endif;
		cmbObjectType.addItemObject(tmpAC.getDescription(), tmpAC);
	endforeach;
	
	cmbObjectType.listObject := self.myCurrentAuditConfig;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="350ffb89-86c0-43f5-a418-6fddd7b60d27">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 Aug 2015	cnwrs1	Par 38117 TFS 2491 - If an Audit Object is passed in as auditted Object then display it
// ---------------------------------------------------------------------------
vars

begin
	self.setTblDataEntRows(ETDef_AuditTblData);
	if self.myAudittedObject &lt;&gt; null then		
		self.addObjectsToTable(numItemsSearched);	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initFilterTable" id="a936e5e8-6046-4a05-ab97-332bd7a5dca6">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
/// 09 Aug 2015	cnwrs1	Par 38117 TFS 2491 - If an Audit Object is passed in as auditted Object then display it
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	controller		: CMUI_Controller;
	combo : ComboBox;
begin
	theTable := tblSearch;

	controller := app.myController;
	entTableDef := controller.getEntTableDef(ETDef_DefaultAuditView);
	
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef ReportParams not found');
		return;
	endif;
	
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	theTable.adjustHeight(200);
	
	combo := self.cmbUserCode;
	self.myAssistant.comboBoxUser(combo, null);

	//self.myCurrentAuditConfig := app.myRoot.allAuditConfigs.first;
	self.initComboObjectType();
	//cmbObjectType.listCollection(app.myRoot.allAuditConfigs, false, 0);
	//cmbObjectType.displayCollection(app.myRoot.allAuditConfigs, false, 0, null, app.getErrorString(AddAnyToSortedComboBox));
	//cmbObjectType.listObject := self.myCurrentAuditConfig;

	theRow := theTable.getRowByControlName(self.cmbObjectType.name);
	if self.isUsingDefinedObject then
		// Still populate combo above as some code assumes that this
		// combo has been preset.  Safer in long term to populate
		// and then hide (RJS 17/12/01)
		theTable.hideRow(theRow);
	elseif self.myCurrentAuditConfig &lt;&gt; null then
		theTable.setValue(theRow, self.myCurrentAuditConfig.getDescription);
	endif;

	combo := cmbAuditType;
	combo.clear;
	combo.addItem(ALL);
	combo.addItem(CREATED);
	combo.addItem(UPDATED);
	combo.addItem(DELETED);
	combo.addItem(INFO);
	if self.myAudittedObject &lt;&gt; null and
	   self.myAudittedObject.isKindOf(CM_AuditObject) then
		combo.listIndex := self.myAudittedObject.CM_AuditObject.type + 1;
	else
		combo.listIndex := 1;
	endif;
	combo.lostFocus(combo);

	self.setFilterDefaults();
	
	theTable.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="dde4e615-0c90-4b26-b82c-433c9f57768e">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// 09 Aug 2015	cnwrs1	Par 38117 TFS 2491 - If an Audit Object is passed in as auditted Object then display it
// 09/06/2017 cnwrh7   TFS4537       # (String too Long) when entering Audits from Storage Configuration
// 22/08/2024 navrv30	Bug 65592: NSW - Audits - Rows count incorrect
// ---------------------------------------------------------------------------
vars
	lastAudit,
	firstAudit : CM_AuditObject;
	allAudits : CM_AuditObjectDictByTimestamp;
begin
	self.allowAdd	 := false;
	self.allowDelete := false;
	self.allowUpdate := false;
	self.showFilterOnStartup := true; 	// Show the filter frame
	self.showDataOnStartup 	:= false; 	// Do not populate the data table with data
	self.allowPrint 		:= true;
	self.allowExportCSV		:= true;
	

	//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.filterFromDate := app.actualTimeServer.date - 31;
	self.filterToDate	:= app.actualTimeServer.date;
	self.allowHideThumbnailEmpty:=false;
	
	//epr TFS 43546 27//2/19
	if self.myAudittedObject &lt;&gt; null then
		if self.myAudittedObject.isKindOf(CM_AuditObject) then
			self.myCurrentAuditConfig := self.myAudittedObject.CM_AuditObject.myAuditConfig;
		else
			self.myCurrentAuditConfig := app.myRoot.allAuditConfigs[self.myAudittedObject.class.name];
		endif;
		self.caption := ("Audit Details for " &amp; self.myAudittedObject.auditIdDisplay())[1:255];				//+TFS4537
		
		allAudits:=self.myAudittedObject.getAllAuditObjects();
		if allAudits &lt;&gt; null then
			lastAudit:=allAudits.last;
			firstAudit:=allAudits.first;
			self.numItemsShown := allAudits.size();   //22/08/2024 navrv30	Bug 65592
		endif;
		
		if firstAudit &lt;&gt; null then
			self.filterFromDate := firstAudit.timestamp.date;
		endif;
	else
		self.caption := "Audit Details";
	endif;
	self.useNumRowsShown	:= true;					//22/08/2024 navrv30	Bug 65592
	self.setNavigatorHeading( self.caption );			// cnwrl1 06/11/2009 PAR 19617
	self.sptDataFilter.setLeftToRightRatioAndResize(40);
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="isUsingDefinedObject" id="23e00804-34d8-48ee-8b29-aa9c894fed00">
        <methodInvocation>mapping</methodInvocation>
        <source>isUsingDefinedObject(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     25 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := (self.myAudittedObject &lt;&gt; null);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="c46c07c4-a44d-4ba5-bf04-6ce58d824bd0">
        <updating/>
        <source>setFilterDefaults() updating;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 12 Sep 2023 	navhl20 ChangeRequest 60432: MTN - Add time filter to Audit Enquiry screen.
vars

begin

	self.filterType := AuditAny;
	self.filterUser := null;
	self.filterUserCode := null;
	
	tblSearch.setValueByName(ETRow_AfterDate, self.filterFromDate);
	tblSearch.setValueByName(ETRow_BeforeDate, self.filterToDate);
	self.tblSearch.setValueByName(ETRow_FromTime, self.filterFromTime);		//12.9.2023 navhl20 #60432
	self.tblSearch.setValueByName(ETRow_ToTime, "23:59:00".Time);			//15.9.2023 navhl20 #60432
	
	if (not self.isUsingDefinedObject) then
		self.cmbObjectType.listIndex := 1;
		self.cmbObjectType.lostFocus(self.cmbObjectType);	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="6fa12c68-dc72-405a-b945-ca6d4f445045">
        <updating/>
        <source>setFilterValues() updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12 Sep 2023 navhl20 ChangeRequest 60432: MTN - Add time filter to Audit Enquiry screen.
// ---------------------------------------------------------------------------
vars
	dateStr : String;
	valid : Boolean;

begin
	//dateStr := tblSearch.getValueByName(ETRow_BeforeDate).String;
	
	//16/09/2009 cnwdz2	par20038
	self.filterToDate := tblSearch.getValueByName(ETRow_BeforeDate).asStringJMT().asDateJMT();
	self.filterToTime := tblSearch.getValueByName(ETRow_ToTime).asStringJMT().asTimeJMT();		//12.9.2023 navhl20 #60432
	//valid := filterToDate.parseForCurrentLocale(dateStr);
	//if (not valid) then
	//	self.filterToDate := null;
	//endif;
	
	//16/09/2009 cnwdz2	par20038
	self.filterFromDate := tblSearch.getValueByName(ETRow_AfterDate).asStringJMT().asDateJMT();
	self.filterFromTime := tblSearch.getValueByName(ETRow_FromTime).asStringJMT().asTimeJMT();	//12.9.2023 navhl20 #60432
	//valid := filterFromDate.parseForCurrentLocale(dateStr);
	//if (not valid) then
	//	self.filterFromDate := null;
	//endif;	
	
end;</source>
    </JadeMethod>
