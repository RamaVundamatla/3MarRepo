    <JadeMethod name="loadDataForFirstTime" id="01eb1de9-6aa0-440c-9b2c-313922a86c0c">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.lstOperators.width := self.shtOperators.clientWidth;
	self.lstOperators.height := self.shtOperators.clientHeight;	

	self.lstCargoTypes.width := self.shtCargoTypes.clientWidth;
	self.lstCargoTypes.height := self.shtCargoTypes.clientHeight;	

	self.lstPorts.width := self.shtPorts.clientWidth;
	self.lstPorts.height := self.shtPorts.clientHeight;	
	
	self.cmbVoyage.centreHorizontallyInParent();
	self.grpDisplaySheets.centreHorizontallyInParent();

	self.resetTblData(self.tblNNCargo);		
	self.resetCargoTypeLst();	
	self.cmbVoyage.initialise(false);
	if self.myCurrentGCVoyage &lt;&gt; null then
		self.cmbVoyage.setObject(self.myCurrentGCVoyage.myVoyage);
	else
		//self.cmbVoyage.setObject(app.myCurrentVoyage);
		//cnwjo3 par 23105
		self.cmbVoyage.setObject(app.getMyCurrentVoyage());
	endif;

	self.resetPortLst(self.cmbVoyage.myObject.CM_Voyage);		
	// set operator list after voyage as it uses voyage to filter operators is needed
	self.resetOperatorLst();	

	if self.cmbVoyage.myObject &lt;&gt; null then
		// set the voyage, table columns, filters and displays data
		self.doSearch();
	else
		self.resetTblData(self.tblOnShip);		
		self.resetTblData(self.tblOnSite);		
		self.resetTblData(self.tblPlanned);		
		self.resetTblData(self.tblNonPlanned);
		self.btnDelete.enabled := false;		
		self.btnPrint.enabled := false;
		self.btnReportOptions.enabled := false;
		self.btnShowSearch.enabled := false;
		self.btnVoyageDefin.enabled := false;
		self.btnSelectAll.enabled := false;
		self.btnMoveIt.enabled := false;
		self.btnImportTasks.enabled := false;
		self.btnCreateCargo.enabled := false;								
		self.frmSearch.centreWindow();
	endif;

	self.btnDelete.enabled := self.optBOL.value and (self.fldMain.topSheet = self.shtOnShip or self.fldMain.topSheet = self.shtNonplanned);
		
	self.doResize();		
end;</source>
        <access>protected</access>
    </JadeMethod>
