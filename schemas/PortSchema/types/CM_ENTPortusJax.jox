    <JadeMethod name="getSiteId" id="8a813480-fb0f-444c-862f-6ae112eb8011">
        <source>getSiteId(_bank: CM_Bank): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 24 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _bank.code = "DFBU" then  
		return "JAX";
	else		
		return "025"; 
	endif;
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <ReturnType type="String"/>
