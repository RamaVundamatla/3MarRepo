    <JadeMethod name="setForUpdate" id="24f8f9fc-ca73-43f5-8cc3-1e0073d6da98">
        <updating/>
        <source>setForUpdate(_pxyDamageParty : CM_DamageParty) updating;
/*

Purpose:			

