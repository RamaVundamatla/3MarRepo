    <JadeMethod name="resortTblWorkEntries" id="a75107c2-3ffb-4334-826d-a9bd79b59168">
        <source>resortTblWorkEntries(_wleTable : CM_DataTable input)protected;
//--------------------------------------------------------------
//Created: 01 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
