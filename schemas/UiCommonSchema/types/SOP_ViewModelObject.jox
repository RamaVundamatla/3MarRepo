    <JadeMethod name="setControlsForAddEdit" id="339d6a50-6b34-47ad-a139-c67ef13ac11b">
        <updating/>
        <source>setControlsForAddEdit() updating;
// -----------------------------------------------------------------------------
// Created:		19 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	maxCodeLength			: Integer;
	entRowTrans				: EntTableRowTransient;
	row, column: Integer;
	
begin

	if self.myForm.mode = self.myForm.Mode_Update then 
		self.myForm.tblInput1.disableRowByName(ETRow_Code);
	else
		self.myForm.tblInput1.enableRowByName(ETRow_Code);
	endif;
	
	self.myForm.tblInput1.userInputEnabled := true;
	self.myForm.tblInput1.setFocus;
	self.myForm.tblInput1.moveFirst();
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="5270e6c3-9705-4df4-8192-789bfa28d24d">
        <source>setControlsForView();
// -----------------------------------------------------------------------------
// Created:		19 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.myForm.tblInput1.userInputEnabled := false;
	//epr par 16850 17/7/08 if these buttons are enabled when they shouldn't be would cause 1090 UE
	self.myForm.btnNewChildTV.enabled:=self.canAddChild;
	self.myForm.btnNewTV.enabled:=self.canAddPeer;
end;</source>
    </JadeMethod>
    <JadeMethod name="setExpanded" id="284bfde0-d232-47d7-b352-36d9960910c3">
        <updating/>
        <source>setExpanded(_value : Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		18 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars 
	child : CMUI_ViewModelObject;
begin
	self.expanded := _value;

	
	foreach child in self.allChildren do
		child.setExpanded(_value);
	endforeach;
	
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
