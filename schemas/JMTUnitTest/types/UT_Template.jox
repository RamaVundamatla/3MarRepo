<Class name="UT_Template" id="f1b829cb-a50d-4824-9b69-db78a62fe02f">
    <superclass name="UT_DSL"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="createGCOnVoyage" id="62a16282-f5e4-4cdd-b22f-43b3a6cd3ca6">
        <source>createGCOnVoyage(_delete : Boolean; _contractId,_id : String; _cargoType : CM_CargoType; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port; _weight : Integer; _volume : Decimal; _quantity : Integer) : CM_TrackedItem;
/*
Purpose:			

Date		Who		Reason

*/

vars
	cargo : CM_TrackedItem;
	lc : CM_LocationsController;
	product : CM_Product;
begin
	if _delete then
		self.deleteCargo(_id, _cargoType);
	endif;
	
	lc := _voyage.myShipBlockStack;
	
	
	product := _cargoType.getProductFromCode("SUBTYPE");
	//create cargo on ship
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("TotalQuantity",_quantity); 
	cargo := lc.createNewCargoForLCDetailed(_cargoType,product, _id, _port.code, TI_IMEX_STATUS_IMPORT, _voyage, _voyage.myOperator, _quantity, null).CM_Cargo;
	self.assertNotNull(cargo);
	self.opts.addAssoc("Commodity", "COM1");
	self.opts.addAssoc("TotalVolume", _volume);
	self.opts.addAssoc("CargoLength", 111.0);
	self.opts.addAssoc("CargoWidth", 222.0);
	self.opts.addAssoc("CargoHeight", 333.0);
	self.opts.addAssoc("Description", "CargoDesc2");
	self.opts.addAssoc("ClientRef", "ClientRef2");
	self.opts.addAssoc("Consignee", "UTDDC");
	self.opts.addAssoc("Consignor", "UTMO1");
	self.opts.addAssoc("ContractId",_contractId);
	self.opts.addAssoc("TotalWeight", _weight);
	self.opts.addAssoc(UTTI_CustomsAgent, "UTCA1"); 
	
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, _quantity);
	assertEqual(cargo.totalWeight, _weight.Decimal);

	self.assertTrueMsg(cargo.contractId = _contractId, "Cargo Contract Id is wrong");
	
	return cargo;
epilog

end;</source>
        <Parameter name="_delete" type="Boolean"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_weight" type="Integer"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_quantity" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="loadTransMap" id="b18ab914-587c-4e87-b119-6c01881c864b">
        <source>loadTransMap(_mapName : String; 
						_transactionName : String;
						_invLineDesc : String);
/*
Purpose - 	
Who - NAVAB1

*/

vars
	fileContent : String;
	fileName : String;
	bank : CM_Bank;
	tranMap : CM_TranMap;

begin
	fileName := "CargoReceive";
	
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?' &amp; CrLf &amp;
					'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All,VOID'&amp; CrLf &amp;
					'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),' &amp;_transactionName &amp; ',,(Default),(Default) ›,(Default),,,**Any**,All,' &amp; _invLineDesc  &amp; CrLf;
					
	// DELETE TRAN MAP
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	tranMap := bank.myCurrentTranMapCargo[_mapName];
 	if tranMap &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(tranMap, app.myPassport);
	endif;
	
	// CREATE TRAN MAP
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	tranMap := bank.myCurrentTranMapCargo[_mapName];
	self.assertNotNullMsg(tranMap, "Transaction map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(tranMap, app.myPassport);
end;
</source>
        <Parameter name="_mapName" type="String"/>
        <Parameter name="_transactionName" type="String"/>
        <Parameter name="_invLineDesc" type="String"/>
    </JadeMethod>
    <JadeMethod name="uTemplate_Cargo" id="370cc22b-e0ec-4512-a10b-4d47f741f9eb">
        <source>uTemplate_Cargo();
/*

Purpose:	EXAMPLES FOR TRAINING 'how to write UTs'

Parameters:			

Return Value:		

Date		Who		Reason

*/

constants
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	TERMINALAREA = "UT58254TA";
vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	cooTS, moveTS				: TimeStamp;	
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
begin
	

	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack(TERMINALAREA,9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// ###### CREATE CARGO ON VOYAGE
	// #########################################
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Incase some have been applied
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	
	// #########################################
	// ##### EDIT TI's IMEX
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in tiSet do
		self.updateTI(ti);
	endforeach;

	foreach ti in tiSet do
		self.assertTrueMsg(ti.isExport, ti.id &amp; " should be an EXPORT");
		trans := ti.getTransOfType(TRANS_TYPE_STORAGE);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Storage transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "Before No Storage charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "Storage charge before COO should be for " &amp; debtorOld.name);
		
		
	endforeach;
	
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	
	self.deleteOperator(OperatorNew);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteTerminalArea(TERMINALAREA);

		
epilog
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="uTemplate_Invoicing" id="a600e9a5-020c-4f88-9b3e-a188b163caf4">
        <source>uTemplate_Invoicing();
/*

Purpose:	EXAMPLES FOR TRAINING 'how to write UTs'

Parameters:			

Return Value:		

Date		Who		Reason

*/

constants
	InvType_Receive = "UT_RECEIVAL";
	CalType_Code_Receive = "UT_CALTYPE_REC";
	CalType_Desc_Receive = "UT_CalType_REC_Desc";
	Srvc_Receive = "UT_SRVC_RECEIVAL";
	InvLineType_Code = "UT_LINEREC";
	Debtor_Type = "SDT1";
	TransType_Receive = "Ship Receive";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	TERMINALAREA = "UT58254TA";
vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	now, cooTS, moveTS				: TimeStamp;	
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;

	businessUnit : CM_Bank;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(NoImportStops, false);
	businessUnit := self.getMyTerminal.getDefaultCompanyBank();
	

	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack(TERMINALAREA,9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := businessUnit.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_Receive);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Receive);

	invType := self.createInvoiceType(InvType_Receive, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Receive &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Receive, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Receive,
										   CalType_Desc_Receive, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Receive &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_Receive, Srvc_Receive, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_Receive &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Receive, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE CARGO ON VOYAGE
	// #########################################
	
	tiId := "UTEMP" &amp; now.date.formatAsYYMMDD() ;
	ti := self.getTrackedItem(tiId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(tiId, true);
	endif;
	ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, 100, 10, 1000);
	
	self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly 
	self.deleteStops(ti);
	
	// #########################################
	// ##### EDIT TI's IMEX 
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	self.updateTI(ti);
	self.assertTrueMsg(ti.isExport, ti.id &amp; " should be an EXPORT");

	trans := ti.getTransOfType(TRANS_TYPE_REC_SHIP);
	transaction := trans.first;
	delete trans;
	
	assertTrueMsg(transaction &lt;&gt; null, "No receive transaction for " &amp; ti.id);
	assertTrueMsg(transaction.type =  TRANS_TYPE_REC_SHIP, "No Storage transaction for " &amp; ti.id);
	
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Before No receive charges for " &amp; ti.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Storage charge should be for " &amp; debtorOld.name);
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	self.deleteTrackedItem(ti, true);
	self.deleteOperator(OperatorNew);
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteTerminalArea(TERMINALAREA);
	self.deleteStorageConfig( false );
	self.deleteService(Srvc_Receive);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Receive);
	self.deleteCalculationType(CalType_Code_Receive, FORCED_ERASE);
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);

		
epilog
	self.resetDefaultTranMap();
	delete services;
	delete trans; 

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
</Class>
