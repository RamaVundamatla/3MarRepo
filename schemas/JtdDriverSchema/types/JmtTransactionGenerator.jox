    <JadeMethod name="zAllocateIMV" id="3a45a891-cf23-4c8f-8bbf-0652ce08ac36">
        <updating/>
        <source>zAllocateIMV() updating;

vars
	imvCode:String;
	masterMachine,
	proxyMachine	: CM_Machine;
	cmif_Machine	: CMIF_Machine;
	//mediator	: CM_RTConnectMediator;
begin
	imvCode:='IM'&amp;app.sequenceId.pad(2);
	self.myIMV := app.myPassport.myTerminal.machines[imvCode];
	
	if self.myIMV &lt;&gt; null then
		beginTransaction;
		self.myIMV.erase(NORMAL_ERASE);
		commitTransaction;
	endif;

	// find a machine to clone from
	foreach masterMachine in app.myPassport.myTerminal.machines where masterMachine.machineType = MACHINETYPE_IMV do
		break;
	endforeach;
	create cmif_Machine transient;
	
	cmif_Machine.code 						:= imvCode;
	cmif_Machine.description 				:= 'IMV ' &amp; imvCode &amp; ' (JBL created)';
    cmif_Machine.machineType 				:= app.myRoot.allMachineTypes[MACHINETYPE_IMV];
    
  	cmif_Machine.colour 					:= Purple;
	cmif_Machine.available 					:= true;
    cmif_Machine.canLift40Foot 				:= true;
    cmif_Machine.canTwinLift 				:= false;
    cmif_Machine.maxLiftWeight 				:= null;
    cmif_Machine.maxStackHeightMT 			:= null;
    cmif_Machine.maxStackHeightFull 		:= null;
    cmif_Machine.isNotAvailableForEntry		:= false;
	cmif_Machine.myRFIDTag					:= null;
 
    cmif_Machine.craneTransferArea	 		:= null;
	cmif_Machine.targetRatePH	 			:= null;
	cmif_Machine.craneJobSeed		 		:= null;

	cmif_Machine.hasRadioTelemetry 			:= true;
    cmif_Machine.networkAddress 			:= null;
    cmif_Machine.requiresAvailabilityCode 	:= false;
    cmif_Machine.recordActivityHistory 		:= false;
    cmif_Machine.maxRejectedTasks 			:= null;
    cmif_Machine.useRTForPickup 			:= true;
    cmif_Machine.useRTForPickupSetdown 		:= true;
    cmif_Machine.canWeigh 					:= false;
    
	masterMachine.allowedTAMasters.copy(cmif_Machine.terminalAreas);
	masterMachine.allAllowedCargoTypes.copy(cmif_Machine.cargoTypes);
	masterMachine.allAllowableContentsStatuses.copy(cmif_Machine.allAllowableContentStatuses);
	masterMachine.allQueues.copy(cmif_Machine.allSelectedQueues);
	
    create proxyMachine transient;
	proxyMachine.setProxyFromCMIF_Machine(cmif_Machine, app.myPassport);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.warningsAcknowledged := true;
	app.myTrxCA.trxCreateMachine(proxyMachine, myIMV, app.myPassport);
	assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	
	app.logMessage(method.qualifiedName&amp;" using "&amp;myIMV.description);
epilog
	// log on to the crane
	//create mediator transient;
	beginTransaction;
	//self.myIMV.executeLogon(mediator);  // 7.7.1: uses app.myUser
	commitTransaction;

	delete cmif_Machine;
	delete proxyMachine;
	//delete mediator;
end;
</source>
    </JadeMethod>
    <JadeMethod name="zAllocateRTGCrane" id="df3e3f0b-6073-4417-886d-e6a216367658">
        <updating/>
        <source>zAllocateRTGCrane() updating;

vars
	rtgCode:String;
	masterMachine,
	proxyMachine	: CM_Machine;
	cmif_Machine	: CMIF_Machine;
	//mediator	: CM_RTConnectMediator;
	pxyTagReader	: CM_RFIDTagReader;
begin
	rtgCode:='RT'&amp;app.sequenceId.pad(2);
	self.myRTGCrane := app.myPassport.myTerminal.machines[rtgCode];
	
	if self.myRTGCrane &lt;&gt; null then
		beginTransaction;
		self.myRTGCrane.erase(NORMAL_ERASE);
		commitTransaction;
	endif;

	// find a machine to clone from
	foreach masterMachine in app.myPassport.myTerminal.machines 
	where masterMachine.machineType = MACHINETYPE_RTG and masterMachine.code[1:3] = 'RTG' do
		break;
	endforeach;
	app.logMessage(method.qualifiedName&amp;" cloning RTG crane from "&amp;masterMachine.description);
	create cmif_Machine transient;
	
	cmif_Machine.code 						:= rtgCode;
	cmif_Machine.description 				:= 'RTG crane ' &amp; rtgCode &amp; ' (JBL)';
    cmif_Machine.machineType 				:= app.myRoot.allMachineTypes[MACHINETYPE_RTG];
    
  	cmif_Machine.colour 					:= Blue;
	cmif_Machine.available 					:= true;
    cmif_Machine.canLift40Foot 				:= true;
    cmif_Machine.canTwinLift 				:= true;
    cmif_Machine.maxLiftWeight 				:= null;
    cmif_Machine.maxStackHeightMT 			:= null;
    cmif_Machine.maxStackHeightFull 		:= null;
    cmif_Machine.isNotAvailableForEntry		:= false;
	cmif_Machine.myRFIDTag					:= null;
 
    cmif_Machine.craneTransferArea	 		:= null;
	cmif_Machine.targetRatePH	 			:= null;
	cmif_Machine.craneJobSeed		 		:= null;

	cmif_Machine.hasRadioTelemetry 			:= true;
    cmif_Machine.networkAddress 			:= null;
    cmif_Machine.requiresAvailabilityCode 	:= false;
    cmif_Machine.recordActivityHistory 		:= false;
    cmif_Machine.maxRejectedTasks 			:= null;
    cmif_Machine.useRTForPickup 			:= true;
    cmif_Machine.useRTForPickupSetdown 		:= true;
    cmif_Machine.canWeigh 					:= false;
    
	masterMachine.allowedTAMasters.copy(cmif_Machine.terminalAreas);
	masterMachine.allAllowedCargoTypes.copy(cmif_Machine.cargoTypes);
	masterMachine.allAllowableContentsStatuses.copy(cmif_Machine.allAllowableContentStatuses);
	masterMachine.allQueues.copy(cmif_Machine.allSelectedQueues);
	
    create proxyMachine transient;
	proxyMachine.setProxyFromCMIF_Machine(cmif_Machine, app.myPassport);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.warningsAcknowledged := true;
	app.myTrxCA.trxCreateMachine(proxyMachine, myRTGCrane, app.myPassport);
	assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	
	//allocate RFID Tag reader to the crane
	self.myRFIDTagReaderRTG := app.getMyTerminal.allRFIDTagReadersByCode[rtgCode];
	if self.myRFIDTagReaderRTG &lt;&gt; null then
		beginLoad;
		pxyTagReader := self.myRFIDTagReaderRTG.pxyCreateUpdateProxy();
		endLoad;
	else
		create pxyTagReader transient;
	endif;
	
	/*pxyTagReader.setProxy(rtgCode,
						'Reader for RTG ' &amp; rtgCode.String,
						'ACS7CE',
						null, 
						null,
						50905,
						TagReaderContext_Machine,
						null,
						myRTGCrane,
						null);/**/
	if self.myRFIDTagReaderRTG &lt;&gt; null then
		app.myTrxUA.trxUpdateRFIDTagReader(pxyTagReader, app.getMyTerminal, app.myPassport);
	else
		app.myTrxCA.trxCreateRFIDTagReader(pxyTagReader, self.myRFIDTagReaderRTG, app.getMyTerminal, app.myPassport);
	endif;
	assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);

	app.logMessage(method.qualifiedName&amp;" using "&amp;myRTGCrane.description);

	// log on to the crane
	//create mediator transient;
	beginTransaction;
	//self.myRTGCrane.executeLogon(mediator);  // 7.7.1: uses app.myUser
	commitTransaction;
epilog
	delete cmif_Machine;
	delete proxyMachine;
	//delete mediator;
end;
</source>
    </JadeMethod>
</Class>
