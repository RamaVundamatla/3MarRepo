    <JadeMethod name="addObjectToTable" id="cf5b17a8-8856-4304-9eb8-8187aac67d7b">
        <updating/>
        <source>addObjectToTable(_obj : Object; _numItems : Integer io; _breakOut : Boolean io) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwrs2
//
// Purpose:     Adds the object to the table and sets a notifiction for
//				updates to the object
// ---------------------------------------------------------------------------
vars
	tmpObj	: Object;

begin

	tmpObj := _obj; 

	if (not self.zTblDataShowDataForObject(tmpObj, _numItems, _breakOut)) then
		// the object was not added to the table
		return;
	endif;

	if tmpObj &lt;&gt; null and (not _obj.isTransient) then
		self.armNotesForObject(_obj);
	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="io"/>
    </JadeMethod>
