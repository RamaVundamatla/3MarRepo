    <JadeMethod name="deleteInvoiceService" id="55d1574a-e785-4fa1-9648-2d1df37e93bc">
        <source>deleteInvoiceService(_serviceName : String; _eraseLevel : Integer);
// --------------------------------------------------------------------------------
// Created:		23 November 2009 by cnwjo3
//
// Purpose:		Delete a Service
vars
	aService : CM_ServiceObject;
	charge	 : CM_Charge;
begin
	foreach aService in CM_Service.instances do
		if aService.name = _serviceName then
		
			// 13/09/2017 jlgmh5 - delete charges
			beginTransaction;
			foreach charge in aService.CM_Service.charges do
				delete charge;			
			endforeach;
			commitTransaction;
			
			if _eraseLevel = FORCED_ERASE then
				app.myTrxDA.trxDeleteServiceObjectForced(aService, app.myPassport);
				//self.assertNoTrxErrorsOrWarnings();
			else
				app.myTrxDA.trxDeleteServiceObject(aService, app.myPassport);
			endif;
			self.assertNoTrxErrorsOrWarnings();					// 13/09/2017 jlgmh5 - check for errors and warnings
		endif;
	endforeach;
end;</source>
        <Parameter name="_serviceName" type="String"/>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="deleteInvoiceTransactionMap" id="239eab38-4a7f-463b-b88f-67b22b8df35d">
        <source>deleteInvoiceTransactionMap(_type : Integer; _name: String);
// May 2010		cnwjre1
//	_type = 1		cargo map
//			2		event map
//			3		voyage map
//
vars
	bank : CM_Bank;
	cargoMap	: CM_TranMap;
	eventMap	: CM_TranMapEvent;
	voyageMap	: CM_TranMapVoyage;
	workOrderMap	: CM_TranMapWorkOrder;
	bolMap : CM_TranMapBOL;	
begin
	//bank := app.myPassport.myTerminal.getConfig(DefCompany).CM_Bank;
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393

	if _type = 1 then
		cargoMap := bank.myCurrentTranMapCargo[_name];
		if cargoMap &lt;&gt; null then
			app.myTrxDA.trxDeleteInvoiceTranMap(cargoMap, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endif;
	elseif _type = 2 then
		eventMap := bank.allEventTranMaps[_name];
		if eventMap &lt;&gt; null then
			app.myTrxDA.trxDeleteInvoiceTranMapEvent(eventMap, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endif;
	elseif _type = 3 then
		voyageMap := bank.allJMHTMs[_name];
		if voyageMap &lt;&gt; null then
			beginTransaction;
			bank.myCurrentTranMapVoyage := null;
			commitTransaction;
			app.myTrxDA.trxDeleteInvoiceTranMapVoyage(voyageMap, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endif;
	
	//04 Jun 2019	NDL	TFS 44773
	elseif _type = 4 then
		workOrderMap := bank.allWorkOrderTranMaps[_name];
		if workOrderMap &lt;&gt; null then
			if bank.myCurrentTranMapWorkOrder = workOrderMap then
				beginTransaction;
				bank.setPropertyValue( CM_Bank::myCurrentTranMapWorkOrder.name, null);
				commitTransaction;
			endif;
			app.myTrxDA.trxDeleteInvoiceTranMapWO(workOrderMap,app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endif;
		
	elseif _type = 5 then	//07 Nov 2019	NDL	TFS 47100
		bolMap := bank.allBOLTranMaps[_name];
		if bolMap &lt;&gt; null then
			if bank.myCurrentTranMapBOL = bolMap then
				beginTransaction;
				bank.setPropertyValue( CM_Bank::myCurrentTranMapBOL.name, null);
				commitTransaction;
			endif;
			app.myTrxDA.trxDeleteInvoiceTranMapBOL(bolMap,app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endif;	
	endif;
	
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteInvoiceType" id="fd647995-97b5-4e44-a075-7f9c4367d10d">
        <source>deleteInvoiceType(_invoiceDesc : String);
//23 November 2009	cnwjo3
vars
	it : CM_InvoiceDesc;
	invType : CM_InvoiceDesc;
	bank : CM_Bank;
begin
	// ### TFS CR 58085 TASK 61344 08JAN2024 NAVAB1
	bank := self.getTerminal().getDefaultCompanyBank();

//	foreach it in CM_InvoiceDesc.instances discreteLock do 
	foreach it in bank.invoiceTypes discreteLock do 
		if it.description = _invoiceDesc then
			invType := self.getTerminal.getCashInvoiceType(null);					// 16/05/2014 cnwmh5
			if invType &lt;&gt; null then
				if not global.isValidObject(invType) then
					self.setDefaultBankCashInvoiceType(null);
				elseif invType.description = _invoiceDesc then
					self.setDefaultBankCashInvoiceType(null);
				endif;
			endif;
			self.deleteInvoicesUsingInvDesc(it);
			app.myTrxDA.trxDeleteInvoiceDesc(it, app.myPassport);	
			self.assertNoTrxErrorsOrWarnings(); // ### TFS CR 55624 TASK 55698 23JAN2023 NAVAB1
			break;
		endif;
	endforeach;
end;</source>
        <Parameter name="_invoiceDesc" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteInvoiceTypeOnly" id="69986e33-c12a-4e9c-96fb-f2a9603881b0">
        <source>deleteInvoiceTypeOnly(_invoiceDesc : String);
/*
Purpose:		TFS 41427
Date			Who			Reason
OCT 2018		NAVAB1		Initial creation
28 Oct 2021 	navma1		 ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
*/

vars
	it		 : CM_InvoiceDesc;
	bank	 : CM_Bank;
begin
	
	bank := self.getTerminal().getDefaultCompanyBank();
	
	self.assertNotNull(bank);
	
	foreach it in bank.invoiceTypes discreteLock do 
		if it.description = _invoiceDesc then
			beginTransaction;
			it.erase(FORCED_ERASE);
			commitTransaction;
		endif;
	endforeach;
	
	/* 
	28.10.2021 navma1 #52163
	foreach it in CM_InvoiceDesc.instances discreteLock do 
		if it.description = _invoiceDesc then
			beginTransaction;
			it.erase(FORCED_ERASE);
			commitTransaction;
		endif;
	endforeach;
	*/
end;</source>
        <Parameter name="_invoiceDesc" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteInvoicesUsingInvDesc" id="17649716-712a-409c-af89-5c4603edcbae">
        <source>deleteInvoicesUsingInvDesc(_invLineDesc : CM_InvoiceDesc);
// delete all invoices using the invoice desc so that it can be deleted
vars
	invLine	: CM_InvoiceLine;
	inv : CM_Invoice;
	invalidInv : Boolean;
	invalidInvLine : Boolean;
	edition : Integer;
begin

	on Exception do app.handleDeletedObject(exception,inv,invalidInv);
	on Exception do app.handleDeletedObject(exception,invLine,invalidInvLine);
	on Exception do app.handleDeletedObject(exception,_invLineDesc,invalidInvLine);
	
	foreach inv in _invLineDesc.getAllInvoices discreteLock do
		
		invalidInvLine := false;
		edition := inv.edition;
		if invalidInv then
			continue;
		endif;
		
		foreach invLine in inv.invoiceLines do
		
			invalidInvLine := false;
			edition := invLine.edition;
			if invalidInvLine then
				continue;
			endif;
			
			self.deleteInvoiceLine(invLine);
		endforeach;
		self.deleteInvoice(inv);
	endforeach;

end;

	</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="deleteInvoicesUsingService" id="fec135bf-ceec-4259-9b49-1dcf0fbdf847">
        <source>deleteInvoicesUsingService(_service : CM_Service);
// delete all invoices using the service so that it can be deleted
vars
	charge	: CM_Charge;
	invLine	: CM_InvoiceLine;
	inv : CM_Invoice;
	oa	: ObjectArray;
	obj	: Object;
begin
	create oa transient;
	foreach charge in _service.charges discreteLock do
		// can be multiple charges per invoice line
		inv := charge.invoiceLine.invoice;
		if not oa.includes(inv) then
			oa.add(inv);
		endif;
	endforeach;
	foreach obj in oa do
		inv := obj.CM_Invoice;
		self.deleteInvoice(inv);
	endforeach;
epilog
	delete oa;
end;

	</source>
        <Parameter name="_service" type="CM_Service"/>
    </JadeMethod>
    <JadeMethod name="deleteJob" id="8476d404-2383-4fb8-addd-0b68ec9a32a3">
        <source>deleteJob(_job: CM_Job input);
//29 August 2008	cnwdw1	
//
vars
	ti: CM_TrackedItem;
	job : CM_Job;
	invalid : Boolean;
	edition : Integer;
begin
	if _job = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _job, invalid );
	edition := _job.edition;
	
	if invalid then
		return;
	endif;
	
	if _job.isKindOf(CM_RoadJob) then
		foreach ti in _job.CM_RoadJob.allReceiveTrackedItems do
			self.deleteTrackedItem(ti, false); // AKB added false
		endforeach;
		foreach ti in _job.CM_RoadJob.allReleaseTrackedItems do
			self.deleteTrackedItem(ti, true); // AKB added false
		endforeach;
	endif;
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	job := _job;
	app.myTrxDA.trxDeleteJob( job, app.myPassport); 
	assertNoTrxErrorsOrWarnings();
end;
</source>
        <Parameter name="_job" type="CM_Job" usage="input"/>
    </JadeMethod>
