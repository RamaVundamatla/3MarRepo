    <JadeMethod name="doMnuFormContextMenu" id="c4b182d4-8966-4b41-9d84-6b46ba13898b">
        <updating/>
        <source>doMnuFormContextMenu(table : CM_DataTable input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//+cnwml2 MSL CCMS 1012
vars
	isShowDataMenus		: Boolean;
	isDataValidRow		: Boolean;
	x1, y1				: Real;
begin
	isShowDataMenus	:=	(table = self.tblLeft);

	
	self.setupContextMenuItems(table);

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(self.mnuMain, x1.Integer, y1.Integer);

	return false;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMoveLeft" id="895b171a-2289-4799-9051-58d94927e391">
        <source>doMoveLeft();
//10 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

// 09/03/2010	cnwcs5	par 22687
vars

	obj : Object;
	oa : ObjectArray;
	row : Integer;
begin
	self.tblLeft.clearAllSelected();
	if self.tblRight.allSelectedObjects.size &gt; 0 then
		//move from right table to left table
		create oa transient;
		foreach obj in self.tblRight.allSelectedObjects do
		//	self.tblRight.removeItemObject(obj);
			if oa.isEmpty then								// 09/03/2010 cnwcs5 par 22687
				self.tblLeft.allSelectedObjects.add (obj);	// 09/03/2010 cnwcs5 par 22687
			endif;											// 09/03/2010 cnwcs5 par 22687
			if self.isStock then
				self.tblLeft.addItemObject(obj, obj.CM_BookingRefItem.myBookingReference.bookingReference &amp; " - " &amp; obj.CM_BookingRefItem.getShortDisplay);
			else
				self.tblLeft.addItemObject(obj, obj.CM_BookingRef.bookingReference);
			endif;
			oa.add(obj);
		endforeach;
		
		foreach obj in oa do
/*			if obj = oa.first then
				self.tblLeft.findObjectInRow(obj, row);
				self.tblLeft.accessRow(row).selected := true;
				self.tblLeft.allSelectedObjects.add(self.tblLeft.accessRow(row).itemObject);
			endif;*/
			row := 1;
			self.tblRight.findObjectInRow(obj, row);
			self.tblRight.removeItemObject(obj);
			if row &gt; self.tblRight.rows then
				row := self.tblRight.rows;
			endif;
			if row &gt; self.tblRight.fixedRows then	// 09/03/2010 cnwcs5 par 22687
				self.tblRight.accessRow(row).selected := true;
				self.tblRight.allSelectedObjects.add(self.tblRight.accessRow(row).itemObject);
			endif;									// 09/03/2010 cnwcs5 par 22687
		endforeach;
	endif;
	
	if self.tblRight.allSelectedObjects.size &gt; 0 and self.tblRight.rows &gt; self.tblRight.fixedRows then
		self.btnShowCargo.enabled := true;
	else
		self.btnShowCargo.enabled := false;
	endif;
epilog
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveRight" id="a6613b49-5828-41f1-bfb1-d57d7c40bfcb">
        <source>doMoveRight();
//10 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

// 09/03/2010	cnwcs5	par 22687
vars
	obj : Object;
	oa : ObjectArray;
	row : Integer;
begin
	self.tblRight.clearAllSelected();
	
	if self.tblLeft.allSelectedObjects.size &gt; 0 then
		//move from left table to right table
		create oa transient;
		foreach obj in self.tblLeft.allSelectedObjects do
			if oa.isEmpty then								// 09/03/2010 cnwcs5 par 22687
				self.tblRight.allSelectedObjects.add (obj);	// 09/03/2010 cnwcs5 par 22687
			endif;											// 09/03/2010 cnwcs5 par 22687
			if self.isStock then
				self.tblRight.addItemObject(obj, obj.CM_BookingRefItem.myBookingReference.bookingReference &amp; " - " &amp; obj.CM_BookingRefItem.getShortDisplay);
			else
				self.tblRight.addItemObject(obj, obj.CM_BookingRef.bookingReference);
			endif;
			oa.add(obj);
		endforeach;
		
		foreach obj in oa do
/*			if obj = oa.first then
				self.tblRight.findObjectInRow(obj, row);
				self.tblRight.accessRow(row).selected := true;
				self.tblRight.allSelectedObjects.add(self.tblRight.accessRow(row).itemObject);
			endif;*/
			row := 1;
			self.tblLeft.findObjectInRow(obj, row);
			self.tblLeft.removeItemObject(obj);
			if row &gt; self.tblLeft.rows then
				row := self.tblLeft.rows;
			endif;
			if row &gt; self.tblLeft.fixedRows then	// par 22568
				self.tblLeft.accessRow(row).selected := true;
				self.tblLeft.allSelectedObjects.add(self.tblLeft.accessRow(row).itemObject);
			endif;									// par 22568
		endforeach;
	endif;
	
	if self.tblRight.allSelectedObjects.size &gt; 0 then
		self.btnShowCargo.enabled := true;
	else
		self.btnShowCargo.enabled := false;
	endif;

epilog
	delete oa;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="3ff912a4-fb32-4c66-9d0b-c33ba70c46ca">
        <updating/>
        <source>doOK() updating;
//10 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

vars

	stRow,numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
begin
	numRows := self.tblRight.rows;
	stRow := self.tblRight.fixedRows + 1;
	
	if self.isStock then
		self.myProxyBooking.allLinkedStockBookingItems.clear();
	else
		self.myProxyBookingItem.allLinkedExportBookings.clear();
	endif;
	
	foreach rowIdx in stRow to numRows do
		jRow := self.tblRight.accessRow(rowIdx);
		if self.isStock then
			self.myProxyBooking.allLinkedStockBookingItems.add(jRow.itemObject.CM_BookingRefItem);
		else
			self.myProxyBookingItem.allLinkedExportBookings.add(jRow.itemObject.CM_BookingRef);
		endif;
	endforeach;
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowCargo" id="8e1ebf42-b789-4e0a-92f1-42cb3b05597c">
        <source>doShowCargo();
//+cnwml2 MSL CCMS 1012
vars
	
	realObj,pxyBookItem: CM_BookingRefItem;
	tiArray : ObjectArray;
	ti 		: CM_TrackedItem;
	obj 	: Object;							
	
begin
	create tiArray transient;
	if self.tblRight.allSelectedObjects.size &gt; 0 then
		foreach obj in self.tblRight.allSelectedObjects do			
			if obj.CM_BookingRefItem.allTIs.size &gt; 0 then
				foreach ti in obj.CM_BookingRefItem.allTIs do
					tiArray.add(ti);
				endforeach;
			endif;
		endforeach;
		if tiArray.size &gt; 0 then
			self.myAssistant.showCargoEnquiryForTIs(tiArray.first.CM_TrackedItem, tiArray, self.myMasterMenuAction, false);
		else
			app.msgBox("No cargo received on these booking items", "Error", MsgBox_OK_Only );
		
		endif;
	endif;
epilog
	delete tiArray;
end;</source>
    </JadeMethod>
