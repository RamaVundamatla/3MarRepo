    <JadeMethod name="doResetBayRefreshTimer" id="30b95217-e1cb-42e2-b348-c31cada71418">
        <updating/>
        <source>doResetBayRefreshTimer() updating, protected;

/*

Purpose:			Reset the current status of the Bay refresh timer - i.e. stop the 
					timer and remove any bays queued to refresh.
					Will be called when voyage changes, or a full refresh happens

Parameters:			None

Return Value:		None


Date		Who		Reason
08 Jun 2010	cnwkpd1	PAR #21995 - System performance enhancements

*/

vars

begin
	self.doStopBayRefreshTimer();
	self.allBaysToUpdate.clear();
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStartBayRefreshTimer" id="bfefe0f9-6c26-4736-9a2d-4c121d7300c7">
        <updating/>
        <source>doStartBayRefreshTimer() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Jun 2010	cnwkpd1	PAR #21995 - System performance enhancements

*/

vars

begin
	if not self.bayTimerStarted then
		self.beginTimer(Bay_Refresh_Timer_Delay, Timer_OneShot, Bay_Refresh_Timer);
		self.bayTimerStarted := true;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStopBayRefreshTimer" id="53cc0cc1-2a20-4af1-8d5e-5c0c669a2e7e">
        <updating/>
        <source>doStopBayRefreshTimer() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Jun 2010	cnwkpd1	PAR #21995 - System performance enhancements

*/

vars
	option,
	timeRemaining	: Integer;
	
begin
	if self.bayTimerStarted then
		if self.getTimerStatus(Bay_Refresh_Timer, option, timeRemaining) then
			self.endTimer(Bay_Refresh_Timer);	
		endif;
		self.bayTimerStarted := false;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="7e4755d6-ba2a-4e90-8ea9-3e558b91537d">
        <updating/>
        <source>doTblDataContextMenu(cntrl : Table input; conwin : Window input; mouse : Boolean; x : Integer; y : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	aBay : CM_Bay;
	
begin
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;
	
	self.mnuContextRemarks.visible := false;
	self.mnuContextHide.visible := false;
	self.mnuContextColourLegend.visible := false;	
	self.mnuColumnOrganiser.visible := false;		
	
	self.mnuContextRemarks.userObject := null;
	if cntrl.row = self.Row_Remarks then
//		if cntrl.accessCell(cntrl.row,cntrl.column).text = "Yes" then
			aBay := cntrl.accessColumn(cntrl.column).itemObject.CM_Bay;
			self.mnuContextRemarks.userObject := aBay;
			self.mnuContextRemarks.visible := true;
//		endif;
	endif;
	
	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="e815b2c4-f6ff-4113-a537-b615b23145d8">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	13 February 2004 By: cnwgd1
//--------------------------------------------------
vars
	aBay 		: CM_Bay;
	aDeck 		: CM_DeckVoyage;
	remarksFrm	: CMUI_Remarks;
	obj			: CM_Object;
begin
	//inheritMethod(table);

	if table.row = self.Row_Remarks then
//		if table.accessCell(table.row,table.column).text &lt;&gt; null then
			obj := table.accessColumn(table.column).itemObject.CM_Object;
			//aBay := table.accessColumn(table.column).itemObject.CM_Bay;

			if obj &lt;&gt; null then
				// Update the navigator
				create remarksFrm;
				self.setNavigatorHeading(remarksFrm.caption); 
				remarksFrm.centreWindow;
				remarksFrm.myCurrentObject := obj;
				remarksFrm.setMyTerminal(self.myTerminal);
				remarksFrm.showModal;
			endif;

//		endif;
	endif;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTableData" id="79a3a1f3-dc18-4403-9641-3eb2829c2b7f">
        <source>initTableData(_theEntDef: String);
// ---------------------------------------------------------------------------
// Created:     09 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	TheBackColor1 = 16768991;
	TheBackColor2 = 14680031;
vars
	idx 		: Integer;
	tbl			: CM_DataTable;
begin
	tbl := self.tblData;
	tbl.fixed3D := false;
	tbl.rows := 0;
	tbl.alignment := Table.Alignment_Center_Top;
//	TheBackColor1 := self.colorRow1;
//	TheBackColor2 := self.colorRow2;
	
	idx := tbl.addItem("Bays");
	idx := tbl.addItem("Disch O/D Import");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	idx := tbl.addItem("Disch O/D SOB");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	idx := tbl.addItem("Disch O/D DLR");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	idx := tbl.addItem("Disch U/D Import");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	idx := tbl.addItem("Disch U/D SOB");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	idx := tbl.addItem("Disch U/D DLR");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	idx := tbl.addItem("Discharge Total");
	tbl.accessRow(idx).backColor := Black;
	tbl.accessRow(idx).foreColor := White;
	tbl.accessCell(idx,1).backColor := Black;
	tbl.accessCell(idx,1).foreColor := White;
	idx := tbl.addItem("Load O/D");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	idx := tbl.addItem("Load O/D DLR");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	idx := tbl.addItem("Load U/D");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	idx := tbl.addItem("Load U/D DLR");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	idx := tbl.addItem("Load Total");
	tbl.accessRow(idx).backColor := Black;
	tbl.accessRow(idx).foreColor := White;
	tbl.accessCell(idx,1).backColor := Black;
	tbl.accessCell(idx,1).foreColor := White;
	idx := tbl.addItem("Hatch Lids");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	idx := tbl.addItem("Bay Totals");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	idx := tbl.addItem("Forward to Aft");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	idx := tbl.addItem("Aft to Forward");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	idx := tbl.addItem("Remarks");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;

	tbl.fixedRows := 1;
	tbl.accessRow(1).backColor := self.colorHeadingColumn;
	tbl.fixedColumns := 1;
	tbl.accessColumn(1).alignment := Table.Alignment_Left_Top;

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
