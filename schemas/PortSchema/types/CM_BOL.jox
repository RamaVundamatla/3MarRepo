    <JadeMethod name="doMoveToLocation" id="8c705c55-65f7-4d94-9821-ee4da455c5d5">
        <updating/>
        <source>doMoveToLocation(_mode : Integer; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 14 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpLogVoyage	: CM_Voyage;
	moveController : CMIF_MoveController;
	firstTime 	: Boolean;
	ti 			: CM_TrackedItem;
	coll		: Collection;
	obj			: Any;
begin

	coll := self.getTICollectionForTerminal(_passport.myTerminal);

	if coll.isEmpty then	
		// Nothing to move
		return;
	endif;
	
	// Initialise move controller parameters.
	create moveController transient;
	moveController.setMoveMode(_mode);
	moveController.setJobForMove(self.myYardJob);	
	moveController.isSystemMove := true;
	moveController.setMyToPrimaryLocation(self.myPlannedLocation);

	if _mode = PLANNING_MODE then
		// for planned mode if already planned then unplan it
		moveController.isFullyUnplan := self.myPlannedLocation &lt;&gt; null; 	
	endif;
		
	firstTime := true;
	foreach obj in coll do
		ti := obj.CM_TrackedItem;
		if firstTime then
			moveController.setMyTrackedItem(ti);
			firstTime := false;
			continue;
		endif;
		moveController.allOtherTrackedItems.add(ti);
	endforeach;
	
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	
	if CM_LogVoyageController.hasInstance(self.myPlannedLocation) then
//		tmpLogVoyage := self.myPlannedLocation.CM_LogVoyageController.myLogVoyage;
		tmpLogVoyage := self.myPlannedLocation.CM_LogVoyageController.myVoyage;		
		if tmpLogVoyage &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(tmpLogVoyage, tmpLogVoyage.myTerminal.getTerminalEvent(LogVoyageOps_Update_Event), tmpLogVoyage);		
		endif;
	endif;
	
epilog
	delete moveController;			
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doToDoRequest" id="5b0bd714-c233-4be1-a770-29a251d916b7">
        <updating/>
        <source>doToDoRequest(_request : CM_WOToDoRequest) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
