    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="f4f6a310-68e7-46c4-94d3-fb10c16088f4">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input): Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if _property = CM_SlotDefn::myOnDeckBay then
		return CM_Bay::id;
	elseif _property = CM_SlotDefn::myUnderDeckBay then
		return CM_Bay::id;
	else
		return inheritMethod(_property);
	endif;
epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="6b2dd6d8-ddc8-4a73-b20e-d05d7c07c716">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if _property = CM_SlotDefn::myOnDeckBay then
		return ExportAsChild;
	elseif _property = CM_SlotDefn::myUnderDeckBay then
