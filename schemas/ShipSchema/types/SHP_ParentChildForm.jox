    <JadeMethod name="loadChildDetails" id="8f82aca8-75b7-4551-97d1-6a38436fe19f">
        <source>loadChildDetails() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	childObject : CM_Object;
begin
	if self.myCurrentChild &lt;&gt; null then
		childObject:=self.myCurrentChild;
	else
		if self.myProxyChild &lt;&gt; null then
			childObject:=self.myProxyChild;
		endif;
	endif;	
	
	if childObject = null then
		self.doClearChildDetails();
		return;
	endif;
	
	
	self.loadChildFields(childObject);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
