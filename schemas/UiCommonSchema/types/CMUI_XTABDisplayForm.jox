    <JadeMethod name="doPrint" id="80934351-4da5-4d27-a75c-d6b70b252555">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/03/2010	cnwcs5		par 22717 - change max length to be 50 (20 was too short)
// ---------------------------------------------------------------------------
vars
	headerStr	: String;
	inputBox			: CMUI_InputBox;
begin

	create inputBox transient;

	headerStr := self.myProxyOutputFormat.name;

	inputBox.init(	app.getErrorString(Report_heading),
					app.getErrorString(Enter_heading_appear_report),
					headerStr, 50, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, false);	// par 22717 - changed from 20 to 50
	
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;

	headerStr := inputBox.txtInput.text;
		
	self.doPrintOutTable( tblMain, headerStr, true, true, true, false );
	
epilog
	delete inputBox;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="6c840fe9-bb37-48df-a9c8-e00e5feaf404">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	self.tblMain.top	:= self.frmToolbar.top + self.frmToolbar.height - 25;
	self.tblMain.width	:= frmMain.clientWidth - ( 2 * tblMain.left );
	self.tblMain.height	:= frmMain.clientHeight - tblMain.top;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveAsVoyAlloc" id="f382e330-c56a-4570-9f32-d5cfd221a468">
        <updating/>
        <source>doSaveAsVoyAlloc(_all : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2010	cnwas3	Initial creation

*/

vars
	selectedCellsColl,tiColl	: ObjectSet;	
	obj, objType 	: Object;
	theTI	: CM_TrackedItem;
	voy 	: CM_Voyage;
	existingAlloc, newAlloc : CM_VoyageAllocation;
	idx : Integer;
	tmpAllocDesc : String;
	result : Integer;
	theBooking :CM_BookingRef;
	theBookingItem : CM_BookingRefItem;
	tiMode, bookingMode, bookingItemMode : Boolean;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	create selectedCellsColl transient;
	if _all then
		self.tblMain.getAllCellObjects(selectedCellsColl);
	else
		self.tblMain.getSelectedCellObjects(selectedCellsColl);
	endif;
	
	if selectedCellsColl = null or selectedCellsColl.isEmpty() then
		return ;
	endif;

	//create tiColl transient;
	foreach obj in selectedCellsColl discreteLock do

		tiColl := self.getCollForSelectedCellObject(obj);
		if tiColl = null or tiColl.isEmpty() then
			continue;
		endif;
		objType := tiColl.first;
		if objType &lt;&gt; null then
			if objType.isKindOf(CM_TrackedItem) then
				tiMode := true;
			elseif objType.isKindOf(CM_BookingRef) then
				bookingMode := true;
			elseif objType.isKindOf(CM_BookingRefItem) then
				bookingItemMode := true;
			else
				continue;
			endif;
		else
			continue;
		endif;
		
		if tiMode then
			theTI := self.getFirstTrackedItemInColl(tiColl);
			voy := theTI.myVoyage;
		elseif bookingMode then
			theBooking := tiColl.first.CM_BookingRef;
			voy := theBooking.myVoyage;
		elseif bookingItemMode then
			theBookingItem := tiColl.first.CM_BookingRefItem;
			voy := theBookingItem.myBookingReference.myVoyage;
		else
			continue;
		endif;
		if voy &lt;&gt; null and voy.useVoyageAllocations then
			create newAlloc transient;
			newAlloc.setTerminal(voy.myTerminal);

			
			newAlloc.setFromSummaryResults(obj.CMIF_OutputField.myParent);
			newAlloc.removeNonconfigCriteria(voy);
			newAlloc.setProxyProjectedValues(obj.CMIF_OutputField.getValue().Integer,0,0,0,0,0); // PAR 23817
			tmpAllocDesc := newAlloc.getDefaultDescription(); 
			newAlloc.setProxy(tmpAllocDesc,
							tmpAllocDesc,
							null,
							YAFillOption_InOrder,
							YAFillOption_InOrder,
							YAExpiryType_Never,
							null,
							newAlloc.getDefaultColour,
							null,  //cnwjo3 par 24145
							YAOverlap_Never,//allow others
							YANoLocation_Continue,
							null,
							0, //priority adjustment
							false,
							false,
							null,
							null,
							true,
							self.myTerminal);
			
			existingAlloc := voy.getAllocationWithSameCriteria(newAlloc);
		
			if existingAlloc = null then
				
				while true do
					app.myTrxUA.trxUpdateVoyageAlloc(false,voy, newAlloc,existingAlloc,app.myPassport);
					if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
						self.clearErrorWarnings();
						break;
					else
						result := app.showErrorWarningDialog(app.getErrorString(Voyage_allocation), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				
						if app.myPassport.noErrors and
						   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
							app.myPassport.warningsAcknowledged	:= true;
						continue;
						endif;
						self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
					endif;
			
					return ;
				endwhile;				
			endif;
			
		endif;
	endforeach;
epilog
	
	delete newAlloc;
	delete selectedCellsColl;
	app.mousePointer := Window.MousePointer_Default;	
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_Send" id="754e905d-a0bf-42e3-81be-4a240a44d873">
