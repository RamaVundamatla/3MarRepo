    <JadeMethod name="doSave" id="cfc8284f-ef06-45aa-a58c-9d6dd79f9865">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 june 2008 concms1		par 17268 - CAMs messages by freight forwarder
// ---------------------------------------------------------------------------
vars
	errObj				: CM_Error;
	idx					: Integer;
	ignoreWarnings,
	rtnValue			: Boolean;
	proxyCamGroup		: CM_CamGroup;
	lCode,
	lDescription,
	lRecipient,
	lSenderCode,
	lSenderCodeDepot,
	lFacilityCode		: String;
	lUseCallSign,
	lUseDailyFileName
	,lUseVoyageOperator	: Boolean;
	lTerminal			: CM_Terminal;
	lOperators			: CM_OperatorByCodeDict;
	lFreightForwarders	: CM_ConsigneeConsignorSet;
	theForm				: SOP_TableMaintForm;
	lMaxSealLength		: Integer;
	lShippersCode : String;
begin
    theForm := self.myForm; 

	lCode				:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription		:= theForm.tblInput1.getValueByName(ETRow_Description).String;
	lRecipient			:= theForm.tblInput1.getValueByName(ETRow_Recipient).String;
	lSenderCode			:= theForm.tblInput1.getValueByName(ETRow_SenderCode).String;
	lShippersCode := theForm.tblInput1.getValueByName(ETRow_ShippersCode).String;
	lSenderCodeDepot	:= theForm.tblInput1.getValueByName(ETRow_SenderCodeDepot).String;
	lFacilityCode		:= theForm.tblInput1.getValueByName(ETRow_FacilityCode).String;
	lUseCallSign		:= theForm.tblInput1.getValueByName(ETRow_UseCallSign).Boolean;
	lUseDailyFileName	:= theForm.tblInput1.getValueByName(ETRow_UseDailyFileName).Boolean;
	lUseVoyageOperator	:= theForm.tblInput1.getValueByName(ETRow_UseVoyageOperator).Boolean;
	lMaxSealLength			:= theForm.tblInput1.getValueByName(ETRow_MaxSealLength).Integer;

	lTerminal := theForm.myTerminal;
	create lOperators transient;
	theForm.mulSelect1.getSelected(lOperators);
	
	create lFreightForwarders transient;				// par 17268
	theForm.mulSelect2.getSelected(lFreightForwarders);	// par 17268

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_CamGroup transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	proxyCamGroup := theForm.myProxyObject.CM_CamGroup;
	proxyCamGroup.setProxy(lCode, lDescription, lRecipient, lSenderCode, lSenderCodeDepot, lFacilityCode, lShippersCode,
							lUseCallSign, lUseVoyageOperator, lUseDailyFileName, lMaxSealLength,
							lOperators, lFreightForwarders, lTerminal);
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCamGroup(proxyCamGroup, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCamGroup(proxyCamGroup, app.myPassport);
	endif;

	return app.myPassport.trxCompletedOK();
epilog
  	if lOperators &lt;&gt; null then
  		delete lOperators;
  	endif;
	
	delete lFreightForwarders;	// par 17268
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
