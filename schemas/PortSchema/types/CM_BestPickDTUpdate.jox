    <JadeMethod name="getCompletedTaskString" id="68e39767-9a0b-4564-9253-bed022609fb2">
        <source>getCompletedTaskString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars
	str : String;
begin
	str :=app.getErrorString3(Best_pick_datet_updat_from_usi,  self.bestPickDT.asStringJMT,self.oldBestPickDT.asStringJMT, CM_BestPickPriority@getBestPickDateTypeDesc(self.bestPickReason)) ;
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="0c4a292d-241e-438f-9b86-eeb2c812d3d9">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars

begin
	inheritMethod(_tiTransCntrl, _passport);
	if _tiTransCntrl.isKindOf(CMIF_BestPickDTController) then
		self.bestPickDT:=_tiTransCntrl.CMIF_BestPickDTController.bestPickDT;
		self.bestPickReason:=_tiTransCntrl.CMIF_BestPickDTController.bestPickReason;
		self.oldBestPickDT:=_tiTransCntrl.CMIF_BestPickDTController.oldBestPickDT;
	endif;
epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
