    <JadeMethod name="validationExHandler" id="a4e753ac-4f67-48ed-9def-fa1035a30c51">
        <updating/>
        <source>validationExHandler(exObj : CM_Exception; _passport : CM_Passport input) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     04 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if exObj.isWarning then
		app.addWarningFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
	else
		app.addErrorFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
	endif;

	if exObj.continuable and 
	   self.continueCMExceptions then
		return Ex_Continue;
	endif;

	return Ex_Pass_Back;
	
end;</source>
        <Parameter name="exObj" type="CM_Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="vbsEnumToString" id="6778df74-c822-4a91-9b81-48a1b2f8fc18">
        <source>vbsEnumToString(_outSideSlotAction:Integer):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2022	navhl20 	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars

begin
	
	if _outSideSlotAction = CM_VehicleBookingTimeSlotType.VBS_ENTRY_NOACTION then 
		return CM_VehicleBookingTimeSlotType.VBS_ENTRY_NOACTION_DESC;
	elseif _outSideSlotAction = CM_VehicleBookingTimeSlotType.VBS_ENTRY_WARN then 
		return CM_VehicleBookingTimeSlotType.VBS_ENTRY_WARN_DESC;
	else
		return CM_VehicleBookingTimeSlotType.VBS_ENTRY_ERROR_DESC;
	endif;
epilog

end;</source>
