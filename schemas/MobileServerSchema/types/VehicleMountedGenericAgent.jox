    <JadeMethod name="resetNotes" id="325cbb16-e820-4a89-afb9-4e3783390da2">
        <source>resetNotes() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwer1	Initial creation
29 March 2018	jlgrh7 TFS 37791 SNO - VMT_Issue
*/

vars

begin
	inheritMethod();
	self.beginNotification(self.myTerminal, EVENT_AT_LabourRestriction,Response_Continuous, 0);
	self.beginNotification(self.myMachine,Event_Machine_Task_Unallocated,Response_Continuous, 0);
	self.beginNotification(self.myMachine,Event_Machine_Target_Changed,Response_Continuous, 0); // epr par 33401 18/2/14
	self.beginNotification(self.myMachine,Event_Machine_Queues_Changed,Response_Continuous, 0 );								//+TFS37791
	if self.myMachine.isIMV then
		self.beginNotification(self.myMachine,Event_Mach_RT_Refresh,Response_Continuous,0);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetNotesForQueue" id="d25c91e9-8e14-4200-bfba-a22f3fe21020">
        <source>resetNotesForQueue(_rtQueue: CM_RadioTelemetryQueue input): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2010	cnwer1	Initial creation

*/

vars
	queues : CM_RadioTelemQueueByIdDict;
	queue,subQueue : CM_RadioTelemetryQueue;
	result ,subResult,
	useSecondaryQueues : Boolean;
	eventNewAvail	: Integer;
begin

	if  not inheritMethod(_rtQueue) then
		return false;
	else
		create queues transient;
		useSecondaryQueues:=true;
		//in get mode get next task always searchs secondary queues but in list mode
		//this is configurable
		if self.showingTaskList and  not self.canDisplaySecondaryQueues then
			useSecondaryQueues:=false;
		endif;
		
		if useSecondaryQueues then
			self.getAllQueuesForType(queues,self.Secondary);
		endif;
		
		eventNewAvail	:= self.myTerminal.getTerminalEvent(RTQueueEntry_Available_Event);	
		
		if not self.showingTaskList then
			//epr par 33423 CCMS 2330 7/2/14
			if  ( self.myRTVehicleConfig.automaticGetNextTask) then
				self.beginNotification(self.myRTQueue, eventNewAvail, Response_Continuous, 0);
			endif;
			
			foreach subQueue in self.myRTQueue.allSubQueuesByOrder discreteLock do
				subQueue.getAllQueuesForMachineTA(self.myMachine, queues);
			endforeach;
		endif;
		
		foreach queue in queues discreteLock do
			subResult:=inheritMethod(queue);
			//epr par 33423 CCMS 2330 7/2/14
			if  (not self.showingTaskList and self.myRTVehicleConfig.automaticGetNextTask) then
				self.beginNotification(queue, eventNewAvail, Response_Continuous, 0);
			endif;
			
			result:=result or  subResult;
		endforeach;
		return result;
	endif;

	return true;

epilog
	delete queues;
end;</source>
        <access>protected</access>
        <Parameter name="_rtQueue" type="CM_RadioTelemetryQueue" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetNotesForVoyageDischarge" id="0fcf1fe8-0ee2-49ab-85b1-b9f7434881c6">
        <source>resetNotesForVoyageDischarge();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 October 2010	cnwer1	Initial creation PAR 25994

*/

vars
	parentQ		: CM_VoyageQueue;
	subQ		: CM_RadioTelemetryQueue;
begin
	self.resetNotes();
	
	if self.myRTQueue.isKindOf(CM_VoyageCraneQueue) then
		parentQ:=self.myRTQueue.myParentQueue.CM_VoyageQueue;
		foreach subQ in parentQ.allSubQueuesById do
			self.resetNotesForQueue(subQ);
		endforeach;
	//epr par 36081 11/5/15  
	elseif self.myRTQueue.isKindOf(CM_VoyageQueue) then
		parentQ:=self.myRTQueue.CM_VoyageQueue;
		foreach subQ in parentQ.allSubQueuesById do
			self.resetNotesForQueue(subQ);
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sendLabourRestrictionError" id="5c6a2f4e-1bf1-4018-a741-79104834b6aa">
        <source>sendLabourRestrictionError(_userInfo : Any) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwer1	Initial creation

*/

vars
	eventObject : Object;
	objectEdition : Integer;
	invalidUserInfo,
	foundTask			: Boolean;
	systemAlert 	: CM_SystemAlert;
	rtQueueEntry 	: CM_RTQueueEntry;
	task			: CM_RTQueueTask;
			
begin
	if self.myVMInterface = null then
		return;
	endif;

	
	on Exception do app.handleDeletedObject(exception,eventObject,invalidUserInfo);
	
	if not _userInfo.isKindOf(CM_SystemAlert) then
		return;
	endif;
		
	systemAlert:=_userInfo.CM_SystemAlert;
	eventObject:=systemAlert.getLinkedTo;
	
	if eventObject = null then
		return;
	endif;
	objectEdition:=eventObject.edition;
	if invalidUserInfo then
		return;
	endif;
	if not eventObject.isKindOf(CM_RTQueueEntry) then
		return;
	endif;
	
	rtQueueEntry:=eventObject.CM_RTQueueEntry;
	
	//epr 25504 23/8/10
	foundTask:=false;
	foreach task in rtQueueEntry.allTasks do
		if  self.myMachine.allCurrentQueueTasks.includes(task) then
			foundTask:=true;
			break;
		endif;
	endforeach;
	
	if not foundTask then
		return;
	endif;
	
	self.myVMInterface.doSendErrorMessage(app.getErrorString(LabourRestriction),systemAlert.details);
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
