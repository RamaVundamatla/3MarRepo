    <JadeMethod name="abortBackup" id="5cb7d99c-288c-432c-b621-04f8232fc06f">
        <updating/>
        <source>abortBackup(_msg: String io): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// ---------------------------------------------------------------------------
vars

begin
	app.myTrxUA.trxUpdateBGPBackupHistStatus(self.myBackupHistory, BackupStatus_Abort);
	_msg := "Backup Aborted";
epilog
	return false;
end;</source>
        <Parameter name="_msg" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyFile" id="32bb6512-ade7-4b9b-b2a1-9e0241f1c7a9">
        <source>copyFile(_sourceFile, _targetFolder: String) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// July 2009    cnwrs1      to replace the data being copied par 20382
// ---------------------------------------------------------------------------
vars
	result: Boolean;
	str: String;
	file: File;
begin
	result := false;
	create file transient;
	file.fileName := _sourceFile;
	if not file.cnCopyFile(_targetFolder, false, str) then //cnwrs1 par 20382 july 2009
		app.writeLog(str, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		return result;
	endif;
	result := true;
epilog
	delete file;
	return result;	//false on exception
end;</source>
        <access>protected</access>
        <Parameter name="_sourceFile" type="String"/>
        <Parameter name="_targetFolder" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
