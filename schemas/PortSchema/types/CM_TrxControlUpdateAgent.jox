    <JadeMethod name="trxSwapWagonCargoPositions" id="74616187-6c1b-4788-8af6-eca8226a4095">
        <updating/>
        <source>trxSwapWagonCargoPositions(_control : CMIF_WagonMoveController; _tiArray : CM_TIArray input; _newLocations : ObjectArray input;_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwndl1	Initial creation

*/

vars
	moveController : CMIF_MoveController;
	allMoveControllers : ObjectArray;
	obj : Object;
	pos : Integer;
	ti : CM_TrackedItem;
	tmpTA : CM_TerminalArea;
	swapLC : CM_LocationsController;
	newLocation : CM_WagonController;
	tiSet : CM_TISet;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	// create move controllers.
	create allMoveControllers transient;
	// create moves for each ti to the swap area first
	foreach pos in 1 to _tiArray.size discreteLock do
		ti := _tiArray[pos];
		if swapLC = null then
			tmpTA := ti.myPrimaryActualLocation.myTerminalArea;
			swapLC := tmpTA.swapStack.myLocationsController;
		endif;
		create moveController transient;
		allMoveControllers.add(moveController);
		moveController.setMoveMode(REAL_MODE);
		moveController.setMyTrackedItem(ti);
		moveController.setMyOriginatingLocation(ti.myPrimaryActualLocation);
		moveController.setMyToPrimaryLocation(swapLC);
		moveController.setMyPassport(app.myPassport);
		//25 Feb 2021	NDL	TFS 50837
		if _control &lt;&gt; null and _control.effectiveTimeStamp.isValid then
			moveController.setEffectiveTimeStampOverride( _control.effectiveTimeStamp );
		endif;
	endforeach;
	
	// create moves from swap area to the new locations
	foreach pos in 1 to _tiArray.size discreteLock do
		ti := _tiArray[pos];
		newLocation := _newLocations[pos].CM_WagonController;
		create moveController transient;
		allMoveControllers.add(moveController);
		moveController.setMoveMode(REAL_MODE);
		moveController.setMyTrackedItem(ti);
		moveController.setPreSwapLocation(ti.myPrimaryActualLocation.CM_WagonController.id);
		moveController.setMyOriginatingLocation(swapLC);
		moveController.setMyToPrimaryLocation(newLocation);
		moveController.setMyPassport(app.myPassport);
		//25 Feb 2021	NDL	TFS 50837
		if _control &lt;&gt; null and _control.effectiveTimeStamp.isValid then
			moveController.setEffectiveTimeStampOverride( _control.effectiveTimeStamp );
		endif;

	endforeach;
	
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;
	
	beginTransaction;
	
	create tiSet transient;
	foreach obj in allMoveControllers do
		tiSet.clear();
		moveController := obj.CMIF_MoveController;
		tiSet.add(moveController.myTrackedItem);
		app.myUtilityUA.utlUpdateMoveTrackedItems(tiSet, moveController, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;
	
epilog

	self.finaliseActivityWithPassport(_passport);

	if not allMoveControllers.isEmpty then
		allMoveControllers.purge();
	endif;
	delete allMoveControllers;
	delete tiSet;
	
end;</source>
        <Parameter name="_control" type="CMIF_WagonMoveController"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_newLocations" type="ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
