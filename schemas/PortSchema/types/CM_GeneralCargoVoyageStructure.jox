    <JadeMethod name="createHoldsFromGCVesselStruct" id="80ce3dea-abbc-44c3-8ff6-3fecb06e7eef">
        <updating/>
        <source>createHoldsFromGCVesselStruct():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/07/2013	cnwndl1	Initial creation	Par 31965
27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
*/

vars

	voyage : CM_Voyage;
	vessel : CM_Vessel;
	gcVesselStruct : CM_GeneralCargoVesselStructure;
	gcHoldLocnDefn : CM_GCHoldLocationDefn;
	tmpLocation : CM_GeneralCargoController;

begin

	if not self.allLocationsByHatchPlace.isEmpty then 
		// if they have already been built from vessel structure or voyage copy form,
		//should only be maintained manually via the Voyage Location Definition form now.
		return true;
	endif;

	voyage := self.myVoyage;
	if voyage &lt;&gt; null then
		vessel := voyage.myVessel;
	endif;
	if vessel &lt;&gt; null then
		gcVesselStruct := vessel.myGeneralCargoVesselStructure;
	endif;

	if gcVesselStruct = null or gcVesselStruct.allHoldLocnDefnByHatchPlace.isEmpty then
		return false;
	endif;
	
	//must need to be built
	foreach gcHoldLocnDefn in gcVesselStruct.allHoldLocnDefnByHatchPlace do
		create tmpLocation persistent;
		//tmpLocation.setInternal(self, gcHoldLocnDefn.hatch , gcHoldLocnDefn.place, gcHoldLocnDefn.name);													// PAR #36766
		tmpLocation.setInternal(self, gcHoldLocnDefn.hatch , gcHoldLocnDefn.place, gcHoldLocnDefn.name, gcHoldLocnDefn.isOnDeck, gcHoldLocnDefn.maxWeight, gcHoldLocnDefn.maxVolume, gcHoldLocnDefn.maxHeight, gcHoldLocnDefn.onShipCrane);	// PAR #36766
		tmpLocation.validateHoldName( voyage.code );	//09 Sep 2015	NDL	Par 36812
	endforeach;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="0508e2cf-3a24-41c2-b88b-ee6f8bffacb1">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

begin

	if not self.allLocationsByHatchPlace.isEmpty then
		self.allLocationsByHatchPlace.purge;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findLocation" id="25d0bdf7-7f43-4c64-a1ef-6525cdacb633">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
//
// Aug 2006 cnwrs1

//
vars
	remainingStrs : StringArray;
	tStr : String;
	hold, locId : Integer;
	locName : String;
	int : Integer;
	gcController : CM_GeneralCargoController;
	string : String;
begin
	if _foundLC &lt;&gt; null or
	   _strs = null then
		return;
	endif;
	//AKB - avoid index out of bounds exception
	if _strs.isEmpty then
		return;
	endif;
	
		//New way... Par 31965
		//Now expected to be one of the following:
		// for our example where hold = 01, location id = 02 and location name = Bilge
		// full id would show as the &lt;voyage code&gt; plus '0102 Bilge'
		// we will accept
		//    2 digit numeric holdnumber plus 2 digit numeric location number i.e. '0102'
		// or 2 digit numeric holdnumber plus a space plus the location name i.e. '01 Bilge'
	
	tStr := _strs[1].trimBlanks;
	if tStr = null then
		//nothing we can do.
		return;
	endif;
	if _strs.size &gt; 1 then
		foreach int in 2 to _strs.size do
			if locName = null then
				locName := _strs[int].trimBlanks.toUpper;
			else
				locName := locName &amp; " " &amp; _strs[int].trimBlanks.toUpper;
			endif;
		endforeach;
	endif;
	
	while tStr.pos("  ",1) &gt; 0 do
		tStr := tStr.replaceString("  "," ");
	endwhile;
	
	if tStr.length = 2 then
		if tStr.isInteger then
			hold := tStr.Integer;
			if locName = null then
				return;
			endif;
		else
			return;
		endif;
			
	elseif tStr.length &gt;= 4 then
		if tStr[1:2].isInteger then
			hold := tStr[1:2].Integer;
		else	
			return;
		endif;
		if tStr[3] = " " then
			locName := tStr[3:end].trimBlanks.toUpper;
		elseif tStr[3:2].isInteger then
			locId := tStr[3:2].Integer;
		else
			return;
		endif;
		
	else
		return;
		
	endif;
	
	if hold &lt; 1 then
		// if we don't know the hold we are buggered.
		return;
	elseif locId &gt; 0 then
		//we have the both keys, use these
		_foundLC := self.allLocationsByHatchPlace.getAtKey(hold, locId);
		if locName &lt;&gt; null and _foundLC &lt;&gt; null and _foundLC.CM_GeneralCargoController.name.toUpper() &lt;&gt; locName then
			_foundLC := null;
		endif;
		return;
	endif;
	
	if locName &lt;&gt; null then
		foreach gcController in self.allLocationsByHatchPlace where gcController.hatch = hold do
			// first one in the hold with a matching name.
			if gcController.name.toUpper = locName then
				_foundLC := gcController;
				return;
			endif;
		endforeach;
	endif;
			
		
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTotalPlanned" id="db2f85a5-4518-4660-95c6-181d242e809b">
        <source>getTotalPlanned(_getLoad : Boolean; _includeDLR : Boolean) : Integer;
/*
Purpose:			
Date		Who		Reason
13 January 2015	cnwab1	Initial creation
*/

vars
	aGC : CM_GeneralCargoController;
	amount : Integer;
	tis: CM_TIArray;
	ti : CM_TrackedItem;
begin
	create tis transient;
	foreach aGC in self.allLocationsByHatchPlace discreteLock do
		if _getLoad then
			aGC.getAllPlannedTrackedItems(tis,true,false);
			amount := amount + tis.size;
		else
			foreach ti in aGC.allTrackedItems discreteLock  where ti.isImport   do
				if ti.myPrimaryPlannedLocation &lt;&gt; null then
					amount := amount + ti.quantity;
				endif;
			endforeach;
		endif;
		
 
	endforeach;
	
	return amount;
epilog
	delete tis;
end;</source>
        <Parameter name="_getLoad" type="Boolean"/>
        <Parameter name="_includeDLR" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDefaultLocationsFrom" id="0080b35e-ff1a-4430-9886-2150d1592a92">
        <source>setDefaultLocationsFrom( _obj : CM_Object; asTransient : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/07/2013	cnwndl1	Initial creation	Par 31965
27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
*/

vars

	objLocation : CM_GeneralCargoController;
	tmpLocation : CM_GeneralCargoController;

begin

	if _obj = null then
		return;
	endif;

	if _obj.isKindOf( CM_GeneralCargoVoyageStructure ) then
		foreach objLocation in _obj.CM_GeneralCargoVoyageStructure.allLocationsByHatchPlace do
			if asTransient then
				create tmpLocation transient;
				//tmpLocation.setProxy(self, objLocation.hatch , objLocation.place, objLocation.name);												// PAR #36766
				tmpLocation.setProxy(self, objLocation.hatch , objLocation.place, objLocation.name, objLocation.isOnDeck, objLocation.maxWeight, objLocation.maxVolume, objLocation.maxHeight, objLocation.onShipCrane);	// PAR #36766
			else
				create tmpLocation persistent;
				//tmpLocation.setInternal(self, objLocation.hatch , objLocation.place, objLocation.name);											// PAR #36766
				tmpLocation.setInternal(self, objLocation.hatch , objLocation.place, objLocation.name, objLocation.isOnDeck, objLocation.maxWeight, objLocation.maxVolume, objLocation.maxHeight, objLocation.onShipCrane);// PAR #36766
			endif;
		endforeach;
	
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="asTransient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="cd57502e-c010-4dbd-8c8b-72a0b7527810">
        <updating/>
        <source>setForUpdate(_proxyVoyage: CM_GeneralCargoVoyageStructure; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
vars
	holdLocation,
	deckLocation,
	tmpLocation : CM_GeneralCargoController;
	hatch,
	tmpNumHatches : Integer;
begin
	inheritMethod(_proxyVoyage, _passport);

	tmpNumHatches := self.numberOfHatches;
	self.numberOfHatches := _proxyVoyage.numberOfHatches;
	
	//09 July 2013	NDL	Par 31965
	if self.createHoldsFromGCVesselStruct() then
		//The new way...
		
	else
		
		// Locations are created when required for both import and export cargo
		// Create locations as per Richard Smith email 27/03/2006 13:28
		if self.numberOfHatches &gt; tmpNumHatches then
			// create locations for number of hatches. 
			// One hold and one deck location controller for each hatch.
			tmpNumHatches := tmpNumHatches+1;
			foreach hatch in tmpNumHatches to self.numberOfHatches do
				
				if self.allLocationsByHatchPlace[hatch, PlaceHold] = null then
					// hatch location not found for hold, create one
					create tmpLocation persistent;
					//tmpLocation.setInternal(self, hatch , PlaceHold, null);				// PAR #36766
					tmpLocation.setInternal(self, hatch , PlaceHold, null, false, null, null, 0, 1);	// PAR #36766
				endif;
				if self.allLocationsByHatchPlace[hatch, PlaceDeck] = null then
					// hatch location not found for deck, create one			
					create tmpLocation persistent;
					//tmpLocation.setInternal(self, hatch , PlaceDeck, null);				// PAR #36766
					tmpLocation.setInternal(self, hatch , PlaceDeck, null, true, null, null, 0, 1);		// PAR #36766
				endif;
			endforeach;
	
		elseif self.numberOfHatches &lt; tmpNumHatches then
			
			// reduce hatches if hatch location not in use
			foreach hatch in self.numberOfHatches+1 to tmpNumHatches do
	
				// only delete if both hold and deck for location are not in use			
				holdLocation := self.allLocationsByHatchPlace[hatch, PlaceHold];
				if holdLocation = null
				or (not holdLocation.isLocationEmpty()) then
					// cannot reduce any further as hold is in use
					break;
				endif;
				deckLocation := self.allLocationsByHatchPlace[hatch, PlaceDeck];			
				if deckLocation = null
				or (not deckLocation.isLocationEmpty()) then
					// cannot reduce any further as deck is in use
					break;
				endif;
				// both hold and deck are not in use so ok to delete	
				delete holdLocation;					
				delete deckLocation;
	
			endforeach;
	
		endif;
		
		// Belts &amp; Braces check locations match hatches
		// should have already been picked up in the validation self.validateMe()
		tmpLocation := self.allLocationsByHatchPlace.last;
		if tmpLocation &lt;&gt; null then
			if tmpLocation.hatch &lt;&gt; self.numberOfHatches then
				app.raiseCMException2(VB_COUNT_MISMATCH, 'locations ('&amp;tmpLocation.hatch.String&amp;')', 'Number of Hatches', null, null);
			endif;
		endif;	
	
	endif;
				
end;</source>
        <Parameter name="_proxyVoyage" type="CM_GeneralCargoVoyageStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyGCVoyage" id="26052770-f03c-4d7c-aa75-30ddeb20955a">
