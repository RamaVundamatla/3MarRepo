    <JadeMethod name="getGivenName" id="a2010779-5d26-4fe2-8438-184ee0940300">
        <source>getGivenName():String;

vars
	retValue : String;
	pos : Integer;
	
begin
	pos	:=	self.name.pos(",", 1);
	
	if pos &gt; 0 then 
		retValue	:=	self.name[(pos + 1):end].trimBlanks();
	endif;
	
	return retValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastName" id="0e591d98-546e-47ef-8282-345fd9c0397c">
        <source>getLastName():String;

vars
	retValue : String;
	pos : Integer;
	
begin
	pos	:=	self.name.pos(",", 1);
	
	if pos &gt; 1 then 
		retValue	:=	self.name[1:(pos - 1)];
	endif;
	
	return retValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="3e03989f-50b3-446c-bd48-451c902157b9">
        <updating/>
        <source>initializeMe(	pEmailAddress:String;
				pMyBaseData:CnEcEmailBaseData;
				pName:String)  : String updating; 

// This method created by JediMethodGenerator at 14:43:43 on 16 March 2001

vars
	errorMessage	: String;

begin
	// Validation

	errorMessage := self.validateMe(pEmailAddress, pMyBaseData, pName);  

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// Attributes (Non Keys)

	self.emailAddress := 	pEmailAddress;

	// Attributes (Keys)

	self.name := 	pName;

	// Singleton References

	self.myBaseData := 	pMyBaseData;
epilog
	return errorMessage;
end;</source>
        <Parameter name="pEmailAddress" type="String"/>
        <Parameter name="pMyBaseData" type="CnEcEmailBaseData"/>
        <Parameter name="pName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="64869bf9-4f51-43c9-b763-3fd2de7bca1b">
        <updating/>
        <source>updateMe(	pEmailAddress:String;
			pMyBaseData:CnEcEmailBaseData;
			pName:String)  : String updating; 

// This method created by JediMethodGenerator at 14:43:43 on 16 March 2001
// Please add any validation required then delete this comment.

vars
	errorMessage	: String;

begin
	// Validation

	errorMessage := self.validateMe(
				pEmailAddress,
				pMyBaseData,
				pName);  

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// Attributes (Non Keys)

	if self.emailAddress &lt;&gt; pEmailAddress then
		self.emailAddress := 	pEmailAddress;
	endif;

	// Attributes (Keys)

	if self.name &lt;&gt; pName then
		self.name := 	pName;
	endif;

	// Singleton References

	if self.myBaseData &lt;&gt; pMyBaseData then
		self.myBaseData := 	pMyBaseData;
	endif;
epilog
	return errorMessage;
end;</source>
        <Parameter name="pEmailAddress" type="String"/>
        <Parameter name="pMyBaseData" type="CnEcEmailBaseData"/>
        <Parameter name="pName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
