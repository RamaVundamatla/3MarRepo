        <updating/>
        <source>load() updating;

vars

begin

	self.setupForm();
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="saveRootHotFixes" id="8d2159fa-6bd5-46d7-bee0-cce14e96d6bb">
        <source>saveRootHotFixes( _dirSetupHotFixes, _releaseVersionNo : String );

vars
	rtH : RootHotFixes;
	
begin
	
	rtH := app.myRootHotFix;
	if rtH = null then
		beginTransaction;
		create rtH;
		commitTransaction;
	endif;

	rtH.initRootHotFixes( _dirSetupHotFixes, _releaseVersionNo );

end;
</source>
        <Parameter name="_dirSetupHotFixes" type="String"/>
        <Parameter name="_releaseVersionNo" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6707c159-6c4e-44fa-b747-5c34a981b367">
        <updating/>
        <source>setupForm() updating;

vars
	rt	: RootHotFixes;

begin
	executeWhen JMTDevelopmentEnvironment;
	if not process.isMPD then
		app.msgBox("Unable to create patches/hotfixes in DEVELOPMENT environment", "Hotfix/Patch Create", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		unloadForm();
	endif;
	endExecuteWhen;


	rt := app.myRootHotFix;
	if (rt = null) or (rt.dirSetupHotFixes = null) then
//		self.saveRootHotFixes( 'C:\Setup', '001' );
		app.msgBox('Root has no instance. Please run HotfixCommonSchema::JadeScript::createRoot()', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;

	self.centreWindow();
	
	self.txtReleaseNo.text		:= rt.releaseVersionNo;
	self.txtReleaseNo.maxLength := rt.LENGTH_OF_RELEASE_VERSION;
	self.txtDirSetup.text		:= rt.dirSetupHotFixes;

//int:= RedValue + (GreenValue * 256) + (BlueValue * 256 * 256);	
	self.txtDirSetup.foreColor	:= Blue;
	self.txtReleaseNo.foreColor := Blue;
//	self.txtReleaseNo.backColor := White;
	
end;
</source>
    </JadeMethod>
</GUIClass>
