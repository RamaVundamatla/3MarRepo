    <JadeMethod name="gotFocus" id="b893b4ef-0461-4ffc-8dbe-b5f3ae064956">
        <updating/>
        <source>gotFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		12 March 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/03/2002	cnwdad1		Added check for a selection style of "Select All".  If
//							this option is used, then the contents will be selected
//							after the newly formatted contents are set.  This is
//							necessary because we're switching from an alphanumeric
//							textbox to a numeric textbox.
// --------------------------------------------------------------------------------
vars
	textValue		: String;
	
begin
	inheritMethod(textbox);
	
	textValue	:=	textbox.text.cnEcAsNumeric(self.myCurrencyFormat);
	
	self.setIsIgnoreState(true);
	textbox.text	:=	null;
	self.dataType	:=	TextBox.DataType_SignedNumeric;
	self.decimals	:=	self.myCurrencyFormat.decimalPlaces;
	self.setIsIgnoreState(false);
	textbox.text	:=	textValue;
	
	if self.selectionStyle = TextBox.SelectionStyle_SelectAll then	// cnwdad1 13/03/2002.
		textbox.selStart	:=	0;									// cnwdad1 13/03/2002.
		textbox.selLength	:=	textValue.length;					// cnwdad1 13/03/2002.
	endif;															// cnwdad1 13/03/2002.
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="74099e65-713c-4c52-aa26-ffa9062a5d2d">
        <updating/>
        <source>lostFocus(textbox: TextBox input) updating;

vars
	value : String;
	
begin
//	value 			:=	textbox.text.cnEcAsNumeric(myCurrencyFormat);					// cnwdad1 12/03/2002.
	value 			:=	textbox.text.Decimal.userCurrencyFormat(self.myCurrencyFormat);	// cnwdad1 12/03/2002.
	self.dataType	:=	TextBox.DataType_AlphaNumeric;									// cnwdad1 12/03/2002.
	self.decimals	:=	0;																// cnwdad1 12/03/2002.
	
	if value &lt;&gt; null then
		textbox.text	:=	value;
	endif;
			
	inheritMethod(textbox);
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setAlignment" id="db2f11c6-6fa7-474e-ba80-89d1417ef40a">
        <updating/>
        <source>setAlignment() updating, protected;
// --------------------------------------------------------------------------------
// Created:		19 September 2002 by cnwdad3
//
// Purpose:		Sets the receiver's alignment to be right-aligned.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.alignment		:=	TextBox.Alignment_Right;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setIsIgnoreState" id="cbf6bd0e-d970-4fce-8157-83cc816d9c0e">
        <updating/>
        <source>setIsIgnoreState(pIsOverride:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 March 2002 by cnwdad1
//
// Purpose:		Sets a flag to indicate that the "text" mapping method should ignore
//				the formatting while the receiver's text is formatted back to a
//				numeric value for user input.
//
// Parameters:	pIsOverride - If true, the mapping method won't format the text.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isIgnoreState	:=	pIsOverride;
end;</source>
        <access>protected</access>
        <Parameter name="pIsOverride" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="text" id="ab588bce-eaf7-4334-bb19-9a50b7bddf68">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>text(set: Boolean; value: String io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 12/02/2002	cnwdad1 	Added check for whether the textbox is currently expecting
//							a currency value or a formatted string, and converted
//							the "value" parameter accordingly.
//
// 13/02/2002	cnwdad1		Added check for whether the receiver's CurrencyFormat
//							is null or not.
// --------------------------------------------------------------------------------
begin
	if set
	and (not self.isIgnoreState)
	and self.myCurrencyFormat &lt;&gt; null		// cnwdad1 13/03/2002.
	then
		if self.dataType = TextBox.DataType_AlphaNumeric then							// cnwdad1 12/03/2002.
			value	:=	self.myCurrencyFormat.cnEcStripNonNumeric(value).Decimal.userCurrencyFormat(self.myCurrencyFormat);
		else																		// cnwdad1 12/03/2002.
			value 	:=	value.cnEcAsNumeric(self.myCurrencyFormat);
		endif;																		// cnwdad1 12/03/2002.
		
// cnwdad1 12/03/2002.		
//		if value &lt;&gt; null then
//			value	:=	self.myCurrencyFormat.cnEcStripNonNumeric(value.Decimal.userNumberFormat(self.myCurrencyFormat));
//		endif;		
	endif;
	
	inheritMethod(set, value);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="e5a04038-42a2-4490-8bc7-ed8aa6b0b842">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------

// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);

	self.myCurrencyFormat	:=	app.currentLocaleInfo.currencyInfo;
	self.setAlignment();
//	self.dataType			:=	self.DataType_SignedNumeric;			// cnwdad1 12/03/2002.
//	self.decimals			:=	self.myCurrencyFormat.decimalPlaces;	// cnwdad1 12/03/2002.
	self.dataType			:=	TextBox.DataType_AlphaNumeric;			// cnwdad1 12/03/2002.
	self.decimals			:=	0;										// cnwdad1 12/03/2002.
	self.text				:=	self.text;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
