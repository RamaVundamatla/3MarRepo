    <JadeMethod name="setCommodity" id="26be0b8d-8647-4cb1-a953-1f29a02500b5">
        <updating/>
        <source>setCommodity(_value: String; _operator :CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - commodity xlations
vars
	foundMatch	: Boolean;
begin	
	if _operator &lt;&gt; null then
		self.commodity := _operator.getXlationSystemCode_Commodity(_value[1:30].trimBlanks(), foundMatch, self.temperature);  //par 18527 cnwrs1 Nov 2008 [1:4];
	else
		self.commodity := _value[1:30].trimBlanks(); //par 18527 cnwrs1 Nov 2008
	endif;
end;</source>
        <Parameter name="_value" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setConsignee" id="82206d99-9659-4b0a-a6f8-ed68549122aa">
        <updating/>
        <source>setConsignee(_code: String) updating;
/*
Date		Who		Reason
05 Feb 2010	cnwas3	Initial creation ccms 1915 - PAR 22271
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
*/

vars
	operator 	: CM_Operator;
	foundMatch	: Boolean;
	consign : CM_ConsigneeConsignor;
begin
	operator := app.myRoot.allOperators[self.operatorCode];
	
	if operator &lt;&gt; null then
		self.consignee := operator.getXlationSystemCode(_code[1:30].trimBlanks(), XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);  
	else
		self.consignee := _code[1:30].trimBlanks(); 
	endif;
	
end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCooledType" id="c4d93fac-5089-48e4-bc13-1a3dacd9804d">
        <updating/>
        <source>setCooledType(_wc: String) updating;
//----------------------------------------------------------------
//	Created:	10 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Always call after setting temperature
vars

begin
	if _wc = null then
		return;
	endif;
	
	if self.temperature &lt;&gt; NULL_TEMPERATURE then
		if _wc[1:1] = "W" then
			self.cooledType := ContainerWaterCooled;
		else
			self.cooledType := ContainerAirCooled;
		endif;
	else
		self.cooledType := ContainerCooledNull;
	endif;
end;</source>
        <Parameter name="_wc" type="String"/>
    </JadeMethod>
