    <JadeMethod name="doTransactionFilterFormLoad" id="a7387acb-fe9f-412c-a67a-c44aa90c1da4">
        <source>doTransactionFilterFormLoad();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 July 2023
TFS#		: 58636
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	form : CMUI_GoodsReceiptMoveTrans;
begin
	if self.myCurrentTableItem = null then
		return;
	endif;
	
	if self.myCurrentObject = null then
		return;
	endif;
	
	if not self.myCurrentObject.isKindOf(CM_CamProtocol) then
		return;
	endif;
	
	form :=app.loadForm(CMUI_GoodsReceiptMoveTrans,CMUI_Assistant,false,false,true,self.myTerminal,null).CMUI_GoodsReceiptMoveTrans;
	form.myCamprotocol:=self.myCurrentObject.CM_CamProtocol;
	form.showModal;

end;</source>
