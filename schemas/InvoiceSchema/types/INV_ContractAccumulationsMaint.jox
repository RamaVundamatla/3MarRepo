    <JadeMethod name="doClearFields" id="2358c57d-8e84-4987-aad4-db8029007997">
        <source>doClearFields();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations
*/

vars

begin
