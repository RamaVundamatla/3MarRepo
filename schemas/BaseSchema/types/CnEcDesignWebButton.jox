    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myTable" id="3bb7acbb-bdd4-432c-8828-7cbddb5083ae">
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CnEcDesignTable"/>
        <access>protected</access>
        <Inverse name="CnEcDesignTable::webNextButton"/>
        <Inverse name="CnEcDesignTable::webPreviousButton"/>
    </ExplicitInverseRef>
    <PrimAttribute name="previousButton" id="5cf582bc-49de-4d85-8e14-86f729607fcc">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="scroll" id="5c066f9e-b697-4a07-abf8-11c726b14a8a">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="click" id="43255c15-9f3b-4a8a-ae62-0901daf7c7fd">
        <updating/>
        <source>click(btn : Button input) updating;

vars

begin
	if previousButton then
		myTable.scrollTableWEB(scroll * -1);
	else
		myTable.scrollTableWEB(scroll);
	endif;
	inheritMethod(btn);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="37e136de-9cd9-4bf4-95f4-25fc086c54ae">
        <updating/>
        <source>windowCreated(cntrl : Control input; persistCntrl : Control) updating;

vars

begin
	if previousButton then
		self.caption := 'P' &amp; Cr &amp; 'R' &amp; Cr &amp; 'E' &amp; Cr &amp; 'V';
		self.move(	myTable.left + myTable.width,
					myTable.top,
					15,
					myTable.height / 2);
	else
		self.caption := 'N' &amp; Cr &amp; 'E' &amp; Cr &amp; 'X' &amp; Cr &amp; 'T';
		self.move(	myTable.left + myTable.width,
					myTable.top + (myTable.height / 2),
					15,
					myTable.height / 2);
	endif;	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
