    <JadeMethod name="setProxy" id="0fba09dd-a9dc-4294-9f6f-a1145f7f4476">
        <updating/>
        <source>setProxy(_debtor : CM_Debtor; _invoiceLineType : CM_InvoiceLineDesc; _otherCode : String) updating;

vars

begin
	self.otherCode := _otherCode;
	self.myDebtor := _debtor;
	self.myInvoiceLineType := _invoiceLineType;

end;
</source>
