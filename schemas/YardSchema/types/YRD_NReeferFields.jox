    <JadeMethod name="btnAdd_click" id="b6e18d45-270f-4352-bdd7-4c363439bb20">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(btn: Button input) updating;
/*
Purpose:			


01 July 2021	navab1		TFS 51361
*/

vars
	entRow : EntTableRow;
	idx : Integer;
begin
	idx :=  self.lstFieldsAvailable.listIndex;
	
	if idx &lt; 0 then
		return;
	endif;
	
	entRow := self.lstFieldsAvailable.itemObject[idx].EntTableRow;
	self.lstFieldsAvailable.removeItem(idx);

	idx := self.lstFieldsUsed.addItem(self.getRowHeading(entRow));
	self.lstFieldsUsed.itemObject[idx] := entRow;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
