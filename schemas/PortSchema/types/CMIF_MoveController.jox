    <JadeMethod name="setRehandleTIsStatus" id="b5fbabad-30c3-4066-9275-85d3dda9fdfc">
        <updating/>
        <source>setRehandleTIsStatus(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		If this is a reahndle move then set the TIs status to that of DLR
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/05/2010	cnwdap1		CCMS 1116 Tranship changes
//							This method doesn't appear to be referenced anywhere, 
//							and had an error in the else, which I have fixed as 
//							well as making my tranship changes
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	imex : Integer;
begin
	
	if not self.isRehandleMove and not self.isUndoMove then
		return;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		if self.isUndoMove then
			if self.myTrackedItem.isRehandle then
				self.myTrackedItem.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
			endif;
		else
			if self.myTrackedItem.getImExStatus &lt;&gt; TI_IMEX_STATUS_TRANSHIP then	// PAR #23645 CCMS 1116
				if self.myTrackedItem.isImport then
					imex := TI_IMEX_STATUS_IMPORT;
				else
					imex := TI_IMEX_STATUS_EXPORT;
				endif;
				self.myTrackedItem.setImExStatus(imex);
			endif;																// PAR #23645 CCMS 1116
			self.myTrackedItem.setTransitStatus(TI_TransitStatusDLR, true, _passport);
		endif;
	endif;
	foreach theTI in self.allOtherTrackedItems do
		if self.isUndoMove then
			if theTI.isRehandle then
				theTI.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
			endif;
		else
			if theTI.getImExStatus &lt;&gt; TI_IMEX_STATUS_TRANSHIP then	// PAR #23645 CCMS 1116
				//if self.myTrackedItem.isImport then				// PAR #23645 CCMS 1116
				if theTI.isImport then								// PAR #23645 CCMS 1116
					imex := TI_IMEX_STATUS_IMPORT;
				else
					imex := TI_IMEX_STATUS_EXPORT;
				endif;
				//self.myTrackedItem.setImExStatus(imex);			// PAR #23645 CCMS 1116
				theTI.setImExStatus(imex);							// PAR #23645 CCMS 1116
			endif;													// PAR #23645 CCMS 1116
			//self.myTrackedItem.setTransitStatus(TI_TransitStatusDLR);	// PAR #23645 CCMS 1116
			theTI.setTransitStatus(TI_TransitStatusDLR, true, _passport);			// PAR #23645 CCMS 1116
		endif;
	endforeach;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
