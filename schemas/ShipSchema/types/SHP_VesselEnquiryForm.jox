    <JadeMethod name="getXMLSettingsForSave" id="84bcd343-b083-413a-af5c-01ad1ff346d7">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	xmlStr	: String;
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblData.getXmlStrForColumns(true) &amp;
			global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.dkbDetails.name) &amp;
			global.formatAsXML(XMLTag_HideExtraInfo, (not self.dkbDetails.visible).String) &amp;			
			global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.dkbDetails.name);

	
	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSystemNotification" id="ce209311-dc90-45c3-846e-696ec4d696d7">
        <updating/>
        <source>handleSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpVessel : CM_Vessel;
begin

	if CM_Vessel.hasInstance(theObject) then
		tmpVessel := theObject.CM_Vessel;
	else
		return;
	endif;
	
	if eventType = Object_Update_Event then
		if self.includeVessel(tmpVessel, app.myPassport) then
			self.tblData.updateItemObject(tmpVessel, self.colorRow1, self.colorRow2, app.myPassport);	
			self.displayExtraInfo();
		else
			self.tblData.removeItemObject(tmpVessel);
			if tmpVessel = self.myCurrentVessel then
				self.myCurrentVessel := null;
				self.displayExtraInfo();
			endif;		
		endif;
	
	elseif eventType = Object_Create_Event then
		if self.includeVessel(tmpVessel, app.myPassport) then
			self.tblData.updateItemObject(tmpVessel, self.colorRow1, self.colorRow2, app.myPassport);	
		endif;
		
	elseif eventType = Object_Delete_Event then
		self.tblData.removeDeletedObject(theObject);
		if theObject = self.myCurrentVessel then
			self.myCurrentVessel := null;
			self.displayExtraInfo();
		endif;
	endif;

	self.statusLine.caption := (self.tblData.rows-self.tblData.fixedRows).String &amp; ' rows found.';
		
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeVessel" id="2113257a-b71e-4f9d-b202-72aa63d977b8">
        <source>includeVessel(_vessel : CM_Vessel; _passport : CM_Passport) : Boolean;
//--------------------------------------------------
// Created:	18 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	validDate : Boolean;
	failedDAC  :CM_DataAccessController;
	invalidVessel : Boolean;
begin

	on Exception do app.handleDeletedObject(exception, _vessel, invalidVessel); 

	if _vessel = null then
		return false;
	endif;

	if (not _vessel.canUserAccessSelf(null, failedDAC,_passport)) then
		return false;
	endif;
	
	if invalidVessel then
		return false;
	endif;

	if self.filterVessel &lt;&gt; null then
		// false is arrived after this date
		if _vessel.code &lt;&gt; self.filterVessel.code then
			return false;
		endif;	
	endif;

	if self.filterCode &lt;&gt; null then
		// return as dates not applicaable to code search
		if _vessel.code.startsWith(self.filterCode) then
			return true;
		else
			return false;
		endif;
	endif;			

	return true;

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="5bfbd667-5133-4c42-8342-08beed47bc81">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//--------------------------------------------------
// Created:	14 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	pos,
	startPos : Integer;
	splitterName : String;
	hideExtraInfo : Boolean;
begin
	if _userWindow = null then
		return;
	endif;
	inheritMethod(_userWindow);
	startPos := 1;
	pos := 1;
	splitterName := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; dkbDetails.name, startPos);

	if splitterName &lt;&gt; null then
		hideExtraInfo := splitterName.cnEcGetNextTagValueOfName(XMLTag_HideExtraInfo, pos).Boolean;
		if hideExtraInfo then
			self.mnuHideShowInfo.caption := app.getErrorString(Hide_Additional_Info);
		else
			self.mnuHideShowInfo.caption := app.getErrorString(Show_Additional_Info);		
		endif;
		self.mnuHideShowInfo.click(self.mnuHideShowInfo);					
	endif;
	
	self.frmSearchToolbar.showCaptions := self.frmToolbar.showCaptions;

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblData" id="8a9f29d0-07cc-4481-9a77-48ba15c4c84b">
        <source>initTblData();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
begin
	if app.myCurrentUserCan(self.myTerminal, Mod_Harbour) then
		self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_VesselEnquiry));	
	else
		self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_VesselEnquiryCargo));
	endif;

	self.tblData.setMyDataClass(CM_Vessel);
	self.tblData.userInputEnabled	:=	false;
	self.tblData.selectMode			:=	Table.SelectMode_CurrentRow;
	self.tblData.selectionType		:=	CM_DataTable.SelectionType_Row;
	self.tblData.multiSelect		:=	self.tblData.MultiSelect_Simple;
	self.tblData.stretchWidth		:=	true;
	self.tblData.stretchHeight		:= 	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="2b5cc486-24e9-41d7-a9e2-db1225fc41c5">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if keyCode = CMUI_Key_F3 then
		self.showHideSearcher();
	elseif keyCode = J_key_Enter then
		if self.frmSearch.visible then
			self.doSearch();
		endif;		
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
