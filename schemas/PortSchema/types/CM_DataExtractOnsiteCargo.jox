    <JadeMethod name="initDataExtractFields_Hazard" id="fc92bd53-c988-4332-bb85-9897a0785139">
        <source>initDataExtractFields_Hazard(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
26 May 2011 cnwdz2  PAR #27598 Reviewed.
*/

vars
	fieldName		: String;
	childField   : CM_DataExtractField; 
    colField     : CM_DataExtractCollectionField;
begin
	fieldName := CM_TrackedItem::allTIHazards.name;
	colField  := self.initDataExtractCollectionField(_fields, CM_TIHazard, fieldName, "Hazardous Details");
	
	fieldName := CM_TIHazard::getClassDesc.name;
	childField := self.initDataExtractField(null, CM_TIHazard.name, null, fieldName, STRING, "Hazardous Class", "Hazardous class", STRING, "No more than 9 characters and/or digits");	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
	fieldName := CM_TIHazard::undgCodes.name;
	childField := self.initDataExtractField(null, CM_TIHazard.name, null, fieldName, STRING, "UNDG Code", "United Nations Dangerous Goods (UNDG) identifier assigned to transportable hazardous goods within the United Nations", STRING, "Comma-separated UNDG codes with a maximum legth of 80");	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
	fieldName := CM_TIHazard::limitedQuantity.name;
	childField := self.initDataExtractField(null, CM_TIHazard.name, null, fieldName, BOOLEAN, "Limited Quantity", "Limited quantity", BOOLEAN, BOOLEAN_POSSIBLEVAL);	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
epilog

end;</source>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initDataExtractFields_Receive" id="fe9ba1a5-ace3-4210-8cb1-0a5dc1bc2ab6">
        <source>initDataExtractFields_Receive(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
25 May 2011 cnwdw1 Reveiwed
26 May 2011	cnwsh3 Reviewed
*/

vars
	fieldName		: String;
	
begin
	fieldName := "receivedDT";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "receivedDT", fieldName, TIMESTAMP, "Received Date/Time", "Date Time the cargo item was received", TIMESTAMP, TIMESTAMP_POSSIBLEVAL);

	fieldName := "inputDT";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "inputDT", fieldName, TIMESTAMP, "Input Date/Time", "The Date/Time the cargo was entered into JMT", TIMESTAMP, TIMESTAMP_POSSIBLEVAL);

	fieldName := "eirNumber";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "eirNumber", fieldName, STRING, "EIR Number", "Equipment Interchange report number", STRING, "Maximum 10 characters");

	fieldName := "freightForwarderCode";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "freightForwarderCode", fieldName, STRING, "Freight Forwarder", "The freight forwarder code", STRING, "Any valid freight fowarder code");

	fieldName := "jobRoadReceive";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "jobRoadReceive", fieldName, STRING, "Job Road Receive ID", "The job id the cargo was received on", STRING, "Maximum 30 characters");

	fieldName := "rakePosition";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "rakePosition", fieldName, STRING, "Rake Position/BAT NO", "Position on a rail rake the cargo was received using the wagon id as a reference", STRING, "Maximum 20 characters");

	fieldName := "jobRoadRelease";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "jobRoadRelease", fieldName, STRING, "Job Road Release ID", "The job id the cargo was released on", STRING, "Maximum 30 characters");

	fieldName := "deliveryReleaseReason";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "deliveryReleaseReason", fieldName, STRING, "Delivery Release Reason", "The reason for the delivery request", STRING, "One of the delivery request reason codes defined in System Admin");

	fieldName := "carrierRemarks";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "carrierRemarks", fieldName, STRING, "Carrier Remarks", "Text that relates to the carrier", STRING, "");

	//fieldName := "condition";
	//self.initDataExtractField(_fields, CM_TrackedItem.name, "condition", fieldName, STRING, "Condition", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

	fieldName := "hasRadio";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "hasRadio", fieldName, STRING, "Has Radio", "Flag to indicate a cargo has a radion", STRING, "Yes or No");

	fieldName := "cutoffTS";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "cutoffTS", fieldName, TIMESTAMP, "Cut-off Time", "Date the cargo needs to be received by to be able to be loaded onto voyage",TIMESTAMP, TIMESTAMP_POSSIBLEVAL);

	fieldName := "earliestRecTS";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "earliestRecTS", fieldName, TIMESTAMP, "Earliest Receival Time", "Earlist time this prenoted cargo will be accepted for receivial", TIMESTAMP, TIMESTAMP_POSSIBLEVAL);


epilog

end;</source>
