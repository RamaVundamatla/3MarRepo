    <JadeMethod name="create" id="b2e80b6f-763b-4948-a0eb-b54da7e93018">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646 Task 55668: UI - Contracts Rate Entries
03 Sep 2024	navnk30	Bug 65602: FR - 54089 - Invoice Contract - permissions

*/

vars

begin
	//self.permissionView := PmInvContractEnqView ;	//03.09.2024 navnk30 #65602
	self.permissionView := PmInvContractMaintView;	//03.09.2024 navnk30 #65602
	self.permissionMaint := PmInvContractMaintMaint; 
	
	self.helpFileName		:= HelpFile_Invoicing;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createContractRateEntry" id="1eda52c8-fb0e-452c-b1af-4aef7b9fef82">
        <updating/>
        <source>createContractRateEntry()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646 Task 55668: UI - Contracts Rate Entries
09 Mar 2023	navmk20		Bug 57006: 4013 error when trying to edit a rate

*/

vars
	pxyCon, realCon 		: CM_InvoiceContractRateEntry;
	terminal				: CM_Terminal;
	bank 					: CM_Bank;
	scheduleTSstart 		: TimeStamp;
	scheduleTSend 			: TimeStamp;
	theReturn : Integer;
	//fromAmount  : Integer;		//9.3.2023 navmk20 TFS - 57006
	fromAmount  : Decimal[14,2];	//9.3.2023 navmk20 TFS - 57006
	//toAmount : Integer64;			//9.3.2023 navmk20 TFS - 57006
	toAmount : Decimal[14,2];		//9.3.2023 navmk20 TFS - 57006
	rate : Decimal [23,4];
	contractrate : CM_InvoiceContractRate;
	proxyRate, realRate : CM_InvoiceContractRate;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	// If first time create contract rate for service
	if self.myInvContractRate = null then
		create proxyRate transient;
		proxyRate.setProxy(null, self.myService, self.myInvContractDetail, null); // ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1

	 // ### TFS BUG 56879 02MAR2023 NAVAB1 - added while loop
		while true do
			app.myTrxCA.trxCreateInvContractDtlRt(proxyRate, self.myInvContractRate, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				self.unloadForm();
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Invoic_contra_rate_entry_creat), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			return;
		endwhile;
	endif;
	
	if self.txtFrom &lt;&gt; null then
		//fromAmount := self.txtFrom.text.Integer;	//9.3.2023 navmk20 TFS - 57006
		fromAmount	:= self.txtFrom.text.Decimal;	//9.3.2023 navmk20 TFS - 57006
	endif;
	if self.txtTo &lt;&gt; null then
		//toAmount := self.txtTo.text.Integer64;	//9.3.2023 navmk20 TFS - 57006
		toAmount :=	self.txtTo.text.Decimal;		//9.3.2023 navmk20 TFS - 57006
	endif;
	if self.txtRate &lt;&gt; null then
		rate := self.txtRate.text.Decimal;
	endif;
	bank := self.myCurrentBank;
	scheduleTSstart.setDate(self.mskContractFromStart.text.asDateJMT());
	scheduleTSstart.setTime(self.mskContractFromStartTime.text.asTimeJMT());
	scheduleTSend.setDate(self.mskContractFromEnd.text.asDateJMT());
	scheduleTSend.setTime(self.mskContractFromEndTime.text.asTimeJMT());

	create pxyCon transient;
	pxyCon.setProxy(0,rate,fromAmount,toAmount,self.localToSystemTime(scheduleTSstart),self.localToSystemTime(scheduleTSend),self.myInvContractRate,bank); // ### BUG 58796 26JUN2023 NAVAB1 'localToSystemTime'
	
	while true do
		app.myTrxCA.trxCreateInvContractDtlRtEntry(pxyCon, realCon, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoic_contra_rate_entry_creat), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;

epilog
	self.mousePointer := Window.MousePointer_Default;
	delete pxyCon;
	delete proxyRate;
end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="357a69f4-da50-41e8-b890-8c0bdd5e7f94">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
Purpose:			

Date		Who		Reason
// ### TFS BUG 59918 20SEP2023 NAVAB1
*/

vars
	theXML : String;
begin

	theXML := inheritMethod();
	theXML := theXML &amp; global.formatAsXML("MAXRANGE",self.chkMaximum.value.Integer.String);
	return theXML;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="c76aee56-1d6a-4aa8-a12b-0c1dc337230c">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
/*
Purpose:			

Date		Who		Reason
// ### TFS BUG 59918 20SEP2023 NAVAB1
*/

vars

	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	showParams : Boolean;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	
	theXML := userWindow.xmlInfo;
	
	
 	theXMLValue := theXML.cnEcGetTagValueOfName("MAXRANGE");
 	showParams := false;
 	if theXMLValue &lt;&gt; null then
 		showParams := theXMLValue.Integer.Boolean;
 	endif;
 	
	self.chkMaximum.value := showParams;
	self.chkMaximum_click(self.chkMaximum);
end;</source>
    </JadeMethod>
    <JadeMethod name="populateRateEntry" id="178d4c2c-a9b0-49a8-b971-56771f1d56d6">
        <source>populateRateEntry();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646 Task 55668: UI - Contracts Rate Entries
09 Mar 2023	navmk20		Bug 57006: 4013 error when trying to edit a rate
*/

vars
	localTS : TimeStamp;
begin
	//self.txtFrom.text		:= self.myInvContractRateEntry.fromAmount.Integer.String;								//9.3.2023 navmk20 TFS - 57006
	self.txtFrom.text		:= self.myInvContractRateEntry.fromAmount.String;								//9.3.2023 navmk20 TFS - 57006
	self.txtTo.text 	:= self.myInvContractRateEntry.toAmount.String;										//9.3.2023 navmk20 TFS - 57006
	self.txtRate.text 	:= self.myInvContractRateEntry.costPerUnit.String;
	
	// ### TFS BUG 58796 26JUN2023 NAVAB1 start
	localTS := self.systemToLocalTime(self.myInvContractRateEntry.fromTS);
	self.mskContractFromStart.setDate(localTS.date);
	self.mskContractFromStartTime.setTime(localTS.time);
	localTS := self.systemToLocalTime(self.myInvContractRateEntry.toTS);
	self.mskContractFromEnd.setDate(localTS.date);
	self.mskContractFromEndTime.setTime(localTS.time);
	// ### TFS BUG 58796 26JUN2023 NAVAB1 end

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromToLabels" id="f2e44370-c054-479f-af57-0a46f648cc0e">
        <source>setFromToLabels();
/*
Purpose:			

Date		Who		Reason
// ### TFS BUG 57505 14APR2023 NAVAB1
*/

vars

begin
	
	if self.myInvContractDetail &lt;&gt; null then
		if self.myInvContractDetail.contractType = INV_CONTRACT_TYPE_VOLUME_BASED then
			if self.myInvContractDetail.myUnitOfMeasure &lt;&gt; null then
				if self.myInvContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_Weight then
					self.lblFrom.caption := app.getErrorString(Weight_from);
					self.lblTo.caption := app.getErrorString(WeightKGTo);
				elseif self.myInvContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_Volume then
					self.lblFrom.caption := app.getErrorString(Volume_from);
					self.lblTo.caption := app.getErrorString(VolumeM3To);
				elseif self.myInvContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_Quantity then
					self.lblFrom.caption := app.getErrorString(Quantity_from);
					self.lblTo.caption :=app.getErrorString(QuantityToTo);
				elseif self.myInvContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_TEU then
					self.lblFrom.caption := app.getErrorString(TEUFrom);
					self.lblTo.caption := app.getErrorString(TEUTo);
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
