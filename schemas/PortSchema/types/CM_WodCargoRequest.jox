    <JadeMethod name="getCurrentLocation" id="decf56b7-4b97-47ed-b8af-342357e34092">
        <source>getCurrentLocation(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2018	jlgndl1	Initial creation	TFS 41272

*/

vars

	berth : HMS_Berth;
	movement : HMS_VoyageMovement;

begin

	//11 Oct 2018	NDL	TFS 41272  Change of rules, use the parent wodtl 
	if self.myVoyageCargoRequest &lt;&gt; null then
		return self.myVoyageCargoRequest.getCurrentLocation();
	elseif self.myPermitRequest &lt;&gt; null then
		return self.myPermitRequest.getCurrentLocation();
	endif;

	movement := self.getMyParent.getMyHMSVoyageMovement();
	
	if movement &lt;&gt; null then
		berth := movement.getMyBerth;
		if berth &lt;&gt; null then
			return berth.description;
		endif;
	endif;

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDestinationLocation" id="e52ee76c-26a3-424d-8713-de28a4009971">
        <source>getDestinationLocation(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2018	jlgndl1	Initial creation	TFS 41272

*/

vars

	berth : HMS_Berth;
	movement : HMS_VoyageMovement;
	nextMovement : HMS_VoyageMovement;

begin

	//11 Oct 2018	NDL	TFS 41272  Change of rules, use the parent wodtl 
	if self.myVoyageCargoRequest &lt;&gt; null then
		return self.myVoyageCargoRequest.getDestinationLocation();
	elseif self.myPermitRequest &lt;&gt; null then
		return self.myPermitRequest.getDestinationLocation();
	endif;

	movement := self.getMyParent.getMyHMSVoyageMovement();
	
	if movement &lt;&gt; null then
		nextMovement := movement.myNextMovement.HMS_VoyageMovement;
		if nextMovement &lt;&gt; null then
			berth := nextMovement.getMyBerth;
			if berth &lt;&gt; null then
				return berth.description;
			endif;
		endif;
	endif;

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="018ef28f-3331-497c-8d0e-c09557b2c4c6">
        <source>getDisplayString(_useShortDesc: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object
//
vars
	displayString : String;
	taskIdString : String;
begin
	if _useShortDesc then
		if self.myVoyageCargoRequest &lt;&gt; null then	//16 Jul 2018	NDL	TFS 39742
			displayString := app.getErrorString(VOYWO_Cargo_request);
		else
			// TFS 42221 19DEC18
			if self.myPermitRequest &lt;&gt; null then
				if self.myPermitRequest.permitType = INV_WO_PERMIT_CONTINUEPENALTY then
					displayString := app.getErrorString(STR_WO_PERMIT_CONPEN);
				elseif self.myPermitRequest.permitType = INV_WO_PERMIT_CONTINUNOPENALTY then
					displayString := app.getErrorString(STR_WO_PERMIT_CONNOPEN);
				else
					displayString := app.getErrorString(Additional_cargo_request);
				
				endif;
			else
				displayString := app.getErrorString(Additional_cargo_request);
			endif;
		endif;
		
		return displayString;
	else
		if self.taskID &lt;&gt; null then
			taskIdString:="(" &amp; self.taskID.String &amp; ") ";
		endif;
		if self.myVoyageCargoRequest &lt;&gt; null then		//16 Jul 2018	NDL	TFS 39742
			displayString := taskIdString &amp; app.getErrorString(VOYWO_Cargo_request);
		else
			if self.myPermitRequest &lt;&gt; null
			and self.myPermitRequest.isWorkOrderPermitContCargoPen() then
				displayString := taskIdString &amp; app.getErrorString(Continue);
			
			else
				displayString := taskIdString &amp; app.getErrorString(Additional_cargo_request);
			endif;
		endif;
	endif;
	
	//16 Jul 2018	NDL	TFS 39742
	if self.myCargoType &lt;&gt; null and self.myCargoType.abbreviation &lt;&gt; null then
		displayString := displayString &amp; " " &amp; self.myCargoType.abbreviation;
	endif;
	
	//16 Jul 2018	NDL	TFS 39742
	if self.getMyWorkPoint &lt;&gt; null and self.getMyWorkPoint.code &lt;&gt; null then
		displayString := displayString &amp; " " &amp; self.getMyWorkPoint.code;
	endif;
	
	return displayString;
	
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDtlType" id="3345c806-ec3a-43ef-b418-5a4342872f8f">
        <source>getDtlType(): Integer;
//
// Purpose:			
