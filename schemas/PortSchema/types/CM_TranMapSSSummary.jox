    <JadeMethod name="setForCreate" id="121ffb26-9ed4-4911-8cb3-9b93b65f2588">
        <updating/>
        <source>setForCreate(_pxyTranMap : CM_TranMapSSSummary) updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars

begin
	_pxyTranMap.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.name := _pxyTranMap.name;
	self.description := _pxyTranMap.description;
	self.initialise(_pxyTranMap.myBank);
end;</source>
        <Parameter name="_pxyTranMap" type="CM_TranMapSSSummary"/>
    </JadeMethod>
