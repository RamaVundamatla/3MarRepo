    <JadeMethod name="tSOBLinking" id="c0ce2947-a7d5-47dc-b33e-e709cba655fa">
        <updating/>
        <source>tSOBLinking() updating;

/*

Purpose:		Run the Automated Stuff that can for SOB	

Date			Who		Reason
17/07/2013		cnwmh5	Initial creation

*/
constants

	VoyageID					: String = 'UTMDHLRSOB';
	ShipID						: String = 'MESGRIG';
	UserDefinedShipBayPlan		: String = 'Unit Test RORO Baplie MSL';
	
vars

	fileTypeUser 				: CM_EDIFileTypeUser;
	pxyFileTypeUser 			: CM_EDIFileTypeUser;
	voyage 						: CM_Voyage;
	ediFile 					: CM_EDIFile;
	ediControllerAgent 			: CM_EDIControllerAgent;
	realAlloc					: CM_VoyageAllocation;
	alloc20						: CM_VoyageAllocation;
	alloc40						: CM_VoyageAllocation;
	deck						: CM_DeckVoyage;
	location					: CM_ROROLocnDefn;
	
	clientRef 					: String;
	messageType 				: String;
	ediText 					: String;
	tempStr 					: String;
	binaryMsg 					: Binary;
	idx 						: Integer;

begin

	// initialise variables / dicts

	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipBayPlan).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipBayPlan &amp; ' is missing');

	// create the voyage
	self.deleteVoyage(VoyageID);
	voyage := self.addVoyageWithConRORO(VoyageID, ShipID, "MSL", "UTSL", "MSL East Africa", 0, false, true);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	
//  now add the ship manifest via EDI
	delete ediControllerAgent;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// setup the add ship manifest here
	ediText := self.xSetupROROSOBLinkingDetails(VoyageID);
	
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg 	:= ediText.Binary;
	messageType := UserDefinedShipBayPlan[1 : fileTypeUser.name.maxLength];  // ie 63
	idx 		:= idx + 1;
	clientRef 	:= method.name[1 : ediControllerAgent.ediClientRef.maxLength-1] &amp; idx.String;		// ie 30
	
	ediControllerAgent.setEdiClientRef(clientRef);
	
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipBayPlan, UserDefinedShipBayPlan&amp;method.name);		
	self.assertNotNull(ediFile);

	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);

	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// get the deck
	deck := voyage.myROROStructure.allDecksByCode["4"];
	self.assertNotNull(deck);
	
	// rotate cells load mode only
	location := deck.allROROLocnDefnByCode['D4103'];
	self.assertNotNull(location);
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 10, 2, true, app.myPassport, true);
	location := deck.allROROLocnDefnByCode['D4103R'];
	self.assertNotNull(location);
	
	// rotate cells load mode only
	location := deck.allROROLocnDefnByCode['D4103'];
	self.assertNotNull(location);
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 10, 2, true, app.myPassport, true);
	location := deck.allROROLocnDefnByCode['D4103R'];
	self.assertNotNull(location);
	
	// create the load OOTL cells
	self.xSetupLoadOOTLsGCs(voyage);
	
	// set load colour coding
	self.xSetupRORODischLoadCC(voyage);
	
	// setup lolo items on ship
	xSetupLOLOCargo(voyage);
	
	
epilog

	delete ediControllerAgent;
	delete pxyFileTypeUser;

end;</source>
    </JadeMethod>
    <JadeMethod name="xSetupLOLOCargo" id="e4a2cbe1-3620-48b4-88aa-01eab9ea2290">
        <source>xSetupLOLOCargo(_voyage : CM_Voyage io);

/*

Purpose:		Setup LOLO Onship Cargo

Date			Who		Reason
19/07/2013		cnwmh5	Initial creation

*/

vars

	port						: CM_Port;
	theSlot 					: CM_LocationsController;
	cargo 						: CM_TrackedItem;
	tmpLoadCC					: CMIF_LoadColorCode;
	
	strs 						: StringArray;
	slots 						: CM_SlotControllerArray;
	
	idx 						: Integer;
	str							: String;

begin

	port := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	create strs transient;
	create slots transient;
	create tmpLoadCC transient;

	app.myTrxUA.trxSetDfltDischargeColourCode(_voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	strs.clear();
	strs.add("250386");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00801", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	strs.clear();
	strs.add("250586");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00802", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	strs.clear();
	strs.add("250786");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00803", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	strs.clear();
	strs.add("250986");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00804", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	strs.clear();
	strs.add("250384");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00805", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	strs.clear();
	strs.add("250584");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00806", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	strs.clear();
	strs.add("250784");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00807", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	strs.clear();
	strs.add("250984");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00808", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	strs.clear();
	strs.add("250382");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00809", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	strs.clear();
	strs.add("250582");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00810", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	strs.clear();
	strs.add("250782");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00811", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	strs.clear();
	strs.add("250982");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMDHV00812", "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);

	// dicharge colour code and SOB
	self.getJobSlotControllers(_voyage.code, "25", DeckOnDeck, 7, 1, 3, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	//self.markSlotsAsDischargeCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_SOB);
	self.getJobSlotControllers(_voyage.code, "25", DeckOnDeck, 8, 1, 3, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	//self.markSlotsAsDischargeCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_SOB);
	self.getJobSlotControllers(_voyage.code, "25", DeckOnDeck, 9, 1, 3, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	//self.markSlotsAsDischargeCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_SOB);
	self.getJobSlotControllers(_voyage.code, "25", DeckOnDeck, 10, 1, 3, slots);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	//self.markSlotsAsDischargeCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_SOB);
	
epilog

	delete strs;
	delete slots;
	delete tmpLoadCC;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xSetupLoadOOTLsGCs" id="b501e727-eb07-4610-8bc5-1d625a72cdea">
        <source>xSetupLoadOOTLsGCs(_voyage : CM_Voyage io);

/*

Purpose:		Create load ootls.  Rotated / Non Rotated.			

Date			Who		Reason
18/07/2013		cnwmh5	Initial creation

*/

vars

	deck 						: CM_DeckVoyage;
	location					: CM_ROROLocnDefn;

begin

	deck := _voyage.myROROStructure.getDeckFromCode("2");
	self.assertNotNull(deck);
	
	// Create the OOTL cells for Load (20ft)
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, false, true, 3.5, -12.00, deck, app.myPassport);
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, false, true, 12.5, -12.00, deck, app.myPassport);
	
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, false, true, 41.5, 4.9, deck, app.myPassport);
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, false, true, 44.5, 4.9, deck, app.myPassport);
	
	
	// Rotate the cells
	location := deck.allROROLocnDefnByCode['D2361O'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, true, app.myPassport, true);
	
	location := deck.allROROLocnDefnByCode['D2362O'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, true, app.myPassport, true);
	
	
	// 40FT
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, true, true, -1.5, -7.30, deck, app.myPassport);
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, true, true, 12.5, -7.30, deck, app.myPassport);
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, true, true, 25.5, -7.30, deck, app.myPassport);
	
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, true, true, 48.50, 7.30, deck, app.myPassport);
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, true, true, 52.50, 7.30, deck, app.myPassport);
	app.myTrxCA.trxCreateROROOOTLLoadCC(null, true, true, 55.5, 7.30, deck, app.myPassport);
	
	location := deck.allROROLocnDefnByCode['D2370O'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, true, app.myPassport, true);
	
	location := deck.allROROLocnDefnByCode['D2372O'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, true, app.myPassport, true);
	
	location := deck.allROROLocnDefnByCode['D2374O'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, true, app.myPassport, true);
	
	app.myTrxCA.trxCreateROROGCLoadCC(null, 4, 67.2, -10.60, deck, app.myPassport);
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xSetupRORODischLoadCC" id="0237c398-5e25-4f9a-88f9-f3a5430833ab">
        <updating/>
        <source>xSetupRORODischLoadCC(_voyage : CM_Voyage io) updating;

/*

Purpose:		Setup the load colour coding	

Date			Who		Reason
18/07/2013		cnwmh5	Initial creation

*/

vars
	
	realAlloc 							: CM_VoyageAllocation;
	realAlloc20							: CM_VoyageAllocation;
	deck								: CM_DeckVoyage;
	
	roroLCs								: CM_LCArray;
	altRoroLCs							: CM_LCArray;
	
begin
	
	create roroLCs transient;
	create altRoroLCs transient;
	
	// deck 4
	deck := _voyage.myROROStructure.allDecksByCode["4"];
	self.assertNotNull(deck);
	
	// 53 Ft
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40421", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40422", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40423", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40424", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40411", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40412", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40413", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40414", roroLCs, true, 1); 
	self.opts.purge();
	self.opts.addAssoc("Is53Ft", true);
	self.opts.addAssoc("Colour", 8454143);
	realAlloc := self.addVoyageAllocation(_voyage, null, "53FT", null, TI_CargoType_Container, false, false);
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	
	// 45Ft
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40201", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40202", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40203", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40204", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40311", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40312", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40313", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40314", roroLCs, true, 1); 
	self.opts.purge();
	self.opts.addAssoc("Is45Ft", true);
	self.opts.addAssoc("Colour", 8421631);
	realAlloc := self.addVoyageAllocation(_voyage, null, "45BX", null, TI_CargoType_Container, false, false);
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	
	// 30Ft
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40301", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40302", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40303", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40304", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40191", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40192", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40193", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40194", roroLCs, true, 1); 
	self.opts.purge();
	self.opts.addAssoc("Is30Ft", true);
	self.opts.addAssoc("Colour", 8453888);
	realAlloc := self.addVoyageAllocation(_voyage, null, "30BX", null, TI_CargoType_Container, false, false);
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	
	// 20Ft Discharge
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41261R", roroLCs, false, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41262R", roroLCs, false, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41263R", roroLCs, false, 1); 
	self.opts.purge();
	self.opts.addAssoc("Colour", 16777088);
	realAlloc20 := self.addVoyageAllocation(_voyage, null, "GEN2", null, TI_CargoType_Container, false, false);
	self.assertNotNull(realAlloc20);
	self.addLCsToROROAllocation(false, realAlloc20, roroLCs, altRoroLCs,1);
	
	
	// 40Ft Discharge 
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41281R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41282R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41271R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41272R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41273R", roroLCs, true, 1); 
	self.opts.purge();
	self.opts.addAssoc("Is40Ft", true);
	self.opts.addAssoc("Colour", 8454016);
	realAlloc := self.addVoyageAllocation(_voyage, null, "40BX", null, TI_CargoType_Container, false, false);
	self.assertNotNull(realAlloc);
	self.addLCsToROROAllocation(false, realAlloc, roroLCs, altRoroLCs,1);
	
	// 20Ft Load
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41031R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41032R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41033R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40981R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40982R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40983R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D40991R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41041R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41001R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41051R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41261R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41262R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41263R", roroLCs, true, 1);
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41271R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41321R", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41151", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41152", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41153", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41101", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41102", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41103", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41161", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41162", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41163", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41111", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41112", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, deck.code, null, "D41113", roroLCs, true, 1); 
