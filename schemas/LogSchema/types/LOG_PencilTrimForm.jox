end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="6ba09905-fd58-4775-9e16-1b1c315f983a">
        <updating/>
        <source>doUpdate()updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	logRegrade	: CMIF_LogRegrade;
	isMove		: Boolean;
	theProduct	: CM_Product;
	sohLocn		: CM_SOHLocation;
	loadStateSet : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if self.myCurrentSOHLocation = null or
	   self.myCurrentLogVoyage = null then
		return;
	endif;
	// Sep 2011 28082 don't allow save for closed etc voyages
	if self.myCurrentLogVoyage.isClosedStatus() then
		app.msgBox("This voyage status is " &amp; self.myCurrentLogVoyage.statusDescription &amp; "," &amp; CrLf &amp; "no updates are allowed.", "Error", 0);
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	sharedLock(self.myCurrentSOHLocation);
	theProduct := self.myCurrentSOHLocation.myProduct;
	
	create logRegrade transient;
	app.cmsBeginLoad(loadStateSet);	
	if self.mode = Mode_Summary then
		foreach sohLocn in self.allSOHLocationsLoadedForLot do
			sharedLock(sohLocn);
			if sohLocn.myProduct = theProduct then
				self.setCMIF_LogRegrade(logRegrade, sohLocn);
				app.myTrxUA.trxRegradeLog(logRegrade, app.getMyUserCode, self.myCurrentSOHLocation.myLocationsController, 
										isMove, app.myPassport);
				if (not app.myPassport.trxCompletedOK) then
					app.showErrorWarningDialog('Pencil Trim', app.myPassport, ErrWarnMode_Update);
					self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
					break;
				else
					self.clearErrorWarnings();
				endif;
			endif;
		endforeach;
	else
		self.setCMIF_LogRegrade(logRegrade, self.myCurrentSOHLocation);
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxRegradeLog(logRegrade, app.getMyUserCode, self.myCurrentSOHLocation.myLocationsController, isMove, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Pencil Trim', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
	endif;
	
	self.getAllLoadedSOHLocns();
epilog
	if logRegrade &lt;&gt; null then
		delete logRegrade;
	endif;
	app.cmsEndLoad(loadStateSet);	
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doVoyageSelect" id="6e5b18c0-272d-4006-ad9f-3d441686e344">
        <updating/>
        <source>doVoyageSelect() updating;
//----------------------------------------------------------------
//	Created:	23 March 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	logAss : LOG_Assistant;
begin

	self.myCurrentLogVoyage := self.cmbVoyage.listObject.CM_Voyage;//self.myAssistant.getVoyageFromCombo(combobox.text).CM_LogVoyage;
	logAss := self.myAssistant.LOG_Assistant;
	logAss.comboBoxLogVoyageLots(cmbLot, self.myCurrentLogVoyage, null);
//	cmbLot.setFocus();		PAR 9800
	self.tblDetails.rows := self.tblDetails.fixedRows;
	self.setNavigatorHeading(self.myCurrentLogVoyage.code);

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllLoadedSOHLocns" id="c402f50f-e320-401f-a7a1-6eff1db5e6df">
        <updating/>
        <source>getAllLoadedSOHLocns()updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	fixedRows	: Integer;

begin

	fixedRows := self.tblDetails.fixedRows;
	self.tblDetails.rows := fixedRows;
	self.allSOHLocationsLoadedForLot.clear();
	self.myCurrentLogVoyage.myLogVoyageStructure.getAllLoadedSOHLocnsForLot(self.allSOHLocationsLoadedForLot, self.myCurrentLogLot);
	if self.mode = Mode_Detail then
		self.showSOHLocationsAssigned();
	else
		self.showSummaries();  //Default mode
	endif;

	if self.tblDetails.rows &gt; fixedRows then
		self.tblDetails.row := fixedRows + 1;
	endif;

	self.setMyCurrentSOHLocation();

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="9614de56-1cf4-4297-9658-a5c7fd20fc94">
        <updating/>
        <source>initForm() updating;
//--------------------------------------------------------------
//Created: September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableDef : EntTableDef;
begin

	self.tblDetails.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
	entTableDef := app.myController.getEntTableDef(ETDef_PencilTrimming);
	tblDetails.readOnly := false;
	tblDetails.userInputEnabled := true;
	tblDetails.selectMode := Table.SelectMode_CurrentRow;
	tblDetails.selectionType := CM_BaseTable.SelectionType_Row;
	tblDetails.autoSize := Table.AutoSize_Column;
	tblDetails.rows := tblDetails.fixedRows;
	tblDetails.setTblDataEntRowsFromDef(entTableDef);
//	tblDetails.tabKey := J_key_Tab;
	tblDetails.alignment := Table.Alignment_Left_Middle;
	tblDetails.accessColumn(tblDetails.getColumnByRowName(ETRow_NumTIs)).alignment := Table.Alignment_Right_Middle;
	tblDetails.accessColumn(tblDetails.getColumnByRowName(ETRow_CurrentVolume)).alignment := Table.Alignment_Right_Middle;
	tblDetails.accessColumn(tblDetails.getColumnByRowName(ETRow_Hatch)).alignment := Table.Alignment_Center_Middle;
		
	self.myAssistant.comboBoxVoyageCode(self.cmbVoyage, null, false, true);
	
	self.tblNewSpecs.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
	tblNewSpecs.warningMethod := 'entTableWarning';
	entTableDef := app.myController.getEntTableDef(ETDef_PencilTrimNewSpecs);	
	tblNewSpecs.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	tblNewSpecs.cnEcResizeContents();
	
	
	// sgp 30 May 2003 : moved to loadDataForFirstTime
//	self.loadRegradeReasons();

	self.resize();
		
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="abf886de-087c-4b29-be16-33a8ab3032ce">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars	
	str : String;
	theTable : CM_DataTable;
	theActiveControl : Control;
	theSheet : JadeTableSheet;
begin

	if keyCode = J_key_Tab then
		tblNewSpecs.handleFormTab(keyCode, shift, tblDetails, btnSaveBase);
		theActiveControl := app.activeControl;
		if theActiveControl.parent.isKindOf(CM_EntryTable) then
			theActiveControl := theActiveControl.parent.Control;
		endif;
		if theActiveControl.isKindOf(CM_EntryTable) then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
	endif;

	inheritMethod(keyCode, shift);
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
