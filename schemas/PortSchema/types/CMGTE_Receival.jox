    <JadeMethod name="getAllSeals" id="40a48b4a-0915-4039-916a-22b7e339b3d9">
        <source>getAllSeals() : String;
// ---------------------------------------------------------------------------
// Created:     13 October 2008 by concms1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	invalidObject : Boolean;
	sealTI : CM_SealTI;
	sealValue : String;
	tmpStr : String;
	
begin
	
	//return null;
	
	
	// 22 Sep 2010	NDL	Par 25608
	on Exception do app.handleDeletedObject( exception, sealTI, invalidObject ); 
	foreach sealTI in self.allSeals do
		invalidObject := false;
		sealValue :=  sealTI.getSealValueAsString.trimBlanks;
		if invalidObject then
			continue;
		endif;
		if sealValue &lt;&gt; null then
			if tmpStr = null then
				tmpStr := sealValue;
			else
				tmpStr := tmpStr &amp; ", " &amp; sealValue;
			endif;
		endif;
	endforeach;
	
	return tmpStr;
	
epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
