/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	roroStructure 	: CM_Object;
	firstDeck		: CM_Deck;
begin

	roroStructure :=combobox.listObject.CM_Object;

	if roroStructure.isKindOf(CM_VesselStructuralElements) then //cnwrd1 32669
		roroStructure := roroStructure.CM_VesselStructuralElements.myVessel.myROROVesselStructure;
	endif;
	
	if roroStructure.isKindOf(CM_ROROVesselStructure) then
		firstDeck:=roroStructure.CM_ROROVesselStructure.allDecks.first;
	elseif roroStructure.isKindOf(CM_ROROVoyageStructure) then
		firstDeck:=roroStructure.CM_ROROVoyageStructure.allDecks.first;
	endif;
	
	
	self.doChangeROROStructure(roroStructure, firstDeck);
epilog

end;</source>
