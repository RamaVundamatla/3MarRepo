    <JadeMethod name="getTrackedItem" id="c1ca2abd-1bbe-45f9-95f7-81559e7feda3">
        <source>getTrackedItem() : CM_TrackedItem;

// Created by cnwdvb1 on 14 August 2006
// Changed On	By			Reason
// ----------	--------	-----------------------------------------
// 07/12/2010	cnwdap1		PAR #26478 Don't return a TBA TI for a ship/rail release request
vars

begin

	if self.myWorkListEntry &lt;&gt; null then
		// PAR #26478 if yard (rail) or voyage (ship) WLE, don't return the tracked item if it's a TBA
		// These TBAs are release request "dummy" TIs, not real TIs
		if (CM_YardWLE.hasInstance(self.myWorkListEntry) or CM_VoyageWLE.hasInstance(self.myWorkListEntry))
		and self.myWorkListEntry.myTrackedItem &lt;&gt; null and self.myWorkListEntry.myTrackedItem.isTBAorIsRRP then
			return null;
		else
			return self.myWorkListEntry.myTrackedItem;
		endif;
	endif;

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTwinCarryFlag" id="e6ebf255-ab3a-4245-a259-182048a620f2">
        <source>getTwinCarryFlag(): Integer;
/*

Purpose:		To determine if the queue entry can be twin carried
				
				Needs to determine two flags:
					- whether it can twin lift with the next entry in the queue i.e. will flag as A
					- whether it can twin lift with the previous entry in the queue i.e. will flag as B
					
				It can twin lift if the prev/next pick up task are next to each other other and the source tasks
				are next to each other.

Parameters:			

Return Value:		


Date		Who		Reason
04 Dec 2008	cnwer1	Initial creation
25 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Allow for Director tasks as well, which are twinnable if the Director task source/location
					are twinnable
24 Jul 2009	cnwkpd1	PAR #20323 - Prevent 1308 exceptions iterating through the RT Queue Array
30 Oct 2009 cnwer1	PAR 20701 - CCMS 1063 - handle twin carry for IMVs - check move tasks 
29 Jun 2010	cnwkpd1	PAR #23525 - Performance changes - no need to startAtObject twice
20 Jun 2012 cnwer1 	PAR #29849 - Can not twin carry director tasks with no ti and request is for 40ft containers
16 Mar 2016	cnwkpd1	TFS 1680 - Lock on CM_RadioTelemetryQueue::allEntries left behind if receiver is being 
					deleted by another process at the time this method is executing
11 Jul 2025	navbs1	Bug MTN-35345: MTN - Avoid Running Twin Lift Flag Logic for Non Container Cargo Items


*/

vars
	iter : Iterator;
	priorQEntry,
	nextQEntry : CM_RTQueueEntry;
	currentPickupTask,
	currentSetdownTask,
	priorPickupTask,
	priorSetdownTask,
	nextPickupTask,
	nextSetdownTask : CM_RTQueueTask;
	canTLB,
	canTLA    : Boolean;
	firstTI : CM_TrackedItem;
	currentSourceLC,
	currentTargetLC,
	priorSourceLC,
	priorTargetLC,
	nextSourceLC,
	nextTargetLC : CM_LocationsController;
	result	: Integer;
	reasonString : String;
	twinADirection,
	twinBDirection : Integer;
	lockedArray : CM_RTQueueEntryArray;
	isForIMV	: Boolean;
	
	currentMachineType : Integer;	//09 Jun 2011	NDL	Par 27437
	priorMachineType : Integer;	//09 Jun 2011	NDL	Par 27437
	nextMachineType : Integer;	//09 Jun 2011	NDL	Par 27437
	invalidPriorQEntry : Boolean;	//06 Nov 2013	NDL	Par 32518
	invalidNextQEntry : Boolean;	//06 Nov 2013	NDL	Par 32518
	
	currentTi : CM_TrackedItem;
	currentTiInvalid : Boolean;
	invalidNextTask : Boolean;
	request : CM_Request;
	currentTargetLCInvalid : Boolean; //25 Feb 2014	NDL	Par 33490
	
begin
	currentPickupTask := self.getDirectorOrPickupTask();
	currentSetdownTask := self.getDirectorOrSetDownTask();
		
	if currentPickupTask = null or currentSetdownTask = null then
		return self.TWIN_NONE;
	endif;
	
	currentTi := currentPickupTask.ti;									//11.07.2025 navbs1 #35345
	if currentTi &lt;&gt; null and not currentTi.isTwinLiftCapable then 		//11.07.2025 navbs1 #35345
		return self.TWIN_NONE;
	endif;
	
	/* if the task is a move task it must be for an IMV in this case we can do some special checking on the assumption of the machine type
		every other time the machine could be any type so we never do this check
		imvs can only twin carry if 
				- the target is to the ship
				- the tasks should be in the same job which is declared as twin lift
		
	*/
	
	isForIMV:=self.machineTypeGroup = MACHINETYPEGRP_IMV;// currentPickupTask.taskType = TASK_MOVE;
	
	//29849 20/6/12 its a director task without an ti then check release iso type grp 
	if currentPickupTask.taskType = TASK_DIRECTOR and currentPickupTask.ti = null then
		request:=self.myWorkListEntry.myRequest;
		if  request &lt;&gt; null then
			if not  request.isValidForTwinLift then
				return self.TWIN_NONE;
			endif;
		endif;
	endif;
	
	currentSourceLC := currentPickupTask.getSourceLocation;
	currentTargetLC := currentSetdownTask.targetLocation;
	
	//09 Jun 2011	NDL	Par 27437
	currentMachineType := self.machineTypeGroup;	
	priorMachineType := -1;	//because 0 means straddle
	nextMachineType := -1;	//because 0 means straddle
	
	// PAR #20323 - need to hold a shared lock on the array while we iterate, to 
	// prevent 1308 exceptions
	lockedArray := self.myQueue.allEntries;			// KPD TFS 1680 - reversed order to ensure lockedArray is set
	sharedLock(lockedArray);
		
	iter := lockedArray.createIterator;
	iter.startAtObject(self);
	iter.back(priorQEntry);
	iter.back(priorQEntry);
//	iter.startAtObject(self);			// PAR #23525
	iter.next(nextQEntry); // we have our self
	iter.next(nextQEntry);
	
	// PAR #20323 - now unlock the array
	unlock(lockedArray);
	lockedArray := null;
	
	on Exception do app.handleDeletedObject(exception, priorQEntry, invalidPriorQEntry);	//06 Nov 2013	NDL	Par 32518
	on Exception do app.handleDeletedObject(exception, priorPickupTask, invalidPriorQEntry);	//06 Nov 2013	NDL	Par 32518
	on Exception do app.handleDeletedObject(exception, priorSetdownTask, invalidPriorQEntry);	//06 Nov 2013	NDL	Par 32518
	
	if priorQEntry &lt;&gt; null then
		priorPickupTask:=priorQEntry.getDirectorOrPickupTask();
		priorSetdownTask:=priorQEntry.getDirectorOrSetDownTask();
		priorMachineType := priorQEntry.machineTypeGroup;	//09 Jun 2011	NDL	Par 27437
		if priorPickupTask &lt;&gt; null and priorSetdownTask &lt;&gt; null then
			priorSourceLC:=priorPickupTask.getSourceLocation;
			priorTargetLC:=priorSetdownTask.targetLocation;
		endif;
	endif;
	
	//06 Nov 2013	NDL	Par 32518
	if invalidPriorQEntry then
		priorSourceLC:=null;
		priorTargetLC:=null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, nextQEntry, invalidNextQEntry);	//06 Nov 2013	NDL	Par 32518
	on Exception do app.handleDeletedObject(exception, nextPickupTask, invalidNextQEntry);	//06 Nov 2013	NDL	Par 32518
	on Exception do app.handleDeletedObject(exception, nextSetdownTask, invalidNextQEntry);	//06 Nov 2013	NDL	Par 32518
	
	if nextQEntry &lt;&gt; null then
		nextPickupTask:=nextQEntry.getDirectorOrPickupTask();
		nextSetdownTask:=nextQEntry.getDirectorOrSetDownTask();
		nextMachineType := nextQEntry.machineTypeGroup;	//09 Jun 2011	NDL	Par 27437
		if nextPickupTask &lt;&gt; null and nextSetdownTask &lt;&gt; null then
			nextSourceLC:=nextPickupTask.getSourceLocation;
			nextTargetLC:=nextSetdownTask.targetLocation;
		endif;
	endif;
	
	//06 Nov 2013	NDL	Par 32518
	if invalidNextQEntry then
		nextSourceLC:=null;
		nextTargetLC:=null;
	endif;
	
	
	firstTI:=null;
	if priorPickupTask &lt;&gt; null then
		firstTI:=priorPickupTask.ti;
	endif;
	
	if currentSourceLC &lt;&gt; null then
	
		if isForIMV then //epr par 20701 if it is for an imv only check the target location
			twinADirection := TWIN_BOTH;
		else
			currentTi := currentPickupTask.ti;	//21 May 2012	NDL	Par 29595
			if currentTi &lt;&gt; null then	//21 May 2012	NDL	Par 29595
				on Exception do app.handleDeletedObject(exception, currentTi, currentTiInvalid);
			endif;
			currentSourceLC.canTwinLiftWithLocation( priorSourceLC, currentTi, firstTI, REAL_MODE, twinADirection, reasonString );
			if currentTiInvalid then	//21 May 2012	NDL	Par 29595
				result:=self.TWIN_NONE;
				return result;
			endif;
		endif;
	endif;

	
	if currentTargetLC &lt;&gt; null then
		currentTi := currentSetdownTask.ti;	//21 May 2012	NDL	Par 29595
		if currentTi &lt;&gt; null then	//21 May 2012	NDL	Par 29595
			on Exception do app.handleDeletedObject(exception, currentTi, currentTiInvalid);
		endif;
		on Exception do app.handleDeletedObject(exception, currentTargetLC, currentTargetLCInvalid);	 //25 Feb 2014	NDL	Par 33490
		currentTargetLC.canTwinLiftWithLocation( priorTargetLC, currentTi, firstTI, QUEUE_MODE, twinBDirection, reasonString );
		if currentTiInvalid or currentTargetLCInvalid then	//21 May 2012	NDL	Par 29595
			result:=self.TWIN_NONE;
			return result;
		endif;
	else
		twinBDirection:=TWIN_BOTH;
	endif;
	
	if twinADirection = TWIN_PREV then
		canTLB:=(twinBDirection = TWIN_PREV) or (twinBDirection =  TWIN_BOTH);
	elseif twinADirection  = TWIN_NEXT then
		canTLB:=(twinBDirection = TWIN_NEXT) or (twinBDirection =  TWIN_BOTH);
	elseif twinADirection  = TWIN_BOTH then
		canTLB:=(twinBDirection =  TWIN_BOTH) or (twinBDirection = TWIN_NEXT) or (twinBDirection =  TWIN_PREV);
	endif;
	
	
	firstTI:=null;
	if nextPickupTask &lt;&gt; null then
		firstTI:=nextPickupTask.ti;
	endif;
	if currentSourceLC &lt;&gt; null then
		if isForIMV then //epr par 20701 if it is for an imv only check the target location
			twinADirection := TWIN_BOTH;
		else
			currentSourceLC.canTwinLiftWithLocation(nextSourceLC,currentPickupTask.ti,firstTI ,  REAL_MODE,twinADirection,reasonString);
		
		endif;
	endif;
	

	
	if currentTargetLC &lt;&gt; null then
		currentTargetLC.canTwinLiftWithLocation(nextTargetLC,currentSetdownTask.ti, firstTI , QUEUE_MODE,twinBDirection,reasonString);
	else
		twinBDirection:=TWIN_BOTH;
	endif;
	

	if twinADirection = TWIN_PREV then
		canTLA:=(twinBDirection = TWIN_PREV) or (twinBDirection =  TWIN_BOTH);
	elseif twinADirection  = TWIN_NEXT then
		canTLA:=(twinBDirection = TWIN_NEXT) or (twinBDirection =  TWIN_BOTH);
	elseif twinADirection  = TWIN_BOTH then
		canTLA:=(twinBDirection =  TWIN_BOTH) or (twinBDirection = TWIN_NEXT) or (twinBDirection =  TWIN_PREV);
	endif;

	result:=self.TWIN_NONE;
	if canTLA and not canTLB then
		result:=self.TWIN_NEXT;
	elseif canTLB and not canTLA then
		result:=self.TWIN_PREV;
	elseif canTLA and canTLB then
		result:=self.TWIN_BOTH;
	else
		result:=self.TWIN_NONE;
	endif;

	//09 Jun 2011	NDL	Par 27437 - don't allow twinlift when machines are of different type.
	if currentMachineType &lt;&gt; nextMachineType then
		if result = TWIN_NEXT then
			result := TWIN_NONE;
		elseif result  = TWIN_BOTH then
			result := TWIN_PREV;
		endif;
	endif; 
	if currentMachineType &lt;&gt; priorMachineType then
		if result = TWIN_PREV then
			result := TWIN_NONE;
		elseif result  = TWIN_BOTH then
			result := TWIN_NEXT;
		endif;
	endif; 
	
	//29849 20/6/12 its a director task without an ti then check release iso type grp 
	if result = TWIN_PREV or result =  TWIN_BOTH then
		if priorPickupTask.taskType = TASK_DIRECTOR and priorPickupTask.ti = null then
			request:=priorQEntry.myWorkListEntry.myRequest;
			if  request &lt;&gt; null then
				if not  request.isValidForTwinLift then
					if result = TWIN_BOTH then
						result:= TWIN_NEXT;
					else
						result := TWIN_NONE;
					endif;
				endif;
			endif;	
		endif;
	endif;
	
	on Exception do app.handleDeletedObject(exception, nextPickupTask, invalidNextTask);
	
	//29849 20/6/12 its a director task without an ti then check release iso type grp 
	if result = TWIN_NEXT or result =  TWIN_BOTH then
		if nextPickupTask.taskType = TASK_DIRECTOR and nextPickupTask.ti = null then
			request:=nextQEntry.myWorkListEntry.myRequest;
			if  request &lt;&gt; null then
				if not  request.isValidForTwinLift then
					if result = TWIN_BOTH then
						result:= TWIN_PREV;
					else
						result := TWIN_NONE;
					endif;
				endif;
			endif;	
		endif;
	endif;
	

	return result;
	
	
epilog
	delete iter;
	if lockedArray &lt;&gt; null then
		unlock(lockedArray);
	endif;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTwinCarryFlayDisplay" id="659941a6-2c3d-4306-8c9c-beaef2ddc455">
        <source>getTwinCarryFlayDisplay() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation 52595

*/

vars
	twinFlag : Integer;
begin
	twinFlag:=self.getTwinCarryFlag;
	if twinFlag = CM_RTQueueEntry.TWIN_NEXT then
		 return TWIN_NEXT_STR;
	elseif  twinFlag = CM_RTQueueEntry.TWIN_PREV then
		 return TWIN_PREV_STR;
	elseif  twinFlag = CM_RTQueueEntry.TWIN_BOTH then
		return TWIN_BOTH_STR;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTwinnableEntry" id="36202d4f-d42c-4302-8e24-33a569b99c3c">
        <source>getTwinnableEntry() : CM_RTQueueEntry;

/*

Purpose:			Get the Queue Entry (if there is one) that can be twin lifted with the
					receiver

Parameters:			None

Return Value:		Twinnable Entry, or null if there isn't one


Date		Who		Reason
12 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
16 Mar 2016	cnwkpd1	TFS 1680 - Lock on CM_RadioTelemetryQueue::allEntries left behind if receiver is being 
					deleted by another process at the time this method is executing

*/

vars
	twinEntry		: CM_RTQueueEntry;
	iter			: Iterator;
	pickupTask		: CM_RTQueueTask;
	ti				: CM_TrackedItem;
	twinFlag		: Integer;
	lockedArray 	: CM_RTQueueEntryArray;
	
begin
	// If we have an overstowed container, then entry is not twinnable
	if self.hasOverstowedTIPickup() then
		return null;
	endif;
		
	// Current rule is that the very next entry in the Queue must be twinnable 
	twinFlag := self.getTwinCarryFlag();
	
	// If this entry is twinnable with the next one, or both the next and previous
	if twinFlag = self.TWIN_NEXT or twinFlag = self.TWIN_BOTH then
		// Then get the next entry
		lockedArray := self.myQueue.allEntries;			// KPD TFS 1680 - reversed order to ensure lockedArray is set
		sharedLock(lockedArray);
		iter := lockedArray.createIterator;
		iter.startAtObject(self);
		iter.next(twinEntry);		// we have our self
		iter.next(twinEntry);		// we have the twin
		
		// If the twinEntry has an overstowed container, then don't twin them
		if twinEntry &lt;&gt; null and twinEntry.hasOverstowedTIPickup() then
			twinEntry := null;
		endif;
	endif;
		
	return twinEntry;
	
	
epilog
	delete iter;
	if lockedArray &lt;&gt; null then
		unlock(lockedArray);
	endif;
	
end;</source>
        <ReturnType type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="getUltimateSourceLocation" id="b8a0802f-2bac-4591-aa4a-db1d17d52485">
        <source>getUltimateSourceLocation() : CM_LocationsController;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/08/2011	cnwdap1	Initial creation PAR #28047 CCMS POL 2095 display extra location information
03/05/2023  navma1	Bug 57849: MSL - Slowness Issues
*/
vars
	task		: CM_RTQueueTask;
	prevEntry	: CM_RTQueueEntry;
	isDeleted    : Boolean;
begin
	on Exception do app.handleDeletedObject (exception, prevEntry, isDeleted);	//03.05.2023 navma1 #57849		
	
	prevEntry:= self.getPreviousRelatedEntry(); 								//epr par 35702 CCMS 2457 17/2/15
	
	if prevEntry = null then
		task := self.allTasks.first;
		if task &lt;&gt; null then
			return task.sourceLocation;
		endif;
	else
		prevEntry.edition;												
		
		if not isDeleted then													//03.05.2023 navma1 #57849
			return prevEntry.getUltimateSourceLocation();
		endif;
	endif;
	
	return null;
epilog

end; </source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getUltimateTargetLocation" id="9c49352b-5da8-4428-8d2c-a81aa60fd167">
        <source>getUltimateTargetLocation() : CM_LocationsController;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/08/2011	cnwdap1	Initial creation PAR #28047 CCMS POL 2095 display extra location information
*/
vars
	task		: CM_RTQueueTask;
	nextEntry : CM_RTQueueEntry;
begin
	
	nextEntry:=self.getNextRelatedEntry(); //epr par 35702 CCMS 2457 17/2/15
	if nextEntry = null then
		task := self.allTasks.last;
		if task &lt;&gt; null then
			return task.targetLocation;
		else
			return null;
		endif;
	else
		return nextEntry.getUltimateTargetLocation();
	endif;
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="hasHeldShipLoadTIs" id="b45dd41e-3fff-4b30-8c97-3e0fd5c924af">
        <source>hasHeldShipLoadTIs();
//Calls a method to check that this TI is suitable to release to load.
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	aTask	:	CM_RTQueueTask;
	ti	:	CM_TrackedItem;
	lastTI	:	CM_TrackedItem;
begin
	foreach aTask in self.allTasks do
		if (not aTask.isShipLoadTask) then
			continue;
		endif;
		ti := aTask.ti;
		if ti &lt;&gt; null and ti &lt;&gt; lastTI then
			ti.isTISuitableToShipLoad();
			lastTI := ti;
		endif;
	endforeach;	
end;</source>
    </JadeMethod>
    <JadeMethod name="hasHeldTasks" id="d34a0fbb-187d-47ca-9aed-95e01aecfc01">
        <source>hasHeldTasks() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwer1	Initial creation

*/

vars
	task : CM_RTQueueTask;
begin
	foreach task in self.allTasks do
	//	if task.status = TASK_USER_HELD then
		if task.status = TASK_SYS_HELD or task.status = TASK_USER_HELD then	//21 Apr 2015	NDL	Par 36014
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasOverstowedTIPickup" id="d011f6f3-3b5b-4c00-b73b-55b375738008">
        <source>hasOverstowedTIPickup() : Boolean;

/*

Purpose:			Determine whether or not the receiver has a pickup task for an
					overstowed (or restricted) TI

Parameters:			None

Return Value:		True if it does, false otherwise


Date		Who		Reason
12 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	pickupTask,
	setdownTask		: CM_RTQueueTask;
	ti				: CM_TrackedItem;
	sideAccessDirection : Integer;
	overstowController : CMIF_OverstowController;
begin
	// If we have a pickup task for an overstowed container, then return true
	pickupTask := self.findTaskOfType(TASK_PICKUP, NULL_INTEGER);		// TASK_UNACTIONED
	
	if pickupTask &lt;&gt; null and pickupTask.status = TASK_COMPLETE and pickupTask.isOverstowTaskAuto then
		//check if the setdown tasks is complete if so then get the next pickup
		setdownTask := self.findTaskOfType(TASK_SETDOWN, NULL_INTEGER);
		if setdownTask &lt;&gt; null and setdownTask.status = TASK_COMPLETE then 
			pickupTask:=self.findNonOverstowTaskOfType(TASK_PICKUP);
		endif;
	endif;
	
	
	if pickupTask &lt;&gt; null then
		ti := pickupTask.ti;
		if ti &lt;&gt; null then
			sideAccessDirection := null;
			//epr TFS 37584 4/5/18
			create overstowController transient;
			overstowController.setParams(sideAccessDirection,ti,false,null,null);
			return overstowController.getAllOverstows();
		endif;
	endif;

	return false;
	
	
epilog
	delete overstowController;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTIWithStops" id="ba5c8b15-26eb-4d11-9198-41f15e71b50d">
        <source>hasTIWithStops()	: Boolean;
//Is there a task here for a TI that has stops or is toBeInspected???
//If so, return true.
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	aTask	:	CM_RTQueueTask;
begin
	if self.myJob = null then
		return false;
	endif;
	if self.myJob.isKindOf(CM_YardInternalJob) then
		//Dont care about internal yard jobs...
		return false;
	endif;
	if self.myJob.isKindOf(CM_VoyageJob) then
		//----------------
		//Dont care about voyage discharge jobs either
		//----------------
		if (self.myJob.CM_VoyageJob.isDischarge) then
			return false;
		endif;
	endif;
	foreach aTask in self.allTasks do
		if aTask.ti &lt;&gt; null and aTask.isOverstowTask = false then
			
			if aTask.ti.isStopSetToBePrevented(StopPreventRTQueuing) then //or aTask.ti.toBeInspected = true then
				return true;
			endif;
		endif;
	endforeach;	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="id" id="9edf77fc-14a5-4862-bb4b-c6fb2adaa676">
        <methodInvocation>mapping</methodInvocation>
        <source>id(set: Boolean; value: String io) mapping;
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	str : String;
//	maxLen : Integer;
	aWle : CM_WorkListEntry;
	aJob : CM_Job;
begin
	value := "";
	if set then
		return;
	endif;
	aJob := self.myJob;
	if aJob = null then
		value := "No job!";		
		return;
	endif;
	aWle := self.myWorkListEntry;
	if aWle &lt;&gt; null then			// and global.isValidObject(aWle) then
		str := aJob.jobId &amp; " " &amp; aWle.id;
	else
		str := aJob.jobId;
	endif;
	//Next call is very painful
	//maxLen := CM_RTQueueEntry.getProperty("id").getLength;
	if str.length &gt; ID_LEN -1 then
		str := str[1:ID_LEN-5] &amp; "...";
	endif;
	value := str;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="idFullDisplay" id="cf2d48b4-f510-406b-97e7-16c56a1922cb">
        <source>idFullDisplay():String;

/*

Purpose:	

			based on the mapping method 'id' but not truncated.

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2011	cnwndl1	Initial creation	Par 25418

*/

vars
	retValue : String;
	str : String;
	aWle : CM_WorkListEntry;
	aJob : CM_Job;
begin
	
	aJob := self.myJob;
	
	if aJob = null then
		retValue := "No job!";
		
	else
		aWle := self.myWorkListEntry;
		if aWle &lt;&gt; null and aJob.jobId &lt;&gt; aWle.id then
			retValue := aJob.jobId &amp; " " &amp; aWle.id;
		else
			retValue := aJob.jobId;
		endif;
		
	endif;
	
	return retValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isAnyId" id="759c776d-29dd-49dc-90c8-e15c278d5039">
