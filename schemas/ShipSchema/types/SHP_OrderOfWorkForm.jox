    <JadeMethod name="getSelectedJobs" id="de337daf-98ae-4b4e-b0bb-38c5f4b83a6b">
        <source>getSelectedJobs(_allJobs : Collection input; _isForLoadPlanning : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars
	idx : Integer;
	voyageJob : CM_VoyageJob;
begin
	// must be in OOW order not the order that they were clicked to select
	foreach idx in 1 to self.tblData.rows do
		if self.tblData.accessRow(idx).selected then
			voyageJob := self.tblData.accessRow(idx).itemObject.CM_VoyageJob;
			if voyageJob &lt;&gt; null then
				//epr TFS 830 30/3/7
				if _isForLoadPlanning and not voyageJob.isValidForLoadPlanning then
					continue;
				endif;
				
				_allJobs.add(voyageJob);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allJobs" type="Collection" usage="input"/>
        <Parameter name="_isForLoadPlanning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSheetForWorkPointObj" id="897f74ca-c634-4189-9216-15a5d614750c">
        <source>getSheetForWorkPointObj( workPointObj : Object) : CMUI_Sheet;
/*

Date		Who		Reason
16 September 2014	cnwer1	Initial creation PAR 34802

*/

vars

	obj : Object;
	sheet : CMUI_Sheet;
begin

	foreach obj in self.allLoadedSheets discreteLock do
		sheet:= obj.CMUI_Sheet;

		if sheet.userObject = workPointObj then
			return sheet;
		endif;
		
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="workPointObj" type="Object"/>
        <ReturnType type="CMUI_Sheet"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="340a99aa-53b3-45cc-89fe-156caf1caecb">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Oct 2012	PJS			PAR # 30631 - Voyage rationalisation
// ---------------------------------------------------------------------------

vars

	xmlStr	: String;
	entRow	: EntTableRow;	
begin
	//xmlStr := inheritMethod(); Dont do as tblData columns does not use organiser

	xmlStr :=          global.formatAsXML(XML_HideLashInfo, self.mnuContextLashInfo.caption);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_HideJobTimes, self.mnuContextJobTimes.caption);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_HideHatchJobs, self.mnuContextHideHatchJob.caption);
	xmlStr := xmlStr &amp; global.formatAsXML( self.XML_PrintLidComments, self.xmlPrintLidComments.Integer.String );
	xmlStr := xmlStr &amp; global.formatAsXML( self.XML_HatchJobComments, self.xmlHideHatchJobs.Integer.String );
	xmlStr := xmlStr &amp; global.formatAsXML(XML_HM,(self.mnuContextHide.caption = self.MNU_MACRO_SHOW).Integer.String); // PAR 16427 2 May 2008 cnwgb1
	xmlStr := xmlStr &amp; global.formatAsXML( self.XML_PrintPreview, self.xmlPrintPreview.Integer.String );

	return xmlStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="fc6bdc66-7364-4ecc-9c93-1d068c605529">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:	02 May 2008 By Graeme Black cnwgb1 PAR 16427
// Just recovers the setting for hiding the macro window
// ---------------------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	hideM : Boolean;
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	theXML := userWindow.xmlInfo;
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HM);
 	hideM := false;
 	if theXMLValue &lt;&gt; null then
 		hideM := theXMLValue.Integer.Boolean;
 	endif;
	
	self.xmlMacro := hideM;

end;
</source>
    </JadeMethod>
    <JadeMethod name="initCraneSheets" id="5071fe7b-911d-45a2-953f-ba88c4fac1f3">
        <source>initCraneSheets() ;
//----------------------------------------------------------------
//	Created:	05 September 2005	by Jason Chapman  (cnwjc2)
//
// 02 Nov 2012		PJS		PAr #30631
//23/08/2016 cnwma1 TFS #2557:SPT - Missing Planned Location on Sequence Sheets- Issue not fixed from previous TFS
//----------------------------------------------------------------
vars
	theVoyageJS 	: CM_VoyageJobSheet;
	theMachines : CM_MachineSet;
	aCraneSheet	: CMUI_Sheet;
	job				: CM_Job;
	jobsCount : Integer;
begin
	
	//change parent on shtMain - purge below can blow this away
	self.fldMain.topSheet := self.shtMain;
	self.splMain.parent := self.shtMain;
	self.shtUnallocated.visible := false;
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	self.allLoadedSheets.purge;
	
	//self.shtMain.caption := app.getErrorString(All_Jobs) &amp; "(" &amp; self.myCurrentVoyage.allVoyageJobs.size.String &amp; ")"; //23/08/2016 cnwma1 TFS# 2557
	
	foreach theVoyageJS in self.myCurrentVoyage.allJobSheets do
		if theVoyageJS.allJobsByOrder.isEmpty then
			continue;
		endif;
		
		self.addCraneSheetForJobSheet(theVoyageJS); //epr 21/3/17 tfs 830 refactored into method
			
	endforeach;

	foreach job in self.myCurrentVoyage.allVoyageJobs do
		if not job.isKindOf(CM_VoyageROROJob) then       //23/08/2016 cnwma1 TFS# 2557
			jobsCount := jobsCount +1;
			if job.myJobSheet = null then
				self.shtUnallocated.visible := true;
			//	break;                                      //23/08/2016 cnwma1 TFS# 2557
			endif;
		endif;
	endforeach;
	self.shtMain.caption := app.getErrorString(All_Jobs) &amp; "(" &amp; jobsCount.asStringJMT &amp; ")"; //23/08/2016 cnwma1 TFS# 2557

epilog
	delete theMachines;
end;</source>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="c9bb4963-f7f3-4d3c-88aa-d9277bc7859f">
        <source>initDataTable(_theEntDef : String; _viewName: String);
// ---------------------------------------------------------------------------
// Created:		September  2005 By Jason Chapman cnwjc2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
begin
	theTable := self.tblData;
	
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	theTable.setTblDataEntRowsFromView(entTableDef, _viewName);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;

end;</source>
        <Parameter name="_theEntDef" type="String"/>
        <Parameter name="_viewName" type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="4bb154cb-93e4-406a-ab1c-134f834eaa31">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//----------------------------------------------------------------
//	Created:	01 September 2005	by Jason Chapman  (cnwjc2)
//
// 31 Oct 2012	PJS		PAR # 30631
//----------------------------------------------------------------
vars
	hideJobTimes	: Boolean;
begin
	if _userWindow = null then
		return;
	endif;

	inheritMethod(_userWindow);

	self.mnuContextLashInfo.caption := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_HideLashInfo);
	if self.mnuContextLashInfo.caption = null then
		self.mnuContextLashInfo.caption := self.MNU_LASH_HIDE;
	endif;

	self.mnuContextJobTimes.caption := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_HideJobTimes);
	if self.mnuContextJobTimes.caption = null then
		self.mnuContextJobTimes.caption := self.MNU_TIMES_SHOW;
	endif;

	self.mnuContextHideHatchJob.caption := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_HideHatchJobs);
	if self.mnuContextHideHatchJob.caption = null then
		self.mnuContextHideHatchJob.caption := self.MNU_HATCH_SHOW;
	endif;
	
	self.xmlPrintLidComments := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_PrintLidComments).Integer.Boolean;
	self.chkPrnLidComment.value := self.xmlPrintLidComments;
	
	self.xmlHideHatchJobs := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_HatchJobComments).Integer.Boolean;
	self.chkHideHatchJob.value := self.xmlHideHatchJobs;
	
	self.xmlPrintPreview := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_PrintPreview).Integer.Boolean;  // 30631
	
	
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initInfo" id="69a26a4d-1b3d-4438-b2b3-bca729d1b4d4">
