        <source>getToQueueEntriesForLocation(_rtQueueEntrySet : CM_RTQueueEntrySet input) : Boolean;
// --------------------------------------------------------------
// Created:		24 August 2007 By cnwvu1
// --------------------------------------------------------------

vars

	queuedMove	: CM_FutureMove;
	queueEntry	: CM_RTQueueEntry;
	rtnValue	: Boolean;

begin

	rtnValue := false;
	
	foreach queuedMove in self.allQueuedFutureMoves do
		queuedMove.CM_FutureMoveQueued.getQueueEntries(_rtQueueEntrySet);
	endforeach;
	
	return rtnValue;

end;
