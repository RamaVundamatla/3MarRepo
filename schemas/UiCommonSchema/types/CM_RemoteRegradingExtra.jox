<Class name="CM_RemoteRegradingExtra">
    <JadeMethod name="loadRemoteTable" id="776f3f41-9b91-4643-b1de-70bfe8655e6f">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 31 March 2003 

vars

begin

	inheritMethod(_table);
	self.addRemoteRow(_table, 'Item Id', self.itemId, null);
	self.addRemoteRow(_table, 'New Item Id', self.newItemId, null);
	self.addRemoteRow(_table, 'Min SED', self.sedMin.String, null);
	self.addRemoteRow(_table, 'Max SED', self.sedMax.String, null);

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
