<Class name="CMIF_EventTransactionCtrl" id="b8ae4cec-b699-4478-9d68-41dc9d16d26c">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="amount" id="0a7a31ed-7315-4c25-8a4a-21b4f90e7c02">
        <precision>16</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="dateTime" id="6deed054-62c2-4c1c-8ca3-d3c82177ebdd">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myDebtor" id="aa7ab25e-a40c-4b0f-8971-d065cced8113">
        <embedded/>
        <type name="CM_Debtor"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTerminal" id="a64b3413-5d30-464f-9ce9-860bd0e2ccdd">
