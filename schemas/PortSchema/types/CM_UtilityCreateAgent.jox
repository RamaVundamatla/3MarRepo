    <JadeMethod name="utlCopyInvoiceTMContentsMap" id="db6cb289-7834-4c64-ae5e-4dc9e0111102">
        <source>utlCopyInvoiceTMContentsMap(_contentsMap : CM_ContentsMap input; _newContentsType : Integer; _parent : CM_ImexServiceMap; _newContentsMap : CM_ContentsMap output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2013 By John Eyers cnwjre1
