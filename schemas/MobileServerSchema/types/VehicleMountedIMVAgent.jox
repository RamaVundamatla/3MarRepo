    <JadeMethod name="doGetNextTask" id="044a4074-ae9f-4c4a-ac9e-6304f1fd1b71">
        <source>doGetNextTask(_errorMsgs: DTO_HandHeldGateErrorDict input; _showErrors : Boolean) : String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 November 2006	cnwer1	Initial creation - PAR#xxxx
04 Decemeber 2009   conkc1  PAR 20388 18807 - moved code to new method doGetNextTask
							Put retry code in here
*/
constants
	
vars

	returnString : String;

begin

	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do
		self.doGetNextTaskBody(_errorMsgs, _showErrors);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;
	return null;
epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;	//15 Jan 2013	NDL	Par 30920
end;</source>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <Parameter name="_showErrors" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
