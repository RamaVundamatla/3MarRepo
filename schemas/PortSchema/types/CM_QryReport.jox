    <JadeMethod name="myReportControllerClass" id="54648b47-5978-41dd-92b9-8cdd3155c3e2">
        <methodInvocation>mapping</methodInvocation>
        <source>myReportControllerClass(set: Boolean; _value: Class io) mapping;
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	portScm 	: Schema;	
	theClass	: Class;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	portScm := rootSchema.getSchema('UiCommonSchema');
	_value := portScm.getClass(self.reportControllerClass);
	
	
end;</source>
        <Parameter name="set" type="Boolean"/>
