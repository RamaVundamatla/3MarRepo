    <JadeMethod name="contentsStatus" id="162d470c-6dd1-47aa-95fa-2e8721a32868">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>contentsStatus(set: Boolean; _value: Integer io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     19 August 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// ### TFS BUG 64678 17JUNE024 NAVAB1 - 3 trailer contents statuses have been added all with values &gt; 3 so remove old check
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.contentsStatus := _value;
	else
		_value := self.contentsStatus;
