    <JadeMethod name="populateProductList" id="c91d328a-0410-487a-90aa-60d3119fe834">
        <source>populateProductList() protected;
// --------------------------------------------------------------------------------
// Created:		20 January 2003 by cnwdad1
//
// Purpose:		Populates the Product/Component listbox hierarchy.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theListbox		: ListBox;
	theProduct		: JSSLKProduct;
	theComponent	: JSSLKComponent;
	listPointer		: Integer;
	
begin
	theListbox	:=	lstProducts;
	theListbox.clear();
	
	foreach theProduct in app.myRoot.allProducts do
		listPointer	:=	theListbox.addItem(theProduct.getDisplay());
		theListbox.itemLevel[listPointer]	:=	1;
		theListbox.itemObject[listPointer]	:=	theProduct;
		
		foreach theComponent in theProduct.allComponents do
			listPointer	:=	theListbox.addItem(theComponent.getDisplay());
			theListbox.itemLevel[listPointer]	:=	2;
			theListbox.itemObject[listPointer]	:=	theComponent;
		endforeach;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateUsedProductsList" id="061e2035-1e0f-4fce-a351-2176fe12737e">
        <source>populateUsedProductsList() protected;
// --------------------------------------------------------------------------------
// Created:		20 January 2003 by cnwdad1
//
// Purpose:		Populates the Used Product/Component listbox hierarchy.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theListbox			: ListBox;
	theCustomer			: JSSLKCustomer;
	theUsedProduct		: JSSLKUsedProduct;
	theUsedComponent	: JSSLKUsedComponent;
	listPointer			: Integer;
	
begin
	theListbox	:=	lstProdUsed;
	theListbox.clear();
	
	if lstCustomers.listIndex = JSS_NULL_INDEX then
		return;
	else
		theCustomer	:=	lstCustomers.listObject.JSSLKCustomer;
		
		foreach theUsedProduct in theCustomer.allUsedProducts do
			listPointer		:=	theListbox.addItem(theUsedProduct.getDisplay());
			theListbox.itemLevel[listPointer]	:=	1;
			theListbox.itemObject[listPointer]	:=	theUsedProduct;
			
			if theUsedProduct.isExpired() then
				theListbox.itemForeColor[listPointer]	:=	Red;
			elseif not theUsedProduct.isLicensed() then
				theListbox.itemForeColor[listPointer]	:=	Blue;
			else
				theListbox.itemForeColor[listPointer]	:=	Black;
			endif;
			
			foreach theUsedComponent in theUsedProduct.allUsedComponents do
				listPointer	:=	theListbox.addItem(theUsedComponent.getDisplay());
				theListbox.itemLevel[listPointer]	:=	2;
				theListbox.itemObject[listPointer]	:=	theUsedComponent;
			endforeach;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setUsedProductExpiryDate" id="df32a6ed-36b1-4295-ab3b-6de7a2f27b58">
        <source>setUsedProductExpiryDate() protected;
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad1
//
// Purpose:		Displays a modal form to edit the expiry date for the currently
//				selected used product.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theExpiryDateForm	: JSSLKEditExpiryDateForm;
	theUsedProduct		: JSSLKUsedProduct;
	
begin
	theUsedProduct	:=	self.listGetSelectedUsedProduct(lstProdUsed);
	
	if theUsedProduct &lt;&gt; null then
		create theExpiryDateForm;
		theExpiryDateForm.setUsedProduct(theUsedProduct);
		theExpiryDateForm.showModal();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="2486627f-6582-4dec-a6f0-a0ece72b42c6">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doSystemNotification(eventType, theObject, eventTag);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="e8032fb3-d477-463d-93e5-77e91d2e812e">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if eventType = CUSTOMER_USEDCOMPONENT_CHANGE then
		self.populateUsedProductsList();
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
