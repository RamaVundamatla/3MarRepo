<Class name="CMIF_RepackTransController" id="7211e856-3ca0-48e6-ad48-d22cb3b55d5e">
    <superclass name="CMIF_TITransactionController"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="action" id="3c86e022-9edd-4b76-b756-701bc698b0f3">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="setFromTransaction" id="81b1996d-e32f-433b-a73c-d7dfd14dcdd2">
        <updating/>
        <source>setFromTransaction(_txn: CM_Repack) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 21 January 2004
//
//********************************************************************
vars

begin
	inheritMethod(_txn);
	self.action := _txn.action;
end;</source>
        <Parameter name="_txn" type="CM_Repack"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDetails" id="0bcc8885-9ed3-49dd-9a4c-89b09511dec7">
        <updating/>
        <source>setTransactionDetails(pTrx: CM_Repack input) updating, protected;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 21 January 2004
//
//********************************************************************
vars

begin
	inheritMethod(pTrx);
	pTrx.setAction(self.action);
end;</source>
        <access>protected</access>
        <Parameter name="pTrx" type="CM_Repack" usage="input"/>
    </JadeMethod>
</Class>
