<Class name="JSSCTNibblerManagerTA" id="b8317d7c-1892-43d3-85a0-1785c469bf1a">
    <superclass name="JSSCTTransactionAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
