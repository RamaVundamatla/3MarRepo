    <JadeMethod name="doCollapseSearchParameters" id="0d17c700-0384-4ef6-a11a-75dd73ecd27d">
        <source>doCollapseSearchParameters();

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
10 September 2008	consw1	Initial creation

*/

vars

