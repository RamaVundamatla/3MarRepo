    <JadeMethod name="doAutoPlan" id="d4d472f7-d2f7-4771-bd7a-9bb6063fc9d2">
        <source>doAutoPlan();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	result : Integer;
	job : CM_Job;
	wle : CM_WorkListEntry;
		wlesWithWarnings,
	wleArray : CM_WLEArray;
	invalidWLE : Boolean;
begin

	if self.myTrackedItem = null then
		return;
	endif;
	
	job := self.myTrackedItem.getFirstAvailableDischargeJob();
	
	wle := self.myTrackedItem.getVoyageWLEForJob(job.CM_VoyageJob);
	if wle &lt;&gt; null and wle.isCompleteForJob then
		job := null;
	endif;
	
	//epr tfs 4699 unplan if planned first
	if wle = null then
		wle:= self.myTrackedItem.getVoyageWLEUnactioned(false);	
	endif;
	
	if wle&lt;&gt; null and wle.myFutureMove &lt;&gt; null and wle.myFutureMove.isKindOf(CM_FutureMovePlanned) then
		create wleArray transient;
		wleArray.add(wle);
		create wlesWithWarnings transient;
			
		while true do
			app.myTrxUA.trxUpdateWLEsUnplan(wleArray, wlesWithWarnings, NO_MODE, app.myPassport);
			if app.myPassport.trxCompletedOK() then
				break;
				
			else
				result := app.showErrorWarningDialog(app.getErrorString(Error),
													app.myPassport,
													ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
				
				if app.myPassport.noErrors()
				and result = IDOK
				then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
	
				break;
			endif;
		endwhile;	
		
		on Exception do app.handleDeletedObject(exception,wle,invalidWLE);
		if wle &lt;&gt; null then
			job:=wle.job;
		endif;
		if invalidWLE then
			job:=null;
		endif;
	endif;
	
	result := self.myMobileGenericAgent.rePlanTi( self.myTrackedItem, job, 0 );

epilog
	delete wleArray;
	delete wlesWithWarnings;
end;</source>
    </JadeMethod>
    <JadeMethod name="doClickDamage" id="7554372b-b28a-464a-8c92-387ee70dd7ea">
        <updating/>
        <source>doClickDamage()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation		TFS 1593

*/

vars

begin

	if self.myTrackedItem = null then
		return;
	endif;
	
	if self.btnDamage.caption = app.getErrorString(Cancel) then
		self.populateTrackedItem();
		return;
	endif;

	if not self.tblDamage.visible then
		self.tblDamage.visible := true;
		self.lblNoDamage.visible := false;
	endif;
	
	self.tblDamage.initCombos(self.myTrackedItem.IF_DamageDetails);
	self.tblDamage.setTableFromDamageInterface(self.myTrackedItem.IF_DamageDetails);
	
	if not self.myTrackedItem.allDamageInstances.isEmpty then
		self.tblDamage.addNewRow();
	endif;
	
	//Ok we are in Damage update mode...
	
	self.btnTwo.enabled := false; // Disable the Process button.  
	self.btnLabel.caption := app.getErrorString(Save);
	self.btnDamage.caption := app.getErrorString(Cancel);
	self.btnDirty.visible := false;	//26 May 2016	NDL	TFS 1593

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickDirty" id="56e41c86-b465-4f68-b1f1-a55bdba36ab1">
        <source>doClickDirty();
/*

Purpose:			
			TFS says "Add new button 'Dirty' if clicked create a CM_NeedsWash transaction
			on the selected cargo. Only create one CM_NeedsWash transaction from this APP,
			no confirmations."
Parameters:			

Return Value:		

Date		Who		Reason
25 May 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	txnController : CMIF_TITransactionController;
	newTITxn : CM_TITransaction;

begin

	if not self.showDirtyButton() then
		return;
	endif;
	
	create txnController transient;
	txnController.type := TRANS_TYPE_NEEDSWASH;
	txnController.noCharge := false; //TFS 3844 changed to false
	txnController.myTerminal := self.myTerminal;
	txnController.myTrackedItem := self.myTrackedItem;
	
	app.myTrxCA.trxCreateTITransaction(txnController, newTITxn, app.myPassport);	

epilog

	self.btnDirty.enabled := self.showDirtyButton();

	delete  txnController;
	
end;</source>
    </JadeMethod>
