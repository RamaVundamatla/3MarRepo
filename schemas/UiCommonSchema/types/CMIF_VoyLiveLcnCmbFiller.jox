<Class name="CMIF_VoyLiveLcnCmbFiller" id="9e9a986e-2692-4ddb-971f-df7a07b5fb47">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="fillCmbWithPotentialLcns" id="902c6438-5952-4346-a594-af4dad5dcdc7">
        <updating/>
        <source>fillCmbWithPotentialLcns(_locationCmb : CMUI_ComboBox io; _currentVoyage : CM_Voyage; _currentTrackedItem : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2024	navra1	Initial creation for CR 62045/Task 62050 - UI - Import Container Confirmation Location and CR 62045/Task 62049 - UI - Export Container Confirmation Location

*/

vars
	tmpDict : CM_GeneralCCtrByHatchPlaceDict;
	hatch : CM_LocationsController;
	objSet : CM_ObjectSetActual;
	obj : Object;
	cta : CM_CraneTransferArea;
	lc : CM_LocationsController;
	wpIa : CM_WorkPointInterchangeArea;
	wpLanes : CM_LCArray;
	vesselLocationControllers : CM_LCSet;
	jobSheetCollection : CM_VoyageJobSheetByCraneDict;
	jobSheet : CM_VoyageJobSheet;	
	wleCollection : CM_WLEArray;
	wle : CM_WorkListEntry;	
	isLoad : Boolean;		//just to make it explicit
	dischargeWLE, loadWLE : CM_VoyageWLE;
	dischargeCrane : CM_Crane;
begin
	
	_locationCmb.clear();
	_locationCmb.sorted := true;
	
	if _currentVoyage = null then
		return;
	endif;
	
	//just to make it explicit while querying using getVoyageWLEUnactioned
	isLoad := true;
	
	//navra1 - CR 62045/Task 62050 - 16th Jan 2024 - change for import LOLO - start	
	if _currentTrackedItem &lt;&gt; null and _currentTrackedItem.isContainer() then
		dischargeWLE := _currentTrackedItem.getVoyageWLEUnactioned(not isLoad);
		if dischargeWLE &lt;&gt; null then	//its going to be discharged			
			dischargeCrane := dischargeWLE.getCrane();
			if dischargeCrane &lt;&gt; null then
				cta := dischargeCrane.getCraneTransferArea;
				if cta &lt;&gt; null then
					foreach lc in cta.dischargeLanes do
						_locationCmb.addItemObject(lc.getFullId(), lc);							
					endforeach;
					
					if cta.dischargeLanes &lt;&gt; null then						
						if cta.dischargeLanes.size() = 1 then	//if there is only one discharge lane for the crane, then set that as the default
							_locationCmb.listObject := cta.dischargeLanes.first();
							return;
						endif;
					endif;
					
					//set null as default if you didnt return yet
					_locationCmb.listObject := null;
					
					return;
				endif;				
			endif;				
		endif;
	endif;
	//navra1 - CR 62045/Task 62050 - 16th Jan 2024 - change for import LOLO - end
	
	//navra1 - CR 62045/Task 62049 - 16th Jan 2024 - change for export LOLO - start
	if _currentTrackedItem &lt;&gt; null and _currentTrackedItem.isContainer() then
		loadWLE := _currentTrackedItem.getVoyageWLEUnactioned(isLoad);
		if loadWLE &lt;&gt; null then		//it is going to be loaded
			vesselLocationControllers := _currentVoyage.getAllLcs();
			if vesselLocationControllers &lt;&gt; null then
				foreach lc in vesselLocationControllers do
					if lc.isKindOf(CM_SlotController) then
						_locationCmb.addItemObject(lc.getFullIdTI(_currentTrackedItem), lc);  //jlier1 TFS 65046 8/7/23 - if 40 ft show 40 ft locations
					endif;
				endforeach;
			endif;
			
			//set the planned location as default
			if _currentTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then
				//this need not be added again, since it will be one of the LC of the ship and its already added above			
				_locationCmb.listObject := _currentTrackedItem.myPrimaryPlannedLocation;
			else
				_locationCmb.listObject := null;
			endif;	
			
			return;
		endif;
	endif;
	//navra1 - CR 62045/Task 62049 - 16th Jan 2024 - change for export LOLO - end
	
	if _currentVoyage.myShipBlockStack &lt;&gt; null then
		_locationCmb.addItemObject(_currentVoyage.myShipBlockStack.getFullId(), _currentVoyage.myShipBlockStack);
	endif;
	
	if _currentVoyage.myGeneralCargoVoyage &lt;&gt; null then
		tmpDict := _currentVoyage.myGeneralCargoVoyage.allLocationsByHatchPlace;
	
		foreach hatch in tmpDict discreteLock, reversed do
			_locationCmb.addItemObject(hatch.getFullId(), hatch);		
		endforeach;
	endif;
	
	if _currentVoyage.isBarge then
		create objSet transient;
		_currentVoyage.findAllMyCranesAndWorkpoints( objSet );
		if not objSet.isEmpty then
		
			foreach obj in objSet do
				if obj.isKindOf( CM_Crane ) then
					cta := obj.CM_Crane.getCraneTransferArea;
					if cta &lt;&gt; null then						
						foreach lc in cta.loadLanes do
							_locationCmb.addItemObject(lc.getFullId(), lc);
						endforeach;					
					endif;
					
				elseif obj.isKindOf( CM_WorkPoint ) then
					wpIa := obj.CM_WorkPoint.myWorkPointInterchangeArea;
					if wpIa &lt;&gt; null then
						create wpLanes transient;
						wpIa.getLanes(wpLanes);
						foreach lc in wpLanes do
							_locationCmb.addItemObject(lc.getFullId(), lc);
						endforeach;
					endif;
				
				endif;
			endforeach;
			
		endif;
	endif;
	
	_locationCmb.sorted := false;
	_locationCmb.addItemAt("",1);
	

epilog
	
	delete objSet;
	delete wpLanes;
	
	delete vesselLocationControllers;
	delete jobSheetCollection;
	delete jobSheet;
	delete wleCollection;
	delete wle;
	
end;</source>
        <Parameter name="_locationCmb" type="CMUI_ComboBox" usage="io"/>
        <Parameter name="_currentVoyage" type="CM_Voyage"/>
        <Parameter name="_currentTrackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
