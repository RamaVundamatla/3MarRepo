					&lt;code&gt;3&lt;/code&gt;
					&lt;description/&gt;
					&lt;fullOrMT/&gt;
					&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;packingGroup/&gt;
					&lt;releaseRequestNumber/&gt;
					&lt;requestDetailID/&gt;
					&lt;undgCodes/&gt;
					&lt;allUNDGCodes/&gt;
				&lt;/HazardousDetails&gt;
			&lt;/AllHazardousDetails&gt;
			&lt;AllSealDetails&gt;
				&lt;SealDetails&gt;
					&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;sealEDINum&gt;SEAL01&lt;/sealEDINum&gt;
					&lt;sealEDIType&gt;SHIP&lt;/sealEDIType&gt;
				&lt;/SealDetails&gt;
			&lt;/AllSealDetails&gt;
		&lt;/Prenote&gt;
	&lt;/AllPrenote&gt;
&lt;/JMTInternalPrenote&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 3, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.dischargePort, "HKHKG", "wrong remarks");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPrenoteViaWeb" id="d2788a11-54db-41fb-8e9d-c160d58da076">
        <source>tPrenoteViaWeb();
/* Changes

Date		Name	TFS#		Description
============================================================================
27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/

constants
	USER_DEF_NAME : String = "JMTInternalPrenote";
	VESSEL_CODE	: String = "UTXVES1";
	VOYAGE_CODE	: String = "UTXVOY1";
	CONTAINER_ID01 : String = "TEST0000001";
	CONTAINER_ID02 : String = "TEST0000002";
	CONTAINER_ID03 : String = "TEST0000003";
vars
	containerObj : CM_TrackedItem;
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	ediControllerAgent : CM_EDIControllerAgent;
	binaryMsg : Binary;
	bSynchronous : Boolean;
	messageType : String;
	idx : Integer;
	clientRef : String;
	errorStr : String;
begin
	passportObj	:=	app.myPassport;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal(self.getTerminal);
	self.deleteContainer(CONTAINER_ID01);
	containerObj := self.getTrackedItem(CONTAINER_ID01);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID02);
	containerObj := self.getTrackedItem(CONTAINER_ID02);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID03);
	containerObj := self.getTrackedItem(CONTAINER_ID03);
	self.assertIsDeleted(containerObj);
	// Create the Vessel and the Voyage.
	self.deleteVessel(VESSEL_CODE);
	vesselObj	:=	self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vesselObj);
	self.deleteVoyage(VOYAGE_CODE);
	voyageObj	:=	self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyageObj);
	self.createVoyageVessel(VOYAGE_CODE, VESSEL_CODE, voyageObj, vesselObj);
	self.assertNotNullMsg(vesselObj, "Add vessel failed!");
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalPrenote&gt;
&lt;AllPrenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID01&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;111111OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;111111InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID02&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;222222OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;222222InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;Prenote&gt;
&lt;weight&gt;2001&lt;/weight&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;id&gt;'&amp;CONTAINER_ID03&amp;'&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;orderNumber&gt;333333OrderNum&lt;/orderNumber&gt;
&lt;invoiceNumber&gt;333333InvoiceNum&lt;/invoiceNumber&gt;
&lt;/Prenote&gt;
&lt;/AllPrenote&gt;
&lt;/JMTInternalPrenote&gt;
';
//	ediFileObj := self.ediLoad(ediText, EDIFileType_Unknown, USER_DEF_NAME);
//	self.assertNotNull(ediFileObj);

	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := USER_DEF_NAME;						// ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	// make sure all of the objects are deleted and created correctly.
	ediFileObj := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFileObj &lt;&gt; null then
		beginTransaction;
		if ediFileObj.ediData = null then
			delete ediFileObj;
		else
			ediDataObj := ediFileObj.ediData;
			delete ediDataObj;
		endif;
		commitTransaction;
	endif;
	ediFileObj := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFileObj);
	
	// Load and DB load the message
	ediControllerAgent.loadMessageFromWeb(System_EDIFileType, binaryMsg, ediFileObj, bSynchronous, null); //jlgka1 TFS 45332
	errorStr := 'Failed to load edi data ';
	errorStr :=	errorStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, errorStr);

epilog
	delete ediControllerAgent;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tReleaseRequest" id="4776f88e-1335-4cf8-ab8f-59862d3a9d27">
        <source>tReleaseRequest();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VESSEL_CODE	: String = "SHIPGEN";
	VOYAGE_CODE	: String = "VOYSHIPGENXX";
	TestOperator = 'MSK';
	USER_DEF_NAME : String = "JMTInternalReleaseRequest";
	ContainerId1 = 'UTXXXX11';
	ContainerId2 = 'UTXXXX22';
	RELEASE_001 : String = "UT_REL2221011";
	RELEASE_002 : String = "UT_REL2221012";
	RELEASE_003 : String = "UT_REL2221013";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	relRequest : CM_BulkRelease;
	container : CM_Container;
	operator : CM_Operator;
	carrier : CM_Carrier;
	opCrit : CM_OperatorCarrierCriteria;
	opCrit1 : CM_OperatorCarrierCriteria;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	passportObj	:=	app.myPassport;
	operator := self.getOperator(TestOperator);
	self.deleteReleaseRequest(RELEASE_001);
	relRequest := self.getReleaseRequest(RELEASE_001);
	self.assertIsDeleted(relRequest);
	self.deleteReleaseRequest(RELEASE_002);
	relRequest := self.getReleaseRequest(RELEASE_002);
	self.assertIsDeleted(relRequest);
	self.deleteReleaseRequest(RELEASE_003);
	relRequest := self.getReleaseRequest(RELEASE_003);
	self.assertIsDeleted(relRequest);
	self.deleteVoyage(VOYAGE_CODE);
	voyage := self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(VESSEL_CODE);
	vessel := self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(VESSEL_CODE, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add vessel failed');

	voyage	:= self.addVoyageWithContainerStructur(VOYAGE_CODE,
													VESSEL_CODE,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VOYAGE_CODE);
	self.assertNotNull(voyage);
	//delete previously created containers
	self.deleteContainer(ContainerId1);
	container := self.getTrackedItem(ContainerId1).CM_Container;
	self.assertNullMsg(container, 'Failed deleting container ' &amp; ContainerId1);
	self.deleteContainer(ContainerId2);
	container := self.getTrackedItem(ContainerId2).CM_Container;
	self.assertNullMsg(container, 'Failed deleting container ' &amp; ContainerId2);

	carrier := app.myRoot.allCarriers["UT_OTHER"];
	foreach opCrit in operator.allOperatorCarrierCriteria do
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType and
		   opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then
			opCrit1 := opCrit;
		endif;
	endforeach;
	if opCrit1 &lt;&gt; null and
	   not opCrit1.allCarriers.includes(carrier) then
		beginTransaction;
		opCrit1.allCarriers.add(carrier);
		commitTransaction;
	endif;
	
	//Now add the container
	container := self.addContainer(ContainerId1, operator, '2200', 'GENL', TI_IMEX_STATUS_IMPORT).CM_Container;
	self.assertNotNullMsg(container, 'Failed creating container ' &amp; ContainerId1);
	container := self.addContainer(ContainerId2, operator, '2200', 'GENL', TI_IMEX_STATUS_IMPORT).CM_Container;
	self.assertNotNullMsg(container, 'Failed creating container ' &amp; ContainerId2);
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalReleaseRequest&gt;
	&lt;AllReleaserequest&gt;
		&lt;Releaserequest&gt;
			&lt;checkISOGroup&gt;true&lt;/checkISOGroup&gt;
			&lt;mtRelease&gt;true&lt;/mtRelease&gt;
			&lt;releaseByType&gt;true&lt;/releaseByType&gt;
			&lt;deliveryReason&gt;3&lt;/deliveryReason&gt;
			&lt;quantity&gt;1&lt;/quantity&gt;
			&lt;releaseType&gt;6&lt;/releaseType&gt;
			&lt;availabilityGrades&gt;4&lt;/availabilityGrades&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;carrierCode&gt;UT_OTHER&lt;/carrierCode&gt;
			&lt;consignee&gt;UTCOE&lt;/consignee&gt;
			&lt;consignor&gt;UTCOE&lt;/consignor&gt;
			&lt;consignorVoyage&gt;UT_X2221AUT UT_X2221&lt;/consignorVoyage&gt;
			&lt;destinationPort&gt;AUSYD&lt;/destinationPort&gt;
			&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
			&lt;fullOrMT&gt;E&lt;/fullOrMT&gt;
			&lt;isoType&gt;22G1&lt;/isoType&gt;
			&lt;isoTypeGroup&gt;GEN2&lt;/isoTypeGroup&gt;
			&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;releaseRequestNumber&gt;'&amp;RELEASE_001&amp;'&lt;/releaseRequestNumber&gt;
			&lt;releaseTypeStr&gt;Unknown&lt;/releaseTypeStr&gt;
			&lt;senderCode&gt;MSKCOPARN&lt;/senderCode&gt;
			&lt;statusBulkRelease&gt;Pending&lt;/statusBulkRelease&gt;
			&lt;subTerminalCode&gt;UT_Depot&lt;/subTerminalCode&gt;
			&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
			&lt;estimatedRequiredDate&gt;07 August 2014, 01:47:00&lt;/estimatedRequiredDate&gt;
			&lt;requestDate&gt;07 August 2014, 01:47:12&lt;/requestDate&gt;
		&lt;/Releaserequest&gt;
		&lt;Releaserequest&gt;
			&lt;allowCargoMultiReleases&gt;true&lt;/allowCargoMultiReleases&gt;
			&lt;quantity&gt;2&lt;/quantity&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;id&gt;UTXXXX11&lt;/id&gt;
			&lt;isoType&gt;2200&lt;/isoType&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSL&lt;/operatorCode&gt;
			&lt;releaseRequestNumber&gt;'&amp;RELEASE_002&amp;'&lt;/releaseRequestNumber&gt;
			&lt;releaseTypeStr&gt;Road&lt;/releaseTypeStr&gt;
			&lt;statusBulkRelease&gt;Active&lt;/statusBulkRelease&gt;
			&lt;subTerminalCode&gt;UT_Depot&lt;/subTerminalCode&gt;
		&lt;/Releaserequest&gt;
		&lt;Releaserequest&gt;
			&lt;allowCargoMultiReleases&gt;true&lt;/allowCargoMultiReleases&gt;
			&lt;quantity&gt;2&lt;/quantity&gt;
			&lt;mark&gt;Markedly&lt;/mark&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;id&gt;UTXXXX22&lt;/id&gt;
			&lt;isoType&gt;2200&lt;/isoType&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSL&lt;/operatorCode&gt;
			&lt;releaseRequestNumber&gt;'&amp;RELEASE_003&amp;'&lt;/releaseRequestNumber&gt;
			&lt;releaseTypeStr&gt;Road&lt;/releaseTypeStr&gt;
			&lt;statusBulkRelease&gt;Active&lt;/statusBulkRelease&gt;
			&lt;subTerminalCode&gt;UT_Depot&lt;/subTerminalCode&gt;
		&lt;/Releaserequest&gt;
	&lt;/AllReleaserequest&gt;
&lt;/JMTInternalReleaseRequest&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 3, "incorrect number of EDI trackedItems");
	relRequest := self.getReleaseRequest(RELEASE_001);
	self.assertNotNull(relRequest);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tReleaseRequestAction" id="a47fe0df-b3e7-4dd3-a012-fb0a7b38b068">
        <source>tReleaseRequestAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalReleaserequest";
	RELEASE_001 : String = "UT_REL2221011";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	relRequest : CM_BulkRelease;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	self.deleteReleaseRequest(RELEASE_001);
	relRequest := self.getReleaseRequest(RELEASE_001);
	self.assertIsDeleted(relRequest);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalReleaseRequest xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalRelaseRequest.xsd"&gt;
	&lt;AllReleaserequest&gt;
		&lt;Releaserequest&gt;
			&lt;allowCargoMultiReleases/&gt;
			&lt;canBeHiLoCube&gt;true&lt;/canBeHiLoCube&gt;
			&lt;checkISOGroup/&gt;
			&lt;clean/&gt;
			&lt;customsAssistance/&gt;
			&lt;directDelivery/&gt;
			&lt;heavyDuty/&gt;
			&lt;isGeneratorAttachment/&gt;
			&lt;mtRelease&gt;true&lt;/mtRelease&gt;
			&lt;releaseByType&gt;true&lt;/releaseByType&gt;
			&lt;removeStops/&gt;
			&lt;requestDateDoUpdate/&gt;
			&lt;weight/&gt;
			&lt;deliveryReason/&gt;
			&lt;quantity&gt;1&lt;/quantity&gt;
			&lt;releaseType/&gt;
			&lt;availabilityGrades/&gt;
			&lt;billOfLading/&gt;
			&lt;bookingConfirmation&gt;true&lt;/bookingConfirmation&gt;
			&lt;bookingRef/&gt;
			&lt;businessUnit/&gt;
			&lt;cargoSubType/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;carrierCode/&gt;
			&lt;consignee&gt;UTCOE&lt;/consignee&gt;
			&lt;consignor/&gt;
			&lt;consignorVoyage/&gt;
			&lt;customsAgent/&gt;
			&lt;deliveryReleaseNumber&gt;DEl001&lt;/deliveryReleaseNumber&gt;
			&lt;description/&gt;
			&lt;destTerminal/&gt;
			&lt;destinationPort/&gt;
			&lt;dischargePort/&gt;
			&lt;freightForwarder/&gt;
			&lt;fullOrMT&gt;E&lt;/fullOrMT&gt;
			&lt;generatorType/&gt;
			&lt;id/&gt;
			&lt;ids/&gt;
			&lt;isoType&gt;22G1&lt;/isoType&gt;
			&lt;isoTypeGroup&gt;GEN2&lt;/isoTypeGroup&gt;
			&lt;loadPort/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;operatorGroup/&gt;
			&lt;releaseRequestNumber&gt;'&amp;RELEASE_001&amp;'&lt;/releaseRequestNumber&gt;
			&lt;releaseTypeStr&gt;Road&lt;/releaseTypeStr&gt;
			&lt;remarks/&gt;
			&lt;senderCode/&gt;
			&lt;sequence/&gt;
			&lt;statusBulkRelease&gt;Active&lt;/statusBulkRelease&gt;
			&lt;subTerminalCode&gt;UT_Depot&lt;/subTerminalCode&gt;
			&lt;trailerType/&gt;
			&lt;vesselName/&gt;
			&lt;voyageCode/&gt;
			&lt;estimatedRequiredDate/&gt;
			&lt;expiryTimeStamp/&gt;
			&lt;requestDate/&gt;
		&lt;/Releaserequest&gt;
	&lt;/AllReleaserequest&gt;
&lt;/JMTInternalReleaseRequest&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	relRequest := self.getReleaseRequest(RELEASE_001);
	self.assertNotNull(relRequest);
	self.assertEqualMsg(relRequest.consigneeCode, "UTCOE", "consigneeCode wrong");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tReleaseRequestBestPick" id="8b32a309-e0b4-451a-b7f1-910939f35dd5">
        <source>tReleaseRequestBestPick();
/* navdap1

Date		Name	TFS#	Description
============================================================================
31/01/2022	jlika1	52472	MSL - Best Pick field for EDI Release Request
============================================================================*/
constants
	TestOperator = 'MSL';
	UserDefineTypeDesc : String = "ReleaseRequestBestPick";	
	ReleaseRequest : String = "UT_REL31012022";	
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	ediDataReleaseRequest : CM_EDIDataReleaseRequest;
	ediDataReleaseRequestTI : CM_EDIReleaseRequestTI;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	relRequest : CM_BulkRelease;
	relRequestTI : CM_ReserveDetail;
	operator : CM_Operator;
	terminal : CM_Terminal;
	subTerminalSettings : Boolean;
begin
	// create user defined file type
	self.createUserDefinedFileType(UserDefineTypeDesc, self.UT_UDT_BESTPICK);
	
	passportObj	:=	app.myPassport;
	
	terminal := self.getTerminal();
	subTerminalSettings := terminal.getConfig(IsSubTerminalsOn).Boolean;
	
	if (subTerminalSettings) then
		beginTransaction;
		terminal.setConfig(IsSubTerminalsOn, false);
		commitTransaction;
	endif;
	
	operator := self.getOperator(TestOperator);
	
	self.deleteReleaseRequest(ReleaseRequest);
	relRequest := self.getReleaseRequest(ReleaseRequest);
	self.assertIsDeleted(relRequest);
	
	ediText := self.UT_BESTPICK;

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, UserDefineTypeDesc, UserDefineTypeDesc&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	
	self.assertNotNull(ediFileObj.ediData);
	
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	
	self.assertEqualMsg(ediFileObj.fileStatus , CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	//Check EDI Best pick field
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	
	ediDataReleaseRequest :=  ediDataObj.CM_EDIDataReleaseRequest;
	self.assertNotNull(ediDataReleaseRequest);
	
	ediDataReleaseRequestTI := ediDataReleaseRequest.allEDITrackedItems.first.CM_EDIReleaseRequestTI;
	self.assertEqualMsg(ediDataReleaseRequestTI.bestPick, true, "EDI Data best pick field is not set");
	
	
	//Check Release Request Best Pick field
	relRequest := self.getReleaseRequest(ReleaseRequest);
	self.assertNotNull(relRequest);
	
	self.assertEqualMsg(relRequest.allReserveDetails.size, 1, "incorrect number of Reserve Details");
	
	relRequestTI := relRequest.allReserveDetails.first.CM_ReserveDetail;
	self.assertEqualMsg(relRequestTI.bestPick, true, "Release Request detail best pick field is not set");	

epilog
	//reset the sub terminal config
	beginTransaction;
	terminal.setConfig(IsSubTerminalsOn, subTerminalSettings);
	commitTransaction;	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tRequestMultiLine" id="9fcb0e4b-fb40-4a5d-b9e9-b95e0d428236">
        <source>tRequestMultiLine();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
constants
	VESSEL_CODE	: String = "SHIPGEN";
	VOYAGE_CODE	: String = "VOYSHIPGENXX";
	TestOperator = 'MSK';
	USER_DEF_NAME : String = "JMTInternalRequestMultiLine";
	RELEASE_000 : String = "UT_REL2221010";
	RELEASE_001 : String = "UT_REL2221011";
	RELEASE_002 : String = "UT_REL2221012";
	RELEASE_003 : String = "UT_REL2221013";
	RELEASE_004 : String = "UT_REL2221014";
	RELEASE_005 : String = "UT_REL2221015";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	relRequest : CM_BulkRelease;
begin
	passportObj	:=	app.myPassport;
	self.deleteReleaseRequest(RELEASE_000);
	relRequest := self.getReleaseRequest(RELEASE_000);
	self.assertIsDeleted(relRequest);
	self.deleteReleaseRequest(RELEASE_001);
	relRequest := self.getReleaseRequest(RELEASE_001);
	self.assertIsDeleted(relRequest);
	self.deleteReleaseRequest(RELEASE_002);
	relRequest := self.getReleaseRequest(RELEASE_002);
	self.assertIsDeleted(relRequest);
	self.deleteReleaseRequest(RELEASE_003);
	relRequest := self.getReleaseRequest(RELEASE_003);
	self.assertIsDeleted(relRequest);
	self.deleteReleaseRequest(RELEASE_004);
	relRequest := self.getReleaseRequest(RELEASE_004);
	self.assertIsDeleted(relRequest);
	self.deleteReleaseRequest(RELEASE_005);
	relRequest := self.getReleaseRequest(RELEASE_005);
	self.assertIsDeleted(relRequest);
	self.deleteVoyage(VOYAGE_CODE);
	voyage := self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(VESSEL_CODE);
	vessel := self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(VESSEL_CODE, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add vessel failed');

	voyage	:= self.addVoyageWithContainerStructur(VOYAGE_CODE,
													VESSEL_CODE,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
