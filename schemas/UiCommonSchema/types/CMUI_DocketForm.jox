    <JadeMethod name="getTextTableDisplay" id="4af556a4-bdec-4c3c-8ce6-6981ac9a2a5f">
        <source>getTextTableDisplay(_obj: Object ; _etRow: EntTableRow): String;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	str, str1 	: String;
	contAtmos	: Boolean;
	cargoType	: CM_CargoType;
	bolDtl		: CM_BOLDtl;
	
begin
	bolDtl := _obj.CM_BOLDtl;
	str1 := _etRow.name;
	if str1 = "cargoTypeDesc" then
		if bolDtl.cargoTypeDescr = null then
			return null;
		endif;
	elseif str1 = "commodity" then
		if bolDtl.commodity = null then
			return null;
		endif;
	elseif str1 = "colour" then
		if bolDtl.colour = null then
			return null;
		endif;
	elseif str1 = "mark" then
		if bolDtl.markNumber = null then
			return null;
		endif;
	elseif str1 = "numItems" then
		if bolDtl.quantity = null then
			return null;
		endif;
	elseif str1 = "weightTotal" then
		if bolDtl.weight = null then
			return null;
		endif;
	elseif str1 = "length" then
		if bolDtl.length = null then
			return null;
		endif;
	elseif str1 = "volume" then
		if bolDtl.volume = null then
			return null;
		endif;
	elseif str1 = "width" then
		if bolDtl.width = null then
			return null;
		endif;
	elseif str1 = "height" then
		if bolDtl.height = null then
			return null;
		endif;
	elseif str1 = "consignorCode" then
		if bolDtl.consignorCode = null then
			return null;
		endif;
	elseif str1 = "consigneeCode" then
		if bolDtl.consigneeCode = null then
			return null;
		endif;
	elseif str1 = "remark" then
		if bolDtl.remarks = null then
			return null;
		endif;
	endif;
	
	str := bolDtl.getDisplayStringForAttribute(_etRow.name, true);
	//app.getCargoFieldString(_obj, str1);
	if str &lt;&gt; null then
		str := _etRow.getHeading(null, null, app.myCurrentLocale) &amp; ': ' &amp; str;
	endif;
	return str;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_etRow" type="EntTableRow"/>
        <ReturnType type="String"/>
    </JadeMethod>
