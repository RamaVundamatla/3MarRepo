			&amp; "&lt;/body&gt;&lt;/message&gt;";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xmlAcknowledge" id="4a50aba5-148f-47b6-9092-3d462249801e">
        <source>xmlAcknowledge(_messageType : String; _response : CM_ITSInterfaceResponse) : String;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
07 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	machineId : String;

begin
	if _response.myMachine &lt;&gt; null then
		machineId := _response.myMachine.id;
	endif;

	return "&lt;message&gt;&lt;header&gt;"
			&amp; "&lt;messageType&gt;" &amp; _messageType &amp; "&lt;/messageType&gt;"
			&amp; "&lt;machineId&gt;" &amp; machineId &amp; "&lt;/machineId&gt;"
			&amp; "&lt;messageNumber&gt;" &amp; self.txtMessageNo.text &amp; "&lt;/messageNumber&gt;"
			&amp; "&lt;originalMsgNo&gt;" &amp; _response.messageNumber.String &amp; "&lt;/originalMsgNo&gt;"
			&amp; "&lt;messageVersion&gt;1&lt;/messageVersion&gt;"
			&amp; "&lt;/header&gt;&lt;body/&gt;&lt;/message&gt;";
			
epilog

end;</source>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_response" type="CM_ITSInterfaceResponse"/>
        <ReturnType type="String"/>
    </JadeMethod>
