<Class name="Class">
    <JadeMethod name="jssCount" id="978394e7-4e2b-43b1-8453-d5e2f40877b2">
        <source>jssCount(pCondition:String; pIsSubclasses:Boolean):Integer;
// --------------------------------------------------------------------------------
// Created:		20 December 2002 by cnwdad1
//
// Purpose:		This method will return a count of all instances of the receiver,
//				optionally executing JADE code against each object, such as some
//				condition to include or exclude particular objects in the count.
//				Note that the JADE code must not be enclosed in begin/end statements.
//
//				For example:
//
//				write Customer.jssCount("balanceOwing &gt; 0", true);
//
// Parameters:	pCondition - JADE source code to execute against each instance.
//				pIsSubclasses - If true, instances of subclasses will also be counted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theObject		: Object;
	allObjects		: ObjectArray;
	sourceCode		: String;
	objectCount		: Integer;
	errorCode		: Integer;
	errorPos		: Integer;
	errorLength		: Integer;
	methodObj		: JadeMethod;
	exceptionObj	: SystemException;
	
begin
	if pCondition &lt;&gt; null then
		sourceCode	:=	"begin return " &amp; pCondition &amp; "; end;";
		methodObj	:=	process.createTransientMethod(	"cnEcObjectFilter",
														self,
														currentSchema,
														sourceCode,
														true,
														Boolean,
														errorCode,
														errorPos,
														errorLength);
		
		if errorCode &lt;&gt; 0 then
			create exceptionObj transient;
			
			exceptionObj.errorCode	:=	errorCode;
			exceptionObj.errorItem	:=	sourceCode[errorPos:errorLength + 1];
			
			if exceptionObj.text.pos("Undefined message number", 1) &gt; 0 then
				exceptionObj.extendedErrorText	:=	process.getErrorText(errorCode);
			endif;
			
			raise exceptionObj;
			
			return null;
		endif;
	endif;
	
	create allObjects transient;
	self.allInstances(allObjects, 0, pIsSubclasses);
	
	if pCondition = null then
		return allObjects.size();
	else
		foreach theObject in allObjects where process.executeTransientMethod(methodObj, theObject).Boolean do
			objectCount	:=	objectCount + 1;
		endforeach;
		
		return objectCount;
	endif;
epilog
	if methodObj &lt;&gt; null then
		process.deleteTransientMethod(methodObj);
	endif;
	
	delete allObjects;
end;</source>
        <Parameter name="pCondition" type="String"/>
        <Parameter name="pIsSubclasses" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssGetAllMethods" id="e75c6dcd-8f9d-44a0-a2d1-5dfb5abaae1a">
        <source>jssGetAllMethods(pAllMethods:MethodSet io);
// --------------------------------------------------------------------------------
// Created:		18 April 2003 by cnwdad1
//
// Purpose:		Populates the specified set with the receiver's methods, plus the
//				methods inherited from all superclasses.
//
// Parameters:	pAllMethods - The method set to populate.
//
// Returns:		The populated method set.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allMethods(pAllMethods);
	
	if self.superclass &lt;&gt; null then
		self.superclass.jssGetAllMethods(pAllMethods);
	endif;
end;</source>
        <Parameter name="pAllMethods" type="MethodSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssIsGUI" id="d967373d-131b-45b2-bdbb-e78f5f05dd63">
        <source>jssIsGUI():Boolean;
// --------------------------------------------------------------------------------
// Created:		07 March 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether or not the receiver is
//				a GUI class.
//
// Parameters:	None
//
// Returns:		True if the receiver is a GUI class, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.inheritsFrom(Window);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
