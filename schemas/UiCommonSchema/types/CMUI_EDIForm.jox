    <JadeMethod name="buildMenuFileFormats" id="0af00dac-e8cc-449a-b243-f543def1cb87">
        <updating/>
        <source>buildMenuFileFormats(_cloneMaster: MenuItem; _ediData: CM_EDIData) updating;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	task				: CM_ToDoTask;
	taskDesc			: CM_ToDoTaskDesc;
	idx					: Decimal[3,1];
	lFactor 			: Real;
	lIndex,lMoveMode 	: Integer;
	lCaption			: String;
	defMenu,tmpMenu,
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 			: Integer;
	lPicture 			: Picture;
	root 				: CM_Root;
	ediFileType			: CM_EDIFileType;
	ediFileFormat		: CM_FileFormatEDI;
	canSee				: Boolean;
begin

	// ##############################################
	// Build up menu of available formats for the datas file type
	
	mnuMaster := _cloneMaster;
//	mnuMaster.visible := true;
//	mnuMaster.enabled := true;
	self.mnuLoadAsSub.visible := true;
	self.mnuLoadAsSub.caption := "Other";
	
	defMenu := self.zCloneMenu(mnuMaster, self.mnuLoadAsSub, true);
	tmpMenu := defMenu;

	foreach ediFileType in app.myRoot.allEDIFileTypes do
		if _ediData = null then
			canSee := false;
		else
//			canSee := _ediData.ediFileArray.isEmpty or (ediFileType = _ediData.ediFileArray.last.myEDIFileType);
			canSee := (_ediData.myEDIFile = null) or (ediFileType = _ediData.myEDIFile.myEDIFileType); // ccms1117 cnwrs1 29 Apr 2010
		endif;
		foreach ediFileFormat in ediFileType.allFormats do
			if ediFileFormat.noLongerUsed then
				continue;
			endif;
			//hide the default menu
			defMenu.visible := false;
			mnuChild := self.zCloneMenu(mnuMaster, tmpMenu, true);
			if ediFileFormat.name = null then
				mnuChild.caption := ediFileFormat.description;
			else
				mnuChild.caption := ediFileFormat.name;
			endif;
			mnuChild.visible := canSee;
			mnuChild.enabled := canSee;
			mnuChild.helpKeyword := 'EDI';
			mnuChild.userObject := ediFileFormat;
			tmpMenu := mnuChild;	
		endforeach;
	endforeach;
	

end;</source>
        <Parameter name="_cloneMaster" type="MenuItem"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="callOffFilter" id="eb972850-9593-427e-b182-52a4017a2ba7">
        <source>callOffFilter(ediData : CM_EDIData input) : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 September 2023
TFS#		: 60232
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	filterMessageType 	: String;
	filterMessageNum 	: String;
	filterAction 		: String;
	filterReceiver 		: String;
	filterSender 		: String;
	filterMessageID		: String;
	filterTranportMode	: String;
	filterVesselName	: String;
	filterVehicle		: String;
	filterVBSExtNum		: String;
	filterTranExpDate	: Date;
	filterGroupID		: String;
	filterOperator		: String;
	returnValue			: Boolean;
begin
	if not ediData.isKindOf(CM_EDIDataCallOff) then
		return false;
	endif;
	
	filterMessageType	:= self.tblSearch.getValueByName(ETRow_FilterMessageType).String;
	filterAction		:= self.tblSearch.getValueByName(ETRow_FilterAction).String;
	filterMessageNum 	:= self.tblSearch.getValueByName(ETRow_FilterMessageNumber).String;
	filterReceiver		:= self.tblSearch.getValueByName(ETRow_FilterReceiver).String;
	filterSender		:= self.tblSearch.getValueByName(ETRow_FilterSender).String;
	filterMessageID		:= self.tblSearch.getValueByName(ETRow_FilterMessageID).String;
	filterTranportMode  := self.tblSearch.getValueByName(ETRow_FilterReceiptTransMode).String;
	filterVesselName	:= self.tblSearch.getValueByName(ETRow_FilterVesselName).String; 
	filterVehicle		:= self.tblSearch.getValueByName(ETRow_FilterVehicle).String;
	filterVBSExtNum		:= self.tblSearch.getValueByName(ETRow_FilterVBSExtRef).String;
	filterTranExpDate	:= self.tblSearch.getValueByName(ETRow_FilterVoyageETA).Date;
	filterGroupID		:= self.tblSearch.getValueByName(ETRow_FilterCargoGrpID).String;
	filterOperator		:= self.tblSearch.getValueByName(ETRow_FilterOperator).String; // need to add filterOperator in the form //TODO
	
    if not filterMessageType.isBlank then
		if filterMessageType.toUpper() = ediData.getMessageType.toUpper() then
			returnValue := false;
		else
			returnValue := true;
		endif;		
	endif;		
	
	if not filterMessageNum.isBlank then
		if filterMessageNum.toUpper() = ediData.getMessageNumber().toUpper() and not returnValue then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;
	
	if not filterAction.isBlank then
		if filterAction.toUpper() = ediData.getAction().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;
	
	if not filterReceiver.isBlank then
		if filterReceiver.toUpper() = ediData.getReceiver().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;
	
	if not filterSender.isBlank then
		if filterSender.toUpper() = ediData.getSender().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;
	
	if not filterMessageID.isBlank then
		if filterMessageID.toUpper() = ediData.getMessageID().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;
	
	if not filterTranportMode.isBlank then
		if filterTranportMode.toUpper() = ediData.getTransportMode().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;	
		
	if not filterVesselName.isBlank then
		if self.filterVesselName.toUpper() = ediData.getVesselName().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;	
		
	if not filterVehicle.isBlank then
		if filterVehicle.toUpper() = ediData.getVehicleNumber().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;	
	
	if not filterVBSExtNum.isBlank then
		if filterVBSExtNum.toUpper() = ediData.getVBSExternalReference().toUpper() and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;		
	
	if not filterTranExpDate.isValid then
		if ediData.getVoyageETA() &gt;= filterTranExpDate and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;		
	
	if not filterGroupID.isBlank then
		if ediData.doesCargoGroupExist(filterGroupID) and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;		
	
	if not filterOperator.isBlank then
		if ediData.doesCargoOperatorExist(filterOperator) and not returnValue  then
			returnValue := false;
		else
			returnValue := true;
		endif;				
	endif;		
	
	if self.filterVoyage &lt;&gt; null then
		if ediData.isForVoyage(self.filterVoyage) and not returnValue  then
			returnValue := false;
		else
			returnValue := true;		
		endif;
	endif;
	
	return returnValue;
end;</source>
        <Parameter name="ediData" type="CM_EDIData" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
