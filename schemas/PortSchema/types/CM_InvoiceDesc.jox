    <JadeMethod name="isVoyageSpecificSeparation" id="fa6f0f2b-b4ae-49c6-8473-3fa6db63ed4d">
        <source>isVoyageSpecificSeparation(_invoiceTypeDebtorSeparation	: CM_InvTypeDebtorSeparation) : Boolean;
 // ### BUG 56925 07MAR2023 NAVAB1
vars
	
begin
	
	if _invoiceTypeDebtorSeparation = null then
		return self.isVoyageSpecific;
	endif;
	
	return _invoiceTypeDebtorSeparation.separatedByVoyage;
	
end;</source>
        <Parameter name="_invoiceTypeDebtorSeparation" type="CM_InvTypeDebtorSeparation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadSurcharges" id="de82d18c-dea4-49a2-ac00-f4e95159d704">
        <updating/>
        <source>loadSurcharges( _tempProxy : CM_InvoiceTypeSurchargeExempt; _passport : CM_Passport input )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2018	jlgndl1	Initial creation	TFS 42061
15 September 2022	navpw1 TFS 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

vars
	existing				: CM_InvoiceTypeSurchargeExempt;
	new						: CM_InvoiceTypeSurchargeExempt;
	
	tempDrSurchargeRate		: CM_DebtorSurchargeRate;
	proxyDrSurchargeRate	: CM_DebtorSurchargeRate;
	drSurchargeRate			: CM_DebtorSurchargeRate;
	
	tempExternalTax			: CM_InvoiceTypeExternalTax;
	proxyExternalTax		: CM_InvoiceTypeExternalTax;
	externalTax				: CM_InvoiceTypeExternalTax;
	
	tempAdditionalCharges	: CM_InvTypeAdditionalCharges;
	proxyAdditionalCharges	: CM_InvTypeAdditionalCharges;
	additionalCharges		: CM_InvTypeAdditionalCharges;
	
	tempCargoSurcharge		: CM_InvTypeCargoSurcharge;
	proxyCargoSurcharge		: CM_InvTypeCargoSurcharge;
	cargoSurcharge			: CM_InvTypeCargoSurcharge;
	
	tempVesselMinCharge		: CM_InvTypeVesselMinCharge;
	proxyVesselMinCharge	: CM_InvTypeVesselMinCharge;
	vesselMinCharge			: CM_InvTypeVesselMinCharge;
	
	tempDebtorMinCharge		: CM_InvTypeDebtorMinCharge;
	proxyDebtorMinCharge	: CM_InvTypeDebtorMinCharge;
	debtorMinCharge			: CM_InvTypeDebtorMinCharge;
	
	tempPilotSurcharge		: CM_InvTypePilotSurcharge;
	proxyPilotSurcharge		: CM_InvTypePilotSurcharge;
	pilotSurcharge			: CM_InvTypePilotSurcharge;
	
begin
	//first off delete any existing surcharges.
	existing := self.mySurchargeAndExemptions;
	if existing &lt;&gt; null then
		if not existing.allInvTypePilotSurcharges.isEmpty then
			existing.allInvTypePilotSurcharges.purge();
		endif;
		delete existing;
	endif;
	
	create new persistent;
	new.setForCreate( _tempProxy );
	
	foreach tempDrSurchargeRate in _tempProxy.allDebtorSurchargeRates do
		create proxyDrSurchargeRate transient;
		proxyDrSurchargeRate.setProxy(	tempDrSurchargeRate.myDebtor,	//_dr : CM_Debtor;
										new,	//_mySurAndExempt : CM_InvoiceTypeSurchargeExempt;
										tempDrSurchargeRate.mySurchargeInvoiceLineType,	//_mySurInvLineType : CM_InvoiceLineDesc;
										tempDrSurchargeRate.surchargeRate	//_surchargeRate : Decimal
										);
		app.myUtilityCA.utlCreateDrSurchargeRate( proxyDrSurchargeRate, drSurchargeRate, _passport );
		delete proxyDrSurchargeRate;
	endforeach;
	
	foreach tempExternalTax in _tempProxy.allInvTypeExternalTax do
		create proxyExternalTax transient;
		proxyExternalTax.setProxy(	tempExternalTax.externalTaxCode,	//_extTaxCode : String;
									tempExternalTax.externalTaxRule,	//_extTaxRule : Integer;
									tempExternalTax.myDebtor,	//_myDebtor : CM_Debtor;
									new,	//_mySurchargeExemption : CM_InvoiceTypeSurchargeExempt;
									tempExternalTax.rangeStart,	//_rangeStart : Real;
									tempExternalTax.rangeEnd	//_rangeEnd : Real
									);
		app.myUtilityCA.utlCreateInvTypeDrExtTax( proxyExternalTax, externalTax, _passport );
		delete proxyExternalTax;
	endforeach;
	
	foreach tempAdditionalCharges in _tempProxy.allInvTypeAdditionalCharges do
		create proxyAdditionalCharges transient;
		proxyAdditionalCharges.setProxy(	tempAdditionalCharges.allAdditionChargeInvTypes,	//_allAdditionalInvTypes : CM_InvoiceLineDescSet input;
											tempAdditionalCharges.myDebtor,	//_myDebtor : CM_Debtor;
											new,	//_mySurchargeExemption : CM_InvoiceTypeSurchargeExempt;
											tempAdditionalCharges.rangeStart,	//_rangeStart : Real;
											tempAdditionalCharges.rangeEnd	//_rangeEnd : Real
											);
		app.myUtilityCA.utlCreateInvTypeAddedFees( proxyAdditionalCharges, additionalCharges, _passport );
		delete proxyAdditionalCharges;
	endforeach;
	
	foreach tempCargoSurcharge in _tempProxy.allInvTypeCargoSurcharges do
		create proxyCargoSurcharge transient;
		proxyCargoSurcharge.setProxy(	tempCargoSurcharge.myCargoType,	//_cargoType : CM_CargoType;
										new,	//_mySurAndExempt : CM_InvoiceTypeSurchargeExempt;
										tempCargoSurcharge.myCargoSurchargeInvLineType,	//_mySurInvLineType : CM_InvoiceLineDesc;
										tempCargoSurcharge.surchargeRate,	//_surchargeRate : Decimal;
										tempCargoSurcharge.mySubCargoType,	//_cargoSubType : CM_Product;
										tempCargoSurcharge.myCommodity,	//_commodity : CM_Commodity;
										tempCargoSurcharge.allSelectedInvLineTypes	//_allSelectedInvLineDescs : CM_InvoiceLineDescSet
										);
		app.myUtilityCA.utlCreateCargoTypeSurRate( proxyCargoSurcharge, cargoSurcharge, _passport );
		delete proxyCargoSurcharge;
	endforeach;
	
	foreach tempVesselMinCharge in _tempProxy.allInvTypeVesselMinCharges do
		create proxyVesselMinCharge transient;
		proxyVesselMinCharge.setProxy(	tempVesselMinCharge.minimumChargeAmount,	//_minimumChargeAmount : Real;
										tempVesselMinCharge.myMinimumChargeInvoiceLineType,	//_myMinimumChargeInvoiceLineType : CM_InvoiceLineDesc;
										tempVesselMinCharge.myVessel,	//_myVessel : CM_Vessel;
										new	//_mySurchargesAndExemptions : CM_InvoiceTypeSurchargeExempt
										); 
		app.myUtilityCA.utlCreateVessMinimumChg( proxyVesselMinCharge, vesselMinCharge, _passport );
		delete proxyVesselMinCharge;
	endforeach;
	
	foreach tempDebtorMinCharge in _tempProxy.allInvTypeDebtorMinCharges do
		create proxyDebtorMinCharge transient;
		proxyDebtorMinCharge.setProxy(	tempDebtorMinCharge.myDebtor,	//_myDebtor : CM_Debtor;
										tempDebtorMinCharge.minimumChargeAmount,	//_minimumChargeAmount : Real;
										tempDebtorMinCharge.myMinimumChargeInvoiceLineType,	//_myMinimumChargeInvoiceLineType : CM_InvoiceLineDesc;
										new	//_mySurchargesAndExemptions : CM_InvoiceTypeSurchargeExempt
										);
		app.myUtilityCA.utlCreateDrMinimumChg( proxyDebtorMinCharge, debtorMinCharge, _passport );
		delete proxyDebtorMinCharge;
	endforeach;
	
	foreach tempPilotSurcharge in _tempProxy.allInvTypePilotSurcharges do
		create proxyPilotSurcharge transient;
		proxyPilotSurcharge.setProxy(	new,	//_surcharges : CM_InvoiceTypeSurchargeExempt;
										tempPilotSurcharge.myPilotSurchargeInvLineTypeVNR,	//_notReadyLineType : CM_InvoiceLineDesc;
										tempPilotSurcharge.myPilotSurchargeInvLineTypeRTS	//_tooSoonLineType : CM_InvoiceLineDesc
										);
		app.myUtilityCA.utlCreatePilotSurcharge( proxyPilotSurcharge, pilotSurcharge, _passport );
		delete proxyPilotSurcharge;
	endforeach;
	
epilog
	delete proxyDrSurchargeRate;
	delete proxyExternalTax;
	delete proxyAdditionalCharges;
	delete proxyCargoSurcharge;
	delete proxyVesselMinCharge;
	delete proxyDebtorMinCharge;
	delete proxyPilotSurcharge;
	
end;</source>
        <Parameter name="_tempProxy" type="CM_InvoiceTypeSurchargeExempt"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
