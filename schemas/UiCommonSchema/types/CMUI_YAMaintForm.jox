    <JadeMethod name="canAddToYA" id="513e1c38-39a8-4594-a209-3e1d71e54343">
        <source>canAddToYA(_ta : CM_TerminalArea) : Boolean;
// --------------------------------------------------------------------------------
// Created:		30 March 2010 by cnwjo3
//
// Purpose:		return true or false depending on if the area you are attempting to add in the Range table
//				is a valid Terminal Area for Yard Allocations.
//				Note, this is a quick fix for par 22883 7.8.1.  In 7.8.2 this method (or something similar)
//				should be added on all subclasses of CM_TerminalArea and just return true or false.
//				need to make a decision with help of Doug to decide which TAs are valid for YAs.
//				par 22883
//
vars

begin
//	if _ta.isKindOf(CM_YardInterchangeArea) then
	if _ta.isKindOf(CM_InterchangeArea) then	//14 Jul 2016	NDL	TFS 2111
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForRangeOverlap" id="eb9c98f4-f19a-4a61-accc-3ae553852996">
        <source>checkForRangeOverlap(_ranges: StringArray): Boolean;
//27 March 2009	cnwdw1	
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 18/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 28/07/2022	navdap1		TFS 54322 EUP - 1309 error when attempting to add an area which has already been added
vars
	locations: CM_LCSet;
	location: CM_GridController;
	topLeft, bottomRight: CM_LocationsController;
	range: String;
	ta: CM_GridArea;
	r, c: Integer;
	
	topLane : CM_RoRoController;
	bottomLane : CM_RoRoController;
	lane : CM_RoRoController;
	la : CM_RoRoLaneArea;
	
	gcArea : CM_GeneralCargoAllocRowArea;						// TFS 49453
	firstColumn, lastColumn : CM_GeneralCargoAllocController;	// TFS 49453
	lcs : CM_LCByIdExtKeyDict;									// TFS 49453
	col : CM_LocationsController;								// TFS 49453
	
	warehouse : CM_IrregularBlockArea;		// TFS 54322
	lc : CM_LocationsController;			// TFS 54322
	stop, start : Boolean;					// TFS 54322
begin
	create locations transient;
	foreach range in _ranges do
		// PAR 19308
		//if self.myTerminal.findYABlock(range, topLeft, bottomRight) then
		if self.myTerminal.findYABlock(range, topLeft, bottomRight, null) then
			if topLeft.isGridLocation then
				ta := topLeft.myTerminalArea.CM_GridArea;
				foreach r in topLeft.CM_GridController.row to bottomRight.CM_GridController.row do
					foreach c in topLeft.CM_GridController.column to bottomRight.CM_GridController.column do
						location := ta.allGridControllersByRowColumn[r, c];
						if locations.includes(location) then
							return true;
						endif;
						locations.add(location);
					endforeach;
				endforeach;
			//cnwjo3 par 23077
			elseif topLeft.isKindOf(CM_RoRoController) then  //its a roro lane
				topLane := topLeft.CM_RoRoController;
				bottomLane := bottomRight.CM_RoRoController;
				la := topLane.myTerminalArea.CM_RoRoLaneArea;
				foreach r in topLane.laneNumber to bottomLane.laneNumber do
					lane := la.allLanesByLaneNumber[r];
					if locations.includes(lane) then
						return true;
					endif;
					locations.add(lane);
				endforeach;
			// TFS 49453 start
			elseif topLeft.isKindOf(CM_GeneralCargoAllocController) then
				firstColumn := topLeft.CM_GeneralCargoAllocController;
				lastColumn := bottomRight.CM_GeneralCargoAllocController;
				//if firstColumn.myGroup &lt;&gt; lastColumn.myGroup then
				//	return true;
				//endif;
				create lcs transient;
				gcArea := firstColumn.myTerminalArea.CM_GeneralCargoAllocRowArea;
				gcArea.getAllLocationsControllersById(lcs);
				foreach col in lcs do
					if col.ident &gt;= firstColumn.ident and col.ident &lt;= lastColumn.ident then
						if locations.includes(col) then
							return true;
						endif;
						locations.add(col);
					endif;
				endforeach;
				delete lcs;
				if gcArea.doesNewRangeOverlapExisting(firstColumn, lastColumn, self.myYardAllocation) then
					return true;
				endif;
			// TFS 49453 end
			// TFS 54322 start
			elseif topLeft.isKindOf(CM_IrregularBlockController) then
				warehouse := topLeft.myTerminalArea.CM_IrregularBlockArea;
				stop := false;
				start := false;
				foreach lc in warehouse.allLocationsControllers do
					if lc = topLeft then
						start := true;
					endif;
					if start and not stop then
						if locations.includes(lc) then
							return true;
						endif;
						locations.add(lc);
					endif;
					if lc = bottomRight then
						stop := true;
					endif;
				endforeach;
			// TFS 54322 end
			else
				locations.add(topLeft);
			endif;
		endif;
	endforeach;
	
	return false;

epilog
	delete locations;
	delete lcs;				// TFS 49453
end;</source>
        <Parameter name="_ranges" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
