    <JadeMethod name="validateMe" id="768ca49e-7446-4be0-97f0-2a4e7e8357d1">
        <source>validateMe() protected;
/* ---------------------------------------------------------------------------
Created:	08 August 2008	by cnwvu1

Purpose:	ccmc 1045
        
Change Date		Who		Reason
29/07/2016		cnwma1 TFS #2447:Adding duplicate gives error
------------------------------------------------------------------------------*/
vars
	genType : CM_GeneratorType;
begin

	inheritMethod();

	if self.isNoseMounted and self.isUnderSlung then	//impossible setting, see setProxy()
	//	app.raiseCMException1( REQUIRED_FIELD, ETRow_Type, null, null);
		app.raiseCMException1( Input_required_field_Required, ETRow_Type, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.code = GeneratorTypeCodeDefault and not self.isStandAlone() then
		app.raiseCMException1( ERR_GenerTypeDefaultStandAlone, GeneratorTypeCodeDefault, null, null);
	endif;
	
	if self.pxyGetRealObject = null or self.pxyGetRealObject.code &lt;&gt; self.code then
		//duplicate tfs 2328 14/7/16		
		/*if app.myRoot.allGeneratorTypes[self.code] &lt;&gt; null then
			app.raiseCMException1(Duplicate_code_must_unique,self.code,null,null);
		endif;*/
		foreach genType in app.myRoot.allGeneratorTypes do    //29/07/2016 cnwma1 TFS #2447
			if genType.code.toUpper = self.code then
				app.raiseCMException1(Duplicate_code_must_unique,self.code,null,null);
			endif;
		endforeach;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
