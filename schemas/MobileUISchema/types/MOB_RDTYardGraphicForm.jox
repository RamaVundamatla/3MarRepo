    <JadeMethod name="updateCaption" id="2539d62e-1230-4078-ae52-962ad8a26a59">
        <updating/>
        <source>updateCaption() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2010	cnwjk3	Initial creation

*/

vars
	caption : String;
begin
	caption := self.width.String &amp; " X " &amp; self.height.String &amp; "; ";
	
	if self.myDrawingController.isLandscape then
		caption := caption &amp; "Landscape";	
	else
		caption := caption &amp; "Portrait";		
	endif;
		
	if self.myDrawingController.flipH then
		caption := caption &amp; "; Flipped Horizontally";
	endif;
	if self.myDrawingController.flipV then
		caption := caption &amp; "; Flipped Vertically";
	endif;
	
	if caption &lt;&gt; null then
		caption := caption &amp; "; ";
	endif;
	
	caption := caption &amp; "Scale: " &amp; self.myDrawingController.scaleFactor.String;
	
	self.caption := caption;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
