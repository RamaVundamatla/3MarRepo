<GUIClass name="SOP_GenerateAuthTokenForm" id="d42551cb-e735-4817-81a9-7046edb6551c">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="fraMain" id="f2a138c1-5c79-4f6c-8b98-6c2c252c69f7">
        <embedded/>
        <type name="CMUI_Frame"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblPassword" id="b4054442-fdf4-47d2-8179-0853facdda51">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblUsername" id="3c132d7e-4acf-4e70-9ebd-f008c2974733">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtPassword" id="9cf6b6a7-46fb-4777-a8d9-f4cb0c7afbce">
        <embedded/>
        <type name="CMUI_TextBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtUsername" id="1bfdb63f-623d-4423-84ce-7458e122587a">
        <embedded/>
        <type name="CMUI_TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="9c03efa5-fe07-4a74-9254-6b071e2a59f5">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	baseString		: String;
	encodedString 	: String;
begin
	
	baseString := self.txtUsername.text &amp; ':' &amp; self.txtPassword.text;
	encodedString := baseString.Binary.base64Encode();

	if self.myProxyObject &lt;&gt; null and self.myProxyObject.isKindOf(CM_LongString) then
		self.myProxyObject.CM_LongString.string := encodedString;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "Error generating token");
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setReturnString" id="de518d48-0ec1-4173-bb3f-00809feebea7">
        <updating/>
        <source>setReturnString(_str : CM_LongString input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars

begin
	_str.raiseExceptionIfNotTransient(method);
	
	self.myProxyObject := _str;
	
epilog

end;</source>
        <Parameter name="_str" type="CM_LongString" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1c784a9a-76ac-420e-a746-b00c37ad2f29">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 February 2020 08:34:57.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023880, locale);
	lblPassword.translateCaption(Xlat_0023881, locale);
	lblUsername.translateCaption(Xlat_0023882, locale);
end;</source>
    </JadeMethod>
</GUIClass>
