<GUIClass name="YRD_WorkOrderRejectForm" id="002d97e1-a3cd-44ba-92a9-c9dc098311c9">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="cmbRejectReason" id="8b3d0513-3ed1-4885-b97c-3d05d72f60fa">
        <embedded/>
        <type name="CMUI_ComboBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblRejectReason" id="00b64289-fe7a-4eed-ae9b-1046d8c35c24">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="selectedRemark" id="55189c0e-a179-4c3d-8130-e9687d2c4215">
        <embedded/>
        <type name="CM_PredefinedRemark"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="cd940048-d8a2-4ea8-9f5a-b0443f5abc3f">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars

begin

	self.permissionView		:= PmAdmWorkOrderEnquiry;
	self.permissionMaint	:= PmAdmWorkOrderEnquiry;	
	self.helpFileName 		:= HelpFile_Yard;
	self.modalResult 		:= IDCANCEL;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="82cfac15-db3e-4fd5-a57b-c50d9a62eeb2">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars

	remark : CM_PredefinedRemark;
	
begin
	self.selectedRemark := null;
	
	remark := self.cmbRejectReason.listObject.CM_PredefinedRemark;
	if remark = null then
		app.msgBox( app.getErrorString(Input_required_field_reason), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	self.selectedRemark := remark;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="782809b3-d314-4b73-a1c1-b48c1ccd0d58">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars

begin

	inheritMethod();
	
	self.width := 345;
	self.height := 125;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbRejectReason" id="289d23a2-f13c-414d-b24e-d20e50674efe">
        <source>populateCmbRejectReason();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars

	index : Integer;
	remark : CM_PredefinedRemark;

begin

	self.cmbRejectReason.clear();
	
	self.cmbRejectReason.addItem( null );
	foreach remark in app.myRoot.allPreDefinedRemarks do
		index := self.cmbRejectReason.addItem( remark.description );
		self.cmbRejectReason.itemObject[index] := remark;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="dd6db62e-f3ac-416e-b52a-f718087b1d99">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars

begin

	inheritMethod();
	
	self.selectedRemark := null;
	populateCmbRejectReason();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="aa9665b0-170d-41d9-8426-b6da70c05c08">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 October 2021 15:28:01.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024526, locale);
	lblRejectReason.translateCaption(Xlat_0024527, locale);
end;</source>
    </JadeMethod>
</GUIClass>
