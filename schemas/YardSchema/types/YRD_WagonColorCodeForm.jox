    <JadeMethod name="setupForm" id="43e83de3-8e8b-403e-b210-781247f8e774">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str			: String;
	wagon		: CM_Wagon;
begin
	self.addToolbarControls();
	inheritMethod();
	self.loadCmbDestinationPort();
	self.loadCmbFreightForward();
	self.loadCmbReleaseRequest();
	self.loadConsignee(); 										//+ cnwmd1, CCMS 1067, Par 19710
	if self.myRailAllocation &lt;&gt; null then 						//+ cnwmd1, CCMS 1067, Par 19710
		self.clColour.setColor(self.myRailAllocation.color);
	else
		self.clColour.setColor(White);
	endif;
		
	/* //- cnwmd1, CCMS 1067, Par 20211 - removed because it appears to do nothing (str is not used anywhere).
	foreach wagon in self.allWagons do
		str := str &amp; wagon.id;
		if wagon &lt;&gt; self.allWagons.last then
			str := str &amp; ', ';
		endif;
	endforeach;*/
	
	self.setCaption('Color-coding ' &amp; self.allWagons.first.id);
	self.btnSaveBase.default := true;	
end;


</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b58128d9-2d93-4de1-aa15-44c194c16bbb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009075, locale);
	clColour.translateBubbleHelp(Xlat_0012815, locale);
	lblColour.translateCaption(Xlat_0012816, locale);
	lblConsignee.translateCaption(Xlat_0014712, locale);
	lblDestination.translateCaption(Xlat_0014713, locale);
	lblFreight.translateCaption(Xlat_0014714, locale);
	lblReleaseNo.translateCaption(Xlat_0014715, locale);
end;</source>
    </JadeMethod>
</GUIClass>
