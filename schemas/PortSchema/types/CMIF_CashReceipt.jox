    <JadeMethod name="setBaseDetails" id="40d12ee6-863c-40c9-b7ab-e4bc13f93b57">
        <updating/>
        <source>setBaseDetails(_cash: CM_CashReceipt; cmifSumm: CMIF_CashTrxSummary) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	inheritMethod(_cash, cmifSumm);
	
	if _cash.myPaymentMethod &lt;&gt; null then
		paymentMethod := _cash.myPaymentMethod.description[1:30];
	endif;
	sequenceNum := _cash.sequenceNum;
	if _cash.myUser &lt;&gt; null then
		user := _cash.myUser.code;
	endif;
	
	self.chequeBank := _cash.chequeBank;
	self.chequeBranch := _cash.chequeBranch;
	self.chequeNumber := _cash.chequeNumber;
	self.chequeDate := _cash.chequeDate;
	
	self.cashAlreadyPaid := _cash.cashAlreadyAllocated;
	self.externalInvoiceNumber := _cash.externalInvoiceNumber;
	self.externalReceiptNumber := _cash.externalReceiptNumber;
	self.bolNumber := _cash.cashId2;
	self.cashPayment1 := _cash.cashPayment1;
	self.cashPayment2 := _cash.cashPayment2;
	self.customsEntryNumber := _cash.cashId3;
	self.effectiveDate := _cash.effectiveDate;
	self.myCashInvoice := _cash.myCashInvoice;
	self.myVoyage := _cash.myVoyage;
	self.totalCargoCharges := _cash.totalCargoCharges;
	
epilog

end;</source>
        <Parameter name="_cash" type="CM_CashReceipt"/>
        <Parameter name="cmifSumm" type="CMIF_CashTrxSummary"/>
    </JadeMethod>
</Class>
