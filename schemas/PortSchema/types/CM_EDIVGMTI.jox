    <JadeMethod name="propertyNotVerified" id="abc910f8-06e6-483e-aacf-d4d451455c61">
        <source>propertyNotVerified(_propName: String): Boolean;
//
//15 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
vars

begin
	if _propName = CM_EDIVGMTI::totalWeight.name then
		return true;
	elseif _propName = CM_EDIVGMTI::weightCertifiedName.name then
		return true;
	elseif _propName = CM_EDIVGMTI::weightCertifiedReference.name then
		return true;
	elseif _propName = CM_EDITrackedItem::messageMode.name then
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="031fd3cc-f929-4b1f-8633-5cd75f7c1e32">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 27/06/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
//
vars

begin
	inheritMethod(_proxyEDITI);
	self.totalWeight := _proxyEDITI.totalWeight;
	self.weightCertifiedName := _proxyEDITI.weightCertifiedName;
	self.weightCertifiedReference := _proxyEDITI.weightCertifiedReference;
	
	self.vgmAuthSignature := _proxyEDITI.vgmAuthSignature;				// TFS 4492
	self.vgmCommsType := _proxyEDITI.vgmCommsType;						// TFS 4492
	self.vgmDeterminationDT := _proxyEDITI.vgmDeterminationDT;			// TFS 4492
	self.vgmDocsIssuedDT := _proxyEDITI.vgmDocsIssuedDT;				// TFS 4492
	self.vgmDocumentDetails := _proxyEDITI.vgmDocumentDetails;			// TFS 4492
	self.vgmEDITransmission := _proxyEDITI.vgmEDITransmission;			// TFS 4492
	self.vgmElectronicMail := _proxyEDITI.vgmElectronicMail;			// TFS 4492
	self.vgmMail := _proxyEDITI.vgmMail;								// TFS 4492
	self.vgmPhone := _proxyEDITI.vgmPhone;								// TFS 4492
	self.vgmTelefax := _proxyEDITI.vgmTelefax;							// TFS 4492
	self.vgmTelephone := _proxyEDITI.vgmTelephone;						// TFS 4492
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setVGMProxy" id="572c8cff-d2a3-474b-8459-ebfaa70d47ab">
        <source>setVGMProxy(_ti : CM_TrackedItem io);
//
//19 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//27 Jun2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//09 Sep 2019	jlgsl4	TFS 46404 - SNO - update from non-null Vermas details only

vars
	container : CM_Container;			// TFS 4492

begin
	_ti.setTotalWeightVermasCert(self.totalWeight, _ti.weightCargo, _ti.weightTare, true, null, app.myPassport); // TFS 46404
//	_ti.setTotalWeight(self.totalWeight, _updateController, app.myPassport);
	//_ti.setWeightCertifiedName(self.weightCertifiedName, null, app.myPassport);				// TFS 4492
	//_ti.setWeightCertifiedReference(self.weightCertifiedReference, null, app.myPassport);		// TFS 4492
	
	if _ti.isKindOf(CM_Container) then															// TFS 4492
		container := _ti.CM_Container;															// TFS 4492
		container.setMyVGMDetailsVermas(self.weightCertifiedReference,								// TFS 4492 // TFS 46404
									self.weightCertifiedName,									// TFS 4492
									self.vgmAuthSignature,										// TFS 4492
									self.vgmCommsType,											// TFS 4492
									self.vgmDocumentDetails,									// TFS 4492
									self.vgmEDITransmission,									// TFS 4492
									self.vgmElectronicMail,										// TFS 4492
									self.vgmMail,												// TFS 4492
									self.vgmPhone,												// TFS 4492
									self.vgmTelefax,											// TFS 4492
									self.vgmTelephone,											// TFS 4492
									self.vgmDocsIssuedDT,										// TFS 4492
									self.vgmDeterminationDT, 									// TFS 4492
									null	);													// TFS 4492
	endif;
			
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
</Class>
