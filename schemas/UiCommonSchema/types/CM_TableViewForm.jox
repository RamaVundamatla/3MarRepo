// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	leftRightRatio,
	tmpTop,
	tmpBottom	: Integer;
begin
	// Position the Main splitter control

	tmpTop := self.getSptMainTop();
	//th2 PAR11063 - splitter main ratio was not accuratly being reset 
	//from users last ratio (see subsiquent use of this variable)
	leftRightRatio := self.sptMain.leftToRightRatio;
	
	if self.showToolbar then
		tmpTop := (tmpTop + self.frmToolbar.height).Integer;
	endif;
	
	sptMain.move(0, tmpTop,
					self.clientWidth,
					self.clientHeight - tmpTop - self.bottomMargin);
	self.sptMain.setLeftToRightRatio(leftRightRatio);
end;</source>
    </JadeMethod>
