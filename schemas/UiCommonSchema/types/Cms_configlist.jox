    <JadeMethod name="initTblThumb" id="1c79f33e-a521-4e36-8ff8-8dd2d5f6ed1a">
        <updating/>
        <source>initTblThumb() updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
//	idx		: Integer;
//	sheet	: JadeTableSheet;
	entDef	: EntTableDef;
	ratio	: Integer;
	
begin

//	if self.useTxtThumb then
//		return;
//	endif;

	self.fldEdit.visible 			:= true; fldEdit.width := frmDetailsBottom.width; fldEdit.height := frmDetailsBottom.height;
	self.frmDetailsBottom.visible	:= true;
	self.frmDetailsTop.visible	:= true;
	self.sptThumbEdit.visible := true;
	self.tblInputTop.visible		:= true;
	self.useFrmDetailsBottomForView := true;

	entDef := app.myController.getEntTableDef(ETDef_TIEnqHeader);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ' &amp; ETDef_TIEnqHeader &amp; ' was not found.');
		return;
	endif;
	self.tblInputTop.setEntTableDef(entDef, null, 'entTableDefSetupWarning');
	self.tblInputTop.adjustHeight(1000);

	ratio := (((self.tblInputTop.height + 10) / self.sptMain.clientHeight) * 100).Integer;

	self.sptThumbEdit.showLeftControl(100, self.isFirstActivateComplete);

end;</source>
    </JadeMethod>
