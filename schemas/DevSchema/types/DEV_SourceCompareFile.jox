    <JadeMethod name="doBrowseForFolder" id="d07f1ff8-0ca9-4156-9448-732e0a1b4cc5">
        <source>doBrowseForFolder(_folderTextBox : TextBox input; _onServer : Boolean);
/*

Purpose:			Browse for a folder, either on the server or client (Should be an app method?)

Parameters:			_onServer set to true if a server folder is required

Return Value:		Selected folder, or null if none selected

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

vars
	dlg	: CMDFileOpen;
	
begin
	create dlg transient;
	if not dlg.open() = 0 then
		// Exit as user did not select a file
		return;
	endif;
	
	_folderTextBox.text := dlg.fileName;
	_folderTextBox.tag := dlg.fileTitle;
	
epilog
	delete dlg;

end;</source>
        <Parameter name="_folderTextBox" type="TextBox" usage="input"/>
        <Parameter name="_onServer" type="Boolean"/>
    </JadeMethod>
