    <JadeMethod name="getTextTableDisplay" id="72f5906c-b86f-4f20-a06b-9d40f55c691e">
        <source>getTextTableDisplay(_obj: Object ; _etRow: EntTableRow): String;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
Changed On	By			Reason
----------	--------	------------------------------------------------------
19/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
*/

vars
	str, str1 	: String;
	contAtmos	: Boolean;
	cargoType	: CM_CargoType;
	measure		: String;					// PAR #31155
	
begin
	if _obj.isKindOf(CM_BRefItemContainer) then
		contAtmos := _obj.CM_BRefItemContainer.isControlledAtmosphere;
		cargoType := _obj.CM_BRefItemContainer.myCargoType;
	elseif _obj.isKindOf(CMIF_BookingRefItem) then  //cnwjo3 par 20615
		contAtmos := _obj.CMIF_BookingRefItem.isControlledAtmosphere;
		cargoType := _obj.CMIF_BookingRefItem.myCargoType;
	else
		cargoType := _obj.CM_BookingRefItem.myCargoType; //cnwjo3 par 20615
	endif;
	str1 := _etRow.name;
	if str1 = "isControlledAtmosphere" then
		if contAtmos = false then
			return str;
		endif;
	elseif str1 = "myHeight" then
		if cargoType &lt;&gt; null and	// 08/02/2010 cnwcs5 par22762
			not cargoType.allAttributesOnProduct.includes(ETRow_MyHeight) then
			return str;
		endif;
	elseif str1 = "myHeightString" then
		if cargoType &lt;&gt; null and	// 08/02/2010 cnwcs5 par22762
			not cargoType.allAttributesOnProduct.includes(ETRow_MyHeightString) then
			return str;
		endif;
	elseif str1 = "myLength" then
		if cargoType &lt;&gt; null and	// 08/02/2010 cnwcs5 par22762
			not cargoType.allAttributesOnProduct.includes(ETRow_MyLength) then
			return str;
		endif;
	elseif str1 = "myLengthString" then
		if cargoType &lt;&gt; null and	// 08/02/2010 cnwcs5 par22762
			not cargoType.allAttributesOnProduct.includes(ETRow_MyLengthString) then
			return str;
		endif;
	elseif str1 = "myWidth" then
		if cargoType &lt;&gt; null and	// 08/02/2010 cnwcs5 par22762
			not cargoType.allAttributesOnProduct.includes(ETRow_MyWidth) then
			return str;
		endif;
	elseif str1 = "myWidthString" then
		if cargoType &lt;&gt; null and	// 08/02/2010 cnwcs5 par22762
			not cargoType.allAttributesOnProduct.includes(ETRow_MyWidthString) then
			return str;
		endif;
	elseif str1 = "myVolume" then
		if cargoType &lt;&gt; null and	// 08/02/2010 cnwcs5 par22762	
			not cargoType.allAttributesOnProduct.includes(ETRow_MyVolume) then
			return str;
		endif;
	elseif str1 = "myWeight" then
		if cargoType &lt;&gt; null and	// 08/02/2010 cnwcs5 par22762
			not cargoType.allAttributesOnProduct.includes(ETRow_MyWeight) then
			return str;
		endif;
	elseif str1 = "myDensity" then
		if cargoType &lt;&gt; null and	// 08/02/2010 cnwcs5 par22762
			not cargoType.allAttributesOnProduct.includes(ETRow_MyDensity) then
			return str;
		endif;
	// ### TFS 52193 22Nov2021 NAVPW1
	elseif str1 = "myDensityDec" then
		if cargoType &lt;&gt; null and
			not cargoType.allAttributesOnProduct.includes(ETRow_MyDensity) then
			return str;
		endif;
	// ### TFS 52193 22Nov2021 NAVPW1
	elseif str1 = "myQuantity" then
		if cargoType &lt;&gt; null and	// 08/02/2010 cnwcs5 par22762
			not cargoType.allAttributesOnProduct.includes(ETRow_MyQuantity) then
			return str;
		endif;
	elseif str1 = "type" then
		if cargoType &lt;&gt; null and	// 08/02/2010 cnwcs5 par22762
			not cargoType.allAttributesOnProduct.includes(ETRow_MyType) then
			return str;
		endif;
	elseif str1 = "allLinkedExpBookingsInfo" then		//+cnwml2 PAR22653
	
		if _obj.isKindOf(CM_BRefItemContainer) then  //cnwrd1 10.3.2010 par 23122
			if _obj.CM_BookingRefItem.allLinkedExportBookings.size &lt; 1 then
				return str;
			endif;
		elseif _obj.isKindOf(CMIF_BookingRefItem) then  //cnwjo3 par 20615
			if _obj.CMIF_BookingRefItem.myRealBookingRefItem &lt;&gt; null then
				if _obj.CMIF_BookingRefItem.myRealBookingRefItem.allLinkedExportBookings.size &lt; 1 then
					return str;
				endif;
			endif;
		endif; //cnwrd1 10.3.2010 par 23122
	
	endif;
	
	str := app.getCargoFieldString(_obj, str1);
	if str &lt;&gt; null then
		if _obj.isKindOf(CM_BookingRefItem) and _etRow.measurementType &lt;&gt; null then								// PAR #31155
			measure := _obj.CM_BookingRefItem.getDefaultMeasurementForType(_etRow.measurementType).shortName;	// PAR #31155
			measure := Space &amp; Left_Round_Bracket &amp; measure &amp; Right_Round_Bracket;								// PAR #31155
		endif;																									// PAR #31155
		//str := _etRow.getHeading(null, null, app.myCurrentLocale) &amp; ': ' &amp; str;								// PAR #31155
		str := _etRow.getHeading(null, null, app.myCurrentLocale) &amp; measure &amp; ': ' &amp; str;						// PAR #31155
	endif;
	return str;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_etRow" type="EntTableRow"/>
        <ReturnType type="String"/>
    </JadeMethod>
