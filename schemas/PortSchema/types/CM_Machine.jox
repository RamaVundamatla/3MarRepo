    <JadeMethod name="isFaultQuestionOutstanding" id="de711e59-383f-47f3-829f-7f94b1038ea0">
        <source>isFaultQuestionOutstanding() : Boolean;
/*

Date		Who		Reason
22 May 2017	cnwer1	Initial creation TFS 995 

*/

vars
	index			: Integer;
	responseStr		: String;
	faultQuestion	: CM_FaultQuestion;
	invalidFault	: Boolean;
begin
	
	if self.allCurrentFaultQuestions.isEmpty then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject(exception, faultQuestion, invalidFault);
	
	foreach index in 1 to self.allCurrentFaultQuestions.size discreteLock  do
			faultQuestion := self.allCurrentFaultQuestions[index];
			responseStr := self.allCurrentFaultResponses[index];
			if responseStr = null then
				return true;
			endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
