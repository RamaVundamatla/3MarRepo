<Class name="CM_EDIDataVoyage" id="94710d44-b0be-4cb1-8d6f-6d328c51d2e8">
    <superclass name="CM_EDIData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="canBeDBLoaded" id="36ac83bd-72b8-4707-9bc6-c4e417d7aeae">
        <source>canBeDBLoaded(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/08/2025	navdap1		Initial creation MTN-35604 NSW - Partial Load Voyage EDI
//
vars
	result : Boolean;
	
begin
	result := inheritMethod();
	
	if not result then
		result := self.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS and self.getMyTerminal.getConfig (EdiVoyageAllowPartial).Boolean;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesVesselNameExist" id="45d83e14-48a1-4c1a-93ff-7236c534304d">
        <source>doesVesselNameExist(_vesselName: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2023	navra1	Initial creation for 57263
4  Apr 2023	navra1	57263 - MTN - EDI Advanced Search is only working on data from the first line of an EDI file - it doesn't search for other lines.
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	ediTi: CM_EDITrackedItem;
	qshipVesselTI : CM_EDIQshipsVesselTI;
	qshipMovementTI : CM_EDIQshipsMovementTI;
	qshipVoyageTI : CM_EDIQshipsVoyageTI;
	voyageCode : String;	
	terminal : CM_Terminal;
	voyage : CM_Voyage;
	vslName : String;
begin
	
	vslName := _vesselName.toUpper();				//08.01.2026 navma1 #MTN-36897
	
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIQshipsVesselTI) then
			qshipVesselTI 	:= ediTi.CM_EDIQshipsVesselTI;
			terminal 		:= qshipVesselTI.getMyTerminal;
			voyageCode 		:= qshipVesselTI.getVoyageCode();
		elseif ediTi.isKindOf(CM_EDIQshipsMovementTI) then
			qshipMovementTI := ediTi.CM_EDIQshipsMovementTI;
			terminal 		:= qshipMovementTI.getMyTerminal;
			voyageCode 		:= qshipMovementTI.getVoyageCode();
		elseif ediTi.isKindOf(CM_EDIQshipsVoyageTI) then
			qshipVoyageTI := ediTi.CM_EDIQshipsVoyageTI;
			terminal      := qshipVoyageTI.getMyTerminal();
			voyageCode    := qshipVoyageTI.getVoyageCode();
		else
			continue;
		endif;
		
		if terminal &lt;&gt; null then
			voyage := terminal.lookupVoyage(voyageCode, null, false);
			if voyage &lt;&gt; null then
				if voyage.vesselName.toUpper().compareEql(vslName, true, false, null) then		//08.01.2026 navma1 #MTN-36897
					return true;
				endif;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_vesselName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
