    <JadeMethod name="changeViews" id="b7ee8943-d250-4e96-bd66-347efc8bcfe1">
        <source>changeViews(_type : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2017	cnwns1	Initial creation
//24/01/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/

vars

begin
	if _type = CM_WeighBridgeObjType.IQ710
	or  _type = CM_WeighBridgeObjType.SeriesW	//25 May 2017	NDL	TFS 4383
	or _type = CM_WeighBridgeObjType.MT226
	or _type = CM_WeighBridgeObjType.Kubota	//05 Jul 2019	NDL	TFS 44965
	or _type = CM_WeighBridgeObjType.GenericScanAPI // ### TFS 52773 1APR2022 NAVPW1
	then
		self.myForm.tblInput1.showHideRowsByViewName( _type , CM_EntryTable.ShowHideRows, false );
	else
		self.myForm.tblInput1.showHideRowsByViewName( 'DefaultNew', CM_EntryTable.ShowHideRows, false );
	endif;
epilog

end;</source>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
