    <JadeMethod name="isCMIFDataMatch" id="8dc61e82-0d1e-440e-8f2b-e575b3b6ed10">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataString): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2023	navsp1	Initial creation TFS 56795

*/

vars

begin
	if _cmifAutoPlan.isKindOf(CMIF_YAAutoPlanNormal) then
		return	_cmifAutoPlan.CMIF_YAAutoPlanNormal.isAlternativeId_Match(_yaData);
	else
		return false;
	endif;

epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataString"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
