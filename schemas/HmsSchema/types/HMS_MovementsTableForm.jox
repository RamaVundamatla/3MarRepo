	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.setNavigatorHeading(self.caption);
	self.tblMovements.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblMovements.buildBackground();

end;</source>
