Return Value:		

Date		Who		Reason
08 Feb 2024 navhl20 ChangeRequest 62084:[62377] EUP | Retrospective Operations - [54177.010] - Road Entry
26 Feb 2024 navhl20 ChangeRequest 62084:[62632] EUP | Retrospective Operations - [54177.010] - Road Entry
*/

vars

begin
	if checkbox.visible then							//26.02.2024 navhl20 #62084[62632]
		if checkbox.value then
			self.lblDateIn.visible := true;
			self.lblTimeIn.visible := true;
			self.txtDateIn.visible := true;
			self.txtTimeIn.visible := true;
			self.lblDateIn.enabled := true;
			self.lblTimeIn.enabled := true;
			self.txtDateIn.enabled := true;
			self.txtTimeIn.enabled := true;
		else
			self.lblDateIn.visible := false;
