    <JadeMethod name="getAttrByType" id="1d5a011e-e36a-4442-ac37-f8289d9f16aa">
        <source>getAttrByType(_type : Integer) : CM_YACriteria;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars
	criteria : CM_YACriteria;	
	voyAlloc : CM_VoyageAllocation;
begin
	voyAlloc := self.getFirstAllocation();
	if voyAlloc = null then
		return null;
	endif;
	criteria := voyAlloc.getCriteriaOfTypeValue(_type);
	
	return criteria;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_YACriteria"/>
    </JadeMethod>
    <JadeMethod name="getAttrCargoType" id="08858f56-a6c2-4331-9b3f-1be448c4b83f">
        <source>getAttrCargoType() : CM_CargoType;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/


vars
	criteria : CM_YACriteria;	
begin
	
	criteria := self.getAttrByType(YACriteriaType_CargoType); 
	if criteria &lt;&gt; null then
