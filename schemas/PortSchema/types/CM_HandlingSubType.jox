    <JadeMethod name="setForCreate" id="c2a4a40e-f01b-4e7b-9fc9-7b79188fcc17">
        <updating/>
        <source>setForCreate( proxy : CM_HandlingSubType ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation

*/

vars

begin

	self.raiseExceptionIfTransient(method);
	
	self.setForUpdate(proxy);
	

epilog

end;</source>
        <Parameter name="proxy" type="CM_HandlingSubType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b47cce97-1862-4a11-9140-f3afc2c222d7">
        <updating/>
        <source>setForUpdate (proxy : CM_HandlingSubType ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

begin

	self.code := proxy.code;
	self.description := proxy.description;
	self.setIsDefault( proxy.isDefault );
	self.setNotAvailableForEntry( proxy.isNotAvailableForEntry );
	
epilog

end;</source>
        <Parameter name="proxy" type="CM_HandlingSubType"/>
    </JadeMethod>
    <JadeMethod name="setIsDefault" id="611e21a4-c653-4d90-8122-3e37dfc11d17">
        <updating/>
        <source>setIsDefault( _isDefault : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	existingDefault : CM_HandlingSubType;

begin
	
	if not self.isTransient then
		//only allowed to be one default one of each type.
		existingDefault := app.myRoot.getDefaultHandlingSubType( self.myHandlingType );
	endif;

	self.isDefault := _isDefault;
	
	if self.isTransient then
		return;
	endif;
	
	if self.isDefault and existingDefault &lt;&gt; null and existingDefault &lt;&gt; self then
		//clear the other one.
		existingDefault.setIsDefault( false );
	elseif not self.isDefault and existingDefault = null then
		app.raiseCMWarning1( Must_have_default_type, self.myHandlingType.description,null, null, null );
		self.isDefault := true;
	endif;

epilog

end;</source>
        <Parameter name="_isDefault" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setNotAvailableForEntry" id="2f9e83cb-e5e5-4f5f-8467-b4799249e654">
        <updating/>
        <source>setNotAvailableForEntry( _value : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

begin
	if not self.isTransient then
		if self.isDefault and _value then
			app.raiseCMException1(Not_make_this_item_not_avail_e, self.myHandlingType.description, null, null );
			return;
		endif;
	endif;

	self.isNotAvailableForEntry := _value;

epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="6c6f087d-a7b3-4e26-835e-a512bac5ec57">
        <updating/>
        <source>setProxy(	_code: String;
			_description: String;
			_isDefault : Boolean;
			_isNotAvailableForEntry : Boolean
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := _code.toUpper;
	self.description := _description;
	self.isDefault := _isDefault;
	self.isNotAvailableForEntry := _isNotAvailableForEntry;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isDefault" type="Boolean"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="95dd9f61-5e33-4bb3-a429-bba89cf340d9">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	product : CM_Product;
	cargoType : CM_CargoType;

begin
	
	if not self.myHandlingType.allCargoTypes.isEmpty then
		iter := self.myHandlingType.allCargoTypes.createIterator;
		while iter.next( cargoType ) do
			if cargoType.myDefHandlingSubType = self then
				app.raiseCMException2(Handl_type_more_cargo_types_ca, app.getErrorString(Code), cargoType.abbreviation, null, null);
				return;
			endif;
		endwhile;
		delete iter;
	endif;

	if not self.myHandlingType.allProducts.isEmpty then
		iter := self.myHandlingType.allProducts.createIterator;
		while iter.next( product ) do
			if product.myHandlingSubType = self then
				app.raiseCMException2(Handl_type_more_cargo_types_ca, app.getErrorString(Code), product.myCargoType.abbreviation, null, null);
				return;
			endif;
		endwhile;
		delete iter;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="fcd14627-18fe-40e1-a76b-c656f27ba265">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	handlingSubType : CM_HandlingSubType;

begin

	self.validateMe;
	
	if not self.isTransient then
		handlingSubType := app.myRoot.allHandlingSubTypes.getAtKey( self.myHandlingType, self.code );
		if handlingSubType &lt;&gt; null and handlingSubType &lt;&gt; self then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="ac026503-ad49-4364-8d66-69c6aaa27782">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation

*/

vars

begin

	self.validateMe;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="9e4f06e9-11cd-4630-b25e-8bbf8929df15">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

begin

	if self.code = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Code), null, null);
	endif;
	
	if self.description = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Description), null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
