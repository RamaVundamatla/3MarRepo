<Class name="CM_RTDeviceScanner">
    <JadeMethod name="importPLXMLReference" id="01ea31ad-d686-4076-9841-b99a30838b75">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = "myRoot" then
		return app.myRoot;
	elseif _name = "myRadioTelemetry" then
		return app.getMyTerminalDO_NOT_USE().radioTelemetry;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
