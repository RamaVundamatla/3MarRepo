    <JadeMethod name="mnuNonTranship_click" id="893ba780-79f4-46f2-86c1-9de7c7bb99c6">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuNonTranship_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2013	cnwndl1	Initial creation	Par 32162

*/

vars
	objArray : ObjectArray;
	tiSet : CM_TISet;
begin
	create objArray transient;
	create tiSet transient;
	
	self.getCurrentlySelectedTIs(tiSet);
	if not tiSet.isEmpty then
		tiSet.copy(objArray);
	endif;
	
	if not objArray.isEmpty then
		self.doMnuNonTranshipClick(objArray);
	endif;
epilog
	delete objArray;
	delete tiSet;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuPlanLoadCargo_click" id="8114b615-05b6-48f0-88e8-62b3ac82a747">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuPlanLoadCargo_click(menuItem: MenuItem input) updating;
/*

Date		Who		Reason
09 September 2015	cnwer1	Initial creation PAR 36320

*/

vars
	theTIs : CM_TIArray;
begin
	if menuItem.userObject.isKindOf(CM_LocationsController) then
		// MULTI SELECT MOVE
		//  LoadList only using this for 1 or many
		app.myMoveController.moveTrackedItemSource(self.myTerminal);
	else
		create theTIs transient;
		self.tblOnsite.allSelectedObjects.copy(theTIs);
	
		app.myMoveController.moveTrackedItemsSource(self.myTerminal,theTIs);
		
	endif;
epilog
	delete theTIs;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
