    <JadeMethod name="getSearchValueStr" id="e2dff4e1-46e1-4e1b-b015-772c6e3162fe">
        <source>getSearchValueStr(_prop : CM_QueryProperty): String;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return _prop.translateToDisplayValue(self.searchValue);

end;</source>
