    <JadeMethod name="hasDifferentLength" id="6bed3b48-ffc2-4680-a6d2-1c77ba5bf0db">
        <source>hasDifferentLength(_isoType : CM_ISOType) : Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	if _isoType.is20ftLong &lt;&gt; self.is20ftLong
	or _isoType.is30ftLong &lt;&gt; self.is30ftLong
	or _isoType.is40ftLong &lt;&gt; self.is40ftLong
	or _isoType.is45ftLong &lt;&gt; self.is45ftLong
	or _isoType.is53ftLong &lt;&gt; self.is53ftLong then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
