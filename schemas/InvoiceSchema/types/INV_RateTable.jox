    <JadeMethod name="initServiceMSG" id="fdccc4f6-9260-4d00-8437-d75cdede2f29">
        <source>initServiceMSG();
// ---------------------------------------------------------------------------
// Created:		July 2010 by cnwjre1 for par 24052, multi-select debtors and services
//
// Purpose:		initialise the service CMUI_MultiSelectGroupBox
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	---------	--------------------------------------------------
// 05/02/2025	navlw1		JIRA-33945: MTN | Add Filter MSG to Some Forms
// ---------------------------------------------------------------------------
vars
	theGroupBox : CMUI_MultiSelectFilterGroupBox; // navlw1 #JIRA-33945 05/02/2025
begin
	theGroupBox := self.msgbServices;
	theGroupBox.caption := null;
	
	// navlw1 Start #JIRA-33945 05/02/2025
	theGroupBox.myAvailableListBox.stretchHeight	:= true;
	theGroupBox.myAvailableListBox.stretchWidth		:= false;
	theGroupBox.myAvailableListBox.integralHeight	:= false;

	theGroupBox.mySelectedListBox.stretchHeight		:= true;
	theGroupBox.mySelectedListBox.stretchWidth		:= false;
	theGroupBox.mySelectedListBox.integralHeight	:= false;
	// navlw1 End #JIRA-33945 05/02/2025
	
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName := "displayService";
	theGroupBox.availableHeading := app.getErrorString(Available_services);
	theGroupBox.selectedHeading := app.getErrorString(Selected_services);
	theGroupBox.myBaseForm	:= self;
	theGroupBox.mySelectedListBox.sorted := false;
	//theGroupBox.cnEcResizeContents();
	theGroupBox.readOnly := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="initServices" id="f9cbe3b8-98f7-4aa0-9d05-39ff177038f8">
        <source>initServices();
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
vars
	service : CM_Service;
	bank : CM_Bank;
begin

	bank := self.myCurrentBank;

	self.allSelectedServices.clear;
	foreach service in bank.services where not service.isNotAvailableForEntry do
		self.allSelectedServices.add(service);
	endforeach;

epilog

end;
</source>
    </JadeMethod>
