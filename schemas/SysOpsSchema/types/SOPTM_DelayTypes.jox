    <JadeMethod name="loadComboVoyageEvents" id="2b208a3c-b508-408c-902f-310696a9eb33">
        <source>loadComboVoyageEvents();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2018	jlgndl1	Initial creation	TFS 40309

*/

vars

	form : SOP_TableMaintForm;
	combo : CMUI_ComboBox;
	iter : Iterator;
	event : CM_EventType;
	index : Integer;

begin

	form := self.myForm;
	combo := form.cmbVoyageEvent;
	
	combo.clear();
	combo.sorted := true;
	
	index := combo.addItem( " " );
	
	iter := app.myRoot.allEventTypesByCategory.createIterator;
	event := app.myRoot.allEventTypesByCategory.getAtKeyGeq(CM_EventType.VOYAGE_EVENT,0);
	if event &lt;&gt; null then
		iter.startAtObject( event );
	endif;
	while iter.next( event ) do
		if not event.isVoyageEvent then
			break;
		endif;
		index := combo.addItem( event.name );
		combo.itemObject[ index ] := event;
		if event.myDelayTypeToCreate &lt;&gt; null then
			combo.itemEnabled[ index ] := false;
		endif;
	endwhile;
	

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="1b3bb6b4-227e-467d-974a-260df599300c">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
02/04/2011 	cnwcs5		CCMS 1132 - add is not available for entry
*/
vars
	form 		: SOP_TableMaintForm;
	table		: CM_EntryTable;
	groupbox	:CMUI_MultiSelectGroupBox;
	delay 		: CM_DelayType;
begin
  	form 		:= self.myForm;
	table 		:= form.tblInput1;
	groupbox	:= form.mulSelect1;
	
	self.loadComboVoyageEvents();	//24 Aug 2018	NDL	TFS 40309
	
	table.userInputEnabled 			:= true;
	form.shtMultiSelect1.visible 	:= true;
	groupbox.userInputEnabled 		:= true;
			
	if form.mode = form.Mode_Add then
		table.clearValues;
		table.enableRowByName(ETRow_Description);
		table.enableRowByName(ETRow_IsNotAvailableForEntry);	// 02/04/2011 cnwcs5
		table.enableRowByName(ETRow_Operational);
		table.enableRowByName(ETRow_RequiresMachine);
		table.enableRowByName(ETRow_RequiresVoyage);
		table.enableRowByName(ETRow_CanScheduleInAdvance);
		table.enableRowByName(ETRow_DelayTypeOrder);
		table.enableRowByName(ETRow_MyVoyageEvent);	//24 Aug 2018	NDL	TFS 40309
		groupbox.setSelected(null);
		table.setFocus;
		table.moveFirst();
		table.gotFocus(table);	// sets case etc.
		form.fldInput.initSheetBackColors();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(form.myProxyObject.CM_DelayType);
		
		table.enableRowByName(ETRow_Code);
		table.enableRowByName(ETRow_Description);
		table.enableRowByName(ETRow_IsNotAvailableForEntry);	// 02/04/2011 cnwcs5
		table.enableRowByName(ETRow_Operational);
		table.enableRowByName(ETRow_RequiresMachine);
		table.enableRowByName(ETRow_RequiresVoyage);
		table.enableRowByName(ETRow_CanScheduleInAdvance);
		table.enableRowByName(ETRow_DelayTypeOrder);
		table.enableRowByName(ETRow_MyVoyageEvent);	//24 Aug 2018	NDL	TFS 40309
	endif;
		
	self.enableMulSelect1Contents();
	table.cnEcResizeContents();
epilog	

end;
</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="8cd5e9ab-d7f0-4766-a4d5-7a6409565afd">
        <updating/>
        <source>setCtrlsForView() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 January 2007 By cnwmo1

