    <JadeMethod name="delete" id="0628351d-e67e-4188-9221-ce9f5fc96c0f">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	self.allCargo.purge;
	delete self.myStructure;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDetailsFromController" id="fac9600a-03b6-4bd1-89e9-afa8862b65d2">
        <updating/>
        <source>setDetailsFromController(_controller : CM_VoyageROROController) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	ti : CM_TrackedItem;
	iter : Iterator;
	wsCargo : WS_PlannedCargo;
	slotDefn :  CM_ROROSlotDefnVoyage;
	aftLinkedSlot : CM_ROROLocnDefn;
begin
	self.isGeneralCargo:=false;
	if _controller.isKindOf(CM_ROROSlotController) then
		slotDefn:=_controller.CM_ROROSlotController.mySlotDefn;	
		self.tierHeight := slotDefn.myROROLocnDen.allROROSlotDefnByOrdinal.size;
		
		aftLinkedSlot:=slotDefn.myROROLocnDen.myAdjacentSlotAft;
		if aftLinkedSlot &lt;&gt; null then
			self.linked40Slot:=aftLinkedSlot.code;
		endif;
	elseif _controller.isKindOf(CM_ROROGCController) then
		self.isGeneralCargo:=true;
	endif;	
	
	if _controller.myRORORequestDischarge &lt;&gt; null then
		return;
	endif;
	
	if _controller.myRORORequestLoad &lt;&gt; null then
		return;
	endif;
	
	//Remain on board 
	
	//only adding cargo that really is remain on board i.e. not in a request
	iter:=_controller.allTrackedItems.createIterator;
	while iter.next(ti) do
		//epr par 31151 13/2/13 only remain on board show if not CC for discharge &amp; IMEX ROB or IMPORT
		if _controller.myRORORequestDischarge &lt;&gt;  null then
			continue;
		endif;
	
		if ti.getImExStatus() &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD and
			ti.getImExStatus() &lt;&gt; TI_IMEX_STATUS_IMPORT then
			continue;
		endif;
		
		create wsCargo transient;
		wsCargo.setProxyFromObject(ti);
		
		self.allCargo.add(wsCargo);
		wsCargo.tierPosition:=self.allCargo.size;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_controller" type="CM_VoyageROROController"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromLOLOController" id="9a182319-aeac-4fd9-8593-dbbdad2f986e">
        <updating/>
        <source>setDetailsFromLOLOController(_controller : CM_SlotController) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2012	cnwer1	Initial creation CCMS MES 1026 Par 29962 - LOLO

*/

vars
	iter : Iterator;
	ti : CM_TrackedItem;
	wsCargo : WS_PlannedCargo;
begin
	self.isGeneralCargo:=false;
	self.tierHeight:=1;
	
	if _controller.mySlotRequestDischarge &lt;&gt; null then
		return;
	endif;
	
	if _controller.mySlotRequestLoad &lt;&gt; null then
		return;
	endif;
		
	//only adding cargo that really is remain on board i.e. not in a request
	iter:=_controller.allTrackedItems.createIterator;
	while iter.next(ti) do
	
		create wsCargo transient;
		wsCargo.setProxyFromObject(ti);
		self.allCargo.add(wsCargo);
		
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_controller" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromRequest" id="8ffc4145-04ce-474f-821c-869f9864d8fc">
        <updating/>
        <source>setDetailsFromRequest(_roroRequest : CM_Request) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Sep 2011	cnwer1	Initial creation CCMS MES 1026
11 Jul 2012 cnwer1	PAR 29962 - changes for LOLO
*/

vars
	wle : CM_WorkListEntry;
	iter 	: Iterator;
	wsCargo : WS_PlannedCargo;
	ti  : CM_TrackedItem;
	job		: CM_VoyageJob;
	stowageConfirmation : CM_StowageConfirmation;
	request : CM_Request;
	isBackendRequest : Boolean;
begin
	isBackendRequest:=false;
	request:=_roroRequest;
	if _roroRequest.isKindOf(CM_SlotRequest) then
		if _roroRequest.CM_SlotRequest.mySlotRequestForward &lt;&gt; null then
			request:=_roroRequest.CM_SlotRequest.mySlotRequestForward;
			isBackendRequest:=true;
		endif;
	endif;
	
	/*if 	(request.isSOB) and request.myRequestLinkedDischarge &lt;&gt; null  then
		request:=request.myRequestLinkedDischarge;		
		isBackendRequest:=true;
	endif;*/
	
	job	:=request.myJob.CM_VoyageJob;
	iter:=request.allWorkListEntries.createIterator;
	self.quantity:=request.getQuantityOnRequest.Integer;  // not sure why it is  a decimal seems to be cast to integer everywhere
		
	while iter.next(wle) do
		ti:=wle.myTrackedItem;
		create wsCargo transient;
		wsCargo.setProxyFromObject(request);
		
		wsCargo.workStatus := WLE_UNACTIONED.String;
		if job &lt;&gt; null then
			if ti &lt;&gt; null then
				stowageConfirmation:= ti.getLastStowageConfirmForJob(job.CM_VoyageJob, not wle.isReceipt);
				if stowageConfirmation &lt;&gt; null or wle.isCompleteForJob then
					wsCargo.workStatus := WLE_COMPLETED.String;
				endif;
			endif;
		endif;
		
		if _roroRequest.getIsDischarge then
			wsCargo.plannedLocn := wle.locationSource;
		else
			wsCargo.plannedLocn := wle.locationTarget;
		endif;
		//if it has a job id will show twice in the tallyman job list
		if isBackendRequest then
			wsCargo.jobID :=null;
		endif;
		wsCargo.setProxyFromObject(ti);
		
		self.allCargo.add(wsCargo);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_roroRequest" type="CM_Request"/>
    </JadeMethod>
</Class>
