vars

begin
	return CMIF_TranMapController.TM_Level_08_Contents;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyTransactionMap" id="f95fbad2-2eca-4a75-be67-74f635ca7644">
        <source>getMyTransactionMap(): CM_TranMap;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self.myContentMap.imexMap.myProductMap.myProductGroupMap.myCargoTypeMap.transactionMap;

end;</source>
        <ReturnType type="CM_TranMap"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="cd19ef11-93ad-4d05-a0f8-7d30bc5a4d1e">
        <source>getPicture(form: INV_TransactionMap): Picture;

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picContents;

end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="getRealMapObject" id="80b773a3-66d0-43ee-8a15-cc8d34b20b91">
        <source>getRealMapObject(): Object;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self.myContentMap;

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="ecad5550-617f-461b-8264-2b4d28bf97cf">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;

vars
	commodityMap:      CM_CommodityMap;
	tmcCommodityGroup: CMIF_TMCCommodityGroup;
begin
	
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;
	foreach commodityMap in self.myContentMap.commoditiesMap do
		if commodityMap.commodityCode = CM_CommodityMap.Default_Commodity_Map_Key then
			create tmcCommodityGroup as CMIF_TMCCommodityDefault;
		else
			create tmcCommodityGroup;
		endif;
		tmcCommodityGroup.myCommodityMap := commodityMap;
		tmcCommodityGroup.itemName := commodityMap.getCommodityString;
		tmcCommodityGroup.extractName := commodityMap.getCommodityCode;
		tmcCommodityGroup.myGroup := self;
		tmcCommodityGroup.initialise(_groupCount);
	endforeach;
	_groupCount:=_groupCount + 1; //epr TFS 3051 2/12/16
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="cf45d0f7-d8b0-4a7e-9c0b-bf24e690e334">
        <source>setControllerCurrent();
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin
	inheritMethod();

	myTMCController.myCurrentMapContents := self.myContentMap;
	myTMCController.myCurrentMapIMEX := myTMCController.myCurrentMapContents.imexMap;
	myTMCController.myCurrentMapProduct := myTMCController.myCurrentMapIMEX.myProductMap;
	myTMCController.myCurrentMapProdGrp := myTMCController.myCurrentMapProduct.myProductGroupMap;
	myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
	myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="eaddcb11-943e-4dd8-9627-7f46f86b21f6">
        <source>setEnableObjects(form: INV_TransactionMap io);

vars

begin

	inheritMethod(form);

	form.menuSItemNew.visible := true;  // MAIN CARGO NEW MENU
	form.menuTMVnew.visible := false;  // MAIN VTMIS NEW MENU
	form.mnuTMExport.visible := false;
	form.menuMappingSetActive.visible := false;
		
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Contents;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_Contents;
	form.modePropertyNew := INV_TransactionMap.ModeProperty_Commodity;
	form.btnNew.enabled := true;
	form.menuSItemNew.enabled := true;
	form.menuSINewCommodity.visible := true;
	form.mnuCopy.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.btnCopy.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.mnuReplace.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.btnReplace.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;

	form.menuSItemDelete.visible := true;
	form.btnDelete.enabled := true;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="8315385e-7daf-4b06-9c25-4011fa643ba6">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(form);

	form.myCurrentMapContents := self.myContentMap;
	form.myCurrentMapIMEX := form.myCurrentMapContents.imexMap;
	form.myCurrentMapProduct := form.myCurrentMapIMEX.myProductMap;
	form.myCurrentMapProdGrp := form.myCurrentMapProduct.myProductGroupMap;
	form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
	form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;

	form.myTMCContent := self;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
