    <JadeMethod name="cmbDestination_lostFocus" id="85639f06-05be-4b5f-a5ae-ab0118f626a8">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDestination_lostFocus(_combobox: GTE_ComboPorts input) updating;
// ccms1031 cnwrs1 Aug 2006
vars
	voyageCombo : GTE_ComboBox;
	operatorCombo : GTE_ComboOperator;
	dischargeCombo : GTE_ComboPorts;
	tmpOperator :CM_Operator;
	tmpVoyage : CM_Voyage;
	dischargePort : CM_Port;
	// cnwjk3 PAR 15627 25/11/08
	// voyageCode : String; 
	operatorCode : String;
	pos : Integer;
	destinationCode, dischargePortCode : String;
begin
	//Check if we have something to lookup in the first place
	if _combobox.text = null then
		return;
	endif;
	
	dischargeCombo := self.getTopSheetControl(GTE_InOutForm::cmbDischarge.name).GTE_ComboPorts;
	if dischargeCombo.text &lt;&gt; null then
		return;
	endif;
	destinationCode := _combobox.getCode();
	
	voyageCombo := self.getTopSheetControl(GTE_InOutForm::cmbVoyage.name).GTE_ComboBox;
	if voyageCombo = null then
		return;
	endif;
	
	// cnwjk3 PAR 15627 25/11/08
	tmpVoyage := voyageCombo.listObject.CM_Voyage;
	
	// cnwjk3 PAR 15627 25/11/08
	/*
	pos := 1;
	voyageCode := voyageCombo.text;
	if voyageCode &lt;&gt; null then
		// strip off the description
		voyageCode := voyageCode.scanUntil(Tab, pos).trimRight;
	endif;
	*/
	
	// need to reset list
//	tmpVoyage := self.myAssistant.getVoyageFromCombo(voyageCode);

	operatorCombo := self.getTopSheetControl(GTE_InOutForm::cmbOperator.name).GTE_ComboOperator;
	if operatorCombo = null then
		return;
	endif;
	pos := 1;
	operatorCode := operatorCombo.text;
	if operatorCode &lt;&gt; null then
		// strip off the description
		operatorCode := operatorCode.scanUntil(Tab, pos).trimRight;
	endif;
	tmpOperator := self.myAssistant.getOperatorFromCombo(operatorCode);
	if tmpOperator &lt;&gt; null then
		// cnwjk3 PAR 15627 25/11/08
		dischargePort := tmpOperator.getDischargePortFromDest(destinationCode, tmpVoyage, null);
//		dischargePort := tmpOperator.getDischargePortFromDest(destinationCode, voyageCode, null);
		if dischargePort &lt;&gt; null then
			dischargeCombo.setObjectFromCode(dischargePort.code);
			self.setCellTextFromControl(dischargeCombo.mySheet, dischargeCombo, dischargeCombo.text);
		endif;
	endif;
end;
</source>
        <Parameter name="_combobox" type="GTE_ComboPorts" usage="input"/>
    </JadeMethod>
