	// Set table colours and input modes
	tblKeyDistances.accessMode:=tblKeyDistances.AccessMode_Column;
	tblKeyDistances.column:=1;
	tblKeyDistances.inputType:=tblKeyDistances.InputType_None;	
	tblKeyDistances.column:=2;
	tblKeyDistances.backColor:=White;
	tblKeyDistances.inputType:=tblKeyDistances.InputType_TextNumeric;
	tblKeyDistances.maxLength:=3;
	tblKeyDistances.alignment:=tblKeyDistances.Alignment_Right;	
	tblKeyDistances.column:=3;
	tblKeyDistances.inputType:=tblKeyDistances.InputType_None;	

	// Set enteries in "Key Distance" column
	tblKeyDistances.column:=1;
	tblKeyDistances.row:=2;
	tblKeyDistances.text:="Bridge to Bow";
	tblKeyDistances.row:=3;
	tblKeyDistances.text:="Bridge to Stern";
	tblKeyDistances.row:=4;
	tblKeyDistances.text:="Bow to foward Container Bay";
	tblKeyDistances.row:=5;
	tblKeyDistances.text:="Stern to aft Container Bay";
	tblKeyDistances.row:=6;
	tblKeyDistances.text:="Stern to Bunker";

	// Set enteries for values column
	if  self.myCurrentVesselData &lt;&gt; null then
		tblKeyDistances.column:=2;
		// BridgeToBow
		tblKeyDistances.row:=2;
		tblKeyDistances.text:= self.myCurrentVesselData.dist_BridgeToBow.String;
		// BridgeToStern
