<Class name="JadeMethod">
    <JadeMethod name="jtdGetLocalVars" id="4a1d8bee-f3fa-4f96-8dd7-2cd0d28473df">
        <source>jtdGetLocalVars() : JadeLocalVarColl ;

vars

begin
	return localVars;
end;</source>
        <ReturnType type="JadeLocalVarColl"/>
    </JadeMethod>
    <JadeMethod name="jtdGetSourceLine" id="764cbb52-1abd-49da-a06e-462d2ceca6ab">
        <source>jtdGetSourceLine(position : Integer) : String;

vars
 	i 		: Integer;
 	e		: Integer;
begin
	if source = null or source.length &lt; position then
		return "&lt;Source not available&gt;";
	endif;

	i := position;

	if i &lt; 1 then 
		return "&lt;Position not specified&gt;";
	endif;

	if position &gt; source.length then
		return "&lt;Position &gt; source length&gt;";
	endif;

	while source[i] &lt;&gt; ";" and source[i] &lt;&gt; #"0D" and i &gt; 2 do
		i := i - 1;
	endwhile;

	while source[i] = ";" or source[i] &lt; #"21" do
		i := i + 1;
		if i &gt; source.length then
			return "&lt;Forward scan couldn't find start of line&gt;";
		endif;
	endwhile;

	e := source.pos(";", i);
	if e = 0 then
		return "&lt;Forward scan couldn't find end of code line&gt;";
	endif;
	return source[i : e - i + 1];
end;</source>
        <Parameter name="position" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
