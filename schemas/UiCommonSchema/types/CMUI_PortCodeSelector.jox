    <JadeMethod name="doLocodeSearch" id="82068ae4-3a69-488b-ba96-51d8bd45bece">
        <source>doLocodeSearch() protected;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/6/2006	RBarr		CM_Port::codeDisplay attribute obsolete
// 26 May 2008	cnwkpd1		PAR #16810 - Increase in Jade table row limit
// 27 May 2009	cnwrl1		PAR 19672 - get search working for Port Code etc
// 03 Jun 2009	concms1		par 19013 - filter by israil
// 11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------

vars
	portCode	: String;
	portDesc	: String;
	index		: Integer;
	countryObj	: CM_Country;
	port		: CM_Port;
	dict		: CM_PortByCodeDict;
	iter		: Iterator;
	
begin
	self.tblLocodes.rows := 1;		// clear the current table
	self.tblLocodes.allSelectedObjects.clear();		// 04/04/2012 cnwar2 #29392
	
	portCode	:= self.txtPortCode.text.toUpper.trimBlanks();
	portDesc	:= self.txtPortDescr.text.toUpper.trimBlanks();
	countryObj 	:= self.cmbCounty.myObject.CM_Country;

	if self.isPort then
		dict := app.myRoot.allPortLocodes;
	else
		dict := app.myRoot.allPorts;
	endif;
	
	iter := dict.createIterator();
	
	if countryObj &lt;&gt; null then
		dict.startKeyGeq( countryObj.code, iter );
	endif;
	
	while iter.next( port ) do
		// Now filter by each of the selection criteria entered doing the quickest filter first.
		
		// If required only get those that are active.
		if self.chkActiveOnly.value and not port.isActiveDestination then
			continue;
		endif;
		
		// Filter by isRail
		if self.chkRailOnly.value and not port.bIsRail then	// par 19013
			continue;										// par 19013
		endif;												// par 19013
		
		// Country
		if countryObj &lt;&gt; null and port.myCountry &lt;&gt; countryObj then
			continue;
		endif;
		
		// Port Code (length of 3) if entered can be anywhere in the Port Code and any case.
		if portCode &lt;&gt; null and not port.portCode.toUpper.cnContains( portCode ) then
			continue;
		endif;
		
		// Port Description if entered can be anywhere in the Port Description and any case.
		if portDesc &lt;&gt; null and not port.description.toUpper.cnContains( portDesc ) then
			continue;
		endif;
		
		index	:= self.tblLocodes.addItem(	port.code &amp; Tab &amp;
											port.description &amp; Tab &amp;
											port.getCountryCodeForDisplay( Space ) &amp; Tab &amp;
											port.isPort.getYes() &amp; Tab &amp;
											port.bIsRail.getYes() &amp; Tab &amp; 		// par 19013
											port.isActiveDestination.getYes() );
		self.tblLocodes.accessRow( index ).itemObject	:= port;
		if index &gt;= JadeTableRowLimit then
			/* cnwrl1 22/06/2009 PAR 19980 - what it was
			app.msgBox(	'Unable to display more than ' &amp; JadeTableRowLimit.display &amp; ' rows',
						'Maximum Rows Reached',
						MsgBox_Exclamation_Mark_Icon );
			cnwrl1 22/06/2009 PAR 19980 - end of what it was */
			app.msgBox(	app.getErrorString1( Unable_To_Display_More_Rows, JadeTableRowLimit.display ),
						app.getErrorString( TableRowLimitReached ),
						MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only );
			break;
		endif;
	endwhile;
	
	self.tblLocodes.sortColumn[ 1 ]	:= 1;
	self.tblLocodes.sortAscending	:= true;
	
	self.tblLocodes.resort();
	
	/* cnwrl1 27/05/2009 PAR 19672 - start of what it was
	self.tblLocodes.rows := 1;
	
	portCode	:= self.txtPortCode.text.trimBlanks();
	portDesc	:= self.txtPortDescr.text.trimBlanks();
	
	countryObj 	:= self.cmbCounty.myObject.CM_Country;
	
	if self.isPort then
		dict := app.myRoot.allPortLocodes;
	else
		dict := app.myRoot.allPorts;
	endif;
	
	iter := dict.createIterator();
	
	if countryObj &lt;&gt; null then
		dict.startKeyGeq(countryObj.code, iter);
	endif;
	
	length := portCode.length;
	
	while iter.next(port) do
		
		if self.chkActiveOnly.value and not port.isActiveDestination then
			continue;
		endif;
			
		if length &lt;&gt; 5 then
			if countryObj &lt;&gt; null and port.myCountry &lt;&gt; countryObj then
				continue;
			endif;
		endif;
		
		if portCode &lt;&gt; null then
			if length &lt; 4 then
				if portCode[1:length] &lt;&gt; port.portCode[1:length] then
					continue;
				endif; 
			else
				if portCode &lt;&gt; port.portCode and portCode &lt;&gt; port.code then
					continue;
				endif;
			endif;
		endif;
		
		if length &lt;&gt; 5 then
			if portDesc &lt;&gt; null then
				length := portDesc.length;
				// cnwrs1 July 2006 make the search work on subStrings 
				if length &lt; 4 then
					if portDesc[1:length] &lt;&gt; port.description[1:length].toUpper() then
						length := 0;
						continue;
					endif;
				else
					if not port.description.toUpper().cnContains( portDesc ) then
						length := 0;
						continue;
					endif;
				endif;
			endif;
		endif;
		
		length	:= 0;	// cnwrl1 27/05/2009 PAR 19672 - what it was
		count	:= count + 1;
		idx		:= self.tblLocodes.addItem(	port.code &amp; Tab &amp;
											port.description &amp; Tab &amp;
											port.countryCode &amp; Tab &amp;
											port.isPort.getYesNo() );
		self.tblLocodes.accessRow( idx ).itemObject	:= port;
		if count &gt;= JadeTableRowLimit then		// PAR #16810
			app.msgBox('Unable to display more than ' &amp; JadeTableRowLimit.String &amp; ' rows', 'Maximum Rows Reached',  MsgBox_Exclamation_Mark_Icon);
			break;
		endif;
	endwhile;
	
	self.tblLocodes.sortColumn[1] := 1;
	self.tblLocodes.sortAscending := true;
	
	self.tblLocodes.resort();
	cnwrl1 27/05/2009 PAR 19672 - end of what it was */
	
epilog
	delete iter;		// PAR #26678	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="makeActive" id="b0c695be-6db3-4418-89cd-f9f0a667cf71">
        <updating/>
        <source>makeActive() protected, updating;

// Created by cnwdvb1 on 07 April 2006

vars


	port		: CM_Port;
//	obj			: Object;
//	idx			: Integer;
//	strDesc,
//	strC		: String;
	objectArray	: ObjectArray;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815

begin

	create objectArray transient;
	port := self.tblLocodes.allSelectedObjects.first.CM_Port;
	if port = null then
		return;
	endif;
	objectArray.add(port);
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxPortCodeMakeActiveInactive(objectArray, true, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Make Code Active', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

epilog
	delete objectArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
