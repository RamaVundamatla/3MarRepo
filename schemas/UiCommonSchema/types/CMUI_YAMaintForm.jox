    <JadeMethod name="hideAllOpCriteriaFrames" id="ede5c46c-d0d5-41a6-a323-b110efbd8582">
        <source>hideAllOpCriteriaFrames();
//26 February 2009	cnwdw1	
//
vars
	i: Integer;
	criteriaFrame: CMUI_YACriteriaCntl;
begin

	i := 1;
	while self.frmCriteria.getControl(i) &lt;&gt; null do
		criteriaFrame := self.frmCriteria.getControl(i).CMUI_YACriteriaCntl;
		criteriaFrame.visible := false;
		i := i + 1;
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="initializeBulkEdit" id="f1ed9309-af0e-4c34-a628-1013765d4eb3">
        <source>initializeBulkEdit();
//30 January 2009	cnwdw1	
//
vars
	firstYA, ya: CM_YardAllocation;
	firstYACriterias: CM_YACriteriaByPriorityDict;
	criteria, firstYACriteria: CM_YACriteria;
	criteriaFrame: CMUI_YACriteriaCntl;
	saveChangeMethod: String;
	match: Boolean;
	colorMatch: Boolean;
	index	: Integer;
	
begin
	firstYA := self.allBulkEditYAs.first;
	firstYACriterias := firstYA.allCriteria;
	// Look at all the operational criteria already added to the form,
	// and if all the selected YAs have the same value for the criteria, then let user edit it
	while true do
		index := index + 1;
		criteriaFrame := self.frmCriteria.getControl( index );
		if criteriaFrame = null then
			break;
		endif;
		criteriaFrame.enabled := false;  
		criteriaFrame.visible := false;  
		firstYACriteria := firstYA.getCriteriaOfType(criteriaFrame.getCriteriaType());
		if firstYACriteria &lt;&gt; null then
			match := true;
			foreach ya in self.allBulkEditYAs do
				criteria := ya.getCriteriaOfType(criteriaFrame.getCriteriaType());
				if criteria = null or not criteria.match(firstYACriteria) then
					match := false;
					break;
				endif;
			endforeach;
			if match then
				criteriaFrame.enabled := true;  
				criteriaFrame.visible := true;  
				criteriaFrame.formCriteriaChangeMethodName := null;  // prevent invoke of criteria change method
				criteriaFrame.setCriteria( firstYACriteria );
				criteriaFrame.formCriteriaChangeMethodName := saveChangeMethod;
			endif;
		endif;
	endwhile;

	// If colour is same for all YA's then let it be editted
	colorMatch := true;
	foreach ya in self.allBulkEditYAs do
		if ya.color &lt;&gt; self.allBulkEditYAs.first.color then
			colorMatch := false;
			break;
		endif;
	endforeach;		
	self.lblYAColour.visible := colorMatch;
	self.clrYAColour.visible := colorMatch;
	self.clrYAColour.setColor(self.allBulkEditYAs.first.color);
	
	self.txtGroupName.visible := false;
	self.lblGroupName.visible := false;
	self.grpTemplate.visible := false;
	
	//07/05/2009 cnwdz2 par19180
	foreach criteria in firstYA.allCriteria do
		if criteria.myYACriteriaType.isKindOf(CM_YATypeImexStatus) then
			if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 0 then
				if criteria.myYAData.CM_YADataObjects.allObjects.first.isKindOf(CM_IMEXStatus) then
					self.cmbIMEX.listObject := criteria.myYAData.CM_YADataObjects.allObjects.first.CM_IMEXStatus;
					break;
				endif;
			endif;
		endif;
	endforeach;

	self.cmbIMEX.enabled := false;	
	self.btnFindImex.enabled := false;
	self.shtOptions.enabled := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initializeControls" id="220401dc-5fa5-42b4-bd7d-c2b3fa4ec392">
        <updating/>
        <source>initializeControls() updating;
//04 August 2008	cnwdw1	
//
// 10 Jun 2013	cnwcs5	par 31712 - deleted btnYACritEdit
//05 July 2022 navds20 	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
vars

begin
	self.savedFormHeight 			:= self.height;
	self.btnCancelBase.visible 		:= false;
	self.btnSaveBase.visible 		:= false;
	self.frmToolbarBtns.top 		:= -1000;	// move out of visible area
	self.btnTmplCritEdit.enabled 	:= true;
	
	//  Remove these fields?
	self.frmBody.visible 			:= false;
	self.frmFooter.visible 			:= false;
	self.txtYADescription.visible 	:= false;
	self.lblYADescription.visible 	:= false;
	self.txtPriorityAdj.visible 	:= false;
	self.frmCriteria.visible 		:= false;
	self.shtLocation.visible 		:= false;    
	
	self.cmbIMEX.clear();
	self.cmbIMEX.listCollection(app.myRoot.allImexStatuses,	true, Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	
	self.resizeForCriteria(self.frmCriteria.height);  // PAR 19462

	if self.isKindOf(CMUI_ObjectCriteriaLineForm) and self.CMUI_ObjectCriteriaLineForm.context = CM_ObjectMatchCriteria.VvrPackageInt or self.isKindOf(CMUI_ObjectCriteriaLineForm) and self.CMUI_ObjectCriteriaLineForm.context = CM_ObjectMatchCriteria.StopCriteriaInt  then	// 5/3/18 MAP TFS37340 //05/07/2022 Navds20 TFS 53862
		return;
	endif;

	self.allYATemplates.clear();
	self.getTerminal.allYATemplates.copy(self.allYATemplates);
	self.populateTemplates();
	
	self.optExpiryDate.caption := null;

	cmbAllowOthers.itemData[cmbAllowOthers.addItem(YAOverlap_AlwaysStr)]		:=	YAOverlap_Always;
	cmbAllowOthers.itemData[cmbAllowOthers.addItem(YAOverlap_NeverStr)]			:=	YAOverlap_Never;
	cmbAllowOthers.itemData[cmbAllowOthers.addItem(YAOverlap_SometimesStr)]		:=	YAOverlap_Sometimes;
	cmbAllowOthers.itemData[cmbAllowOthers.addItem(YAOverlap_LastResortStr)]	:=	YAOverlap_LastResort;
	
	cmbNoLocation.itemData[cmbNoLocation.addItem(YANoLocation_ContinueStr)]		:=	YANoLocation_Continue;
	cmbNoLocation.itemData[cmbNoLocation.addItem(YANoLocation_StopStr)]			:=	YANoLocation_Stop;

	cmbOverstowRule.displayCollection(self.getTerminal.allYAOverstowRules, true, 0, null, "None");

	cmbFillOptionIn.itemData[cmbFillOptionIn.addItem(YAFillOption_InOrderStr)]			:=	YAFillOption_InOrder;
	cmbFillOptionIn.itemData[cmbFillOptionIn.addItem(YAFillOption_AlternatingStr)]		:=	YAFillOption_Alternating;
	cmbFillOptionIn.itemData[cmbFillOptionIn.addItem(YAFillOption_FIFOStr)]				:=	YAFillOption_FIFO;

	cmbFillOptionOut.itemData[cmbFillOptionOut.addItem(YAFillOption_InOrderStr)]		:=	YAFillOption_InOrder;
	cmbFillOptionOut.itemData[cmbFillOptionOut.addItem(YAFillOption_AlternatingStr)]	:=	YAFillOption_Alternating;
	cmbFillOptionOut.itemData[cmbFillOptionOut.addItem(YAFillOption_FIFOStr)]			:=	YAFillOption_FIFO;
	cmbFillOptionOut.itemData[cmbFillOptionOut.addItem(YAFillOption_BestPickStr)]		:=	YAFillOption_BestPick;

	//cnwjo3 par 24145
	self.cmbDisplayHatche.itemData[self.cmbDisplayHatche.addItem(app.getErrorString(Yes))] := true.Integer;
	self.cmbDisplayHatche.itemData[self.cmbDisplayHatche.addItem(app.getErrorString(No))] := false.Integer;
	
	self.cmbMultiRange.itemData[self.cmbMultiRange.addItem(app.getErrorString(Yes))] := true.Integer;		//15 Jun 2016	NDL	TFS 2172
	self.cmbMultiRange.itemData[self.cmbMultiRange.addItem(app.getErrorString(No))] := false.Integer;		//15 Jun 2016	NDL	TFS 2172
end;</source>
    </JadeMethod>
