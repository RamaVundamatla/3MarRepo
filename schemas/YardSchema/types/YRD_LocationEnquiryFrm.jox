    <JadeMethod name="showNumRowsShown" id="124bdcf7-24f4-4559-b6f1-9fe0dbb6fdd4">
        <updating/>
        <source>showNumRowsShown() updating;
// -------------------------------------------
// Created 04 October 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();
//	if self.filterTerminalArea = null then
		self.txtHeader.text := self.staMain.caption;
//	endif;
	//jlier JIRA-35555 24/7/25
	self.frmStatusLine.myFrameCaption.caption := "Selected: " &amp; self.tblData.allSelectedObjects.size.String;
end;</source>
