    <JadeMethod name="getExpandedForByCriteriaList" id="1ff810d1-9f9e-431e-b815-54c969279de7">
        <source>getExpandedForByCriteriaList( _expandedObjects : ObjectSet input; _vehicle : CM_Vehicle; _allItems : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwndl1	Initial creation	TFS 3123

*/

vars

	vehicleIndex : Integer;
	index : Integer;
	obj : Object;

begin

	if not _allItems  and _vehicle = null then
		// trying to do just one vehicle but no vehicle nominated, nothing to check.
		return;
	endif;
	if not self.chkCargoAttr.value or self.myTerminal.allRoadOpsDisplayCriteria.size &lt; 1 then
		//Not using criteria to sort the list, nothing special to do
		return;
	endif;
	
	if _allItems then
		// doing everything, probably a 'form' refresh
		foreach index in 1 to self.lstJobs.listCount do
			obj := self.lstJobs.itemObject[index];
			if obj &lt;&gt; null then
				if self.lstJobs.itemExpanded[index] then
					_expandedObjects.add(obj);
				elseif self.lstJobs.itemVisible(index) then
					_expandedObjects.add(obj);  // and visible wles
				endif;
			endif;
		endforeach;
		
	elseif _vehicle &lt;&gt; null then
		//just doing one vehicle.
		vehicleIndex := self.lstJobs.findObject( _vehicle );	
		if vehicleIndex &lt; 1 then
			// vehicle not already in the list, nothing to check.
			return;
		endif;
		
		if not self.lstJobs.itemExpanded[vehicleIndex] then
			// vehicle in the list but completely collapsed.
			return;
		endif;
		
		foreach index in vehicleIndex to self.lstJobs.listCount do
			obj := self.lstJobs.itemObject[index];
			if obj &lt;&gt; null then
				if obj.isKindOf( CM_Vehicle) and obj.CM_Vehicle &lt;&gt; _vehicle then
					break;
				endif;
				if self.lstJobs.itemExpanded[index] then
					_expandedObjects.add(obj);
				elseif self.lstJobs.itemVisible(index) then
					_expandedObjects.add(obj);  // and visible wles
				endif;
			endif;
		endforeach;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_expandedObjects" type="ObjectSet" usage="input"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_allItems" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLocationForVehicleMove_TI" id="659f7bbe-20c4-49ba-9c1c-4b2f4297fa00">
        <source>getLocationForVehicleMove_TI(_ti :CM_TrackedItem; _vehicle :CM_Vehicle; _in :Boolean):CM_YardController protected;
// ---------------------------------------------------------------------------
// Created:     03 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/06/2010	cnwcs5		par 24292 - change of parameter
// ---------------------------------------------------------------------------
vars
	location	:CM_LocationsController;
	ta			:CM_TerminalArea;
	icArea		:CM_InterchangeArea;

begin
	if _ti = null then		// director task
		return null;
	endif;
	
	if _ti.directDelivery then	//30 Jan 2013	NDL	Par 31102
		location := _ti.getYardLocationForVehicleForDD();
		
	elseif _in then
		// where is the tracked item queued to
		location := _ti.getPrimaryLocation(QUEUE_MODE);
		
	else
		location := _ti.myPrimaryActualLocation;
		
	endif;
	
	if location = null then
		return null;	// not queued anywhere
	endif;

	return location.getLocationForVehicleMove (_vehicle);	// par 24292
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_in" type="Boolean"/>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getLocationForVehicleMove_WLE" id="adb4693c-b064-4549-9dbb-76e52f851961">
        <source>getLocationForVehicleMove_WLE(_wle :CM_WorkListEntry):CM_YardController protected;
// ---------------------------------------------------------------------------
// Created:     03 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/06/2010	cnwcs5		par 24292 - change of paremeters in method being called
// ---------------------------------------------------------------------------
vars
	location	:CM_LocationsController;
	ta			:CM_TerminalArea;
	icArea		:CM_InterchangeArea;
	ti 			:CM_TrackedItem;
begin
	// where is the tracked item queued to
	location := _wle.getLocationForMode(QUEUE_MODE);
	
	//30 Jan 2013	NDL	Par 31102
	if _wle.status = WLE_UNACTIONED and _wle.isDirectDelivery() then
		ti := _wle.myTrackedItem;
		if ti &lt;&gt; null then
			location := ti.getYardLocationForVehicleForDD();
		endif;
	endif;
	
	if location = null then
		return null;	// not queued anywhere
	endif;

	return location.getLocationForVehicleMove (_wle.getJobVehicle);	// par 24292
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getMenu" id="e86b4d93-02dc-4792-b428-7c1fdf351eb7">
        <source>getMenu(_menuType: String input): MenuItem;
/*

Purpose:		Don't delete it isn't referenced but is called from a object.sendMessageWithParameter	


Return Value:		


Date		Who		Reason
04 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _menuType = CMUI_GridAreaStatusLine.MenuType_DISPLAY then
		return self.mnuDisplay;
	elseif _menuType = CMUI_GridAreaStatusLine.MenuType_MOVE then
		return self.mnuMove;
	elseif _menuType = CMUI_GridAreaStatusLine.MenuType_OTHER then
		return  self.mnuOther;
	endif;


epilog

end;</source>
        <Parameter name="_menuType" type="String" usage="input"/>
        <ReturnType type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="getTurnaroundReason" id="b706d38a-4d0c-4c2d-be12-48d1e1c8e695">
        <source>getTurnaroundReason(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwrd1	Initial creation
// cnwrd1 par 22624 3.5.2010
*/
vars

	inputBox	: CMUI_InputBox;
	numHours	: Integer;
	errorSet	: CM_ErrorSet;
	theError	: CM_Error;
	result 		: String;
begin

	create inputBox transient;
	create errorSet transient;
	inputBox.init(	app.getErrorString( Turnaround_reason ), app.getErrorString( Road_turnaround_reason),
					'', 30, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, false);
	
	//inputBox.btnCancel.visible := false;
	inputBox.myTerminal := self.myTerminal;
	//inputBox.btnOk.left := inputBox.btnCancel.left;
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return '';
	endif;
	
	result := inputBox.txtInput.text.String;

	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeighFormObjects" id="36d91afb-ee00-48e1-a108-a2040c94ffea">
        <source>getWeighFormObjects(_obj: CM_Object; _objArray: ObjectArray input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation	Par 33268
08 Jan 2018	NDL	TFS 36437
*/

vars

	errMsg : String;

begin

	if _obj &lt;&gt; null then
		_objArray.addExclusive(_obj);
		_obj.isWeighBridgeWeighable(_objArray,errMsg);
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForExit" id="cb6aa77b-f7ec-4ebe-8a0c-85b409ae96e8">
        <updating/>
        <source>getXMLSettingsForExit(): String updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	theXML : String;
	
begin

	theXML := inheritMethod();

	return theXML;


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="735f6030-a794-4d74-a056-670e6cfdbe63">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
Purpose:			
Return Value:		

Date		Who		Reason
07 September 2006	cnwer1	Initial creation - PAR#xxxx
26 August 2009		cnwcs5	ccms 1061 - road ops form changes
*/
vars
	xml,widthStr,tmpStr,sortStr, str, strSelected : String;
	hideMacro 		: Boolean;
	obj 			: CMIF_RoadOpObject;
	table 			: CM_DataTable;
	gate			: CM_Gate;
	area			: CM_TerminalArea;
	operator        : CM_Operator;
	invalidObject	: Boolean;	
	userWindow		: CM_UserWindow;
	boldReqPower	: Boolean;
	mnu				: Object;
	
begin
	xml := inheritMethod();
	
	if self.openedFromSatelliteView then
		userWindow := app.getUserWindow(self.name, false);

		if userWindow &lt;&gt; null then
			xml := userWindow.xmlInfo;
			return xml;
		endif;
	endif;
	
	
	foreach obj in self.myRoadOpController.allCMIFRoadOpObjects discreteLock do	
		table 		:= obj.myDataTable;
		
		if table.allTblDataEntRows.isEmpty then
			continue;
		endif;
		
		tmpStr 		:= table.getXMLStrForColItems();
		widthStr	:= table.getXMLStrForColWidths();
		sortStr 	:= table.getXMLStrForColSort();
		
		// 03/09/2014 cnwar2 #34651
		foreach mnu in obj.CMIF_RoadOpObject.allMenuItems do
			if mnu.MenuItem.name = YRD_RoadOperationsForm::mnuBoldRequiresPower.name then
				boldReqPower := mnu.MenuItem.checked;
			endif;
		endforeach;
		
		xml := xml &amp; 
				global.formatAsXMLPrefix(CM_DataTable.XMLTag_Table &amp; obj.getAreaTypeName) &amp;
				global.formatAsXMLPrefix(CM_DataTable.XMLTag_EntTblDef &amp; table.myEntTableDef.name) &amp;			
				tmpStr &amp;
				global.formatAsXML(CM_DataTable.XMLTag_ColWidth, widthStr) &amp;
				global.formatAsXML(CM_DataTable.XMLTag_SortOrder, sortStr) &amp;
				global.formatAsXMLSuffix(CM_DataTable.XMLTag_EntTblDef &amp; table.myEntTableDef.name) &amp;
				global.formatAsXML(XML_HighlightReqPower, boldReqPower.String) &amp;	// 03/09/2014 cnwar2 #34651								
				global.formatAsXMLSuffix(CM_DataTable.XMLTag_Table &amp; obj.getAreaTypeName);
	endforeach;
				
	// NOTE if these menus have a caption saying SHOW it means that the item is hidden	
	xml := xml &amp; 
			global.formatAsXML(XML_Tiled, self.chkPrefTiled.value.String)&amp; 
			global.formatAsXML(XML_Vehicle_Area,self.chkPrefTree.value.String)&amp;  
			global.formatAsXML(XML_Macro, self.chkPrefMacro.value.String)&amp; 
			global.formatAsXML(XML_Pregate_Area,self.chkPrefPreGate.value.String)&amp; 
			global.formatAsXML(XML_GateIn_Area,self.chkPrefIn.value.String)&amp;    
			global.formatAsXML(XML_Yard_Area,self.chkPrefYard.value.String)&amp;  
			global.formatAsXML(XML_GateOut_Area,self.chkPrefOut.value.String) &amp;
			global.formatAsXML(XML_List_Order_Attr, self.chkCargoAttr.value.String) &amp; //02 Dec 2016	NDL	TFS 2995/2638
			global.formatAsXML(XML_List_Order_Time, self.optArriveTime.value.String) &amp; //02 Dec 2016	NDL	TFS 2995/2638
			global.formatAsXML(XML_List_Order_Vehicle, self.optVehicleID.value.String) &amp;
			global.formatAsXML(XML_List_GroupBy_None, self.optNone.value.String)&amp;//11 Jan 2022 NAVLW TFS# 52455
			global.formatAsXML(XML_List_GroupBy_Gate, self.optGate.value.String)&amp;//11 Jan 2022 NAVLW TFS# 52455
			global.formatAsXML(XML_List_GroupBy_Operator, self.optOperator.value.String)&amp;//11 Jan 2022 NAVLW TFS# 52455
			global.formatAsXML(XML_Inclu_GateOperator_Label, self.chkIncludeGateInLabel.value.String);//03 Feb 2022 NAVLW1 TFS# 52772

//	save selected gates
	if not self.allGates.isEmpty then
		strSelected	:= null;
		str 		:= self.formatAsXMLPrefix(self.XML_Selected_Gates);
		
		on Exception do app.handleDeletedObject (exception, gate, invalidObject);
		
		foreach gate in self.allGates do
			if strSelected &lt;&gt; null then
				strSelected := strSelected &amp; ',' &amp; gate.getOidString;
			else
				strSelected := strSelected &amp; gate.getOidString;
			endif;
			// if gate is invalid we will end up here - strSelected not updated
		endforeach;
		
		str := str &amp; strSelected &amp; self.formatAsXMLSuffix (self.XML_Selected_Gates);
		
		xml := xml &amp; str;
	endif;
	
/// save selected interchange areas
	if not self.allInterchangeAreas.isEmpty then
		strSelected	:= null;
		str 		:= self.formatAsXMLPrefix(self.XML_Selected_Areas);
		
		on Exception do null;
		on Exception do app.handleDeletedObject (exception, area, invalidObject);
		
		foreach area in self.allInterchangeAreas do
			if strSelected &lt;&gt; null then
				strSelected := strSelected &amp; ',' &amp; area.getOidString;
			else
				strSelected := strSelected &amp; area.getOidString;
			endif;
			// if we have an exception we will ned up here
		endforeach;
		
		str := str &amp; strSelected &amp; self.formatAsXMLSuffix (self.XML_Selected_Areas);
		
		xml := xml &amp; str;
	endif;
	
	// save selected operators NAVLW1 #TFS 52455
	if not self.allOperators.isEmpty then
		strSelected	:= null;
		str 		:= self.formatAsXMLPrefix(self.XML_Selected_Operators);
		
		on Exception do null;
		on Exception do app.handleDeletedObject (exception, operator, invalidObject);
		
		foreach operator in self.allOperators do
			if strSelected &lt;&gt; null then
				strSelected := strSelected &amp; ',' &amp; operator.getOidString;
			else
				strSelected := strSelected &amp; operator.getOidString;
			endif;
		endforeach;
		
		str := str &amp; strSelected &amp; self.formatAsXMLSuffix (self.XML_Selected_Operators);
		
		xml := xml &amp; str;
	endif;
	return xml; // 04 Feb 2022 NAVLW1 TFS# 52769 
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="66f798da-fd58-4d78-a717-8136d9b27e50">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
/*
Purpose:			
Return Value:		

Date				Who		Reason
06 September 2006	cnwer1	Initial creation - PAR#xxxx
10 Octobe    2006	cnwer1	PAR 12703
26 August 2009		cnwcs5	ccms 1061 - road ops form changes
08 June 2010		cnwcs5	prevent exception
22/11/2017 			cnwma1  TFS #7828 QNS - System buffering
03 Feb 2022 		NAVLW1	TFS #52772 STWR - Review of 52455 (Include Gate/Operator in Label Button not working)
*/
vars
	xml, xmlValue, str	: String;
	blnValue, invalid		: Boolean;
	userWindow					: CM_UserWindow;
	areas 						: IntegerArray;
	values 						: BooleanArray;
	tokens						: StringArray;
	startPos 					: Integer;
	cmifRoadOpObject 			: CMIF_RoadOpObject;
	stageTable 					: CM_DataTable;
	obj							: Object;
begin
	userWindow := app.getUserWindow(self.name, false);

	if userWindow &lt;&gt; null then
		xml := userWindow.xmlInfo;
	else
		// nothing save
		return;
	endif;
	
	foreach cmifRoadOpObject in self.myRoadOpController.allCMIFRoadOpObjects discreteLock do	
		stageTable:=cmifRoadOpObject.myDataTable;
		startPos := 1;
	
		xmlValue := xml.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_Table &amp; cmifRoadOpObject.getAreaTypeName, startPos);
		
		if xmlValue &lt;&gt; null then
			stageTable.setColumnsFromXMLStr(xmlValue);
			
			// 03/09/2014 cnwar2 #34651
			str := xmlValue.cnEcGetTagValueOfName(XML_HighlightReqPower);
			blnValue := false;
			if str &lt;&gt; null then
				blnValue := str.Boolean;
				cmifRoadOpObject.setupBoldPowerOption(self.mnuBoldRequiresPower);
				foreach obj in cmifRoadOpObject.allMenuItems do
					if obj.MenuItem.name = YRD_RoadOperationsForm::mnuBoldRequiresPower.name then
						obj.MenuItem.checked := blnValue;
					endif;	
				endforeach;
			endif;
		endif;
	endforeach;	
	
	create areas transient;
	create values transient;
	
// 	Tiled
	xmlValue := xml.cnEcGetTagValueOfName(XML_Tiled);
 	blnValue := true;
	
 	if xmlValue &lt;&gt; null then
 		blnValue := xmlValue.Boolean;
		
		self.chkPrefTiled.value:=blnValue;
		self.myRoadOpController.setTiled(blnValue);					//+cnwml2 PAR21536
 	endif;
	
//	Show vehicle list
	xmlValue := xml.cnEcGetTagValueOfName(XML_Vehicle_Area);
 	blnValue := true;
 	if xmlValue &lt;&gt; null then
 		blnValue := xmlValue.Boolean;
		self.chkPrefTree.value	:= blnValue;
		self.dkcVehicles.visible:= blnValue;
 	endif;
	
// 	Vehicle Tree Order
	xmlValue 			:= xml.cnEcGetTagValueOfName (XML_List_Order_Vehicle);
	blnValue			:= xmlValue.Boolean;
	optVehicleID.value	:= blnValue;
	
	 //02 Dec 2016	NDL	TFS 2995/2638
	xmlValue 			:= xml.cnEcGetTagValueOfName (XML_List_Order_Attr);
	blnValue			:= xmlValue.Boolean;
	chkCargoAttr.value	:= blnValue;
	chkCargoAttr.click(chkCargoAttr);
	 //02 Dec 2016	NDL	TFS 2995/2638
	xmlValue 			:= xml.cnEcGetTagValueOfName (XML_List_Order_Time);
	blnValue			:= xmlValue.Boolean;
	optArriveTime.value	:= blnValue;
	
	//11 Jan 2022 NAVLW	TFS# 52455
	xmlValue 			:= xml.cnEcGetTagValueOfName (XML_List_GroupBy_None);
	blnValue			:= xmlValue.Boolean;
	optNone.value		:= blnValue;
	
	//11 Jan 2022 NAVLW	TFS# 52455
	xmlValue 			:= xml.cnEcGetTagValueOfName (XML_List_GroupBy_Gate);
	blnValue			:= xmlValue.Boolean;
	optGate.value		:= blnValue;
	
	//11 Jan 2022 NAVLW	TFS# 52455
	xmlValue 			:= xml.cnEcGetTagValueOfName (XML_List_GroupBy_Operator);
	blnValue			:= xmlValue.Boolean;
	optOperator.value	:= blnValue;
	
	//03 Feb 2022 NAVLW	TFS# 52772
	xmlValue 			:= xml.cnEcGetTagValueOfName (XML_Inclu_GateOperator_Label);
	blnValue			:= xmlValue.Boolean;
	chkIncludeGateInLabel.value	:= blnValue;
	
	
//	Show macro pane
	xmlValue := xml.cnEcGetTagValueOfName(XML_Macro);
 	blnValue := true;
 	if xmlValue &lt;&gt; null then
 		blnValue := xmlValue.Boolean;
		self.chkPrefMacro.value :=blnValue;
		self.dkbMacro.visible := blnValue;    //22/11/2017 cnwma1 TFS #7828
 	endif;
	areas.add(CMIF_RoadOpController.Macro);
	values.add(blnValue);

//	Show pre-gate
	xmlValue := xml.cnEcGetTagValueOfName(XML_Pregate_Area);
 	blnValue := true;
 	if xmlValue &lt;&gt; null then
 		blnValue := xmlValue.Boolean;
		self.chkPrefPreGate.value:=blnValue;
 	endif;
	areas.add(RoadOpsForm_PreGate);
	values.add(blnValue);
//	Show gate-in	
	xmlValue := xml.cnEcGetTagValueOfName(XML_GateIn_Area);
 	blnValue := true;
 	if xmlValue &lt;&gt; null then
 		blnValue := xmlValue.Boolean;
		self.chkPrefIn.value:=blnValue;
 	endif;
	areas.add(RoadOpsForm_GateIn);
	values.add(blnValue);
	
	xmlValue := xml.cnEcGetTagValueOfName(XML_GateOut_Area);
 	blnValue := true;
 	if xmlValue &lt;&gt; null then
 		blnValue := xmlValue.Boolean;
		self.chkPrefOut.value:=blnValue;
 	endif;	
	areas.add(RoadOpsForm_GateOut);
	values.add(blnValue);
	
//	show yard	
	xmlValue := xml.cnEcGetTagValueOfName(XML_Yard_Area);
 	blnValue := true;
 	if xmlValue &lt;&gt; null then
 		blnValue := xmlValue.Boolean;
		self.chkPrefYard.value:=blnValue;
 	endif;	
	areas.add(RoadOpsForm_Yard);
	values.add(blnValue);
	
	//self.myRoadOpController.setTiled(blnValue);					//-cnwml2 PAR21536
	self.myRoadOpController.doShowHideAreas(areas,values);
		
//	Restore saved gates
	on Exception do app.handleDeletedObject (exception, obj, invalid);
	create tokens transient;
	
	xmlValue	:= xml.cnEcGetTagValueOfName(XML_Selected_Gates);
	xmlValue.getTokensForDelimiter (',', tokens);
	
	foreach str in tokens do
		if str = null then
			continue;
		endif;
		
		invalid	:= false;
		obj 	:= str.asOid; 
		if obj = null then
			continue;
		endif;		
		str 	:= obj.getOidString;	// if invalid causes exception
		if invalid or obj.CM_Gate.myTerminal &lt;&gt; self.myTerminal then
			continue;
		endif;
		self.allGates.add (obj.CM_Gate);
	endforeach;

//	Restore selected interchange areas
	tokens.clear;
	
	xmlValue	:= xml.cnEcGetTagValueOfName(XML_Selected_Areas);
	xmlValue.getTokensForDelimiter (',', tokens);
	
	if self.openedFromSatelliteView then
		return;
	endif;
	
	foreach str in tokens do
		if str = null then
			continue;
		endif;
		invalid	:= false; 
		obj 	:= str.asOid;
		
		if obj = null then	// 08/06/2010 cnwcs5 - stop exception
			continue;		// 08/06/2010 cnwcs5 - stop exception
		endif;				// 08/06/2010 cnwcs5 - stop exception
		
		str 	:= obj.getOidString;	// if invalid causes exception
		
		if obj = null or invalid or obj.CM_TerminalArea.myTerminal &lt;&gt; self.myTerminal then
			continue;
		endif;
		
		self.allInterchangeAreas.add (obj.CM_TerminalArea);
	endforeach;
	
	//26 Jan 2022 NAVLW1 TFS# 52455
	tokens.clear;
	xmlValue	:= xml.cnEcGetTagValueOfName(XML_Selected_Operators);
	xmlValue.getTokensForDelimiter (',', tokens);
	
	foreach str in tokens do
		if str = null then
			continue;
		endif;
		
		invalid	:= false;
		obj 	:= str.asOid; 
		if obj = null then
			continue;
		endif;		
		obj.edition;
		if invalid then
			continue;
		endif;
		if obj.CM_Operator.isNotAvailableForEntry then
			continue;
		endif;
		self.allOperators.add (obj.CM_Operator);
	endforeach;
	
epilog
	delete areas;
	delete values;
	delete tokens;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleUserNotification" id="e63152b0-f503-4b78-8a78-db4719d1b39a">
        <updating/>
        <source>handleUserNotification(_obj : CM_Object input; _event : Integer)updating;
//--------------------------------------------------------------
//Created: 31 January 2003 By: cnwgd1
//--------------------------------------------------------------
// 26 Feb 2010	consw1	PAR #21320 - Revise behaviour of Edit Registration for Vehicle Visit
// 23/10/2012	cnwcs5	par 29653 - hide completed
// 09/11/2012 	cnwmh5	#24936 - Clear macro when vehicle road exited
// 22/11/2017   cnwma1  TFS #7828 QNS - System buffering
// 28/01/2022   navlw1	TFS #52455 STWR - Filter Option Vehicle Tree in Road Operations
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)

vars
	idx					: Integer;
	vehicle 			: CM_Vehicle;
	roadJob 			: CM_RoadJob;
	expanded 			: Boolean;
	tmpTable			: CM_GroupingTable;
	cmifRoadOpObject 	: CMIF_RoadOpObject;
	displayed   		: Boolean;
	deletedObject 		: Boolean;
	expandedObjects 	: ObjectSet;
	invalid			 	: Boolean;
	gate 				: CM_Gate;
	operator 			: CM_Operator;
begin
	
	on Exception do app.handleDeletedObject( exception, _obj, invalid );		//14.01.2026 navma1 MTN-35897
	
	if _obj &lt;&gt; null then
		_obj.edition;
	endif;
	
	if invalid then
		//epr 17/2/15 par 35702 CCMS 2457
		if _event = WLE_Delete_Event then
			self.myRoadOpController.handleUserNotification(_event,_obj);
		endif;
		return;
	endif;
	
	
	if _obj.isKindOf(CM_Vehicle) then
		vehicle := _obj.CM_Vehicle;
		roadJob := vehicle.allRoadJobs.first.CM_RoadJob;
		
	elseif _obj.isKindOf(CM_RoadJob) then
		roadJob := _obj.CM_RoadJob;
		vehicle := roadJob.myVehicle;
		
	elseif _obj.isKindOf(CM_WorkListEntry) then
		if _obj.CM_WorkListEntry.job &lt;&gt; null and _obj.CM_WorkListEntry.job.isKindOf(CM_RoadJob) then
			roadJob := _obj.CM_WorkListEntry.job.CM_RoadJob;
		endif;
		
	//23 Apr 2012	NDL	Par 29417
	elseif _obj.isKindOf(CM_RFIDTag) then
		if _event = Event_RFIDTagInUse then
			roadJob := _obj.CM_RFIDTag.myRoadJob;
			
			if roadJob &lt;&gt; null then
				vehicle := roadJob.myVehicle;
				
				if vehicle &lt;&gt; null then
					self.myRoadOpController.handleUserNotification(Vehicle_Update_Event,vehicle);
				endif;
			endif;
		endif;
		return;
		
	elseif _event = Event_GateLane_Change then
		self.doLaneRefresh(); 
		return;
	endif;

	
	//check if the update is for a job associated with the terminal area we are interested in
	if roadJob = null then
		if _event &lt;&gt; RoadJob_Delete_Event and _event &lt;&gt; Vehicle_Update_Event then
			return;
		endif;
	else
		if roadJob.status = JOB_UNVERIFIED or roadJob.status = JOB_TROUBLE then // PAR 17703
			return;
		endif;
		// *** no need to filter as all jobs shown in the list *** hide completed handled by controller
	endif;
	
	if self.dkcVehicles.visible then             //22/11/2017 cnwma1 TFS #7828
		if _event = RoadJob_Delete_Event or roadJob = null then
			idx := self.lstJobs.findObject(vehicle);	// cnwcs5 08/09/2009 - changed from _obj
			
			if idx &gt; 0 then
				self.lstJobs.clearBelowLevel(idx);
				self.lstJobs.removeItem(idx);
			endif;
			
		elseif _event = RoadJob_Create_Event then
			if roadJob &lt;&gt; null then
				self.lstJobsAddRoadJob(roadJob);		
			endif;
			
		elseif _event = RoadJob_Update_Event then
			// look for vehicle in list
			idx := self.lstJobs.findObject(vehicle);	// cnwcs5 08/09/2009 - changed from _obj
			if idx &gt; 0 then 
				expanded :=	self.lstJobs.itemExpanded[idx];
				//21 Dec 2016	NDL	TFS 3123
				create expandedObjects transient;
				if expanded then
					self.getExpandedForByCriteriaList( expandedObjects, vehicle, false );
				endif;
				self.lstJobsUpdateVehicle(vehicle, expanded, false, expandedObjects);
			else
				if roadJob &lt;&gt; null then
					self.lstJobsAddRoadJob(roadJob);		
				endif;
			endif;
			
		elseif (_event = Vehicle_Update_Event or _event = Vehicle_VTA_Area_Update) and  vehicle &lt;&gt; null then 
			idx := self.lstJobs.findObject(vehicle);	
			
			if idx &gt; 0 then 
				expanded :=	self.lstJobs.itemExpanded[idx];
			endif;
			//21 Dec 2016	NDL	TFS 3123
			create expandedObjects transient;
			if expanded then
				self.getExpandedForByCriteriaList( expandedObjects, vehicle, false );
			endif;
			
			//28 Jan 2022 NAVLW1 TFS# 52455
			if optGate.value then
				if roadJob &lt;&gt; null then
					gate := roadJob.myGate;
				endif;
				if not allGates.includes(gate) then
					return;
				endif;
			elseif optOperator.value then
				if roadJob &lt;&gt; null then
					operator := roadJob.myOperator;
				endif;
				if not allOperators.includes(operator) then
					return;
				endif;
			else
				self.lstJobsUpdateVehicle(vehicle, expanded, false, expandedObjects);
			endif;
			
			//28 Jan 2022 NAVLW1 TFS# 52455
			//self.lstJobsUpdateVehicle(vehicle, expanded, false, expandedObjects);
			
		endif;
	endif;
	
	if not global.isValidObject(self.myCurrentWLE) then // + dh 19/11/2007 par 15215
		self.myCurrentWLE := null;						// dh 19/11/2007
	endif;												// dh 19/11/2007
	
	self.myRoadOpController.handleUserNotification(_event,_obj);
epilog
	if self.dkcVehicles.visible then     //22/11/2017 cnwma1 TFS #7692
		
		delete expandedObjects;
		// 23/11/2012 cnwmh5 24936
		on Exception do app.handleDeletedObject (exception, self.myCurrentTable.allSelectedObjects.last, deletedObject);
		foreach cmifRoadOpObject in self.myRoadOpController.allCMIFRoadOpObjects discreteLock do	
			tmpTable := self.tblStage.getControl((cmifRoadOpObject.getDockOrder.String &amp; tblStage.tabIndex.String).Integer);
			if tmpTable = self.myCurrentTable and not self.myCurrentTable.allSelectedObjects.isEmpty() then
				if not deletedObject then
					displayExtraInfoForObj(self.myCurrentTable.allSelectedObjects.last.CM_Object);
					displayed := true;
				endif;
			endif;
		endforeach;
	endif;
	
	if not displayed then
		if self.dkbMacro.visible then        //22/11/2017 cnwma1 TFS #7828
			displayExtraInfoForObj(null);
		endif;
	endif;
	endLoad;
end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initAreaTables" id="6a9cc8c1-31d4-4dc5-a05c-8d088cfe4179">
        <updating/>
        <source>initAreaTables() updating;

vars
	i : Integer;
	obj  : Object;
	db: JadeDockBar;
	control : Control;
	areaFrame : CMUI_Frame;
	cmifRoadOpObject : CMIF_RoadOpObject;
	textHeight : Integer;
begin
		
	foreach cmifRoadOpObject in self.myRoadOpController.allCMIFRoadOpObjects discreteLock do	
		db					:= cmifRoadOpObject.myDockBar;
		db.floatingStyle	:= JadeDockBar.FloatingStyle_None;
		db.drawGrip			:= JadeDockBase.DrawGripBar_None;
		control 			:= frmStage.getControl((cmifRoadOpObject.getDockOrder.String &amp; frmStage.tabIndex.String).Integer);
		
		if control &lt;&gt; null then
			cmifRoadOpObject.setMyStageFrame(control.CMUI_Frame);
			
			control := null;
		endif;		
		//get the table
		control := tblStage.getControl((cmifRoadOpObject.getDockOrder.String &amp; tblStage.tabIndex.String).Integer);
		
		cmifRoadOpObject.setMyDataTable(control.CM_GroupingTable);
		cmifRoadOpObject.setupDataTable();
		
	
		// TFS 2198 CNWAB1
		if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			control.CM_GroupingTable.userInputEnabled := false;
			
		endif;
	
	
		
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="initAreaTablesMultiSelect" id="83556413-34ff-420c-a461-a1763e31398c">
        <source>initAreaTablesMultiSelect(_multiSelectType : Integer);

/*

Purpose:		To go through all the controls derived from tblStage and update multiSelect
				If you don't then changes to the Toggle Multi only affect the tabel that you are on

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwmh5	Initial creation  PAR23634

*/

vars
	control : Control;
	cmifRoadOpObject : CMIF_RoadOpObject;
begin
		
	foreach cmifRoadOpObject in self.myRoadOpController.allCMIFRoadOpObjects discreteLock do	
		control := tblStage.getControl((cmifRoadOpObject.getDockOrder.String &amp; tblStage.tabIndex.String).Integer);
		control.CM_GroupingTable.multiSelect := _multiSelectType;
		// TFS 2198 CNWAB1
		if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			control.CM_GroupingTable.userInputEnabled := false;
			
		endif;
	endforeach;
end;</source>
        <Parameter name="_multiSelectType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="bf13430b-2a62-47c8-98d3-a98e6dbd2d6d">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if keyCode = CMUI_Key_F3 then
		self.showHideFinder();
	elseif keyCode = J_key_F4 then
		self.frmPreferences.visible:=true;
		self.frmPreferences.centreWindow();
	// 27594 cnwjre1 May 2011 make bubble help shortcut keys work
	elseif keyCode = J_key_E then 
		if app.isAltKeyDown()
		and not app.isControlKeyDown()
		and not app.isShiftKeyDown()
		then
			self.doEdit();
			return;
		endif;
	elseif keyCode = J_key_M then 
		if app.isAltKeyDown()
		and not app.isControlKeyDown()
		and not app.isShiftKeyDown()
		then
			self.doMove_ForMode(REAL_MODE,false);
			return;
		endif;
	elseif keyCode = J_key_P then 
		if app.isAltKeyDown()
		and not app.isControlKeyDown()
		and not app.isShiftKeyDown()
		then
			self.doBtnPrint();
			return;
		endif;
		// end 27594
	else
		inheritMethod(keyCode,shift);
	endif;
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="ccd4bca4-758b-4c30-9b0c-14133bda2c00">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// par 27594 cnwjre1 May 2011 shortcut keys
vars
	regKeys : IntegerArray;
begin
	create regKeys transient;
	regKeys.add(J_key_M); // move
	regKeys.add(J_key_P); // print
	regKeys.add(J_key_E); // edit
	regKeys.add(J_key_R); // road exit
	self.addRegisteredKeys(regKeys);
epilog
	delete regKeys;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadListJobsForTerminal" id="4a77ea6f-2c29-4a50-a8a0-ba34f6160242">
        <updating/>
        <source>loadListJobsForTerminal(_expand :Boolean) updating;
//--------------------------------------------------------------
//Created: 30 September By: cnwgd1
//--------------------------------------------------------------
// 11/08/2009	cnwcs5	ccms1061 - renamed method and change to load all jobs for the terminal
// 03/09/2014	cnwdap1	PAR #34748 Avoid 1090 errors if road job has no vehicle
//						(not sure how the road job got in to this state in the first place though....)
//22/11/2017    cnwma1  TFS #7828 QNS - System buffering
// 22 Jan 2018	jlgkpd1	TFS 36660 - Penn locking issues
// 10 Jan 2022  NAVLW1  TFS# 52455 - Filter Option Vehicle Tree in Road Operations
// 18 Jul 2022	NAVKC1	TFS# 52966 - Road Ops preferences menu collapse behaviour
// 25/02/2025	naviv1	JIRA-29374- EUP | Transaction Instrumentation - Gate
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
constants
	LEVEL_VEHICLE	= 1;
	LEVEL_JOB		= 2;
vars
	coll				: Collection;
	dd					: DynaDictionary;
	any					: Any;
	roadJob				: CM_RoadJob;
	vehicle				: CM_Vehicle;
	gate				: CM_Gate;
	operator 			: CM_Operator;
	idx					: Integer;
	regArray			: StringArray;
	preIndex 			: Integer;
	obj 				: Object;
	expandedItems 		: ObjectSet;
	jobListCount 		: Integer;
	postIndex 			: Integer;
	expandedObjects 	: ObjectSet;
	jobArray			: CM_JobArray;
	currentGate         : String;
	currentOp			: String;
	label 				: String;
begin
	if not self.dkcVehicles.visible then     //22/11/2017 cnwma1 TFS #7828 
		return;
	endif;
	
	create regArray transient;

	if (not self.isFirstActivateComplete) then
		self.progressStart((self.myRoadJobSheet.allJobsByOrder.size) , null, null, null,'Loading data into view');
	endif;
	
	if self.optGate.value then // 10 Jan 2022 NAVLW TFS# 52455
		create dd transient;
		
		dd.setMembership(CM_RoadJob);
		dd.addMemberKey(CM_RoadJob::myGate.name, false, false);
		// 28 feb 2022 navlw1 TFS# 52787
		if optVehicleID.value then
			dd.addMemberKey (CM_RoadJob::myVehicle.name &amp; '.' &amp; CM_Vehicle::regNumber.name,false,false);
		endif;
		dd.endKeys(true);
		self.myRoadJobSheet.allJobsByOrder.copy (dd);	
		
		coll := dd;
	elseif self.optOperator.value then
		//create oprArr transient;
		create dd transient;
		
		dd.setMembership(CM_RoadJob);
		dd.addMemberKey(CM_RoadJob::myOperator.name, true, false);
		// 28 feb 2022 navlw1 TFS# 52787
		if optVehicleID.value then
			dd.addMemberKey (CM_RoadJob::myVehicle.name &amp; '.' &amp; CM_Vehicle::regNumber.name,false,false);
		endif;
		dd.endKeys(true);
		self.myRoadJobSheet.allJobsByOrder.copy (dd);	
		
		coll := dd;	
	elseif self.optVehicleID.value then
		// since i am loading all the vehicles i will get them in the correct order
		// to improve load time (hopefully)
		create dd transient;
		
		dd.setMembership (CM_RoadJob);
		dd.addMemberKey (CM_RoadJob::myVehicle.name &amp; '.' &amp; CM_Vehicle::regNumber.name,false,false);
		dd.endKeys (true);
		
		self.myRoadJobSheet.allJobsByOrder.copy (dd);	
		
		coll := dd;
	else
		jobArray := self.myRoadJobSheet.allJobsByOrder.cloneSelf(true);
		coll := jobArray;
	endif;	
	//13 Apr 2016	NDL TFS 1819
	if not _expand then
		// If not explicitly expand, then only re-expand the items already expanded
		// Apparently it annoys the penn users off we change things
		create expandedItems transient;
		jobListCount := lstJobs.listCount;
		if jobListCount &gt; 0 then
			foreach preIndex in 1 to jobListCount do
				//if lstJobs.itemLevel[preIndex] &lt;&gt; LEVEL_VEHICLE then		// 18/07/2022 NAVKC1	TFS# 52966
				if (self.optNone.value and lstJobs.itemLevel[preIndex] &lt;&gt; LEVEL_VEHICLE)		// 18/07/2022 NAVKC1	TFS# 52966
				 or ((self.optGate.value or self.optOperator.value) and lstJobs.itemLevel[preIndex] &lt;&gt; LEVEL_JOB) then		// 18/07/2022 NAVKC1	TFS# 52966
					continue;
				endif;
				if not lstJobs.itemExpanded[preIndex] then
					continue;
				endif;
				obj := lstJobs.itemObject[preIndex];
				if obj = null then
					continue;
				endif;
				if CM_Vehicle.hasInstance(obj) then
					expandedItems.add(obj);
				endif;
			endforeach;
		endif;
	endif;
	
	//21 Dec 2016	NDL	TFS 3123
	create expandedObjects transient;
	self.getExpandedForByCriteriaList( expandedObjects, null, true );
	
	lstJobs.clear;
	
	foreach any in coll do
		if (not self.isFirstActivateComplete) then
			self.progressUpdate;
		endif;
		
		roadJob := any.CM_RoadJob;
		
		if self.btnHideCompleted.value and roadJob.status = JOB_COMPLETE then
			continue;
		endif;
		
		if (roadJob.status = JOB_UNVERIFIED or roadJob.status = JOB_TROUBLE) then // PAR 17703
			continue;
		endif;
		//epr TFS 7828 24/11/17
		if self.checkLogDocket then
			//cnwmc5 - 27 Jan 2015 - PAR 35528
			if roadJob.containsLogDocket() then
				continue;
			endif;
		endif;
		
		vehicle := roadJob.myVehicle;
		if vehicle = null then								// PAR #34748
			continue;										// PAR #34748
		endif;												// PAR #34748
		
		// 10 Jan 2022 NAVLW TFS# 52455
		if self.optGate.value then
			gate := roadJob.myGate;
			if gate = null then
				label := "UNKNOWN";
			else
				if not allGates.includes(gate) then
					continue;
				endif;
				label := gate.name;
			endif;
			
			if currentGate = null or currentGate &lt;&gt; label then
				currentGate := label;
					// sorting by arrival time - just add to list
				idx := lstJobs.addItem(label); 
		
				lstJobs.itemObject[idx]		:= gate;
				lstJobs.itemLevel[idx]		:= 1;
				lstJobs.itemPicture[idx]	:= self.picTruck.picture;
			endif;
		elseif self.optOperator.value then
			operator := roadJob.myOperator;
			if operator = null then
				label := "UNKNOWN";
			else
				if not allOperators.includes(operator) then
					continue;
				endif;
				label := operator.code;
			endif;
			
			if currentOp = null or currentOp &lt;&gt; label then
				currentOp := label;
					// sorting by arrival time - just add to list
				idx := lstJobs.addItem(label); 
		
				lstJobs.itemObject[idx]		:= operator;
				lstJobs.itemLevel[idx]		:= 1;
				lstJobs.itemPicture[idx]	:= self.picTruck.picture;
			endif;
		endif;
		if (not regArray.includes(vehicle.regNumber)) then
			
			self.lstJobsUpdateVehicle(vehicle, false, true, expandedObjects);
			
			regArray.add(vehicle.regNumber);				
		endif;
	endforeach;
	
	//13 Apr 2016	NDL TFS 1819
	if not _expand then
		jobListCount := lstJobs.listCount;
		if jobListCount &gt; 0 and not expandedItems.isEmpty then
			foreach postIndex in 1 to jobListCount do
				//if lstJobs.itemLevel[postIndex] &lt;&gt; LEVEL_VEHICLE then 		// 18/07/2022 NAVKC1	TFS# 52966
				if (self.optNone.value and lstJobs.itemLevel[postIndex] &lt;&gt; LEVEL_VEHICLE)		// 18/07/2022 NAVKC1	TFS# 52966
				 or ((self.optGate.value or self.optOperator.value) and lstJobs.itemLevel[postIndex] &lt;&gt; LEVEL_JOB) then		// 18/07/2022 NAVKC1	TFS# 52966
					continue;
				endif;
				obj := lstJobs.itemObject[postIndex];
				if obj = null then
					continue;
				endif;
				if expandedItems.includes(obj) then
					self.lstJobs.itemExpanded[postIndex] := true;
				endif;
			endforeach;
		endif;
		
	elseif _expand or (not self.isFirstActivateComplete) then	
		self.lstJobsExpandAllItems();
	endif;

epilog
	
	delete expandedObjects;
	delete regArray;
	delete dd;
	delete expandedItems;
	delete jobArray;
	progressFinish;
end;</source>
        <Parameter name="_expand" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadSortListJobsForTerminal" id="08cf8085-1b1b-4710-bf9e-b7077694627f">
        <source>loadSortListJobsForTerminal(roadJob : CM_RoadJob) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2022	navlw1	Initial creation tfs# 52787

*/

vars
	gate 		: CM_Gate;
	operator 	: CM_Operator;
	label       : String;
	idx 		: Integer;
	currentGate : String;
	currentOp   : String;
	invalid  	: Boolean;
	numItems,
	rowNum		: Integer;
	rowObject 	: CM_Object;
	
begin
	if self.optGate.value then
		if roadJob.myGate = null then
			label := "UNKNOWN";
		else
			if not allGates.includes(roadJob.myGate) then
				return idx;
			endif;
			label := roadJob.myGate.name;
		endif;
		
		if currentGate = null or currentGate &lt;&gt; label then
			currentGate := label;
			idx := lstJobs.findObject(roadJob.myGate);
			if idx &gt;= 1 then
				idx := idx + 1;
				on Exception do app.handleDeletedObject(exception, rowObject, invalid);
				numItems := lstJobs.listCount;
				foreach rowNum in idx to numItems do
					rowObject := lstJobs.itemObject[rowNum].CM_Object;
					// If next item down is the next gate, we've gone far enough
					if rowObject.isKindOf(CM_Gate) then
						break;
					endif;
						
					if rowObject.isKindOf(CM_Vehicle) then
						// If the current row/vehicle should be after us, then we've gone far enough
						if optVehicleID.value then //vehicle order
							if rowObject.CM_Vehicle.code &gt; roadJob.myVehicle.code then
								break;
							endif;
						endif;
					endif;
					
					idx += 1;
					
				endforeach;
				
				// foreach item in list under gate
				// test is not null/end of list
					// If it is, then just add at index-1
				//	test is 'itemObject' CM_Gate
					// If it is, then just add at index-1
				// test 'itemObject' 'code' is after than us
					// if it is, then just add at index-1
				// else (code is before us)
					// continue loop
				return idx;
			endif;
			
			//if we do not have a gate in the list then we add it
			idx := lstJobs.addItem(label); 
		
			lstJobs.itemObject[idx]		:= roadJob.myGate;
			lstJobs.itemLevel[idx]		:= 1;
			lstJobs.itemPicture[idx]	:= self.picTruck.picture;
			idx := idx + 1;
		endif;
		
	elseif self.optOperator.value then
		operator := roadJob.myOperator;
		if operator = null then
			label := "UNKNOWN";
		else
			if not allOperators.includes(operator) then
				return idx;
			endif;
			label := operator.code;
		endif;
		
		if currentOp = null or currentOp &lt;&gt; label then
			currentOp := label;
			//need to check that we have not already added it to the tree view
			idx := lstJobs.findObject(operator);
			if idx &gt;= 1 then
				idx := idx + 1;
				// Add exception handler for null/invalid objects				
				on Exception do app.handleDeletedObject(exception, rowObject, invalid);
				numItems := lstJobs.listCount;
				foreach rowNum in idx to numItems do
					rowObject := lstJobs.itemObject[rowNum].CM_Object;
					
					// If next item down is the next gate, we've gone far enough
					if rowObject.isKindOf(CM_Operator) then
						break;
					endif;
					
					if rowObject.isKindOf(CM_Vehicle) then
						// If the current row/vehicle should be after us, then we've gone far enough
						if optVehicleID.value then //vehicle order
							if rowObject.CM_Vehicle.code &gt; roadJob.myVehicle.code then
								break;
							endif;
						endif;
					endif;
					
					idx += 1;
					
				endforeach;
				return idx;
			endif;
			
			//if we do not have a Operator in the list then we add it
			idx := lstJobs.addItem(label); 
			lstJobs.itemObject[idx]		:= operator;
			lstJobs.itemLevel[idx]		:= 1;
			lstJobs.itemPicture[idx]	:= self.picTruck.picture;
			idx := idx + 1;
		endif;
	endif;
	// 24 feb 2022 navlw added this as it was breaking DMAST road ops for dave
	if idx = 0 then
		idx := idx + 1;
	endif;
	return idx;
epilog

end;</source>
        <Parameter name="roadJob" type="CM_RoadJob"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
