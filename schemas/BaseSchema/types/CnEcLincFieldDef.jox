    <JadeMethod name="configField" id="9b306543-0d15-49c7-8ab6-d631bd2204e0">
        <updating/>
        <source>configField ( newName, newType, newUsage : String;
			  newOffset, newLength, newtrueLength, newDecimals : Integer;
			  newdecimalsKeyed :String;
			  newCopyFromOccurs : Integer; 
			  newSecureField: String) updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	name := newName;
	type := newType;
	usage := newUsage;
	offset := newOffset;
	length := newLength;
	trueLength := newtrueLength;
	decimals := newDecimals;
	copyFromOccurs := newCopyFromOccurs;

	if newdecimalsKeyed = "Y" then 
		decimalsKeyed := true;
	else
		decimalsKeyed := false;
	endif;	

	if newSecureField = "Y" then 
		secureField := true;
	else
		secureField := false;
	endif;	 
end;</source>
        <Parameter name="newName" type="String"/>
        <Parameter name="newType" type="String"/>
        <Parameter name="newUsage" type="String"/>
        <Parameter name="newOffset" type="Integer"/>
        <Parameter name="newLength" type="Integer"/>
        <Parameter name="newtrueLength" type="Integer"/>
        <Parameter name="newDecimals" type="Integer"/>
        <Parameter name="newdecimalsKeyed" type="String"/>
        <Parameter name="newCopyFromOccurs" type="Integer"/>
        <Parameter name="newSecureField" type="String"/>
    </JadeMethod>
    <JadeMethod name="display" id="8773e200-585a-41c3-ba45-72b03d88fae6">
        <source>/*******************************************************
