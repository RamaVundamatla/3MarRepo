    <JadeMethod name="delete" id="420c4dc6-3d89-43dd-8d20-70893703139a">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin
	if not self.allShifts.isEmpty then
		self.allShifts.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findPickUpSourceForSetDown" id="ecb2bbba-957d-4be9-9273-87945b239f21">
        <source>findPickUpSourceForSetDown( _setDownTi : CM_TrackedItem; _unmatchedPickups : CM_MachineHistoryByDateTime io ): CM_LocationsController protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	history : CM_MachineMoveHistory;
	move : CM_Move;
	ti : CM_TrackedItem;
	foundIt : Boolean;
	pickUpSourceController : CM_LocationsController;
	tmpFoundHeight : Integer;
	
begin

	iter := _unmatchedPickups.createIterator;
	while iter.next( history ) do
		move := history.CM_MachineMoveHistory.myMoveTransaction;
		ti := move.myTrackedItem;
		if ti = _setDownTi then
			foundIt := true;
			break;
		endif;
	endwhile;
	delete iter;
	
	if foundIt then
		_unmatchedPickups.remove(history);
		self.myTerminal.findLocationFromString(history.sourceLocation, true, pickUpSourceController, tmpFoundHeight);
	endif;
	
	return pickUpSourceController;
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_setDownTi" type="CM_TrackedItem"/>
        <Parameter name="_unmatchedPickups" type="CM_MachineHistoryByDateTime" usage="io"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getRelevantShift" id="8e3f05db-fc78-45c6-8134-5b9f03344135">
        <source>getRelevantShift( _timeStamp : TimeStamp ) : CM_Shift protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	shift : CM_Shift;
	
begin

	iter := self.allShifts.createIterator;
	while iter.next( shift ) do
		if shift.startDateTime &gt; _timeStamp then
			continue;
		endif;
		if shift.endDateTime &lt; _timeStamp then
			continue;
		endif;
		return shift;
	endwhile;
	
	return null;
	
	
epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="getShiftMovementsTotalsObj" id="9ddef295-c3ae-497f-991b-7129fdfa1155">
        <source>getShiftMovementsTotalsObj( _shift : CM_Shift ) : CMIF_ShiftMovementTotalsObject protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	shiftMoveTotObj : CMIF_ShiftMovementTotalsObject;
	
begin

	iter := self.allShiftMovementsTotals.createIterator;
	while iter.next( shiftMoveTotObj ) do
		if shiftMoveTotObj.myShift = _shift then
			return shiftMoveTotObj;
		endif;
	endwhile;
	
	return null;
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_shift" type="CM_Shift"/>
        <ReturnType type="CMIF_ShiftMovementTotalsObject"/>
    </JadeMethod>
    <JadeMethod name="getTotalsObjectForTi" id="18f28550-06a6-44d2-93ad-1314be20fb98">
        <source>getTotalsObjectForTi( 	_train : CM_Train;
						_inward : Boolean;
						_ti : CM_TrackedItem;
						_firstWorked : TimeStamp output;
						_lastWorked : TimeStamp output;
						_allMoveTrans : CM_TITransactionByDateDict io
						) : CMIF_TrainStatTotalsObject protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	trans : CM_TITransaction;
	locController : CM_LocationsController;
	move : CM_Move;
	shift : CM_Shift;
	theShift : CM_Shift;
	
begin

	// find all of the moves for this piece of cargo that involves a wagon
	iter := _ti.allTransactions.createIterator;
	while iter.next( trans ) do
		if trans.isCM_Move then
			if not trans.deleted then
				if trans.CM_Move.locationsControllerIsRail(_inward) then	// true = get the source location...
					_allMoveTrans.add( trans );
					self.incrementNonWagonTotals( trans.CM_Move, _inward );
				endif;
			endif;
		endif;
	endwhile;
	delete iter;

	// no move for the ti that involved a wagon.  (Might have been in transit)
	if _allMoveTrans.isEmpty then
		return null;
	endif;
	
	// get _firstWorked and _lastWorked times.
	_firstWorked := null;
	_lastWorked := null;
	iter := _allMoveTrans.createIterator;
	while iter.next( trans ) do
		move := trans.CM_Move;
		if _firstWorked = null or move.completedDateTime &lt; _firstWorked then
			_firstWorked := move.completedDateTime;
		endif;
		if _lastWorked = null or move.completedDateTime &gt; _lastWorked then
			_lastWorked := move.completedDateTime;
		endif;
	endwhile;
	delete iter;
	
	// find which shift the move(s) started on
	theShift := self.getRelevantShift(_firstWorked);
	
	// now get the appropriate CMIF_TrainStatTotalsObject
	if theShift &lt;&gt; null then
		return self.allTrainStatTotalsObjects.getAtKey( _inward, _train, theShift );
	else
		return null;
	endif;
		
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_firstWorked" type="TimeStamp" usage="output"/>
        <Parameter name="_lastWorked" type="TimeStamp" usage="output"/>
        <Parameter name="_allMoveTrans" type="CM_TITransactionByDateDict" usage="io"/>
        <ReturnType type="CMIF_TrainStatTotalsObject"/>
    </JadeMethod>
    <JadeMethod name="getWorkTimes" id="a2e3e9c9-a1ba-4154-b22b-ce22ca7dac54">
        <source>getWorkTimes( _train : CM_Train; _inward : Boolean; _timeStarted : TimeStamp output; _timeEnded : TimeStamp output) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	cmifTotals : CMIF_TrainStatTotalsObject;
	
begin

	_timeStarted := null;
	_timeEnded := null;

	iter := self.allTrainStatTotalsObjects.createIterator;
	while iter.next( cmifTotals ) do
		if cmifTotals.inward &lt;&gt; _inward then
			continue;
		endif;
		if cmifTotals.myTrain &lt;&gt; _train then
			continue;
		endif;
		if cmifTotals.workStarted.Date &lt;&gt; null then
			if _timeStarted = null or _timeStarted &gt; cmifTotals.workStarted then
				 _timeStarted := cmifTotals.workStarted;
			endif;
		endif;
		if cmifTotals.workEnded.Date &lt;&gt; null then
			if _timeEnded = null or _timeEnded &lt; cmifTotals.workEnded then
				 _timeEnded := cmifTotals.workEnded;
			endif;
		endif;
	endwhile;
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_timeStarted" type="TimeStamp" usage="output"/>
        <Parameter name="_timeEnded" type="TimeStamp" usage="output"/>
    </JadeMethod>
    <JadeMethod name="has30s" id="ddb98d5e-d58c-4d84-a863-9e9b16bfd39e">
        <source>has30s():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	trainTot : CMIF_TrainStatTotalsObject;
	shiftTot : CMIF_ShiftMovementTotalsObject;
	
begin
	
//	return true;	process.isNDL; //testing only
	
	foreach trainTot in self.allTrainStatTotalsObjects do
		if trainTot.mt30 &gt; 0 then
			return true;
		endif;
		if trainTot.full30 &gt; 0 then
			return true;
		endif;
	endforeach;
	
	foreach shiftTot in self.allShiftMovementsTotals do
		if shiftTot.roadDischarge30 &gt; 0 then
			return true;
		endif;
		if shiftTot.roadLoad30 &gt; 0 then
			return true;
		endif;
		if shiftTot.shipDischarge30 &gt; 0 then
			return true;
		endif;
		if shiftTot.shipLoad30 &gt; 0 then
			return true;
		endif;
		if shiftTot.yardPickUp30 &gt; 0 then
			return true;
		endif;
		if shiftTot.yardSetDown30 &gt; 0 then
			return true;
		endif;
	endforeach;

	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
