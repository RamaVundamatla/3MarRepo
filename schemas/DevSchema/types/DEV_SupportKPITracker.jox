        <source>cmbCustomerRpt_click(combobox: ComboBox input) updating;

/*
Date			Who		Reason
28 July 2016	cnwar2	Initial creation

*/
vars
	tz : DEV_SupportTimezone;
	
begin
	cmbTimezone.clear();
	
	if combobox.text = "*ALL*" then
		cmbTimezone.addItem('*ALL*');
		foreach tz in self.myRoot.allTimezones do
			cmbTimezone.addItem(tz.name);
		endforeach;
	else
		tz := self.getTimezoneForCust(combobox.text.trimBlanks);
		cmbTimezone.addItem(tz.name);
	endif;
	cmbTimezone.listIndex := 1;
end;</source>
