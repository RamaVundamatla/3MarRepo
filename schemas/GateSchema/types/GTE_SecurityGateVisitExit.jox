        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="5b6270c4-32b2-4f69-8da8-ba4110a5191b">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	exitTime	: TimeStamp;
	updateOK	: Boolean;
	result		: Integer;

begin
	exitTime.setDate(self.txtDepartureDate.getDate);
	exitTime.setTime(self.txtDepartureTime.getTime);
	
	while true do
	
		app.myTrxUA.trxVVRSecurityGateExit(self.myVehicleVisit, self.localToSystemTime(exitTime), app.myPassport);	// 24/5/16 cnwmp6 TFS 488 - Multi timezone support

		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			updateOK := true;
			break;
		else
			result := app.showErrorWarningDialog('Vehicle Visit - Security Gate', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;

	if updateOK then
		self.unloadForm();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyVehicleVisitRecord" id="a687e2ac-a4fd-4b84-895c-0147e3d0094a">
        <updating/>
        <source>setMyVehicleVisitRecord(_vvr : CM_VehicleVisitRecord) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars

begin
	self.myVehicleVisit := _vvr;
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="00bbb8d0-e36b-43ac-a8e2-c6218e1a032e">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 05/12/2016   cnwma1		Tfs #2911 PAR38437 STWR - Security gate 1090 error when exiting a truck
//
constants
	VertDist	= 24;
vars
	hideBAT, 
	hideState					: Boolean;
	cargoDetails 				: String;
	detail,						
	securityGateArrivedDetail   : CM_VehicleVisitRecordDetail;
	now							: TimeStamp;
begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar  := true;
	
	// show the BAT number field only if we're using BAT numbers
	hideBAT := self.myTerminal.getConfig(GateInOutHideBatNumber).Boolean;
	
	// show state only if requested
	hideState := not self.myTerminal.getConfig(ShowVehicleState).Boolean;
	
	self.height := 335; // TFS 52522, also moved all controls down in the painter. Was 275
	
	if hideBAT then
		self.txtRegistration.top 	:= self.txtRegistration.top - VertDist;
		self.lblRegistration.top 	:= self.lblRegistration.top - VertDist;
		self.txtState.top 			:= self.txtState.top - VertDist;
		self.lblState.top 			:= self.lblState.top - VertDist;
		self.lblCargo.top 			:= self.lblCargo.top - VertDist;
		self.txtCargo.top 			:= self.txtCargo.top - VertDist;
		self.lblDeparture.top 		:= self.lblDeparture.top - VertDist;
		self.txtDepartureDate.top 	:= self.txtDepartureDate.top - VertDist;
		self.txtDepartureTime.top 	:= self.txtDepartureTime.top - VertDist;
		
		self.lblBatNbr.visible 		:= false;
		self.txtBatNbr.visible 		:= false;
	endif;
	
	if hideState then
		self.txtState.visible := false;
		self.lblState.visible := false;
	endif;
	
	// show data for vehicle visit record
	self.txtVisitNbr.text			:= self.myVehicleVisit.visitNumber;
	self.txtVisitNbr.backColor		:= self.backColor;
	securityGateArrivedDetail		:= self.myVehicleVisit.getSecurityGateArrivedDetail();
	
	if securityGateArrivedDetail &lt;&gt; null then      //05/12/2016 cnwma1 TFS #2991
		self.txtBatNbr.text				:= securityGateArrivedDetail.getExtraInfo_AssignRFIDTag;
	endif;
	self.txtBatNbr.backColor		:= self.backColor;
	self.txtRegistration.text		:= self.myVehicleVisit.regNumber;
	self.txtRegistration.backColor	:= self.backColor;
	self.txtState.text				:= self.myVehicleVisit.state;
	self.txtState.backColor			:= self.backColor;
	
	foreach detail in self.myVehicleVisit.allVehicleVisitRecordDetails discreteLock where detail.isCargoMove do
		cargoDetails := cargoDetails &amp; detail.getRecordDetailDescription &amp; CrLf;
	endforeach;
	cargoDetails.stripTrailingChar(CrLf.Character);
	
	self.txtCargo.text				:= cargoDetails;
	self.txtCargo.backColor			:= self.backColor;
	
	// default departure date/time to "now"
	now := app.actualTimeServer();
	self.txtDepartureDate.setDate(self.systemToLocalTime(now).Date);	// 24/5/16 cnwmp6 TFS 488 - Multi timezone support
	self.txtDepartureTime.setTime(self.systemToLocalTime(now).Time);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4be077ab-d3ac-4fd3-b871-82307dce9a26">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 February 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019529, locale);
	lblBatNbr.translateCaption(Xlat_0019455, locale);
	lblCargo.translateCaption(Xlat_0019456, locale);
	lblDeparture.translateCaption(Xlat_0019457, locale);
	lblRegistration.translateCaption(Xlat_0019458, locale);
	lblState.translateCaption(Xlat_0019459, locale);
	lblVisitNbr.translateCaption(Xlat_0019460, locale);
end;</source>
    </JadeMethod>
</GUIClass>
