    <JadeMethod name="isSatelliteViewable" id="e9407345-2cdd-40f1-9c5c-d073add0e789">
        <source>isSatelliteViewable() : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	27 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
26/06/2009	 CONCMS1	ccms 1061 - added gate area/road intechange
25/02/2010 	 cnwcs5 	remove VTA references
15 Jul 2013  cnwer1		removed trailer area references - while here removed old general cargo area references
12/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
08/09/2022	jlika1		TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/
vars
	terminalAreaType		: Integer;
begin
	terminalAreaType := self.type;
	
	if terminalAreaType &gt; TA_TYPE_JMTMax then
		return false;
	endif;
	
	if terminalAreaType = TA_TYPE_STRADDLE_STACK then
		return true;
	elseif self.isGantryAreaType then
		return true;
	elseif self.isGantryInterchangeArea then
		return false;
	elseif self.isGantryLaneAreaType then
		return false;
	elseif terminalAreaType = TA_TYPE_LOGAREA then
		return false;
	elseif terminalAreaType = TA_TYPE_FORK_LIFT_STACK then
		return true;
	elseif terminalAreaType = TA_TYPE_RAILWAY_TRACK then
		return false;
	elseif terminalAreaType = TA_TYPE_SUBBLOCK_STACK then
		//return false;
		return true;	//30 Aug 2011	NDL	Par 28076
	elseif terminalAreaType = TA_TYPE_SWAP then
		return false;
	elseif terminalAreaType = TA_TYPE_DEPOT_LCL then
		return false;
	elseif terminalAreaType = TA_TYPE_BUILDING then
		return false;
	elseif terminalAreaType = TA_TYPE_CRANE_TRANS then
		return false;
	elseif terminalAreaType = TA_TYPE_INTERTERM_TRANS_AREA then
		return false;
	elseif terminalAreaType = TA_TYPE_RAIL_TRANS then
		return false;
//	elseif terminalAreaType = TA_TYPE_ROAD_TRANS then	25/02/2010 cnwcs5 remove VTA references
//		return false;									25/02/2010 cnwcs5 remove VTA references
	elseif terminalAreaType = TA_TYPE_BULK then	// R Barr 2/11/2006 Comalco
		return true;
	elseif terminalAreaType = TA_TYPE_IRREGULAR_BLOCK_AREA then
		//return false;
		return true; //cnwjk3 27/02/09 SFW1030
	elseif terminalAreaType = TA_TYPE_RORO_LANE_AREA then	// cnwjk3 ccms 1018
		return true;										// cnwjk3 ccms 1018
	elseif terminalAreaType = TA_TYPE_GATE_ROAD then	// ccms 1061
		return false;
	elseif  terminalAreaType = TA_TYPE_BLOCK_STACK
		or terminalAreaType = TA_TYPE_REPAIR
		or terminalAreaType = TA_TYPE_PTI
		or terminalAreaType = TA_TYPE_COU_STORE_AREA
		or terminalAreaType = TA_TYPE_GENERATOR_STORE_AREA
		or terminalAreaType = TA_TYPE_WASH_AREA
		or terminalAreaType = TA_TYPE_FUMIGATION_AREA
		or terminalAreaType = TA_TYPE_CONT_PACK_REPACK
		or terminalAreaType = TA_TYPE_COU_CRIB_PACK_UNPACK
		or terminalAreaType = TA_TYPE_DELETE
		or terminalAreaType = TA_TYPE_HIDE
		or terminalAreaType = TA_TYPE_RELTRANS		//NFS 3833 AA 5/0/01
		or terminalAreaType = TA_TYPE_RECTRANS
		or terminalAreaType = TA_TYPE_DAIRY	
		or terminalAreaType = TA_TYPE_YARD_INTERCHANGE // ccms 1061
		or terminalAreaType = TA_TYPE_GEN_CARGO_ALLOC_ROW					// TFS 49453
		or terminalAreaType = TA_TYPE_WORKPOINT_INTERCHANGE 
		or terminalAreaType = TA_TYPE_MAFI
		then //ccms 1033 epr 9/8/11then	
		return true;
	// TFS 51097 this method is only used by the UI so remove this exception
	// TFS 51097 else
	// TFS 51097	app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled type (' &amp; self.type.String &amp; '"');
	endif;
		
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSingleLCType" id="510547a0-d275-4335-9658-0c4532212434">
        <source>isSingleLCType() : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 May 2007 by cnwrs2
//
// Purpose:     For some Terminal Area Types it is only valid to have 1 
//				locations controller - return true for those types
// ---------------------------------------------------------------------------
vars
	tmpClass	: Class;
begin
	tmpClass := self.getTAClassToCreate();
	if tmpClass = CM_BlockStack or
	   tmpClass = CM_SubBlockStack or //30/12/2008 cnwdz2 par18698
	   tmpClass = CM_Depot or
	   tmpClass = CM_BulkArea then
		return true;
	endif;
	   
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUserMaintainable" id="7cad1990-8a6a-492d-a688-b3907c21b0f9">
        <source>isUserMaintainable(_terminal :CM_Terminal):Boolean;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     Based on SOP_TerminalAreaDefForm::isValidType
// Parameters:  None
// Returns:     true if receiver is one that is maintained via SOP_TerminalAreaDefForm
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	areaType	:Integer;
	user		:CM_User;
begin
	if areaType = TA_TYPE_SWAP or 
		areaType = TA_TYPE_SUBBLOCK_STACK or
		areaType = TA_TYPE_GATE_ROAD or
		areaType = TA_TYPE_RTG_INTERCHANGE or
		areaType = TA_TYPE_RMG_INTERCHANGE then
		return false;
	endif;
	
	if areaType = TA_TYPE_INTERTERM_TRANS_AREA and 
		not app.myRoot.isInterTerminalTransferEnabled then
		return false;
	endif;	
	
	if areaType = TA_TYPE_BULK then
		user := app.getMyUser();
		
		if user = null or _terminal = null or not user.canDo(_terminal, Mod_BulkCargo) then
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidTypeForRTMoveMethod" id="b839a856-28d8-448c-932f-41e746bad2c9">
        <source>isValidTypeForRTMoveMethod(	_rtMoveMethod : CM_RTMoveMethod;
							_isSource : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwer1	Initial creation

*/

vars
	machineTypeGrp : CM_MachineTypeGroup;
begin
	if self.isGantryAreaType then
		if _isSource then
			if _rtMoveMethod.allMachineTypeGroups.first.type &lt;&gt; MACHINETYPEGRP_RTG then
				return false;
			endif;
		else
			if _rtMoveMethod.allMachineTypeGroups.last.type &lt;&gt; MACHINETYPEGRP_RTG then
				return false;
			endif;
		endif;
	elseif self.type = TA_TYPE_STRADDLE_STACK then
		if _isSource then
			if _rtMoveMethod.allMachineTypeGroups.first.type &lt;&gt; MACHINETYPEGRP_STRADDLE then
				return false;
			endif;
		else
			if _rtMoveMethod.allMachineTypeGroups.last.type &lt;&gt; MACHINETYPEGRP_STRADDLE then
				return false;
			endif;
		endif;
	elseif self.type = TA_TYPE_FORK_LIFT_STACK then
		if _isSource then
			if _rtMoveMethod.allMachineTypeGroups.first.type &lt;&gt; MACHINETYPEGRP_LIFTER then
				return false;
			endif;
		else
			if _rtMoveMethod.allMachineTypeGroups.last.type &lt;&gt; MACHINETYPEGRP_LIFTER then
				return false;
			endif;
		endif;
	elseif self.type = TA_TYPE_CRANE_TRANS then
		if _isSource then
			if _rtMoveMethod.allMachineTypeGroups.first.type = MACHINETYPEGRP_RTG 	then
				return false;
			endif;
		else
			if _rtMoveMethod.allMachineTypeGroups.last.type = MACHINETYPEGRP_RTG then
				return false;
			endif;
		endif;
	elseif 	self.type = TA_TYPE_GATE_ROAD or
		self.type = TA_TYPE_RTG_INTERCHANGE or
		self.type = TA_TYPE_RMG_INTERCHANGE then
		if _isSource then
			if _rtMoveMethod.allMachineTypeGroups.first.type = MACHINETYPEGRP_IMV then
				return false;
			endif;
		else
			if _rtMoveMethod.allMachineTypeGroups.last.type = MACHINETYPEGRP_IMV then
				return false;
			endif;
		endif;
	elseif self.type = TA_TYPE_RAILWAY_TRACK then
		if _isSource then
			
			if _rtMoveMethod.allMachineTypeGroups.first.type = MACHINETYPEGRP_IMV then
				return false;
			endif;
		else
			
			if _rtMoveMethod.allMachineTypeGroups.last.type = MACHINETYPEGRP_IMV then
				return false;
			endif;
		endif; 
	elseif self.type = TA_TYPE_YARD_INTERCHANGE then
	//ccms 1099 11/5/10  realised some of these don't make sense
		if _isSource then
			if _rtMoveMethod.allMachineTypeGroups.first.type &lt;&gt; MACHINETYPEGRP_LIFTER and
				 _rtMoveMethod.allMachineTypeGroups.first.type &lt;&gt; MACHINETYPEGRP_STRADDLE then
				return false;
			endif;
			machineTypeGrp:=self.myRoot.allMachineTypeGroups[MACHINETYPEGRP_SOURCEIC];
			if _rtMoveMethod.allMachineTypeGroups.includes(machineTypeGrp) then
				return false;
			endif;
		else
			if _rtMoveMethod.allMachineTypeGroups.last.type &lt;&gt; MACHINETYPEGRP_LIFTER and
				 _rtMoveMethod.allMachineTypeGroups.last.type &lt;&gt; MACHINETYPEGRP_STRADDLE then
				return false;
			endif;
			
			machineTypeGrp:=self.myRoot.allMachineTypeGroups[MACHINETYPEGRP_TARGETIC];
			if _rtMoveMethod.allMachineTypeGroups.includes(machineTypeGrp) then
				return false;
			endif;
		endif;
	elseif self.type = TA_TYPE_WORKPOINT_INTERCHANGE then //ccms 1033 9/8/11 
		if _isSource then
			if _rtMoveMethod.allMachineTypeGroups.first.type = MACHINETYPEGRP_RTG 	then
				return false;
			endif;
		else
			if _rtMoveMethod.allMachineTypeGroups.last.type = MACHINETYPEGRP_RTG then
				return false;
			endif;
		endif;
	else
		if _isSource then
			if _rtMoveMethod.allMachineTypeGroups.first.type = MACHINETYPEGRP_RTG then
				return false;
			endif;
			// PAR 24611 - RJS 24 Jun 2010
			//if _rtMoveMethod.allMachineTypeGroups.first.type = MACHINETYPEGRP_STRADDLE then
			//	return false;
			//endif;
			if _rtMoveMethod.allMachineTypeGroups.first.type = MACHINETYPEGRP_IMV then
				return false;
			endif;
		else
			if _rtMoveMethod.allMachineTypeGroups.last.type = MACHINETYPEGRP_RTG then
				return false;
			endif;
			// PAR 24611 - RJS 24 Jun 2010
			//if _rtMoveMethod.allMachineTypeGroups.last.type = MACHINETYPEGRP_STRADDLE then
			//	return false;
			//endif;
			if _rtMoveMethod.allMachineTypeGroups.last.type = MACHINETYPEGRP_IMV then
				return false;
			endif;
		endif;
		
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_rtMoveMethod" type="CM_RTMoveMethod"/>
        <Parameter name="_isSource" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="db92c2b1-88e7-4ccd-abaf-a73b99d158ef">
        <updating/>
        <source>setForCreate(_proxy : CM_TerminalAreaType) updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
