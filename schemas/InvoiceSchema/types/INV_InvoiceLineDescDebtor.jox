    <JadeMethod name="setupForm" id="f766ba5d-20b3-47ae-ba61-5ab5fd6f6807">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.doCmbBankBuild();

	inheritMethod();
	self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
//	TFS 2682	self.caption := self.myCurrentBank.code &amp; " Invoice Line Debtor";
	self.setCaption("Invoice Line Debtor " &amp; self.myCurrentBank.code);

	beginClassNotification(CM_DebtorInvoiceLineDesc, false, Object_Create_Event, Response_Continuous, 0); 
	
	self.initMSG();
	self.initMSGDebtor();
	self.msgLines.setAvailable(self.myCurrentBank.invoiceLineDescriptors,true); // PAR 11827

	self.doResize();
end;</source>
