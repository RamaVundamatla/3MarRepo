    <JadeMethod name="utlCreateKPITerminalArea" id="89ef072a-c0a1-40b8-a2ba-1bf3827ff1b8">
        <source>utlCreateKPITerminalArea(_agent :CMIF_SpaceUtilisationQryAgent; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyKPI : CM_KPI;
	pxyTA, kpiTA : CM_KPITerminalArea;
	pxyLocn, kpiLocn : CM_KPILocation;
begin

	self.initialiseActivity();
	
	foreach pxyKPI in _agent.allKPITerminalAreas discreteLock do
		pxyTA := pxyKPI.CM_KPITerminalArea;
		create kpiTA persistent;
		kpiTA.setForCreate(pxyTA);
		if _passport.noErrors then
			self.myCreateAuditAgent.audCreateGeneric(kpiTA);
		endif;
		
		foreach pxyLocn in pxyTA.allKIPLocations discreteLock do
			create kpiLocn persistent;
			kpiLocn.setForCreate(pxyLocn);
			kpiLocn.setParent(kpiTA);
			
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_agent" type="CMIF_SpaceUtilisationQryAgent"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateKiosk" id="7b55659e-cc21-45dd-8b43-f00b0b72edb9">
