    <JadeMethod name="doCmbInvoiceLineTypeBuild" id="9b4f2749-d572-44b7-a215-3f506a2c67fc">
        <source>doCmbInvoiceLineTypeBuild();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theCombo : CMUI_ComboBox;
	anInvLineType : CM_InvoiceLineDesc;
begin
	theCombo := self.cmbInvLineType;
	theCombo.clear;
	theCombo.sorted := true;
	self.cmbInvLineTypeQu.clear; // PAR 34469
	self.cmbInvLineTypeQu.sorted := true; // PAR 34469
	
	foreach anInvLineType in self.myCurrentBank.invoiceLineDescriptors where not anInvLineType.isNotAvailableForEntry do
		theCombo.addItemObject(anInvLineType.getComboDescription(), anInvLineType); // ### TFS BUG 59913 31AUG2023 NAVAB1
		self.cmbInvLineTypeQu.addItemObject(anInvLineType.getComboDescription(), anInvLineType); // PAR 34469 // ### TFS BUG 59913 31AUG2023 NAVAB1
	endforeach;
	
	self.cmbInvLineTypeQu.sorted := false; // PAR 34469
	self.cmbInvLineTypeQu.addItemAt(app.getErrorString(Line_types),1); // PAR 34469
	self.cmbInvLineTypeQu.listIndex := 1; // PAR 34469
end;
</source>
