    <JadeMethod name="isOriginalDirector" id="fbff980b-abbe-42a9-a1b5-a29c958458aa">
        <source>isOriginalDirector()	:	Boolean;
//Returns TRUE if this was originally a director Task entry
vars
	aTask	: CM_RTQueueTask;
	request : CM_Request;
	bulkRel : CM_BulkRelease;
begin
	foreach aTask in self.allTasks do
		if aTask.taskType = TASK_DIRECTOR then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
