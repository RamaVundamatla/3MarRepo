    <JadeMethod name="getIdUPSPformat" id="f3d6a3f2-8328-4d67-8fc7-4d091a11a60b">
        <source>getIdUPSPformat( _ti : CM_TrackedItem ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	str : String;
	wellId : String;
	tierId : String;
	colId : String;
	
begin

	str := self.myWagon.id;
	
	wellId := self.getWellId;
	if wellId &lt;&gt; null then
		str := str &amp; " " &amp; wellId;
	endif;
	
	tierId := self.getTierId( _ti );
	if tierId &lt;&gt; null then
		str := str &amp; " " &amp; tierId;
	endif;
	
	colId := self.getColIdForUPSP( _ti );
	if colId &lt;&gt; null then
		str := str &amp; colId;
	endif;
	
	return str;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLabel" id="8573dd39-4dfc-40d1-86d5-5d5baa9be96f">
        <source>getLabel() : String;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	lWagon : CM_Wagon;
begin
	lWagon := self.myWagon;
	idx := lWagon.allLocationsControllersArray.indexOf(self);
	if idx &lt;= lWagon.myWagonClass.locationIds.size then
		return lWagon.myWagonClass.locationIds[idx];
	else
		return null;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLengthOfTIs" id="43701603-f611-4c42-89ee-d875f94b1c53">
        <source>getLengthOfTIs(_mode : Integer; _atHeight : Integer) : Real; // serverExecution;
/*
 ------------------------------------------------------------------------
Created:			24 July 2001 by cnwdwq1
Purpose:			Returns the length in 10' units of the ti's on this wagonController
Parameters:			None
Returns:			Nothing
Changed On			Changed By			Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	array : CM_TIArray;	
	ti : CM_TrackedItem;
begin
	if _atHeight &lt; 1 then
		return null;
	endif;
	if _atHeight &gt; self.myWagon.myWagonClass.maxNumInStack then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_GTMAX_HEIGHT, null, null);
		return null;
	endif;
	create array transient;
	self.getTIs(array, _mode, true); // PAR 27749
	if _atHeight = null then
		//-------------------
		//Get last in this stack
		//-------------------
		ti := array.last();
		if ti = null then
			return null;
		endif;
		if self.isBackEnd(ti, _mode) then
			//Dont count if its a back end
			return null;
		endif;
		return ti.getLengthInUnits();
	endif;
	
	if _atHeight &gt; array.size then
		return null;
	endif;
	
	ti := array[_atHeight];
	if ti = null then
		return null;
	endif;
	
	if self.isBackEnd(ti, _mode) then
		//Dont count if its a back end
		return null;
	endif;
	
	return ti.getLengthInUnits();
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_atHeight" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getLocationArea" id="8f05eb10-c852-418c-a79a-d96467d798d0">
        <source>getLocationArea(): String;
/*
Purpose:		PAR 35397	
Date				Who			Reason
JANUARY 2015		CNWAB1		Initial creation
*/
vars

begin

	if self.myTerminal.getConfig( RailDefaultWCIdFormat ).Integer = Rail_UPSP_Int then	
