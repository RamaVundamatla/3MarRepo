    <JadeMethod name="auditIdDisplay" id="49a9f67d-ace8-4498-b88b-36372d40595a">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2018	jlgmp6	Initial creation	TFS 37718

*/

vars

begin
	if self.auditId() &lt;&gt; null then
		return app.getErrorString(Line_group_debtor) &amp; Space &amp; Hyphen &amp; Space &amp; self.auditId();
	else
		return app.getErrorString(Line_group_debtor);
	endif;


epilog

end;</source>
        <ReturnType type="String"/>
