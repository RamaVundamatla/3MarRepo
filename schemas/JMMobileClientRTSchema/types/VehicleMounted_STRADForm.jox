    <JadeMethod name="beginTimerForRefresh" id="26625a5b-e34d-4630-a38b-465effbff9b9">
        <updating/>
        <source>beginTimerForRefresh() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if (not self.timerRefreshActive) then
		self.timerRefreshActive := true;
		self.beginTimer(60000, Timer_OneShot, Timer_Refresh);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="btnAccept_click" id="2215d9cd-af5b-480f-aab5-1733cf74a638">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAccept_click(btn: Button input) updating;

vars

begin

	if btn.caption = "Accept" then
		self.doAcceptTask();
	elseif btn.caption = "Pickup" then
		self.doPickupTask(null,null); //cnwrd1 ccms 2274 break bulk
	elseif btn.caption = "Setdown" then
		self.doSetdownTask();
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
