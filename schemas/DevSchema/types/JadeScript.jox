    <JadeMethod name="updateLicense" id="71692bbc-61cc-49bb-b98b-fad99a4dd304">
        <source>updateLicense();
// -----------------------------------------------------------------------------
// Created:		October 2004  by cnwrs1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	licenseName, licenseKey, licenseNameEDI, licenseKeyEDI: String;
begin
	app.initialize;
	licenseName := "JADE Master Terminal";
	licenseKey := "D500000099000000AA99D3D4CD999999999999999A9999991965B399668045666666666666DA";
	licenseNameEDI := "JADE Master Terminal (EDI)";
	licenseKeyEDI := "5D0000005C0000006B5C161108031918155C5C5C475C5C5CB687795CA3A3A35F5C5CA0A3A3A323A2A3A3A3A3A3A3A3A35F";
//License Name : JADE Master Terminal
//License Key  : 6C00000090000000A390DADDC49090909090909093909090106CBA906F844C6F6F6F91
//Product Code : JMT

//License Name : JADE Master Terminal (EDI)
//License Key  : 8B0000006100000056612B2C353E2425286161617A616161341344619E9E9E6261619D9E9E9E1E
//Product Code : JMT_EDI
	app.myTrxUA.trxUpdateLicense(CM_Root.firstInstance, licenseName, licenseKey, ProductCode_JMT, CM_Root.firstInstance.edition, app.myPassport);
	if not app.myPassport.noErrors then
		app.writeStatement( "Failed");
		return;
	endif;
	if licenseKeyEDI &lt;&gt; null then
		app.myTrxUA.trxUpdateLicense(CM_Root.firstInstance, licenseNameEDI, licenseKeyEDI, ProductCode_JMT_EDI, CM_Root.firstInstance.edition, app.myPassport);
		if not app.myPassport.noErrors then
			app.writeStatement( "Failed");
			return;
		endif;
	endif;
end;</source>
