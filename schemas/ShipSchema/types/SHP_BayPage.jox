    <JadeMethod name="addBay" id="d79491b7-51d7-476d-b8db-3c484850a6fb">
        <updating/>
        <source>addBay(_bay : CM_BayVoyage; _row, _col : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

//write class.name &amp; '::' &amp; method.name &amp; '  adding ' &amp; _bay.id &amp; ' at ' &amp; _row.String &amp; ', ' &amp; _col.asStringJMT;
	self.allBays.add(_bay);
	self.allBayRowColumns.putAtKey(_bay, _row, _col, _bay);
	self.allBaysByRowColumn.putAtKey(_row, _col, _bay);

end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_BayVoyage"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addBayToPage" id="34365c53-ba02-4ca3-9ab9-499037063286">
        <updating/>
        <source>addBayToPage(_bay : CM_BayVoyage; _printFrame : SHP_BayDrawingFrame input; _onDeck, _underDeck: Boolean; thePrintStyle : Integer; _removedBay : CM_BayVoyage output ) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     08 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRow,
	theCol,
	tmpWidth,
	tmpHeight,
	oldHeight,
	oldHeightOD,
	oldHeightUD,
	tmpHeightOD,
	tmpHeightUD,
	rowPrintHeight,
	savePrintHeight,
	rowHeightDiff,
	numRows		: Integer;
	needNewCol	: Boolean;
	lastBay		: CM_Bay;
	
begin
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. self.printHeight " &amp; self.printHeight.String);
	if _bay = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_bay', null, null);
		return false;
	endif;

//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; ' ======== handling bay ' &amp; _bay.id &amp; ' =================');

	tmpHeight := self.myController.getFrameHeightForBay(_bay, tmpHeightOD, tmpHeightUD);
	// PAR 27456 tmpWidth := self.getFrameWidthForBay(_bay);
	tmpWidth := self.getFrameWidthForHold(_bay);
	
	if self.allBays.isEmpty then
		// this is the first time so just add and leave
		// NOTE - this code is repeated further down when
		// we print out the current bays and reset for
		// adding another block
		self.allRowHeights.add(tmpHeight);
		self.allRowHeightsOD.add(tmpHeightOD);
		self.allRowHeightsUD.add(tmpHeightUD);
		self.allColWidths.add(tmpWidth);
		self.currentPrintHeight := tmpHeight;
//app.writeStatement( '  ** firstTime setting currentPrintHeight to ' &amp; self.currentPrintHeight.String);
		self.currentPrintWidth := tmpWidth;
		self.currentRow := 1;
		self.addBay(_bay, 1, 1);
		self.currentBlockStartRowPos := 0;
		return true;
	endif;
	
	lastBay := self.allBays.last;
	numRows := self.allRowHeights.size;
	
	// *** need to move calc of actual print height to here (based on OD/UD figures)
	
	if lastBay &lt;&gt; null and
	   lastBay.myHold &lt;&gt; _bay.myHold then
		// always start a new hold at the top of a column
//app.writeStatement( ' newHold so new column');
		needNewCol := true;
	else
		// need to see if height of bay will fit into the
		// vertical space available.
		theRow := self.currentRow + 1;
		if theRow &lt;= numRows then
			rowPrintHeight := self.allRowHeightsOD[theRow].max(tmpHeightOD) + self.allRowHeightsUD[theRow].max(tmpHeightUD);
			rowHeightDiff := rowPrintHeight - self.allRowHeights[theRow];
			if rowHeightDiff &gt; 0 then
				// we need to adjust the height of this row =&gt; need to check if we can
				// still fit subsequent rows onto the page
				if self.currentPrintHeight + rowHeightDiff &gt; self.printHeight then
					// insufficent room to fit this bay in the current column
//app.writeStatement(' No room 1 ' &amp; _bay.id &amp; ' so new column' );
					needNewCol := true;
				endif;
			endif;
		else
			rowPrintHeight := tmpHeightOD + tmpHeightUD;
			if self.currentPrintHeight + rowPrintHeight &gt; self.printHeight then
				// insufficent room to fit this bay in the current column
//app.writeStatement(' No room 2 ' &amp; _bay.id &amp; ' so new column' );
				needNewCol := true;
			endif;
		endif;
	endif;
	
	if needNewCol then
		if self.currentPrintWidth + tmpWidth &lt;= self.printWidth then
			// add a new column
//app.writeStatement( ' adding newCol (' &amp; tmpWidth.String &amp; ') self.currentPrintWidth + tmpWidth = ' &amp; (self.currentPrintWidth + tmpWidth).String &amp; '  self.pageWidth = ' &amp; self.printWidth.String);
			self.allColWidths.add(tmpWidth);
			
//			if thePrintStyle = CMUI_GridDrawingController.PrintOutput_Medium then	//24 Jun 2020	NDL	TFS 49651  20 Jul 2020	NDL TFS 49795 - removed again
//				theRow := self.currentRow;	
//			else
				theRow := 1;
//			endif;
			self.currentPrintWidth := self.currentPrintWidth + tmpWidth;
			
			// need to update currentPrintHeight here
			self.adjustHeightForRow(theRow, tmpHeightOD, tmpHeightUD);
		
		else
			// there is no room for a new column so
			// see if we can add a new row
			if self.currentPrintHeight + tmpHeight &gt; self.printHeight then
//app.writeStatement( ' no height for ' &amp; _bay.id &amp; ' so new column.  self.currentPrintHeight + tmpHeight = ' &amp; (self.currentPrintHeight + tmpHeight).String &amp; '  self.printHeight = ' &amp; self.printHeight.String);			
				//20 Jul 2020	NDL TFS 49795
				if thePrintStyle &lt;&gt; CMUI_GridDrawingController.PrintOutput_Large and lastBay &lt;&gt; null and lastBay.myHold = _bay.myHold then
//app.writeStatement( ' no room for a new column for ' &amp; _bay.id &amp; ' the back end of the last bay added.');
					// Even though we had room for the previous bay, this is its back end and it is not allowed to be on a subsequent page
					// so remove the previous bay and pass it back so the current page can be printed and the last bay can be put on a new page
					// with this one...
					_removedBay := lastBay.CM_BayVoyage;
					self.allBaysByRowColumn.removeKeyEntry( self.currentRow, self.allColWidths.size, _removedBay );
					self.allBayRowColumns.removeKeyEntry( _removedBay, self.currentRow, self.allColWidths.size, _removedBay );
					self.allBays.remove(_removedBay);
					return false;
				else
					return false;
				endif;
			endif;
			// Add a new block so print the current block and
			// reset the back to 1
			
			savePrintHeight := self.currentPrintHeight;
			self.printCurrentBays(_printFrame, _onDeck, _underDeck);
			self.clear();

			self.allRowHeights.add(tmpHeight);
			self.allRowHeightsOD.add(tmpHeightOD);
			self.allRowHeightsUD.add(tmpHeightUD);
			self.allColWidths.add(tmpWidth);
			self.currentPrintHeight := savePrintHeight + tmpHeight;
//app.writeStatement('  ** new block setting currentPrintHeight to ' &amp; currentPrintHeight.String &amp; '  save = ' &amp; savePrintHeight.String &amp; '  tmpHeight = ' &amp; tmpHeight.String );

			self.currentPrintWidth := tmpWidth;
			self.currentRow := 1;
			self.addBay(_bay, 1, 1);
			
			self.currentBlockStartRowPos := savePrintHeight;
			
			return true;
		endif;
	endif;
	
	if theRow &gt; numRows + 1 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'theRow(' &amp; theRow.String &amp; ') &gt; numRows(' &amp; numRows.String &amp; ') + 1');
//app.writeStatement(' ##############  theRow(' &amp; theRow.String &amp; ') &gt; numRows(' &amp; numRows.String &amp; ') + 1');
		return false;
	endif;
	
	if numRows &lt; theRow  then
		// this is the first time we have added this row
		self.allRowHeights.add(tmpHeight);
		self.allRowHeightsOD.add(tmpHeightOD);
		self.allRowHeightsUD.add(tmpHeightUD);
		self.currentPrintHeight := self.currentPrintHeight + tmpHeight;
	else
		
		self.adjustHeightForRow(theRow, tmpHeightOD, tmpHeightUD);
	
		if self.currentPrintHeight &gt; self.printHeight then
			// could readjust other rows and see if can get
			// to fit (ie 3 rows in col 1 could become 2 rows in col 1 and 1 row in col 2)
			// If do this then need to have a maxRows and reset to current value - 1 before
			// rejigging print positions
//app.writeStatement(' self.currentPrintHeight &gt; self.printHeight (' &amp; self.currentPrintHeight.String &amp; ') &gt; (' &amp; self.printHeight.String &amp; ')');
			return false;
		endif;
	endif;

	self.currentRow := theRow;
	theCol := self.allColWidths.size;
	
	self.addBay(_bay, theRow, theCol);

//app.writeStatement(' added ' &amp; _bay.id &amp; " @ row " &amp; theRow.String &amp; ", col " &amp; theCol.String);
	// can fit this bay on the page
	return true;
	
end;</source>
        <Parameter name="_bay" type="CM_BayVoyage"/>
        <Parameter name="_printFrame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_underDeck" type="Boolean"/>
        <Parameter name="thePrintStyle" type="Integer"/>
        <Parameter name="_removedBay" type="CM_BayVoyage" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="adjustHeightForRow" id="0790db68-7e85-48ff-8256-41049b300f1b">
        <updating/>
        <source>adjustHeightForRow(_theRow, _newHeightOD, _newHeightUD : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 14/07/2022	jlizm1	TFS 54057 When printing a new row of bays not caluclating print height correctly
//
vars
	oldHeight,
	oldHeightOD,
	oldHeightUD,
	tmpHeight	: Integer;

begin

	oldHeight := self.allRowHeights[_theRow];
	oldHeightOD := self.allRowHeightsOD[_theRow];
	oldHeightUD := self.allRowHeightsUD[_theRow];

	if oldHeightOD &lt; _newHeightOD or
	   oldHeightUD &lt; _newHeightUD then
		// the current height for this row less than the
		// height required for this bay so need to adjust
		if oldHeightOD &lt; _newHeightOD then
			self.allRowHeightsOD[_theRow] := _newHeightOD;
		endif;
		if oldHeightUD &lt; _newHeightUD then
			self.allRowHeightsUD[_theRow] := _newHeightUD;
		endif;
		tmpHeight := oldHeightOD.max(_newHeightOD) + oldHeightUD.max(_newHeightUD);
		self.allRowHeights[_theRow] := tmpHeight;
		//self.currentPrintHeight := self.currentPrintHeight - oldHeight + tmpHeight;
		//write class.name &amp; '::' &amp; method.name &amp; ' ** setting currentPRintHeight to ' &amp; self.currentPrintHeight.asStringJMT;
		
		//20 Jul 2020	NDL	TFS 49795 - The actual size needed because they are kept in line in the printout is the highest of each row, multipled by the number of rows.
		// TFS 54057 make sure to account for the fact that the block of rows may not start at position 0
		self.currentPrintHeight := self.currentBlockStartRowPos + (( self.allRowHeightsOD.getMaxValue + self.allRowHeightsUD.getMaxValue ) * self.allRowHeights.size);
		
		if self.currentPrintHeight &gt; self.printHeight then				// TFS 54057
			// this row is going to overflow page, revert height value so any bays that have been added will use the correct heights
			self.allRowHeightsOD[_theRow] := oldHeightOD;				// TFS 54057
			self.allRowHeightsUD[_theRow] := oldHeightUD;				// TFS 54057
			self.allRowHeights[_theRow] := oldHeightOD + oldHeightUD;	// TFS 54057
		endif;
	
	endif;
		
	//write class.name &amp; '::' &amp; method.name &amp; ' ** ROW (' &amp; _theRow.String &amp; ')  oldHeight = ' &amp; 
	//			oldHeight.String &amp; '  newHeight = ' &amp; (_newHeightOD + _newHeightUD).String &amp;
	//			'  tmpHeight = ' &amp; tmpHeight.asStringJMT;

end;</source>
        <access>protected</access>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_newHeightOD" type="Integer"/>
        <Parameter name="_newHeightUD" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clear" id="8e81a36a-ac18-4829-8e9b-775f91db5667">
        <updating/>
        <source>clear() updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.allBayRowColumns.clear;
	self.allBaysByRowColumn.clear;
	self.allBays.clear;
	self.allColWidths.clear;
	self.allRowHeights.clear;
	self.allRowHeightsOD.clear;
	self.allRowHeightsUD.clear;
	
	self.currentPrintHeight := 0;
	self.currentPrintWidth	:= 0;
	self.currentRow := 0;
	self.maxHeightOD := 0;
	self.maxHeightUD := 0;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="9d613e98-b99b-43c6-8105-59b9666c5538">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myBayRowColumnIterator := self.allBayRowColumns.createIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="4d22beb0-0150-459c-9345-2583892650eb">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	delete self.myBayRowColumnIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="getFrameWidthForBay" id="af9a5632-62fb-478e-84fb-7fdabfcd65eb">
        <source>getFrameWidthForBay(_bay : CM_Bay) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     29 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.myController.getFrameWidthForBay(_bay.getMaxCells(self.myController.displayMode), self.myController.columnWidth); // PAR 26760
end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFrameWidthForHold" id="7f507257-63be-4796-b2d5-b9f9d4fa9758">
        <source>getFrameWidthForHold(_bay : CM_Bay) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     29 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	bay1width, bay2width : Integer;
	otherBay : CM_Bay;
	theHold : CM_Hold;
	bayID : String;
begin

	// PAR 27456 get widest for hold
	if _bay.isFirstInHold() then
		bay1width := self.myController.getFrameWidthForBay(_bay.getMaxCells(self.myController.displayMode), self.myController.columnWidth); // PAR 26760
		
		theHold := _bay.myHold;
		if theHold &lt;&gt; null then
			otherBay :=theHold.allBays.last;
			if otherBay &lt;&gt; null then
				bay2width := self.myController.getFrameWidthForBay(otherBay.getMaxCells(self.myController.displayMode), self.myController.columnWidth); 
				if bay2width &gt; bay1width then
					return bay2width;
				else
					return bay1width;
				endif;
			else
				return bay1width;
			endif;
		else
			return bay1width;
		endif;
	else
		bay2width := self.myController.getFrameWidthForBay(_bay.getMaxCells(self.myController.displayMode), self.myController.columnWidth); 
		
		theHold := _bay.myHold;
		if theHold &lt;&gt; null then
			otherBay :=theHold.allBays.first;
			if otherBay &lt;&gt; null then
				bay1width := self.myController.getFrameWidthForBay(otherBay.getMaxCells(self.myController.displayMode), self.myController.columnWidth); 
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' XX 1.' &amp; _bay.id &amp; " - " &amp; bay2width.String &amp; ' 2.' &amp; otherBay.id &amp; " - " &amp; bay1width.String);				
				
				if bay2width &gt; bay1width then
					return bay2width;
				else
					return bay1width;
				endif;
			else
				return bay2width;
			endif;
		else
			return bay2width;
		endif;
	endif;

	
	return self.myController.getFrameWidthForBay(_bay.getMaxCells(self.myController.displayMode), self.myController.columnWidth); // PAR 26760
end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPrintPositionForBay" id="bb39cb20-9a6d-4cce-8f0d-00e462aa4ebc">
        <source>getPrintPositionForBay(_bay : CM_BayVoyage; _row, _col : Integer output) protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	keyBay	: CM_BayVoyage;
	keyRow,
	keyCol	: Integer;
begin
	iter := self.myBayRowColumnIterator;
	self.allBayRowColumns.startKeyGeq(_bay, 0, 0, iter);
	self.allBayRowColumns.getIteratorKeys(keyBay, keyRow, keyCol, iter);
	
	if keyBay &lt;&gt; _bay then
		app.raiseUnexpectedProgramError(class.name, method.name, 'keyBay (' &amp; keyBay.String &amp; ') does not match _bay (' &amp; _bay.String &amp; ')');
		return;
	endif;
	
	_row := keyRow;
	_col := keyCol;
	
end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_BayVoyage"/>
        <Parameter name="_row" type="Integer" usage="output"/>
        <Parameter name="_col" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="init" id="17af3b4c-d4eb-4f2c-9671-7c9496195452">
        <updating/>
        <source>init(_controller : SHP_BayDrawingController) updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.pageHeight	:= app.printer.pageHeight();
	self.pageWidth	:= app.printer.pageWidth();

	self.myController	:= _controller;
	self.printHeight	:= self.pageHeight - SHP_VoyageAreaForm2.ReportTop;
	self.printWidth		:= self.pageWidth - SHP_VoyageAreaForm2.ReportLeft - SHP_VoyageAreaForm2.ReportLegendWidth - 10;
	
	self.timeStr := app.actualTimeServer.cnEcShortFullFormat; // PAR 10070 //reportDisplayLong();

	self.clear();
end;</source>
        <Parameter name="_controller" type="SHP_BayDrawingController"/>
    </JadeMethod>
    <JadeMethod name="print" id="f749fe2e-8865-402b-905d-9b979c13bc8b">
        <updating/>
        <source>print(_reportLine : CMUI_ReportLine input; _printFrame : SHP_BayDrawingFrame input;
		_largeTitle : String; _onDeck, _underDeck: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBay	: CM_BayVoyage;
	numRows,
	numCols,
	theRow,
	theCol,
	theHeight,
	theWidth,
	theX,
	theY	: Integer;

begin

	//write class.name &amp; '::' &amp; method.name &amp; '  printing page - numBays = ' &amp; self.allBays.size.asStringJMT;

	app.printer.drawRectangle(SHP_VoyageAreaForm2.ReportLeft, SHP_VoyageAreaForm2.ReportTop, self.pageWidth, self.pageHeight, Black);
	
	self.printCurrentBays(_printFrame, _onDeck, _underDeck);

	if _largeTitle &lt;&gt; null then
		_reportLine.lblTitle02.caption := _largeTitle &amp; ' ' &amp; self.bayIdStr;
	endif;

	// print the page header
	app.printer.setPrintPosition(0);
	app.printer.print(_reportLine.frHeader);
	
	// print the page footer
	self.printPageFooter(_reportLine);

end;</source>
        <Parameter name="_reportLine" type="CMUI_ReportLine" usage="input"/>
        <Parameter name="_printFrame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_largeTitle" type="String"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_underDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printBayArray" id="f57c483f-3d43-47ab-9fe3-a75d41980e72">
        <updating/>
        <source>printBayArray(_printFrame : SHP_BayDrawingFrame input; _bayArray : CM_BayVoyageArray; _onDeck, _underDeck: Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/10/2011	cnwdap1		PAR #28106 Change 'theY' position to be top of frame 
//							to fix problem with bays splitting over two pages
vars
	tmpBay	: CM_BayVoyage;
	numRows,
	numCols,
	theRow,
	theCol,
	theHeight,
	theWidth,
	theX,
	theY	: Integer;

begin

	//write class.name &amp; '::' &amp; method.name &amp; '  printing page - numBays = ' &amp; self.allBays.size.asStringJMT;

	numRows := self.allRowHeights.size;
	numCols := self.allColWidths.size;
	
	self.myController.setDrawingPositionsForPrinting(_bayArray);

	foreach tmpBay in _bayArray do
		self.getPrintPositionForBay(tmpBay, theRow, theCol);
		if theRow = 0 or theRow &gt; numRows or
		   theCol = 0 or theCol &gt; numCols then
			app.raiseUnexpectedProgramError(class.name, method.name, 'getPrintPosition returned ' &amp; 
						theRow.String &amp; '/' &amp; numRows.String &amp; ', ' &amp;
						theCol.String &amp; '/' &amp; numCols.String);
			continue;
		endif;
		
		theHeight := self.allRowHeights[theRow];
		theWidth := self.allColWidths[theCol];

		theX := self.allColStartPositions[theCol] + SHP_VoyageAreaForm2.ReportLegendWidth + 20;
		//theY := self.allRowStartPositions[theRow] + SHP_VoyageAreaForm2.ReportTop;		// PAR #28106
		theY := self.allRowStartPositions[theRow] + SHP_VoyageAreaForm2.ReportTop - 1;		// PAR #28106
		
		_printFrame.init(tmpBay, 0, 0, theWidth, theHeight, White, self.myController);
		_printFrame.drawSelf(self.myController, _onDeck, _underDeck);
	
		//percentDone := (theGridPC / theGridSize) * 100;
		//self.lblPrintProgress.caption := "Printing " &amp; percentDone.String &amp; "%";
		//self.lblPrintProgress.refreshNow;
		
		//write class.name &amp; '::' &amp; method.name &amp; ' printing ' &amp; tmpBay.id &amp; ' at ' &amp; 
		//		theRow.String &amp; ', ' &amp; theCol.String &amp; '  pos ' &amp;
		//		theX.String &amp; ', ' &amp; theY.String &amp; ' h/w ' &amp;
		//		theHeight.String &amp; ', ' &amp; theWidth.asStringJMT;
		
		_printFrame.move(theX, theY, theWidth, theHeight);
		app.printer.setPrintPosition(theY);				
		app.printer.print(_printFrame);

	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_printFrame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_bayArray" type="CM_BayVoyageArray"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_underDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printCurrentBays" id="3575f0b2-a3ea-4ab6-8bd2-5965d71e91ec">
        <updating/>
        <source>printCurrentBays(_printFrame : SHP_BayDrawingFrame input; _onDeck, _underDeck: Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBay	: CM_BayVoyage;
	numRows,
	numCols,
	prevRow,
	theRow,
	theCol,
	theHeight,
	theWidth,
	theX,
	theY	: Integer;
	tmpBayIdStr	: String;
	tmpBayArray	: CM_BayVoyageArray;

begin

	//write class.name &amp; '::' &amp; method.name &amp; '  printing page - numBays = ' &amp; self.allBays.size.asStringJMT;

	self.setStartPositions();

	numRows := self.allRowHeights.size;
	numCols := self.allColWidths.size;

	create tmpBayArray transient;

	foreach tmpBay in self.allBaysByRowColumn do
		if tmpBayIdStr = null then
			tmpBayIdStr := tmpBay.id;
		else
			tmpBayIdStr := tmpBayIdStr &amp; ', ' &amp; tmpBay.id;
		endif;
		// change to iter get keys
		self.getPrintPositionForBay(tmpBay, theRow, theCol);
		if theRow = 0 or theRow &gt; numRows or
		   theCol = 0 or theCol &gt; numCols then
			app.raiseUnexpectedProgramError(class.name, method.name, 'getPrintPosition returned ' &amp; 
						theRow.String &amp; '/' &amp; numRows.String &amp; ', ' &amp;
						theCol.String &amp; '/' &amp; numCols.String);
			continue;
		endif;
		
		if theRow &lt;&gt; prevRow then
			prevRow := theRow;
			if tmpBayArray.size &gt; 0 then
				self.printBayArray(_printFrame, tmpBayArray, _onDeck, _underDeck);
				tmpBayArray.clear;
			endif;
		endif;

		tmpBayArray.add(tmpBay);
		
		//percentDone := (theGridPC / theGridSize) * 100;
		//self.lblPrintProgress.caption := "Printing " &amp; percentDone.String &amp; "%";
		//self.lblPrintProgress.refreshNow;
		
	endforeach;

	if tmpBayArray.size &gt; 0 then
		self.printBayArray(_printFrame, tmpBayArray, _onDeck, _underDeck);
	endif;

	self.bayIdStr := tmpBayIdStr;

epilog
	delete tmpBayArray;
end;</source>
        <access>protected</access>
        <Parameter name="_printFrame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_underDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printPageFooter" id="f352487a-a52f-453a-8164-72b45c8a505b">
        <source>printPageFooter(_reportLine : CMUI_ReportLine input) protected;
// ---------------------------------------------------------------------------
// Created:     29 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	PAGELABELWIDTH = 250;	//300;

begin
	app.printer.setPrintPosition(self.pageHeight - 22);

	_reportLine.frDetail.height := 15;
	_reportLine.lblDetail.height := _reportLine.frDetail.height;
	_reportLine.lblDetail.width := PAGELABELWIDTH;
	_reportLine.frDetail.width := PAGELABELWIDTH;
	_reportLine.printLine("Page " &amp; app.printer.pageNumber.String &amp; ".  " &amp; self.timeStr);

end;</source>
        <access>protected</access>
        <Parameter name="_reportLine" type="CMUI_ReportLine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setStartPositions" id="9881465a-6cfe-4cbe-912c-f4e5f06d976d">
        <source>setStartPositions() protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx,
	tot		: Integer;

begin

	self.allColStartPositions.clear;
	self.allColStartPositions.add(0);
	tot := 0;
	foreach idx in self.allColWidths do
		tot := tot + idx;
		self.allColStartPositions.add(tot);
	endforeach;

	self.allRowStartPositions.clear;
	tot := self.currentBlockStartRowPos;
	self.allRowStartPositions.add(tot);
	foreach idx in self.allRowHeights do
		tot := tot + idx;
		self.allRowStartPositions.add(tot);
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
