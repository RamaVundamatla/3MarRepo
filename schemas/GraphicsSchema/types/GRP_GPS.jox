    <JadeMethod name="drawGridGPS" id="b41da158-9a21-4d2f-bbb2-259204633ed1">
        <executionLocation>client</executionLocation>
        <source>drawGridGPS() clientExecution;
// ---------------------------------------------------------------------------
// Created:		19 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	RowGap = 40;
	ColGap = 120;
	Margin = 60;
vars
	row, col, idx, idy : Integer;
	x1,x2,y1,y2 : Integer;
	midX, midY : Integer;
	gpsXY : CMIF_GPS;
begin
	frame1.autoRedraw := true;
	frame1.drawFontSize := 20;
	frame1.clearGraphics();

	y1 := Margin;
	y2 := y1 + RowGap;
	row := (Margin / 2).Integer;
	foreach idx in 1 to 6 do
		x1 := Margin;
		x2 := x1 + ColGap;

		row := row + RowGap;
		frame1.drawTextAt(self.labelsRow[idx],5, row,Black);
		foreach idy in 1 to 7 do
		
			frame1.drawTextAt(self.labelsCol[idy],x1 + (ColGap / 2).Integer, (Margin / 2).Integer, Black);
		
			frame1.drawRectangle(x1,y1,x2,y2,Black);
			midX := (((x2 - x1) / 2) + x1).Integer;
			midY := (((y2 - y1) / 2) + y1).Integer;
			
			frame1.drawRectangle(midX -1, midY - 1, midX + 1, midY + 1, Red);
			if self.coordCol.size &lt; self.labelsCol.size then
				self.coordCol.add(midX);
			endif;

			x1 := x2;
			x2 := x1 + ColGap;
			
		endforeach;
		if self.coordRow.size &lt; self.labelsRow.size then
			self.coordRow.add(midY);
		endif;
		y1 := y2;
		y2 := y1 + RowGap;
	endforeach;
	
	//self.inspect;
end;</source>
    </JadeMethod>
    <JadeMethod name="frame1_mouseUp" id="a30517dd-c981-430e-97cc-e9b473fb321f">
        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frame1_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		19 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.getLocation(x,y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getLocation" id="9c52f1fd-041e-46c8-85ff-5c5bfec33aaf">
        <source>getLocation(x,y : Real);
// ---------------------------------------------------------------------------
// Created:		20 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	row, col, ennd, idx, idy : Integer;
	tmpGPS2, tmpGPS1 : Integer;
begin

	// ### COLUMN
	ennd := self.coordCol.size;
	col := 1;
	foreach idx in 1 to ennd do
		if x &gt; self.coordCol[idx] then
			if idx = ennd then
				col := idx;
			else
				tmpGPS1 := (x - self.coordCol[idx]).Integer.abs();
				tmpGPS2 := (x - self.coordCol[idx + 1]).Integer.abs();
				
				if tmpGPS1 &lt; tmpGPS2 then
					col := idx;
				else
					col := idx +1;
				endif;
			
			endif;
		endif;
	endforeach;

	// ### ROW
	row := 1;
	ennd := self.coordRow.size;
	foreach idx in 1 to ennd do
		if y &gt; self.coordRow[idx] then
			if idx = ennd then
				row := idx;
			else
				tmpGPS1 := (y - self.coordRow[idx]).Integer.abs();
				tmpGPS2 := (y - self.coordRow[idx + 1]).Integer.abs();
				
				if tmpGPS1 &lt; tmpGPS2 then
					row := idx;
				else
					row := idx +1;
				endif;
			
			endif;
		endif;
	endforeach;

	self.label1.caption := self.labelsRow[row] &amp; "/" &amp; self.labelsCol[col];

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="load" id="648fd16a-afcd-43dd-85ee-3a4eafd29966">
        <controlMethod name="Form::load"/>
