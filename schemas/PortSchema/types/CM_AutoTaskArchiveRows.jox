<Class name="CM_AutoTaskArchiveRows" id="1ebbdd71-9942-4403-87c7-bc46977ebbfb">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Archive Rows&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="hoursAhead" id="81000a5b-0061-4e4c-9299-165ed19dc69b">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="terminalAreaType" id="b925e7fe-942f-419a-a138-48d93b9dc6d4">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getEntryTableViewName" id="2209e5c0-fed3-451f-9813-63679e49545c">
        <source>getEntryTableViewName(): String;

// cnwdvb1 16 January 2003 

vars

begin

	return 'bgpAutoViewArchiveRows';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="6ba76bad-ecd5-4086-90fc-c394dd51e3f7">
        <source>getValueForRow(_rowName : String; _obj : Object output): Any;

// cnwdvb1 16 January 2003 

vars

begin
	
	if _rowName =ETRow_BgpAutoHoursAhead then
		return hoursAhead;
	elseif _rowName = ETRow_BgpAutoTATypes then
		return self.terminalAreaType;
	endif;
	return inheritMethod(_rowName, _obj);

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b89ebf3c-0ba7-4574-a321-cdc73b27b946">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskArchiveRows) updating;

// cnwdvb1 16 January 2003 

vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName	:= BGP_ArchiveRowsRequest.name;
	self.hoursAhead			:= _pxyAutoTask.hoursAhead;
	self.terminalAreaType	:= _pxyAutoTask.terminalAreaType;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskArchiveRows"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="53247aa5-421a-4ff9-bb0a-1a4e6dd798e1">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskArchiveRows) updating;

// cnwdvb1 17 January 2003 

vars

begin
	inheritMethod(_pxyAutoTask);
	self.hoursAhead			:= _pxyAutoTask.hoursAhead;
	self.terminalAreaType	:= _pxyAutoTask.terminalAreaType;


end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskArchiveRows"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="a3e479d6-6fdc-44fc-b5d2-b6bea914ba97">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;

// cnwdvb1 17 January 2003 

vars

begin

	if _rowName = ETRow_BgpAutoHoursAhead then
		self.hoursAhead := _value.Integer;
	elseif _rowName = ETRow_BgpAutoTATypes then
		self.terminalAreaType := _value.Integer;
	else
		inheritMethod(_rowName, _value);
	endif;	
	

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="1f1bf22f-d56f-4587-a5a5-6d7c53705c25">
        <source>validate();

// cnwdvb1 17 January 2003 
// 12/12/2014  cnwdb2	PAR 35364

vars

begin
	
	inheritMethod();
	if self.hoursAhead = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Number of hours empty', ETRow_BgpAutoHoursAhead, null);
		app.raiseCMException(Input_required_field_NumHrsEmp, ETRow_BgpAutoHoursAhead, null);// cnwdb2	PAR 35364 

	endif;
	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_BgpAutoTerminals, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_BgpAutoTerminals, null); // cnwdb2	PAR 35364


	endif;

	// No validation for terminal area type as 0 is valid.	
end;</source>
    </JadeMethod>
</Class>
