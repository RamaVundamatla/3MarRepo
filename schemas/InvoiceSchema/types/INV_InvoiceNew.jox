    <JadeMethod name="getMyCargoGroup" id="db597d0a-6a51-4792-a8d2-8a86a75f0069">
        <source>getMyCargoGroup(_id			: String;
				_cargoType	: CM_CargoType
				) : CM_CargoGroup protected;
/*

Purpose:			Gets the cargo group from the currently selected values

Parameters:			_id			String			The id of the cargo group
					_cargoType	CM_CargoType	The cargo type of the cargo group

Return Value:		CM_CargoGroup	Representing the cargo group that was found

Date			Who		Reason
03 October 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	tiSet	    : CM_TISet;
	ti		    : CM_TrackedItem;
	cargoTypeId : Integer;
	iter        : Iterator;
	
begin
	if _id = null then
		return null;
	endif;
	 
	if _cargoType &lt;&gt; null then
		cargoTypeId := _cargoType.id;
	endif;
	
	create tiSet transient;
	
	self.myTerminal.allCargoGroupsByIdCargoType.lookupByIDExactMatch(_id, _cargoType.id, app.myPassport, false, false, tiSet);
	
	if tiSet &lt;&gt; null then
		foreach ti in tiSet do
			if ti.id &lt;&gt; _id then
				break;
			endif;
			
			if _cargoType &lt;&gt; null and ti.myCargoType &lt;&gt; _cargoType then
				break;
			endif;
			
			if not ti.isKindOf(CM_CargoGroup) then
				break;
			endif;
			
			return ti.CM_CargoGroup;
			
		endforeach;
	endif;
	
	return null;
	
epilog
	delete tiSet;
	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <ReturnType type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="getMyTrackedItem" id="2fb4877d-f2ca-4136-92b4-47c7d01f5665">
        <source>getMyTrackedItem(_id		: String;
				_cargoType	: CM_CargoType;
				_subType : CM_Product;
				_commodity : CM_Commodity;
				_operator	: CM_Operator;
				_location	: CM_LocationsController
				) : CM_TrackedItem protected;
/*

Purpose:			Gets the tracked item from the currently selected values

Parameters:			_id			String					The id of the tracked item
					_cargoType	CM_CargoType			The cargo type of the tracked item
					_operator	CM_Operator				The operator of the tracked item
					_location	CM_LocationsController	The locations controller of the tracked item

Return Value:		CM_TrackedItem	Representing the tracked item that was found

Date				Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	tiSet	    : CM_TISet;
	ti		    : CM_TrackedItem;
	cargoTypeId : Integer;
	iter        : Iterator;
	
begin
	if _id = null then
		return null;
	endif;
	
	if _cargoType &lt;&gt; null then 			// TFS 46054
		cargoTypeId := _cargoType.id;	// TFS 46054
	endif;
	
	create tiSet transient;
	
	self.myTerminal.lookupAllOnsiteTrackedItems(cargoTypeId, _id, tiSet, false, null);
	
	//cnwmc5 - 22 Feb 2016 - PAR 37550 - check onship if not onsite..
	if tiSet.isEmpty then
		self.myTerminal.lookupAllOnShipTrackedItems(_id, cargoTypeId, false, false, false, tiSet, null);
	endif;
	
	if tiSet &lt;&gt; null then
		foreach ti in tiSet do
			if ti.id &lt;&gt; _id then
				break;
			endif;
			if _cargoType &lt;&gt; null and ti.myCargoType &lt;&gt; _cargoType then
				break;
			endif;
			
			// ### JIRA 33006 15OCT2024 NAVAB1
			if _subType &lt;&gt; null and ti.myProduct &lt;&gt; _subType then
				continue;
			endif;
			if _commodity &lt;&gt; null and ti.commodity &lt;&gt; _commodity.code then
				continue;
			endif;
			
			if _operator &lt;&gt; null and ti.myOperator &lt;&gt; _operator then
				continue;
			endif;
			if _location &lt;&gt; null and ti.myPrimaryActualLocation &lt;&gt; _location then
				continue;
			endif;
			
			return ti;
			
		endforeach;
	endif;
	
	// when tiSet is null - to check offsite
	//return self.myTerminal.lookupOffsiteTrackedItem(cargoTypeId, _id, true);
	if _location = null then
		iter := self.myTerminal.allOffsiteTIsByIdCargoType.createIterator;
	    self.myTerminal.allOffsiteTIsByIdCargoType.startKeyGeq(_id,cargoTypeId,null, iter);  //14.02.2020 cnwma1 #48578
		while iter.next( ti ) do
			if ti.id &lt;&gt; _id then
				break;
			endif;
			if _cargoType &lt;&gt; null and ti.myCargoType &lt;&gt; _cargoType then
				break;
			endif;
			
			// ### JIRA 33006 15OCT2024 NAVAB1
			if _subType &lt;&gt; null and ti.myProduct &lt;&gt; _subType then
				continue;
			endif;
			if _commodity &lt;&gt; null and ti.commodity &lt;&gt; _commodity.code then
				continue;
			endif;
			
			if _operator &lt;&gt; null and ti.myOperator &lt;&gt; _operator then
				continue;
			endif;	
			return ti;
		endwhile;
	endif;
	
	return null;
	
epilog
	delete tiSet;
	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_subType" type="CM_Product"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
