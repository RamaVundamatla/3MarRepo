<CollClass name="CM_QueryCriteriaHolderArray" id="af8c70bd-7a1b-4134-89a4-05186a1762a9">
    <memberType name="CM_QueryCriteriaLineHolder"/>
    <superclass name="ObjectArray"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="cloneContents" id="fb8e812f-e1c2-4c57-b52f-c5b961d996c9">
        <source>cloneContents(_holderArray : CM_QueryCriteriaHolderArray input);

// Created by cnwdvb1 on 03 August 2006

vars

	clonedCritHolder,
	critHolder 			: CM_QueryCriteriaLineHolder;
	isTrans			: Boolean;
	critLine,
	clonedCritLine	: CM_SelectorCriteriaLine;

begin

	_holderArray.purge();
	isTrans := self.isTransient;
	
	foreach critHolder in self do
		clonedCritHolder := critHolder.cloneSelf(isTrans);
		_holderArray.add(clonedCritHolder);
		foreach critLine in critHolder.allCriteriaByPropertyName do
			clonedCritLine := critLine.cloneSelf(true);
			clonedCritLine.setMyCriteriaLineHolder(clonedCritHolder);
		endforeach;
	endforeach;
	
end;</source>
        <Parameter name="_holderArray" type="CM_QueryCriteriaHolderArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="cd9d23de-260b-4b12-9496-9fa45d145e32">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected, lockReceiver;

// Created by cnwdvb1 on 03 August 2006

vars

begin

	self.purge();

end;</source>
        <access>protected</access>
    </JadeMethod>
</CollClass>
