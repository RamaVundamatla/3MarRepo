	self.doSelectItemTable();
end;</source>
    </JadeMethod>
    <JadeMethod name="filter" id="0d55293f-d2ae-41d8-9faf-f1093c1d5e97">
        <source>filter(_voyage : CM_Voyage; _ts : TimeStamp):Boolean;
/*
	Created on 21 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/
vars
	currentDate	: Date;
	futureDate	: Date;
	arriveDate	: Date;
	
begin
	currentDate	:=	_ts.date();
	futureDate	:=	currentDate.cnEcAddMonths(2);
	arriveDate	:=	_voyage.arrivedDT.date();
	
	if arriveDate &gt;= currentDate
	and arriveDate &lt;= futureDate
//	and _voyage.hasStockBookingRef()
	then
// cnwdad1 30/06/2008 - PAR #17310, add check for active Voyage.
		//return true;
		return _voyage.isActiveDisplay(_ts);
	endif;
	
	return false;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTableSettings" id="11aacded-a9e7-4e46-abde-25f79e7d9ff3">
        <source>getTableSettings(_columns: Integer output; _header: String output);
/*
	Created on 28 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	_columns := 2;
	_header := 'Vessel Name' &amp; Tab &amp; 'Arrival';
end;</source>
        <Parameter name="_columns" type="Integer" usage="output"/>
        <Parameter name="_header" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getVoyageDisplay" id="1586dc71-7fb1-456e-9f0c-2582620a6aaf">
        <source>getVoyageDisplay(_voyage : CM_Voyage input) : String;
// ---------------------------------------------------------------------------
// Created:     29 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	vesselName		: String;
	arrivalDT		: String;
	
begin
	vesselName	:=	_voyage.vesselName;
	arrivalDT	:=	self.systemToLocalTime(_voyage.arrivedDT).asStringJMT();	// 8/6/16 cnwmp6 TFS 488 - Multi timezone support
	
	return vesselName &amp; Tab &amp; arrivalDT;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadTable" id="aadc0f66-dc59-478a-b212-cad3e25e699a">
        <updating/>
        <source>loadTable() updating;
/*
	Created on 28 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	voyage			: CM_Voyage;
	activeVoyages	: CM_VoyageByDepartDTCodeDict;
	ts				: TimeStamp;
	tableObj		: CM_MobTable;
	
begin
	tableObj			:=	tbl_Items;
	tableObj.autoSize	:=	Table.AutoSize_Both;
	tableObj.rows		:=	1;
	ts					:=	app.actualTimeServer();
	activeVoyages		:=	self.myMobileDataAgent.myTerminal.allVoyagesByDepartDTCode;
	
	foreach voyage in activeVoyages do
		if filter(voyage, ts) then
			self.addVoyageToTable(tableObj, voyage);
		endif;
	endforeach;	
end;</source>
    </JadeMethod>
