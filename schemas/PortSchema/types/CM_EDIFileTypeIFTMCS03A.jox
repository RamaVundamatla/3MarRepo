    <JadeMethod name="create" id="383edc9b-3766-494c-873d-8b30edd1d2fa">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     July 2006 cmwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "IFTMCS 03A - Booking Reference";
	self.type	:= EDIFileType_IFTMCS03A;
end;</source>
    </JadeMethod>
    <JadeMethod name="doUNTFileSizeCheck" id="fe4e83be-473b-4243-a384-006dcca4e8b7">
        <source>doUNTFileSizeCheck(): Boolean protected;
/*
Date		Who		Reason
11 July 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
vars

begin
	return false;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
