    <JadeMethod name="setControlsForAddEdit" id="b238b7b0-bcb6-44b4-8152-fe25567ad71a">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm     : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_Name);
		//theForm.tblInput1.enableRowByName(ETRow_Colour);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.mulSelect1.setSelected(null);
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_EventTypeGroup);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.mulSelect1.setSelected(theForm.myProxyObject.CM_EventTypeGroup.allEventTypes);
	endif;
	
	self.enableMulSelect1Contents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="cc865334-8b33-42e0-894c-7d88fac69e71">
        <updating/>
        <source>setCtrlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
