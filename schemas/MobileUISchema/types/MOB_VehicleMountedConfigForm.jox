    <JadeMethod name="tblChgQ_keyUp" id="09684771-d5f1-4a08-b50a-59502370d9e6">
        <controlMethod name="Table::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblChgQ_keyUp(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwer1	Initial creation

*/

vars

begin
	if keyCode = J_key_UpArrow or
		keyCode = J_key_DownArrow then
		table.click(table);
	endif;
epilog

end;</source>
