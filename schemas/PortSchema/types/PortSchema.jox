    <JadeMethod name="yardOpsDeliveryTypeEnumToStr" id="3215689c-99b7-4dae-9577-7c871163b3f0">
        <source>yardOpsDeliveryTypeEnumToStr(deliveryCheckOption : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2022	navds20	52720 Delivery Requests - All Release Types

*/

begin
if deliveryCheckOption = DELIVERY_PACK_ONLY then
		return DELIVERY_PACK_ONLY_STR;
	elseif deliveryCheckOption = DELIVERY_ROAD_ONLY then
		return DELIVERY_ROAD_ONLY_STR;
	elseif deliveryCheckOption = DELIVERY_RAIL_ONLY then
		return DELIVERY_RAIL_ONLY_STR;
	elseif deliveryCheckOption = DELIVERY_SHIP_ONLY then
		return DELIVERY_SHIP_ONLY_STR ;
	elseif deliveryCheckOption = DELIVERY_PACK_ROAD then
		return DELIVERY_PACK_ROAD_STR;
		elseif deliveryCheckOption = DELIVERY_PACK_RAIL then
		return DELIVERY_PACK_RAIL_STR;
	elseif deliveryCheckOption = DELIVERY_PACK_SHIP then
		return DELIVERY_PACK_SHIP_STR;
	elseif deliveryCheckOption = DELIVERY_PACK_ROAD_RAIL then
		return DELIVERY_PACK_ROAD_RAIL_STR;
	elseif deliveryCheckOption = DELIVERY_PACK__ROAD_SHIP then
		return DELIVERY_PACK_ROAD_SHIP_STR;
	elseif deliveryCheckOption = DELIVERY_PACK_RAIL_SHIP then
		return DELIVERY_PACK_RAIL_SHIP_STR;
	elseif deliveryCheckOption = DELIVERY_ALL then
		return DELIVERY_ALL_STR;
	elseif deliveryCheckOption = DELIVERY_ROAD_RAIL then
		return DELIVERY_ROAD_RAIL_STR;
	elseif deliveryCheckOption = DELIVERY_ROAD_SHIP then
		return DELIVERY_ROAD_SHIP_STR;
	elseif deliveryCheckOption = DELIVERY_RAIL_SHIP then
		return DELIVERY_ROAD_SHIP_STR;
	else
		return DELIVERY_ALL_STR;
	endif;
epilog

end;</source>
        <Parameter name="deliveryCheckOption" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
