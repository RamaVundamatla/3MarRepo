    <JadeMethod name="getObjects" id="7af606cf-3471-4a52-8592-d87ee3be09a3">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type

// 02 June 2009	concms1	par 19520 - Allow null voyage as part of criteria
vars
	voyage: Object;
	voyages: ObjectSet;
begin
	create voyages transient;
	app.getMyTerminalDO_NOT_USE().getAllCargoVoyages(voyages);
	foreach voyage in voyages do 
		//jlger1 TFS 52797 10/2/22
		if objects[voyage.CM_Voyage.getYAIdentifier] = null then
			objects[voyage.CM_Voyage.getYAIdentifier] := voyage;
		endif;
	endforeach;
// par 19520 - include NULL voyage	
	voyage := app.getMyTerminalDO_NOT_USE.getNullVoyage;
	if not objects.includes(voyage) then		// 17/05/2010 cnwmh5 #24230
		objects [voyage.CM_Voyage.getYAIdentifier] := voyage;
	endif;
// par 19520 - end
epilog
	delete voyages;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
