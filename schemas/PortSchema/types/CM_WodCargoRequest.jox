    <JadeMethod name="getValueForCargoCalcType" id="937feae2-f125-4394-bbce-a58bf445e9fa">
        <source>getValueForCargoCalcType(_calcType : Integer) : Decimal;
/*

Purpose:		TFS 39236 	

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgab1	Initial creation

*/

vars
	weightTonnes : Decimal[14,4];
begin

	weightTonnes := self.totalWeight / 1000;
	
	if _calcType = INV_CALC_TYPE_UNITY then
		return 1;
	elseif (_calcType = INV_CALC_TYPE_QUANTITY or _calcType = INV_CALC_TYPE_WO_CARGOQUANTITY) then // TFS 39236 
		return self.totalQuantity;
	elseif (_calcType = INV_CALC_TYPE_WEIGHT or _calcType = INV_CALC_TYPE_WO_CARGOWEIGHT) then // TFS 39236 
		return self.totalWeight;
	elseif _calcType = INV_CALC_TYPE_WEIGHT_TON then
		return weightTonnes;
	elseif (_calcType = INV_CALC_TYPE_VOLUME or _calcType = INV_CALC_TYPE_WO_CARGOVOLUME) then // TFS 39236 
		return self.totalVolume;
	elseif (_calcType = INV_CALC_TYPE_REVENUE_TONS or _calcType = INV_CALC_TYPE_WO_CARGOREVTONS) then // TFS 39236 
		if self.totalVolume &gt; weightTonnes then
			return self.totalVolume;
		endif;
		
		return weightTonnes;

	endif;
	

	return 1;
	
epilog

end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
