    <JadeMethod name="getSelectedName" id="63bf3c2e-0fbc-49f5-99e5-90e480282ab7">
        <updating/>
        <source>getSelectedName(): String updating;
//22 January 2009	cnwdw1
//28 Jan 2011	NDL	Par 26311	
//
vars
	yaEntity: CM_YAEntity;
	retValue : String;
	invalidObject : Boolean;
begin
	yaEntity := self.getSelectedObject();
	if yaEntity = null then
		retValue := null;
		return retValue;
	endif;
	
	on Exception do app.handleDeletedObject( exception, yaEntity, invalidObject);
	
	retValue :=  yaEntity.getYAMDisplay(self.isIN);
	return retValue;
	
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedObject" id="03be2f7f-263a-4d9c-afb3-e598e378bf4a">
        <updating/>
        <source>getSelectedObject(): CM_YAEntity updating;
//27 August 2008	cnwdw1	
//
vars
begin
	if self.allSelectedObjects.size &gt; 0 then
		return self.allSelectedObjects.first.CM_YAEntity;
	endif;
	return null;
end;</source>
        <ReturnType type="CM_YAEntity"/>
    </JadeMethod>
    <JadeMethod name="getSelectedObjectsYA" id="17ae57d1-32b1-42be-9875-f4f72c65ef70">
        <updating/>
        <source>getSelectedObjectsYA()	: CM_YardAllocation updating;

/*

Purpose:			Get Yard Allocation for selected object

Parameters:			

Return Value:		


Date		Who		Reason
08 Sep 2008	consw1	Initial creation
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	obj : Object;
	invalid 		: Boolean;
	ed 				: Integer;
	
begin
	obj := self.getSelectedObject();
	
	if obj = null then		// or not global.isValidObject(obj) then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, obj, invalid);
	ed := obj.edition();
	if invalid then
		return null;
	endif;
	
	if obj.isKindOf(CM_YardAllocation) then
		return obj.CM_YardAllocation;
	elseif obj.isKindOf(CM_YABlock) then
		return obj.CM_YABlock.myYardAllocationIn;
	elseif obj.isKindOf(CM_YABlockGroup) then
		return obj.CM_YABlockGroup.myYardAllocationIn;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="getSelectedYardAllocations" id="4df3a04b-3abf-4a3f-a34c-5790dcec2b40">
        <source>getSelectedYardAllocations( _coll : Collection input );

/*

Purpose:			Get Yard Allocations belonging to selected rows

Parameters:			

Return Value:		


Date				Who		Reason
11 November 2008	consw1	Initial creation

*/

vars
	invalid	: Boolean;
	obj		: Object;
	ya		: CM_YardAllocation;
	
begin
	_coll.clear;

	on Exception do app.handleDeletedObject(exception, obj, invalid);

	foreach obj in self.allSelectedObjects do
		ya := null;
		if obj.isKindOf(CM_YardAllocation) then
			ya := obj.CM_YardAllocation;
		elseif obj.isKindOf(CM_YABlock) then
			ya := obj.CM_YABlock.myYardAllocationIn;
		elseif obj.isKindOf(CM_YABlockGroup) then
			ya := obj.CM_YABlockGroup.myYardAllocationIn;
		endif;
		if ya &lt;&gt; null and not _coll.includes(ya) then
			_coll.add(ya);
		endif;
	endforeach;			

epilog

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSubTitleWidth" id="2125752a-bab5-45af-ae0e-c77170de74b2">
        <updating/>
        <source>getSubTitleWidth(_subTitles : StringArray) : Integer updating;
// --------------------------------------------------------------------------------
// Created:		1 February 2010 by cnwjo3
//
// Purpose:		When we first open screen we can rely on the title width for
//				calculating the subtitle widths.  When there is a resize we
//				need to check the subtitle widths themselves
//
vars
	i : Integer;
	subTitlesWidth : Integer;
	colPointer : Integer;
	foundCols : Integer;  //foundCols is the number of visible sub titles under the title (eg Total, Used, Queued In, etc)
begin
	subTitlesWidth := 0;
	foreach i in 1 to _subTitles.size() do
		colPointer := self.getColumnByRowName(_subTitles[i]);
		if colPointer &gt; 0 then
			foundCols := foundCols +1;
			subTitlesWidth := subTitlesWidth + self.accessColumn(colPointer).width;
		endif;
	endforeach;	
	
	if subTitlesWidth &gt; (35*foundCols) then
		return subTitlesWidth;
	else
		return (35*foundCols);
	endif;
end;</source>
        <Parameter name="_subTitles" type="StringArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTitleWidth" id="bd077d68-4c93-47b3-945b-5cb4930c1243">
        <source>getTitleWidth(_subTitles : StringArray; _titleName : String) : Integer;
// --------------------------------------------------------------------------------
// Created:		1 Feb 2009 by cnwjo3
//
// Purpose:		get title width to calculate individual columns (and some other columns)
//
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	i, foundCols, colPointer : Integer;
	widthValue : Integer;
	invalidUserWindow : Boolean;
begin
	foreach i in 1 to _subTitles.size() do
		colPointer := self.getColumnByRowName(_subTitles[i]);
		if colPointer &gt; 0 then
			foundCols := foundCols +1;
		endif;
	endforeach;	

	if foundCols=0 then
		foundCols:=1;  //set as 1 if caulculating titles such as AllowOthers, Priority etc
	endif;
	
	if form = null or not form.isKindOf(CM_BaseForm) then
		return 35*foundCols;
	endif;
	
	userWindow := form.CM_BaseForm.myUserWindow;
	
	//11/03/2011 cnwdz2 27128
	on Exception do app.handleDeletedObject(exception, userWindow, invalidUserWindow);
	
	if userWindow = null then
		userWindow := app.getUserWindow(form.name, false);
	else
		//11/03/2011 cnwdz2 27128 start
		userWindow.edition;
		if invalidUserWindow then
			userWindow := app.getUserWindow(form.name, false);
			invalidUserWindow := false;
		endif;
		//11/03/2011 cnwdz2 27128 end
	endif;
	
	if userWindow = null then
		return 35*foundCols;
	else
		//11/03/2011 cnwdz2 27128 start
		userWindow.edition;
		if invalidUserWindow then
			return 35*foundCols;
		endif;
		//11/03/2011 cnwdz2 27128 end
	endif;
	
	theXML := userWindow.xmlInfo;

	if _titleName = app.getErrorString(YAM_Stats_Total) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_totalWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_Used) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_usedWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_QueuedIn) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_qInWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_QueuedOut) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_qOutWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_Free) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_freeWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_Projected) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_projectedWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_PlanIn) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_planInWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = app.getErrorString(YAM_Stats_PlanOut) then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_planOutWidth);
		widthValue := theXMLValue.Integer;

	elseif _titleName = "Priority" then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_priorityWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = "Decking" then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_deckingWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = "Seq" then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_seqWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = "Allow Others" then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_allowOthersWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = "If No Loc Found" then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_ifNoLocFoundWidth);
		widthValue := theXMLValue.Integer;
	elseif _titleName = "Overstow Rule" then
		theXMLValue := theXML.cnEcGetTagValueOfName(XML_YAMTable_overstowRuleWidth);
		widthValue := theXMLValue.Integer;
		
	//05 Jan 2012	NDL	Par 28889
	else
		theXMLValue := theXML.cnEcGetTagValueOfName(_titleName);
		if theXMLValue &lt;&gt; null and theXMLValue.isInteger then
			widthValue := theXMLValue.Integer;
		endif;
	endif;

	if widthValue &gt; (35*foundCols) then
		return widthValue;
	else
		return (35*foundCols);
	endif;
end;</source>
        <Parameter name="_subTitles" type="StringArray"/>
        <Parameter name="_titleName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalColumns" id="a7e9e9b7-fa5d-41a6-a7e2-2c43fb034aa9">
        <source>getTotalColumns(_totalColumns: IntegerArray io);
//17 February 2009	cnwdw1	
//
vars
	sizes: StringArray;
	sizeString : String;
	size: Integer;
	col: Integer;
begin
	create sizes transient;
	sizes.add(ETRow_Total20); sizes.add(ETRow_Total30); sizes.add(ETRow_Total40); sizes.add(ETRow_Total45); sizes.add(ETRow_Total53); 
	sizes.add(ETRow_Used20); sizes.add(ETRow_Used30); sizes.add(ETRow_Used40); sizes.add(ETRow_Used45); sizes.add(ETRow_Used53); 
	sizes.add(ETRow_QueuedIn20); sizes.add(ETRow_QueuedIn30); sizes.add(ETRow_QueuedIn40); sizes.add(ETRow_QueuedIn45); sizes.add(ETRow_QueuedIn53); 
	sizes.add(ETRow_QueuedOut20); sizes.add(ETRow_QueuedOut30); sizes.add(ETRow_QueuedOut40); sizes.add(ETRow_QueuedOut45); sizes.add(ETRow_QueuedOut53); 
	sizes.add(ETRow_Free20); sizes.add(ETRow_Free30); sizes.add(ETRow_Free40); sizes.add(ETRow_Free45); sizes.add(ETRow_Free53); 
	// PAR 19760
	//sizes.add(ETRow_Projected20); sizes.add(ETRow_Projected30); sizes.add(ETRow_Projected40); sizes.add(ETRow_Projected45); sizes.add(ETRow_Projected53); 
	sizes.add(ETRow_PlannedIn20); sizes.add(ETRow_PlannedIn30); sizes.add(ETRow_PlannedIn40); sizes.add(ETRow_PlannedIn45); sizes.add(ETRow_PlannedIn53); 
	sizes.add(ETRow_PlannedOut20); sizes.add(ETRow_PlannedOut30); sizes.add(ETRow_PlannedOut40); sizes.add(ETRow_PlannedOut45); sizes.add(ETRow_PlannedOut53); 

	//cnwjo3 par 21189
	sizes.add(ETRow_ColTotalTotal);
	sizes.add(ETRow_ColTotalUsed);
	sizes.add(ETRow_ColTotalQIn);
	sizes.add(ETRow_ColTotalQOut);
	sizes.add(ETRow_ColTotalFree);
	sizes.add(ETRow_ColTotalPlanIn);
	sizes.add(ETRow_ColTotalPlanOut);
	
	
	//07/12/2009 cnwdz2 par21859
	//foreach size in 1 to sizes.size do
	foreach sizeString in sizes do
		//col := self.getColumnByRowName(sizes[size]);
		col := self.getColumnByRowName(sizeString);
		if col &lt;&gt; 0 then
			_totalColumns.add(col);
		endif;
	endforeach;

	
epilog
	delete sizes;
end;</source>
        <Parameter name="_totalColumns" type="IntegerArray" usage="io"/>
    </JadeMethod>
