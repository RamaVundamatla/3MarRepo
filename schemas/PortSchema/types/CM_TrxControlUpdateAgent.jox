        <source>trxUpdateTIExternalMonitoring(	_theTIs: CM_TIArray input; 
								_externallyMonitored : Boolean; 
								_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2015	cnwmc5	Initial creation

*/

vars
	ti					: CM_TrackedItem;
