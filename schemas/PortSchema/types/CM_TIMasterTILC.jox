    <JadeMethod name="isStopValid" id="7d8c56fa-6bdc-421f-b9a7-b4c1ceb8b391">
        <source>isStopValid(_theStop: CM_StopsTable): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2008	cnwrd1	Initial creation
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
*/

vars
	cargoTypeObj	: CM_CargoType;
	stopsTable		: CM_StopsTable;
	criteria : CM_YACriteria;		// 20 Jul 2022	navsj20	TFS 53862
	
begin
	cargoTypeObj	:=	self.myTILCType.myCargoType;
	// START 20 Jul 2022	navsj20	TFS 53862
	//return _theStop.allCargoTypesNew.includes(cargoTypeObj);			
	if _theStop.myStopCriteria &lt;&gt; null then  
		foreach criteria in _theStop.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do	// END 27 Jul 2022	navsj20	TFS 53862
			return criteria.myYAData.CM_YADataObjects.allObjects.includes(cargoTypeObj);	
		endforeach;//27 Jul 2022	navsj20	TFS 53862
	endif;
	// END 20 Jul 2022	navsj20	TFS 53862
epilog

end;</source>
        <Parameter name="_theStop" type="CM_StopsTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
