    <JadeMethod name="zDoLstDataContextMenu" id="2a4c936d-6ce3-4b0a-9053-197af8333364">
        <updating/>
        <source>zDoLstDataContextMenu(cntrl: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean protected, updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 13 February 2004
//
//********************************************************************
vars

begin

	if self.mode &lt;&gt; Mode_View then
		//disallow context menu whilst editing
		return false;
	endif;

// refer to notes in CM_TableViewForm::contextMenu for adding to this context menu

	self.doMnuFormContextMenu(conwin, mouse, x, y);
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
