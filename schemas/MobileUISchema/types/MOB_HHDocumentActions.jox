    <JadeMethod name="addTableItem" id="3244cca8-c4c1-4431-b593-8a026b4c008b">
        <source>addTableItem(	documentActions : CM_DocumentActions;
				_table : Table input;
				stop : CM_StopsTable;
				task : CM_ToDoTaskDesc;
				ti : CM_TrackedItem;
				_disableItem : Boolean
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	totalApplied : Real;
	totCompleted : Real;
	remaining : Real;
	rowIndex : Integer;
	objId : String;
	obj : CM_Object;
	remarksStr : String;	//05 Oct 2016	NDL	TFS 2001 / 2792

begin

	documentActions.getTotalsForTi( stop, task, ti, totalApplied, totCompleted, remaining );
	
	if stop &lt;&gt; null then
		objId := stop.shortHeading;
		obj := stop;
		remarksStr := null;	//05 Oct 2016	NDL	TFS 2001 / 2792
	elseif task &lt;&gt; null then
		objId := task.shortDescription;
		obj := task;
		remarksStr := Tab &amp; documentActions.getRemarksFor( task );	//05 Oct 2016	NDL	TFS 2001 / 2792
	endif;
	if remaining &lt;= 0 then		//28 Nov 2016	NDL	TFS 2962 - show all completed
		rowIndex := _table.addItem( objId &amp; Tab &amp; "0" &amp; Tab &amp; ti.getMyCargoGroupId &amp; Tab &amp; ti.id &amp; Tab &amp; "" &amp; Tab &amp; remaining.String &amp; remarksStr);
		_table.accessCell( rowIndex, 2 ).inputType := Table.InputType_CheckBox;
		_table.accessRow( rowIndex ).backColor := Gray;
		_table.accessRow( rowIndex ).enabled := false;
	elseif remaining &gt; 0 then
		if _disableItem then
			rowIndex := _table.addItem( objId &amp; Tab &amp; "0" &amp; Tab &amp; ti.getMyCargoGroupId &amp; Tab &amp; ti.id &amp; Tab &amp; "" &amp; Tab &amp; remaining.String &amp; remarksStr);	//05 Oct 2016	NDL	TFS 2001 / 2792
			_table.accessCell( rowIndex, 2 ).inputType := Table.InputType_CheckBox;
			_table.accessRow( rowIndex ).backColor := LightGray;
			_table.accessRow( rowIndex ).enabled := false;
		else
		//	rowIndex := _table.addItem( objId &amp; Tab &amp; "1" &amp; Tab &amp; ti.getMyCargoGroupId &amp; Tab &amp; ti.id &amp; Tab &amp; remaining.String &amp; Tab &amp; remaining.String &amp; remarksStr);	//05 Oct 2016	NDL	TFS 2001 / 2792
		//	rowIndex := _table.addItem( objId &amp; Tab &amp; "1" &amp; Tab &amp; ti.getMyCargoGroupId &amp; Tab &amp; ti.id &amp; Tab &amp; "" &amp; Tab &amp; remaining.String &amp; remarksStr);	//28 Nov 2016	NDL	TFS 2962
		
			//09 Feb 2017	NDL	TFS 3002 - Flip flop flip flop flip flop - Now STW do want the remaing value displaid but only if its '1'.
			if remaining = 1 then
				rowIndex := _table.addItem( objId &amp; Tab &amp; "1" &amp; Tab &amp; ti.getMyCargoGroupId &amp; Tab &amp; ti.id &amp; Tab &amp; remaining.String &amp; Tab &amp; remaining.String &amp; remarksStr);
			else
				rowIndex := _table.addItem( objId &amp; Tab &amp; "1" &amp; Tab &amp; ti.getMyCargoGroupId &amp; Tab &amp; ti.id &amp; Tab &amp; "" &amp; Tab &amp; remaining.String &amp; remarksStr);
			endif;
			
			_table.accessCell( rowIndex, 2 ).inputType := Table.InputType_CheckBox;
			_table.accessCell( rowIndex, 3 ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, 3 ).itemObject := documentActions;
			_table.accessCell( rowIndex, 3 ).enabled := false;
			_table.accessCell( rowIndex, 4 ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, 4 ).enabled := false;
			_table.accessCell( rowIndex, 5 ).inputType := Table.InputType_TextNumeric;
			_table.accessCell( rowIndex, 6 ).enabled := false;
			_table.accessCell( rowIndex, 6 ).itemObject := obj;
			if task &lt;&gt; null then	//05 Oct 2016	NDL	TFS 2001 / 2792
				_table.accessCell( rowIndex, 7 ).inputType := Table.InputType_None;
			endif;
			_table.accessRow( rowIndex ).itemObject := ti;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="documentActions" type="CM_DocumentActions"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="stop" type="CM_StopsTable"/>
        <Parameter name="task" type="CM_ToDoTaskDesc"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="_disableItem" type="Boolean"/>
    </JadeMethod>
