    <JadeMethod name="btnCancel_click" id="ccc5e2eb-ffee-4653-a4b2-aa9373111dab">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="f65609bf-b971-4f01-87b8-0fa76cae2f2e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;

	if self.doFormUpdate() then
		modalResult	:=	1;
		unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkIsValidated_change" id="42d9ebb8-3f90-4f58-8fed-fcb8a6cab1e9">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkIsValidated_change(checkbox: CheckBox input) updating;
// --------------------------------------------------------------------------------
// Created:		08 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doEnableValidationControls(checkbox.value);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEnableValidationControls" id="f31916bc-0278-498b-808c-a22ea0f2799c">
        <source>doEnableValidationControls(pIsFieldValidated:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		08 June 2000 by cnwdad1
//
// Purpose:		Enables/disables validation type controls based upon whether the
//				web test field requires validation.
//
// Parameters:	pIsFieldValidated - True if validation is required for the web test
//					field.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	grpValidationType.enabled	:=	pIsFieldValidated;

	if (not pIsFieldValidated) then
		optIsForEqual.value		:=	true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pIsFieldValidated" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="856c0702-4c6e-4d9d-a300-302da4d549d9">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	centreWindow();
	self.doLoadFieldProperties();
	modalResult	:=	0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="93b901e6-e0a8-48c8-bc0b-f9f1acc2929e">
        <updating/>
        <source>doFormUpdate(): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fieldName			: String;
	isValidatedField	: Boolean;
	defaultFieldValue	: String;
	isValidateTagValue	: Boolean;
	isValidateEqualTo	: Boolean;

begin
	fieldName			:=	txtFieldName.text.trimBlanks();
	isValidatedField	:=	chkIsValidated.value;
	defaultFieldValue	:=	txtDefaultValue.text.trimBlanks();
	isValidateTagValue	:=	optIsTagField.value;
	isValidateEqualTo	:=	optIsForEqual.value;

	if self.aMyCommonField = null then
		self.aError	:=	self.aMyTA.valCommonFieldCreate(	self.aMyWebTest,
															fieldName,
															defaultFieldValue,
															isValidatedField,
															isValidateTagValue,
															isValidateEqualTo);

		if self.aError = null then
			self.aError	:=	self.aMyTA.trxCommonFieldCreate(self.aMyWebTest,
															fieldName,
															defaultFieldValue,
															isValidatedField,
															isValidateTagValue,
															isValidateEqualTo,
															self.aMyCommonField);
		endif;
	else
		self.aError	:=	self.aMyTA.valCommonFieldUpdate(	self.aMyCommonField,
															defaultFieldValue,
															isValidatedField,
															isValidateTagValue,
															isValidateEqualTo);

		if self.aError = null then
			self.aError	:=	self.aMyTA.trxCommonFieldUpdate(self.aMyCommonField,
															self.aObjectEdition,
															defaultFieldValue,
															isValidatedField,
															isValidateTagValue,
															isValidateEqualTo);
		endif;
	endif;
epilog
	return self.doShowError();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadFieldProperties" id="175430a1-e763-4ed5-8511-e12aa95eb41f">
        <updating/>
        <source>doLoadFieldProperties() updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Populates the receiver's controls with the web test field's details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	commonField	: CnEcWebTestCommonField;

begin
	if self.aMyCommonField &lt;&gt; null then
		commonField	:=	self.aMyCommonField;
	endif;

	self.setFormCaption(CAPTION_NAME, (commonField = null), false);

	if commonField = null then
		chkIsValidated.value	:=	false;
		optIsQueryField.value	:=	true;
		txtFieldName.readOnly	:=	false;
		self.doEnableValidationControls(false);
	else
		txtFieldName.text		:=	commonField.fieldName;
		chkIsValidated.value	:=	commonField.isValidatedField;
		txtDefaultValue.text	:=	commonField.defaultFieldValue;
		optIsQueryField.value	:=	(not commonField.isValidateTagValue);
		optIsTagField.value		:=	commonField.isValidateTagValue;
		optIsForEqual.value		:=	commonField.isValidateEqualTo;
		optIsForNotEqual.value	:=	(not commonField.isValidateEqualTo);
		txtFieldName.readOnly	:=	true;
		self.doEnableValidationControls(commonField.isValidatedField);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCommonField" id="cf89d76f-5672-4a26-a92b-32b4072044ec">
        <updating/>
        <source>setCommonField(pCommonField:CnEcWebTestCommonField; pWebTest:CnEcWebTest) updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Sets a reference to the web test field to be edited.
//
// Parameters:	pCommonField - The web test field being edited.
//				pWebTest - The web test that owns the field being edited.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyCommonField	:=	pCommonField;
	self.aMyWebTest		:=	pWebTest;
end;</source>
        <Parameter name="pCommonField" type="CnEcWebTestCommonField"/>
        <Parameter name="pWebTest" type="CnEcWebTest"/>
    </JadeMethod>
</GUIClass>
