<Class name="CM_QDecimalVentilationProperty" id="310cdfd4-0987-4e5c-9769-f0f7402694fb">
    <superclass name="CM_QDecimalProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="displayNull" id="044492c8-04d3-4db3-a1e1-ba05357d6663">
        <methodInvocation>mapping</methodInvocation>
        <source>displayNull(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	07 May 2009 cnwjo3
//----------------------------------------------------------------
begin
	_value := true;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="e2659831-756a-4b2c-9aca-6cfa9390981a">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     07 May 2009 cnwjo3
//
vars

begin
	if _value.Decimal &lt;&gt; NULL_VENTILATION then
		return inheritMethod(_value);
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
