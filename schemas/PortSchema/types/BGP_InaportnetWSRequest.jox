    <JadeMethod name="setMarineTimings" id="7e0a8a47-5bfa-445d-aa18-7d4e26aa77b0">
        <updating/>
        <source>setMarineTimings(	_timings : HMS_MarineServicesTimings;
					_pilotTimingType : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2018	jlger1	Initial creation 40847

*/

vars

begin
