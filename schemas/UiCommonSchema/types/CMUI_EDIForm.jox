        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEDITI_dblClick(table: Table input) updating;
//----------------------------------------------------------------
//	Created:	01 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tiTable : CM_DataTable;
begin
	tiTable := table.CM_DataTable; //cnwgb1 29..9.09 MES 1011 20320. Handle cloned tables
	if tiTable.row = tiTable.fixedRows then
		tiTable.resortTableByColumn(tiTable.column);
	endif;
epilog

end;</source>
