    <JadeMethod name="btnEditTrain_click" id="bc597458-77ea-419b-a0c4-b3cebedf2e87">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEditTrain_click(btn: Button input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
12/12/2017 jlgns1 TFS 8179 ChangeRequest 8179: Copy Train button causes a 75768 error
*/
vars
	
begin
	if self.mySelectedTrain = null then
		app.msgBox(app.getErrorString(Must_select_train_edit_first),app.getErrorString(Train_selected_NO), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//self.mode := self.Mode_Update;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.setMode( self.Mode_View );
		self.showTrainInfo(false,self.mode);//TFS 8179
		self.setControlsForView();
	else
		self.setMode( self.Mode_Update );	//18 Apr 2012	NDL	Par 27704
		self.showTrainInfo(false,self.mode);//TFS 8179
		self.setControlsForAddEdit();

	endif;


end;


</source>
