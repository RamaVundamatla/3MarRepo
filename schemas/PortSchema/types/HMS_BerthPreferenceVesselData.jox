<Class name="HMS_BerthPreferenceVesselData" id="9565e0b9-a6e3-4ac1-a122-efd62c26be99">
    <superclass name="HMS_BerthPreference"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ExplicitInverseRef name="myVesselDataHarbour" id="09af8dd8-8e8e-42f1-a694-33fe586b7ac2">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="HMS_VesselDataHarbour"/>
        <access>readonly</access>
        <text>
This in man/auto for conversion only. Change to auto after conversion.</text>
        <Inverse name="HMS_VesselDataHarbour::allBerthPrefByName"/>
        <Inverse name="HMS_VesselDataHarbour::allBerthPrefByOrder"/>
    </ExplicitInverseRef>
    <JadeMethod name="erase" id="f922040e-4b79-452e-90fb-576c6f5b71b8">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------
// Created:	24 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.isTransient then
		inheritMethod(_eraseLevel);
		return;
	endif;
	self.myVesselDataHarbour.removeBerthPreference(self);
	inheritMethod(_eraseLevel);	
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="79c7f9d8-fb59-4f67-a709-bb6f05addcd4">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	24 August 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="086eb5be-949f-4a1d-b338-2c3a9d37be37">
        <updating/>
        <source>setForUpdate(_pxyBerthPref: HMS_BerthPreferenceVesselData; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	24 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_pxyBerthPref, _passport);
	if app.isConverting then
		self.myVesselDataHarbour := _pxyBerthPref.myVesselDataHarbour;
	endif;
end;</source>
        <Parameter name="_pxyBerthPref" type="HMS_BerthPreferenceVesselData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="15aa3d98-e575-4841-af11-89e9d937a68c">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	24 August 2004 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------
vars
	tmpPref,
	realPref,
	existingPref : HMS_BerthPreference;
begin
	inheritMethod(_passport);
	if _passport.hasErrors() then
		return;
	endif;
	if self.myVesselDataHarbour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Vessel', ETRow_Vessel,  null);
		app.raiseCMException(Input_required_field_vessel, ETRow_Vessel,  null); // cnwdb2	PAR 35364
		return;
	endif;		

	if self.getMyBerth.getHarbour() &lt;&gt; self.myVesselDataHarbour.myHarbour then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Harbour mismatch');
		return;
	endif;			
	//---------------------------------------------------------------------------
	// Check for duplicates
	//---------------------------------------------------------------------------
	if self.isTransient then		
		realPref := self.pxyGetRealObject();
	endif;
	foreach tmpPref in self.myVesselDataHarbour.allBerthPrefByOrder do
		if tmpPref = self then
			continue;
		endif;
		if tmpPref = realPref then
			continue;
		endif;		
		if tmpPref.isTransient then
			existingPref := tmpPref.pxyGetRealObject();
		endif;
		if existingPref &lt;&gt; null then
			if existingPref = realPref then
				continue;
			endif;
		endif;
		
		if tmpPref.berthName = self.berthName then
			//app.raiseCMException2(DuplicateItem, 'Berth Preference', self.berthName, ETRow_MyBerth, null); //14.06.2022 navds20 53760
			// Berth Preference already exists for %1 : Berth_prefere_already_exists
			app.raiseCMException1(Berth_prefere_already_exists, self.berthName, ETRow_MyBerth, null); //14.06.2022 navds20 53760
			return;		
		endif;
	endforeach;


	if self.defaultBowMark = null then
		if self.defaultBridgeMark = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Bridge Mark', ETRow_DefaultBridgeMark,  null);
			app.raiseCMException(Input_required_field_bridgeMrk, ETRow_DefaultBridgeMark,  null); // cnwdb2	PAR 35364
		endif;
// cnwdad1 30/08/2006 - Constant is no longer used.
//		if self.defaultSternMark = null then
//			app.raiseCMException1(REQUIRED_FIELD, 'Stern Mark', ETRow_DefaultSternMark,  null);
//		endif;
	endif;
		
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
