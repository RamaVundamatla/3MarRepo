    <JadeMethod name="removeSlotRequest" id="4bc6cc77-0873-4a1c-b471-9970e72f9477">
        <updating/>
        <source>removeSlotRequest(_request : CM_RORORequest input) updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars
	otherSlotRequest	: CM_RORORequest;
	
	invalidObject : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,_request,invalidObject);

	
	if _request = null then
		return;
	endif;
	self.myDeck.removeRequestFromSortDict(_request);
	
	if _request.isLoad then
		if self.allRequestsLoad.includes(_request) then
			self.allRequestsLoad.remove(_request);
		endif;

		// always check this in case we get out of sync
		if self.myRORORequestLoad = _request then
			// TFS 41381  self.myRORORequestLoad := self.allRequestsLoad.first;
		endif;
/*		
		if not self.isRotatedLinked(true) then // PAR 28990 the aft req will be handled in its own right
			otherSlotRequest := _request.getOtherRequest().CM_RORORequest;
			if otherSlotRequest &lt;&gt; null then
				otherSlotRequest.myROROController.removeSlotRequest(otherSlotRequest);
			endif;
		endif;
		*/
		_request.setMyLC(null); // PAR 28990 - AKB switch the load CC from the cloned LC to the actual LC
	else
		if self.allRequestsDischarge.includes(_request) then
			self.allRequestsDischarge.remove(_request);
		endif;

		if self.myRORORequestDischarge = _request then
			// TFS 41381  self.myRORORequestDischarge := self.allRequestsDischarge.first;
		endif;

		otherSlotRequest := _request.getOtherRequest().CM_RORORequest;
		if otherSlotRequest &lt;&gt; null then
			otherSlotRequest.myROROController.removeSlotRequest(otherSlotRequest);
		endif;
	endif;
	
end;</source>
        <Parameter name="_request" type="CM_RORORequest" usage="input"/>
    </JadeMethod>
