    <JadeMethod name="getShortDisplay" id="c19f98ce-d578-4883-a8c0-83a01ebac76e">
        <source>getShortDisplay():String;
/*
	Created on 25 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

//cnwjo3 par 22756.  Changed a little since code didn't make alot of sense with return strings in if statements
// 21/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - show total weight / volume depending on track as type

vars
	str 	: String;
begin

	str := self.getAmountDisplay() &amp; ' x '; //epr par 34935 23/9/14
	
	if myISOType &lt;&gt; null then 
		str := str &amp; myISOType.getTableDisplay;
	elseif isoTypeGroup &lt;&gt; null then
		str := str &amp; isoTypeGroup;
	elseif self.myCargoType &lt;&gt; null then
		str := str &amp; self.myCargoType.description;
		if myProduct &lt;&gt; null then
			str := str &amp; " " &amp; myProduct.code;
		endif;
	else
		// should not happen to data entered post 7.8.1
		str := str &amp; "***Invalid cargo type ***";
	endif;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
