    <JadeMethod name="trxCreateSchema" id="5c2100a2-6374-486a-bd4b-eef1ebe5fa1a">
        <source>trxCreateSchema(_schemaName, 
				_subschema,
				_otherData				: String;
				_devSchema 				: DEV_Schema io) protected;
/*

Purpose:			Creates a DEV_Schema

Parameters:			_schemaName:			String			The name of the schema
					_subschema:				String			The subschema the schema belongs to
					_otherData:				String			The data we are not interested in but needs to be written out
					_documentationTextStr:	String			The documentation text on the global constant
					_devSchema:				DEV_Schema		The created schema

Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	_devSchema := create DEV_Schema(_schemaName, _subschema, _otherData, "") transient;
	self.mySchemaFile.setSchema(_devSchema);
	
end;</source>
        <access>protected</access>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_subschema" type="String"/>
        <Parameter name="_otherData" type="String"/>
        <Parameter name="_devSchema" type="DEV_Schema" usage="io"/>
