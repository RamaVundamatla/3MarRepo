    <JadeMethod name="getTotalCompleted" id="effe3a88-a9e8-4ce5-ac60-09e9e8c547e5">
        <source>getTotalCompleted(_qty: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue

*/

vars
	qty 		: Integer;
	invalid		: Boolean;
	job			: CM_Job;
begin
	if not app.myPassport.isVASEnabled then
		return null;
	endif;
	
	if _qty then
		job := self.allJobs.first;
		if job &lt;&gt; null then
			qty := job.getTotalQuantity() - job.getRemainingQuantity().Integer;
		endif;
		return qty;
	endif;
epilog

end;</source>
        <Parameter name="_qty" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getTotalRequest" id="de680e82-0121-41db-bcad-80d3b6fe3f8d">
        <source>getTotalRequest(_qty: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue
31 Jul 2024 navhl20	Defect 65460: Some columns are missing on the Pack Unpack operation mode and the Quantity is not displaying the correct value
*/

vars
	qty 		: Integer;
	ti	 		: CM_TrackedItem;
	wt   		: Decimal[14,4];
	childItem 	: CM_TrackedItem;
	invalid		: Boolean;
	job			: CM_Job;
begin
	if not app.myPassport.isVASEnabled then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	on Exception do app.handleDeletedObject(exception, childItem, invalid);
	
	if _qty then
		if self.allJobs.isEmpty() then
			foreach ti in self.allSelectedTIs discreteLock do
				invalid := false;
				ti.edition;
				if invalid then
					continue;
				endif;
				
				foreach childItem in ti.allChildren discreteLock do
					invalid := false;
					childItem.edition;
					if invalid then
						continue;
					endif;
					
					qty := qty + childItem.totalQuantity;							//31.07.2024 navhl20 #65460				
				endforeach;
			endforeach;
		else
			job := self.allJobs.first;
			qty := job.getTotalQuantity();
		endif;
		return qty;
	endif;
epilog

end;</source>
        <Parameter name="_qty" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getTransTypeByMode" id="e13f4e02-2070-4e37-a6f7-0b3afcabb53d">
