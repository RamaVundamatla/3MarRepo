    <JadeMethod name="btnAllFromSelect_click" id="e6a9b17b-247b-44d1-9c05-742d25d2ad3f">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAllFromSelect_click(btn: Button input) updating;

vars
	listboxObj		: ListBox;
	listPointer		: Integer;
	
begin
	app.mousePointer	:=	Busy;
	listboxObj			:=	lstSelected;
	
	foreach listPointer in 1 to listboxObj.listCount do
		if listboxObj.itemForeColor[listPointer] = Black then
			listboxObj.itemSelected[listPointer] := true;
		endif;
	endforeach;
	
	self.moveFromSelected();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnBack_click" id="5279ef6d-fc3a-4846-beeb-d0d94da77cac">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBack_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;

	if self.aSheetVisible = 6 and not chkObjectCreate.value and not chkCreateTrx.value then
		self.aSheetVisible := 5;
	endif;
	
	self.setSheetState(self.aSheetVisible - 1);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="ffb74ddf-26f8-47da-86f9-e201ede442a2">
