	_realRequest.namaKapalTunda1 := self.namaKapalTunda1;
	_realRequest.namaKapalTunda2 := self.namaKapalTunda2;
	_realRequest.namaKapalTunda3 := self.namaKapalTunda3;
	_realRequest.namaKapalTunda4 := self.namaKapalTunda4;
	_realRequest.namaPetugasPandu := self.namaPetugasPandu;
	_realRequest.nomorPKK := self.nomorPKK;
	_realRequest.nomorPPK := self.nomorPPK;
	_realRequest.nomorSPKPandu := self.nomorSPKPandu;
	_realRequest.tanggalPandu := self.tanggalPandu;
	_realRequest.waktuGerak := self.waktuGerak;

epilog

end;</source>
