<Class name="CM_BOLConsigneeChanged" id="7c4fd0a6-9ba3-4460-be85-960d142855fb">
    <superclass name="CM_BOLTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transactbol"/>
    <PrimAttribute name="detailDescription" id="5964dc40-9421-4197-9041-d016b2a569d5">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="newConsigneeCode" id="ccd8c40d-8c53-4329-89fd-064e3e5c721e">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="previousConsigneeCode" id="55811550-3bfd-43db-afef-18d4494a72ed">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDebtorFromConsignee" id="7c7f8449-73c5-439a-ad0f-e16581c3d54d">
        <source>getDebtorFromConsignee(): CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	debtor : CM_Debtor;
	consignee : CM_ConsigneeConsignor;

begin

	consignee := app.myRoot.allConsigneeConsignors.getAtKey( self.newConsigneeCode );
	if consignee &lt;&gt; null then
		debtor := consignee.debtor;
	endif;
	
	return debtor;

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayID" id="571686e6-29e7-45c3-bbbe-548934c67040">
        <source>getDisplayID(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	return inheritMethod &amp; " " &amp; self.detailDescription;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5526fa06-b83b-4be6-be34-237fdd6ee504">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	if _attrName = ETRow_Details then
		return self.detailDescription;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="578b585b-4c31-42c9-9ab0-05fadceab2c1">
        <updating/>
        <source>setDetails( _prevConsignee : String; _newConsignee : String; bolDtl : CM_BOLDtl ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin

	self.previousConsigneeCode := _prevConsignee;
	self.newConsigneeCode := _newConsignee;
	self.detailDescription := bolDtl.getShortDisplay &amp; " " &amp; app.getErrorString2( Consignee_changed_from, _prevConsignee, _newConsignee );

epilog

end;</source>
        <Parameter name="_prevConsignee" type="String"/>
        <Parameter name="_newConsignee" type="String"/>
        <Parameter name="bolDtl" type="CM_BOLDtl"/>
    </JadeMethod>
</Class>
