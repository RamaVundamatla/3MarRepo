    <JadeMethod name="doSTWCreatePackingAndRoadRels" id="dd2f48e7-f7d3-489a-9197-6d75b88af87f">
        <source>doSTWCreatePackingAndRoadRels(	useEDI : Boolean; 	
							oper : CM_Operator io;
							packRequest : CM_BulkRelease io;
							releaseID : String;
							cargo_GroupId1 : String;
							ctv : CM_CargoType;
							reserveDetail1 : CM_ReserveDetail io;
							cargo_GroupId2 : String;
							reserveDetail2 : CM_ReserveDetail io;
							ctw : CM_CargoType;
							cargo_GroupId3 : String;
							reserveDetail3 : CM_ReserveDetail io;
							ctq : CM_CargoType;
							roadRequest : CM_BulkRelease io
							) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Name	TFS#		Description
============================================================================
07 Jan 2016	cnwndl1	Par 37288 	Initial creation	
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/

constants

	UserDefined : String = 'UT_PackUnpack_STW';
	
vars

	pxyReleaseMatchCrit : CM_ReleaseByTypeCriteria;
	pxyCriteria : CM_YACriteria;
	
	ediControllerAgent : CM_EDIControllerAgent;
	term : CM_Terminal;
	fileTypeUser : CM_EDIFileTypeUser;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	ediText : String;
	fileSetup : String;
	binaryMsg : Binary;
	bSynchronous : Boolean;
	messageType : String;
	clientRef : String;
	tempStr : String;
	reserveDetail : CM_ReserveDetail;
	rsCount : Integer;
	subTermStr : String;
	subTerminal : CM_SubTerminal;
	xmlBlock : String;
	ediFile	: CM_EDIFile; 
begin

	if useEDI then
	
		create ediControllerAgent transient;
		create pxyFileTypeUser transient;
		term := self.getTerminal;
		ediControllerAgent.setTerminal(term);
		
		if term.allSubTerminals.isNotEmpty then
			subTerminal := self.getSubTerminal(null);
			if subTerminal &lt;&gt; null then
				subTermStr := subTerminal.code;
			endif;
		endif;
		
		
		// the block string below represents the XML of the required user file type definition format.
		xmlBlock := self.xmlDef_UT_PackUnpack_STW(UserDefined);
		
		// break up the XML into the proxy CM_EDIFileTypeUser
		pxyFileTypeUser.importMeXML(xmlBlock);
		
		// make sure the required definition name does not already exist.
		fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefined).CM_EDIFileTypeUser;
		if fileTypeUser &lt;&gt; null then
			// if it does exist then delete it.
			app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
			self.assertIsDeleted(fileTypeUser);
			self.assertTrue(app.myPassport.trxCompletedOK());
		endif;
		
		// create the required user definition format.
		app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
		fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefined).CM_EDIFileTypeUser;
		tempStr	:= "Creating: User Type File Format Definition '" &amp; UserDefined &amp; "'";
		self.assertNotNullMsg(fileTypeUser, tempStr);
	
		
		ediText :=
"Action;Control;Release Request Number;Cargo Type Descr;Cargo Sub-type;Operator;Release By Type;Release Type (String);Status (Bulk release);Remarks;Sub-Terminal;RemAdd1;RemAdd2"&amp;CrLf&amp;
"Action;Control;Release Request Number;Request Detail ID;Cargo Type Descr;Cargo Sub-type;Is Child;Quantity;Weight (kg);ISO Type;Volume (m3)"&amp;CrLf&amp;
"Action;Control;Release Request Number;Request Detail ID;CriteriaName;Criteria Value"&amp;CrLf&amp;
"Add;H;"&amp;releaseID&amp;";;;"&amp;oper.code&amp;";Yes;"&amp;BR_TYPE_PACKING_STR&amp;";Active;Created by "&amp;method.qualifiedName&amp;";"&amp;subTermStr&amp;";Remarks Add 1;Remarks Add 2"&amp;CrLf&amp;
"Add;D;"&amp;releaseID&amp;";"&amp;releaseID&amp;"_P1;ISO CONTAINER;;No;1;0;2200;0"&amp;CrLf&amp;	//parent reserve detail
"Add;D;"&amp;releaseID&amp;";"&amp;releaseID&amp;"_C1;"&amp;ctv.abbreviation&amp;";;Yes;;;;3500"&amp;CrLf&amp;	//1st child detail reserve detail
"Add;D;"&amp;releaseID&amp;";"&amp;releaseID&amp;"_C2;"&amp;ctw.abbreviation&amp;";;Yes;;2500;;"&amp;CrLf&amp;	//2nd child detail reserve detail
"Add;C;"&amp;releaseID&amp;";"&amp;releaseID&amp;"_C2;"&amp;"Cargo Group Id"&amp;";"&amp;cargo_GroupId2&amp;CrLf&amp; // Extra Criteria for 2nd child
"Add;D;"&amp;releaseID&amp;";"&amp;releaseID&amp;"_C3;"&amp;ctq.abbreviation&amp;";;Yes;15;;;"&amp;CrLf&amp;	//3rd child detail reserve detail
"Add;C;"&amp;releaseID&amp;";"&amp;releaseID&amp;"_C3;"&amp;"Cargo Group Id"&amp;";"&amp;cargo_GroupId3&amp;CrLf; // Extra Criteria for 3rdd child
	
		
		binaryMsg := ediText.Binary;
		bSynchronous := true;									// true = load, false = queue
		messageType := UserDefined[1 : fileTypeUser.name.maxLength];						// ie 63
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength];		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);

		// load the edi data, verify and load to database
		if bSynchronous then
			ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
			tempStr	:= 'Failed to load EDI file';
		else
			ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
			tempStr	:= 'Failed to queue EDI file';
		endif;
		tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
		
		ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
		self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
		
		// Now check the actual data has been loaded correctly.
		packRequest := term.getBulkReleaseFromCode(releaseID);
		self.assertTrueMsg( packRequest &lt;&gt; null, releaseID &amp; " Pack Request not created via EDI - setup phase : (test 15a) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
		
		self.assertEqualMsg( packRequest.remarksAdditional1, "Remarks Add 1", releaseID &amp; ' additionalRemarks1 s/b Remarks Add 1' );	//04 May 2018	NDL	TFS 37795
		self.assertEqualMsg( packRequest.remarksAdditional2, "Remarks Add 2", releaseID &amp; ' additionalRemarks1 s/b Remarks Add 2' );	//04 May 2018	NDL	TFS 37795

		foreach reserveDetail in packRequest.allReservePackingChildren do
			rsCount := rsCount + 1;
			if rsCount = 1 then
				reserveDetail1 := reserveDetail;
				continue;
			elseif rsCount = 2 then
				reserveDetail2 := reserveDetail;
				continue;
			elseif rsCount = 3 then
				reserveDetail3 := reserveDetail;
				continue;
			endif;
			break;
		endforeach;
		
		self.assertTrueMsg( rsCount = 3, releaseID &amp; " Pack Request wrong number of child reserve details created via EDI - setup phase : (test 16a) - " &amp; app.myPassport.getErrorsAndWarningsAsString );

	
	else

		self.opts.purge;
		self.opts.addAssoc("ISOType", "2200");
		self.opts.addAssoc("Number", 2.Integer);
		self.opts.addAssoc("Operator", oper);
		packRequest := self.addReleaseByTypeRequestOpts(releaseID, BR_TYPE_PACKING, TI_CargoType_Container);
		self.assertTrueMsg( packRequest &lt;&gt; null, releaseID &amp; " Pack Request not created - setup phase : (test 15) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
		
		create pxyReleaseMatchCrit transient;
		create pxyCriteria transient;
		pxyReleaseMatchCrit.allCriteria.add(pxyCriteria);
		pxyCriteria.setProxy(	CM_YATypeCargoGroup.firstInstance,	//pCriteriaTypeObj:CM_YACriteriaType;
								cargo_GroupId1,	//pDataValue:Any;
								"Cargo Grou"	//pCode:String
								);
		self.opts.purge;
		self.opts.addAssoc(UTTI_Volume, "3500".Decimal);
		self.opts.addAssoc("Operator", oper);
		self.opts.addAssoc(ETRow_SetCriteria, pxyReleaseMatchCrit);
		self.addReserveSelectionOpts( packRequest, CM_ReserveDetail.PackType_Child, ctv.id);
		self.assertTrueMsg( packRequest.allReservePackingChildren.size = 1, releaseID &amp; " Pack Request 1st child reserve details not created - setup phase : (test 16) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
		reserveDetail1 := packRequest.allReservePackingChildren.last;
		
		create pxyReleaseMatchCrit transient;
		create pxyCriteria transient;
		pxyReleaseMatchCrit.allCriteria.add(pxyCriteria);
		pxyCriteria.setProxy(	CM_YATypeCargoGroup.firstInstance,	//pCriteriaTypeObj:CM_YACriteriaType;
								cargo_GroupId2,	//pDataValue:Any;
								"Cargo Grou"	//pCode:String
								);
		self.opts.purge;
		self.opts.addAssoc(UTTI_TotalWeight, "2500".Decimal);
		self.opts.addAssoc("Operator", oper);
		self.opts.addAssoc(ETRow_SetCriteria, pxyReleaseMatchCrit);
		self.addReserveSelectionOpts( packRequest, CM_ReserveDetail.PackType_Child, ctw.id);
		self.assertTrueMsg( packRequest.allReservePackingChildren.size = 2, releaseID &amp; " Pack Request 2nd child reserve details not created - setup phase : (test 17) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
		reserveDetail2 := packRequest.allReservePackingChildren.last;
		
		create pxyReleaseMatchCrit transient;
		create pxyCriteria transient;
		pxyReleaseMatchCrit.allCriteria.add(pxyCriteria);
		pxyCriteria.setProxy(	CM_YATypeCargoGroup.firstInstance,	//pCriteriaTypeObj:CM_YACriteriaType;
								cargo_GroupId3,	//pDataValue:Any;
								"Cargo Grou"	//pCode:String
								);
		self.opts.purge;
		self.opts.addAssoc("Number", "15".Integer);
		self.opts.addAssoc("Operator", oper);
		self.opts.addAssoc(ETRow_SetCriteria, pxyReleaseMatchCrit);
		self.addReserveSelectionOpts( packRequest, CM_ReserveDetail.PackType_Child, ctq.id);
		self.assertTrueMsg( packRequest.allReservePackingChildren.size = 3, releaseID &amp; " Pack Request 3rd child reserve details not created - setup phase : (test 18) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
		reserveDetail3 := packRequest.allReservePackingChildren.last;
	
	endif;
	
	//Build teh Road Release too
	
	opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Number", "2".Integer);
	self.opts.addAssoc("Operator", oper);
	self.opts.addAssoc("NoDelete", true);
	roadRequest := self.addReleaseByTypeRequestOpts(releaseID, BR_TYPE_ROAD, TI_CargoType_Container);
	self.assertTrueMsg( roadRequest &lt;&gt; null, releaseID &amp; " Road Request not created - setup phase : (test 19) - " &amp; app.myPassport.getErrorsAndWarningsAsString );


epilog

	delete ediControllerAgent;
	delete pxyFileTypeUser;

end;</source>
        <access>protected</access>
        <Parameter name="useEDI" type="Boolean"/>
        <Parameter name="oper" type="CM_Operator" usage="io"/>
        <Parameter name="packRequest" type="CM_BulkRelease" usage="io"/>
        <Parameter name="releaseID" type="String"/>
        <Parameter name="cargo_GroupId1" type="String"/>
        <Parameter name="ctv" type="CM_CargoType"/>
        <Parameter name="reserveDetail1" type="CM_ReserveDetail" usage="io"/>
        <Parameter name="cargo_GroupId2" type="String"/>
        <Parameter name="reserveDetail2" type="CM_ReserveDetail" usage="io"/>
        <Parameter name="ctw" type="CM_CargoType"/>
        <Parameter name="cargo_GroupId3" type="String"/>
        <Parameter name="reserveDetail3" type="CM_ReserveDetail" usage="io"/>
        <Parameter name="ctq" type="CM_CargoType"/>
        <Parameter name="roadRequest" type="CM_BulkRelease" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tCheckCantChangeChildVoyImex" id="1c1578a9-c672-4ec5-afc1-6881f90fe1df">
        <source>tCheckCantChangeChildVoyImex();

/*

Purpose:			Check that you get an error message when you change a child's voyage/imex/discharge port

Date		Who		Reason
05/04/2011	cnwmh5	Initial Create - PAR27375

*/


vars
	parent,
	child				: CM_TrackedItem;
	voyage1,
	voyage2				: CM_Voyage;
	vessel1,
	vessel2				: CM_Vessel;
	wh					: CM_IrregularBlockArea;
	dischargePort1,
	dischargePort2		: CM_Port;
	
	packTIs				: CM_TIArray;
	
begin	
	// setup the voyages
	deleteVoyage("UTMDH1");
	deleteVessel("UTMDH1");
	vessel1 := addVesselCellular("UTMDH1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage1 := addVoyageWithContainerStructur("UTMDH1", "UTMDH1", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	deleteVoyage("UTMDH2");
	deleteVessel("UTMDH2");
	vessel2 := addVesselCellular("UTMDH2", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage2 := addVoyageWithContainerStructur("UTMDH2", "UTMDH2", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	// setup discharge ports
	dischargePort1 := app.myRoot.allPorts["NZAKL"];
	dischargePort2 := app.myRoot.allPorts["NZNSN"];
	
	// setup the parent container
	self.deleteContainer("UTPAR27375A");
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage1.code);
	self.opts.addAssoc(UTTI_DischargePort, dischargePort1.code);
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	self.opts.addAssoc('State', TI_STATE_NORMAL);
	parent := self.addContainerOpts("UTPAR27375A", "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	assertNotNull(parent);
	
	// setup the child container
	self.deleteContainer("27375A");
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage1.code);
	self.opts.addAssoc(UTTI_DischargePort, dischargePort1.code);
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	self.opts.addAssoc('State', TI_STATE_NORMAL);
	child := self.addContainerOpts("27375A", "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	assertNotNull(child);
	
	// pack the child into the parent
	create packTIs transient;
	packTIs.add(child);
	packContainer(parent.CM_Container, packTIs);
	assertEqualMsg(parent.numChildren, 1, "Container children incorrect");
	
	self.opts.purge();
	self.opts.addAssoc('State', TI_STATE_NORMAL);
	updateTI(child);
	
	// change the child's voyage, imex, and discharge port
	self.expectTrxError(Item_Not_Match_Parent_VoyIMEXD);
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage2.code);
	self.opts.addAssoc(UTTI_DischargePort, dischargePort2.code);
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_EXPORT);
	updateTI(child);
	
epilog
	delete packTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCopyOfCustomsNumbersToChild" id="444a77af-d808-4b8e-9ae8-ce8c69cb7196">
        <source>tCopyOfCustomsNumbersToChild();
// cnwndl1
//13 November 2008	cnwdw1	
// Test copy of Customs numbers to children
// CCMS 1696
vars
	parentTI: CM_TrackedItem;
	attach: CMIF_InOutAttachment;
	attachments: CMIF_InOutAttachmentArray;
	product: CM_Product;
	cargoType: Integer;

begin
	self.deleteContainer("TEST0000001");
	self.deleteCargo("MDF9999", self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	
	self.opts.purge();
	self.opts.addAssociation("CustomsExportEntryNumber", "T1-A");
	self.opts.addAssociation("CustomsEntryNumber", "T1-B");
	self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);

	parentTI := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));

	assertEqualMsg(parentTI.customExportEntryNumber, "T1-A", "CustomsExportEntryNumber not set");
	assertEqualMsg(parentTI.customsEntryNumber, "T1-B", "CustomsEntryNumber not set");
	deleteProduct("UTMDF 99Amm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	product := addProduct("UTMDF 99Amm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));

	cargoType := app.myRoot.getCargoTypeIDFromAbbrev(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString);
	create attach transient;
	attach.set(getTerminal, cargoType, "MDF9999", "", 100); 
	attach.myProduct := product;
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	
	create attachments transient;
	attachments.add(attach);
	
	// Test1 - Check that after the children are attached the customs numbers have been copied
	setTerminalConfig(CopyCustomsNumbers, true);
	addContainerChildren(parentTI.CM_Container, attachments);

	//assertEqualMsg(parentTI.allChildren.size, 1, "Container children incorrect");//PAR 22954
	assertEqualMsg(parentTI.numChildren, 1, "Container children incorrect");
	//assertEqualMsg(parentTI.allChildren.first.customExportEntryNumber, "T1-A", "Child CustomsExportEntryNumber not set");//PAR 22954
	assertEqualMsg(parentTI.getFirstChild().customExportEntryNumber, "T1-A", "Child CustomsExportEntryNumber not set");
	//assertEqualMsg(parentTI.allChildren.first.customsEntryNumber, "T1-B", "Child CustomsEntryNumber not set");//PAR 22954
	assertEqualMsg(parentTI.getFirstChild().customsEntryNumber, "T1-B", "Child CustomsEntryNumber not set");

	// Test2 - Check that when the parent customs numbers are changed, the childrens numbers are changed
	self.opts.purge;
	self.opts.addAssociation("CustomsExportEntryNumber", "T2-A");
	self.opts.addAssociation("CustomsEntryNumber", "T2-B");
	updateTI(parentTI);
	assertEqualMsg(parentTI.customExportEntryNumber, "T2-A", "CustomsExportEntryNumber not set");
	assertEqualMsg(parentTI.customsEntryNumber, "T2-B", "CustomsEntryNumber not set");
	//assertEqualMsg(parentTI.allChildren.size, 1, "Container children incorrect");//PAR 22954
	assertEqualMsg(parentTI.numChildren, 1, "Container children incorrect");
	//assertEqualMsg(parentTI.allChildren.first.customExportEntryNumber, "T2-A", "Child CustomsExportEntryNumber not updated");//PAR 22954
	//assertEqualMsg(parentTI.allChildren.first.customsEntryNumber, "T2-B", "Child CustomsEntryNumber not updated");//PAR 22954
	assertEqualMsg(parentTI.getFirstChild().customExportEntryNumber, "T2-A", "Child CustomsExportEntryNumber not updated");
	assertEqualMsg(parentTI.getFirstChild().customsEntryNumber, "T2-B", "Child CustomsEntryNumber not updated");
	
	// Test3 - Check that the childrens numbers can be changed
	self.opts.purge;
	self.opts.addAssociation("CustomsExportEntryNumber", "T3-A");
	self.opts.addAssociation("CustomsEntryNumber", "T3-B");
	//self.opts.addAssociation("CargoType", parentTI.allChildren.first.cargoType);//PAR 22954
	self.opts.addAssociation("CargoType", parentTI.getFirstChild().cargoType);
	//updateTI(parentTI.allChildren.first, opts);//PAR 22954
	updateTI(parentTI.getFirstChild());
	assertEqualMsg(parentTI.customExportEntryNumber, "T2-A", "CustomsExportEntryNumber not set");
	assertEqualMsg(parentTI.customsEntryNumber, "T2-B", "CustomsEntryNumber not set");
	//assertEqualMsg(parentTI.allChildren.size, 1, "Container children incorrect");//PAR 22954
	//assertEqualMsg(parentTI.allChildren.first.customExportEntryNumber, "T3-A", "Child CustomsExportEntryNumber not updated");//PAR 22954
	//assertEqualMsg(parentTI.allChildren.first.customsEntryNumber, "T3-B", "Child CustomsEntryNumber not updated");//PAR 22954
	assertEqualMsg(parentTI.numChildren, 1, "Container children incorrect");
	assertEqualMsg(parentTI.getFirstChild().customExportEntryNumber, "T3-A", "Child CustomsExportEntryNumber not updated");
	assertEqualMsg(parentTI.getFirstChild().customsEntryNumber, "T3-B", "Child CustomsEntryNumber not updated");

	// Test4 - Change Parent and check that the childrens numbers are not changed
	// (as they have been changed by Test 3)
	self.opts.purge;
	self.opts.addAssociation("CustomsExportEntryNumber", "T4-A");
	self.opts.addAssociation("CustomsEntryNumber", "T4-B");
	updateTI(parentTI);
	assertEqualMsg(parentTI.customExportEntryNumber, "T4-A", "CustomsExportEntryNumber not set");
	assertEqualMsg(parentTI.customsEntryNumber, "T4-B", "CustomsEntryNumber not set");
	/*assertEqualMsg(parentTI.allChildren.size, 1, "Container children incorrect");
	assertEqualMsg(parentTI.allChildren.first.customExportEntryNumber, "T3-A", "Child CustomsExportEntryNumber was updated");
	assertEqualMsg(parentTI.allChildren.first.customsEntryNumber, "T3-B", "Child CustomsEntryNumber was updated");*///PAR 22954
	assertEqualMsg(parentTI.numChildren, 1, "Container children incorrect");
	assertEqualMsg(parentTI.getFirstChild().customExportEntryNumber, "T3-A", "Child CustomsExportEntryNumber was updated");
	assertEqualMsg(parentTI.getFirstChild().customsEntryNumber, "T3-B", "Child CustomsEntryNumber was updated");

epilog
	delete attach;
	delete attachments;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateChildInCont" id="13cb97a6-6869-4635-87fe-ef89996c1101">
        <source>tCreateChildInCont();
// cnwndl1
//13 November 2008	cnwdw1	
// Create and Attach children cargo to a container when Container has no stops
vars
	container1: CM_TrackedItem;
	attach: CMIF_InOutAttachment;
	attachments: CMIF_InOutAttachmentArray;
	product: CM_Product;
	cargoType: Integer;
	totalWeightBefore,
	weightCargoBefore	: Decimal[14,4];

begin
	self.deleteContainer("TEST0000001");
	self.deleteCargo("MDF9999", self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	
	self.opts.purge();
	self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc("CustomsEntryNumber", "100");
	container1 := self.addContainerOpts("TEST0000001", "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	assertEqualMsg(container1.getImExStatus, TI_IMEX_STATUS_IMPORT, "Container1 has incorrect IMEX Status");
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container1 has incorrect Status");
	// MAke sure all stops are removed
	self.opts.addAssoc("CENum", container1.customsEntryNumber);
	deleteStops(container1);
//	assertEqualMsg(container1.getAllStops().size, 0, "Container1 has stops");	// cnwrl1 14/12/2009 PAR 21889 - what it was
	assertEqualMsg(container1.getAllActiveStopsSize, 0, "Container1 has stops");
	
	
	deleteProduct("UTMDF 99Bmm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	product := addProduct("UTMDF 99Bmm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));

	cargoType := app.myRoot.getCargoTypeIDFromAbbrev(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString);
	create attach transient;
	attach.set(getTerminal, cargoType, "MDF9999", "", 100); 
	attach.myProduct := product;
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach.imExStatus := container1.getImExStatus;
	
	create attachments transient;
	attachments.add(attach);
	
		/* #26662 11/01/2011. Testing weight for a container. When make a child inside a container, 
	totalWeight and weightCargo should remain intact. They are changed wehn packing/unpacking only.*/
	totalWeightBefore := container1.totalWeight;
	weightCargoBefore := container1.CM_Container.weightCargo;
	
	addContainerChildren(container1.CM_Container, attachments);
	//assertEqualMsg(container1.allChildren.size, 1, "Container children incorrect");//PAR 22954
	assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	// #26662 11/01/2011. Testing weight
	assertEqualMsg(container1.totalWeight, 				totalWeightBefore, "Container " &amp; container1.id &amp; ", totalWeight should remain intact when creating a child inside the container.");
	assertEqualMsg(container1.CM_Container.weightCargo, weightCargoBefore, "Container " &amp; container1.id &amp; ", weightCargo should remain intact when creating a child inside the container.");
	
epilog
	delete attach;
	delete attachments;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateChildInContWithStops" id="a8e05add-71d2-41d1-90e6-de11f46fe62c">
        <source>tCreateChildInContWithStops();
// cnwndl1
//13 November 2008	cnwdw1	PAR 18549
// Create and Attach children cargo to a container when 
//	Container as a Stop
//  and the Stop is auto set on the child when the child is created
vars
	container1: CM_TrackedItem;
	attach: CMIF_InOutAttachment;
	attachments: CMIF_InOutAttachmentArray;
	product: CM_Product;
	cargoType: Integer;
	processAreas: IntegerArray;
	checkAreas: IntegerArray;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable1: CM_StopsTable;
	opts : CM_AssociationDict;

begin
	create opts transient;
	self.deleteContainer("TEST0000001");
	self.deleteCargo("MDF9999", self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));

	// Create a "Auto Import" and "Copy to Child" Stop
	deleteStopsTable(99);
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	selectedTypes.add(app.myRoot.allCargoTypesById[app.myRoot.getCargoTypeIDFromAbbrev(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString)]);	
	create checkAreas transient;
	checkAreas.add(StopApplyImport);
	create processAreas transient;
	processAreas.add(StopProcessCopyToChild);
	opts.purge;
	opts.addAssoc(ETRow_CheckStopAreas, checkAreas);
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	stopsTable1 := addStopsTable(99, "UT1", "Unit Test 1", selectedTypes, opts);
	assertNotNullMsg(stopsTable1, "StopsTable1 not created");
	
	opts.copy(self.opts);
	self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	container1 := self.addContainerOpts("TEST0000001", "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	assertEqualMsg(container1.getImExStatus, TI_IMEX_STATUS_IMPORT, "Container1 has incorrect IMEX Status");
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container1 has incorrect Status");
	
	deleteProduct("UTMDF 99Cmm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	product := addProduct("UTMDF 99Cmm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));

	cargoType := app.myRoot.getCargoTypeIDFromAbbrev(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString);
	create attach transient;
	attach.set(getTerminal, cargoType, "MDF9999", "", 100); 
	attach.myProduct := product;
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach.imExStatus := container1.getImExStatus;
	
	create attachments transient;
	attachments.add(attach);
	
	addContainerChildren(container1.CM_Container, attachments);
	//assertEqualMsg(container1.allChildren.size, 1, "Container children incorrect");//PAR 22954
	assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable1, selectedTypes);
	
epilog
	delete attach;
	delete attachments;
	delete selectedTypes;
	delete processAreas;
	delete checkAreas;
	delete opts;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateChildInContWithStops3" id="e95efab5-4c5d-4146-be74-8a1603bcc852">
        <source>tCreateChildInContWithStops3();
// cnwndl1
//19 Dec 2008	cnwdw1	PAR 18686
// Create and Attach children cargo to a container when 
//	There is a "Auto Import" stop with Process Action of "Remove When child" and "Copy to Children"
//     and
// The Parent container does have this stop set
// When the child is added it should NOT get this stop set
vars
	container1: CM_TrackedItem;
	attach: CMIF_InOutAttachment;
	attachments: CMIF_InOutAttachmentArray;
	product: CM_Product;
	cargoType: Integer;
	processAreas: IntegerArray;
	checkAreas: IntegerArray;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable1: CM_StopsTable;
	opts : CM_AssociationDict;
begin
	create opts transient;
	self.deleteContainer("TEST0000001");
	self.deleteCargo("MDF9999", self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));

	// Create a "Auto Import", "Remove From Child", "Copy to Child" Stop
	deleteStopsTable(98);
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	selectedTypes.add(app.myRoot.allCargoTypesById[app.myRoot.getCargoTypeIDFromAbbrev(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString)]);	
	create checkAreas transient;
	checkAreas.add(StopApplyImport);
	create processAreas transient;
	processAreas.add(StopProcessRemoveWhenChild);
	processAreas.add(StopProcessCopyToChild);
	opts.purge;
	opts.addAssoc(ETRow_CheckStopAreas, checkAreas);
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	stopsTable1 := addStopsTable(98, "UT2", "Unit Test 2", selectedTypes, opts);
	assertNotNullMsg(stopsTable1, "StopsTable1 not created");

	opts.copy(self.opts);
	self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	container1 := self.addContainerOpts("TEST0000001", "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	assertEqualMsg(container1.getImExStatus, TI_IMEX_STATUS_IMPORT, "Container1 has incorrect IMEX Status");
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container1 has incorrect Status");

	deleteProduct("UTMDF 99Dmm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	product := addProduct("UTMDF 99Dmm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));

	cargoType := app.myRoot.getCargoTypeIDFromAbbrev(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString);
	create attach transient;
	attach.set(getTerminal, cargoType, "MDF9999", "", 100); 
	attach.myProduct := product;
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach.imExStatus := container1.getImExStatus;
	
	create attachments transient;
	attachments.add(attach);
	
	addContainerChildren(container1.CM_Container, attachments);
	//assertEqualMsg(container1.allChildren.size, 1, "Container children incorrect");//PAR 22954
	assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	//assertFalse(container1.allChildren.first.hasStopOfType(stopsTable1));//PAR 22954
	assertFalse(container1.getFirstChild().hasStopOfType(stopsTable1));
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable1, selectedTypes);
	
epilog
	delete attach;
	delete attachments;
	delete selectedTypes;
	delete processAreas;
	delete checkAreas;
	delete opts;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDischargeChildCargo" id="3666bc6e-4f0b-4e93-93d1-41665a5650f5">
        <source>tDischargeChildCargo();
// cnwns1
// cnwjre1

// Create and child cargo in a container and discharge some taking the minimum weight into account - TFS 456
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
vars
	container1: CM_TrackedItem;
	child: CM_TrackedItem;
	pxyTI: CM_TrackedItem;
	trans	: CM_TITransaction;
	attach: CMIF_InOutAttachment;
	attachments: CMIF_InOutAttachmentArray;
	cargoType : CM_CargoType;
	product: CM_Product;
	cargoTypeId: Integer;
	totalWeightBefore,
	totalWeightAfter,
	weightCargoBefore	: Decimal[14,4];
	fieldUpdate	: CM_EDIDataCargoFieldUpdate;
	updateTI	: CM_EDICargoFieldUpdateTI;
	dict		: CM_EDICargoByIdBOLDict;
	array	: HugeStringArray;
	count	: Integer;
	str		: String;

begin
	cargoType := self.getCargoType("UT_TNKCARG");
	product := cargoType.allProducts[null, "UT_TANKSTUFF"];

	self.deleteContainer("TEST0000009");
	// NOTE - the deleteContainer should delete the TANK9999 child - this is in case it doesn't for some reason
	self.deleteCargo("TANK9999", cargoType);
	
	self.opts.purge();
	self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc("CustomsEntryNumber", "100");
	container1 := self.addContainerOpts("TEST0000009", "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	assertEqualMsg(container1.getImExStatus, TI_IMEX_STATUS_IMPORT, "Container1 has incorrect IMEX Status");
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container1 has incorrect Status");
	// Make sure all stops are removed
	self.opts.addAssoc("CENum", container1.customsEntryNumber);
	deleteStops(container1);
	assertEqualMsg(container1.getAllActiveStopsSize, 0, "Container1 has stops");
	create array transient;

	cargoTypeId := cargoType.id;
	create attach transient;
	attach.set(getTerminal, cargoTypeId, "TANK9999", "", 5000); 
	attach.myProduct := product;
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach.imExStatus := container1.getImExStatus;
	
	create attachments transient;
	attachments.add(attach);
	
		/* #26662 11/01/2011. Testing weight for a container. When make a child inside a container, 
	totalWeight and weightCargo should remain intact. They are changed when packing/unpacking only.*/
	totalWeightBefore := container1.totalWeight;
	weightCargoBefore := container1.CM_Container.weightCargo;
	
	addContainerChildren(container1.CM_Container, attachments);
	assertEqualMsg(container1.numChildren, 1, "Container children incorrect");

	child := container1.allChildren.first;
	// need to explicitly increase the parent cargo and total weights to simulate a pack
	beginTransaction;
	container1.setTotalWeightWithoutTrans(container1.totalWeight + child.totalWeight);
	container1.setWeightCargo(child.totalWeight);
	child.setWeightCargo(child.totalWeight);
	commitTransaction;

	// child weight 5000, container total 9000, unload 4000 kg
	create fieldUpdate transient;
	create dict transient;
	create updateTI transient;
	updateTI.setId(child.id);
	updateTI.setCargoType(child.cargoType);
	updateTI.fieldName := CM_EDICargoFieldUpdateTI.F_CargoWeightChange;
	updateTI.fieldValue := "-4000";		// unload 4000 kg
	dict.add(updateTI);
	beginTransaction;
	fieldUpdate.testUpdateTIs(dict, false, app.myPassport);
	commitTransaction;
		
	self.assertNoTrxErrorsOrWarnings();

	assertEqualMsg(container1.totalWeight, 5000.Decimal, "Container " &amp; container1.id &amp; ", totalWeight after first discharge.");
	assertEqualMsg(container1.weightCargo, 1000.Decimal, "Container " &amp; container1.id &amp; ", cargoWeight after first discharge.");
	assertEqualMsg(child.totalWeight, 1000.Decimal, "Child " &amp; child.id &amp; ", totalWeight after first discharge.");
	assertEqualMsg(child.weightCargo, 1000.Decimal, "Child " &amp; child.id &amp; ", cargoWeight after first discharge.");
	trans := container1.getLastTransOfType(TRANS_TYPE_EDIT);
	trans.CM_Edit.fieldsValues.getStrings(array);
	foreach str in array do	
		if str = "allCustomsEntryNumbers  =&gt; 100" or str.startsWith("houseBillOfLading  =&gt;") then
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(str, "totalWeight 9000.0000 =&gt; 5000.0000", "Container Edit after first discharge");
		elseif count = 2 then
			self.assertEqualMsg(str, "weightCargo 5000.0000 =&gt; 1000.0000", "Container Edit after first discharge");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Container Edit contents after first discharge");
	trans := child.getLastTransOfType(TRANS_TYPE_EDIT);
	trans.CM_Edit.fieldsValues.getStrings(array);
	count := 0;
	foreach str in array do	
		if str = "allCustomsEntryNumbers  =&gt; 100" or str.startsWith("houseBillOfLading  =&gt;") then
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(str, "totalWeight 5000.0000 =&gt; 1000.0000", "Child Edit after first discharge");
		elseif count = 2 then
			self.assertEqualMsg(str, "weightCargo 5000.0000 =&gt; 1000.0000", "Child Edit after first discharge");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Child Edit contents after first discharge");

	// child weight 1000, container total 5000, unload 1000 kg, should be left with minimum child weight of 500
	dict.clear();
	delete updateTI;
	create updateTI transient;
	updateTI.setId(child.id);
	updateTI.setCargoType(child.cargoType);
	updateTI.fieldName := CM_EDICargoFieldUpdateTI.F_CargoWeightChange;
	updateTI.fieldValue := "-1000";		// unload 1000 kg
	dict.add(updateTI);
	beginTransaction;
	fieldUpdate.testUpdateTIs(dict, false, app.myPassport);
	commitTransaction;
		
	self.assertNoTrxErrorsOrWarnings();
	assertEqualMsg(container1.totalWeight, 4500.Decimal, "Container " &amp; container1.id &amp; ", totalWeight after second discharge.");
	assertEqualMsg(container1.weightCargo, 500.Decimal, "Container " &amp; container1.id &amp; ", cargoWeight after second discharge.");
	assertEqualMsg(child.totalWeight, 500.Decimal, "Child " &amp; child.id &amp; ", totalWeight after second discharge.");
	assertEqualMsg(child.weightCargo, 500.Decimal, "Child " &amp; child.id &amp; ", cargoWeight after second discharge.");

	trans := container1.getLastTransOfType(TRANS_TYPE_EDIT);
	trans.CM_Edit.fieldsValues.getStrings(array);
	count := 0;
	foreach str in array do	
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(str, "totalWeight 5000.0000 =&gt; 4500.0000", "Container Edit after second discharge");
		elseif count = 2 then
			self.assertEqualMsg(str, "weightCargo 1000.0000 =&gt; 500.0000", "Container Edit after second discharge");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Container Edit contents after second discharge");

	trans := child.getLastTransOfType(TRANS_TYPE_EDIT);
	trans.CM_Edit.fieldsValues.getStrings(array);
	count := 0;
	foreach str in array do	
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(str, "totalWeight 1000.0000 =&gt; 500.0000", "Child Edit after second discharge");
		elseif count = 2 then
			self.assertEqualMsg(str, "weightCargo 1000.0000 =&gt; 500.0000", "Child Edit after second discharge");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Child Edit contents after second discharge");
epilog
	abortTransaction;
	delete attach;
	delete attachments;
	delete fieldUpdate;
	delete updateTI;
	delete dict;
	delete array;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPackByReqProspectiveChild" id="bf32dc03-0aa9-49c5-8dad-8017bd07e356">
        <updating/>
        <source>tPackByReqProspectiveChild() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 01 July 2019
TFS#		: 45287
Function	:

*** Changes ***
Date		Name	TFS#	Description
15/08/2019	jlgka1	45924	JMT - Pack by Request - Webservice. 
							BA decided to change the logic to use CM_TerminalArea instead of the yard interchanged
							and use a Dictionary instead of TIArray.
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
05/03/2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
****************************************************/
vars	
	trackedItemSet	: CM_TISet;
	releaseRequest	: CM_BulkRelease;
	cont1, 
	cont2			: CM_TrackedItem;	
	operator		: CM_Operator;
	trackedItemList	: Dictionary;
	reserveDetail	: CM_ReserveDetail;
	expTrackedItem	: CM_TrackedItem;
	currTrackedItem	: CM_TrackedItem;
	blockStack		: CM_BlockStack;
	count			: Integer;			// MTN-34024
begin
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	self.deleteContainer("UTPACK001");
	self.deleteContainer("UTPACK002");
	self.deleteReleaseRequest("UTPackReq");
	
	blockStack := addBlockStack("UTBS1", 100, null);	
	
	cont1 := self.addContainerAtLocation("UTPACK001", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack);
	cont2 := self.addContainerAtLocation("UTPACK002", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack);
	
	opts.addAssociation("FullRelease", true);
	
	create trackedItemSet transient;	
	trackedItemSet.add(cont1); 	
	trackedItemSet.add(cont2);
	
	releaseRequest := self.addReleaseById("UTPackReq", BR_TYPE_ROAD, trackedItemSet);
	assertEqual(releaseRequest.allReserveDetails.size, 2);
	assertTrue(releaseRequest.fullRelease);
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	//expTrackedItem := reserveDetail.allTrackedItems.first;
	expTrackedItem := reserveDetail.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	create trackedItemList as CM_TIByIdCargoTypeDict transient;
	
	releaseRequest.getProspectiveCargo(reserveDetail, null, null,null, trackedItemList, false, null, null, count);		// MTN-34024
	
	currTrackedItem := trackedItemList.CM_TIByIdCargoTypeDict.first;
	
	assertEqualMsg(trackedItemList.size, 1, "Tracked item list from Release Request expected 1" &amp; " actual " &amp; trackedItemList.size.asStringJMT);
	assertEqualMsg(expTrackedItem, currTrackedItem, "Selected Tracked item ");
			
epilog
	delete trackedItemSet;
	delete trackedItemList;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPackByReqProspectiveParent" id="e9149ac5-5595-4279-bf70-5193df227c97">
        <updating/>
        <source>tPackByReqProspectiveParent() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 01 July 2019
TFS#		: 45287
Function	:

*** Changes ***
Date		Name	TFS#		Description
21/08/2019	jlgka1 	TFS 46218 	JMT - Stop the getProspectivePackingParents  to findMore when it is coming from Web.
****************************************************/
vars	
	trackedItemSet	: CM_TISet;
	releaseRequest	: CM_BulkRelease;
	cont1, 
	cont2			: CM_TrackedItem;	
	operator		: CM_Operator;
	trackedItemList	: CM_TIArray;
	blockStack		: CM_BlockStack;
	isFromWeb		: Boolean;
begin
	isFromWeb := true;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	self.deleteContainer("UTPACK001");
	self.deleteContainer("UTPACK002");
	self.deleteReleaseRequest("UTPackReq");
	
	blockStack := addBlockStack("UTBS1", 100, null);
		
	cont1 := self.addContainerAtLocation("UTPACK001", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack);
	cont2 := self.addContainerAtLocation("UTPACK002", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack);
	
	opts.addAssociation("FullRelease", true);
	
	create trackedItemSet transient;	
	trackedItemSet.add(cont1); 	
	trackedItemSet.add(cont2);
	
	releaseRequest := self.addReleaseById("UTPackReq", BR_TYPE_ROAD, trackedItemSet);
	assertEqual(releaseRequest.allReserveDetails.size, 2);
	assertTrue(releaseRequest.fullRelease);
	
	create trackedItemList transient;
	
	releaseRequest.getProspectiveParentCargo(trackedItemList, isFromWeb);
	
	assertEqualMsg(trackedItemList.size, 2, "Tracked item list from Release Request expected 2" &amp; " actual " &amp; trackedItemList.size.asStringJMT);
			
epilog
	delete trackedItemSet;
	delete trackedItemList;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPackCompleteWithRelByTypeReq" id="ee91ddfa-34f3-44e9-a1d6-31faa1501861">
        <source>tPackCompleteWithRelByTypeReq();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2024	navbs1	Initial creation

*/

constants
	REF	 : String  =  "65544";
	BLOCKSTACK : String = "BS" &amp;REF;
	Voyage	: String = "UTVOY" &amp; REF;
vars

	ti1,
	ti2						: CM_TrackedItem;
	releaseRequest			: CM_BulkRelease;
	taSource				: CM_TerminalArea;
	code					: String;
	relTime					: TimeStamp;
	terminal 				: CM_Terminal;
	operator 				: CM_Operator;
	blockStack, 
	targetBs				: CM_BlockStack;
	voyage 					: CM_Voyage;
	vessel 					: CM_Vessel;
	dischargePort 			: CM_Port;
	packingCargo1,
	packingCargo2,
	packingCargo3			: CM_TrackedItem;
	wh						: CM_IrregularBlockArea;
	cargoType				: CM_CargoType;

begin
	app.setIsWebApp(true); // Need to execute our methods like we are a web app
	
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "terminal");
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2" &amp; REF);
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2" &amp; REF, 10, null);
	
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(operator, "operator");
	
	self.deleteReleaseRequest("UHLREL1");
	self.deleteVoyage(Voyage);
	
	// vessel and voyage	
	vessel := self.addVesselWithHolds("UTHLVESS1", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	self.deleteContainer("UTHL01" &amp; REF);
	self.deleteContainer("UTHL02" &amp; REF);
	self.deleteContainer(REF &amp; "PACK1");
	self.deleteContainer(REF &amp; "PACK2");
	self.deleteContainer(REF &amp; "PACK3");
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	ti1 := self.addContainerOpts("UTHL01" &amp; REF, "2200", "MT", operator);	
	ti2 := self.addContainerOpts("UTHL02" &amp; REF, "2200", "MT", operator);
	
	self.move(ti1, blockStack);	
	self.move(ti2, blockStack);
	
	cargoType := terminal.getCargoTypeFromDescription("Steel Coil");
	self.assertNotNullMsg(cargoType, "CargoType");
	
	self.opts.purge();
	self.opts.addAssoc("Product", cargoType.getProductFromCode("GVS"));
	
	wh := terminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	packingCargo1 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK1", cargoType, 100, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	packingCargo2 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK2", cargoType, 100, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	packingCargo3 := self.addCargoBreakBulkAtLocation(REF &amp; "PACK3", cargoType, 100, wh.allLocationsControllers.first, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc('Number', 2);
	self.opts.addAssoc('NumberSec', 300);
	self.opts.addAssoc('ISOType', "2200");
	self.opts.addAssoc('CargoType', cargoType);
	self.opts.addAssoc('PackType', CM_ReserveDetail.PackType_Parent);
	self.opts.addAssoc('PackType1', CM_ReserveDetail.PackType_Child);
	releaseRequest:=self.addReleaseByTypeRequestOpts("UHLREL1", BR_TYPE_PACKING, 1);
	code := releaseRequest.code;
	relTime := releaseRequest.dateRequested;
	self.assertNotNull(releaseRequest);
	
	
	app.myTrxUA.trxUpdatePackCargo(ti1, packingCargo1, 100, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,null, app.myPassport);
	self.checkTrxResult();
	self.webServiceCallWithParams( CM_UnitTestAgent::wsRESTPutPackComplete.name, ti1, releaseRequest);
	
	app.myTrxUA.trxUpdatePackCargo(ti2, packingCargo2, 100, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,null, app.myPassport);
	self.checkTrxResult();
	app.myTrxUA.trxUpdatePackCargo(ti2, packingCargo3, 100, 0, true, releaseRequest, releaseRequest.allReservePackingChildren.first,false,null, app.myPassport);
	self.checkTrxResult();
	self.webServiceCallWithParams( CM_UnitTestAgent::wsRESTPutPackComplete.name, ti2, releaseRequest);
	
	self.assertEqualMsg(releaseRequest.status,BR_COMPLETE,"Release request status is incorrect");


epilog		
	app.setIsWebApp(false); //We always want to set this to false

end;</source>
    </JadeMethod>
    <JadeMethod name="tPackContainer" id="dc109b9d-1c86-459b-aa3a-7e904e780124">
        <source>tPackContainer();
// cnwdap1
//04 December 2009	cnwml2
//+cnwml2 MSL CCMS 1017

vars
	container1: CM_TrackedItem;
	packTIs: CM_TIArray;
	product: CM_Product;
	wh: CM_IrregularBlockArea;
	selectedTypes: CM_CargoBOLTypeSet;
	cargo, cargo1: CM_TrackedItem;
	container1_totalVolumeOriginal, 
	container1_cargoVolumeOriginal	: Decimal[16,4];
	
begin
	self.deleteContainer("TEST0000001");

	self.opts.addAssoc("TotalVolume", 20);
	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	assertEqual(container1.totalWeight, "4000".Decimal);
	assertEqual(container1.weightCargo, 0.Decimal);
	assertEqual(container1.weightTare, 4000.Decimal);
	assertTrue(container1.getMyTotalVolume &gt; 0.Decimal);
	
	self.deleteContainer("MATCHILD001");
	self.deleteContainer("MATCHILD002");
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	cargo := self.addContainerAtLocation("MATCHILD001", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	assertLocationHasTI(wh.allLocationsControllers.first, cargo);
	assertTrue(cargo.getMyTotalVolume &gt; 0);
	assertEqual(cargo.totalWeight, "2000".Decimal);
	cargo1 := self.addContainerAtLocation("MATCHILD002", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	assertLocationHasTI(wh.allLocationsControllers.first, cargo1);
	assertEqual(cargo1.totalWeight, "2000".Decimal);
	assertTrue(cargo1.getMyTotalVolume &gt; 0);

	// Par 25592. Volume test when packing
	container1_totalVolumeOriginal	:= container1.getMyTotalVolume;	// this is Container Total Volume, i.e. current real volume of iron box. When a container is created, volume can be equal 0 or default Cubic metres from container range or a fleet file.
	container1_cargoVolumeOriginal	:= container1.getMyCargoVolume;	// this is total volume of all children packed into the container.
	
	create packTIs transient;
	packTIs.add(cargo);
	packContainer(container1.CM_Container, packTIs);
	assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	assertEqual(container1.totalWeight, "6000".Decimal);   //original total weight is 4000 + total weight of child 400 = 4400
	assertEqual(container1.weightCargo, cargo.totalWeight);
	assertEqual(container1.weightTare, 4000.Decimal);

	delete packTIs;
	create packTIs transient;
	packTIs.add(cargo1);
	packContainer(container1.CM_Container, packTIs);
	assertEqualMsg(container1.numChildren, 2, "Container children incorrect");
	assertEqual(container1.totalWeight, "8000".Decimal);   //original total weight is 4000 + total weight of child 400 = 4400
	assertEqual(container1.weightCargo, cargo1.totalWeight + cargo.totalWeight);
	assertEqual(container1.weightTare, 4000.Decimal);

	// #25592 - volume test after packing
	assertEqual(container1.getMyTotalVolume, container1_totalVolumeOriginal);	// when packing/unpacking, the volume of iron box should be intact. A container cannot become bigger/smaller, when some items are packed inside.
	assertEqual(container1.getMyCargoVolume, container1_cargoVolumeOriginal + cargo.getMyTotalVolume + cargo1.getMyTotalVolume);	
	
	
epilog
	delete packTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPackContainerThenChgeChildWgt" id="f76e152a-1d05-4897-bd31-d0dadc4db78a">
        <source>tPackContainerThenChgeChildWgt();
// cnwdap1
//04 December 2009	cnwml2
//+cnwml2 MSL CCMS 1017

vars
	container1: CM_TrackedItem;
	packTIs: CM_TIArray;
	wh: CM_IrregularBlockArea;
	selectedTypes: CM_CargoBOLTypeSet;
	cargo, cargo1, pxyCargo: CM_TrackedItem;
begin
	self.deleteContainer("TEST0000001");
	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	assertEqual(container1.totalWeight, "4000".Decimal);
	assertEqual(container1.weightTare, "4000".Decimal);
	assertEqual(container1.weightCargo, null);
	
	self.deleteContainer("MATCHILD001");
	self.deleteContainer("MATCHILD002");
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	cargo := self.addContainerAtLocation("MATCHILD001", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	cargo1 := self.addContainerAtLocation("MATCHILD002", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	assertLocationHasTI(wh.allLocationsControllers.first, cargo);
	assertEqual(cargo.totalWeight, "2000".Decimal);
	assertEqual(cargo.weightTare, "400".Decimal);
	assertEqual(cargo1.totalWeight, "2000".Decimal);
	assertEqual(cargo1.weightTare, "400".Decimal);

	//first pack the 2 child containers
	create packTIs transient;
	packTIs.add(cargo);
	packTIs.add(cargo1);
	packContainer(container1.CM_Container, packTIs);
	assertEqualMsg(container1.numChildren, 2, "Container children incorrect");
	assertEqual(container1.totalWeight, "8000".Decimal);   //original total weight is 4000 + total weight of children (2000 x 2) = 8000
	assertEqual(container1.weightCargo, "4000".Decimal);
	
	self.opts.addAssoc("TotalWeight", "400");
	self.updateTrackedItem(cargo);
	self.updateTrackedItem(cargo1);
	assertEqualMsg(container1.numChildren, 2, "Container children incorrect");
	assertEqual(cargo.totalWeight, "400".Decimal);	// checking that the weight has changed on teh child.
	assertEqual(cargo1.totalWeight, "400".Decimal);
	
	// Changing the weight of a child should NOT have an effect on the weight of the parent Pars 26121 and 26122....
	assertEqual(container1.totalWeight, "8000".Decimal);
	assertEqual(container1.weightCargo, "4000".Decimal);
	
epilog

	delete packTIs;

end;</source>
    </JadeMethod>
    <JadeMethod name="tPackContainterWithBreakBulk" id="904d08c4-3a63-42aa-9d6f-dbd0a738dfdd">
        <source>tPackContainterWithBreakBulk();
/*
Purpose:			
Date				Who			Reason
JANUARY 2016		NAVAB1		Initial creation
*/
vars
	container1: CM_TrackedItem;
	packTIs: CM_TIArray;
	product: CM_Product;
	wh: CM_IrregularBlockArea;
	selectedTypes: CM_CargoBOLTypeSet;
	cargo4, cargo3, cargo2, cargo1: CM_TrackedItem;
	container1_totalVolumeOriginal, 
	container1_cargoVolumeOriginal	: Decimal[16,4];
	ct : CM_CargoType;
	op : CM_Operator;
	voy : CM_Voyage;
	newTiIds : StringArray;
begin

	ct := app.myRoot.getCargoTypeFromAbbrev("UTBYQ");
	assertNotNullMsg(ct,"Cargo type UTBYQ not found");
	op := app.myRoot.allOperators["UT01"];
	assertNotNullMsg(op,"Operator UT01 not found");
	voy := self.getTerminal().getNullVoyage();
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	
	
	self.deleteContainer("PACK0000001");

	self.opts.addAssoc("TotalVolume", 20);
	container1 := self.addContainerOpts("PACK0000001", "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	self.move(container1,wh.allLocationsControllers.first);
	
	assertEqual(container1.totalWeight, "4000".Decimal);
	assertEqual(container1.weightCargo, 0.Decimal);
	assertEqual(container1.weightTare, 4000.Decimal);
	assertTrue(container1.getMyTotalVolume &gt; 0.Decimal);
	
	self.deleteCargo("PACKCHILD001",ct);
	self.deleteCargo("PACKCHILD002",ct);
	self.deleteCargo("PRESPLIT003",ct);	//01 Sep 2020	NDL	TFS 49993
	self.deleteCargo("PACKCHILD003",ct); //01 Sep 2020	NDL	TFS 49993


	self.opts.addAssoc("TotalQuantity", 10);
	cargo1 := self.addCargoAtLocationDetailed("PACKCHILD001",ct,null,wh.allLocationsControllers.first, "ESBCN", TI_IMEX_STATUS_EXPORT, voy,op);
	assertEqualMsg(cargo1.quantity, 10, "1. PACKCHILD001 quantity should be 10, actually is " &amp; cargo1.quantity.String);
	assertLocationHasTI(wh.allLocationsControllers.first, cargo1);
	assertTrue(cargo1.getMyTotalVolume &gt; 0);
	assertEqual(cargo1.totalWeight, "1000".Decimal);
	assertEqualMsg(cargo1.site, TI_SITE_ONSITE, "1. PACKCHILD001 Site should be ON SITE");
	
	
	cargo2 := self.addCargoAtLocationDetailed("PACKCHILD002",ct,null,wh.allLocationsControllers.first, "ESBCN", TI_IMEX_STATUS_EXPORT, voy,op);
	assertLocationHasTI(wh.allLocationsControllers.first, cargo2);
	assertEqual(cargo2.totalWeight, "1000".Decimal);
	assertTrue(cargo2.getMyTotalVolume &gt; 0);
	
	//01 Sep 2020	NDL	TFS 49993
	self.opts.purge();
	cargo3 := self.addCargoAtLocationDetailed("PRESPLIT003",ct,null,wh.allLocationsControllers.first, "ESBCN", TI_IMEX_STATUS_EXPORT, voy,op);
	assertLocationHasTI(wh.allLocationsControllers.first, cargo3);
	self.opts.addAssoc("TotalQuantity", 2);
	self.updateTI( cargo3 );

	container1_totalVolumeOriginal	:= container1.getMyTotalVolume;	// this is Container Total Volume, i.e. current real volume of iron box. When a container is created, volume can be equal 0 or default Cubic metres from container range or a fleet file.
	container1_cargoVolumeOriginal	:= container1.getMyCargoVolume;	// this is total volume of all children packed into the container.

	create packTIs transient;
	packTIs.add(cargo1);
	packContainer(container1.CM_Container, packTIs);
	assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	assertEqual(container1.totalWeight, "5000".Decimal);   //original total weight is 4000 + total weight of child 1000 = 5000
	assertEqual(container1.weightTare, 4000.Decimal);
	
	assertNullMsg(cargo1.getTransactionOfType(TRANS_TYPE_MERGE), "PACKCHILD001 Should not have any MERGE transactions");
	assertEqualMsg(cargo1.totalWeight, 1000.Decimal, "PACKCHILD001 weight should be 1000, actually is " &amp; cargo1.totalWeight.String);
	assertEqualMsg(cargo1.quantity, 10, "PACKCHILD001 quantity should be 10, actually is " &amp; cargo1.totalQuantity.String);
	assertEqualMsg(cargo1.site, TI_SITE_ONSITE, "2. PACKCHILD001 Site should be ON SITE");

	delete packTIs;
	create packTIs transient;
	packTIs.add(cargo2);
	packContainer(container1.CM_Container, packTIs);
	assertEqualMsg(container1.numChildren, 2, "Container children incorrect");
	assertEqual(container1.totalWeight, "6000".Decimal);   //original total weight is 4000 + total weight of child 200 = 6000
	assertEqual(container1.weightTare, 4000.Decimal);
	
	assertNullMsg(cargo2.getTransactionOfType(TRANS_TYPE_MERGE), "PACKCHILD002 Should not have any MERGE transactions");
	assertEqualMsg(cargo2.totalWeight, 1000.Decimal, "PACKCHILD002 weight should be 1000, actually is " &amp; cargo2.totalQuantity.String);
	assertEqualMsg(cargo2.site, TI_SITE_ONSITE, "PACKCHILD002 Site should be ON SITE");

	//01 Sep 2020	NDL	TFS 49993
	create newTiIds transient;
	newTiIds.add("PACKCHILD003");
	app.myTrxUA.trxSplitBreakBulkToNewID(	cargo3.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											0,	// _weightOrVolume : Decimal;
											cargo3.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
											
	cargo4 := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( ct.id, "PACKCHILD003" );
	self.assertTrueMsg(cargo4.site = TI_SITE_ONSITE, "PACKCHILD003 Site should be ON SITE");
	
	self.assertTrueMsg(cargo4.allTransactions.size = 1, "PACKCHILD003 should only have 1 transaction, a split"); // note the receive displayed in the trx enq form belongs to the parent it was split from
	self.assertTrueMsg(cargo4.getTransReceive = null, "PACKCHILD003 should not have a receivce trx");
	self.assertTrueMsg(cargo4.getMySplitFromParent = cargo3, "PACKCHILD003 should have a split from trx");
	
	delete packTIs;
	create packTIs transient;
	packTIs.add(cargo4);
	packContainer(container1.CM_Container, packTIs);
	
	self.assertTrueMsg(cargo4.getTransReceive = null, "PACKCHILD003 should STILL not have a receivce trx"); // we don't create a receive for a ti without a receieve as it is being
																														// packed if it was created on-site by a split. (we do as part of the lcl create process)
	
	
epilog
	delete packTIs;
	delete newTiIds;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPackUnpackPackContainer" id="b4602665-ec6e-451e-9c90-065ce276f3af">
        <source>tPackUnpackPackContainer();
// cnwns1
// cnwjre1
// test 32065 don't clear packed date on unpack, and don't clear unpacked date on pack

vars
	container1: CM_TrackedItem;
	packTIs, unpackTIs: CM_TIArray;
	wh: CM_IrregularBlockArea;
	cargo, cargo1: CM_TrackedItem;
	
begin
	self.deleteContainer("TEST0000001");

	container1 := self.addContainerOpts("TEST0000001", "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	self.deleteContainer("MATCHILD001");
	self.deleteContainer("MATCHILD002");
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	cargo := self.addContainerAtLocation("MATCHILD001", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	cargo1 := self.addContainerAtLocation("MATCHILD002", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	self.assertLocationHasTI(wh.allLocationsControllers.first, cargo);

	//first pack in 1 child container
	create packTIs transient;
	packTIs.add(cargo);
	self.packContainer(container1.CM_Container, packTIs);
	self.packCompleteContainer(container1.CM_Container);

	self.assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	self.assertNullMsg(container1.unpackedDT, "Unpack date, first pack");
	self.assertNotNullMsg(container1.packedDT, "Pack date, first pack");

	//unpack this container
	create unpackTIs transient;
	unpackTIs.add(cargo);
	self.unpackContainer(container1, unpackTIs);
	self.unpackCompleteContainer(container1);

	self.assertEqualMsg(container1.numChildren, 0, "Container children incorrect");
	self.assertNotNullMsg(container1.unpackedDT, "Unpack date, first unpack");
	self.assertNotNullMsg(container1.packedDT, "Pack date, first unpack");
	
	// pack the second child
	packTIs.clear();
	packTIs.add(cargo1);
	self.packContainer(container1.CM_Container, packTIs);
	self.packCompleteContainer(container1.CM_Container);

	self.assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	self.assertNotNullMsg(container1.unpackedDT, "Unpack date, second pack");
	self.assertNotNullMsg(container1.packedDT, "Pack date, second pack");

epilog
	delete unpackTIs;
	delete packTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPackWeightCheckMobile" id="c007e36c-76d8-403e-a461-6a240ceb58c2">
        <source>tPackWeightCheckMobile();
//cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 March 2012	cnwndl1	Initial creation	Par 29250
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

constants

	ContId : String = "CONT0708091";
	Child1Id : String = "LCLA0708092";
	Child2Id : String = "LCLB0708093";
	
vars

	ti1 : CM_TrackedItem;
	attach: CMIF_InOutAttachment;
	attachments: CMIF_InOutAttachmentArray;
	lclCargoTypeInt : Integer;
	lclCargoType : CM_CargoType;
	pxyTI : CM_TrackedItem;
	childTi1 : CM_TrackedItem;
	childTi2 : CM_TrackedItem;
//	schema : Schema;
//	class : Class;
//	transClass : CM_Transient;
	form : Form;
	bs : CM_BlockStack;
	newLocation : CM_LocationsController;
	skipQuestion : Boolean;
	mobileAgent : CMIF_MobileGenericAgent;
	
begin

/*
	If unpacking a container then at the point where there is no more child cargo,
	JMT we will set the "Declared Weight" to zero,  the 'Cargo Weight' to zero and
	the 'Total Weight' to the 'Tare Weight' .  ( I.e. at the same time that we
	clear the hazards and OD settings from an empty container)
	While unpacking cargo ( and re-calculating 'Total Weight' and 'Cargo Weight' values )
	if subtracting the child cargos 'total weight' would cause the Containers
	'total weight' to be less than the Tare weight we will just make the containers
	'Total weight' its 'Tare weight'.
	Similarly the Cargo weight will not be permitted to go below zero due to unpacking. 
*/

	lclCargoTypeInt := TI_CargoType_LCL;
	lclCargoType := app.myRoot.allCargoTypesById[lclCargoTypeInt];
	
	//create a Box with children in it 
	self.deleteContainer(ContId);
	self.deleteCargo(Child1Id,lclCargoType);
	self.deleteCargo(Child2Id,lclCargoType);
	
	bs := self.getTerminal.allTerminalAreasByTypeId[1,"UT_BS"].CM_BlockStack;
	assertTrueMsg(bs &lt;&gt; null, "UT_BS Block stack not available");

	ti1 := self.addContainerOpts(ContId, "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	create attachments transient;
	
	create attach transient;
	attach.set(getTerminal, lclCargoTypeInt, Child1Id, "", 1800); 
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attachments.add(attach);
	
	create attach transient;
	attach.set(getTerminal, lclCargoTypeInt, Child2Id, "", 2100); 
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attachments.add(attach);
	
	self.addContainerChildren(ti1.CM_Container, attachments);
	
	childTi1 := ti1.allChildren.first;
	childTi2 := ti1.allChildren.last;
	
	assertTrueMsg(childTi1 &lt;&gt; null, "First Child not created");
	assertTrueMsg(childTi1.id = Child1Id, "First child should be " &amp; Child1Id);
	assertTrueMsg(childTi2 &lt;&gt; null, "Second Child not created");
	assertTrueMsg(childTi2.id = Child2Id, "Second child should be " &amp; Child2Id);
	
	//manually set the weights so that the childrens individual weight is greater than the total.
	pxyTI := app.createUpdateProxy(ti1).CM_TrackedItem;
	pxyTI.setWeightTare(2000);
	pxyTI.setPropertyValue("weightDeclared","4000".Decimal);
	pxyTI.setWeightCargo(3900);
	pxyTI.setTotalWeight(5900, null,app.myPassport);
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyTI;
	
	assertEqualMsg(ti1.getTareWeight, "2000.0000".Decimal, "Original Tare Weight should be 2000.0000");
	assertEqualMsg(ti1.weightDeclared, "4000.0000".Decimal, "Original Weight Declared should be 4000.0000");
	assertEqualMsg(ti1.weightCargo, "3900.0000".Decimal, "Original Cargo Weight should be 3900.0000");
	assertEqualMsg(ti1.totalWeight, "5900.0000".Decimal, "Original Total Weight should be 5900.0000");
	
	//unpack the children, and check that the calculated weight values do not go negative, and are set to teh correct values when MT.
	
	newLocation := bs.myLocationsController;
//	schema := rootSchema.getSchema("MobileUISchema");
//	class := schema.getClass("MOB_HandHeldCheckerAgent");
	create mobileAgent transient;
	mobileAgent.setDoNotShowMsgBox(true);
	
	//mobileAgent.doUnPack( form, ti1, childTi1, newLocation );
	mobileAgent.doUnpackCargo(childTi1,newLocation,0,childTi1.totalWeight,null);
	
	self.assertNoTrxErrorsOrWarnings();
	assertEqualMsg(ti1.getTareWeight, "2000.0000".Decimal, "After first unpack, Tare Weight should be 2000.0000");
	assertEqualMsg(ti1.weightDeclared, "4000.0000".Decimal, "After first unpack, Weight Declared should be 4000.0000");
	assertEqualMsg(ti1.weightCargo, "2100.0000".Decimal, "After first unpack, Cargo Weight should be 2100.0000");
	assertEqualMsg(ti1.totalWeight, "4100.0000".Decimal, "After first unpack, Total Weight should be 4100.0000");
	
	//mobileAgent.doUnPack( form, ti1, childTi2, newLocation );
	mobileAgent.doUnpackCargo(childTi2,newLocation,0,childTi2.totalWeight,null);
	
	self.assertNoTrxErrorsOrWarnings();
	assertEqualMsg(ti1.getTareWeight, "2000.0000".Decimal, "After second unpack, Tare Weight should be 2000.0000");
	assertEqualMsg(ti1.weightDeclared, "0.0000".Decimal, "After second unpack, Weight Declared should be 0.0000");
	assertEqualMsg(ti1.weightCargo, "0.0000".Decimal, "After second unpack, Cargo Weight should be 0.0000");
	assertEqualMsg(ti1.totalWeight, "2000.0000".Decimal, "After second unpack, Total Weight should be 2000.0000");
	
	//pack the children back into the container. make sure the weights are corrctly incremented.
	
	skipQuestion := true;
	mobileAgent.doPackCargo( ti1, childTi1, skipQuestion );
	
	self.assertNoTrxErrorsOrWarnings();
	assertEqualMsg(ti1.getTareWeight, "2000.0000".Decimal, "After first pack, Tare Weight should be 2000.0000");
	assertEqualMsg(ti1.weightDeclared, "0.0000".Decimal, "After first pack, Weight Declared should be 0.0000");
	assertEqualMsg(ti1.weightCargo, "1800.0000".Decimal, "After first pack, Cargo Weight should be 1800.0000");
	assertEqualMsg(ti1.totalWeight, "3800.0000".Decimal, "After first pack, Total Weight should be 3800.0000");
	
	mobileAgent.doPackCargo( ti1, childTi2, skipQuestion );
	
	self.assertNoTrxErrorsOrWarnings();
	assertEqualMsg(ti1.getTareWeight, "2000.0000".Decimal, "After first pack, Tare Weight should be 2000.0000");
	assertEqualMsg(ti1.weightDeclared, "0.0000".Decimal, "After first pack, Weight Declared should be 0.0000");
	assertEqualMsg(ti1.weightCargo, "3900.0000".Decimal, "After first pack, Cargo Weight should be 3900.0000");
	assertEqualMsg(ti1.totalWeight, "5900.0000".Decimal, "After first pack, Total Weight should be 5900.0000");
	

epilog

	if attachments &lt;&gt; null and not attachments.isEmpty then
		attachments.purge();
	endif;
	delete attachments;
	delete pxyTI;
	//delete transClass;
	delete mobileAgent;

end;</source>
    </JadeMethod>
    <JadeMethod name="tPackingCoiltainers" id="621bb605-5840-4619-b7b1-9862e1203bc5">
        <source>tPackingCoiltainers();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2015	cnwndl1	Initial creation	Par 36111 - Coiltainers and coils are both packed into a container.
											The Coils actually sit on the coiltainer, but are not associated with them.
											Stripping the coiltainers from the contaimer should mark them as Storage and remove the voyage details from them
											Stuffing the Coiltainers should mark them with the voyage details from the Coil/Container and as export.
											Shouldn't matter what oreder the children asre stuffed, i.e. coiltainers first or coils first.
// 10 Sep 2019	cnwrs1	TFS 46030
09 Jan 2024	navma1 Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

constants

	Booking1		: String = "PackBook1";
	BlockStack1		: String = "COIL1";
	Container1		: String = "COIL000001";
	Container2		: String = "COIL000002";
	Coils1			: String = "COILS01";
	Coils2			: String = "COILS02";
	Coils3			: String = "COILS03";
	Coils4			: String = "COILS04";
	Coiltainer1		: String = "COILT01";
	Coiltainer2		: String = "COILT02";
	Coiltainer3		: String = "COILT03";
	Coiltainer4		: String = "COILT04";
	
vars
	booking1 : CM_BookingRef;
	bs1 : CM_BlockStack;
	ti1 : CM_Container;
	ti2 : CM_Container;
	coiltainerCargoType : CM_CargoType;
	coilsCargoType : CM_CargoType;
	voyage1 : CM_Voyage;
	vessel : CM_Vessel; 
	coils1 : CM_TrackedItem;
	coils2 : CM_TrackedItem;
	coils3 : CM_TrackedItem;
	coils4 : CM_TrackedItem;
	coiltainer1 : CM_TrackedItem;
	coiltainer2 : CM_TrackedItem;
	coiltainer3 : CM_TrackedItem;
	coiltainer4 : CM_TrackedItem;
	dischargePort : CM_Port;
	destinationPort : CM_Port;
	
	setParentFromChild : Boolean;
	nullVoyage : CM_Voyage;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	//Mark Coiltainer cargo type as "chgToStorageOnUnpack" 
	//Create some onsite coils, and some onsite coiltainers
	//Create some storage containers onsite
	//create a voyage.
	
	
	
	//cleanup old data
	self.deleteBooking(Booking1);
	self.deleteContainer(Container1);
	self.deleteContainer(Container2);
	self.deleteCargo(Coils1,"COILS");
	self.deleteCargo(Coils2,"COILS");
	self.deleteCargo(Coils3,"COILS");
	self.deleteCargo(Coils4,"COILS");
	self.deleteCargo(Coiltainer1,"COILT");
	self.deleteCargo(Coiltainer2,"COILT");
	self.deleteCargo(Coiltainer3,"COILT");
	self.deleteCargo(Coiltainer4,"COILT");
	self.deleteTerminalArea(BlockStack1);
	self.deleteVoyage("UTVOY1");
	self.deleteVessel("UTBOAT");
	
	nullVoyage := self.getTerminal().getNullVoyage;
	
	coiltainerCargoType := self.getCargoType("COILT");
	self.assertTrueMsg( coiltainerCargoType &lt;&gt; null, "Cargo type of 'COILT' not found.");
	self.assertTrueMsg( coiltainerCargoType.chgToStorageOnUnpack, "Cargo type of 'COILT' not marked as '" &amp; ETRow_ChgToStorageOnUnpack &amp; "'.");
	
	coilsCargoType := self.getCargoType("COILS");
	self.assertTrueMsg( coilsCargoType &lt;&gt; null, "Cargo type of 'COILS' not found.");
	self.assertTrueMsg( not coilsCargoType.chgToStorageOnUnpack, "Cargo type of 'COILS' SHOULD NOT be marked as '" &amp; ETRow_ChgToStorageOnUnpack &amp; "'.");
	
	bs1 := addBlockStack(BlockStack1, 10, null);
	self.assertTrueMsg(bs1 &lt;&gt; null, "Failed to create Block Stack " &amp; BlockStack1 );
	
	ti1 := self.addContainerAtLocation(Container1,null,"2200","MT",TI_IMEX_STATUS_STORAGE,bs1);
	self.assertTrueMsg(ti1 &lt;&gt; null, "Failed to create MT container " &amp; Container1 );
	
	ti2 := self.addContainerAtLocation(Container2,null,"2200","MT",TI_IMEX_STATUS_STORAGE,bs1);
	self.assertTrueMsg(ti2 &lt;&gt; null, "Failed to create MT container " &amp; Container2 );
	
	vessel := addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage1 := addVoyageWithContainerStructur("UTVOY1", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	dischargePort := voyage1.allPorts.first;
	destinationPort := voyage1.allPorts.last;

	booking1 := self.addBookingForGeneralCargo(Booking1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),
						voyage1, dischargePort.code, coilsCargoType.id, 10);
	
	beginTransaction;
	booking1.setPropertyValue("packAs", BOOKING_PACKAS_FCL);
	commitTransaction;	
	
	self.opts.purge();
	self.opts.addAssoc( UTTI_VoyageCode, voyage1.code );
	self.opts.addAssoc( UTTI_DestinationPort, destinationPort.code );
	self.opts.addAssoc( UTTI_DischargePort, dischargePort.code );
	//self.opts.addAssoc( UTTI_BookingRef, "PackBook1" );
	self.opts.addAssoc("BookingItem", booking1.allBookingRefItems.first);
	
	coils1 := self.addCargoOpts(Coils1, "", "", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), coilsCargoType.id);
	self.assertTrueMsg(coils1 &lt;&gt; null, "Failed to create coils " &amp; Coils1 );
	self.move(coils1,bs1);
	coils2 := self.addCargoOpts(Coils2, "", "", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), coilsCargoType.id);
	self.assertTrueMsg(coils2 &lt;&gt; null, "Failed to create coils " &amp; Coils2 );
	self.move(coils2,bs1);
	coils3 := self.addCargoOpts(Coils3, "", "", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), coilsCargoType.id);
	self.assertTrueMsg(coils3 &lt;&gt; null, "Failed to create coils " &amp; Coils3 );
	self.move(coils3,bs1);
	coils4 := self.addCargoOpts(Coils4, "", "", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), coilsCargoType.id);
	self.assertTrueMsg(coils4 &lt;&gt; null, "Failed to create coils " &amp; Coils4 );
	self.move(coils4,bs1);
	
	self.assertEqual(booking1.allTIs.size, 4);
	
	self.opts.purge();
	self.opts.addAssoc( "IMEXStatus", TI_IMEX_STATUS_STORAGE );
	
	coiltainer1 := self.addCargoOpts(Coiltainer1, "", "", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), coiltainerCargoType.id);
	self.assertTrueMsg(coiltainer1 &lt;&gt; null, "Failed to create coiltainer " &amp; Coiltainer1 );
	self.updateTI(coiltainer1);
	self.move(coiltainer1,bs1);
	coiltainer2 := self.addCargoOpts(Coiltainer2, "", "", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), coiltainerCargoType.id);
	self.assertTrueMsg(coiltainer1 &lt;&gt; null, "Failed to create coiltainer " &amp; Coiltainer2 );
	self.updateTI(coiltainer2);
	self.move(coiltainer2,bs1);
	coiltainer3 := self.addCargoOpts(Coiltainer3, "", "", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), coiltainerCargoType.id);
	self.assertTrueMsg(coiltainer1 &lt;&gt; null, "Failed to create coiltainer " &amp; Coiltainer3 );
	self.updateTI(coiltainer3);
	self.move(coiltainer3,bs1);
	coiltainer4 := self.addCargoOpts(Coiltainer4, "", "", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), coiltainerCargoType.id);
	self.assertTrueMsg(coiltainer1 &lt;&gt; null, "Failed to create coiltainer " &amp; Coiltainer4 );
	self.updateTI(coiltainer4);
	self.move(coiltainer4,bs1);
	
	//pack coil1 into container1 - check that Voyage Discharge Port and Destination of the container have been set to match coil1.
	setParentFromChild := ti1.allChildren.isEmptyOrContainsOnlyEquipment and ti1.isStorage;
	app.myTrxUA.trxUpdatePackCargo(ti1, coils1, 1, 0, setParentFromChild, null, null,false,null, app.myPassport);	//19.03.2024 navhl20 #62863

	self.assertTrueMsg(ti1.myVoyage = voyage1, "Parent Container " &amp; ti1.id &amp; " voyage NOT updated. Test 1" );
	self.assertTrueMsg(ti1.dischargePort = dischargePort.code, "Parent Container " &amp; ti1.id &amp; " dischargePort NOT updated. Test 3" );
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_EXPORT, "Parent Container " &amp; ti1.id &amp; " imex NOT updated. Test 4" );

	self.assertEqualMsg(booking1.allTIs.size, 5, "Container has not been linked to booking. Test 4a");
	
	//pack coil2 into container1 - check that Voyage Discharge Port and Destination of the container still match coil2.
	setParentFromChild := ti1.allChildren.isEmptyOrContainsOnlyEquipment and ti1.isStorage;
	app.myTrxUA.trxUpdatePackCargo(ti1, coils2, 1, 0, setParentFromChild,null, null,false,null,  app.myPassport);	//19.03.2024 navhl20 #62863
	
	self.assertTrueMsg(ti1.myVoyage = voyage1, "Parent Container " &amp; ti1.id &amp; " voyage updated. Test 5" );
	self.assertTrueMsg(ti1.dischargePort = dischargePort.code, "Parent Container " &amp; ti1.id &amp; " dischargePort updated. Test 7" );
	
	//pack coiltainer1 into container1 - check that Voyage Discharge Port and Destination of the coiltainer have been updated to match coil1.
	setParentFromChild := ti1.allChildren.isEmptyOrContainsOnlyEquipment and ti1.isStorage;
	app.myTrxUA.trxUpdatePackCargo(ti1, coiltainer1, 1, 0, setParentFromChild,null, null,false,null,  app.myPassport);	//19.03.2024 navhl20 #62863
	
	self.assertTrueMsg(coiltainer1.myVoyage = voyage1, "Coiltainer " &amp; coiltainer1.id &amp; " voyage NOT updated. Test 8" );
	self.assertTrueMsg(coiltainer1.destinationPort = destinationPort.code, "Coiltainer " &amp; coiltainer1.id &amp; " destinationPort NOT updated. Test 9" );
	self.assertTrueMsg(coiltainer1.dischargePort = dischargePort.code, "Coiltainer " &amp; coiltainer1.id &amp; " dischargePort NOT updated. Test 10" );
	self.assertTrueMsg(coiltainer1.getImExStatus = TI_IMEX_STATUS_EXPORT, "Coiltainer " &amp; coiltainer1.id &amp; " imex NOT updated. Test 11" );

	self.assertTrueMsg(coiltainer1.bookingReference = null, "Coiltainer " &amp; coiltainer1.id &amp; " booking should NOT be updated to match coils. Test 12" );
	self.assertEqualMsg(booking1.allTIs.size, 5, "Coiltainer has been incorrectly linked to booking. Test 12a");
	
	//pack coiltainer2 into container1 - check that Voyage Discharge Port and Destination of the coiltainer have been set to match the container.
	setParentFromChild := ti1.allChildren.isEmptyOrContainsOnlyEquipment and ti1.isStorage;
	app.myTrxUA.trxUpdatePackCargo(ti1, coiltainer2, 1, 0, setParentFromChild, null, null,false,null, app.myPassport);	//19.03.2024 navhl20 #62863
	
	self.assertTrueMsg(coiltainer2.myVoyage = voyage1, "Coiltainer " &amp; coiltainer2.id &amp; " voyage NOT updated. Test 13" );
	self.assertTrueMsg(coiltainer2.destinationPort = destinationPort.code, "Coiltainer " &amp; coiltainer2.id &amp; " destinationPort NOT updated. Test 14" );
	self.assertTrueMsg(coiltainer2.dischargePort = dischargePort.code, "Coiltainer " &amp; coiltainer2.id &amp; " dischargePort NOT updated. Test 15" );
	self.assertTrueMsg(coiltainer2.getImExStatus = TI_IMEX_STATUS_EXPORT, "Coiltainer " &amp; coiltainer2.id &amp; " imex NOT updated. Test 16" );
	self.assertTrueMsg(coiltainer2.bookingReference = null, "Coiltainer " &amp; coiltainer2.id &amp; " booking should NOT be updated to match coils. Test 17" );
	
	
	//Now repeat but in the opposite order, i.e. pack the coiltainers first, the update has to happen later in
	//the process when the first coil is packed, but it should still update the same details when the first real coil goes in.
	
	//pack coiltainer3 into container2 - check that nothing gets updated except the coiltainers imex..
	setParentFromChild := ti2.allChildren.isEmptyOrContainsOnlyEquipment and ti2.isStorage;
	app.myTrxUA.trxUpdatePackCargo(ti2, coiltainer3, 1, 0, setParentFromChild, null, null,false,null, app.myPassport);	//19.03.2024 navhl20 #62863
	
	self.assertTrueMsg(ti2.myVoyage = nullVoyage, "Container " &amp; ti2.id &amp; " voyage should NOT have been updated. Test 18" );
	self.assertTrueMsg(coiltainer3.myVoyage = nullVoyage, "Coiltainer " &amp; coiltainer3.id &amp; " voyage should NOT have been updated. Test 19" );
	self.assertTrueMsg(ti2.destinationPort = null, "Container " &amp; ti2.id &amp; " destinationPort should NOT have been updated. Test 20" );
	self.assertTrueMsg(coiltainer3.destinationPort = null, "Coiltainer " &amp; coiltainer3.id &amp; " destinationPort should NOT have been updated. Test 21" );
	self.assertTrueMsg(ti2.dischargePort = null, "Container " &amp; ti2.id &amp; " dischargePort should NOT have been updated. Test 22" );
	self.assertTrueMsg(coiltainer3.dischargePort = null, "Coiltainer " &amp; coiltainer3.id &amp; " dischargePort should NOT have been updated. Test 23" );
	self.assertTrueMsg(ti2.getImExStatus = TI_IMEX_STATUS_STORAGE, "Container " &amp; ti2.id &amp; " imex should NOT have been updated. Test 24" );
	self.assertTrueMsg(coiltainer3.getImExStatus = TI_IMEX_STATUS_EXPORT, "Coiltainer " &amp; coiltainer3.id &amp; " imex should have been updated. Test 25" );
	self.assertTrueMsg(ti2.bookingReference = null, "Container " &amp; ti2.id &amp; " booking should NOT have been updated. Test 26" );
	self.assertTrueMsg(coiltainer3.bookingReference = null, "Coiltainer " &amp; coiltainer3.id &amp; " booking should NOT have been updated. Test 27" );
	
	//pack coiltainer4 into container2 -  check that nothing gets updated except the coiltainers imex..
	setParentFromChild := ti2.allChildren.isEmptyOrContainsOnlyEquipment and ti2.isStorage;
	app.myTrxUA.trxUpdatePackCargo(ti2, coiltainer4, 1, 0, setParentFromChild, null, null,false,null, app.myPassport);	//19.03.2024 navhl20 #62863
	
	self.assertTrueMsg(ti2.myVoyage = nullVoyage, "Container " &amp; ti2.id &amp; " voyage should NOT have been updated. Test 28" );
	self.assertTrueMsg(coiltainer4.myVoyage = nullVoyage, "Coiltainer " &amp; coiltainer4.id &amp; " voyage should NOT have been updated. Test 29" );
	self.assertTrueMsg(ti2.destinationPort = null, "Container " &amp; ti2.id &amp; " destinationPort should NOT have been updated. Test 30" );
	self.assertTrueMsg(coiltainer4.destinationPort = null, "Coiltainer " &amp; coiltainer4.id &amp; " destinationPort should NOT have been updated. Test 31" );
	self.assertTrueMsg(ti2.dischargePort = null, "Container " &amp; ti2.id &amp; " dischargePort should NOT have been updated. Test 32" );
	self.assertTrueMsg(coiltainer4.dischargePort = null, "Coiltainer " &amp; coiltainer4.id &amp; " dischargePort should NOT have been updated. Test 33" );
	self.assertTrueMsg(ti2.getImExStatus = TI_IMEX_STATUS_STORAGE, "Container " &amp; ti2.id &amp; " imex should NOT have been updated. Test 34" );
	self.assertTrueMsg(coiltainer4.getImExStatus = TI_IMEX_STATUS_EXPORT, "Coiltainer " &amp; coiltainer4.id &amp; " imex should have been updated. Test 35" );
	self.assertTrueMsg(ti2.bookingReference = null, "Container " &amp; ti2.id &amp; " booking should NOT have been updated. Test 36" );
	self.assertTrueMsg(coiltainer4.bookingReference = null, "Coiltainer " &amp; coiltainer4.id &amp; " booking should NOT have been updated. Test 37" );
	
	//pack coil3 into container2 - NOW check that Voyage Discharge Port and Destination of the coiltainer have been updated to match the container.
	setParentFromChild := ti2.allChildren.isEmptyOrContainsOnlyEquipment and ti2.isStorage;
	app.myTrxUA.trxUpdatePackCargo(ti2, coils3, 1, 0, setParentFromChild,null, null, false,null,app.myPassport);	//19.03.2024 navhl20 #62863
	
	self.assertTrueMsg(ti2.myVoyage = voyage1, "Parent Container " &amp; ti2.id &amp; " voyage NOT updated. Test 38" );
	self.assertTrueMsg(ti2.dischargePort = dischargePort.code, "Parent Container " &amp; ti2.id &amp; " dischargePort NOT updated. Test 40" );
	self.assertTrueMsg(ti2.getImExStatus = TI_IMEX_STATUS_EXPORT, "Parent Container " &amp; ti2.id &amp; " imex NOT updated. Test 41" );
	
	self.assertTrueMsg(coiltainer3.myVoyage = voyage1, "Coiltainer " &amp; coiltainer3.id &amp; " voyage NOT updated. Test 42" );
	self.assertTrueMsg(coiltainer3.destinationPort = destinationPort.code, "Coiltainer " &amp; coiltainer3.id &amp; " destinationPort NOT updated. Test 43" );
	self.assertTrueMsg(coiltainer3.dischargePort = dischargePort.code, "Coiltainer " &amp; coiltainer3.id &amp; " dischargePort NOT updated. Test 44" );
	self.assertTrueMsg(coiltainer3.bookingReference = null, "Coiltainer " &amp; coiltainer3.id &amp; " booking should NOT be updated to match coils. Test 45" );
	
	self.assertTrueMsg(coiltainer4.myVoyage = voyage1, "Coiltainer " &amp; coiltainer4.id &amp; " voyage NOT updated. Test 46" );
	self.assertTrueMsg(coiltainer4.destinationPort = destinationPort.code, "Coiltainer " &amp; coiltainer4.id &amp; " destinationPort NOT updated. Test 47" );
	self.assertTrueMsg(coiltainer4.dischargePort = dischargePort.code, "Coiltainer " &amp; coiltainer4.id &amp; " dischargePort NOT updated. Test 48" );
	self.assertTrueMsg(coiltainer4.bookingReference = null, "Coiltainer " &amp; coiltainer4.id &amp; " booking should NOT be updated to match coils. Test 49" );
	
	// Now test the unpacking.
	
	
	

	//Try unloading coiltainers first
	//app.myTrxUA.trxUpdateUnpackCargo(coiltainer1, bs1.myLocationsController, 1, 0,false, app.myPassport);  //09.01.2023 navma1 #60947		//14.03.2024 navhl20 #62861
	//app.myTrxUA.trxUpdateUnpackCargo(coiltainer2, bs1.myLocationsController, 1, 0,false, app.myPassport);  //09.01.2023 navma1 #60947		//14.03.2024 navhl20 #62861
	//app.myTrxUA.trxUpdateUnpackCargo(coils1, 	  bs1.myLocationsController, 1, 0,false, app.myPassport);  //09.01.2023 navma1 #60947		//14.03.2024 navhl20 #62861
	//app.myTrxUA.trxUpdateUnpackCargo(coils2, 	  bs1.myLocationsController, 1, 0,false, app.myPassport);  //09.01.2023 navma1 #60947		//14.03.2024 navhl20 #62861
	app.myTrxUA.trxUpdateUnpackCargo(coiltainer1, bs1.myLocationsController, 1, 0,false,null, app.myPassport);  //14.03.2024 navhl20 #62861
	app.myTrxUA.trxUpdateUnpackCargo(coiltainer2, bs1.myLocationsController, 1, 0,false,null, app.myPassport);  //14.03.2024 navhl20 #62861
	app.myTrxUA.trxUpdateUnpackCargo(coils1, 	  bs1.myLocationsController, 1, 0,false,null, app.myPassport);  //14.03.2024 navhl20 #62861
	app.myTrxUA.trxUpdateUnpackCargo(coils2, 	  bs1.myLocationsController, 1, 0,false,null, app.myPassport);  //14.03.2024 navhl20 #62861
	
	
	self.assertTrueMsg(coiltainer1.myVoyage = nullVoyage, "Coiltainer " &amp; coiltainer1.id &amp; " voyage NOT set to null. Test 50" );
	self.assertTrueMsg(coiltainer1.destinationPort = null, "Coiltainer " &amp; coiltainer1.id &amp; " destinationPort NOT set to null. Test 51" );
	self.assertTrueMsg(coiltainer1.dischargePort = null, "Coiltainer " &amp; coiltainer1.id &amp; " dischargePort NOT set to null. Test 52" );
	
	self.assertTrueMsg(coiltainer2.myVoyage = nullVoyage, "Coiltainer " &amp; coiltainer2.id &amp; " voyage NOT set to null. Test 53" );
	self.assertTrueMsg(coiltainer2.destinationPort = null, "Coiltainer " &amp; coiltainer2.id &amp; " destinationPort NOT set to null. Test 54" );
	self.assertTrueMsg(coiltainer2.dischargePort = null, "Coiltainer " &amp; coiltainer2.id &amp; " dischargePort NOT set to null. Test 55" );
	
	self.assertTrueMsg(coils1.myVoyage = voyage1, "Coil " &amp; coils1.id &amp; " voyage should NOT have changed. Test 56" );
	self.assertTrueMsg(coils1.destinationPort = destinationPort.code, "Coil " &amp; coils1.id &amp; " destinationPort should NOT have changed. Test 57" );
	self.assertTrueMsg(coils1.dischargePort = dischargePort.code, "Coil " &amp; coils1.id &amp; " dischargePort should NOT have changed. Test 58" );
	
	
	self.assertTrueMsg(coils2.myVoyage = voyage1, "Coil " &amp; coils2.id &amp; " voyage should NOT have changed. Test 59" );
	self.assertTrueMsg(coils2.destinationPort = destinationPort.code, "Coil " &amp; coils2.id &amp; " destinationPort should NOT have changed. Test 60" );
	self.assertTrueMsg(coils2.dischargePort = dischargePort.code, "Coil " &amp; coils2.id &amp; " dischargePort should NOT have changed. Test 61" );
	
	//And in this one try unloading coils first.
	//app.myTrxUA.trxUpdateUnpackCargo(coils3,	  bs1.myLocationsController, 1, 0,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
	//app.myTrxUA.trxUpdateUnpackCargo(coils4, 	  bs1.myLocationsController, 1, 0,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
	//app.myTrxUA.trxUpdateUnpackCargo(coiltainer3, bs1.myLocationsController, 1, 0,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
	//app.myTrxUA.trxUpdateUnpackCargo(coiltainer4, bs1.myLocationsController, 1, 0,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
	app.myTrxUA.trxUpdateUnpackCargo(coils3,	  bs1.myLocationsController, 1, 0,false,null, app.myPassport);  //14.03.2024 navhl20 #62861
	app.myTrxUA.trxUpdateUnpackCargo(coils4, 	  bs1.myLocationsController, 1, 0,false,null, app.myPassport);  //14.03.2024 navhl20 #62861
	app.myTrxUA.trxUpdateUnpackCargo(coiltainer3, bs1.myLocationsController, 1, 0,false,null, app.myPassport);  //14.03.2024 navhl20 #62861
	app.myTrxUA.trxUpdateUnpackCargo(coiltainer4, bs1.myLocationsController, 1, 0,false,null, app.myPassport);  //14.03.2024 navhl20 #62861
	
	self.assertTrueMsg(coiltainer3.myVoyage = nullVoyage, "Coiltainer " &amp; coiltainer3.id &amp; " voyage NOT set to null. Test 61" );
	self.assertTrueMsg(coiltainer3.destinationPort = null, "Coiltainer " &amp; coiltainer3.id &amp; " destinationPort NOT set to null. Test 62" );
	self.assertTrueMsg(coiltainer3.dischargePort = null, "Coiltainer " &amp; coiltainer3.id &amp; " dischargePort NOT set to null. Test 63" );
	
	self.assertTrueMsg(coiltainer4.myVoyage = nullVoyage, "Coiltainer " &amp; coiltainer4.id &amp; " voyage NOT set to null. Test 64" );
	self.assertTrueMsg(coiltainer4.destinationPort = null, "Coiltainer " &amp; coiltainer4.id &amp; " destinationPort NOT set to null. Test 65" );
	self.assertTrueMsg(coiltainer4.dischargePort = null, "Coiltainer " &amp; coiltainer4.id &amp; " dischargePort NOT set to null. Test 66" );
	
	self.assertTrueMsg(coils3.myVoyage = voyage1, "Coil " &amp; coils3.id &amp; " voyage should NOT have changed. Test 67" );
	self.assertTrueMsg(coils3.destinationPort = destinationPort.code, "Coil " &amp; coils3.id &amp; " destinationPort should NOT have changed. Test 68" );
	self.assertTrueMsg(coils3.dischargePort = dischargePort.code, "Coil " &amp; coils3.id &amp; " dischargePort should NOT have changed. Test 69" );
	
	self.assertTrueMsg(coils4.myVoyage = voyage1, "Coil " &amp; coils4.id &amp; " voyage should NOT have changed. Test 70" );
	self.assertTrueMsg(coils4.destinationPort = destinationPort.code, "Coil " &amp; coils4.id &amp; " destinationPort should NOT have changed. Test 71" );
	self.assertTrueMsg(coils4.dischargePort = dischargePort.code, "Coil " &amp; coils4.id &amp; " dischargePort should NOT have changed. Test 72" );
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.deleteContainer(Container1);
	self.deleteContainer(Container2);
	self.deleteCargo(Coils1,"COILS");
	self.deleteCargo(Coils2,"COILS");
	self.deleteCargo(Coils3,"COILS");
	self.deleteCargo(Coils4,"COILS");
	self.deleteCargo(Coiltainer1,"COILT");
	self.deleteCargo(Coiltainer2,"COILT");
	self.deleteCargo(Coiltainer3,"COILT");
	self.deleteCargo(Coiltainer4,"COILT");
	self.deleteTerminalArea(BlockStack1);
	self.deleteVoyage("UTVOY1");
	self.deleteVessel("UTBOAT");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tStwPackAndRelease" id="f2f7c3df-c7ae-42f3-8cfe-81b7cee86b05">
        <source>tStwPackAndRelease();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2015	cnwndl1	Initial creation	Par 37288
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// 08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

constants

	BSId : String = "UTCG3";
	ICId : String = "UTIC3";
	ContId1 : String = "UTCG6602201";
	ContId2 : String = "UTCG6602202";
	DriverId : String = "UTDRIVER";
	TruckId : String = "UTCGTruk";
	Cargo_TypeW : String = "UTBYW";
	Cargo_TypeV : String = "UTBYV";
	Cargo_TypeQ : String = "UTBYQ";
	Cargo_GroupId1 : String = "UTCGV";
	Cargo_GroupId2 : String = "UTCGW";
	Cargo_GroupId3 : String = "UTCGQ";
	Cargo_Id1 : String = "UTCV";
	Cargo_Id2 : String = "UTCW";
	Cargo_Id3 : String = "UTCQ";
	ReleaseID : String = "UTPACKREL01234567890123456";
	RFIDTagId : String = "UTPQ1";
	RFIDSerial : String = "UTPQ01";
	TruckRego : String = "UTWSAUTO3";
	
vars

	now : TimeStamp;
	term : CM_Terminal;
	oper : CM_Operator;
	dualGate : CM_Gate;
	bs1 : CM_BlockStack;
	yic1 : CM_YardInterchangeArea; 
	cg1 : CM_CargoGroup;
	cg2 : CM_CargoGroup;
	cg3 : CM_CargoGroup;
	ctw : CM_CargoType;
	ctv : CM_CargoType;
	ctq : CM_CargoType;
	contCargoType : CM_CargoType;
	cargoW : CM_Cargo;
	cargoV : CM_Cargo;
	cargoQ : CM_Cargo;
	selectedTerminalAreas : CM_TerminalAreaSet;
	allCargoToAssign : CM_TISet;
	packRequest : CM_BulkRelease;
	roadRequest : CM_BulkRelease;
	carrier : CM_Carrier;
	carrierCode : String;
	cont1 : CM_TrackedItem;
	cont2 : CM_TrackedItem;
	pinNumber : String;
	allPins : StringArray;
	driverCode : String;
	gateName : String;
	batNumber : String;
	extraDetail : String;
	expectedError : Integer;
	truckRego :String;
	truckState : String;
	vehicle :CM_Vehicle;
	rfidTag : CM_RFIDTag;
	moveController : CMIF_MoveController;
	reserveDetail1 : CM_ReserveDetail;
	reserveDetail2 : CM_ReserveDetail;
	reserveDetail3 : CM_ReserveDetail;
	parentReserveDetail : CM_ReserveDetail;
	handHeldCheckerAgent : CM_Transient;
	allReleaseTIs : CM_TISet;
	roadReserveDetail : CM_ReserveDetail;
	vvr : CM_VehicleVisitRecord;
	wle :CM_WorkListEntry;
	mobileGenericAgent : CMIF_MobileGenericAgent;
	oldSetting2 : Boolean;
	

begin

	oldSetting2 := self.setTerminalConfig(AllowPINwithoutVGM,true).Boolean;

	create allPins transient;
	now := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	term := self.getTerminal;
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	ctw := app.myRoot.getCargoTypeFromAbbrev(Cargo_TypeW);
	ctv := app.myRoot.getCargoTypeFromAbbrev(Cargo_TypeV);
	ctq := app.myRoot.getCargoTypeFromAbbrev(Cargo_TypeQ);
	contCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertTrueMsg( contCargoType &lt;&gt; null, "Failed to find Container Cargo Type in set up");
	carrier := app.myRoot.allCarriers[self.getProfileSetting(UT_Profile.P_CARRIER).asString].CM_Carrier;
	self.assertTrueMsg( carrier &lt;&gt; null, "Failed to find Carrier in set up");
	truckRego := TruckRego;
	rfidTag := self.addRFIDTag(RFIDTagId, RFIDSerial);
	self.assertNotNull(rfidTag);
	
	self.assertTrueMsg(term &lt;&gt; null,"Terminal not found - setup phase : (test 1)" );
	self.assertTrueMsg(oper &lt;&gt; null,"Opertaor not found - setup phase : (test 2)" );
	self.assertTrueMsg(dualGate &lt;&gt; null,"Gate not found - setup phase : (test 3)" );
	self.assertTrueMsg(ctw &lt;&gt; null,"Cargo Type by Weight not found - setup phase : (test 4)" );
	self.assertTrueMsg(ctv &lt;&gt; null,"Cargo Type by Volume not found - setup phase : (test 5)" );
	self.assertTrueMsg(ctq &lt;&gt; null,"Cargo Type by Quantity not found - setup phase : (test 6)" );

// 1/. Clean up old data

	self.deleteReleaseRequest(ReleaseID);
	app.isGarbageCollectionProcess := true;
	self.deleteContainer(ContId1);
	self.deleteContainer(ContId2);
	app.isGarbageCollectionProcess := false;
	self.deleteCargoGroup(Cargo_GroupId1);
	self.deleteCargoGroup(Cargo_GroupId2);
	self.deleteCargoGroup(Cargo_GroupId3);
	self.deleteVehicle(TruckRego);
	self.deleteTerminalArea(BSId);
	self.deleteTerminalArea(ICId);
	self.deleteVehicle(TruckId);
	
	
	bs1 := self.addBlockStack(BSId,200,null);
	self.assertTrueMsg(bs1 &lt;&gt; null,"Block Stack " &amp; BSId &amp; " not created - setup phase : (test 7)" );
	
	create selectedTerminalAreas transient;
	selectedTerminalAreas.add(bs1);
	yic1 := self.addInterchangeArea(ICId,selectedTerminalAreas);
	self.assertTrueMsg(bs1 &lt;&gt; null,"Interchange area " &amp; ICId &amp; " not created - setup phase : (test 8)" );

// 2/. Add 3 cargo groups one each for Cargo By Weight, Cargo by volume and cargo by quantity.  And add cargo to each.
	create allCargoToAssign transient;
	cargoV := self.addCargoAtLocation(Cargo_Id1, ctv, oper, bs1.myLocationsController).CM_Cargo;
	self.assertTrueMsg( cargoV &lt;&gt; null, Cargo_Id1 &amp; " not created - setup phase : (test 9) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	beginTransaction;
	cargoV.setMyTotalVolume(50000);
	cargoV.setTotalWeightWithoutTrans(50000);
	commitTransaction;
	allCargoToAssign.add(cargoV);
	
	cg1 := self.addCargoGroup( Cargo_GroupId1, allCargoToAssign );
	self.assertTrueMsg(cg1 &lt;&gt; null, Cargo_GroupId1 &amp; " Cargo Group not created - setup phase : (test 10) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	allCargoToAssign.clear();
	cargoW := self.addCargoAtLocation(Cargo_Id2, ctw, oper, bs1.myLocationsController).CM_Cargo;
	self.assertTrueMsg( cargoW &lt;&gt; null, Cargo_Id2 &amp; " not created - setup phase : (test 11) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	beginTransaction;
	cargoW.setTotalWeightWithoutTrans(50000);
	commitTransaction;
	allCargoToAssign.add(cargoW);
	
	cg2 := self.addCargoGroup( Cargo_GroupId2, allCargoToAssign );
	self.assertTrueMsg(cg2 &lt;&gt; null, Cargo_GroupId2 &amp; " Cargo Group not created - setup phase : (test 12) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	allCargoToAssign.clear();
	cargoQ := self.addCargoAtLocation(Cargo_Id3, ctq, oper, bs1.myLocationsController).CM_Cargo;
	self.assertTrueMsg( cargoQ &lt;&gt; null, Cargo_Id3 &amp; " not created - setup phase : (test 13) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	beginTransaction;
	cargoQ.setTotalQuantity(50);
	cargoQ.setTotalWeightWithoutTrans(50000);
	commitTransaction;
	allCargoToAssign.add(cargoQ);
	
	cg3 := self.addCargoGroup( Cargo_GroupId3, allCargoToAssign );
	self.assertTrueMsg(cg2 &lt;&gt; null, Cargo_GroupId3 &amp; " Cargo Group not created - setup phase : (test 14) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
// 3/. Create an active pack request, with a parent (total requested = 2) and 3 child reserve details all by type. ( extra criteria include a cargo group ) Ultimately this step should be by EDI
// 4/. Create a road release by type for a container, with the same id as the packing release request.
	
	self.doSTWCreatePackingAndRoadRels(	true,	//useEDI : Boolean;  	
									oper,	//oper : CM_Operator io;
									packRequest,	//packRequest : CM_BulkRelease io;
									ReleaseID,	//releaseID : String
									Cargo_GroupId1,	//cargo_GroupId1 : String;
									ctv,	//ctv : CM_CargoType;
									reserveDetail1,	//reserveDetail1 : CM_ReserveDetail io;
									Cargo_GroupId2,	//cargo_GroupId2 : String;
									reserveDetail2,	//reserveDetail2 : CM_ReserveDetail io;
									ctw,	//ctw : CM_CargoType;
									Cargo_GroupId3,	//cargo_GroupId3 : String;
									reserveDetail3,	//reserveDetail3 : CM_ReserveDetail io;
									ctq,	//reserveDetail3 : CM_CargoType;
									roadRequest	//roadRequest : CM_BulkRelease io
									);

// 5/. Gate in a truck with two empty container suitable to use as the Parent on the Packing request. Assign the container to the packing request parent, and to the road release request.

	self.opts.purge();
	self.opts.addAssoc('transMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('carrier', carrier.code);
	self.opts.addAssoc('pin', true);
	cont1 := self.uAddPrenote(ContId1, "2200", oper, contCargoType);
	self.assertTrueMsg( cont1 &lt;&gt; null, "Failed to create Pre Note setup phase : (test 20) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	pinNumber := cont1.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Pre Note in setup phase : (test 21) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	allPins.add( pinNumber );
	
	self.opts.purge();
	self.opts.addAssoc('transMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('carrier', carrier.code);
	self.opts.addAssoc('pin', true);
	cont2 := self.uAddPrenote(ContId2, "2200", oper, contCargoType);
	self.assertTrueMsg( cont2 &lt;&gt; null, "Failed to create Pre Note 2 setup phase : (test 22) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	pinNumber := cont2.getPinNumber();
	self.assertTrueMsg( pinNumber.trimBlanks &lt;&gt; null, "Failed to create PIN for Pre Note 2 in setup phase : (test 23) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	allPins.add( pinNumber );
	
	driverCode := null;
	carrierCode := carrier.code;
	gateName := null;
	batNumber := RFIDTagId;
	extraDetail := "Base test A.";
	expectedError := 0;
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckRego,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									allPins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	allPins.clear();
	
	vehicle := term.vehicles[truckRego, truckState];
	self.assertTrueMsg( vehicle &lt;&gt; null, "Failed to create vehicle1 - test 22");
	self.assertTrueMsg( cont1.isOnSite, "Cargo Item " &amp; ContId1 &amp; " should be on site - test 23");
	self.assertTrueMsg( cont2.isOnSite, "Cargo Item " &amp; ContId2 &amp; " should be on site - test 24");
	
	self.move(cont1, bs1);
	self.move(cont2, bs1);
	
	//Move the truck out the gate, using the bat number only.
	create allReleaseTIs transient;
	extraDetail := "Base test B.";
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateOut.name,
									truckRego,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									gateName,	//_gateName: String;
									allReleaseTIs,	//_allReleaseTIs: CM_TISetinput;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	self.assertTrueMsg( not vehicle.isOnsite, "Truck " &amp; truckRego &amp; " should be off site - test 24a");
	
// 6/. Stage the cargo using the using the mobile hand held trxs ( check its assigned to the requests )

	create moveController transient;
	moveController.setMyTrackedItem( cargoV );
	moveController.setMoveMode( REAL_MODE );
	moveController.setWeight(3500);
	moveController.setMyToPrimaryLocation( yic1.getLocationsController );
		
	app.myPassport.setWarningsIgnored(true);

	app.myTrxUA.trxStageCargoForRelease(moveController, reserveDetail1, false, app.myPassport);
	cargoV := moveController.myTrackedItem.CM_Cargo;	// was split, get the bit split off
	delete moveController;
	self.assertTrueMsg( cargoV.myPrimaryActualLocation =  yic1.getLocationsController, "Failed to move " &amp; cargoV.id &amp; " : (test 25) - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	//self.assertTrueMsg( reserveDetail1.allTrackedItems.includes(cargoV), "Reserve Detail assigned does not include " &amp; cargoV.id &amp; " - test 25a");
	self.assertTrueMsg( reserveDetail1.includeTrackedItem(cargoV, false), "Reserve Detail assigned does not include " &amp; cargoV.id &amp; " - test 25a");//23/06/2023	navkc1	CR 58406 Task 58408
	self.assertTrueMsg( reserveDetail1.isFullyStaged, "Reserve Detail by Volume Not fully staged - test 25b");
	
	
	create moveController transient;
	moveController.setMyTrackedItem( cargoW );
	moveController.setMoveMode( REAL_MODE );
	moveController.setWeight(2500);
	moveController.setMyToPrimaryLocation( yic1.getLocationsController );
		
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxStageCargoForRelease(moveController, reserveDetail2, false, app.myPassport);
	cargoW := moveController.myTrackedItem.CM_Cargo;	// was split, get the bit split off
	delete moveController;
	self.assertTrueMsg( reserveDetail2.isFullyStaged, "Reserve Detail by Weight Not fully staged - test 26");
	//self.assertTrueMsg( reserveDetail2.allTrackedItems.includes(cargoW), "Reserve Detail assigned does not include " &amp; cargoW.id &amp; " - test 26a");
	self.assertTrueMsg( reserveDetail2.includeTrackedItem(cargoW, false), "Reserve Detail assigned does not include " &amp; cargoW.id &amp; " - test 26a"); //23/06/2023	navkc1	CR 58406 Task 58408
	self.assertTrueMsg( reserveDetail2.isFullyStaged, "Reserve Detail by Volume Not fully staged - test 26b");
	
	
	create moveController transient;
	moveController.setMyTrackedItem( cargoQ );
	moveController.setMoveMode( REAL_MODE );
	moveController.setQuantity(15);
	moveController.setMyToPrimaryLocation( yic1.getLocationsController );
		
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxStageCargoForRelease(moveController, reserveDetail3, false, app.myPassport);
	cargoQ := moveController.myTrackedItem.CM_Cargo;	// was split, get the bit split off
	delete moveController;
	self.assertTrueMsg( reserveDetail3.isFullyStaged, "Reserve Detail by Quantity Not fully staged - test 27");
	//self.assertTrueMsg( reserveDetail3.allTrackedItems.includes(cargoQ), "Reserve Detail assigned does not include " &amp; cargoW.id &amp; " - test 27a");
	self.assertTrueMsg( reserveDetail3.includeTrackedItem(cargoQ, false), "Reserve Detail assigned does not include " &amp; cargoW.id &amp; " - test 27a"); //23/06/2023	navkc1	CR 58406 Task 58408
	self.assertTrueMsg( reserveDetail3.isFullyStaged, "Reserve Detail by Volume Not fully staged - test 27b");

// 7/. Pack all of the first child reserve details (using the mobile hand held trxs ) into the first container and do pack complete passing in the pack request.
//     The request should stay active.
	
	parentReserveDetail := packRequest.allReserveDetails.first;
	app.myTrxUA.trxAddToReserveDetail( parentReserveDetail, cont1, app.myPassport );
	
	handHeldCheckerAgent := self.createHandHeldCheckerAgent();
	mobileGenericAgent := handHeldCheckerAgent.getPropertyValue("myMobileGenericAgent").CMIF_MobileGenericAgent;
	mobileGenericAgent.setDoNotShowMsgBox(true);
	
	mobileGenericAgent.setMyBulkRelease(packRequest);
	mobileGenericAgent.doPackCargo( cont1, cargoV, true );
	self.assertTrueMsg( cargoV.isChild, "Cargo by Volume failed to pack - test 28");
	mobileGenericAgent.clearAll();

	self.opts.purge();
	self.opts.addAssoc(UTTI_BulkRelease, packRequest);
	self.packCompleteContainer( cont1.CM_Container );
	self.assertTrueMsg( cont1.isPackingComplete, "Parent not marked as Pack Complete - test 29");
	self.assertTrueMsg( packRequest.status = BR_ACTIVE, "Packing request should still be active - test 30"); // still has unpacked child reserves and one more parent requested

	roadReserveDetail := roadRequest.allReserveDetails.first();
	app.myTrxUA.trxAddToReserveDetail( roadReserveDetail, cont1, app.myPassport );
	app.myTrxUA.trxAddToReserveDetail( roadReserveDetail, cont2, app.myPassport );
	
	self.opts.purge;
	self.opts.addAssoc("release", roadRequest);
	vvr := self.gateOutContainer(TruckRego, "", "", cont1.CM_Container, false, dualGate , null);
	self.assertTrueMsg( vvr &lt;&gt; null, "No Vehicle Visit Record - test 31 - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	wle := vvr.myRoadJob.workListEntries.first; 
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	self.assertTrueMsg( not vehicle.isOnsite, "Truck " &amp; truckRego &amp; " should be off site - test 31a");
	self.assertTrueMsg( not cont1.isOnSite, "Container " &amp; cont1.id &amp; " should be off site - test 31b");
	
// 8/. Pack the remaining child reserve details (using the mobile hand held trxs ) into the other container and do pack complete passing in the pack request.
//     This time the pack request should become completed.

	app.myTrxUA.trxAddToReserveDetail( parentReserveDetail, cont2, app.myPassport );
	
	mobileGenericAgent.setMyBulkRelease(packRequest);
	mobileGenericAgent.doPackCargo( cont2, cargoW, true );
	self.assertTrueMsg( cargoW.isChild, "Cargo by Weight failed to pack - test 32");
	mobileGenericAgent.sendMsg("clearAll");
	
	mobileGenericAgent.setMyBulkRelease(packRequest);
	mobileGenericAgent.doPackCargo(cont2, cargoQ, true );
	self.assertTrueMsg( cargoQ.isChild, "Cargo by Weight failed to pack - test 33");
	mobileGenericAgent.clearAll();
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_BulkRelease, packRequest);
	self.packCompleteContainer( cont2.CM_Container );
	self.assertTrueMsg( cont2.isPackingComplete, "Parent not marked as Pack Complete - test 34");
	self.assertTrueMsg( packRequest.status = BR_COMPLETE, "Packing request should now be complete - test 35");

// 9/. Gate in a truck against the road release request for the container.  Load the container and gate out the truck.
	
	self.opts.purge;
	self.opts.addAssoc("release", roadRequest);
	vvr := self.gateOutContainer(TruckRego, "", "", cont2.CM_Container, false, dualGate , null);
	self.assertTrueMsg( vvr &lt;&gt; null, "No Vehicle Visit Record - test 36 - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	wle := vvr.myRoadJob.workListEntries.first; 
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	self.assertTrueMsg( not vehicle.isOnsite, "Truck " &amp; truckRego &amp; " should be off site - test 36a");
	self.assertTrueMsg( not cont2.isOnSite, "Container " &amp; cont2.id &amp; " should be off site - test 36b");
	
epilog

	self.setTerminalConfig(AllowPINwithoutVGM, oldSetting2);
	app.isGarbageCollectionProcess := false;
	
	delete selectedTerminalAreas;
	delete allCargoToAssign;
	delete allPins;
	delete moveController;
	delete handHeldCheckerAgent;
	delete allReleaseTIs;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tUnpackBreakBulkMulti" id="9406a6a5-6775-4731-acbe-ee6fc712cc54">
        <source>tUnpackBreakBulkMulti();
/*

Date		Who		Reason
27 Jun 2014	cnwer1	Initial creation PAR
09 Jan 2024	navma1  Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/
constants
	Cargo_Type			: String = "UTREBAR";
	Cargo_Type2 = "UT_USR";
vars
	cargoTypeObj,cargoTypeObj2 : CM_CargoType;
	unpackCargo,
	packCargo,
	container1, cargo3 : CM_TrackedItem;
	packTIs: CM_TIArray;
	cargo: CM_TrackedItem;
	bs1	: CM_BlockStack;
	unpackTrx : CM_Unpack;
begin
	self.deleteContainer("TEST0000001");
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	container1 := self.addContainerAtLocation("TEST0000001",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "APPL",TI_IMEX_STATUS_STORAGE, bs1.myLocationsController);	
	
	//assertEqual(container1.totalWeight, "4000".Decimal);
	//assertEqual(container1.weightCargo, null);
	
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	self.deleteAllCargo("PACKREBAR",cargoTypeObj);
	
	
	cargo:=self.addCargoAtLocation("PACKREBAR",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	beginTransaction;
	cargo.setTotalQuantity(50);
	self.assertEqual(cargo.totalQuantity,50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(50000);
	commitTransaction;
	packCargo:=	cargo;
	app.myTrxUA.trxUpdatePackCargo(container1,packCargo,30,null,false,null,null,false,null,app.myPassport);			//19.03.2024 navhl20 #62863
	self.assertNoTrxErrors();
	self.assertEqual(container1.allChildren.size,1);
	self.assertEqual(packCargo.totalQuantity,30);
	self.assertEqual(cargo.totalQuantity,20);
	self.assertEqual(container1.weightCargo.Integer,30000.Integer);

	self.assertEqual(packCargo.totalWeight.Integer,30000.Integer);
	self.assertEqual(cargo.totalWeight.Integer,20000);
	
	self.deleteCargoType(Cargo_Type2);
	cargoTypeObj2 := self.addCargoType(Cargo_Type2, false);
	assertNotNull(cargoTypeObj2);
	
	cargo3:=self.addCargoAtLocation("PACKUSR",cargoTypeObj2,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	//this now defaults total weight to 1 
	self.assertNotNull(cargo3);
	self.assertEqual(cargo3.myPrimaryActualLocation,bs1.myLocationsController);
		
	app.myTrxUA.trxUpdatePackCargo(container1,cargo3,null,null,false,null,null,false,null,app.myPassport);			//19.03.2024 navhl20 #62863
	self.assertNoTrxErrors();
	self.assertEqual(container1.allChildren.size,2);
	
	self.assertEqual(container1.weightCargo.Integer,30001.Integer);
	
	
	//assertEqualMsg(container1.allChildren.size, 2, "Container children incorrect");//PAR 22954
	assertEqualMsg(container1.numChildren, 2, "Container children incorrect");
	unpackCargo:=packCargo;
	//app.myTrxUA.trxUpdateUnpackCargo(unpackCargo,bs1.myLocationsController,10,null,false, app.myPassport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
	app.myTrxUA.trxUpdateUnpackCargo(unpackCargo,bs1.myLocationsController,10,null,false, null, app.myPassport);  //14.03.2024 navhl20 #62861
	
	self.assertNoTrxErrors();
	self.assertEqual(container1.allChildren.size,2);
	self.assertEqual(container1.allChildren.first.totalQuantity,20);
	self.assertEqual(container1.weightCargo.Integer,20001.Integer);

	self.assertEqual(cargo.totalQuantity,30);

	unpackTrx := cargo.getMyUnpackedFromTransaction();
	self.assertNotNull(unpackTrx);
	self.assertEqual(unpackTrx.action,ACTION_UNPACK_FROM);
	self.assertNull(packCargo.getMyUnpackedFromTransaction());
epilog
	delete packTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUnpackContainer" id="f08d7e23-710b-433c-9750-816a78b14507">
        <source>tUnpackContainer();
// cnwdap1
//04 December 2009	cnwml2
//+cnwml2 MSL CCMS 1017

vars
	container1: CM_TrackedItem;
	packTIs, unpackTIs: CM_TIArray;
	wh: CM_IrregularBlockArea;
	selectedTypes: CM_CargoBOLTypeSet;
	cargo, cargo1: CM_TrackedItem;
	container1_volumeBefore, 
	container1_totalVolumeBefore	: Decimal[16,4];
	
	notAvailable			: Boolean;
	realHookCode			: CM_HookCode;
	linkObjects				: ObjectArray;
	hookLink				: CM_HookLink;
	
begin
	self.deleteContainer("TEST0000001");

	container1 := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	
	assertEqual(container1.totalWeight, "4000".Decimal);
	assertEqual(container1.weightCargo, null);
	
	self.deleteContainer("MATCHILD001");
	self.deleteContainer("MATCHILD002");
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	cargo := self.addContainerAtLocation("MATCHILD001", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	assertEqual(cargo.totalWeight, 2000.Decimal);
	assertEqual(cargo.weightCargo, 0.Decimal);
	cargo1 := self.addContainerAtLocation("MATCHILD002", null, "2200", "GENL", 1, wh.allLocationsControllers.first);
	assertEqual(cargo1.totalWeight, 2000.Decimal);
	assertEqual(cargo1.weightCargo, 0.Decimal);
	assertLocationHasTI(wh.allLocationsControllers.first, cargo);

	//first pack in 2  child containers
	create packTIs transient;
	packTIs.add(cargo);
	packTIs.add(cargo1);
	packContainer(container1.CM_Container, packTIs);
	//assertEqualMsg(container1.allChildren.size, 2, "Container children incorrect");//PAR 22954
	assertEqualMsg(container1.numChildren, 2, "Container children incorrect");
	assertEqual(container1.totalWeight, 8000.Decimal);   //original total weight is 4000 + total weight of child 400 x 2 = 4800
	assertEqual(container1.weightCargo, 4000.Decimal);

	// Par 25592. Volume test for unpacking
	container1_volumeBefore		:= container1.getMyTotalVolume;		// this is Container Volume, i.e. current real volume of iron box. When a container is created, volume can be equal 0 or default Cubic metres from container range or a fleet file.
	container1_totalVolumeBefore:= container1.getMyCargoVolume;	// this is total volume of all children packed into the container.
	
	//unpack fist container
	create unpackTIs transient;
	unpackTIs.add(cargo);
	self.unpackContainer(container1, unpackTIs);
	//assertEqualMsg(container1.allChildren.size, 1, "Container children incorrect");//PAR 22954
	assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	assertEqual(container1.totalWeight, 6000.Decimal);   //original total weight is 4000 + total weight of child 400 = 4400
	assertEqual(container1.weightCargo, 2000.Decimal);
	assertEqual(cargo.totalWeight, 2000.Decimal);
	
	// #25592 - volume test after unpacking
	assertEqual(container1.getMyTotalVolume, container1_volumeBefore);	// when packing/unpacking, the volume of iron box should be intact. A container cannot become bigger/smaller, when some items are packed inside.
	assertEqual(container1.getMyCargoVolume, container1_totalVolumeBefore - cargo.getMyTotalVolume);	
	
	// 17/05/2016 cnwmh5 - TFS1821
	realHookCode := app.myRoot.allHookCodes["GPHARESTUFF", notAvailable];
	self.assertNotNull(realHookCode);
	
	create linkObjects transient;
	foreach hookLink in realHookCode.allHookLinks do
		linkObjects.add(hookLink.myLinkObject);
	endforeach;
	linkObjects.add(self.getTerminal());
	
	self.opts.purge();
	self.opts.addAssoc("LinkObjects", linkObjects);
	self.xHookCodeUpdate(realHookCode);
	
	unpackTIs.clear();
	unpackTIs.add(cargo1);
	self.unpackContainer(container1, unpackTIs);
	assertEqualMsg(container1.numChildren, 0, "Container children incorrect");
	self.assertNotNullMsg(cargo1.getTransactionOfType(10000092), "No CM_TaskComplete (10000092) transaction found");
	
epilog
	delete unpackTIs;
	delete packTIs;
	
	// 17/05/2016 cnwmh5 - TFS1821
	linkObjects.remove(self.getTerminal);
	self.opts.purge();
	self.opts.addAssoc("LinkObjects", linkObjects);
	self.xHookCodeUpdate(realHookCode);
	
	delete linkObjects;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tUnpackContentsStatus" id="522c12dd-54b8-4a71-a8b2-8f11c665be4d">
        <source>tUnpackContentsStatus();
//cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 May 2011	cnwndl1	Initial creation	Par 27344

*/

vars
	container1: CM_TrackedItem;
	attach: CMIF_InOutAttachment;
	attach2: CMIF_InOutAttachment;
	attachments: CMIF_InOutAttachmentArray;
	product: CM_Product;
	operator	: CM_Operator;
	cargoType: Integer;
	unpackTIs, thePackTIs: CM_TIArray;
	theMoveController : CMIF_MoveController;
	pxyContainer : CM_Container;
	lc : CM_LocationsController;
	wh : CM_BlockStack;
	loadState : Boolean;
	containerID : String;
	child1Id : String;
	child2Id : String;

	toDoTemplate  : CM_ToDoTemplate;
begin


	 // Create ToDo Template for 35362
	toDoTemplate :=self.addToDoTemplate2("UT Template2");
	self.assertNotNull(toDoTemplate);
	
	containerID := "TEST1010101";
	child1Id := "MDF1011";
	child2Id := "MDF1012";
	operator := self.getOperator("MSK");

	self.deleteContainer(containerID);
	self.deleteCargo( child1Id, self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	self.deleteCargo( child2Id, self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));

	self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc("CustomsEntryNumber", "100");
	container1 := self.addContainerOpts(containerID, "2200", "GENL", operator);	
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container1 has incorrect Status");
	// MAke sure all stops are removed
	self.opts.addAssoc("CENum", container1.customsEntryNumber);
	deleteStops(container1);
	
	deleteProduct("UTMDF 99Emm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	product := addProduct("UTMDF 99Emm", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));

	cargoType := app.myRoot.getCargoTypeIDFromAbbrev(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString);
	create attach transient;
	attach.set(getTerminal, cargoType, child1Id, "", 100); 
	attach.myProduct := product;
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach.imExStatus := container1.getImExStatus;
	
	create attach2 transient;
	attach2.set(getTerminal, cargoType, child2Id, "", 100); 
	attach2.myProduct := product;
	attach2.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach2.imExStatus := container1.getImExStatus;
	
	create attachments transient;
	attachments.add(attach);
	attachments.add(attach2);
	
	addContainerChildren(container1.CM_Container, attachments);
	assertEqualMsg(container1.numChildren, 2, "Container children incorrect");
	
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container has incorrect Status after being Populated");
	
	//unpack fist container
	create unpackTIs transient;
	unpackTIs.add(container1.allChildren.first);
	self.unpackContainer(container1, unpackTIs);
	
	beginTransaction;
	container1.updateContentsStatus();
	commitTransaction;

	assertEqualMsg(container1.numChildren, 1, "Container children incorrect after first unpack");
	assertEqualMsg(container1.getContentsStatus(), TI_CONTENTS_STATUS_LCL, "Container has incorrect Status after unpacking first Child");
	assertEqualMsg(container1.allToDoTasksToDo.size, 0, "Container has to do tasks after unpacking first Child");	// 35362
	
	unpackTIs.clear();
	unpackTIs.add(container1.allChildren.first);
	self.unpackContainer(container1, unpackTIs);

	beginTransaction;
	container1.updateContentsStatus();
	commitTransaction;
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container has incorrect Status after unpacking all children but not resetting commodity");
	assertEqualMsg(container1.allToDoTasksToDo.size, 1, "Container has NO to do tasks after unpacking all children but not resetting commodity");	// 35362
	
	beginTransaction;
	container1.setCommodity( null );
	container1.updateContentsStatus();
	commitTransaction;
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_EMPTY, "Container has incorrect Status when no children and no commodity");
		
epilog

	delete attach;
	delete attach2;
	delete attachments;
	delete unpackTIs;
	delete theMoveController;
	delete thePackTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUnpackReefer" id="cde0da56-55e1-45fc-a476-3678381661f2">
        <source>tUnpackReefer();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2015	cnwndl1	Initial creation	Par 36154	TFS 319 / 310

*/
constants

	BlockStack1 : String = "DIS1";
	Container1 : String = "DISC000001";
	Child1 : String = "KIDD000001";
	
vars

	bs1 : CM_BlockStack;
	tiReef : CM_TrackedItem;
	packTIs : CM_TIArray;
	tiKid : CM_TrackedItem;
	cargoType : CM_CargoType;
	oper : CM_Operator;
	prod : CM_Product;
	trx1 : CM_TITransaction;
	trx2 : CM_TITransaction;
	
begin

	cargoType := app.myRoot.getCargoTypeFromAbbrev("MELN");
	self.assertTrueMsg(cargoType &lt;&gt; null, "Failed to find cargo type MELN" );
	
	prod := cargoType.allProducts.first;
	self.assertTrueMsg(prod &lt;&gt; null, "Failed to find sub cargo type within MELN" );
	
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertTrueMsg(cargoType &lt;&gt; null, "Failed to find operator" );

	//cleanup old data
	self.deleteContainer(Container1);
	self.deleteCargo(Child1,cargoType);
	self.deleteTerminalArea(BlockStack1);

	self.setTerminalConfig( DoAutoUnpackClearFields, true );
	
	bs1 := addBlockStack(BlockStack1, 10, null);
	self.assertTrueMsg(bs1 &lt;&gt; null, "Failed to create Block Stack " &amp; BlockStack1 );
	
	tiReef := self.addContainerAtLocation(Container1,null,"2231","REEF",TI_IMEX_STATUS_EXPORT,bs1);
	self.assertTrueMsg(tiReef &lt;&gt; null, "Failed to create Reefer container " &amp; Container1 );
	
	app.myMobileAgent.updateTIConnection( tiReef.CM_Container, true, true, null );
	self.assertTrueMsg(tiReef.isConnected = true, "TI not connected");
	
	tiKid := self.addCargoAtLocation( Child1, prod, oper, bs1.myLocationsController );
	self.assertTrueMsg(tiKid &lt;&gt; null, "Failed to create Child " &amp; Child1 &amp; " - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	create packTIs transient;
	packTIs.add(tiKid);
	self.packContainer(tiReef.CM_Container, packTIs);
	self.assertEqualMsg(tiReef.numChildren, 1, "Container children incorrect");
	
	self.unpackContainer(tiReef, packTIs);
	self.assertEqualMsg(tiReef.numChildren, 0, "Container children incorrect");

	trx1 := tiReef.getLastTransOfType( TRANS_TYPE_DISCONNECT_POWER );
	self.assertTrueMsg(trx1 = null, "Should not be a disconnect trx yet");
	
	self.assertEqualMsg(tiReef.numChildren, 0, "Container children incorrect");
	self.unpackCompleteContainer(tiReef);
	trx1 := tiReef.getLastTransOfType( TRANS_TYPE_DISCONNECT_POWER );
	self.assertTrueMsg(tiReef.isConnected = false, "Reefer should no longer be connected (config option is on )");
	self.assertTrueMsg(trx1 &lt;&gt; null, "Should have a disconnect trx after the unpack complete when the " &amp; DoAutoUnpackClearFields &amp; " config is ON");
	
	//beginTransaction;
	//self.getTerminal.setConfig( DoAutoUnpackClearFields, false );
	//commitTransaction;
	self.setTerminalConfig( DoAutoUnpackClearFields, false );
	
	// unpack clears these suckers, need to put them back to get reefer details again so we can plug it in
	self.opts.purge;
	self.opts.addAssoc("Commodity", "REEF");
	self.opts.addAssoc("Temperature", "4");
	self.updateTI( tiReef );
	
	app.myMobileAgent.updateTIConnection( tiReef.CM_Container, true, true, null );
	self.assertTrueMsg(tiReef.isConnected = true, "TI not connected - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	self.packContainer(tiReef.CM_Container, packTIs);
	self.assertEqualMsg(tiReef.numChildren, 1, "Container children incorrect");
	
	self.unpackContainer(tiReef, packTIs);
	self.assertEqualMsg(tiReef.numChildren, 0, "Container children incorrect");
	trx2 := tiReef.getLastTransOfType( TRANS_TYPE_DISCONNECT_POWER );
	self.assertTrueMsg(trx1 = trx2, "Should not have a new disconnect trx");
	
	self.unpackCompleteContainer(tiReef);
	trx2 := tiReef.getLastTransOfType( TRANS_TYPE_DISCONNECT_POWER );
	self.assertTrueMsg(tiReef.isConnected = true, "Reefer should still be connected (config option is off )");
	self.assertTrueMsg(trx1 = trx2, "Should NOT have a new disconnect trx after the unpack complete when the " &amp; DoAutoUnpackClearFields &amp; " config is OFF");
	
	
epilog
	
	self.deleteContainer(Container1);
	self.deleteCargo(Child1,cargoType);
	self.deleteTerminalArea(BlockStack1);
	
	delete packTIs;

end;</source>
    </JadeMethod>
    <JadeMethod name="tUnpackReefer2" id="82662d21-f356-496c-a5ca-28ab87794ba1">
        <source>tUnpackReefer2();
//
//03 Nov 2016	cnwrs1	TFS 2898 PAR 38331 - Clear VGM details on unpack
//
constants
	BlockStack1 : String = "DIS1";
	Container1 : String = "DISC000001";
//	Child1 : String = "KIDD000001";
vars
	bs1 : CM_BlockStack;
	tiReef : CM_TrackedItem;
//	packTIs : CM_TIArray;
	tiKid : CM_TrackedItem;
	cargoType : CM_CargoType;
	oper : CM_Operator;
	prod : CM_Product;
	trx1 : CM_TITransaction;
	trx2 : CM_TITransaction;
begin
	cargoType := app.myRoot.getCargoTypeFromAbbrev("MELN");
	self.assertTrueMsg(cargoType &lt;&gt; null, "Failed to find cargo type MELN" );
	
	prod := cargoType.allProducts.first;
	self.assertTrueMsg(prod &lt;&gt; null, "Failed to find sub cargo type within MELN" );
	
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertTrueMsg(cargoType &lt;&gt; null, "Failed to find operator" );

	//cleanup old data
	self.deleteContainer(Container1);
//	self.deleteCargo(Child1,cargoType);
	self.deleteTerminalArea(BlockStack1);

	self.setTerminalConfig( DoAutoUnpackClearFields, true );
	
	bs1 := addBlockStack(BlockStack1, 10, null);
	self.assertTrueMsg(bs1 &lt;&gt; null, "Failed to create Block Stack " &amp; BlockStack1 );
	
	tiReef := self.addContainerAtLocation(Container1,null,"2231","REEF",TI_IMEX_STATUS_EXPORT,bs1);
	self.assertTrueMsg(tiReef &lt;&gt; null, "Failed to create Reefer container " &amp; Container1 );
	
	app.myMobileAgent.updateTIConnection( tiReef.CM_Container, true, true, null );
	self.assertTrueMsg(tiReef.isConnected = true, "TI not connected");
	
//	tiKid := self.addCargoAtLocation( Child1, prod, oper, bs1.myLocationsController );
//	self.assertTrueMsg(tiKid &lt;&gt; null, "Failed to create Child " &amp; Child1 &amp; " - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
//	create packTIs transient;
//	packTIs.add(tiKid);
//	self.packContainer(tiReef.CM_Container, packTIs);
//	self.assertEqualMsg(tiReef.numChildren, 1, "Container children incorrect");
//	// set the vgm details
	self.opts.purge();
	self.opts.addAssoc("IsWeightCertified", true);
	self.opts.addAssoc("WeightCertBy", "Weight is Certified by");
	self.opts.addAssoc("AuthorisedPerson", "Authorised Person!!!!");
	self.updateTI(tiReef);
	
//	self.unpackContainer(tiReef, packTIs);
//	self.assertEqualMsg(tiReef.numChildren, 0, "Container children incorrect");

//	trx1 := tiReef.getLastTransOfType( TRANS_TYPE_DISCONNECT_POWER );
//	self.assertTrueMsg(trx1 = null, "Should not be a disconnect trx yet");
	
//	self.assertEqualMsg(tiReef.numChildren, 0, "Container children incorrect");
	self.unpackCompleteContainer(tiReef);
	trx1 := tiReef.getLastTransOfType( TRANS_TYPE_DISCONNECT_POWER );
	self.assertTrueMsg(tiReef.isConnected = false, "Reefer should no longer be connected (config option is on )");
	self.assertTrueMsg(trx1 &lt;&gt; null, "Should have a disconnect trx after the unpack complete when the " &amp; DoAutoUnpackClearFields &amp; " config is ON");
	self.assertTrueMsg(tiReef.isWeightCertified = false, "Reefer should no longer be weight certified (config option is on )");
	
	//beginTransaction;
	//self.getTerminal.setConfig( DoAutoUnpackClearFields, false );
	//commitTransaction;
	self.setTerminalConfig( DoAutoUnpackClearFields, false );
	
	// unpack clears these suckers, need to put them back to get reefer details again so we can plug it in
	self.opts.purge;
	self.opts.addAssoc("IsWeightCertified", true);
	self.opts.addAssoc("WeightCertBy", "Weight is Certified by");
	self.opts.addAssoc("AuthorisedPerson", "Authorised Person!!!!");
	self.opts.addAssoc("Commodity", "REEF");
	self.opts.addAssoc("Temperature", "4");
	self.updateTI( tiReef );
	
	app.myMobileAgent.updateTIConnection( tiReef.CM_Container, true, true, null );
	self.assertTrueMsg(tiReef.isConnected = true, "TI not connected - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
//	self.packContainer(tiReef.CM_Container, packTIs);
//	self.assertEqualMsg(tiReef.numChildren, 1, "Container children incorrect");
	// set the vgm details
	self.opts.purge();
	self.opts.addAssoc("IsWeightCertified", true);
	self.opts.addAssoc("WeightCertBy", "Weight is Certified by");
	self.opts.addAssoc("AuthorisedPerson", "Authorised Person!!!!");
	self.updateTI(tiReef);
	
//	self.unpackContainer(tiReef, packTIs);
//	self.assertEqualMsg(tiReef.numChildren, 0, "Container children incorrect");
//	trx2 := tiReef.getLastTransOfType( TRANS_TYPE_DISCONNECT_POWER );
//	self.assertTrueMsg(trx1 = trx2, "Should not have a new disconnect trx");
	
	self.unpackCompleteContainer(tiReef);
	trx2 := tiReef.getLastTransOfType( TRANS_TYPE_DISCONNECT_POWER );
	self.assertTrueMsg(tiReef.isConnected = true, "Reefer should still be connected (config option is off )");
	self.assertTrueMsg(trx1 = trx2, "Should NOT have a new disconnect trx after the unpack complete when the " &amp; DoAutoUnpackClearFields &amp; " config is OFF");
	self.assertTrueMsg(tiReef.isWeightCertified = false, "Reefer should no longer be weight certified (config option is off)");
epilog
	self.deleteContainer(Container1);
//	self.deleteCargo(Child1,cargoType);
	self.deleteTerminalArea(BlockStack1);
//	delete packTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUnpackTransship" id="83549e72-b2d0-46dc-8ed1-f04b8cb99c54">
        <updating/>
        <source>tUnpackTransship() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2016	cnwns1	Initial creation

- Create a tranship container onship.


* Create 2 child cargo items (GC) inside the container.
* Discharge the container.
* Open the Pack/Unpack screen and select a block stack and the container to unpack.
* Unpack both child cargo items. Should get no errors.
* Check the container is still tranship. Check both child cargo items are still tranship. (NOTE: Check the TRANSHIP tab on all items... This was the problem last time - should not cause 1090 viewing this tab).
- Find an MT container onsite. 
- Pack one of the child cargo items into the container.
- The MT container that was packed, should have gotten the tranship details off the child cargo item.
- Repeat steps with different MT container and other child item. Should have same results.
// 10 Sep 2019	cnwrs1	TFS 46030
//*/
constants
	CraneId         : String  = "CRR1";
	CTAId           : String = "UTC1A2";
vars
	vessel       	: CM_Vessel;
	voyage          : CM_Voyage;
	voyage2         : CM_Voyage;
	operator        : CM_Operator;
	tas             : StringArray;
	cta             : CM_CraneTransferArea;
	crane           : CM_Machine;      
	slotsFrom       : CM_SlotControllerArray;
	tmpLoadCC       : CMIF_LoadColorCode;
    voyageDischJob	: CM_VoyageJob;
    wle             : CM_WorkListEntry;
    request         : CM_Request;
    port            : CM_Port;
	strs            : StringArray;
	tiArray         : CM_TIArray;
	cargoType 		: CM_CargoType;
	product			: CM_Product;
	cargoTypeId		: Integer;
	container1		: CM_TrackedItem;
	array			: HugeStringArray;
	attachments		: CMIF_InOutAttachmentArray;
	attach			: CMIF_InOutAttachment;
	attach2			: CMIF_InOutAttachment;
	fieldUpdate		: CM_EDIDataCargoFieldUpdate;
	dict			: CM_EDICargoByIdBOLDict;
	updateTI		: CM_EDICargoFieldUpdateTI;
	tiController	: CMIF_TranshipTIController;
	tiController2	: CMIF_TranshipTIController;
	tiController3	: CMIF_TranshipTIController;
	bs1				: CM_BlockStack;
	packUnpackTIs	: CM_TIArray;
	child1			: CM_TrackedItem;
	child2			: CM_TrackedItem;
	container2		: CM_Container;
	container3		: CM_Container;
	termArea1		: CM_TerminalArea;
	allConts		: ObjectSet;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
    deleteTerminalArea("11UTBS1");
	bs1:=self.addBlockStack("11UTBS1",200,null);
	self.assertNotNull(bs1);
             
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertNotNull(operator);             
	vessel := app.myRoot.getVesselByLloydsNumber("612341982",true);     
	self.assertNotNull(vessel);
						 
	// create the voyage
	self.deleteVoyage("1VOYLOLO");
	voyage := self.addVoyageWithContainerStructur("1VOYLOLO",vessel.code, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage);
	
						 
	// create the voyage
	self.deleteVoyage("2VOYLOLO");
	voyage2 := self.addVoyageWithContainerStructur("2VOYLOLO",vessel.code, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage2);
	
	
	// initialisations
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	self.assertNotNull(port);
	
	cargoType := self.getCargoType("CANNON");
	self.assertNotNull(cargoType);
	
	create strs transient;
	
	// create a parent container on the voyage
	strs.add("010684");
	
	create tiArray transient;
	
	self.addQuickCargo(voyage, strs, strs.size, tiArray);
	container1 := voyage.allOnshipTIsByCargoTypeId.first();
	self.assertNotNullMsg(container1,"Container is null");
	
	self.assertEqualMsg(container1.getAllActiveStopsSize, 0, "Container1 has stops");
	create array transient;

	cargoTypeId := cargoType.id;
	create attachments transient;
	
	
	create attach transient;
	attach.set(getTerminal, cargoTypeId, "CHI6661", "", 5000); 
	attach.myProduct := product;
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach.imExStatus := container1.getImExStatus;
		
	attachments.add(attach);
	
	create attach2 transient;
	attach2.set(getTerminal, cargoTypeId, "CHI6662", "", 5000); 
	attach2.myProduct := product;
	attach2.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach2.imExStatus := container1.getImExStatus;
		
	attachments.add(attach2);
		
	self.deleteStops(container1);
	self.opts.purge();
	self.opts.addAssoc("Voyage",voyage);
	self.updateTI(container1);
		
	create tiController transient;

	tiController.allTrackedItems.clear();
	tiController.allTrackedItems.add(container1);
	tiController.myExportDestPort := app.getMyRoot.allPorts["NZAKA"];
	tiController.myExportDisPort:= app.getMyRoot.allPorts["NZAKL"];
	tiController.myExportVoyage := voyage2;
	tiController.remarks := "fisch schlapping";
	//tiController.removeStops := true; // TFS 47222 jlgzm1 20/11/2019
	
	self.makeTrackedItemTranship(tiController);		
	addContainerChildren(container1.CM_Container, attachments);
	self.assertEqualMsg(container1.numChildren, 2, "Container children incorrect");
	
	create fieldUpdate transient;
	create dict transient;
	create updateTI transient;

	
	// create the crane transfer area
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CTAId);
	cta := self.addCraneTransferArea(CTAId);
	self.assertNotNull(cta);
	
	// create the crane
	create tas transient;
	tas.add(cta.id );
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	self.deleteMachine(CraneId);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	          
	// colour code the discharge slots
	create slotsFrom transient;
			
	self.getJobSlotControllers(voyage.code, "01", DeckOnDeck, 3, 1, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	voyageDischJob := self.addVoyageJob(voyage, crane.id , slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
	
	// discharge the following slots
	self.loadAllJobsToOps(voyage, true);

	// Queue the required containers
	slotsFrom.clear();
	foreach request in voyageDischJob.allRequests do                          
		foreach wle in request.allWorkListEntries do       
			if wle.CM_VoyageWLE.myRequest.CM_SlotRequest.isDischarge then
				slotsFrom.add(wle.CM_VoyageWLE.myRequest.CM_SlotRequest.mySlotController);
				self.autoplanWLE(wle);
				self.deleteStops(wle.myTrackedItem);                                                  
				self.move(wle.myTrackedItem,bs1);
				///self.moveQueuedCargo(wle);
			endif;
		endforeach;
	endforeach;
	
	assertTrue(voyageDischJob.allReceiveTrackedItems.size = 1);
	
	self.assertEqualMsg(container1.getImExStatus(),TI_IMEX_STATUS_TRANSHIP,"container1 IMEX Status is wrong First");
		
		//unpack Child containers
	create packUnpackTIs transient;
	
	child1 := container1.allChildren.first();
	child2 := container1.allChildren.last();
	
	packUnpackTIs.add(child1);	
	self.unpackContainer(container1, packUnpackTIs);
	
	self.assertEqualMsg(container1.numChildren, 1, "Container children incorrect");
	self.assertEqualMsg(container1.getImExStatus() 	, TI_IMEX_STATUS_TRANSHIP,"container1 IMEX Status is wrong second");	
	self.assertEqualMsg(child1.getImExStatus() 		, TI_IMEX_STATUS_TRANSHIP,"child1 IMEX Status is wrong");	
	self.assertEqualMsg(child2.getImExStatus() 		, TI_IMEX_STATUS_TRANSHIP,"child2 IMEX Status is wrong");
	
	packUnpackTIs.clear();
	packUnpackTIs.add(child2);
	self.unpackContainer(container1, packUnpackTIs);

	self.assertEqualMsg(container1.numChildren, 0, "Container children incorrect");
	self.assertNotEqualMsg(container1.getImExStatus() 	, TI_IMEX_STATUS_TRANSHIP,"container1 IMEX Status is wrong second");	
	self.assertEqualMsg(child1.getImExStatus() 			, TI_IMEX_STATUS_TRANSHIP,"child1 IMEX Status is wrong");	
	self.assertEqualMsg(child2.getImExStatus() 			, TI_IMEX_STATUS_TRANSHIP,"child2 IMEX Status is wrong");
	
	
	
	//Create 2 new containers
	strs.clear();
	tiArray.clear();
	
	strs.add("010101");
	strs.add("010102");
		
	termArea1 := container1.myTerminalArea;	
	self.addQuickCargo(termArea1, strs, strs.size, tiArray);

	create allConts transient;
	termArea1.getAllLocationsTrackedItems(allConts);
	self.assertEqualMsg(allConts.size(), 3, "Containers in area incorrect");
	
	container2:=termArea1.allLocationsControllers.first().allTrackedItems[2].CM_Container;
	container3:=termArea1.allLocationsControllers.first().allTrackedItems[3].CM_Container;
	self.assertNotNullMsg(container2,"Container2 is null");
	self.assertNotNullMsg(container3,"Container3 is null");
		
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus",TI_IMEX_STATUS_STORAGE);
	self.updateTI(container2);
	self.updateTI(container3);
		
	
	//turn off warnings
	
	self.assertNoTrxErrorsOrWarnings();	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_CHILD_OP_DIFF);
	app.myPassport.setWarningsIgnored(true);
	
	
	//pack into new containers
	packUnpackTIs.clear();
	packUnpackTIs.add(child1);		
	self.packContainer(container2, packUnpackTIs);
	self.assertEqualMsg(container2.numChildren, 1, "Container2 children incorrect");
	self.assertEqualMsg(child1.getImExStatus() , TI_IMEX_STATUS_TRANSHIP,"child1 IMEX Status is wrong after repack");
	self.assertEqualMsg(container2.getImExStatus() , TI_IMEX_STATUS_TRANSHIP,"01 container2 IMEX Status is wrong, it is " &amp; container2.getImExStatusString() );
	
	app.myPassport.setWarningsIgnored(true);
	
	self.assertEqualMsg(child2.getImExStatus() , TI_IMEX_STATUS_TRANSHIP,"child2 IMEX Status is wrong before repack");
	packUnpackTIs.clear();
	packUnpackTIs.add(child2);	
	self.packContainer(container3, packUnpackTIs);
	self.assertEqualMsg(container3.numChildren, 1, "Container3 children incorrect");
	self.assertEqualMsg(container3.getImExStatus() , TI_IMEX_STATUS_TRANSHIP,"container3 IMEX Status is wrong, it is " &amp; container3.getImExStatusString());
	self.assertEqualMsg(child2.getImExStatus() , TI_IMEX_STATUS_TRANSHIP,"child2 IMEX Status is wrong after repack");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.clearExpectedTrxErrors();
	app.myPassport.setWarningsIgnored(false);
	if container1 &lt;&gt; null then
	self.deleteContainer(container1.id);
	endif;
	if container2 &lt;&gt; null then
	self.deleteContainer(container2.id);
	endif;
	if container3 &lt;&gt; null then
	self.deleteContainer(container3.id);
	endif;
	self.deleteVoyage("2VOYLOLO");
	self.deleteVoyage("1VOYLOLO");
	delete strs;
	delete tiArray;
	delete tas;
	delete slotsFrom;	
	delete array;
	delete attachments;
	delete dict;
	delete attach;
	delete fieldUpdate;
	delete updateTI;
	delete attach2;
	delete allConts;
	delete tiController;
	delete tiController2;
	delete tiController3;
	delete packUnpackTIs;
end;
</source>
    </JadeMethod>
    <JadeMethod name="uAddPrenote" id="c456d54a-f4f5-4e75-9a9c-4c7cbb764986">
        <source>uAddPrenote(_id, _isoType : String;	_operator : CM_Operator; _cargoType : CM_CargoType) : CM_TrackedItem protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2015	cnwndl1	Initial creation

*/

vars

	ti 					: CM_TrackedItem;
	
	totalWeight			: Decimal[12,2];
	commodity			: String;
	tiSet : CM_TISet;
	carrier : CM_Carrier;
	termEmailDef,
	tmpCarrierEmail	: CM_PINObjectDefaultEmail;
	trailerType		: CM_TILCType;
	
begin

	self.deleteContainer( _id );
	
	// get the commodity
	commodity := "MT";
	if self.opts.includesKey("commodity") then
		commodity := self.opts.str("commodity");
	endif;	
	
	beginTransaction;
	ti := self.getTerminal.createTI(_cargoType, false);
	ti.setPxyFromDefaultTI(self.getTerminal, _cargoType.id, _id, commodity, _operator);
	ti.changeState(TI_STATE_NOTIFIED, app.myPassport);
	ti.setISOType(_isoType);
	
	// set the mt grade
	if self.opts.includesKey("mtGrade") then
		ti.setAvailabilityGradeRT(self.opts.obj("mtGrade").CM_MTGrade.code, app.myPassport);
	endif;
	
	// set the total weight
	totalWeight := 4000.00;
	if self.opts.includesKey('totalWeight') then
		totalWeight := self.opts.dec('totalWeight');
	endif;
	ti.setPropertyValue( "totalWeight", totalWeight );
	
	if self.opts.includesKey('transMode') then
		ti.setReceiptTransportMode( self.opts.int("transMode") );
	endif;
	
	// set the carrier
	if self.opts.includesKey('carrier') then
		ti.setCarrier(self.opts.str('carrier'));
	endif;
	
	//25 Sep 2015	NDL	Par 36951
	if self.opts.includesKey('pin') and self.opts.bool("pin") and ti.carrier &lt;&gt; null then
		carrier := ti.getCarrierReceive;
		if carrier &lt;&gt; null then
			if ti.getCarrierRelease = null then
				ti.setReleaseCarrier(carrier.code);
			endif;
			ti.setCustomsEntryNumber("X");
			create tiSet transient;
			tiSet.add(ti);
			app.myUtilityUA.utlUpdateGeneratePin(tiSet, null, true, app.myPassport);
		endif;
	endif;
	
	if self.opts.includesKey( ETRow_TrailerType ) then
		trailerType	:= self.getTrailerType( self.opts.str( ETRow_TrailerType ) );
		ti.setMyType( trailerType );
	endif;
	
	if self.opts.includesKey(UTTI_IMEX) then						
		ti.setImExStatus(self.opts.int(UTTI_IMEX));
	endif;
	
	ti.setRemarks(self.createdByUnitTest(ti.remarks), false);					// 10/09/2015 cnwmh5
	
	commitTransaction;
	
	return ti;

epilog

	abortTransaction;

	delete tiSet;

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="uPackCompletePerformace" id="3f07c4f6-96a5-45b0-9c4e-8ecc11e71f53">
        <source>uPackCompletePerformace();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2021	navndl1	Initial creation	TFS 51443

*/

constants

	Cargo_Type : String = "UT_WIDGET";
	ParentID : String = "PRNT7654321";
	ChildBaseID : String = "CHILD000";
	
vars
	
	cargoTypeObj : CM_CargoType;
	operator : CM_Operator;
	index : Integer;
	childId : String;
	wh : CM_IrregularBlockArea;
	container: CM_TrackedItem;
	cargo : CM_TrackedItem;
	packTIs : CM_TIArray;
	unpackTIs : CM_TIArray;
	pxyTI	: CM_TrackedItem;
	
//	myProfiler : JadeProfiler;
	
begin

//	myProfiler := process.profiler;

	create packTIs transient;
	create unpackTIs transient;

	cargoTypeObj :=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	operator := self.getOperator( self.getProfileSetting(UT_Profile.P_OPERATOR).asString );
	
	self.deleteContainer( ParentID );	
	foreach index in 1 to 200 do
		childId := ChildBaseID &amp; index.padLeadingWith( '0', 3 );
		self.deleteAllCargo( childId, cargoTypeObj );
	endforeach;

	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	
	container := self.addContainerOpts( ParentID, "2200", "MT", operator);	
	
	foreach index in 1 to 200 do
		childId := ChildBaseID &amp; index.padLeadingWith( '0', 3 );
		cargo := self.addCargoAtLocation( childId, cargoTypeObj, operator, wh.allLocationsControllers.first );
		packTIs.add(cargo);
		unpackTIs.add(cargo);
	endforeach;

	self.packContainer( container.CM_Container, packTIs );
	self.packCompleteContainer( container.CM_Container );

	self.assertEqualMsg(container.numChildren, 200, "Container children incorrect");
	
	//unpack this container
	
	self.unpackContainer( container, unpackTIs );
	
	pxyTI := app.createUpdateProxy( container ).CM_TrackedItem;
	
	
/*	if myProfiler.isProfiling then
		myProfiler.reset;
		myProfiler.stop;
	endif;

	myProfiler.reportMethodSize := false;
	myProfiler.reportActualTime := true;
	myProfiler.reportCacheStatistics := false;
	myProfiler.reportLoadTime := false;
	myProfiler.reportTotalTime := true;
	myProfiler.reportStatistics := false;
	myProfiler.methodCount := 6000;
	
	myProfiler.start; */
write app.actualTimeServer;	
	app.myTrxUA.trxUpdateTIUnpackComplete( pxyTI, app.myPassport, null);
write app.actualTimeServer;	

epilog
	
/*	if myProfiler &lt;&gt; null and myProfiler.isProfiling then
		myProfiler.stop;
		myProfiler.report;
	endif; */
	
	delete unpackTIs;
	delete packTIs;
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="xHookCodeUpdate" id="a54ba2de-0707-4658-afc8-614ca55ed2e3">
        <source>xHookCodeUpdate(_realHookCode : CM_HookCode);

/*

Purpose:		Update the GPHARESTUFF Hook Code

Date			Who		Reason
17/05/2016		cnwmh5	Initial creation

*/

vars
	
	proxyHookCode 				: CM_HookCode;
	realHookCode 				: CM_HookCode;
	cmifHookCode				: CMIF_HookCode;
	
	objArray					: ObjectArray;
	
	loadState	 				: Boolean;
	
begin
	
	app.cmsBeginLoad(loadState);
	proxyHookCode := _realHookCode.pxyCreateUpdateProxy();
	
	create cmifHookCode transient;
	cmifHookCode.myProxyHookCode := proxyHookCode;
	cmifHookCode.code := proxyHookCode.code;
	cmifHookCode.myHookType := proxyHookCode.myHookType;
	objArray := self.opts.obj("LinkObjects").ObjectArray;
	if objArray &lt;&gt; null then
		objArray.copy(cmifHookCode.allLinkObjects);
	endif;
	cmifHookCode.jadeCode := _realHookCode.getCurrentJadeCode();
	
	app.myTrxUA.trxUpdateHookCode(cmifHookCode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	
	app.cmsEndLoad(loadState);
	
	delete proxyHookCode;
	delete cmifHookCode;
	
end;</source>
        <Parameter name="_realHookCode" type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="xmlDef_UT_PackUnpack_STW" id="8f70da7e-e182-42e4-add2-e1a36e36e30c">
        <source>xmlDef_UT_PackUnpack_STW(_userDefined : String) : String protected;
/*

Purpose:			

