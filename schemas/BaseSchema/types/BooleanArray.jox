<CollClass name="BooleanArray">
    <JadeMethod name="cnEcDoSort" id="1725e550-002e-4e72-a252-a791c28d3f66">
        <lockReceiver/>
        <updating/>
        <source>cnEcDoSort(pSorterObj:CnEcSorter) updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	booleanValue	: Boolean;
	sortKeyObj		: Object;

begin
	foreach booleanValue in self do
		pSorterObj.addKey(booleanValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.allKeys do
		self.add(sortKeyObj.CnEcSortKey.getKey().Boolean);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="CnEcSorter"/>
    </JadeMethod>
</CollClass>
