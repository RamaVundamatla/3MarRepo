    <JadeMethod name="loadCriteriaFrames" id="2d875a34-087b-4afe-a933-b4a5c8f2139e">
        <updating/>
        <source>loadCriteriaFrames() updating;

/*

Purpose:		Load Controls for criteria

Parameters:			

Return Value:		


Date			Who		Reason
19 August 2008	consw1	Initial creation

*/

vars
	i: Integer;
	top, left, height, width: Integer;
	criteriaFrame : CMUI_YACriteriaCntl;
	cntlTabIndex: Integer;
	numRows : Integer;
begin

	top :=  1; 
	left := 1; 
	numRows:= (self.maxCriteria / 2).Integer;
	height := ((self.grpAllCriteria.height - 10) / numRows).Integer;
	width := (self.grpAllCriteria.width / 2).Integer;

	cntlTabIndex := self.frmCriteria.tabIndex;

	// Load up the criteria controls max of 20 criteria
	foreach i in 1 to self.maxCriteria do 
		if (i = (numRows) + 1) then
			left := width;	// second column
			top := 1;
		endif;
		criteriaFrame := self.frmCriteria.loadControl(i).CMUI_YACriteriaCntl;
		criteriaFrame.setVoyagesReference(self.myVoyagesReference);
		criteriaFrame.setWidth(width);			
		criteriaFrame.setTabIndex(cntlTabIndex);
		criteriaFrame.move(left, top, width, height);
		criteriaFrame.visible := true;
		criteriaFrame.tag := "true";	// to active three-state booleans 23 Mar 2015	NDL	Par 35886
		top := top + height;
	endforeach;

	self.frmCriteria.visible := false;
	
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="populateCriteriaFrames" id="66af46f1-bdb0-4842-af94-2a33d2407afd">
        <updating/>
        <source>populateCriteriaFrames() updating;

/*

Purpose:		Populate supplied values in criteria fields

Parameters:			

Return Value:		


Date			Who		Reason
18 August 2008	consw1	Initial creation

*/
vars
	cmifCriteria	: CMIF_YACriteriaPriority;
	criteria		: CM_YACriteriaPriority;
	criteriaFrame	: CMUI_YACriteriaCntl;
	i				: Integer;
	iterCriteria	: Iterator;
	
begin
	if self.frmCriteria.getControl(1) = null then
		self.loadCriteriaFrames();
	endif;

	iterCriteria := self.allOperationalCriteria.createIterator;

	foreach i in 1 to self.allOperationalCriteria.size do 
		criteriaFrame := self.frmCriteria.getControl(i).CMUI_YACriteriaCntl;
		criteriaFrame.setMasterControl(self.frmCriteria);	//cnwmc5 - PAR 31255	
		criteriaFrame.formCriteriaChangeMethodName := CMUI_YACriteriaMaintForm::doCriteriaChanged.name;
		if iterCriteria &lt;&gt; null and iterCriteria.next(cmifCriteria) then
			criteria := cmifCriteria.CMIF_YACriteriaPriority.myProxy;					// can be of type CM_RecRestrictCriteria also
			criteriaFrame.setCriteria( criteria );
			criteriaFrame.setLabelVisible(true);   // Cannot change the criteria type for op criteria
		else
			criteriaFrame.setCriteria( null );
		endif;
	endforeach;

	delete iterCriteria;
	iterCriteria := self.allTemplateCriteria.createIterator;

	foreach i in i to self.maxCriteria do 
		criteriaFrame := self.frmCriteria.getControl(i).CMUI_YACriteriaCntl;
		criteriaFrame.setMasterControl(self.frmCriteria);	//cnwmc5 - PAR 31255
		criteriaFrame.formCriteriaChangeMethodName := CMUI_YACriteriaMaintForm::doCriteriaChanged.name;
		if  iterCriteria.next(cmifCriteria) then
			criteria := cmifCriteria.CMIF_YACriteriaPriority.myProxy;					// can be of type CM_RecRestrictCriteria also
			criteriaFrame.setCriteria( criteria );
		else
			criteriaFrame.setCriteria( null );
		endif;
	endforeach;

	self.isModified := false;
	
epilog
	delete iterCriteria;
end;</source>
    </JadeMethod>
