    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllYAIdentifiers" id="53808c5c-d088-4507-beb3-dd870860d9ad">
        <source>getAllYAIdentifiers(_yaIdentifiers: StringArray input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2017	cnwma1	TFS #3890:STWO - Add 'in transit' to Cargo allocations

*/

vars

begin
	_yaIdentifiers.clear;
	_yaIdentifiers.add(app.transitStatusEnum2String(TI_TransitStatusSOB));
	_yaIdentifiers.add(app.transitStatusEnum2String(TI_TransitStatusDLR));
	
	return true;

epilog

end;</source>
        <Parameter name="_yaIdentifiers" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="36ee1050-98a7-4fd3-8961-efeab1d2d25a">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2017	cnwma1	TFS #3890:STWO - Add 'in transit' to Cargo allocations

*/

vars
	modes : IntegerArray;

begin
	create modes transient;
	modes.add(_ti.getTransitStatus);
	_criteriaValue := modes;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="a5ce934f-8993-41c8-b6de-3c0700baace5">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2017	cnwma1 TFS #3890:STWO - Add 'in transit' to Cargo allocations

*/

vars
	i				: Integer;
	displayString	: String;
	
begin
	if pDataObj.isKindOf(CM_YADataPattern) then
		return pDataObj.CM_YADataPattern.getDataDisplay(self);
	endif;

	foreach i in pDataObj.CM_YADataInteger.allValues do
		if displayString = null then
			displayString	:=	app.transitStatusEnum2String(i);
		else
			displayString	:=	displayString &amp; ", " &amp; app.transitStatusEnum2String(i);
		endif;
	endforeach;
	
	return displayString;
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIntegerDisplay" id="0de2cfa8-5200-4ffc-8735-ef02587038b1">
