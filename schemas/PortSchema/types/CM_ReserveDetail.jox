        <source>isEDIMatch(_ediReleaseRequestTI: CM_EDIReleaseRequestTI; _isExact:Boolean):Boolean;
// --------------------------------------------------------------------------------
// Created:		14 October 2010
//
// Purpose:		Returns a boolean flag to indicate whether the details of the EDI
//				Tracked Item object is a match for the receiver's details.
//
// NOTE: Any details that are on the EDI TI object, but are NOT on the receiver, will
// be treated as a match.
//
// Parameters:	_ediReleaseRequestTI - A reference to the EDI Tracked Item object.
//				_isExact - If true, then the details must be an exact match.
//
// Returns:		True if the proxy object is a match, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
