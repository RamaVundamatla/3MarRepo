    <JadeMethod name="canTwinLiftWithLocation" id="7fac32a3-c9cf-41b3-8419-1bf0702b5d2b">
        <source>canTwinLiftWithLocation(	_nextLocation: CM_LocationsController;
							_myTrackedItem: CM_TrackedItem;
							_nextLocationTrackedItem: CM_TrackedItem;
							_mode		: Integer;
							_direction  : Integer output;
							_errorString : String io): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2009	cnwer1	Initial creation

*/

vars

begin
	if not inheritMethod(_nextLocation,_myTrackedItem,_nextLocationTrackedItem,_mode,_direction,_errorString) then
		return false;
	endif;
	
	_direction:=CM_RTQueueEntry.TWIN_NONE;
	if not self = _nextLocation then
		_errorString:=app.getErrorString(Next_locati_this_block_locati);
		return false;
	endif;

	_direction:=CM_RTQueueEntry.TWIN_BOTH;
	return true;
epilog

end;</source>
        <Parameter name="_nextLocation" type="CM_LocationsController"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_nextLocationTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_direction" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCreateLogicalDelTrx" id="3b0ff37e-5117-46c5-841a-679fcade1b51">
        <source>doCreateLogicalDelTrx():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2017	jlgndl1	Initial creation	TFS 5679

*/

vars
	termArea : CM_TerminalArea;
begin	
	termArea := self.myTerminalArea;
	
	return  (	termArea &lt;&gt; null
				and termArea.isBlockStack
				and termArea.CM_BlockStack.doCreateLogicalDelTrx
				and self.isLogicalDeleteArea()
				);

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForOrigLocation" id="4f64fc29-cb6a-486a-86fd-9bb0baddb89b">
        <updating/>
        <source>executePostMoveForOrigLocation(control: CMIF_MoveController; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	19 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	ti : CM_TrackedItem;
	iter : Iterator;
	tiTrx : CM_TITransaction;

begin
	inheritMethod(control, _passport);
	//---------------------------------------
	//	If a real move then we need to reset the isFull flag - CCMS 1095
	//---------------------------------------
	if control.moveMode = REAL_MODE then
		self.myTerminalArea.resetFullFlag();
		self.calculateFIFODateDuringMove( false, control.myTrackedItem );	//22 Mar 2018	NDL	TFS 37759
	endif;
	
	//moving out need to 'delete' any current trx for this area.
	//03 Aug 2017	NDL	TFS 5679
	if self.doCreateLogicalDelTrx() then
		ti := control.myTrackedItem;
		if ti &lt;&gt; null then
			iter := ti.allTransactions.createIterator;
			while iter.next( tiTrx ) do
				if tiTrx.type &lt;&gt; TRANS_TYPE_Logical_Delete then
					continue;
				endif;
				if tiTrx.CM_LogicallyDeleted.myLogicalDelArea &lt;&gt; self then
					continue;
				endif;
				if tiTrx.deleted then
					continue;
				endif;
				//This is the active one we created when we moved in here
				tiTrx.CM_LogicallyDeleted.logicallyDelete();
			endwhile;
		endif;
	endif;

epilog

	delete iter;
	
end;
	</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForToLocation" id="a8ec82ff-a8a2-42e3-849d-00b8d8107e48">
        <updating/>
        <source>executePostMoveForToLocation(_control: CMIF_MoveController; _passport: CM_Passport input) updating;
//Executes the required post move stuff on this location.
vars
	ti : CM_TrackedItem;
	delTxCont : CMIF_TITransactionController;
	delTrx : CM_LogicallyDeleted;
begin
	inheritMethod(_control, _passport);
	//Now, for one of these areas, update the fifo move date etc
	if _control.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;

	//self.myTerminalArea.calculateFIFODate();
	self.calculateFIFODateDuringMove( true, _control.myTrackedItem );	//22 Mar 2018	NDL	TFS 37759
	
	//03 Aug 2017	NDL	TFS 5679
	if self.doCreateLogicalDelTrx() then
		ti := _control.myTrackedItem;
		if ti &lt;&gt; null then
			create delTxCont transient;
			delTxCont.type := TRANS_TYPE_Logical_Delete;
			delTxCont.noCharge := false;
			delTrx := ti.createTransaction(delTxCont, app.myPassport).CM_LogicallyDeleted;
			delTrx.setMyDelArea( self );
		endif;
	endif;

epilog
	delete delTxCont;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCapacityPC" id="e84de5b0-4dbc-4ccc-b2cc-0bbaf065bedd">
        <source>getCapacityPC(_mode: Integer): Integer;

/*

Purpose:		TFS 49959	

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2020	jlgab1	Initial creation

*/

vars
	capacity, capacityPC, totQty : Integer;
	array : CM_TIArray; 
	ti : CM_TrackedItem;
begin

	capacity := self.getCurrentCapacity();
	if capacity = 0 then
		return 0;
	endif;
	
	create array transient;
	self.getTIs(array, _mode, true);
	foreach ti in array discreteLock do
		totQty := totQty + ti.totalQuantity;
	endforeach;
	
	capacityPC := ((totQty / capacity) * 100).Integer;

	return capacityPC;
epilog
	delete array;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentCapacity" id="aa545998-474e-4567-8bb5-cebbc435cb28">
        <source>getCurrentCapacity(): Integer;

/*

Purpose:			TFS 49959

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2020	jlgab1	Initial creation

*/

vars
	minMax : CM_TerminalAreaProductMinMax;
	
begin

	minMax := self.getMinMaxForFirstTI();
	if minMax &lt;&gt; null and minMax.maxQuantity &gt; 0 then
			return minMax.maxQuantity;
	endif;

	return self.myTerminalArea.getMaxCapacity();

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFIFOTimeStamp" id="e7094e4f-1079-46f9-84f8-c67803faa079">
        <source>getFIFOTimeStamp(): TimeStamp;
//Returns the received timestamp of the earliest TI in this Stack
//If stack is MT, returns current timestamp.
//If stack does NOT have this test enabled, then returns current date.
vars/*
	sortedByDate	:	CM_TIByReceiveDT;
	ti	:	CM_TrackedItem;
	firstDT	:	TimeStamp;*/
	now	:	TimeStamp;
begin

	//autoPlanTest settings deimplimented
	//cnwrd1 par 28295 13.10.2011
	// this test seems unused return false.
	return now;
	
	/*
	if self.myTerminalArea.autoPlanTest.testFirstInFirstOut = false then
		//They dont want to test for this!
		return now;
	endif;

	if self.allTrackedItems.isEmpty then
		return now;
	endif;

	create sortedByDate transient;
	//----------------
	//Painful, but no other way!
	//----------------
	foreach ti in self.allTrackedItems do
		sortedByDate.add(ti);		
	endforeach;

	if sortedByDate.size = 0 then
		return now;
	endif;
	//----------------
	//Return the received DT of the 1st TI
	//----------------
	firstDT := sortedByDate.first.receivedDT;
	return firstDT;
	*/
epilog/*
	if sortedByDate &lt;&gt; null then
		sortedByDate.clear;		
		delete sortedByDate;
	endif;*/
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
