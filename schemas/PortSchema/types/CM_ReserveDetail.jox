    <JadeMethod name="getTotalReleased" id="857c6f6d-5ada-41a0-9939-a7bdf367addb">
        <source>getTotalReleased() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2013	cnwrd1	Initial creation
06 Sep 2013 cnwer1	par 32408
30 Jun 2025 navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
*/

vars
	result  : Integer;
	ti 		: CM_TrackedItem;
begin
	//epr TFS 45287 16/8/19
	if self.isPackingChild then
		return self.getTotalPacked;
	endif;
	
	
	foreach ti in self.allTrackedItemsReleased discreteLock do	//30.06.2025 navma1 #MTN-34090
		//epr par 34406 25/6/14
		if ti.isBulkByVolume or ti.isBulkByWeight then	
			continue;
		endif;
		
		result := result + ti.totalQuantity.max(1);
	endforeach;
	
	return result;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
