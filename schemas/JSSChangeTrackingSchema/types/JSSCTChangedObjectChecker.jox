<Class name="JSSCTChangedObjectChecker" id="c9b87839-c524-487b-8cac-a73db94568b1">
    <superclass name="JSSCTTransientServiceObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="jssct_transient"/>
    <ImplicitInverseRef name="myExternalInterfaceObject" id="456ac6d6-2a22-418e-8207-1d10931321b4">
        <embedded/>
        <type name="Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="checkObjectUpdated" id="5d63a30c-49e6-44ca-bbef-a96a7b2d2016">
        <source>checkObjectUpdated(pObject: Object): TimeStamp;
/*
*/
begin
	if self.myExternalInterfaceObject = null then
		return (null);
	else
		return (self.myExternalInterfaceObject.sendMsgWithParams(method.name, pObject).TimeStamp);
	endif;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="f8b23117-2352-4d49-82ec-472cf7fe9f6c">
        <updating/>
        <source>initialize(pSchema: Schema) updating;

vars
	class: Class;
	appName: String;
	appNameLength: Integer;
	externalClass: Class;
	classColl: ClassColl;
begin
	externalClass := pSchema.getClass(self.getName());
	if externalClass = null then

	else
		create classColl transient;
		externalClass.getSubclasses(classColl);
		if classColl.size = 0 then

		else
			appName := app.name;
			appNameLength := appName.length;
			//	see if there is a subclass of JSSCTChangedObjectChecker prefixed with this app name
			externalClass := classColl.first;
			foreach class in classColl do
				if class.name.length &gt;= appNameLength then
					if class.name[1:appNameLength] = appName then
						externalClass := class;
						break;
					endif;
				endif;
			endforeach;
			create self.myExternalInterfaceObject as externalClass transient;
		endif;
	endif;
epilog
	delete classColl;
end;</source>
        <Parameter name="pSchema" type="Schema"/>
    </JadeMethod>
</Class>
