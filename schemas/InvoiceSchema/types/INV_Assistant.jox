        <source>showInvoiceAllocationMaint(	_alloc : CM_InvoiceAllocation; // ### TFS 51219 25MAY2021 NAVAB1
							_tranmap : CM_TranMapCargoAllocation;
							_tranmapInvent : CM_TranMapInventoryAllocation;  // ### TFS 51219 25MAY2021 NAVAB1
							_masterMenuAction : CMUI_MenuAction;
							_parentForm : CM_BaseForm  // ### TFS 51219 25MAY2021 NAVAB1
							);
/*
Purpose:			 // PAR 35833
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/
vars
	invoiceForm : CMUI_YAMaintInvoiceAllocation;
	yas: ObjectArray;
begin
	invoiceForm := app.loadForm(CMUI_YAMaintInvoiceAllocation, 
							INV_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							null).CMUI_YAMaintInvoiceAllocation;	
	
	// from 36280 check for no form because of security issue
	if invoiceForm = null then
		return;
	endif;
	invoiceForm.createMyAssistant(INV_Assistant);
	invoiceForm.myTranMap := _tranmap;
	invoiceForm.myTranMapInvent := _tranmapInvent;  // ### TFS 51219 25MAY2021 NAVAB1
	
	if _alloc&lt;&gt; null then // UPDATE
		create yas transient;		
		yas.add(_alloc);
	endif;
	
	invoiceForm.setYardAllocation(yas);
	invoiceForm.setParentForm(_parentForm);  // ### TFS 51219 25MAY2021 NAVAB1
	
	invoiceForm.centreOverParent(0);
	invoiceForm.showModal();	
	
epilog
	delete yas;
end;</source>
