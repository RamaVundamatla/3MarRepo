    <JadeMethod name="initTableItems" id="7b32d078-7af6-457f-945e-af631eeabc8a">
        <source>initTableItems(_theEntDef : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements

*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
	xmlStr			: String;
begin
	theTable := self.tblItems;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;
		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		xmlStr := self.enquiryTypeDef_Cargo;
		
		if xmlStr &lt;&gt; null then
			theTable.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
		else	
			theTable.setTblDataEntRowsFromDef(entTableDef);
		endif;
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		theTable.rows := 1;
		self.setColorsForTable(self.tblItems);
		self.setFieldAlignmentOnTable(theTable);
	else
		theTable.rows := 1;	
	endif;
epilog

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="55bd9d1f-f559-4436-9a24-3c16a91322b2">
        <updating/>
        <source>initialise(_parent 			: CM_BaseForm;
			_proxyWorkOrder : CM_WorkOrder; 
			_mode 			: Integer;
			_selectedTask 	: CM_WorkOrderDtl;
			_workOrderType  : Integer;
			_voyage 		: CM_Voyage	)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	wodtl  : CM_WorkOrderDtl;
	term   : CM_Terminal;
	voyage : CM_Voyage;
begin
	term 				:= self.myTerminal;					
	self.isUseYardJobs	:= term.isUseYardJobsForCargoWo;    
	
	self.setParentForm(_parent);
	
	self.createPxyWorkOrder();

	_proxyWorkOrder.raiseExceptionIfNotTransient(method);
	
	foreach wodtl in _proxyWorkOrder.allWoDtls do
		wodtl.raiseExceptionIfNotTransient(method);
	endforeach;
	
	self.myWorkOrder    := _proxyWorkOrder.pxyGetRealObject();
	self.myPxyWorkOrder := _proxyWorkOrder;
	self.myPxyTask 	    := _selectedTask;
	self.workOrderMode  := _mode;
	self.workOrderType  := _workOrderType;
	
	if self.myPxyWorkOrder.hasBeenApproved() then
		self.isApproved := true;
	else
		self.isApproved := false;		
	endif;
	
	
	if _selectedTask &lt;&gt; null then									//06.03.2023 navma1 #56457:[56458]	
		voyage := _selectedTask.getMyVoyageObject();					
	endif;																		
	
	if voyage &lt;&gt; null then										    //06.03.2023 navma1 #56457:[56458]	
		self.myVoyage := voyage;
	elseif _voyage &lt;&gt; null then
		self.myVoyage := _voyage;
	endif;
	
	if self.workOrderMode = self.MODE_ADD then
		self.canMaintainTasks(WO_STATUS_USERENTRY);
	else
		self.canMaintainTasks(_proxyWorkOrder.taskStatus);
	endif;
	
epilog

end;</source>
        <Parameter name="_parent" type="CM_BaseForm"/>
        <Parameter name="_proxyWorkOrder" type="CM_WorkOrder"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_selectedTask" type="CM_WorkOrderDtl"/>
        <Parameter name="_workOrderType" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="loadCargoTaskDetails" id="d3718192-01e9-4fbc-8077-8142691cd0e6">
        <updating/>
        <source>loadCargoTaskDetails(_taskType : Integer)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 March 2022		navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
29 Mar 2023 		navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
03 Oct 2023 		navhl20 Bug 60373: MTN - Expected to see a validation message to save the changes before closing the work order form.
03 Oct 2023 		navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
13 Oct 2023			navhl20 Bug 60868: EUP- Work Order New Form has  issues on Remarks Textbox and High Priority Checkbox
30 Jul 2024 		navhl20	ChangeRequest 65468: EUP -  VAS Mobile App - Enable Remarks for ToDo Tasks on Cargo Work Orders
22 Oct 2024 		navbs1	Bug MTN-19889: MTN - Pack Work Order - Pack Container Not Being refreshed
*/

vars
	
begin
	self.fldCargo.visible := true;
	
	self.clearSheets();
	
	self.setParentAspect(true);		//03.10.2023 navhl20 #60373
	
	if self.hasVasSubscription then		//30.07.2024 navhl20 #65468
		self.setTodoDetails(true);
	else
		self.setTodoDetails(false);		//13.10.2023 navhl20 #60868
	endif;
	
	if _taskType = WO_TASK_RELEASE then
		self.loadTabCargoRelease();
	elseif _taskType = WO_TASK_MOVE then
		self.loadTabCargoMove();
	elseif _taskType = WO_TASK_TODO then
		self.loadTabCargoToDo();
		//06 Apr 2022 navgm20  TFS #52351   START
	elseif _taskType = WO_TASK_PACK then
		self.loadTabCargoPack();
	elseif _taskType = WO_TASK_UNPACK then
		self.loadTabCargoUnPack();
	elseif _taskType = WO_TASK_RECEIVE then
		self.loadTabCargoReceive();
	elseif _taskType = WO_TASK_RELEASEEXTENSION  then
		self.loadTabCargoRelExtension();
	elseif _taskType = WO_TASK_CHANGEVOYAGE  then
		self.loadTabCargoNullVoyage();
	elseif _taskType = WO_TASK_EXPORTRETURN  then
		self.loadTabCargoBlank();
		
	endif;
	
	self.tblSelectedCargo.clearAllData();																//22.10.2024 navhl20 #19889
		
	/*if _taskType = WO_TASK_PACK then																	//03.10.2023 navhl20 #60033
		self.tblSelectedCargo.height := 150;
	else
		self.tblSelectedCargo.height := 320;
	endif;
	//self.btnCreateCargo.top := self.tblSelectedCargo.height + self.tblSelectedCargo.top + 10;			//29.3.2023 navhl20	#55443[54991]*/

epilog

end;</source>
        <Parameter name="_taskType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadEmailController" id="53a1f211-8e24-4355-85c2-6656ff364b1e">
        <updating/>
        <source>loadEmailController()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
15 Feb 2023 navma1 ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars

begin
	create self.myEmailController transient;

	self.chkSendEmail.value 	   := self.myPxyWorkOrder.emailNotification;
	
	if self.chkSendEmail.value = true then
		self.txtEmail.visible := true;
		self.btnEmail.visible := true;
		self.doAddUserEmail();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadItemTable" id="4292a9ae-9bed-406a-b889-935d03d0d9ff">
        <source>loadItemTable(_item : Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 January 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
27 June 2023	navlw1	ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders

*/

vars
	table			: CM_DataTable;
	idx				: Integer;
	booking 		: CM_BookingRefItem;
	bol				: CM_BOLDtl;
	reserveDetail	: CM_ReserveDetail;
begin 
	table := self.tblItems;
	table.clearAllData();

	if _item = null then
		table.rows := 1;
		return;
	endif;	

	if _item.isKindOf(CM_BookingRef) then
		table.setMyDataClass(CM_BookingRefItem);
		foreach booking in _item.CM_BookingRef.allBookingRefItems do
			idx := table.updateItemObject(booking, self.colorRow1, self.colorRow2, app.myPassport);
		endforeach;
	elseif _item.isKindOf(CM_BulkRelease)then
		table.setMyDataClass(CM_ReserveDetail);
		foreach reserveDetail in _item.CM_BulkRelease.allReserveDetails do
			idx := table.updateItemObject(reserveDetail, self.colorRow1, self.colorRow2, app.myPassport);
		endforeach;
	else
		table.setMyDataClass(CM_BOLDtl);
		foreach bol in _item.CM_BOLIn.allBOLDtls do
			idx := table.updateItemObject(bol, self.colorRow1, self.colorRow2, app.myPassport);
		endforeach;
	endif;
	
	//table.allSelectedObjects.clear;
epilog

end;</source>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="loadTabCargoBlank" id="1711a246-4851-4e19-aa4a-b2317f7a44c2">
        <updating/>
        <source>loadTabCargoBlank() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
07 April 2022	navukv20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
28/07/2022		navcs2		Bug 54319: MTN - Work Order - Export Return task details tab showing as Blank
*/

vars

begin
	if self.myPxyTask = null then
		return;
	endif;
	
	self.shtBlank.visible		:= false;
	self.shtToDoTasks.visible	:= false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabCargoMove" id="21b9b08c-65ce-4675-b65e-d5c72189fe9d">
        <updating/>
        <source>loadTabCargoMove()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/03/2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
03/08/2022	navcs2	Bug 54407: MTN - Work Order Maintenance - Inappropriate To Terminal Area List when To Terminal Area Type hasn't been Selected
*/

vars
	ta		: CM_TerminalArea;
	tType   : CM_TerminalAreaType;
	type	: Integer;
	lc		: CM_LocationsController;
begin
	
	self.shtMove.visible		:= true;
	self.shtToDoTasks.visible	:= false;
	self.fldCargo.topSheet  	:= self.shtMove;
	self.grpMove.enabled		:= not self.isApproved;

	if self.myPxyTask &lt;&gt; null and self.myPxyTask.CM_WodMove.myTargetLocation &lt;&gt; null   then
		ta   	:= self.myPxyTask.CM_WodMove.myTargetLocation.myTerminalArea;
		tType	:= ta.myType;
		type 	:= ta.type; 
		lc      := self.myPxyTask.CM_WodMove.myTargetLocation;
	else
		type := TA_TYPE_NULL;
	endif;
	
	self.myAssistant.comboBoxTAType(self.cmbTerminalAreaType,tType, true);	
	
	// 03/08/2022	navcs2	Bug 54407
	if type &lt;&gt; TA_TYPE_NULL then
		self.myAssistant.comboBoxTerminalArea(self.cmbTerminalArea, type, ta);	
		self.cmbTerminalArea.lostFocus(self.cmbTerminalArea);
	endif;
	
	if lc&lt;&gt; null  then
		if self.cmbYardLocation.findObject(lc) &gt; 0 then
			self.cmbYardLocation.listObject := lc;
		endif;
	endif;
	
	self.chkMoveAutoQueue.value := self.myPxyTask.autoQueueTask;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabCargoNullVoyage" id="a4734a55-660e-4b8b-9b31-8fb88d780c14">
        <updating/>
        <source>loadTabCargoNullVoyage() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
07 April 2022	navukv20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin
