		_controller.logEntry(" Resetting CargoType.myWeightMeasurementType") ;	
	endif;
	
	beginTransaction;
	foreach cargoType in CM_CargoType.instances do
		if cargoType.isBulkMulti then
			//Leave these ones alone
		else
