    <JadeMethod name="tblReleases_keyDown" id="8b3975da-c5ec-4faa-b0d5-feb64c88927d">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReleases_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2011	cnwndl1	Initial creation	Par 28367

*/

vars

	origValueInteger : Integer;

begin

	if table.userInputEnabled
	and table.row &gt; table.fixedRows
	and shift = 0
	and keyCode = J_key_Tab then
		origValueInteger := table.rows;
		//if at the end of the last row then a new row will be added
		self.doQueryRowColumnChange(table, table.row+1);
		if table.rows &gt; origValueInteger then
			//A new row has been added, reset key code
			//To prevent jade from re-setting the column
			keyCode := 0;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
