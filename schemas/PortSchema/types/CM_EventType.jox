end;</source>
    </JadeMethod>
    <JadeMethod name="getCategoryIntegerFromString" id="d24c2c46-8062-4f23-830a-6d5eb45c62f8">
        <source>getCategoryIntegerFromString( _catString : String ):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 October 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	if _catString = app.getErrorString(System_event) then
		return SYSTEM_EVENT;
	elseif _catString = app.getErrorString(Warning_error_event) then
		return WARNING_EVENT;
	elseif _catString =  app.getErrorString(Train_event) then
		return TRAIN_EVENT;
	endif;
	
	return 0;
	
epilog

end;</source>
        <Parameter name="_catString" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCategoryString" id="794ec2d4-59d1-4d97-b3b6-2e10935ce2df">
        <source>getCategoryString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Oct 2009	cnwndl1	Initial creation	Par 21519
31 Oct 2022 navma1  ChangeRequest 56636[54258]: EUP - Adding New Event Type for VAS TodoTask Description

*/

vars

begin
	if self.category = SYSTEM_EVENT then
		return app.getErrorString(System_event);
	elseif self.category = WARNING_EVENT then
		return app.getErrorString(Warning_error_event);
	elseif self.category = TRAIN_EVENT then
		return app.getErrorString(Train_event);
	elseif self.category = VOYAGE_EVENT then
		return app.getErrorString(Voyage_event);
	elseif self.category = TRUCK_EVENT then
		return app.getErrorString(Truck_event);
	elseif self.category = WAGON_EVENT then
		return app.getErrorString(Wagon_event);
	elseif self.category = LOCATION_EVENT then					 //14 Apr 2021	NDL	TFS 50906
		return app.getErrorString(Location_activity);
	elseif self.category = VBS_EVENT  then						//31.10.2022 navma1 #56636[54258]
		return app.getErrorString(Vbs_event);
	elseif self.category = NONOPS_EVENT then					//31.10.2022 navma1 #56636[54258]
		return app.getErrorString(Nonops_event);
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="f74a4ac4-94c9-4600-a57e-b9a28690f1a5">
        <source>getDisplayDetails(_short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

begin
	return self.name;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="871385e2-a762-4025-b1d5-cbe2c47f1ccb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 October 2009	cnwndl1	Initial creation	Par 21519
29 July 2022	jlizm1	TFS 54165 EDI Voyage Events

*/

vars

begin

	if _attrName = ETRow_Category then
		return getCategoryString;
	elseif _attrName = ETRow_SystemAction then
		return null;
	elseif _attrName = ETRow_EventType then
		return self.name;
	elseif _attrName = ETRow_Completed then
		return null;
	elseif _attrName = ETRow_MyVoyageDelay  then	//24 Aug 2018	NDL	TFS 
		if self.myDelayTypeToCreate &lt;&gt; null then
			return self.myDelayTypeToCreate.description;
		endif;
		return null;
	elseif _attrName = ETRow_WeightMeasureType then	// TFS 54165
		if self.myWeightType &lt;&gt; null then
			return self.myWeightType.name;
		endif;
		return null;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextTypeInteger" id="c8cc8795-37f5-4c25-8368-c98e28dade2c">
        <source>getNextTypeInteger(): Integer;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	eventTypeDict 	: CM_EventTypeByTypeDict;
	eventType		: CM_EventType;
begin
	eventTypeDict := app.myRoot.allEventTypesByType;
	eventType := eventTypeDict.last;
	
	if eventType = null then	
		return EVT_MAX_JMT + 1;
	else
		if eventType.type &lt; EVT_MAX_JMT then
			return EVT_MAX_JMT +1;
		else
			return eventType.type +1;
		endif;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
