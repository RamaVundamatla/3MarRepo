		return false;
	endif;
	
	create tiSet transient;
	self.myTrackedItem.CM_TILC.getAllOnboardTIs(tiSet);
	
	create consigneeNorSet transient;
	
	foreach ti in tiSet do	
		consigneeNorSet.tryAddIfNotNull(ti.myConsignee);	
		consigneeNorSet.tryAddIfNotNull(ti.myConsignee);	
	endforeach;
	
	foreach consingeenor in consigneeNorSet do
		if _yaData.matches(consingeenor) then
			return true;
		endif;
	endforeach;
	
	return false;
	

epilog
