    <JadeMethod name="doSave" id="3e823fc8-d70e-4906-9a33-f674bc331009">
        <updating/>
        <source>doSave( _doNext : Boolean )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393
10/02/2017 		cnwrh7     TFS3303      #Error on adding time slot to Vehicle Booking Template
*/

vars

	start : Time;
	proxy : CM_VehicleBookingTimeTemplate;
	remarks : String;
	duration : Integer;
	numSlots : Integer;
	newTimeTemp : CM_VehicleBookingTimeTemplate;
	theReturn : Integer;
	loadState : Boolean;
	nextTimeTemplate : CM_VehicleBookingTimeTemplate;
	msg : String;
	tsType : CM_VehicleBookingTimeSlotType;

begin

	if not self.doValidate() then
		return;
	endif;
	
	if self.myTimeTemplate &lt;&gt; null and _doNext then
		nextTimeTemplate := self.myDayTemplate.allTimeTemplates.getNext( self.myTimeTemplate );
	endif;
	
	start := self.txtTimeStart.getTime();
	duration := self.txtDuration.text.Integer;
	numSlots := self.txtNumSlots.text.Integer;
	remarks := self.txtRemarks.text.trimBlanks;
	//20 Oct 2014	NDL	Par 35008
	if self.cmbTSType.listIndex &gt; 1 then 
		tsType := self.cmbTSType.itemObject[self.cmbTSType.listIndex].CM_VehicleBookingTimeSlotType;
		if tsType.notAvailableForEntry then
			msg := app.getErrorString1( Marke_not_avail_entry_will_cle, tsType.description );
			app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only );
			self.cmbTSType.listIndex := -1;
			tsType := null;
			return;
		endif;
	endif;
	
	if self.myTimeTemplate = null then
		create proxy transient;
	else
		app.cmsBeginLoad(loadState);
		proxy := self.myTimeTemplate.pxyCreateUpdateProxy().CM_VehicleBookingTimeTemplate;
		app.cmsEndLoad(loadState);
	endif;
	
	
	proxy.setProxy(	duration,	//_duration : Integer;
					numSlots,	//_numberOfSlots : Integer;
					remarks,	//_remarks : String;
					start,	//_startTime : Time;
					self.myDayTemplate,	//_myDayTemplate : CM_VehicleBookingDayTemplate
					tsType	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType	//01 Oct 2014	NDL	Par 35008
					);
					
	while true do
		if self.myTimeTemplate = null then
			app.myTrxCA.trxCreateVehicleTimeTemp(proxy, newTimeTemp, app.myPassport);
		else
			app.myTrxUA.trxUpdateVehicleTimeTemp(proxy, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_time_templat), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	if not _doNext then
		//just pressed save
		self.unloadForm;
		
	elseif not app.myPassport.trxCompletedOK then
		// pressed 'Next' but got an error
		return;
		
	elseif ( self.myTimeTemplate = null  and newTimeTemp &lt;&gt; null ) then
		//created a new one and want to create the next one.
		if newTimeTemp.endTime &lt; newTimeTemp.startTime then
			// must have gone past midnight
			msg := "No 'next' to add, gone past midnight.";
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only);
			self.unloadForm;
			return;
		endif;
		self.txtTimeStart.setTime( newTimeTemp.endTime );
		duration := self.txtDuration.text.Integer;
		numSlots := self.txtNumSlots.text.Integer;
		remarks := self.txtRemarks.text.trimBlanks;   
		if self.cmbTSType.listIndex &gt;1 then 																																			//+TFS3303 index invalid UE
			tsType := self.cmbTSType.itemObject[self.cmbTSType.listIndex].CM_VehicleBookingTimeSlotType;	//20 Oct 2014	NDL	Par 35008
			if tsType.notAvailableForEntry then																																		//+TFS3303
				msg := app.getErrorString1( Marke_not_avail_entry_will_cle, tsType.description );
				app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only );
				self.cmbTSType.listIndex := -1;
				tsType := null;
				return;
			endif;
		endif;
		self.myParentForm.CMUI_VehicleBookDayTemplate.initTblTimes();
	
	elseif nextTimeTemplate &lt;&gt; null then
		//updated an existing one and wants to update the next one.
		self.myTimeTemplate := nextTimeTemplate;
		self.txtTimeStart.setTime( self.myTimeTemplate.startTime );
		self.txtDuration.text := self.myTimeTemplate.duration.String;
		self.txtNumSlots.text := self.myTimeTemplate.numberOfSlots.String;
		self.txtRemarks.text := self.myTimeTemplate.remarks;
		if self.myTimeTemplate.myVBTimeslotType &lt;&gt; null then	//20 Oct 2014	NDL	Par 35008
			self.cmbTSType.listIndex := self.cmbTSType.findObject( self.myTimeTemplate.myVBTimeslotType );
		else
			self.cmbTSType.listIndex := -1;
		endif;
		
		self.myParentForm.CMUI_VehicleBookDayTemplate.initTblTimes();
		
	elseif nextTimeTemplate = null and newTimeTemp = null and _doNext then
		// was updating has run out of existing
		if self.myTimeTemplate.startTime &lt; self.myTimeTemplate.endTime then
			//not past midnight yet, so ask if they want to swap into creating additional ones
			msg := "No more to update, do you want to start adding  from " &amp; self.myTimeTemplate.endTime.asStringJMT &amp; "?";
			if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No) = MsgBox_Return_No then
				self.unloadForm;
				return;
			endif;
		else
			msg := "No more Time Templates to update.";
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only);
			self.unloadForm;
			return;
		endif;
		
		self.txtTimeStart.setTime( self.myTimeTemplate.endTime );
		self.setMyTemplates( self.myDayTemplate, null );
		duration := self.txtDuration.text.Integer;
		numSlots := self.txtNumSlots.text.Integer;
		remarks := self.txtRemarks.text.trimBlanks;
		tsType := self.cmbTSType.itemObject[self.cmbTSType.listIndex].CM_VehicleBookingTimeSlotType;	//20 Oct 2014	NDL	Par 35008
		
		self.myParentForm.CMUI_VehicleBookDayTemplate.initTblTimes();
		
	endif;
	
epilog

	delete proxy;
	app.cmsEndLoad(loadState);

end;</source>
        <Parameter name="_doNext" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidate" id="8e42d906-d394-4f2c-90f1-2dab57f8c3ac">
        <source>doValidate():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393
6 July 2022 navtnr20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
20 Dec 2022	navak20 Task 55978: EUP - VBS MTN - [1] - VBS Slot Types - Review Changes
*/

vars
	vbsProcess : CM_VBSProcess;		// 20.12.2022 navak20 TFS 55978
begin
	//Start 20.12.2022 navak20 TFS 55978
	if self.myTerminal &lt;&gt; null then
		vbsProcess := self.myTerminal.getMyVBSProcess();
	endif;
	//End 20.12.2022 navak20 TFS 55978
	
	//if self.myTerminal.getMyVBSProcess().isVbsSlotValidation and self.cmbTSType.listIndex = -1 then	//5.07.2022	navtnr20 TFS 53697	// 20.12.2022 navak20 TFS 55978
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation and self.cmbTSType.listIndex = -1 then		// 20.12.2022 navak20 TFS 55978
		//app.raiseCMException(Slot_type_should_mandato,null,null);
		app.msgBox( app.getErrorString(Slot_type_should_mandato), app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	if self.myDayTemplate = null then
		app.msgBox( app.getErrorString(No_Vehicle_visit_Day_template), app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;

	
	if self.txtDuration.text.Integer &lt; 1 then
		app.msgBox( app.getErrorString(Duratio_must_minute_more),  app.getErrorString(Error), MsgBox_OK_Only);
		self.txtDuration.setFocus();
		return false;
	endif;
	
	if self.txtNumSlots.text.Integer &lt; 1 then
		app.msgBox( app.getErrorString(Number_bookin_slots_must_great),  app.getErrorString(Error), MsgBox_OK_Only);
		self.txtDuration.setFocus();
		return false;
	endif;

	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCmbTSType" id="6646475a-2af5-43b6-839a-c20ff0944c65">
        <source>populateCmbTSType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2014	cnwndl1	Initial creation	Par 35008
21 Jun 2022 navsrk20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
*/

vars

	tsType : CM_VehicleBookingTimeSlotType;
	index : Integer;
	term  : CM_Terminal;		//21.06.2022 navsrk20 TFS 53697

begin

	self.cmbTSType.clear();
	self.cmbTSType.addItem( null );
	
	term := self.myTerminal;		//21.06.2022 navsrk20 TFS 53697
	
	//foreach tsType in app.myRoot.allVehicleBookingTSTypes do		//21.06.2022 navsrk20 TFS 53697
	foreach tsType in term.allTerminalVBSSlotTypes do				//21.06.2022 navsrk20 TFS 53697
		index := self.cmbTSType.addItem( tsType.description );
		self.cmbTSType.itemObject[index] := tsType;
		if tsType.notAvailableForEntry then
			self.cmbTSType.itemEnabled[index] := false;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="ab396f59-bffc-40f4-9196-2c168862dcd9">
        <updating/>
        <source>setCorrectComboStyle() updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
11 June 2024	navab1	BUG 64462
*/

vars

begin
	inheritMethod();

	self.cmbTSType.style := 2;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTemplates" id="4e4671d1-0816-4614-af75-71ccd65fffaa">
        <updating/>
        <source>setMyTemplates( dayTemp : CM_VehicleBookingDayTemplate; timeTemp : CM_VehicleBookingTimeTemplate ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	
	self.myTimeTemplate := timeTemp;
	if timeTemp &lt;&gt; null then
		self.myDayTemplate := timeTemp.myVehicleBookingDayTemplate;
	else
		self.myDayTemplate := dayTemp;
	endif;
	
	if self.myDayTemplate &lt;&gt; null then
		if timeTemp = null then
			self.lblDayTemplate.caption := self.myDayTemplate.name &amp; " - " &amp; app.getErrorString(Add_Mode);
		else
			self.lblDayTemplate.caption := self.myDayTemplate.name &amp; " - " &amp; app.getErrorString(Update_mode);
		endif;
	else
		if timeTemp = null then
			self.lblDayTemplate.caption := app.getErrorString(Add_Mode);
		else
			self.lblDayTemplate.caption := app.getErrorString(Update_mode);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="dayTemp" type="CM_VehicleBookingDayTemplate"/>
        <Parameter name="timeTemp" type="CM_VehicleBookingTimeTemplate"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e62ea154-ff2e-4f55-a6c5-7b8191a8ff99">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393
23 june 2022 navtnr20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars

begin

	inheritMethod();
	
	self.populateCmbTSType();
	self.lblDayTemplate.visible := false;	//24.06.2022	navtnr20 TFS 53697
	if self.myTimeTemplate &lt;&gt; null then
		self.txtTimeStart.setTime( self.myTimeTemplate.startTime );
		self.txtDuration.text := self.myTimeTemplate.duration.String;
		self.txtNumSlots.text := self.myTimeTemplate.numberOfSlots.String;
		self.txtRemarks.text := self.myTimeTemplate.remarks;
		if self.myTimeTemplate.myVBTimeslotType &lt;&gt; null then	//20 Oct 2014	NDL	Par 35008
			self.cmbTSType.listIndex := self.cmbTSType.findObject( self.myTimeTemplate.myVBTimeslotType );
		else
			self.cmbTSType.listIndex := -1;
		endif;
		
	else
		self.txtTimeStart.setTime( null );
		self.txtDuration.text := "1";
		self.txtNumSlots.text := "1";
		self.txtRemarks.text := null;
		self.cmbTSType.listIndex := -1;	//20 Oct 2014	NDL	Par 35008
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="acdd3ce6-7e05-4ec5-9fef-642bc756180f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 October 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018893, locale);
	btnCancel.translateCaption(Xlat_0018894, locale);
