    <JadeMethod name="getAPIEndpoint" id="b8bf8c05-40dc-42ad-bf2f-70086dbae297">
        <source>getAPIEndpoint(): CM_Endpoint;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2024	jlier1	Initial creation

*/

vars
	endPoint : CM_Endpoint;
	endPointName, lastEndPointNoun: String;
	postStart,pos : Integer;
begin
	if self.requestName = null then
		return null;
	endif;
	
	if self.myExtWebserviceDef = null or self.myExtWebserviceDef.allEndpoints.isEmpty then
		return null;
	endif;
	
	postStart:=self.requestName.pos("POST",1);
	if postStart &lt;= 0 then
		return null;
	endif;
	
	endPointName:=self.requestName[postStart+5:end];
	
	
	foreach endPoint in self.myExtWebserviceDef.allEndpoints do
		pos :=1;
		lastEndPointNoun:=endPoint.endpoint.reverse.scanUntil('/', pos).reverse();
	
		if lastEndPointNoun = endPointName then
			return endPoint;
		endif;
	endforeach;
	
	return null;
	

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Endpoint"/>
    </JadeMethod>
