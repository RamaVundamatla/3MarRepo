    <JadeMethod name="listRequests" id="3675d6be-7afd-4344-8903-13582e718b87">
        <source>listRequests();
/*
Purpose:			
Date		Who		Reason
02 August 2011	cnwab1	Initial creation
*/

vars
	req : CM_VoyageRequest;
begin
	foreach req in self.allRequests discreteLock do
		if req.isKindOf(CM_ROROSlotRequest) then
			if req.CM_ROROSlotRequest.mySlotRequestAft &lt;&gt; null then
				app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' REQ: ' &amp; req.CM_ROROSlotRequest.myROROController.ident &amp; " AFT SLOT:" &amp; req.CM_ROROSlotRequest.mySlotRequestAft.myROROController.ident);
			else
				app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' REQ: ' &amp; req.CM_ROROSlotRequest.myROROController.ident &amp; " AFT SLOT: NULL" );
			endif;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="needsAftRequest" id="6714d2e4-5c55-440a-b761-6e99dd55583c">
        <source>needsAftRequest() : Boolean;
// ---------------------------------------------------------------------------
// Created:     27 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 01 Jun 2010		cnwkpd1			PAR #24345 - fixed 1090 error found in testing
// ---------------------------------------------------------------------------

vars
	criteria, criteriaISO, criteriaISOGRP : CM_YACriteria;	
	isoGrp : CM_ISOTypeGroup;
	iso : CM_ISOType;
begin
	// ##### IS FORTY
	criteria := self.getCriteriaOfTypeValue(YACriteriaType_IsForty);
	if criteria &lt;&gt; null and criteria.myYAData.CM_YADataBoolean.value =  CM_YADataBoolean.VALUE_TRUE then
		return true;
	else
		criteriaISOGRP := self.getCriteriaOfTypeValue(YACriteriaType_ISOGroup); // PAR 23817 CHECK ISO GROUP
		
		if criteriaISOGRP &lt;&gt; null then
			isoGrp := criteriaISOGRP.myYAData.CM_YADataObjects.allObjects.first().CM_ISOTypeGroup;
			if isoGrp &lt;&gt; null then
				if isoGrp.is40ftLong() then return true;
		//		elseif isoGrp.is30ftLong() then return true;
				elseif isoGrp.is30ftLong() then return false;	//22 Jun 2020	NDL	TFS 49408
				elseif isoGrp.is45ftLong() then return true;
				elseif isoGrp.is53ftLong() then return true;
				endif;
			endif;
		endif;
		criteriaISO := self.getCriteriaOfTypeValue(YACriteriaType_ISO); // PAR 23817 CHECK ISO 
		if criteriaISO &lt;&gt; null then
			iso := criteriaISO.myYAData.CM_YADataObjects.allObjects.first().CM_ISOType;	// KPD 01/06/2010
			if iso &lt;&gt; null then
				if iso.is40ftLong() then return true;
			//	elseif iso.is30ftLong() then return true;
				elseif iso.is30ftLong() then return false;	//22 Jun 2020	NDL	TFS 49408
				elseif iso.is45ftLong() then return true;
				elseif iso.is53ftLong() then return true;
				endif;
			endif;
		endif;

		// ##### IS THIRTY
		criteria := self.getCriteriaOfTypeValue(YACriteriaType_IsThirty);
		if criteria &lt;&gt; null and criteria.myYAData.CM_YADataBoolean.value =  CM_YADataBoolean.VALUE_TRUE then
		//	return true;
			return false;	//22 Jun 2020	NDL	TFS 49408
		else
		// ##### IS FORTY FIVE
			criteria := self.getCriteriaOfTypeValue(YACriteriaType_IsFortyFive);
			if criteria &lt;&gt; null and criteria.myYAData.CM_YADataBoolean.value =  CM_YADataBoolean.VALUE_TRUE then
				return true;
			else
				// ##### IS FIFTY THREE
				criteria := self.getCriteriaOfTypeValue(YACriteriaType_IsFiftyThree);
				if criteria &lt;&gt; null and criteria.myYAData.CM_YADataBoolean.value =  CM_YADataBoolean.VALUE_TRUE then
					return true;
				endif;
			endif;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeNonconfigCriteria" id="10a5c734-cede-42f3-bc2a-cf8cc623e14f">
        <source>removeNonconfigCriteria(_voyage : CM_Voyage);
// ---------------------------------------------------------------------------
// Created:     19 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars


	yaCriteria : CM_YACriteria;
	voyYAConfig : CM_VoyageAllocationConfig;
begin
		// remove the criteria that this voyage is not interested in...
		voyYAConfig := _voyage.allVoyageAllocationConfigs.first.CM_VoyageAllocationConfig;
		if voyYAConfig &lt;&gt; null then
			if voyYAConfig.allOpCriteria &lt;&gt; null then
				foreach yaCriteria in self.allCriteria do
					if yaCriteria.myYACriteriaType.type = YACriteriaType_ImexStatus then
						continue;
					endif;
					if not voyYAConfig.allOpCriteria.includes(yaCriteria.myYACriteriaType) then
//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. Remove ' &amp; yaCriteria.myYACriteriaType.description);
						delete yaCriteria;
					endif;
				endforeach;
			endif;
		endif;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromTemplate" id="e8ead3ba-6b35-4035-a157-6b5a79feee01">
        <updating/>
        <source>setForCreateFromTemplate(_voyageAllocation: CM_VoyageAllocation; _terminal: CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2009	cnwas3	Initial creation

*/

vars

begin
	self.setForUpdate(_voyageAllocation);
	self.allCriteria.purge();
	// Clone criteria using special method.
	self.cloneCriteria(_voyageAllocation);

epilog

end;</source>
        <Parameter name="_voyageAllocation" type="CM_VoyageAllocation"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateColour" id="f45cbd6c-8b64-4186-bd4d-d724adf822e5">
        <source>setForUpdateColour();
/*
Purpose:			
Date		Who		Reason
04 August 2011	cnwab1	Initial creation
*/

vars
	voyReq : CM_VoyageRequest;
begin

	foreach voyReq in self.allRequests discreteLock do
		voyReq.setColourFromAllocation(self, voyReq.quantity);
