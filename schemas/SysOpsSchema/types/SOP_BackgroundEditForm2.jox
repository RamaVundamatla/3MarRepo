    <JadeMethod name="setAutoWarning" id="97c8ea62-7407-4946-8504-6bd2f566c973">
        <source>setAutoWarning(_cmif : CMIF_BGPManagerChildren input) : Boolean protected;
// --------------------------------------------------------------------------------
// Created:		24 February 2006 by cnwdad1
//
// Purpose:		Updates the proxy data object with the user-selected details.
//
// Parameters:	_cmif - A reference to the proxy data object.
//
// Returns:		True if the update is successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	itemObj		: Object;
	warning		: CM_AutoWarningItem;
	inputBox 	: CMUI_InputBox;
	
begin
	_cmif.allAutoWarningItems.clear();
	
	foreach itemObj in tblWarnList.allSelectedObjects do
		warning := itemObj.CM_AutoWarningItem;
		_cmif.allAutoWarningItems.add(warning);
		// CCMS 1556
		if warning.className = CM_WebSiteConfig.name then
			create inputBox;
			inputBox.setAssistantAndTerminalRefs(self.myAssistant, CM_Terminal.firstInstance);
//			inputBox.init(app.getErrorString(LBLWebConfig), app.getErrorString(LBLPleaseEnterWebConfigName),	// cnwrl1 05/06/2009 PAR 19574 - what it was
//			warning.webSiteConfigName, 30, TextBox.DataType_AlphaNumeric, false);								// cnwrl1 05/06/2009 PAR 19574 - what it was
			inputBox.init(	app.getErrorString(LBLWebConfig), app.getErrorString(LBLPleaseEnterWebConfigName),
							warning.webSiteConfigName, 30, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, false);
			
			app.mousePointer	:=	Idle;
			inputBox.showModal;
			if inputBox.modalResult &lt;&gt; IDOK then
				//self.clearErrorWarnings();
				return false;
			else
				warning.setWebSiteConfigName(inputBox.txtInput.text.trimBlanks());
				app.mousePointer	:=	Busy;
			endif;
		endif;
	endforeach;
	
	_cmif.cellAddress	:=	fieldCellAddress.getString();
	_cmif.cellNumbers	:=	fieldCellNumbers.getString();
	
	return true;

epilog
	delete inputBox;
end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBackupJournal" id="d5753f2b-b1b4-4b61-9fd6-f40f17db36dd">
