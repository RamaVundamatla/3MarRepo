    <JadeMethod name="lstHazardList_lostFocus" id="cb7036fb-4163-4a35-bfa9-874e724988fc">
        <controlMethod name="CMUI_HazardsListTable::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
