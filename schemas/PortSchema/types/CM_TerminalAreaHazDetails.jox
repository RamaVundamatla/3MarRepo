    <JadeMethod name="setProxy" id="f536617c-1995-48c5-a273-0bc3b8a08a45">
        <updating/>
        <source>setProxy(	_id : String; 
			_colour : Integer; 
			_hazClass : CM_HazardClass;
			_flashPoints : CM_HazTempRangeByValueDict;
			_packingGroups : StringArray;
			_acidBase : String;
			_allowNonHaz : Boolean; 
			_showError : Boolean; 
			_allLCs : CM_LCArray; 
			_terminalArea : CM_TerminalArea	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars

begin
	self.id := _id;
	self.colour := _colour;
	self.myHazardClass := _hazClass;
	self.allHazTempRanges.clear;
	_flashPoints.copy(self.allHazTempRanges);
	self.packingGroups.clear;
	_packingGroups.copy(self.packingGroups);
	self.acidBase := _acidBase;
	self.allowNonHazardous := _allowNonHaz;
	self.showError := _showError;
	
	self.myTerminalArea := _terminalArea;
	
	self.allLocationsControllers.clear;
	_allLCs.copy(self.allLocationsControllers);
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_hazClass" type="CM_HazardClass"/>
        <Parameter name="_flashPoints" type="CM_HazTempRangeByValueDict"/>
        <Parameter name="_packingGroups" type="StringArray"/>
        <Parameter name="_acidBase" type="String"/>
        <Parameter name="_allowNonHaz" type="Boolean"/>
        <Parameter name="_showError" type="Boolean"/>
        <Parameter name="_allLCs" type="CM_LCArray"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
