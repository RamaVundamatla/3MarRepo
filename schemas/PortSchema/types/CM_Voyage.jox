    <JadeMethod name="status" id="88beaee7-eba8-4fe9-8247-d9b55b7a3fbe">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>status(set: Boolean; _value: Integer io) mapping, updating;
//--------------------------------------------------------------
//Created: 29 November 2002 By: cnwgd1
//--------------------------------------------------------------
//01 Apr 2014	cnwrs1	Par 35963 coil not being produced as it is mising transdate and camsDateTime
//21/03/2018	jlgdap1	TFS 37445 PEL1 Voyage Status Security
//31/08/2022	jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process
vars
	vstatus : CM_VoyageStatus;			// TFS 37445
	sendOpsView : Boolean;
begin

	if set then
		/*  epr TFS 41523 2/11/18 too much status changes happens automatically can't not expect users to have all the statuses and
		should not stop the automatic update
		
		if not self.isVoyageInlandTerminal()						// TFS 37445
		and self.myVoyageGlobalArrival = null then					// MAP 5/9/18 TFS40672
			vstatus := app.myRoot.allVoyageStatuses [_value];		// TFS 37445
			if vstatus &lt;&gt; null and self.myTerminal &lt;&gt; null then		// TFS 37445
				if not vstatus.userCanSet(self.myTerminal) then		// TFS 37445
					app.raiseCMException2(Cannot_Set_Voyage_Status, self.myTerminal.code, vstatus.description, "status", null);	// TFS 37445
					return;											// TFS 37445
				endif;												// TFS 37445
			endif;													// TFS 37445
		endif;														// TFS 37445
		*/
		

		if self.isUsingDefaultProcessJMT then // ### TFS 53105 02JUN2022 NAVAB1
			if _value &lt;&gt; self.status and _value = Voyage_Status_Loading then // ### TFS 53105 02JUN2022 NAVAB1 changing to LOADING
				sendOpsView := true; // ### TFS 53105 16JUN2022 NAVAB1
				
			endif;
		else
			if _value &lt;&gt; self.status // changing
			and self.status &lt; Voyage_Status_VoyageArrived // previously prior to arrived
			and _value &gt;= Voyage_Status_VoyageArrived // now arrived but not departed
			and _value &lt; Voyage_Status_VesselDeparted then // ### TFS 53105 02JUN2022 NAVAB1 
				sendOpsView := true; // ### TFS 53105 16JUN2022 NAVAB1
			
			endif;
		endif;
		
		self.status := _value;
		if self.status = Voyage_Status_Archived then
			self.archived := true;
		else
			self.archived := false;
		endif;
		if self.status = Voyage_Status_Departed or self.status = Voyage_Status_EUP_Departed then
			self.setVoyDepartureCAMSTimeStamp();
		endif;
		
		if sendOpsView then // ### TFS 53105 16JUN2022 NAVAB1
		
			self.sendCargoToOpsView(); // ### TFS 53105 16JUN2022 NAVAB1
		endif;

	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
