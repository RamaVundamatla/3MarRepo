    <JadeMethod name="initTaxCodesTable" id="4a5acebe-6392-4eca-bd04-5617d38c546c">
        <source>initTaxCodesTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars

	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_DataTable;
	
begin
	theTable := self.tblInvTable;
	
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	
	entTableDef := app.myController.getEntTableDef(ETDef_InvChargeTaxOverride);
	theTable.setTblDataEntRowsFromDef(entTableDef);

	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllErrorWarnings" id="42161f8c-ad8a-4606-9d4e-ab2c958e4c96">
        <updating/>
        <source>setAllErrorWarnings(_passport : CM_Passport) updating;

/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	err	: CM_Error;
	
begin

	if _passport = null then
		return;
	endif;
	
	self.allErrorWarnings.purge;
	self.addAllErrorWarnings(_passport);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setProxyChargeTax" id="6411e4bf-776f-4965-ba5f-b0bd92597c15">
        <updating/>
        <source>setProxyChargeTax(_theCharges : CM_ChargeByServiceTaxOvrdDict input;_theService: CM_Service; _taxCodeCurrent:CM_TaxCode; 
					_currentlyOverridden: Boolean; _items: Integer; _taxCodeNew : CM_TaxCode; _isReinstateTax : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	pxyCharge        :  CM_Charge;
	keyService       :  CM_Service;
	keyOverridden,
	releaseTax       :  Boolean;
	keyRate          :  Real;
	taxCodeCurrent,
	taxCodeNew 		 : CM_TaxCode;
	count            : Integer;
	chargeIterator   : Iterator;

begin
	releaseTax := _isReinstateTax;
	taxCodeNew := _taxCodeNew;
	
	chargeIterator := _theCharges.createIterator;
	while chargeIterator.next(pxyCharge) do
	
		
		if pxyCharge.service = _theService then
			_theCharges.remove(pxyCharge);
			if releaseTax and not _currentlyOverridden then
				pxyCharge.setProxyTaxRelease();
			elseif taxCodeNew &lt;&gt; null and (taxCodeCurrent = null or taxCodeCurrent.code &lt;&gt; taxCodeNew.code) then
				pxyCharge.setProxyTaxNew(taxCodeNew);
			endif;
			count := count + 1;
		endif;

		if count = _items then
			break;
		endif;

	endwhile;
epilog
	delete chargeIterator;
end;</source>
        <Parameter name="_theCharges" type="CM_ChargeByServiceTaxOvrdDict" usage="input"/>
        <Parameter name="_theService" type="CM_Service"/>
        <Parameter name="_taxCodeCurrent" type="CM_TaxCode"/>
        <Parameter name="_currentlyOverridden" type="Boolean"/>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_taxCodeNew" type="CM_TaxCode"/>
        <Parameter name="_isReinstateTax" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="61594321-61e6-43a8-a0c8-28721d8c93fe">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars

begin
	inheritMethod();
	
	if not app.getMyUser().canDo(self.myTerminal,PmInvTaxOverrideMaint) then
		self.disableObjects();
	endif;
	
	self.handleMenusForModalDisplay();
	self.caption:= app.getErrorString(Tax_Code_Override);
	self.initTaxCodesTable();
	self.displayTaxCode();
	self.doBuildTaxCodeCombo();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4b4bd4d1-31d8-4886-b2ae-b0a928e3aba4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 November 2022 09:29:18.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025210, locale);
	btnClose.translateCaption(Xlat_0025211, locale);
	btnOverrideTaxCode.translateCaption(Xlat_0025212, locale);
	btnRemoveOverride.translateCaption(Xlat_0025213, locale);
	btnSaveChanges.translateCaption(Xlat_0025214, locale);
	lblNewTaxCode.translateCaption(Xlat_0025215, locale);
end;</source>
    </JadeMethod>
</GUIClass>
