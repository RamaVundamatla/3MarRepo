    <JadeMethod name="colourRows" id="356e7d06-3553-4b97-8558-8a4ac0212cd1">
        <updating/>
        <source>colourRows(_colour1: Integer; _colour2: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		13 March 2007 by cnwdad1
//
// Purpose:		Colours the receiver's alternate rows using the colours specified by
//				the two parameters.  This method was promnoted from the CM_DataTable
//				subclass.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	backColour	: Integer;
	maxRow		: Integer;
	startRow	: Integer;
	rowPointer	: Integer;
	
begin
	maxRow		:=	self.rows;
	startRow	:=	self.fixedRows + 1;
	
	foreach rowPointer in startRow to maxRow do
		if rowPointer mod 2 = 0 then
			backColour	:=	_colour1;
		else
			backColour	:=	_colour2;
		endif;
		
		self.accessRow(rowPointer).backColor	:=	backColour;
	endforeach;
end;</source>
        <Parameter name="_colour1" type="Integer"/>
        <Parameter name="_colour2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="filterRowHasAllText" id="a0e77461-d6c4-45ec-8913-c5dd56c88672">
        <updating/>
        <source>filterRowHasAllText(_allText : HugeStringArray; _numOfRows : Integer output) updating;
/*

Purpose:	This method shows rows that contain string in _allText

Parameters:			

Return Value:		

Date		Who		Reason
18/04/2024	navkc1 CR63736 Task 63737: Jade - New Filter Control
*/

vars
	cellText	: String;

	row			: Integer;
	start		: Integer;
	totalRows	: Integer;
	totalCols	: Integer;
	col			: Integer;
	filterText	: String;
	found		: Boolean;
	exclude		: Boolean;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	_numOfRows := 0;
	
	if self.rows = 0 then
		return;
	endif;
	
	start := self.fixedRows + 1;
	totalRows := self.rows;
	
	if _allText.isEmpty() then
		foreach row in start to totalRows do
			self.accessRow(row);
			_numOfRows += 1;
			self.accessedRow.visible := true;
		endforeach;
		self.topRow := 1;
		return;
	endif;
	
	totalCols := self.columns;
	// Filter table
	foreach row in start to totalRows do : rowLoop
		self.accessRow(row);
			foreach filterText in _allText do : textLoop
				exclude := false;
				filterText := filterText.toUpper().trimBlanks;
				
				// "!2" becomes "2", and exclude any row that has "2" in it.
				if filterText.length() &gt; 1 and filterText[1] = ExclaimationMark then
					exclude := true;
					filterText := filterText[2:end];
				endif;
				foreach col in 1 to totalCols do : cellLoop
					
					found := false;
					
					cellText := self.accessCell(row, col).text.toUpper();
					
					if cellText = null then
						continue;
					endif;
					
					if cellText.pos(filterText, 1) &gt; 0 then
						found := true;
						if exclude then
							self.accessedRow.visible := false;
						else
							_numOfRows += 1;
							self.accessedRow.visible := true;
						endif;
						continue rowLoop;
					endif;
				endforeach;
				// if "!2" and the row doesn't contain "2", display it.
				if exclude and not found then
					_numOfRows += 1;
					self.accessedRow.visible := true;
					continue rowLoop;
				endif;
			endforeach;
		self.accessedRow.visible := false;
	endforeach;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_allText" type="HugeStringArray"/>
        <Parameter name="_numOfRows" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="filterRowHasText" id="51a77b5c-ae60-47e1-ae26-8cabec8e2d67">
        <updating/>
        <source>filterRowHasText(_text : String) updating;
/*

Purpose:	This method shows rows that contain "_text"

Parameters:			

Return Value:		

Date		Who		Reason
27/07/2023	navkc1	Bug 57701: FR | 54538 - EUP - Filtered Drop-downs and Lists - Find lists filter
08/09/2023	navkc1	CR 60429 Task 60446: UI - Cargo Review UI Changes - FIlter and Totals
*/

vars
	cellText	: String;

	row			: Integer;
	start		: Integer;
	totalRows	: Integer;
	totalCols	: Integer;
	col			: Integer;
	filterText	: String;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	if self.rows = 0 then  //02/10/2023	navkc1	CR 60423 Task 60763
		return;
	endif;
	
	start := self.fixedRows + 1;
	totalRows := self.rows;
	filterText := _text.toUpper(); //08/09/2023	navkc1	CR 60429 Task 60446
	
	// Clear filter, display all rows;
	if filterText = null then
		foreach row in start to totalRows do
			self.accessRow(row);
			self.accessedRow.visible := true;
		endforeach;
		self.topRow := 1;
		return;
	endif;
	totalCols := self.columns;
	// Filter table
	foreach row in start to totalRows do : rowLoop
		self.accessRow(row);
		
		foreach col in 1 to totalCols do : cellLoop
			cellText := self.accessCell(row, col).text.toUpper();
			
			if cellText.length() &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.accessedRow.visible := true;
				continue rowLoop;
			endif;
		endforeach;
		self.accessedRow.visible := false;
	endforeach;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastVisibleColumn" id="ccb5e7d5-9813-4d48-954f-39b8b05f460e">
        <source>getLastVisibleColumn() : Integer;
/*

Date		Who		Reason
06 September 2016	cnwer1	Initial creation TFS 2606

*/

vars
	col,
	lastVisibleColumn : Integer;
	
begin
	col := self.columns;
	while col &gt; 0 do
		if self.columnVisible[col] then
			return col;
		endif;		
		col := col -1;
	endwhile;	
	
	return col;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="row2FilterApplyFilters" id="b81bff4b-3d43-438f-8ee8-6ea1364d8e9a">
        <updating/>
        <source>row2FilterApplyFilters( pCombo : CMUI_ComboBox ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2014	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	colIndex : Integer;
	filterCombo : CMUI_ComboBox;
	filterString : String;

begin

	self.row2FilterShowAllRows;
	
	if self.rows &lt; 3 then
		return;
	endif;
	
	foreach colIndex in 1 to self.columns do
		filterCombo := pCombo.getControl(colIndex);
		if filterCombo &lt;&gt; null then
			filterString := filterCombo.text;
			if filterString = self.AllValues then
				continue;
			endif;
			foreach rowIndex in 3 to self.rows do
				if not self.accessRow(rowIndex).visible then
					continue;
				endif;
				if self.accessCell( rowIndex, colIndex ).text &lt;&gt; filterString then
					self.accessRow(rowIndex).visible := false;
				endif;
			endforeach;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="pCombo" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="row2FilterGetValues" id="fdb44c2a-4a86-4faa-acdb-c60007b15569">
        <updating/>
        <source>row2FilterGetValues( pCombo : CMUI_ComboBox; _colIndex : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2014	cnwndl1	Initial creation

*/

vars

	combo : CMUI_ComboBox;
	rowIndex : Integer;
	startIndex : Integer;
	strArray : StringArray;
	str : String;

begin

	combo := pCombo.getControl( _colIndex ).CMUI_ComboBox;
	
	combo.clear();

	startIndex := self.fixedRows + 2;
	
	if startIndex &gt; self.rows then
		return;
	endif;
	
	create strArray transient;
	
	if startIndex &lt;= self.rows then
		foreach rowIndex in startIndex to self.rows do
			str := self.accessCell( rowIndex, _colIndex).text.trimBlanks;
			if not strArray.includes( str ) then
				strArray.add( str );
			endif;
		endforeach;
	endif;
	
	combo.sorted := true;
	
	foreach str in strArray do
		combo.addItem(str);
	endforeach;
	
	combo.sorted := false;
	
	combo.addItemAt(self.AllValues,1);
	combo.addItemAt(self.ClearFilters,2);

epilog

	delete strArray;

end;</source>
        <Parameter name="pCombo" type="CMUI_ComboBox"/>
        <Parameter name="_colIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="row2FilterSetup" id="211f06db-688a-4411-adcd-6f71a4ddcde0">
        <updating/>
        <source>row2FilterSetup( pCombo : CMUI_ComboBox input; firstTime : Boolean ) updating;
/*

Purpose:			

Parameters:		testing filtering.		

Return Value:		

Date		Who		Reason
30 September 2014	cnwndl1	Initial creation

*/

vars

	colIndex : Integer;
	startCol : Integer;
	cell : JadeTableCell;
	cellCombo : CMUI_ComboBox;
	existingValue : String;
	index : Integer;

begin

	if firstTime then
		//we need to add the filter criteria row 
		self.addItemAt( null, 2 );
		self.accessRow(2).backColor := self.accessCell(1,1).backColor;
		self.accessRow(2).inputType := Table.InputType_ComboBox;
	endif;
	
	startCol := self.fixedColumns + 1;
	
	self.accessMode := Table.AccessMode_Cell;
	if startCol &lt;= self.columns then
		foreach colIndex in startCol to self.columns do
			cell := self.accessCell(2,colIndex);
			cell.inputType := Table.InputType_TextBox;
			cellCombo := pCombo.getControl(colIndex).CMUI_ComboBox;
			if cellCombo = null then
				cellCombo := pCombo.loadControl(colIndex).CMUI_ComboBox;
				cell.cellControl := cellCombo;
				cellCombo.backColor := Table.Pink;
				existingValue := Table.AllValues;
			else
				existingValue := cellCombo.text;
			endif;
			self.row2FilterGetValues( pCombo, colIndex );	
			cellCombo.listIndex := cellCombo.findStringExact(1,existingValue);
			if cellCombo.listIndex &lt; 1 then
				cellCombo.listIndex := 1;
			endif;
			cell := self.accessCell(2,colIndex);
			cell.text := cellCombo.text;
		endforeach;
	endif;
	
	if not firstTime then
		self.row2FilterApplyFilters( pCombo );
	endif;

epilog

end;</source>
        <Parameter name="pCombo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="firstTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="row2FilterShowAllRows" id="195b29e8-b905-411c-8b05-f3a65c18cb4f">
        <updating/>
        <source>row2FilterShowAllRows() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2014	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;

begin

	foreach rowIndex in 1 to self.rows do
		self.accessRow(rowIndex).visible := true;
	endforeach;

epilog

end;</source>
    </JadeMethod>
</GUIClass>
