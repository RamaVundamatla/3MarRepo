    <JadeMethod name="pxyCreateUpdateProxy" id="5eeb3706-fd58-42e3-86b3-9bb75186e56c">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			Creates an Update proxy and populates references

Parameters:			NONE

Return Value:		SelfType The proxy proxy to use for updating

Date		Who		Reason
22 February 2022	navpw1	Initial creation TFS: 52752

*/

vars
	pxy : SelfType;
	
begin
	pxy 			:= inheritMethod();
	pxy.myInvoice 	:= self.myInvoice;
	return pxy;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0396370d-aa33-4bca-bb7e-ba386055e6c5">
        <updating/>
        <source>setForCreate(_proxyInvoiceNote: CM_InvoiceNote) updating;
/*

Purpose:			Sets our real object, we are creating, to our proxy objects values

Parameters:			_proxyInvoiceNote	CM_InvoiceNote	The Proxy invoice note we need to set our object up from

Return Value:		NONE

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

begin
	self.myInvoice		:= _proxyInvoiceNote.myInvoice;
	self.internalOnly 	:= _proxyInvoiceNote.internalOnly;
	self.note 			:= _proxyInvoiceNote.note;

end;</source>
        <Parameter name="_proxyInvoiceNote" type="CM_InvoiceNote"/>
    </JadeMethod>
