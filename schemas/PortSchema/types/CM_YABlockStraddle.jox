    <JadeMethod name="setGridObjects" id="95f647b6-0c35-4d63-ad03-ac15e54f997a">
        <updating/>
        <source>setGridObjects() updating;
// -------------------------------------------
// Created 20 May 2005 by cnwdvb1
// -------------------------------------------
vars

	gridRow	: CM_GridRow;

begin
	inheritMethod();

	self.allGridObjects.clear();
	gridRow := self.getGridRow();
	if gridRow &lt;&gt; null then
		self.allGridObjects.add(gridRow);
	endif;

end;</source>
    </JadeMethod>
