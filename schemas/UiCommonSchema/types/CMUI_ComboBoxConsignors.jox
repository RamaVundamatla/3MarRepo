    <PrimAttribute name="isDisplayByName" id="3c4749d6-2fda-4d05-bd62-6fb8dbd8544c">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="displayEntry" id="c50ddbba-ccb8-44cc-a831-67b9690aa9e0">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _con : CM_ConsigneeConsignor; lstIndex: Integer): String updating, clientExecution;
//17 February 2010	cnwml2
//16 June 2022		navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP

vars
	failedDAC  :CM_DataAccessController;
	invalid : Boolean;
	str : String;
begin
	if _con = null then
		return null;
	endif;
	on Exception do app.handleDeletedObject(exception, _con, invalid);
	str := _con.code;
	if invalid then
		return null;
	endif;

	if (not _con.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	if _con.isNotAvailableForEntry then
		if self.myObject &lt;&gt; _con then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
	
	//if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then	// TFS 53362
	if self.isDisplayByName then	//18 Oct 2013	NDL	Par 32594			// TFS 53362
		return _con.getDescriptionTabCode;
	else
		return _con.code &amp; Tab &amp; _con.description;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_con" type="CM_ConsigneeConsignor"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="bf872259-fc9f-45bc-8c9c-84d56097c5ad">
        <source>getCollectionJMT(): Collection protected;
//17 February 2010	cnwml2
//+cnwml2 PAR22371

vars

	con : CM_ConsigneeConsignor;
begin
	self.allConsignors.clear();
	foreach con in app.myRoot.allConsigneeConsignors do
		if con.isConsignor then
			self.allConsignors.add(con);
		endif;
	endforeach;
	return self.allConsignors;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getListUpdateStatus" id="c5ba696c-81e2-4836-95b0-891c1d62c798">
        <source>getListUpdateStatus(): Boolean;
//18 February 2010	cnwml2
//+cnwml2 PAR22371

vars

begin
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="ef7e0254-459f-48f2-be27-a3a614601104">
        <updating/>
        <source>init() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/06/2022	navdap1		Initial creation TFS 53362 EUP Master Data interface customers between TOS and ERP
//
vars

begin
	inheritMethod();

	self.isDisplayByName := app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean;
	if self.isDisplayByName then
		self.sorted := true;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setObject" id="b1eb8fd7-e6d6-42b8-afef-8cbac3ebf638">
        <updating/>
        <source>setObject(_value: Object) updating;
//17 February 2010	cnwml2
//+cnwml2 PAR22371

vars

	value : Object;
begin
	value := _value;
	if value &lt;&gt; null then
		if not self.getCollectionJMT.includes(_value) then
			app.msgBox(app.getErrorString2(InvalidSettings, app.getString(CM_Consignor), value.CM_ConsigneeConsignor.code), app.getString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			value := null;
		endif;
	endif;
	
	inheritMethod(value);

epilog

end;</source>
        <Parameter name="_value" type="Object"/>
    </JadeMethod>
