    <PrimAttribute name="receivingCompanyCode" id="afd18510-8163-4920-9279-227493a84c11">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="canUpdateTransaction" id="aa051b10-49b3-4cd5-8a8b-05030c4e8677">
