        <updating/>
        <source>utlUpdateTIToDoTaskRemBulk(_toDoTaskDesc : CM_ToDoTaskDesc;
							_allTIs 	: CM_TISet;
							_passport 	: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	ti				: CM_TrackedItem;

begin
	app.setContinueCMExceptions(false);
	
	if _allTIs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_allTIs set", null, null);
	endif;
	
	if _toDoTaskDesc = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_toDoTaskDesc", null, null);
	endif;
	
	if _toDoTaskDesc.description = null then
		app.raiseCMException1(ERR_TODOTASK_ADD, 'Task has a null description (' &amp; _toDoTaskDesc.description &amp; '). This operation cannot proceed.', null, null);
