    <JadeMethod name="setForDelete" id="8850ba6e-0975-4a08-9320-23652bd63e6c">
        <updating/>
        <source>setForDelete(_reason: String) updating;
//----------------------------------------------------------------
//	Created:	02 December 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_reason);
	
	if self.myTrackedItem = null then
		return;
	endif;
	//PAR 6825
	self.myTrackedItem.removePreTripDetails();

epilog

end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="6e3b84fa-a1f0-4177-9b1c-c2de98507956">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;

vars
	trans : CM_TITransaction;
begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	if not self.myTrackedItem.isKindOf(CM_Container) then
		return;
	endif;
	
	self.myTrackedItem.CM_Container.updatePreTripDT();

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
