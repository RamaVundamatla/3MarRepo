    <JadeMethod name="actionForApproved" id="cb49741c-6a3d-4fc2-9423-d5e8d3d5824e">
        <updating/>
        <source>actionForApproved(_voyage : CM_Voyage input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/07/2018	jlgdap1		Initial creation TFS 39815 PEL1 WO Approved Set Voyage Status
//
vars
	status : CM_VoyageStatus;

begin
	
	if not self.validateRequiresLengthOfTime() then	//27 Jul 2018	NDL	TFS 39932
		return; // TFS 39932
	endif;
	
	status := self.getStatusForApproved(_voyage);
	if status &lt;&gt; null then
		_voyage.setStatusFromObject(status);
	endif;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
