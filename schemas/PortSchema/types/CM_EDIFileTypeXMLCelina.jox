<Class name="CM_EDIFileTypeXMLCelina" id="52c4a9b5-f787-4825-9883-92bf5c537ee8">
    <superclass name="CM_EDIFileTypeXML"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This is the file we send to Polish Customs Celina system</text>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="db211363-32e4-40dc-b7d6-b3767db2b31d">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
vars

begin
	self.name := "Polish Customs Celina";
	self.type := EDIFileType_XML_Celina;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractFile" id="72298817-6b84-419c-97c7-18595e8fae98">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile io; _number: Integer; _recipient: CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
/*

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
///15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
*/
constants
	HDR1 : String = '&lt;?xml version="1.0" encoding="WINDOWS-1250"?&gt;';
//	HDR2 : String = "";
//	EOT : String = "";
vars
	xlOperator : CM_Operator;
	voyageOid : CM_Voyage;
	now : TimeStamp;
	terminal : CM_Terminal;
	fileStr	: String;
	strTime	: String;
	ediData	: CM_EDIData;
	str : String;
	ediTI : CM_EDIBayPlanTI;
	lastEDITI : CM_EDIBayPlanTI;
	dynaDict : DynaDictionary;
	iter : Iterator;
	bolID : String;
	carNum : Integer;
	carStrArray : StringArray512;
	bolWeight : Decimal[14,4];
	filePath : String;
	lineStr : String;
begin

	terminal := app.myPassport.myTerminal;
	ediData := _ediFile.ediData;
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	strTime := now.date.shortYearEDI() &amp; now.time.shortFormatEDI();

	if (not CM_EDIDataBayPlan.hasInstance(ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, ediData.class.name, null, null);
		return;
	endif;
	
	if xlOperator = null and _recipient &lt;&gt; null then
		xlOperator := _recipient;
	endif;

	create carStrArray transient;
	create dynaDict transient;
	dynaDict.setMembership(CM_EDIBayPlanTI);
	dynaDict.addMemberKey(CM_EDIBayPlanTI::bol.name, false, true);
	dynaDict.addMemberKey(CM_EDIBayPlanTI::id.name, false, true);
	dynaDict.endKeys(true);
	_ediFile.ediData.allEDITrackedItems.copy(dynaDict);
	iter := dynaDict.createIterator();
	lineStr := lineStr &amp; HDR1 &amp; CrLf;
	while iter.next(ediTI) do
		if bolID = null then //firstTime thru
			bolID := ediTI.bol;
		endif;
		if ediTI.bol &lt;&gt; bolID then //changeOf bol
			lineStr := lineStr &amp; self.writeFile(carStrArray, _ediFile, lastEDITI, bolWeight);
			carStrArray.clear();
			carNum := 0;
			bolWeight := 0;
		endif;
		carNum := carNum + 1;
		str := self.getCarDetails(ediTI.CM_EDIBayPlanTI, carNum);
		carStrArray.add(str);
		bolWeight := bolWeight + ediTI.weight;
		bolID := ediTI.bol;
		lastEDITI := ediTI;
	endwhile;
	_ediFile.setNumContainers(ediData.allEDITrackedItems.size);
	if carStrArray.size &gt; 0 then //write out final bol
		lineStr := lineStr &amp; self.writeFile(carStrArray, _ediFile, lastEDITI, bolWeight);
		carStrArray.clear();
		carNum := 0;
		bolWeight := 0;
	endif;
	_ediFile.setRawDataString(lineStr);
epilog
	delete iter;			// PAR #26678
	delete dynaDict;		// PAR #26678
	delete carStrArray;		// PAR #26678
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="a5e73ebc-8316-4a43-af6a-7fd4640eb647">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
vars

begin
	_ediDataClass := CM_EDIDataBayPlan;
	_dataType := EDIDataType_BayPlan;
	_fileTypeCode := self.type;

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getBOLDetails" id="70886929-209c-41ae-b8f8-9f97008c7ec5">
        <source>getBOLDetails(_ediTI : CM_EDIBayPlanTI; _carNum: Integer; _bolWeight : Decimal) : String protected;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------

vars
	str : String;
begin
	str := _ediTI.getPolishCustomsConsignorXML(_carNum, _bolWeight);
	return str;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDIBayPlanTI"/>
        <Parameter name="_carNum" type="Integer"/>
        <Parameter name="_bolWeight" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBOLTail" id="b22345d4-362d-4d3f-89c2-2439d2863a33">
        <source>getBOLTail(_ediTI : CM_EDIBayPlanTI) : String protected;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------

vars
	str : String;
	now : TimeStamp;
begin
	str := '&lt;MiejsceData Miejsce="GDANSK" Data="'&amp;now.date.format('yyyy-MM-dd')&amp;'" NazwiskoImie="WWL"/&gt;'&amp;CrLf;
	str := str &amp; '&lt;/DeklaracjaSkrocona&gt;';
	return str;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDIBayPlanTI"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCarDetails" id="375a86f8-33c6-4dd2-bc5c-b40d498b7f30">
        <source>getCarDetails(_ediTI : CM_EDIBayPlanTI; _numCar : Integer) : String protected;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------

vars
	str : String;
begin
	str := '&lt;Kontener PozId="'&amp;_numCar.String&amp;'" Nr="'&amp;_ediTI.id&amp;'"&gt;';
	str := str &amp; '&lt;Zamkniecie PozId="1" Ilosc="1" Nr="L802936"/&gt;';
	str := str &amp; '&lt;/Kontener&gt;';
	return str;
end;

</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDIBayPlanTI"/>
        <Parameter name="_numCar" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="be19c643-271a-4775-a714-66be890c1b79">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2025	navkc1	JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return self.EDI_Bundle_CUSTOM;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPath" id="79da8892-b3ae-4f94-b920-639d1b15d382">
        <source>getPath(_fileName : String) : String;

vars
	str : String;
	pos : Integer;
begin
	pos := _fileName.reversePos("\");
	if pos &gt; 0 then
		str := _fileName[1:pos - 1]&amp;"\";
	endif;
	return str;
end;
</source>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="writeFile" id="bc42423a-fe4b-47ee-bc1d-804df57b9b91">
        <source>writeFile(_strArray : StringArray; _ediFile : CM_EDIFile io; _ediTI : CM_EDIBayPlanTI; _bolWeight : Decimal) : String;
//
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
constants
	HDR1 : String = '&lt;?xml version="1.0" encoding="WINDOWS-1250"?&gt;';
vars
	file : File;
	filePath : String;
	fileStr : String;
	str : String;
begin
	create file transient;
	filePath := self.getPath(_ediFile.fileName);
	file.mode := File.Mode_Output;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := filePath&amp;_ediTI.bol&amp;'.xml';
	if file.isAvailable then
		file.purge;
	endif;
	file.open();
	// Header
	file.writeLine(HDR1);
	fileStr := '&lt;DS xmlns="http://www.krakow.uc.gov.pl/Celina/CLN-XML/xsd/DSw2r0.xsd" EmailPodmiotu="ops@intermarine.com.pl"&gt;';
	str := str &amp; fileStr;
	file.writeLine(fileStr);
	fileStr := self.getBOLDetails(_ediTI, _strArray.size, _bolWeight);
	str := str &amp; fileStr;
	file.writeLine(fileStr);
	foreach fileStr in _strArray do
		str := str &amp; fileStr &amp; CrLf;
		file.writeLine(fileStr);
	endforeach;
	fileStr := self.getBOLTail(_ediTI);
	str := str &amp; fileStr;
	file.writeLine(fileStr);
	fileStr := '&lt;/DS&gt;';
	str := str &amp; fileStr;
	file.writeLine(fileStr);
	file.close();
	return str;
epilog
	file.close();
	delete file;
end;
</source>
        <Parameter name="_strArray" type="StringArray"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_ediTI" type="CM_EDIBayPlanTI"/>
        <Parameter name="_bolWeight" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
