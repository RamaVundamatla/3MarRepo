<Class name="CM_WOVoyageToDoRequest" id="69500a59-7dff-489d-b3ae-f59efc71f391">
    <superclass name="CM_WOToDoRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ExplicitInverseRef name="allVoyages" id="1b955dfc-d0df-48da-a30f-54e4103ecc18">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_VoyageSet"/>
        <access>readonly</access>
        <Inverse name="CM_Voyage::allWorkOrderRequests"/>
    </ExplicitInverseRef>
    <JadeMethod name="createWLEs" id="8457c5ff-af84-4e1f-b860-28e056dff0d2">
        <source>createWLEs();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	aWLE			:	CM_WOVoyageToDoWLE;
	voyage			:	CM_Voyage;
	voyIter			:	Iterator;
begin
	voyIter := self.myJob.CM_WOToDoVoyageJob.allVoyages.createIterator();
	
	while voyIter.next(voyage) do
		create aWLE persistent;
		aWLE.setForCreate(self.myJob, self); 
		aWLE.setMyVoyage(voyage);
	endwhile;
	
epilog
	delete voyIter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="858ee544-b4b0-4f4b-a30a-b78103507fae">
        <updating/>
        <source>setForCreateInternal(_myJob: CM_WOToDoTaskJob; _toDoInternalJobParam: CMIF_WorkOrderJobParams) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin
	inheritMethod(_myJob, _toDoInternalJobParam);
	
	self.myJob.CM_WOToDoVoyageJob.allVoyages.copy(self.allVoyages);
epilog

end;</source>
        <Parameter name="_myJob" type="CM_WOToDoTaskJob"/>
        <Parameter name="_toDoInternalJobParam" type="CMIF_WorkOrderJobParams"/>
    </JadeMethod>
</Class>
