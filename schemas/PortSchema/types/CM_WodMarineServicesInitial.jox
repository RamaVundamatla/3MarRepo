    <JadeMethod name="getAuditChildSubjects" id="e334b66d-011b-4440-9fb8-870547cf97c5">
        <source>getAuditChildSubjects(_childAuditSubjectNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2019	jlger1	Initial creation 43546

*/

