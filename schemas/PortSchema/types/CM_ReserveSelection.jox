    <JadeMethod name="getRollingLength" id="47064fb9-2921-47e4-a1d9-f8c7f03d9e7f">
        <source>getRollingLength(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2024	navnk30	Bug 66204: EUP | 53308 - 1011 error when using and dimensions field in the Grouping criteria URGENT

*/

vars
	relCriteria			: CM_ReleaseByTypeCriteria;
	rollLengthCriteria	: CM_YACriteria;
begin
	relCriteria := self.myReleaseCriteria;
	if relCriteria = null then
		return 0;
	endif;
	rollLengthCriteria :=relCriteria.getCriteriaFor(YACriteriaType_RollingLength);
	if rollLengthCriteria = null or rollLengthCriteria.myYAData = null then
		return 0;
	endif;
	return rollLengthCriteria.myYAData.CM_YADataString.value.Decimal;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
