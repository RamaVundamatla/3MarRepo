        <source>contextMenu(frame: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	shpForm : SHP_BulkVoyagePlanningForm;
	
begin
	shpForm := self.form.SHP_BulkVoyagePlanningForm;	
	return shpForm.doContextMenuBuild(frame, conwin, mouse, x, y);

epilog

end;</source>
