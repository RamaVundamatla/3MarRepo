    <JadeMethod name="getDetailForBol" id="4fcfa2d5-f56a-47a6-ab06-e75f88a921fe">
        <source>getDetailForBol(_version : Integer): String;

vars
	extraV5,
	response,
	volume,
	weight	:	String;

begin
	if _version &gt;= 5 then
		extraV5 := self.fellDate.formatAsYYYYMMDD() &amp; ',' &amp;		// CCMS 1082
			self.scalerCode &amp; ',' ;	// CCMS 1082
	endif;
	return	extraV5 &amp; 
			self.gangNumber &amp; ',' &amp;
			self.logSpeciesCode &amp; ',' &amp;
			self.logGradeCode &amp; ',' &amp;
			self.logTypeCode &amp; ',' &amp; 
			self.logTreatmentCode &amp; ',' &amp; 
			self.lengthCode &amp; ',' &amp; 
			self.jasVolume.jasVolumeString();

end;</source>
        <Parameter name="_version" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="22874a36-9d85-40b9-9cbb-8e3a29c59c51">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 13 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rtStr,
	type,
	treatment : String;
begin

	if _attrName = ETRow_Specifications then
		rtStr := self.getSpecsDisplayStr();		
		return rtStr;
	elseif _attrName = ETRow_NumberOfLifts then
		return self.numberOfLifts.String;
	elseif _attrName = ETRow_JasVolume then
		return self.jasVolume.asStringJMTWithPrecision(3, true);
	elseif _attrName = ETRow_LengthRandom then
		return self.getSpecLength();
	elseif _attrName = ETRow_ScalerCode then
		return self.allScalerCodes.asCSV(false);


// ### TAKE OUT THIS for kernal overflow
	elseif   _attrName = ETRow_IsHazardous then // AKB2005MAR added during testing
		return null;
		
		
		
		
		
		
	elseif _attrName = ETRow_LogLocation then
		if self.myBOL.isKindOf(CM_BOLIn) then
			return self.myBOL.CM_BOLIn.origLocationControllerId;				
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLogLocations" id="f72e8203-9267-46b9-8211-2bd40dd0e9de">
        <source>getLogLocations(_set : CMIF_DocketLogDefByLocation input; _class : Class; _terminal : CM_Terminal);

vars
	log			: CM_Log;
	location	: CM_LocationsController;
	tmpDef		: CMIF_DocketLogDef;
	iter		: Iterator;
	coll		: Collection;
	obj			: Any;


begin

	coll := self.myBOL.getTICollectionForTerminal(_terminal);

	iter := coll.createIterator;
	while iter.next(obj) do
		log := obj.CM_Log;
		location := log.getPrimaryLocation(REAL_MODE);
		if location &lt;&gt; null and location.isKindOf(_class) then
			tmpDef := _set.getAtKey(location.getID(), location, log.myOperator, log.speciesCode, log.gradeCode, log.typeCode, log.treatmentCode, log.lengthCode, log.isNoNumber, self.myBOL);
			if tmpDef = null then
				create tmpDef transient;
				tmpDef.init(location, log.myOperator, log.speciesCode, log.gradeCode, log.typeCode, log.treatmentCode, log.lengthCode, log.isNoNumber, 0, 0, self.myBOL);
				_set.add(tmpDef);
			endif;
			if not tmpDef.allTi.includes(log) then
				tmpDef.addTi(log, true);
			endif;
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_set" type="CMIF_DocketLogDefByLocation" usage="input"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getProductCode" id="c94c79ef-0b96-4179-b7b0-8c07393add7a">
        <source>getProductCode() : String;
//--------------------------------------------------------------
//Created: 10 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return app.buildLogProductCode(logSpeciesCode, logGradeCode, logTypeCode, logTreatmentCode, lengthCode);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSpecLength" id="016be8f3-4a35-40ac-9e22-b763180fad9c">
        <source>getSpecLength() : String;
// -----------------------------------------------------------------------------
// Created:		04 July 2002 by cnwka1
//
// Purpose:		used in Jade Report Writer
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return self.logSpeciesCode &amp; self.lengthCode;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSpecsDisplayStr" id="d436ac8e-4223-4d1d-8be1-c74f65db1473">
        <source>getSpecsDisplayStr() : String;
// ---------------------------------------------------------------------------
// Created:     29 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
//19/02/2009 cnwdz2 par 18586
	return self.logSpeciesCode &amp; ':' &amp; 
		   self.logGradeCode &amp; ':' &amp; 
		   self.logTypeCode &amp; ':' &amp; 
		   self.logTreatmentCode &amp; ':' &amp; 
		   self.lengthCode;		

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasUnscaledLogs" id="4b07ceca-c78b-4cb0-9fd5-3c013ae3c63a">
        <source>hasUnscaledLogs() : Boolean;
//--------------------------------------------------------------
//Created: 20 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	log : CM_Log;
begin
	if not self.myBOL.allTrackedItems.isEmpty then
		log := self.myBOL.allTrackedItems.first.CM_Log;
		if log.isUnscaled then
			return true;
		else
			return false;
		endif;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myLogGrade" id="85c0b83f-9008-49e2-824a-60bf8f186b35">
        <methodInvocation>mapping</methodInvocation>
        <source>myLogGrade(set: Boolean; _value: CM_LogGrade io) mapping;
// -----------------------------------------------------------------------------
// Created:		12 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 29 Mar 2017	cnwkpd1		TFS 3369 - Push Events application - invalid object exceptions
// -----------------------------------------------------------------------------
vars
	prod		: CM_Product;
	invalid		: Boolean;
	
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);	
	else
		prod := self.myBOL.myProduct;
		if prod &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, prod, invalid);
			_value := prod.CM_ProductLog.myLogGrade;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_LogGrade" usage="io"/>
    </JadeMethod>
