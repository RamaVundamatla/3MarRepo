    <JadeMethod name="cnEcBinaryView" id="ba7c8922-ccd6-4360-8907-9572c7191fcd">
        <source>cnEcBinaryView(pDescription:String; pBinaryData:Binary; pAllowEditing:Boolean):Binary;
// --------------------------------------------------------------------------------
// Created:		02 May 1999 by cnwdad1
//
// Purpose:		Searches for a disk file(s).
//
// Parameters:	pBinaryData (Binary) - The binary data to be viewed/edited.
//				pAllowEditing (Boolean) - Indicated whether the binary data can be edited.
// Returns:		Binary - The (edited) binary (returns null when viewing).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	hexFormObj		: CnEcHexViewerForm;
	returnBinary	: Binary;

begin
	if pBinaryData &lt;&gt; null then
		create hexFormObj;
		hexFormObj.setBinaryData(pBinaryData);
		hexFormObj.setAllowEditing(false);		//(pAllowEditing);
		hexFormObj.setDataDescription(pDescription);
		hexFormObj.showModal();

		if pAllowEditing then
			returnBinary	:=	hexFormObj.getBinaryData();
		else
			returnBinary	:=	null;
		endif;
	endif;
epilog
	return returnBinary;
end;</source>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pBinaryData" type="Binary"/>
        <Parameter name="pAllowEditing" type="Boolean"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAllChildControls" id="c1feabf5-640d-4709-9aec-f9c3dc90e80c">
        <source>cnEcGetAllChildControls(pAllChildControls: CnEcControlArray io; pIsGetTheirChildren: Boolean);
// --------------------------------------------------------------------------------
// Refer to the Window class abstraction for a description etc.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlIndex		: Integer;
	numberOfControls	: Integer;
	controlObj			: Control;
	
begin
	pAllChildControls.clear();
	numberOfControls	:=	self.controlCount;
	
	foreach controlIndex in 1 to numberOfControls do
		controlObj	:=	self.controls(controlIndex);
		
		if controlObj.parent = self then
			pAllChildControls.add(self.controls(controlIndex));
			
			if pIsGetTheirChildren then
				controlObj.cnEcGetAllChildControls(pAllChildControls, pIsGetTheirChildren);
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="pAllChildControls" type="CnEcControlArray" usage="io"/>
        <Parameter name="pIsGetTheirChildren" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcKeyDown" id="08e23408-dceb-4a21-8ee2-ae548acdb0f9">
        <source>cnEcKeyDown(pKeyCode: Integer io; pShift: Integer);
// --------------------------------------------------------------------------------
// Created:		13 December 2005 by cnwdad1
//
// Purpose:		Standard BaseSchema implementation of the Form::keyDown event.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pKeyCode = CNEC_KEY_F12 then
		if pShift.cnEcIsCtrlKey() then
			if pShift.cnEcIsShiftKey() then
				self.cnEcShowContents();
			else
				self.cnEcShowGuiInfo();
			endif;
		elseif pShift.cnEcIsAltKey() then
			self.cnEcListInUseBy();
		endif;
	endif;
end;</source>
        <Parameter name="pKeyCode" type="Integer" usage="io"/>
        <Parameter name="pShift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcListInUseBy" id="a38ad570-ecdd-4d3d-a6c6-39bddf5460b8">
        <source>cnEcListInUseBy() protected;
// --------------------------------------------------------------------------------
// Created:		28 May 2009 by cnwdad1
//
// Purpose:		Writes out a list of which users/processes have the receiver in use.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	schemaObj		: Schema;
	classObj		: Class;
	pos				: Integer;
	len				: Integer;
	inuseString		: String;
	processObj		: Process;
	invalidProcess	: Boolean;
	
begin
	classObj	:=	self.class;
	
	if classObj = null then
		write "Class not found!";
		return;
	endif;
	
	schemaObj	:=	classObj.rootType().schema;
	
	if schemaObj = null then
		write "Schema not found!";
		return;
	endif;
	
	write classObj.name &amp; " (" &amp; classObj.number.String &amp; ") in " &amp; schemaObj.name &amp; " is in-use by:";

	// Class method gets all inuse in &lt;proc oid&gt; comma delimted list
	classObj._getAcquisitions(inuseString);
	
	pos := 1;
	len := inuseString.length();

	on Exception do app.cnEcXhandlerInvalidRef(exception, processObj, invalidProcess);
	
	while pos &lt; len do
		processObj	:=	inuseString.scanUntil(",", pos).asOid().Process;
		pos	:=	pos + 1;
		
		write "  " &amp; processObj.userCode &amp; " at " &amp; processObj.node.name &amp; " (" &amp; processObj.persistentApp.name &amp; " app)";
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnEcShowContents" id="5a2ba2ff-5732-4f62-a2b9-458773d32ab6">
        <source>cnEcShowContents();
// --------------------------------------------------------------------------------
// Created:		12 December 2005 by cnwdad1
//
// Purpose:		Shows the receiver's contents in an hierarchy.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formObj		: CnEcGuiContents;
	classObj	: Class;
	
begin
	classObj	:=	self.class;
	
	if classObj = CnEcActiveGuiForm or classObj = CnEcGuiContents then
		return;
	endif;
	
	create formObj transient;
	formObj.setForm(self);
	formObj.show();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcShowControlForPos" id="37269f1d-382b-4a65-a7e6-87888fbf5f10">
        <updating/>
        <source>cnEcShowControlForPos(pX:Real; pY:Real) updating;
// --------------------------------------------------------------------------------
// Created:		20 February 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columns		: IntegerArray;
	rows		: IntegerArray;
	controlsObj	: ObjectLongNameDict;
	controlObj	: Object;
	
begin
	create columns transient;
	create rows transient;
	create controlsObj transient;
	
	columns.add(pX.Integer);
	rows.add(pY.Integer);
	self.getControlInfo(columns, rows, controlsObj);
	
	if controlsObj.isEmpty() then
		write "Control not found.";
	else
		controlObj	:=	controlsObj.first();
		controlObj.inspectModal();
	endif;
epilog
	delete columns;
	delete rows;
	delete controlsObj;
end;</source>
        <Parameter name="pX" type="Real"/>
        <Parameter name="pY" type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcShowGuiInfo" id="73bfadea-15c3-453c-834c-4a0d19a230a9">
        <source>cnEcShowGuiInfo();
// --------------------------------------------------------------------------------
// Created:		23 November 2005 by cnwdad1
//
// Purpose:		Displays the Current Active Form and Control and copies the Form
//				name to the clipboard.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formObj		: CnEcActiveGuiForm;
	classObj	: Class;
	
begin
	classObj	:=	self.class;
	
	if classObj = CnEcActiveGuiForm or classObj = CnEcGuiContents then
		return;
	endif;
	
	create formObj transient;
	formObj.setWindows(app.activeForm, app.activeControl);
	formObj.show();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcTileWindows" id="a36fe96f-d58e-4e73-a603-e921ecdb1cb2">
        <source>cnEcTileWindows(pHow:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		19 July 2007 by cnwdad1
//
// Purpose:		Tiles the receiver's windows either horizontally or vertically.  If
//				the receiver is not an MDI Frame, the method will fail.
//
// Parameters:	pHow - Horizontally or Vertically - Refer to the CnEcExternalFunctions
//					category of Global Constants.
//
// Returns:		True if the windows were tiled, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	callResult	: Integer;
	
begin
	if not self.mdiFrame then
		return false;
	endif;
	
	callResult	:=	call cnEcTileWindows(self.hwnd(), pHow, 0, 0, 0);
	
	return (callResult &gt; 0);
end;</source>
        <Parameter name="pHow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
