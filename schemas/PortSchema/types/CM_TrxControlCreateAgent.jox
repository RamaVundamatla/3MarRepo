    <JadeMethod name="trxCreateStowageConfirmNoJob" id="aecc7174-9043-4bfb-b685-36df274371a8">
        <updating/>
        <source>trxCreateStowageConfirmNoJob(	_stowageConfirmController : CMIF_StowageConfirmController input; 
								_newTITransaction:CM_TITransaction output;
								_passport : CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
10MAR2023	NAVAB1	CR 56806 TASK 56807 
*/

vars
	ti : CM_TrackedItem;
	currentLocation,
	targetLocation,
	confirmLocation,
	moveLocn		: CM_LocationsController;
	moveController 	: CMIF_MoveController ;
	stowageConfirmController : CMIF_StowageConfirmController;
	voyage 			: CM_Voyage;
	confirmSlotString,
	confirmLocnString,
	confirmLocnHeight : String;
	gcDefn    : CM_ROROGCDefnVoyage;
	lcStrings, searchStrings : StringArray;
	foundHeight : Integer;
	wle : CM_WorkListEntry;	
	queueToYard : Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	ti:= _stowageConfirmController.myTrackedItem;
	voyage := _stowageConfirmController.myVoyage;
	targetLocation := _stowageConfirmController.myTargetLocation;
	confirmLocation := _stowageConfirmController.myConfirmationLocation;
	
	if confirmLocation = null then // incase someone has to use strings
		lcStrings:=_stowageConfirmController.confirmedLocation.trimBlanks.getTokens();
		confirmSlotString:=lcStrings[2];// remove the voyage token
		confirmLocnString :=confirmSlotString[ 1 : confirmSlotString.length -1];//remove tier height from end
		if voyage.myROROStructure &lt;&gt; null then
			// try and find the gc slot from the string
			gcDefn:=voyage.myROROStructure.allROROGCDefnByCode[confirmLocnString].CM_ROROGCDefnVoyage;
			if gcDefn &lt;&gt; null then
				confirmLocation:=gcDefn.myGCController;
			endif;
		
			if confirmLocation = null then	
				confirmLocnHeight :=confirmSlotString[confirmSlotString.length  : end];		
				confirmLocation:=voyage.myROROStructure.findSlotController(confirmLocnString,confirmLocnHeight.Integer );
			endif;
		endif;
		//could be a lolo slot controller
		if confirmLocation = null then
			if voyage.myCellularVoyageStructure &lt;&gt; null then
				create	searchStrings transient;
				searchStrings.add(confirmLocnString);
				voyage.myCellularVoyageStructure.findLocation(searchStrings,false,confirmLocation,foundHeight);
			endif;
		endif;
	endif;
	
	if confirmLocation = null then
		app.raiseCMException1(Err_LocationNotFound,confirmLocnString,null,null);
		return;
	endif;
	
	// Start the transaction
	beginTransaction;

	app.myUtilityCA.utlCreateStowageConfirmTrans(_stowageConfirmController,_newTITransaction,_passport);

	if _passport.hasErrors then
		return;
	endif;
	
	//jlier1 TFS 64016 17/5/24
	currentLocation:=ti.myPrimaryActualLocation;
	if currentLocation = voyage.myShipBlockStack then
		if  ti.isImport and (targetLocation.isKindOf(CM_GeneralCargoController) or targetLocation.isKindOf(CM_VoyageROROController)) then
			queueToYard:=true;
		endif;
	else
		//there is a discharge wle unactioned and moving to CTA
		wle:=ti.getVoyageWLEUnactioned(false);
		if currentLocation.isVoyageController and wle  &lt;&gt; null and targetLocation.isKindOf(CM_CraneLaneController) then
			//Don't queue of already queued to yard or direct delivery
			if wle.myFutureMoveDR = null and wle.myFutureMove = null then
				queueToYard:=true;
			endif;
		endif;
	endif;
	
	//if the confirm location
	if ti.myPrimaryActualLocation  &lt;&gt; confirmLocation then	
		create moveController transient;
		moveController.setMyTrackedItem(ti);
		moveController.setMyToPrimaryLocation(targetLocation);
		moveController.setMoveMode(REAL_MODE);
		moveController.setMyWorkListEntry(ti.getVoyageWLEUnactioned(confirmLocation.isVoyageController()));				//navra1 - 27th Feb 2024 - TFS 62390
		
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController,_passport);
		
	
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	//jlier1 TFS 64016 17/5/24 - if there is already a direct discharge don't auto queue it
	if queueToYard then
		moveLocn := app.autoPlanTiYA(ti.myTerminal, null,ti);
		if moveLocn &lt;&gt; null then
			delete moveController;
			create moveController transient;
			moveController.setMyTrackedItem(ti);
			moveController.setMyToPrimaryLocation(moveLocn);
			moveController.setMoveMode(QUEUE_MODE);
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		endif;
	endif;
	
epilog
	delete lcStrings;													// 27/03/2014 cnwmh5 - Transient Leak
	delete searchStrings;
	delete moveController;
	delete stowageConfirmController;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_stowageConfirmController" type="CMIF_StowageConfirmController" usage="input"/>
        <Parameter name="_newTITransaction" type="CM_TITransaction" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateStowageConfirmation" id="6a7df929-bdad-419e-83dc-d4be4060d6e8">
        <updating/>
        <source>trxCreateStowageConfirmation(	_stowageConfirmController : CMIF_StowageConfirmController input; 
								_newTITransaction:CM_TITransaction output;
								_passport : CM_Passport input) updating;
/* ---------------------------------------------------------------------------
// Created:		
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 15 Nov 2011	cnwer1		Initial Creation - Tallyman CCMS 
 11 Jul 2012	cnwer1		PAR 29962 - Added LOLO to tallyman
 16 Jul 2012 	cnwer1		PAR 30019 - SOB in tallyman
 27 Mar 2013 	cnwer1		par 31360
 --------------------------------------------------------------------------- */
vars
	ti : CM_TrackedItem;
	originalLocation,
	confirmLocation,sobLocation : CM_LocationsController;
	job				: CM_VoyageJob;
	isLoad			: Boolean;
	swapMoveController,
	moveController 	: CMIF_MoveController ;
	swapWLE,
	wle, jobWLE		: CM_WorkListEntry;
	sobLoadWLE, sobDischargeWLE: CM_VoyageWLE;
	voyageWLE: CM_VoyageWLE;
	request,
	swapRequest		: CM_Request;
	swapTrackedItem : CM_TrackedItem;
	stowageConfirmController : CMIF_StowageConfirmController;
	newTITransaction:CM_TITransaction;
	voyage 			: CM_Voyage;
	confirmSlotString,
	confirmLocnString,
	confirmLocnHeight : String;
	gcDefn    : CM_ROROGCDefnVoyage;
	lcStrings, searchStrings : StringArray;
	locationSource: String;
	foundHeight : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	ti:= _stowageConfirmController.myTrackedItem;
	job:=_stowageConfirmController.myVoyageJob;
	voyage := job.myVoyage;
	
	if job.isSOB then
		// SOB have two wles in the job, one for discharge, one for load
		foreach jobWLE in job.workListEntries where jobWLE.myTrackedItem = ti do
			voyageWLE := jobWLE.CM_VoyageWLE;
			if voyageWLE.myRequest.isSOB then
				if voyageWLE.isReceipt then
					sobDischargeWLE := voyageWLE;
				else
					sobLoadWLE := voyageWLE;
				endif;
			else
				wle:=jobWLE;
				isLoad:=voyageWLE.myRequest.CM_VoyageRequest.isLoad;
				locationSource := wle.locationSource;
				break;
			endif;
		endforeach;
		
		if wle = null and (sobDischargeWLE = null or sobLoadWLE = null )then
			//epr par 33143 28/2/14
			app.raiseCMWarning3(Tallyman_SOB_no_discharge_wle,ti.id,_stowageConfirmController.confirmedLocation,job.id,null,null ,null);
			return;
		endif;
		
		//if wle = null then its a SOB 
		if wle = null then
			locationSource := sobDischargeWLE.locationSource;
			//epr par 30019 stowage confirmation includes tier height tagged to end need to remove that for comparision
			lcStrings:=_stowageConfirmController.confirmedLocation.trimBlanks.getTokens();
			confirmSlotString:=lcStrings[2]; // remove the voyage token
			confirmLocnString :=confirmSlotString[ 1 : confirmSlotString.length -1];
			if not sobDischargeWLE.myRequest.isKindOf(CM_ROROGCRequest) then
				confirmLocnHeight :=confirmSlotString[confirmSlotString.length  : end];		
				sobLocation:=voyage.myROROStructure.findSlotController(confirmLocnString,confirmLocnHeight.Integer );	
				if sobLocation &lt;&gt; null then
					confirmLocnString:=sobLocation.ident;
				else
					confirmLocnString :=confirmSlotString[ 1 : confirmSlotString.length]; //epr par 30334 location does include height as does the confirm string.
				endif;
			endif;
			if locationSource = confirmLocnString then
				wle := sobDischargeWLE;	// discharge confirmation
				isLoad := false;
			else
				wle := sobLoadWLE;	// load confirmation
				isLoad := true;
			endif;
		endif;
	else
		wle := job.getWLEForTI(ti);
		isLoad:= not job.isDischarge;
		locationSource := wle.locationSource;
	endif;
	
	if isLoad then
		_stowageConfirmController.plannedLocation:=wle.locationTarget;
	else
		_stowageConfirmController.plannedLocation:=locationSource;
	endif;
	
	_stowageConfirmController.isLoad := isLoad;
	
	if isLoad then
		lcStrings:=_stowageConfirmController.confirmedLocation.trimBlanks.getTokens();
		confirmSlotString:=lcStrings[2];// remove the voyage token
		confirmLocnString :=confirmSlotString[ 1 : confirmSlotString.length -1];//remove tier height from end
		if voyage.myROROStructure &lt;&gt; null then
			// try and find the gc slot from the string
			gcDefn:=voyage.myROROStructure.allROROGCDefnByCode[confirmLocnString].CM_ROROGCDefnVoyage;
			if gcDefn &lt;&gt; null then
				confirmLocation:=gcDefn.myGCController;
			endif;
		
			if confirmLocation = null then	
				confirmLocnHeight :=confirmSlotString[confirmSlotString.length  : end];		
				confirmLocation:=voyage.myROROStructure.findSlotController(confirmLocnString,confirmLocnHeight.Integer );
			endif;
		endif;
		//could be a lolo slot controller
		if confirmLocation = null then
			if voyage.myCellularVoyageStructure &lt;&gt; null then
				create	searchStrings transient;
				searchStrings.add(confirmLocnString);
				voyage.myCellularVoyageStructure.findLocation(searchStrings,false,confirmLocation,foundHeight);
			endif;
		endif;
	else
		// discharge get the wles final destination
		confirmLocation := wle.getTargetLocation();
	endif;

	request := wle.myRequest;
	
	if confirmLocation = null then
		app.raiseCMException1(Err_LocationNotFound,confirmLocnString,null,null);
		return;
	endif;
	
	// Start the transaction
	beginTransaction;

	app.myUtilityCA.utlCreateStowageConfirmTrans(_stowageConfirmController,_newTITransaction,_passport);

	if _passport.hasErrors then
		return;
	endif;
	
	//if the confirm location
	if ti.myPrimaryActualLocation  &lt;&gt; confirmLocation then	
		//swap the wles first so when the move is done it will take care of the 
		// un planning unqueueing correctly
		if (isLoad and (request.getVoyageLoadController &lt;&gt; confirmLocation)) then
			originalLocation:= request.getVoyageLoadController;
			// need to swap wle with requests 
			swapRequest:= confirmLocation.getRequest(true);
			if swapRequest &lt;&gt; null  then
				swapWLE:=swapRequest.allWorkListEntries.first;
				if swapWLE &lt;&gt; null and swapWLE &lt;&gt; wle then
					wle.updateRequest(swapRequest);			
					wle.setNewLocationTarget(confirmLocation);
									
					if confirmLocation.isKindOf(CM_ROROSlotController) or
						confirmLocation.isKindOf(CM_SlotController) then
					
						swapWLE.updateRequest(request);
						swapWLE.setNewLocationTarget(originalLocation);
						
						// if there are any trackedItems in the slot definition 
						swapTrackedItem:=swapWLE.myTrackedItem;
						
						// only do this if the cargo is swapWLE status  is complete i.e on the voyage
						//epr par 31137 4/3/13
						if swapTrackedItem &lt;&gt; null and swapTrackedItem.myPrimaryActualLocation &lt;&gt; originalLocation and swapWLE.status = WLE_COMPLETED then
						// if we move the container created a stowage confirmation transaction 
						// copy basic details i.e. user date/time		
							create stowageConfirmController transient;
							stowageConfirmController.type:=TRANS_TYPE_STOWAGE_CONFIRM;
							stowageConfirmController.dateTime:=_stowageConfirmController.dateTime;
							stowageConfirmController.userId:=_stowageConfirmController.userId;
							stowageConfirmController.noCharge:=true;
							stowageConfirmController.myTrackedItem:=swapTrackedItem;
							stowageConfirmController.myVoyageJob:=swapWLE.job.CM_VoyageJob;
							stowageConfirmController.isForVoyage := true; // ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1
							stowageConfirmController.confirmedLocation:=originalLocation.getFullId();
							stowageConfirmController.plannedLocation:=swapWLE.locationTarget;
							stowageConfirmController.myTerminal:=job.myTerminal;
							stowageConfirmController.isLoad:=true;  //epr 31360 27/3/2013
							
							app.myUtilityCA.utlCreateStowageConfirmTrans(stowageConfirmController,newTITransaction,_passport);
							
							if _passport.hasErrors then
								return;
							endif;
							
							create swapMoveController transient;
							swapMoveController.setMyTrackedItem(swapTrackedItem);
							swapMoveController.setMyToPrimaryLocation(originalLocation);
							swapMoveController.setMoveMode(REAL_MODE); 
							swapMoveController.setMyWorkListEntry(swapWLE);
							swapMoveController.setJobForMove(swapWLE.job);
							
							app.myUtilityUA.utlUpdateMoveTrackedItem(swapMoveController,_passport);
							
							if _passport.hasErrors then
								return;
							endif;
						endif;	
					endif;
				endif;
			endif;	
		endif;		
		
		if confirmLocation &lt;&gt; null and isLoad  then
			// If this is the SOB Load then need to complete the SOB Discharge WLE
			if sobDischargeWLE &lt;&gt; null then
				wle := sobDischargeWLE;
			endif;
			
			//if container is not in the confirmed location move it there
			create moveController transient;
			moveController.setMyTrackedItem(ti);
			moveController.setMyToPrimaryLocation(confirmLocation);
			moveController.setMoveMode(REAL_MODE); 
			moveController.setMyWorkListEntry(wle);
			moveController.setJobForMove(job);
			
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController,_passport);
		endif;
		
	endif;

	
epilog
	delete lcStrings;													// 27/03/2014 cnwmh5 - Transient Leak
	delete searchStrings;
	delete moveController;
	delete stowageConfirmController;
	delete swapMoveController;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_stowageConfirmController" type="CMIF_StowageConfirmController" usage="input"/>
        <Parameter name="_newTITransaction" type="CM_TITransaction" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateSubAreaAndRestLabour" id="dd5b6b6b-cef7-4621-ae52-3c98468bc3e0">
        <updating/>
        <source>trxCreateSubAreaAndRestLabour(	_pxyTermSubArea : CM_TerminalSubArea io;
								_theProxyRestriction : CM_LabourRestriction;
								_theNewRestriction : CM_LabourRestriction output;
								_passport : CM_Passport input
								) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars
	aTA	: CM_TerminalArea;
	queueEntrySet_after	: CM_RTQueueEntrySet;
	newTerminalSubArea : CM_TerminalSubArea;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	beginLoad;
	app.myValCA.valRestrictionLabour( _theProxyRestriction );
	endLoad;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create queueEntrySet_after transient;
	
	beginTransaction;
	
	if _passport.noErrors then
		app.myUtilityCA.utlCreateTerminalSubArea( _pxyTermSubArea, newTerminalSubArea, _passport );
		if _passport.hasErrors() then
			return;
		endif;
	endif;

	if _passport.noErrors then
		// PAR 17051 (reopened) - need to record before view 
		aTA := newTerminalSubArea.myTerminalArea;
		// 02/03/2011 cnwcs5 CCMS CPL 2027/PAR 27126 - replace audit of ta with an audit that includes the changes to locations as well
		// app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(aTA, true);
		app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation(aTA, true, null,CM_AuditTALocations.LocnTypeUpdate_LabRestrict, AuditCreated, null);
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	create _theNewRestriction persistent;
	_theNewRestriction.setForCreate(_theProxyRestriction);

	if _passport.noErrors then
		_theNewRestriction.getQueueEntries( queueEntrySet_after );
		_theNewRestriction.setQueueTasksStatus( null, queueEntrySet_after );	//ccms1573	cnwvu1
		_theNewRestriction.notifyRecentMachines(); //cnwrd1 15.1.09 ccms JMT 1750
	endif;
	
	if _passport.noErrors then
		aTA := _theNewRestriction.myTerminalArea;
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,aTA);
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TALocation_Create),false,_theNewRestriction);
		
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_theNewRestriction);	// cnwdad1 06/08/2008 - PAR #17673.
		if _passport.hasErrors() then
			return;
		endif;
		
		app.myUtilityUA.myUpdateAuditAgent.audUpdateTALocation (aTA, false, _theNewRestriction.allLocationControllers,CM_AuditTALocations.LocnTypeUpdate_LabRestrict, 
									AuditCreated, _theNewRestriction.getAuditTALocationDetails);
		
		if _passport.hasErrors() then
			return;
		endif;
		
		_theNewRestriction.sendCreateDeleteEmail( app.getErrorString(LOB_Create_Action), _passport);	//08 Jul 2015	NDL	Par 36588
		
	endif;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete queueEntrySet_after;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyTermSubArea" type="CM_TerminalSubArea" usage="io"/>
        <Parameter name="_theProxyRestriction" type="CM_LabourRestriction"/>
        <Parameter name="_theNewRestriction" type="CM_LabourRestriction" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateSubBlockStack" id="51255647-75e4-4975-8b23-b5a982f66dd3">
        <updating/>
        <source>trxCreateSubBlockStack(theGridArea : CMIF_GridTARegion input;_theRealSubBlock : CM_SubBlockStack output; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		to convert a grid area into a sub block stack.
//				This assumes that the proxy sub has all the locations that are to be part of the sub block in its allByPassedControllers
//				The controllers in allByPassedControllers will be proxy copies of the real thing. The proxy copies have had their 
//				real object link set. In updating the sub block we simply update the real controllers mySubBlockStack with the new real subBlockStack  
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realBlockStack : CM_BlockStack;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if theGridArea = null then
		app.raiseCMException1(ERR_NO_OBJECT, "Sub Block Stack TA", null, null);
	endif;

	beginTransaction;
	app.myUtilityCA.utlCreateSubBlockStack(theGridArea,_theRealSubBlock, _passport); // pass in both to check edition
	
	
epilog

	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="theGridArea" type="CMIF_GridTARegion" usage="input"/>
        <Parameter name="_theRealSubBlock" type="CM_SubBlockStack" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
