    <JadeMethod name="setupForDeadlockReplay" id="c56c329d-16da-4dda-b1c4-05c4c0e001e7">
        <updating/>
        <source>setupForDeadlockReplay(_priority : Integer; _sleepDuration : Integer) updating;
/*
Purpose:		setup values when deadlock replay in required

Return value;	None

Date:				Who		Reason		
09 Decemeber 2009	conkc1	Created
*/
vars

begin
	self.silentDeadlockRetryCount := 0;
	self.silentDeadlockPriority   := _priority;
	self.silentDeadlockSleepTime  := _sleepDuration;
	self.hadDeadlock              := false;
	self.replayingDeadlocks       := true;
	process.setPersistentDeadlockPriority(self.silentDeadlockPriority);
	app.setPassBackExceptions(false, false);
epilog

end;</source>
        <Parameter name="_priority" type="Integer"/>
        <Parameter name="_sleepDuration" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxCompletedOK" id="e73df9a9-a8cd-47e0-9da6-001c4868b413">
        <source>trxCompletedOK() : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if process.isInTransactionState then
		// Added here 25Mar03 as this was being called incorrectly after a utl
		// instead of after a trx (rjs).
		app.raiseUnexpectedProgramError(class.name, method.name, 'call while still in transaction state');
		return false;
	endif;
	return (self.status = TRXStatus_Committed);

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateEventTransForDeferUpd" id="a30d0a9e-0001-48c0-b46d-c53ec836372f">
        <updating/>
        <source>updateEventTransForDeferUpd() updating, protected;
/*
Purpose - 	
Who - NAVAB1
Date - 02MAY2024
ADO -  CR 63938 TASK 63942
Changed By	On			Reason
----------	--------	----------------------------------------------------
21/07/2024	navdap1		MTN-34430 MTN - Deferred Updates For Event Required For Login and Logout Trxs
*/

vars
	terminal			: CM_Terminal;
	eventTrans			: CM_EventTransaction;
	camsTS				: TimeStamp;
	root				: CM_Root;			// MTN-34430
	rootLockedByMe		: Boolean;			// MTN-34430
begin
	
	if self.hasErrorsIgnored() then
		return;
	endif;
	
	if self.allEventsForDeferUpd.isEmpty() then
		return;
	endif;
	
	terminal := self.myTITransactionTerminal;
	root := app.myRoot;						// MTN-34430
	
	// MTN-34430 some events (like login and logout) don't have a terminal 
	//if terminal = null then
	//	app.raiseUnexpectedProgramError(class.name, method.name, 'myTITransactionTerminal is null');
	//	return;
	//endif;
	
	if terminal &lt;&gt; null then	// MTN-34430
		// lock all event transaction collections before getting camsTimestamp
		self.exclusiveLock(terminal.allEventsByDateTime);			//65
		self.exclusiveLock(terminal.allEventsByTypeDateTime);		//66
		self.exclusiveLock(terminal.allEventTransactionsByCamsTS);	//228	
	endif;

	// get the CAMS timestamp as late as possible in the transaction
	camsTS := app.actualTimeServer;
	
	foreach eventTrans in self.allEventsForDeferUpd do
		eventTrans.setCAMSTimeStamp (camsTS);
		// MTN-34430 for login and logout, set root, not terminal
		if eventTrans.isLoginEvent or eventTrans.isLogoutEvent then
			if not rootLockedByMe then
				self.exclusiveLock(root.allEventsByDateTime);		// 194
				self.exclusiveLock(root.allEventsByTypeDateTime);	// 195
				rootLockedByMe := true;
			endif;
			eventTrans.setMyRoot();
		else
			eventTrans.setMyTerminal(terminal);
		endif;
		eventTrans.createChargeDeferred(self);
	endforeach;
	
	self.allEventsForDeferUpd.clear();
	
	// used by deferred TI transactions as well. This method is called before updateTITransForDeferUpd() 
	if self.allTITransactionsForDeferUpd.isEmpty() then
		self.myTITransactionTerminal 		:= null;
	endif;

	self.useEventDeferUpdate 	:= false;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateFutureActorsForDeferUpd" id="b1da583e-3015-4143-98d2-1dfd9d83486e">
        <updating/>
        <source>updateFutureActorsForDeferUpd()updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
17 Mar 2025 navma1  MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
*/

vars
	root 		: CM_Root;
	futureActor	: CM_OfflineFutureActor;
	obj			: Object;
begin
	
	if self.hasErrorsIgnored() then
		return;
	endif;
	
	if self.allFutureActorForDefUpd.isEmpty() and self.allFutureActorForDefDel.isEmpty then //17.03.2025 navma1 #MTN-34120
		return;
	endif;
	
	root := app.myRoot;
	/*
	Need to be in order of Oid 
	Class: PortSchema::CM_OfflineFutureActorDict (12567)
	Class: PortSchema::CM_OfflineFutureActorParentDct (12580)
	*/
	self.exclusiveLock(root.allOfflineFutureActors);
	self.exclusiveLock(root.allOfflineFutureActorParents);
	
	foreach obj in self.allFutureActorForDefUpd do
		futureActor := obj.CM_OfflineFutureActor;
		futureActor.setRoot(root);
	endforeach;
	
	/*
	Delete future Actors For Road,Ship and Rail Release
	17.03.2025 navma1 #MTN-34120
	*/
	foreach obj in self.allFutureActorForDefDel do
		futureActor := obj.CM_OfflineFutureActor;
		futureActor.setRoot(null);
	endforeach;
	
	self.allFutureActorForDefDel.purge();
	
epilog
	
	self.allFutureActorForDefUpd.clear();
	self.allFutureActorForDefDel.clear();					//17.03.2025 navma1 #MTN-34120
	self.useOfflineFutureActorDeferUpd 	:= false;			//17.03.2025 navma1 #MTN-34120
	self.useOfflineFutureActorDeferDel  := false;			//17.03.2025 navma1 #MTN-34120
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateSubTermForDeferUpd" id="ef908e89-e5d6-4e5b-b86f-7975b552bf0c">
        <updating/>
        <source>updateSubTermForDeferUpd( _subTerm : CM_SubTerminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgndl1	Initial creation	TFS 37278 - Update teh extra info of all trxs
										that are NOT sub term changes to the pre-update value, so 
										that the deferred update proces can reset the Sub Term values in the thos e trxs.

*/

vars

	tiTrx : CM_TITransaction;

begin

	foreach tiTrx in self.allTITransactionsForDeferUpd where not tiTrx.isSubTermRecOrRel do
		tiTrx.setMySubTermForDefUpd( _subTerm );
	endforeach;

epilog

end;</source>
        <Parameter name="_subTerm" type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="updateTITransForDeferUpd" id="6d297e97-3b68-424e-bbad-d0637b160462">
        <updating/>
        <source>updateTITransForDeferUpd() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwrs2
//
// Purpose:     Should only be called from self.doDeferredUpdates
// ---------------------------------------------------------------------------
// 11/12/2012	cnwcs5	par 30855 / CCMS SFW 1294 - set CAMS timestamp
// 07/09/2017   cnwma1	TFS # 6670 PEN - RE: Ticket 5132 - Cargo IDs in a continuous loop issue continues to cause Cargo Enquiry to fail and a file lock.
// 04/10/2023	navma1 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
// 25/06/2025	navdap1	MTN-12349 EUP - Transport Manifest load after locking does not add all cargo to work order
vars
	terminal			: CM_Terminal;
	tiTrans				: CM_TITransaction;
	camsTS				: TimeStamp;
	isSubTerminalsOn	: Boolean;
	allReleaseShipTIs	: ObjectSet;
	obj					: Object;
	isCashOnly			: Boolean;
begin
	
	if self.hasErrorsIgnored() then // PAR 17703
		return;
	endif;
	
	self.allTITransactionsForDeferUpd.rebuild();				// MTN-12349
	if self.allTITransactionsForDeferUpd.isEmpty() then
		return;
	endif;
	
	terminal := self.myTITransactionTerminal;
	
	if terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myTITransactionTerminal is null');
		return;
	endif;
	
	isSubTerminalsOn := app.isSubTerminalsOn(terminal);
	isCashOnly		 := terminal.isCashOnlyEnabled;									//04.10.2023 navma1 #59638
	
	// lock all TI transaction collections before getting camsTimestamp
	self.exclusiveLock(terminal.allTITransactions);
	self.exclusiveLock(terminal.allTITransactionsByTypeDate);
	self.exclusiveLock(terminal.allTITransactionsByCamsTS);		

	create allReleaseShipTIs transient;
	
	// get the CAMS timestamp as late as possible in the transaction
	camsTS := app.actualTimeServer;
	
	foreach tiTrans in self.allTITransactionsForDeferUpd do
		tiTrans.setCAMSTimeStamp (camsTS);
		tiTrans.setMyTerminal(terminal);
		
		if isSubTerminalsOn then
			if not tiTrans.isSubTermRecOrRel then	//28 Feb 2018	NDL	TFS 37278 
				tiTrans.setMySubTermDuringDefUpd();	//28 Feb 2018	NDL	TFS 37278 - Set the sub term from the pre-update value
			else
				tiTrans.setMySubTerminal(tiTrans.myTrackedItem.mySubTerminal);
			endif;
		endif;
		
		tiTrans.createChargeDeferred(self);	//09 Aug 2021	TFS 51443 NDL - Potentially creates charges as part of a BGP instead of directly in-line
		
		//epr CCMS 1280 Cash System - not ideal place to do this but because transactions charges done here have to
		if isCashOnly then											//04.10.2023 navma1 #59638
			if tiTrans.isKindOf(CM_ReleaseShip) then
				allReleaseShipTIs.tryAdd(tiTrans.myTrackedItem);	//20.05.2024 navma1 #64191		
			endif;
		endif;
	endforeach;
	
	if  isCashOnly then //04/09/2017 cnwma1 TFS #6670
		foreach obj in allReleaseShipTIs discreteLock do
			// epr 14/8/12 CCMS 1280 Cash System - release to ship have to re-evaluate the cash payments &amp; remove the proforma 
			app.myUtilityUA.utlUpdateCashPaymentFromTI(obj.CM_TrackedItem, null, self);
			
			if self.hasErrors() then
				break;
			endif;
		endforeach;
	endif;
	
	self.allTITransactionsForDeferUpd.clear();
	
	self.myTITransactionTerminal 		:= null;
	self.useTITransactionDeferUpdate 	:= false;
epilog
	delete allReleaseShipTIs;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateTIsForDeferUpd" id="497d8e05-ce62-4690-8617-bdcdcbb8bda7">
        <updating/>
        <source>updateTIsForDeferUpd() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwrs2
//
// Purpose:     Should only be called from self.doDeferredUpdates
// ---------------------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 14/12/2023	navcs2		ChangeRequest 57539: CUX | Multiple Prenotes Unique by Booking Reference
// 20/05/2024   navma1		Bug 64191: EUP - Lock and Freeze issue
vars
	ti,
	checkTI					: CM_TrackedItem;
	addMsg					: String;
	invalidTI 				: Boolean; // PAR 17485
	isPrenoteUniqBooking	: Boolean;
	ct						: CM_CargoType;
	term					: CM_Terminal;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);		 // PAR 17485

	if self.hasErrorsIgnored() then // PAR 17703
		return;
	endif;
	
	if self.allTIsForDeferredUpdate.isEmpty then
		return;
	endif;
	
	//20.05.2024 navma1 #64191
	term 				 := self.myTerminal;
	isPrenoteUniqBooking := term.getConfig( PrenoteUniqBooking ).Boolean;	//20.05.2024 navma1 #64191
	

	foreach ti in self.allTIsForDeferredUpdate do
		invalidTI := false; 							// PAR 17485
		ct	 	  := ti.myCargoType;					//20.05.2024 navma1 #64191
		
		if invalidTI then								// PAR 17485
			continue;									// PAR 17485
		endif;

		exclusiveLock(ti);
		
		// PAR 13386
		// When doing deferred updates checks done in changeIdInternal cannot be
		// done as they will cause locks.  As some cargoTypes allow duplicate ID's
		// we need to do a double check here

		// IMPT:  similar code is in CM_TrackedItem::changeIdInternal.
		// if changes are made here then check if a similar change is required
		// there as well.

		// Par 13738
		if (ti.state = TI_STATE_NORMAL or ti.state = TI_STATE_ONSHIP ) and (not ct.allowDuplicates) then
			// do a quick dup check
			//th2 14/05/2007 - benchmarking work - timing hole here between the implicit read lock
			//on collections and the exclusive lock from update
			/*
			### TFS CR 64297 TASK 64298 28MAY2024 NAVAB1 - Hugh at Jade recommended locking 
			all these collections in the order that they were added to the schema (OID order)
			*/
			
			/*
			
			***** LEAVING COMMENTED WHILE ITS CODE CEHCKED *****
			
			self.tryLock(term.allOnsiteTIsByCargoTypeId, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined);
			self.tryLock(term.allOnsiteTIsByCargoTypeIdRev, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined);
			self.tryLock(term.allOnsiteTIsByIdCargoType, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined);
			self.tryLock(term.allOnsiteTIsByIdCargoType, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined);
			self.tryLock(term.allOnsiteTIsByIdCargoTypeRev, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined);
			self.tryLock(term.allOnsiteTIsByBookingRef, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined);
			*/
			
			self.exclusiveLock(term.allOnsiteTIsByCargoTypeId);      //110 - CM_TIByCargoTypeIdDict						
			self.exclusiveLock(term.allOnsiteTIsByCargoTypeIdRev);	 //111 - CM_TIByCargoTypeIdDictRev					
			self.exclusiveLock(term.allOnsiteTIsByIdCargoType);		 //112 - CM_TIByIdCargoTypeDict				
			self.exclusiveLock(term.allOnsiteTIsByIdCargoTypeRev);	 //113 - CM_TIByIdCargoTypeDictRev					
			self.exclusiveLock(term.allOnsiteTIsByBookingRef);		 //205 - CM_TIByBookingRefDict				
			self.exclusiveLock(term.allOnsiteTIsByAlternativeId);	 //236 - CM_TIByAlternativeID	
			
			
			checkTI := term.allOnsiteTIsByCargoTypeId[ti.cargoType, ti.id];

			// proposed new code Par13557
			if checkTI &lt;&gt; null then
				if checkTI = ti then 
				else
					app.raiseCMException1(ERR_ALREADY_ONSITE, ti.id, ETRow_Id, null);
				endif;
			endif;
		
			//th2 14/05/2007 - benchmarking work - timing whole here between the implicit read lock
			//on collections and the exclusive lock from update
			self.exclusiveLock(term.allNotifiedTIsByCargoTypeId);				
			
			// need to check pre-notes (PAR 8594)
			checkTI := term.allNotifiedTIsByCargoTypeId[ti.cargoType, ti.id];
				
			if checkTI &lt;&gt; null and checkTI &lt;&gt; ti then
				addMsg := ti.getKeyDifferenceList(checkTI);
				app.raiseCMWarning2(WARN_PRENOTE_EXISTS, ti.id, "E.g. " &amp; addMsg, ETRow_Id, null, ti);
			endif;
			//31/03/2011 cnwdz2 par27234 start
		
		// 14/12/2023	navcs2	ChangeRequest 57539 Start
		elseif ti.state = TI_STATE_NOTIFIED and isPrenoteUniqBooking then		//20.05.2024 navma1 #64191
			if not term.noOnsiteDuplicate(ti, ti.cargoType, ti.operatorCode, ti.bookingReference, false, false) then
				app.raiseCMException1(Preno_with_same_booki_ref, ti.id, null, null);
			endif;
		// 14/12/2023	navcs2	ChangeRequest 57539 End
		elseif ti.state = TI_STATE_NOTIFIED and	not ct.allowDuplicates then
			self.exclusiveLock(term.allNotifiedTIsByCargoTypeId);			
			
			// need to check pre-notes (PAR 8594)
			checkTI := term.allNotifiedTIsByCargoTypeId[ti.cargoType, ti.id];
				
			if checkTI &lt;&gt; null then
				if checkTI = ti then
				else
					app.raiseCMException1(ERR_DUP_NOTIFIED_TI, ti.id, null, null);
				endif;
			endif;
			//31/03/2011 cnwdz2 par27234 end
		
		endif;
		ti.updateCollections();
	endforeach;
	
	self.allTIsForDeferredUpdate.clear;
	self.useTIDictDeferUpdate := false;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateWOTransForDeferUpd" id="0e9a0069-32b7-45f9-915e-b6bf868ee1cd">
        <updating/>
        <source>updateWOTransForDeferUpd() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2024	navnk30	JIRA 19927: EUP - Error 1081 When using Rail Lander 

*/

vars
	woTxn			: CM_WOTransaction;
	terminal		: CM_Terminal;
	invalidWoTxn	: Boolean;
	bu				: CM_Bank; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	on Exception do app.handleDeletedObject(exception, woTxn, invalidWoTxn);

	if self.hasErrorsIgnored() or self.allWOTransactionsForDeferUpd.isEmpty() then
		return;
	endif;
	
	terminal := self.myTerminal;
	if terminal = null then
		return;
	endif;
	
	/*
	Need to be Locked in the order of Oid 
	*/	
	self.exclusiveLock(terminal.allWOTransByTypeDateTime);		//268
	self.exclusiveLock(terminal.allWOTransByDateTime);			//269
	
	foreach woTxn in self.allWOTransactionsForDeferUpd do	
		woTxn.setMyTerminal(terminal);
		
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
		bu := woTxn.getMyBank();
		
		if bu &lt;&gt; null then
			bu.createChargeWOResync(woTxn); 
		endif;
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	endforeach;
epilog
	self.allWOTransactionsForDeferUpd.clear();
	self.useWOTransactionDeferUpdate := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="userNotification" id="070905ee-cb9e-4f21-9b43-38b609598d00">
        <updating/>
        <source>userNotification(_eventType: Integer; theObject: Object; eventTag : Integer; userInfo : Any) updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2004 by cnwrs2
//
// Purpose:     Fires when data access controller is updated
// ---------------------------------------------------------------------------
vars
	eventTrans	: CM_EventTransaction;
	eventType	: CM_EventType;
	alertType 	: CM_SystemAlertType;
	object 		: Object;
begin

	if self.myUser = null then
		return;
	endif;
	
	if _eventType = EVENT_DAC_UPDATE then
		self.allDataAccessControllers.clear();
		self.myUser.allDataAccessControllers.copy(self.allDataAccessControllers);
	
	elseif userInfo.isKindOf(CM_SystemAlert) then
		alertType := self.myUser.allSystemAlertTypes[_eventType];
		if alertType &lt;&gt; null then
			object := userInfo.CM_SystemAlert;
			app.showAlertAlarm(object);
		endif;

	elseif userInfo.isKindOf(CM_EventTransaction) and app.isValidObject(userInfo.CM_EventTransaction) then
		eventTrans := userInfo.CM_EventTransaction;
		eventType := self.myUser.allEventTypes[eventTrans.type];
		if eventType &lt;&gt; null then
			app.showEventAlarm();
		endif;
	endif;
		
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateUserHasOnePermission" id="64a1089a-a96e-4b96-9ca7-b9f80c1cf0a9">
        <source>validateUserHasOnePermission(_permissions : IntegerArray);
/*

Purpose:	raise exception if the user does not have any of the permissions		

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2017	jlger1	Initial creation TFS 5535

*/

vars
	user			: CM_User;
	terminal		: CM_Terminal;
	permission 		: Integer;
begin
	if self.myUser = null then
		return;
	endif;
	
	if self.myTerminal = null then
		app.raiseCMException(Input_required_field_terminal,null,null);
		return;
	endif;
	
	if _permissions.isEmpty then
		return;
	endif;
	
	foreach permission in _permissions do		
		if  self.myUser.canDo(self.myTerminal, permission) then			
			return;
		endif;
	endforeach;
	
	app.raiseCMException2(ERR_USER_NO_PERMISSION,
						   self.myUser.code, 
						   app.getPermissionName(permission),
						   null, 
						   null);
	
	
epilog

end;</source>
        <Parameter name="_permissions" type="IntegerArray"/>
    </JadeMethod>
</Class>
