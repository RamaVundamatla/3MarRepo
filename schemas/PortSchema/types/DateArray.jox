<CollClass name="DateArray">
    <JadeMethod name="displayDateToString" id="f274e0f3-a81e-47bc-a650-8839c5526c9a">
        <source>displayDateToString(_delim : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/10/2023	navkc1	CR 60974 Task 60975: UI - Cargo Review Additional Cust Doc Columns

*/

vars
	date	: Date;
	str		: String;
	iter	: Iterator;
begin

	iter := self.createIterator();
	
	while iter.next(date) do
		if date = null then
			continue;
		endif;
		
		if str &lt;&gt; null then
			str &amp;= _delim;
		endif;
		
		str &amp;= date.asStringJMT();
	endwhile;
	
	return str;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_delim" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
