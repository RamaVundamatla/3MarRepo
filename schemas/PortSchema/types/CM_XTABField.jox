    <JadeMethod name="cloneSelf" id="680ce65d-06de-421e-9620-6c35d5eb1af1">
        <source>cloneSelf(_transient: Boolean): SelfType;
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	clone	:SelfType;
begin
	clone :=  inheritMethod(_transient);
	
	return clone;
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="create" id="8aaea197-cf58-498e-9202-50f88ef54dd1">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.function := self.Function_Count;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDefaultHeading" id="5901f48d-c2e5-439d-84a5-c6d4e80f19d5">
        <source>getDefaultHeading():String;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/02/2010	CNWCS5	CCMS 1925 / PAR 22295
// 12/02/2010	cnwcs5	par 22140 - New functions
// 16/02/2010	cnwcs5	Fix exception when heading &gt; 30 characters
// ---------------------------------------------------------------------------
vars
	str	:String;
begin
	str := self.getQueryPropertyTerminology();

	if self.function = Function_Count then
		str :=  app.getErrorString1 (XTABFieldHeading_COUNT, str);
	elseif self.function = Function_Sum then
		str := app.getErrorString1 (XTABFieldHeading_SUM, str);
	elseif self.function = Function_Average then
		str := app.getErrorString1 (XTABFieldHeading_AVG, str);
	elseif self.function = Function_Max then
		str := app.getErrorString1 (XTABFieldHeading_MAX, str);
	elseif self.function = Function_Min then
		str := app.getErrorString1 (XTABFieldHeading_MIN, str);
	elseif self.function = Function_Count_True then							// cnwcs5 ccms 1925
		str := app.getErrorString1 (XTABFieldHeading_COUNT_TRUE, str);		// cnwcs5 ccms 1925
	elseif self.function = Function_Count_False then						// cnwcs5 ccms 1925
		str := app.getErrorString1 (XTABFieldHeading_COUNT_FALSE, str);		// cnwcs5 ccms 1925
	elseif self.function = Function_Count_Null then							// 12/02/2010 cnwcs5 par 22140
		str := app.getErrorString1 (XTABFieldHeading_COUNT_NULL, str);		// 12/02/2010 cnwcs5 par 22140
	elseif self.function = Function_Count_NotNull then						// 12/02/2010 cnwcs5 par 22140
		str := app.getErrorString1 (XTABFieldHeading_COUNT_NOTNULL, str);	// 12/02/2010 cnwcs5 par 22140
	elseif self.function = Function_Count_Zero then							// 15/02/2010 cnwcs5 par 22140
		str := app.getErrorString1 (XTABFieldHeading_COUNT_ZERO, str);		// 15/02/2010 cnwcs5 par 22140
	elseif self.function = Function_Count_NotZero then						// 15/02/2010 cnwcs5 par 22140
		str := app.getErrorString1 (XTABFieldHeading_COUNT_NOTZERO, str);	// 15/02/2010 cnwcs5 par 22140
	endif;
	
	if str.length &gt; 30 then			// 16/02/2010 cnwcs5
		return str[1:27] &amp; '...';	// 16/02/2010 cnwcs5
	endif;							// 16/02/2010 cnwcs5
	
	return str;						// 16/02/2010 cnwcs5
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFunctionAsString" id="17a8b872-4f0b-4e04-a1f1-e94e8008577e">
        <source>getFunctionAsString():String;
/*
Purpose:			
Parameters:			
Return Value:	Function Name, eg COUNT, SUM etc	

Date		Who		Reason
03 December 2009	cnwndl1	Initial creation	CCMS 1023
12/02/2010	cnwcs5	par 22140 - New functions
*/
vars

begin
	if self.function = Function_Count then
		return app.getErrorString( COUNT );
	elseif self.function = Function_Sum then
		return app.getErrorString( SUM );
	elseif self.function = Function_Average then
		return app.getErrorString( AVERAGE );
	elseif self.function = Function_Max then
		return app.getErrorString( MAX );
	elseif self.function = Function_Min then
		return app.getErrorString( MIN );
	elseif self.function = Function_Count_True then		// 12/02/2010 cnwcs5 par 22140
		return app.getErrorString( COUNT_TRUE );		// 12/02/2010 cnwcs5 par 22140
	elseif self.function = Function_Count_False then	// 12/02/2010 cnwcs5 par 22140
		return app.getErrorString( COUNT_FALSE );		// 12/02/2010 cnwcs5 par 22140
	elseif self.function = Function_Count_Null then		// 12/02/2010 cnwcs5 par 22140
		return app.getErrorString( COUNT_NULL );		// 12/02/2010 cnwcs5 par 22140
	elseif self.function = Function_Count_NotNull then	// 12/02/2010 cnwcs5 par 22140
		return app.getErrorString( COUNT_NOT_NULL );	// 12/02/2010 cnwcs5 par 22140
	elseif self.function = Function_Count_Zero then		// 15/02/2010 cnwcs5 par 22140
		return app.getErrorString( COUNT_ZERO );		// 15/02/2010 cnwcs5 par 22140
	elseif self.function = Function_Count_NotZero then	// 15/02/2010 cnwcs5 par 22140
		return app.getErrorString( COUNT_NOT_ZERO );	// 15/02/2010 cnwcs5 par 22140
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHeading" id="5c2bf139-c608-4c86-b57a-4b42b38c84b6">
        <source>getHeading():String;
// ---------------------------------------------------------------------------
// Created:     11 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if self.heading &lt;&gt; null then
		return self.heading;
	endif;
	
	return self.getDefaultHeading;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIndex" id="90bbf42d-727c-4fb8-8dfb-4d4efaa59f7a">
