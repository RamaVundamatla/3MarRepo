    <JadeMethod name="queryResultTableColours" id="f403f3a5-f4db-44a4-8d73-7d383e006791">
        <source>queryResultTableColours() protected;
// -------------------------------------------
// Created 15 May 2008 by cnwvu1
// -------------------------------------------

vars
	rowObj	: JadeTableRow;
	bckColorAlternate,
	bckColor,
	i		: Integer;
	
begin
	
	bckColorAlternate	:= MB_GradesTable.firstInstance.getAlternateColor();
	bckColor			:= self.getSystemColor(Window.Color_Window);
	
	foreach i in 1 to tblResults.rows do

		rowObj	:=	self.tblResults.accessRow( i );
		if i.isEven() then
			rowObj.backColor := bckColorAlternate;
		else
			rowObj.backColor := bckColor;
		endif;
		
	endforeach;
	
	tblResults.mbSetFixedColors( app.colorBackTables, app.colorForeTables );

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="queryResultTableInitialize" id="03a89bb9-30e0-40c6-977d-5fcf4ee7cc04">
        <source>queryResultTableInitialize();
