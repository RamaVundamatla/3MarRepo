    <JadeMethod name="doBtnAutoMaskClick" id="ea9d7c1c-6540-4d97-aab6-e6af6d31b4ca">
        <updating/>
        <source>doBtnAutoMaskClick(btn: Button input; _redraw : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cdc : YRD_ContainerDrawingController;
	obj : Object;
begin

	self.autoMask := (not self.autoMask);
	//epr par 15087
	if self.myCurrentDrawingController = null then
		return;
	endif;
	if self.autoMask then
		self.myCurrentDrawingController.autoMask := true;
		btn.caption		:= self.myCurrentDrawingController.myTerminalArea.id &amp; ' Auto-Mask is on';
		btn.bubbleHelp 	:= self.myCurrentDrawingController.myTerminalArea.id &amp; ' Auto-Mask is on';
	else
		foreach obj in self.allDrawingControllers do
			cdc := obj.YRD_ContainerDrawingController;
			cdc.allSelectorTIs.clear;	
			cdc.autoMask := false;
		endforeach;
		btn.caption		:= 'Auto-Mask is off';
		btn.bubbleHelp	:= "Auto-Mask is off";
		btn.value := false;
		if app.myMoveController &lt;&gt; null then
			app.myMoveController.isAutoMasked := false;
		endif;
		if _redraw then
			foreach obj in self.allDrawingControllers do
				cdc := obj.YRD_ContainerDrawingController;
				cdc.drawSelf(true);	
			endforeach;
		endif;
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
        <Parameter name="_redraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnPopupEnqClick" id="0635f13a-9f36-4ff3-b52c-7a32fb72c3f8">
        <source>doBtnPopupEnqClick();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTI : CM_TrackedItem;
	theObject : Object;
begin
	theObject := self.frmPopupInfo.userObject;
	if theObject = null then
		return;
	endif;
	
	if theObject.isKindOf(CM_TrackedItem) then
		theTI := theObject.CM_TrackedItem;
		self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);	
	endif;



end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPopupPrintClick" id="fc8fdaad-4427-47cd-b8b9-bf4caccd344a">
        <updating/>
        <source>doBtnPopupPrintClick() updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theReport : CMUI_ReportLine;
	tmpJadeReport  : JadeReport;
	bakColour : Integer;
	tmpLeft,tmpTop : Real;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	tmpLeft := self.frmPopupInfo.left;
	tmpTop := self.frmPopupInfo.top;	
	
	bakColour := self.frmPopupInfo.backColor;
	self.frmPopupInfo.backColor := White;
	self.tblPopupInfo.backColor := White;
	create theReport transient;
	theReport.initReportForPortrait();
	theReport.initReport;
	theReport.lblTitle02.drawFontBold := true;
	theReport.lblPrintedBy.caption := app.myPassport.myUser.userName;
	theReport.lblTitle01.caption := "";
	theReport.lblTitle02.caption := "Cargo Popup Info";
	theReport.lblTitle03.caption := "";
	theReport.lblTitle04.caption := self.frmPopupInfo.caption;
	create tmpJadeReport transient;
	tmpJadeReport.description := theReport.lblTitle02.caption[1:60];
	app.printer.setReport(tmpJadeReport);
	app.printer.setMargins(Print_Portrait,5,5,5,5);
	app.printer.setHeader(theReport.frHeader);
	app.printer.setFooter(null);
	app.printer.suppressDialog := true;
	app.printer.printPreview := false; // &lt;&lt;&lt; LEAVE THIS
	app.printer.documentType := Print_A4;
	
	self.frmPopupInfo.left := 5;
	app.printer.print(self.frmPopupInfo);
	app.printer.close();
	app.printPreview(tmpJadeReport, true);
epilog
	delete theReport;
	self.frmPopupInfo.left := tmpLeft;
	self.frmPopupInfo.top := tmpTop;	
	self.frmPopupInfo.backColor := bakColour;
	self.tblPopupInfo.backColor := bakColour;
	self.mousePointer := Window.MousePointer_Default;


end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSelectAreaShow" id="d300042c-d909-429b-bf1d-423aead8b213">
        <updating/>
        <source>doBtnSelectAreaShow() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//23 Nov 2017	jlgrh7 TFS7469 JMT - Yard Grid Area Bulk Select Drag Net
// ---------------------------------------------------------------------------

vars
	aTA : Object;
	idx : Integer;
	aDB : YRD_ContainerGridAreaDockBar;
	numDB : Integer;
	sfr : CMUI_JadeDockContainer;
	viewMode : Integer;
	ydc : YRD_ContainerDrawingController;
	showYardAlloc : Boolean;
begin
	app.myPassport.myActivityCapture.startCaptureDebugMisc('Grid areas show');
	
	viewMode := VIEW_VOYAGE;
	if self.myCurrentDrawingController &lt;&gt; null then
		viewMode := self.myCurrentDrawingController.viewMode;
	endif;
	if viewMode = VIEW_VOYAGE then
		self.btnViewVoyage.value := true;
	endif;

	sfr := self.dkcGridArea;
	self.mousePointer := Window.MousePointer_HourGlass;
	
	
	self.showAreaSelectorEnable(false);
	
	self.allTerminalAreas.clear();
	self.allDockBars.purge;
	self.btnViewYardAlloc.value := false;
	self.dkcGridArea.refreshNow();
	
	foreach aTA in self.allDrawingControllers do
		self.endNotificationForSubscriber(aTA);
	endforeach;
	
	
	self.allDrawingControllers.purge;
//	self.myCurrentDrawingController := null;
	self.setMyCurrentDrawingController(null, false);
	self.myCurrentTerminalArea := null;
	self.myDrawingFrame := null;

	self.msgSelectAreas.getSelected(self.allTerminalAreas);
	
	if self.allTerminalAreas.isEmpty then
		app.msgBox("You must select as least 1 terminal area." , "Area Select", MsgBox_OK_Only);
		return;
	endif;

	self.tblYAM.clearAllData();
	self.tblGridAreaInfo.rows := 0;
	
	// ### PAR 10529
	if viewMode = VIEW_YARD_ALLOC then 
		showYardAlloc := true;
		viewMode := self.viewModePrev4YardAlloc;
	endif;

	foreach aTA in self.allTerminalAreas reversed    do
		idx := idx + 1;
		self.showArea(aTA.CM_GridArea,0,0,0,0,idx,viewMode,0);	// PAR 21532 CCMS SFW 1025 - added last 0 parameter for extra stack height
	endforeach;

	self.setYardAllocLegend();

	numDB := self.allDockBars.size;
	foreach aTA in self.allDockBars do
		aDB := aTA.YRD_ContainerGridAreaDockBar;
		aDB.width := (self.dkcGridArea.clientWidth / numDB);
		aDB.myDrawingController.showDrawingFrame(true);
	endforeach;
	self.doSetCaption();
	self.myDrawingFrame.myDragSelectFrame.zOrder(1);							//+TFS7469  
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.myDrawingFrame.myDragSelectFrame.enabled:= false;
	endif;
	self.refreshNow();
	self.doResize();

epilog
	app.myPassport.myActivityCapture.stopCaptureDebugMisc();
	self.frmSelectAreas.visible := false;

	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnShowOSGrid" id="e5712f67-afcf-4628-877a-dfe6d95b17f8">
        <updating/>
        <source>doBtnShowOSGrid(btn: Button input; _redraw : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cdc : YRD_ContainerDrawingController;
	obj : Object;
begin

	self.showOSGrid := (not self.showOSGrid);

	if self.myCurrentDrawingController = null then
		return;
	endif;
	if self.showOSGrid then
		self.myCurrentDrawingController.showOSGrid := true;
	else
		foreach obj in self.allDrawingControllers do
			cdc := obj.YRD_ContainerDrawingController;
			cdc.showOSGrid := false;
		endforeach;
		btn.value := false;
	endif;
	if _redraw then
		foreach obj in self.allDrawingControllers do
			cdc := obj.YRD_ContainerDrawingController;
			cdc.drawSelf(true);	
		endforeach;
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
        <Parameter name="_redraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseAll" id="41f7182b-eeb8-49b6-af04-c644fb196f4e">
        <updating/>
        <source>doBtnSummariseAll() updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
13 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	
begin
	self.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects (containers) to pass to the Summary Definition form.
	if self.myCurrentDrawingController &lt;&gt; null and self.myCurrentDrawingController.myTerminalArea &lt;&gt; null then
		// For the current drawing controller process each of the location controllers and get the tracked items.
		self.myCurrentDrawingController.myTerminalArea.CM_TerminalArea.getAllLocationsTrackedItems( coll );
	endif;
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	self.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnSwitchView" id="bdd88063-d9d0-493d-bb7d-c48129e046eb">
        <updating/>
        <source>doBtnSwitchView() updating;

/*

Purpose:			Toggle between Side View and End View

Parameters:			

Return Value:		


Date		Who		Reason
11 Dec 2008	consw1	Initial creation
07 Jul 2010	cnwkpd1	PAR #24916 - restrict Terminal Area saved settings to TAs that 
					are JMT system ones

*/

vars
	aDB : YRD_ContainerGridAreaDockBar;
	area : CM_GridArea;
	dockBarColl : ObjectArray;
	idx : Integer;
	minRow, maxRow, minColumn, maxColumn : Integer;
	numDB : Integer;
	obj : Object;
	viewMode : Integer;
	ydc : YRD_ContainerDrawingController;
	ta : CM_TerminalAreaMaster;
	taIndex : Integer;

begin
	app.myPassport.myActivityCapture.startCaptureDebugMisc('Grid areas switch view');
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	//04 Jun 2010	NDL	Par 24331
	if self.myCurrentDrawingController &lt;&gt; null then
		// PAR #24916 - Ignore Terminal Area types that are not JMT system ones
		ta := self.myCurrentDrawingController.myTerminalArea;
		if ta &lt;&gt; null and ta.type &lt;= TA_TYPE_MAX then
			taIndex := ta.type + 1;
			self.xmlEndViewByType[taIndex] := not self.getXMLEndViewValueFor(ta);
		endif;
		viewMode := self.myCurrentDrawingController.displayMode;	//02 Feb 2018	NDL	TFS 36848
	endif;
	//self.xmlEndView := not self.xmlEndView;

	create dockBarColl transient;
	self.allDockBars.copy(dockBarColl);

	self.allDockBars.clear;
	self.allDrawingControllers.clear;
	self.setMyCurrentDrawingController(null, false);
	self.myCurrentTerminalArea := null;
	self.myDrawingFrame := null;
	
	foreach obj in dockBarColl do
		ydc := obj.YRD_ContainerGridAreaDockBar.myDrawingController.YRD_ContainerDrawingController;
		area := ydc.myTerminalArea.CM_GridArea;
		minRow := ydc.minRow;
		maxRow := ydc.maxRow;
		minColumn := ydc.minColumn;
		maxColumn := ydc.maxColumn;
	//	viewMode := ydc.viewMode;	
		delete obj;
		self.dkcGridArea.refreshNow();
		idx := idx + 1;
		self.showArea(area,minRow,maxRow,minColumn,maxColumn,idx,viewMode,0);	// PAR 21532 CCMS SFW 1025 - added last 0 parameter for extra stack height
	endforeach;

	numDB := self.allDockBars.size;
	foreach obj in self.allDockBars do
		aDB := obj.YRD_ContainerGridAreaDockBar;
		aDB.width := (self.dkcGridArea.clientWidth / numDB);
		aDB.myDrawingController.showDrawingFrame(true);
	endforeach;

	self.doSetCaption();

	self.refreshNow();
	self.doResize();
	
	self.setDisplayMode( viewMode );	//02 Feb 2018	NDL	TFS 36848

epilog
	delete dockBarColl;
	app.myPassport.myActivityCapture.stopCaptureDebugMisc();
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnViewYardAllocClick" id="d4f0671c-33e5-44c6-b8dd-f6d0c6ce4cb7">
        <updating/>
        <source>doBtnViewYardAllocClick() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
12 November 2008	consw1	SWF1030 - Method rewritten for Yard Allocation rework

*/

vars
	showYAM : Boolean;
begin
	showYAM := self.btnViewYardAlloc.value;

	self.tblYAM.visible := showYAM;
	
	self.tblGridAreaInfo.visible := not showYAM;
	self.dkbCargoPic.visible := not showYAM and self.myTerminal.getConfig(ShowCargoPicture).Boolean;

	
	self.setLastColumnMaxWidth(self.tblGridAreaInfo); // PAR 19027
	self.doResizeColumnWidths(self.tblGridAreaInfo, true); // PAR 19027
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildAttachCaption" id="322967fd-9dec-4af4-a00b-bd2528ffc973">
        <updating/>
        <source>doBuildAttachCaption(_theTI : CM_TrackedItem; _theAction : Integer io) : String updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theContainer : CM_Container;
	theCOU, theCaption : String;
	
begin
	if _theTI &lt;&gt; null then
		if _theTI.isKindOf(CM_Container) then
			theContainer := _theTI.CM_Container;
			if theContainer.isPortHole then
				theCOU := theContainer.couId.trimBlanks;
				if theCOU.trimBlanks = null then
					theCOU := "COU";
				endif;
				if theContainer.hasCOU then
					_theAction := ACTION_DISCONNECT;
					theCaption := theContainer.id &amp; " Dettach From " &amp; theCOU &amp; "..." ;
				else
					_theAction := ACTION_CONNECT;
					theCaption := theContainer.id &amp; " Attach To " &amp; theCOU &amp; "...";
				endif;
			endif;
		endif;				
	endif;

	return theCaption;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theAction" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildConnectCaption" id="fa25cca7-91b7-4ed3-a094-e4520d642fa7">
        <updating/>
        <source>doBuildConnectCaption(_theTI : CM_TrackedItem;_theAction : Integer io) : String updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theContainer : CM_Container;
	theTower, theCaption : String;
	otherTI : CM_TrackedItem;
	
begin
	if _theTI &lt;&gt; null then
		if _theTI.isKindOf(CM_Container) then
			theContainer := _theTI.CM_Container;
			if theContainer.isConnected then
				_theAction := ACTION_DISCONNECT;
			else
				_theAction := ACTION_CONNECT;
			endif;
			
			if theContainer.isPortHole then
				theTower := theContainer.towerId.trimBlanks;
				if theTower.trimBlanks = null then
					otherTI := theContainer.getOtherTrackedItem(_theAction);
					if otherTI &lt;&gt; null then
						theTower := otherTI.id;
					else
						theTower := "Tower";
						theCaption := null;
						return theCaption;
					endif;
				endif;
				if _theAction = ACTION_DISCONNECT then
					theCaption := theContainer.id &amp; " Disconnect From " &amp; theTower &amp; "...";
				else
					theCaption := theContainer.id &amp; " Connect To " &amp; theTower &amp; "...";
				endif;
			else
				if theContainer.isConnected then
					_theAction := ACTION_DISCONNECT;
					theCaption := theContainer.id &amp; " Disconnect From Power...";
				else
					_theAction := ACTION_CONNECT;
					theCaption := theContainer.id &amp; " Connect To Power...";
				endif;
			
			endif;
		endif;				
	endif;

	return theCaption;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theAction" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuAddLabourRestrict" id="ac7bfba8-77ab-4bae-89ce-66da46baee81">
        <source>doBuildMnuAddLabourRestrict(_ta : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tStr :String;
	str :String;
	index :Integer;
	lIndex : Integer;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	root : CM_Root;
	checked : Boolean;
	termSubArea : CM_TerminalSubArea;
begin

	if not app.myCurrentUserCan(self.myTerminal,PmAdmLabrestrMaint) then
		self.mnuAddLabourRestrict.enabled := false;
		self.mnuAddLabourRestrict.visible := false;
		return;
	endif;

	mnuMaster := self.mnuAddLabourRestrict;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.userObject := null;
	mnuMaster.helpKeyword := "MAIN";

	foreach index in 1 to 50 do
		mnuChild := mnuMaster.getMenuItem(index); // check if the menu is already cloned
		delete mnuChild;
	endforeach;


	foreach termSubArea in _ta.allSubAreas do
		mnuIndex 	:= mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif;
		mnuChild.caption := termSubArea.id;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := termSubArea.id;
		mnuChild.userObject := termSubArea;
	endforeach; 
	
	if mnuIndex &gt; 0 then // index has not been set as no termsubareas added above 
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned	
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif;
		mnuChild.caption := "-";
	endif;
	
	mnuIndex := mnuIndex + 1; 
	
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	mnuChild.caption := "&amp;All...";
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := "ALL";
	mnuChild.userObject := _ta;
	
	mnuIndex := mnuIndex + 1; 
		
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	mnuChild.caption := "&amp;Define Area...";
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := "DEFINE";
	mnuChild.userObject := _ta;

end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuContainer" id="6cee388c-bf42-4085-85f4-1377924bfdd6">
        <updating/>
        <source>doBuildMnuContainer(_theTI : CM_TrackedItem input; _fm : CM_FutureMove) updating;
// ---------------------------------------------------------------------------
// Created:		April 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags
// 15/06/2010	cnwcs5		par 24342 - no context menus for stops
// ---------------------------------------------------------------------------

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	theAction 	: Integer;
	container	: CM_Container;
begin
	self.mnuGridAreaContext.enabled := true;

	self.mnuCargo.visible := true;
	self.mnuCargoSetGrade.visible := false;
	self.mnuCargoConnectDis.visible := false;
	
	if _theTI.isKindOf(CM_Container) then
		self.mnuCargoConnectDis.caption := self.doBuildConnectCaption(_theTI,theAction);
		if _theTI.CM_Container.isPortHole then
			if _theTI.requiresPower then  //par 19221
				self.mnuCargoConnectDis.visible := true;
				self.mnuCargoConnectDis.userObject := _theTI;
			endif;
		endif;
		if _theTI.requiresPower then
			self.mnuCargoConnectDis.visible := true;
			self.mnuCargoConnectDis.userObject := _theTI;
		endif;	
	endif;
	
	self.doBuildUnplanMenu(self.mnuCargoUnplan,self.mnuCargoUnqueue, _theTI);
	//epr par 32261 19/8/13
	self.myAssistant.menuSetGradeBuild(self.mnuCargoSetGrade,self.mnuSetGradeSub,_theTI);
	
	self.mnuCargoAttach.visible := false;
	self.mnuCargoAttachGenSet.visible := false;	// Attach Generator Set. Par17775. ccms1405. APM Yard Ops, new generator types
	self.mnuCargoDetachGenSet.visible := false;	// Detach Generator Set. Par17775. ccms1405. APM Yard Ops, new generator types
	if _theTI.isKindOf(CM_Container) then
		container := _theTI.CM_Container;
		self.mnuCargoAttach.caption := self.doBuildAttachCaption(_theTI,theAction);
		if container.hasCOU then
			self.mnuCargoAttach.visible := true;
			self.mnuCargoAttach.userObject := _theTI;
		endif;
		if container.isPortHole then // isPortHole is designed for attaching COU
			self.mnuCargoAttach.visible := true;
			self.mnuCargoAttach.userObject := _theTI;
		endif;
		if container.isReefer then	// Par17775. ccms1405. APM Yard Ops, new generator types
			if container.getGenerator = null then
				self.mnuCargoAttachGenSet.visible := true;
				self.mnuCargoAttachGenSet.userObject := _theTI;
			else
				self.mnuCargoDetachGenSet.visible := true;
				self.mnuCargoDetachGenSet.userObject := _theTI;
			endif;
		endif;
		

	endif;
	// PAR 18682
	self.mnuGridShiftLeft.visible := self.canShiftLeft(_theTI);
	self.mnuGridShiftRight.visible := self.canShiftRight(_theTI);
	if self.myCurrentDrawingController.flipHorizontal then
		self.mnuGridShiftLeft.picture := null;// PAR 19215
		self.mnuGridShiftRight.picture := null;// PAR 19215
		self.mnuGridShiftLeft.caption  := self.getShiftTranslate(Xlat_0010360);// PAR 19215
		self.mnuGridShiftRight.caption := self.getShiftTranslate(Xlat_0010359);// PAR 19215
	else
		self.mnuGridShiftLeft.caption  := self.getShiftTranslate(Xlat_0010359);// PAR 19215
		self.mnuGridShiftRight.caption := self.getShiftTranslate(Xlat_0010360);// PAR 19215
	endif;
	
	if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
		self.mnuGridShiftRight.userObject := _theTI;
		self.mnuGridShiftLeft.userObject := _theTI;
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE or self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
		self.mnuGridShiftRight.userObject := _fm;
		self.mnuGridShiftLeft.userObject := _fm;
	
	endif;
	
	if _theTI.isKindOf(CM_TILC) then	// Par17775. ccms1405. APM Yard Ops, new generator types
		if _theTI.CM_TILC.myGenerator = null then
			self.mnuCargoAttachGenSet.visible := true;
			self.mnuCargoAttachGenSet.userObject := _theTI;
		else
			self.mnuCargoDetachGenSet.visible := true;
			self.mnuCargoDetachGenSet.userObject := _theTI;
		endif;
	endif;
	
	self.mnuCargoTestAP.visible := true;
	self.mnuCargoTestAP.userObject := _theTI;
	self.mnuCargoTestAP.caption := app.getErrorString(YRDTestAutoPlan) &amp; _theTI.id &amp; "...";
	
	self.mnuCargoAP.visible := true;
	//epr par 36069 6/5/15
	if self.myCurrentDrawingController &lt;&gt; null and
		self.myCurrentDrawingController.allSelectedObjects.size &gt; 1  then
		self.mnuCargoAP.caption := app.getErrorString(Auto_queue_selected_item);
	else
		self.mnuCargoAP.caption := app.getErrorString1(Auto_queue, _theTI.id);
	endif;
	
	
	self.mnuCargoLCL.visible := false;
	if _theTI.isKindOf(CM_Container) then  //always allow pack/unpack
		self.mnuCargoLCL.visible := true;
		self.mnuCargoLCL.userObject := _theTI;
		self.mnuCargoLCL.caption := app.getErrorString(CMUI_Pack_Unpack) &amp; _theTI.id;
	endif;

	self.mnuRemarks.userObject := _theTI;
	self.mnuRemarks.caption := app.getErrorString(Remarks_GC) &amp; _theTI.id;

	//Added from OLD JC 16/06/2005 - 
	self.mnuCargoEnquiry.userObject := _theTI;
	self.mnuCargoEnquiry.caption := app.getErrorString(CMUI_Enquiry) &amp; _theTI.id ;

	//self.doBuildUnplanMenu(self.mnuCargoUnplan,self.mnuCargoUnqueue, _theTI);
	
	self.mnuCargoEdit.userObject := _theTI;
	self.mnuCargoEdit.caption := app.getErrorString(CMUI_Edit) &amp; _theTI.id;
	self.mnuCargoEdit.visible := true;
	self.mnuCargoMoveIt.visible := true;

	self.mnuCargoMoveIt.userObject := _theTI; // PAR 17818
	
	// PAR 21532 CCMS SFW 1025
	self.mnuCargoShowOverstow.visible := false;
	self.mnuCargoMoveOverstow.visible := false;
	
	if _theTI.isOverStowedRTQueue(null) then
		
		self.mnuCargoShowOverstow.visible := true;
		self.mnuCargoShowOverstow.userObject := _theTI;
		self.mnuCargoMoveOverstow.visible := true;
		self.mnuCargoMoveOverstow.userObject := _theTI;
	endif;
	
	self.doBuildMnuTasksAdd(_theTI);	
	self.doBuildMnuTasksComplete(_theTI);	
	self.doBuildMnuTasksRemove(_theTI);	

	// par 24342 self.doBuildMnuStops(_theTI);	
	self.mnuStops.userObject := _theTI;	// par 24342
	
	//epr 20/1/10 inspect is good
	self.mnuInspect.visible				:=	false;
	if app.isAllowedToInspect then
			self.mnuInspect.visible		:=	true;
			self.mnuInspect.enabled		:=	true;
		self.mnuInspect.userObject:=_theTI;
	endif;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_fm" type="CM_FutureMove"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuLocation" id="b43630ee-2c53-4ae6-ba92-06aee95ce242">
        <source>doBuildMnuLocation(_termArea : CM_TerminalArea;_gridController : CM_GridController);
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
vars
	menuParams : CMIF_MenuParams;
	aSub : CM_BlockStack;
	aLabR : CM_LabourRestriction;
	termArea : CM_TerminalArea;
	gridController : CM_GridController;
	termID,controllerID : String;
	aChildMenuItem : MenuItem;
	maxHeight, idx,nuthinIndex : Integer;
begin
	self.clearupMenuParams(); // PAR 18723

	termArea := _termArea;
	maxHeight := termArea.CM_GridArea.heightOfStack;
	gridController := _gridController;
	termID := termArea.id;
	controllerID := gridController.getID;
	
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	// ########
	// The Form
	self.mnuLcnAreaMain.visible := true; 
	self.mnuLcnPadMain.visible := true; 
	
	// ##############################
	// ##############################
	// AREA MENU
	// ##############################
	// ##############################
	
	self.mnuLcnAreaMain.caption := termID  &amp; " Location &amp;Maintenance"; 
	create menuParams transient;
	self.mnuLcnAreaMaint.userObject := menuParams;
	menuParams.setForCreate(YRD_PadArea.AreaMode_Height,null,null,termArea,null,null);
	self.mnuLcnAreaMaint.caption := termID  &amp; " Location &amp;Maintenance...";
	self.mnuLcnAreaMaint.visible := false; // do not use?
	
	// ########
	// PAD EDIT
	create menuParams transient;
	self.mnuLcnAreaHeight.userObject := menuParams;
	menuParams.setForCreate(YRD_PadArea.AreaMode_Height,null,null,termArea,null,null);
	self.mnuLcnAreaHeight.caption := termID &amp; " Pad &amp;Edit...";

	// ########
	// LABOUR
	create menuParams transient;
	self.mnuLcnAreaLabour.userObject := menuParams;
	menuParams.setForCreate(YRD_PadArea.AreaMode_Labour,null,null,termArea,null,null);
	self.mnuLcnAreaLabour.caption := termID &amp; " &amp;Labour Restrictions...";
	
	self.mnuLcnAreaLocation.visible := false;
	self.mnuLcnPadLocation.visible := false;

	// ########
	// SUB BLOCK STACKS
	create menuParams transient;
	self.mnuLcnAreaSBS.userObject := menuParams;
	menuParams.setForCreate(YRD_PadArea.AreaMode_SubBlock,null,null,termArea,null,null); // just generally go to SBS
	self.mnuLcnAreaSBS.caption := termID &amp; " &amp;Sub BlockStacks...";

// ############################################################################################################

	// ##############################
	// ##############################
	// PAD MENU
	// ##############################
	// ##############################
	
	aSub := gridController.mySubBlockStack;
	self.mnuLcnPadMain.caption := controllerID  &amp; " Location &amp;Maintenance"; 
	
	// ########
	// PAD EDIT
	create menuParams transient;
	self.mnuLcnPadPad.userObject := menuParams;
	menuParams.setForCreate(YRD_PadArea.AreaMode_Height,null,gridController,termArea,null,null);
	self.mnuLcnPadPad.caption := controllerID &amp; " Pad &amp;Edit...";

/* 771 YAM work no longer needed
	// ########
	// LOCATION RESTRICTIONS
	if not self.configAutoPlanUseAllocations then
		self.mnuLcnPadLocation.visible := false;
	else
		aLR := gridController.myLocationRestriction;
		if aLR &lt;&gt; null then
			create menuParams transient;
			self.mnuLcnPadLocation.visible := true;
			self.mnuLcnPadLocation.userObject := menuParams;
			menuParams.setForCreate(YRD_PadArea.AreaMode_Location,null,aLR,termArea,null,null); // just generally go to Restrictions
			self.mnuLcnPadLocation.caption := aLR.id &amp; " Location &amp;Restriction...";
		else
			self.mnuLcnPadLocation.visible := false;
		endif;
	endif;
*/
	// ########
	// SUB BLOCK STACKS
	if aSub &lt;&gt; null then
		create menuParams transient;
		self.mnuLcnPadSBS.userObject := menuParams;
		menuParams.setForCreate(YRD_PadArea.AreaMode_SubBlock,null,aSub,termArea,null,null); // just generally go to SBS
		self.mnuLcnPadSBS.visible := true;
		self.mnuLcnPadSBS.caption := aSub.id &amp; " &amp;Sub BlockStack...";
		self.mnuSubBlock.visible := true;
		self.mnuSubBlock.userObject := aSub;
		self.mnuSubBlock.caption := aSub.id &amp; " &amp;View...";
	else
		self.mnuLcnPadSBS.visible := false;
		self.mnuSubBlock.visible := false;
	endif;

	// #################################
	// DYNAMIC LOCATION CONTROLLER MENUS
	
	// clean up first
	foreach idx in 1 to 8 do
		aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_NOTHING_BASE + idx);
		if aChildMenuItem &lt;&gt; null then
			delete aChildMenuItem;
		endif;
	endforeach;
	foreach idx in 1 to 10 do
		aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_LABOUR_BASE + idx);
		if aChildMenuItem &lt;&gt; null then
			delete aChildMenuItem;
		endif;
	endforeach;
	
	aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_POWER_GOOD);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_POWER_BAD);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_UNAVAIL);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_AVAIL);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	
	// make those menus
	// ########
	// LABOUR
	self.mnuLcnPadLabour.visible := false;
	idx := 0;
	foreach aLabR in gridController.allLabourRestrictions do
		idx := idx + 1;
		create menuParams transient;
		aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_LABOUR_BASE + idx);
		if aChildMenuItem = null then
			aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_LABOUR_BASE + idx);
		endif;
		aChildMenuItem.caption := controllerID &amp; " &amp;" &amp; aLabR.id &amp; " Labour Restriction...";
		aChildMenuItem.userObject := menuParams;
		menuParams.setForCreate(YRD_PadArea.AreaMode_Labour,null,aLabR,termArea,null,null);
	endforeach;
	
	// ### HEIGHTS
	if gridController.canHaveHeightRestrictions() then
		
		// ### AVAILABLE OR NOT
		if not gridController.amIAvailable then
			aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_AVAIL);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_AVAIL);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Make &amp;Available";
			aChildMenuItem.userObject := gridController;
			aChildMenuItem.helpContextId := MENU_INDEX_AVAIL;

		else
			if gridController.getAvailability() &lt;&gt; PAD_AVAILABLE then
				aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_AVAIL);
				if aChildMenuItem = null then
					aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_AVAIL);
				endif;
				aChildMenuItem.caption := controllerID &amp; " Make &amp;Available";
				aChildMenuItem.userObject := gridController;
				aChildMenuItem.helpContextId := MENU_INDEX_AVAIL;
			endif;

			aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_UNAVAIL);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_UNAVAIL);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Make &amp;Unavailable";
			aChildMenuItem.userObject := gridController;
			aChildMenuItem.helpContextId := MENU_INDEX_UNAVAIL;
		endif;
		
		// ### NOTHING FROM... MENUS
		foreach idx in 1 to maxHeight do
			nuthinIndex := MENU_INDEX_NOTHING_BASE + idx;
			aChildMenuItem := self.mnuLcnPadMain.getMenuItem(nuthinIndex);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(nuthinIndex);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Nothing From &amp;" &amp; idx.String;
			aChildMenuItem.userObject := gridController;
			aChildMenuItem.helpContextId := nuthinIndex;
		endforeach;	
	endif;
	
	// ### POWER GOOD OR BAD
	if gridController.hasPower then
		if gridController.powerDamaged then
			aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_POWER_GOOD);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_POWER_GOOD);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Power Is &amp;Good";
			aChildMenuItem.userObject := gridController;
			aChildMenuItem.helpContextId := MENU_INDEX_POWER_GOOD;

		else
			aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_POWER_BAD);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_POWER_BAD);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Power Is &amp;Bad";
			aChildMenuItem.userObject := gridController;
			aChildMenuItem.helpContextId := MENU_INDEX_POWER_BAD;
		endif;
	endif;
	
	//epr 20/1/10 inspect is good
	self.mnuInspect.visible				:=	false;
	if app.isAllowedToInspect then
			self.mnuInspect.visible		:=	true;
			self.mnuInspect.enabled		:=	true;
		self.mnuInspect.userObject:=gridController;
	endif;
end;</source>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
        <Parameter name="_gridController" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuRemoveLabRestrict" id="24ecb14a-944d-4bfd-a53a-4d86c46084db">
        <source>doBuildMnuRemoveLabRestrict(_ta : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	str :String;
	index :Integer;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	labourRestriction : CM_LabourRestriction;

begin

	if not app.myCurrentUserCan(self.myTerminal,PmAdmLabrestrMaint) or _ta.allRestrictionsLabour.isEmpty then
		self.mnuRemoveLabRestrict.enabled := false;
		self.mnuRemoveLabRestrict.visible := false;
		return;
	endif;

	mnuMaster := self.mnuRemoveLabRestrict;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.userObject := null;
	mnuMaster.helpKeyword := "MAIN";

	foreach index in 1 to 50 do
		mnuChild := mnuMaster.getMenuItem(index); // check if the menu is already cloned
		delete mnuChild;
	endforeach;

	foreach labourRestriction in _ta.allRestrictionsLabour do
		mnuIndex 	:= mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif;
		
		mnuChild.caption := labourRestriction.getDisplayStringFull();
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := labourRestriction.id ;
		mnuChild.userObject := labourRestriction;
	endforeach; 
	
	if mnuIndex &gt; 0 then // index has not been set as no termsubareas added above 
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned	
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
		endif;
		mnuChild.caption := "-";
	endif;
	
	mnuIndex := mnuIndex + 1; 
	
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	mnuChild.caption := "&amp;All...";
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := "ALL";
	mnuChild.userObject := _ta;
	
	mnuIndex := mnuIndex + 1; 
		
	mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := mnuMaster.loadSubMenu(mnuIndex); // Clone menu
	endif;
	mnuChild.caption := "&amp;View Restrictions...";
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := "VIEW";
	mnuChild.userObject := _ta;

epilog

end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksAdd" id="e5457b10-27b9-4a40-b628-1970c47ee8ea">
        <updating/>
        <source>doBuildMnuTasksAdd(_theTI : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	dynaDict	: DynaDictionary;
	obj			: Object;
	taskDesc	: CM_ToDoTaskDesc;
	mnuChild,mnuMaster	: MenuItem;
	taskDict		: CM_ToDoTaskDescByCode;
	useTaskForm : Boolean;
	
begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskAdd.visible := false;
		return;
	endif;
	
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	if taskDict.isEmpty then
		// no permission to add any tasks
		self.mnuTaskAdd.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that can be set
	mnuMaster := self.mnuTaskAdd;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption :=  app.getErrorString(Tasks_ADDDDdd); 	//"Add Tasks";
	self.mnuTaskAddSub.visible := true;

	// 36868 sort menu items by sortKey then description, so that if there is no sort key or it is not unique then the description becomes the main sort field
	create dynaDict transient;
	dynaDict.setMembership(CM_ToDoTaskDesc);
	dynaDict.addMemberKey("sortKey", false, true);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.endKeys(true);
	
	foreach taskDesc in taskDict do
		dynaDict.add(taskDesc);
	endforeach;

	foreach obj in dynaDict do
		taskDesc := obj.CM_ToDoTaskDesc;
		// Always delete the tasks to complete menu
		mnuChild := mnuTaskComplete.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		mnuChild := mnuTaskRemove.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;

		if taskDesc.description = null then 
			continue;
		endif;
		
			// DVB added to screen for cargo type.
		if not taskDesc.isAvailableForCargoType(_theTI.cargoType) then
			continue;
		endif;
		
		// Par 17775. ccms1045. APM - Yard Ops, new generator Types. August 2008
		if not taskDesc.isValidForGenSet( _theTI ) then
			mnuChild := mnuMaster.getMenuItem(taskDesc.code); // check if the menu is already cloned
			if mnuChild &lt;&gt; null then
				delete mnuChild;
			endif;
			continue;
		endif;

		// add each todo task type into the add menu
		mnuChild := mnuMaster.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskAddSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(taskDesc.code); // Clone menu
		mnuChild.caption := taskDesc.description;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := taskDesc.description;
		mnuChild.userObject := _theTI;
	endforeach;

epilog
	delete taskDict;
	delete dynaDict;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksComplete" id="f4b4a2d1-1d7f-4a49-8c5a-bcd4024a532d">
        <updating/>
        <source>doBuildMnuTasksComplete(_theTI : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	task	: CM_ToDoTask;
	taskDesc	: CM_ToDoTaskDesc;
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex,lMoveMode : Integer;
	lCaption	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	lPicture : Picture;
	root : CM_Root;
	taskDict		: CM_ToDoTaskDescByCode;
	useTaskForm : Boolean;

begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskComplete.visible := false;
		return;
	endif;
	
	taskDict := app.myPassport.myUser.getToDoTasksCompleteForTerm(self.myTerminal);
	if taskDict.isEmpty then
		// no permission to complete any tasks
		self.mnuTaskComplete.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	mnuMaster := self.mnuTaskComplete;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Complete Tasks";
	self.mnuTaskCompleteSub.visible := true;
	self.mnuTaskCompleteSub.caption := "No Tasks";
	
	foreach task in _theTI.allToDoTasksToDo do
	
		// Hide the todo tasks inthe add menu that we already have to do
		mnuChild := self.mnuTaskAdd.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			mnuChild.visible := false;
		endif;
		
		if (not taskDict.includes(task.toDoTaskDesc)) then
			// user does not have permission to complete this task
			continue;
		endif;
		
		if task.toDoTaskDesc.isForGenSetAttachDetach() then	//Par17775. ccms 1045. Attach / detach generator cannot be completed manually
			continue;
		endif;

		// create a list of the todo tasks that we have to do
		mnuChild := mnuMaster.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		// always delete as this is different for each TI
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskCompleteSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(task.toDoTaskDescCode); // Clone menu
		mnuChild.caption := task.toDoTaskDescDesc;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := task.toDoTaskDescDesc;
		mnuChild.userObject := _theTI;
	endforeach;

	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksRemove" id="7d40438c-85e1-44e1-9341-d1e2314d9281">
        <updating/>
        <source>doBuildMnuTasksRemove(_theTI : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	task	: CM_ToDoTask;
	taskDesc	: CM_ToDoTaskDesc;
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex,lMoveMode : Integer;
	lCaption	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	lPicture : Picture;
	root : CM_Root;
	taskDict		: CM_ToDoTaskDescByCode;
	useTaskForm : Boolean;

begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskRemove.visible := false;
		return;
	endif;
	
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	if taskDict.isEmpty then
		// no permission to remove any tasks
		self.mnuTaskRemove.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	mnuMaster := self.mnuTaskRemove;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Remove Tasks";
	self.mnuTaskRemoveSub.visible := true;
	self.mnuTaskRemoveSub.caption := "No Tasks";
	
	foreach task in _theTI.allToDoTasksToDo do
	
		// Hide the todo tasks inthe add menu that we already have to do
		mnuChild := self.mnuTaskAdd.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			mnuChild.visible := false;
		endif;
		
		if (not taskDict.includes(task.toDoTaskDesc)) then
			// user does not have permission to add/remove this task
			continue;
		endif;
		
		// create a list of the todo tasks that we have to do
		mnuChild := mnuMaster.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		// always delete as this is different for each TI
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskRemoveSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(task.toDoTaskDescCode); // Clone menu
		mnuChild.caption := task.toDoTaskDescDesc;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := task.toDoTaskDescDesc;
		mnuChild.userObject := _theTI;
	endforeach;

epilog
	delete taskDict;
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuZoom" id="7f26fdc4-ccf7-475d-a023-1a7a501188dc">
        <source>doBuildMnuZoom(_theZoomMenu : MenuItem input);
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex : Integer;
	lCaption	: String;
	mnuChild	: MenuItem;
	mnuIndex 	: Integer;
begin

	if self.myCurrentDrawingController = null then
		_theZoomMenu.visible := false;
		return;
	endif;
	
	self.mnuGridAreaContext.enabled := true;

	_theZoomMenu.visible := true;

	self.doBuildMnuZoomSub(_theZoomMenu,1.0, 1);
	self.doBuildMnuZoomSub(_theZoomMenu,1.5, 2);
	self.doBuildMnuZoomSub(_theZoomMenu,2.0, 3);
	self.doBuildMnuZoomSub(_theZoomMenu,3.0, 4);
	self.doBuildMnuZoomSub(_theZoomMenu,4.0, 5);

	self.doBuildMnuZoomSub(_theZoomMenu,6.0, 6);   // PAR 36575
	self.doBuildMnuZoomSub(_theZoomMenu,9.0, 7);

end;</source>
        <Parameter name="_theZoomMenu" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuZoomSub" id="2a57cc7e-7e20-4cf0-bcdb-dd0b083885d6">
        <source>doBuildMnuZoomSub(_theZoomMenu : MenuItem input;_scale : Decimal; _index : Integer);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex : Integer;
	lCaption	: String;
	mnuChild	: MenuItem;
	mnuIndex 	: Integer;
begin

	lFactor := self.myCurrentDrawingController.scaleFactor;
	lCaption := "View At " &amp; _scale.String &amp; " Scale" ;
	mnuChild := _theZoomMenu.getMenuItem(_index); // check if the menu is already cloned
	if mnuChild = null then
		mnuChild := _theZoomMenu.loadSubMenu(_index); // Clone menu
	endif;
	mnuChild.caption := lCaption;
	mnuChild.visible := true;
	mnuChild.enabled := true;
	mnuChild.helpKeyword := _scale.String;
	if lFactor = _scale then
		mnuChild.checked := true;
	else
		mnuChild.checked := false;
	endif;

end;</source>
        <Parameter name="_theZoomMenu" type="MenuItem" usage="input"/>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="c1148323-c6c1-483a-8e7c-384e85abe435">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	ti : CM_TrackedItem;
	realTiSet : CM_TISet;
	taskFormName : String;
	taskFormNameLength : Integer;
	passedAction : Integer;
	selectedCargo : CM_TIArray;

begin

	taskFormName := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
		passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
		create realTiSet transient;
		create selectedCargo transient;
		self.myCurrentDrawingController.getAllSelectedTIs( selectedCargo );
		if not selectedCargo.isEmpty then
			selectedCargo.copy(realTiSet);
			ti  := realTiSet.first;
			self.myAssistant.showTasksForm (ti, realTiSet, true, passedAction );
			return;
		endif;
		return;
	endif;

	inheritMethod(menuItem);

epilog

	delete realTiSet;
	delete selectedCargo;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doContextMenuBuild" id="3dc7573a-b66d-4726-95fb-70aa10509067">
        <updating/>
        <source>doContextMenuBuild(cntrl: Control input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
16 Dec 2008	cnwkpd1	PAR #18664 - Clean up leaked transients

*/

vars
	lTI					: CM_TrackedItem;
	gridController		: CM_GridController;
	anLC				: CM_LocationsController;
	aRestriction		: CM_Restriction;
	aTiDict				: CM_TIByIdDict;
	termArea			: CM_TerminalArea;
	anFM			: CM_FutureMove;
	theObj				: Object;
	theDrawController	: YRD_ContainerDrawingController;
	tiArray				: CM_TIArray;
	deckingForTA		: Boolean;
	menuitem			: MenuItem;
begin
	self.doTurnOffContextMenus();
	self.allMenuTransients.purge; // PAR 18723

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	if self.myCurrentDrawingController = null
	or (not global.isValidObject(self.myCurrentDrawingController.myTerminalArea)) then
		//th2 PAR 12121 - ??we've just tested whether it's null - why then continue to dereference it?
		//self.myCurrentDrawingController.init(null,null);
		return;
	endif;
	
	if CMUI_GridAreaScrollableFrame.hasInstance(cntrl) then
		if conwin = cntrl.CMUI_GridAreaScrollableFrame.myTopLeftFillerFrame then
			//decking menu should be for terminal area
			deckingForTA := true;
		endif; 
	endif;
	
	self.mnuGridSelectorClear.visible := not self.myCurrentDrawingController.allSelectorTIs.isEmpty;

	anLC := self.myDrawingFrame.getObjectForPositionClass(CM_LocationsController,x, y).CM_GridController;
	if anLC.isKindOf(CM_GridController) then
		gridController := anLC.CM_GridController;
	endif;
	
	
	if deckingForTA then
		//nothing much else is relevant
		return;
	endif;

	
	theObj := self.myDrawingFrame.getObjectForPosition(x, y);
	theDrawController := self.myCurrentDrawingController;

	// PAR 24343
	if self.allowList and
	   ( theDrawController.displayMode = DISPLAY_MODE_ACTUAL or theDrawController.displayMode = DISPLAY_MODE_QUEUE ) then
		self.mnuList.visible			:= true;
		// the summarise selected is only enabled if a container is actually selected.
		self.mnuListSelected.visible	:= not theDrawController.allSelectedObjects.isEmpty;
	endif;
	
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	// Summarise menu options are only enabled if display mode is ( actual or queued ) and have correct permissions.
	// Has been defaulted to invisible in doTurnOffContextMenus.
	if self.allowSummaryDefn and
	   ( theDrawController.displayMode = DISPLAY_MODE_ACTUAL or theDrawController.displayMode = DISPLAY_MODE_QUEUE ) then
		self.mnuSummarise.visible			:= true;
		// the summarise selected is only enabled if a container is actually selected.
		self.mnuSummariseSelected.visible	:= not theDrawController.allSelectedObjects.isEmpty;
	endif;
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	if theObj = null then
		return;
	endif;
	
	if theObj.isKindOf(CM_LocationsController) then
		anLC := theObj.CM_LocationsController;
		if theObj.isKindOf(CM_GridController) then
			gridController := theObj.CM_GridController;
		endif;
		if theDrawController.displayMode = DISPLAY_MODE_ACTUAL then
			lTI := theDrawController.get40FooterFromBackEnd(y,anLC,REAL_MODE);
		elseif theDrawController.displayMode = DISPLAY_MODE_QUEUE then
			lTI := theDrawController.get40FooterFromBackEnd(y,anLC,QUEUE_MODE);
		elseif theDrawController.displayMode = DISPLAY_MODE_PLAN then
			lTI := theDrawController.get40FooterFromBackEnd(y,anLC,PLANNING_MODE);
		endif;
	elseif theObj.isKindOf(CM_Restriction) then
		aRestriction := theObj.CM_Restriction;
	elseif theObj.isKindOf(CM_TrackedItem) then
		lTI := theObj.CM_TrackedItem;
	// PAR 18682
	elseif theObj.isKindOf(CM_FutureMove) then
		anFM := theObj.CM_FutureMove;
		lTI := anFM.getTrackedItem();
	endif;

	if anLC &lt;&gt; null then
		termArea := anLC.myTerminalArea;
		if gridController &lt;&gt; null then
			self.doBuildMnuLocation(termArea,gridController);
		endif;
		
		self.doBuildMnuAddLabourRestrict(termArea); 
		self.doBuildMnuRemoveLabRestrict(termArea); 
		
		// 09/03/2011 cnwcs5 CCMS CPL 2017/PAR 27126 - start
		if app.getMyUser.canDo (self.myTerminal, PmAdmAuditTALocationView) then
			menuitem 			:= self.mnuTALocnMaint;
			menuitem.visible 	:= true;
				
			if termArea &lt;&gt; null then
				menuitem.userObject	:= termArea;
				menuitem.caption 	:= termArea.id &amp; ' ' &amp; app.getErrorString (XLAT_AuditTALocnDetails);
			else
				menuitem.userObject	:= null;
				menuitem.caption 	:= app.getErrorString (XLAT_AuditTALocnDetails);
			endif;
		endif;
		// 09/03/2011 cnwcs5 CCMS CPL 2017/PAR 27126 - end
		
		//if app.myCurrentVoyage &lt;&gt; null then
		//cnwjo3 par 23105
		if app.getMyCurrentVoyage() &lt;&gt; null then
			self.mnuGridTBA.visible := true;
			self.mnuGridTBA.userObject := anLC;
		endif;
		
		
		self.mnuCreateQuickCargo.visible := app.isSpecial();
		if self.mnuCreateQuickCargo.visible then
			self.mnuCreateQuickCargo.userObject := anLC;
		endif;
		
	endif;
	if lTI &lt;&gt; null then
		self.mnuCargo.visible := true;
		// #######################
		self.doBuildMnuContainer(lTI, anFM);
		if global.isValidObject(self.mnuCargoAP.userObject) then
			delete self.mnuCargoAP.userObject;
		else
			self.mnuCargoAP.userObject := null;
		endif;
		create tiArray transient;
		self.allMenuTransients.add(tiArray); // PAR 18723
		
		//14 Sep 2009	NDL 	Par 20514	- Not always just Tis in this coll...
		//theDrawController.allSelectedObjects.copy(tiArray);
		theDrawController.getAllSelectedTis(tiArray);
				
		self.mnuCargoMoveIt.userObject := tiArray;
		self.mnuCargoAP.userObject := tiArray;
		if theDrawController.allSelectedObjects.size &gt; 1 then
//			self.mnuCargo.visible := false;
			self.mnuGridBulkEdit.visible := true;
			create aTiDict transient;
			self.allMenuTransients.add(aTiDict); // PAR 18723
			//14 Sep 2009	NDL 	Par 20514	- Not always just Tis in this coll...
			//theDrawController.allSelectedObjects.copy(aTiDict);
			theDrawController.getAllSelectedTis(aTiDict);
			self.mnuGridBulkEdit.userObject := aTiDict;
			
			self.mnuCargoUnplan.visible := false;
			self.mnuCargoUnqueue.visible := false;
			self.mnuGridBulkUnqueue.visible := true;
			self.mnuGridBulkUnqueue.userObject := aTiDict;
			
		endif;
		
			// #####################
			// PLANNING FROM SHIP?
			// #####################
		self.myAssistant.buildMnuGridLoadPlan(self.mnuGridPlanLoad,lTI,gridController,self.myCurrentDrawingController.allSelectedObjects);		
	else
		self.myAssistant.buildMnuGridDischargePlan(self.mnuGridPlanDischarge,gridController);		
	endif;

	self.doHideSeperator();
	
	
epilog
// PAR 18723 AKB took this out as these objects are on menu items that when the user clicks would have invalid objects. See allMenuTransients
//	delete aTiDict;		// PAR #18664
//	delete tiArray;
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDFContextMenu" id="f038c777-c8ff-49b0-b1bd-20b4a3fa448d">
        <updating/>
        <source>doDFContextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	showAll : Boolean;
	caption: String;
begin
	self.doTurnOffContextMenus();
	
	// cnwjk3 SFW1030
	if conwin = self.tblYAM then
		// Show Context menu for YAM table
		self.mnuYANew.visible		:=	true;
		if app.getMyUser.canDo(self.myTerminal, PmAdmYardStatistics) then
			self.mnuGridSeperator03.visible		:=	true;
			self.mnuRebuildStats.visible		:=	true;
			self.mnuProcessMovementLog.visible	:=	true;
		endif;
		self.mnuGridSeperator02.visible		:=	true;
		//04 Jan 2012	NDL	Par 28889
		if self.allColumnFilters &lt;&gt; null then
			if not self.allColumnFilters.isEmpty then
				if self.allColumnFilters.includesFiltersFor( self.tblYAM ) then
					self.mnuClearYamTblFilters.visible := true;
				endif;
			endif;
		endif;
		self.mnuColumnOrg.visible			:=	true;
		self.mnuColumnOrg.userObject		:=	self.tblYAM;
		if self.tblYAM.hasGroups then
			self.mnuYAGroupNew.visible			:=	true;
		endif;
		if self.tblYAM.isSelected then
			if self.tblYAM.isSingleSelection then
				if self.tblYAM.isYABlockSelected then
					 caption := "Range ";
				elseif self.tblYAM.isYAGroupSelected then
					 caption := "Group ";
				endif;
				caption := caption &amp; '"' &amp; self.tblYAM.getSelectedName() &amp; '"';
			else
				caption := 'Selected';
			endif;
			if self.tblYAM.isSingleSelection or self.tblYAM.isYASelected then
				self.mnuYAEdit.caption := 'Edit ' &amp; caption &amp; '...';
				self.mnuYAEdit.visible := true;
			endif;
			self.mnuYADelete.caption := 'Delete ' &amp; caption;
			self.mnuYADelete.visible := true;
		endif;
		if self.tblYAM.isSingleSelection and self.tblYAM.isYABlockSelectedAndDeckable then
			self.mnuYADeckingOptions.visible := true;
			self.mnuYADeckingOptions.caption := "Decking Options";
		endif;
		
		self.mnuInspect.visible				:=	false;
		if app.isAllowedToInspect then
			self.mnuInspect.visible		:=	true;
			self.mnuInspect.enabled		:=	true;
			self.mnuInspect.userObject	:=	self.tblYAM.getSelectedObject();
		endif;
	else	
		showAll := true;
		self.mnuGridSeperator02.visible := showAll;
		self.doBuildMnuZoom(self.mnuZoomSub);
		self.doContextMenuBuild(cntrl,conwin, mouse,x,y);
		
		//epr par 15087
		if self.myCurrentDrawingController = null then
			return false;
		endif;
		
		self.mnuZoomSub.visible := showAll;
		if self.myCurrentDrawingController &lt;&gt; null
		and self.myCurrentDrawingController.getOverlayFrame(false).visible then
			self.mnuZoomSub.visible := true;
			self.mnuGridSelector.visible := false;
		endif;
		self.mnuGridBigFont.visible := true;
		self.mnuGridSeperator01.visible := false;
		self.mnuGridAreaContext.visible := true;
	endif;
	
	return self.showContextMenu(mnuGridAreaContext, cntrl, conwin, mouse, x, y);

end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDFDblClick" id="6a055f59-b3cc-4f93-b29a-01c456c4ef79">
        <updating/>
        <source>doDFDblClick(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - remove references to location restrictions, replace YRD_LocationMaintForm constants with YRDPadArea Constants
vars
	theTI				: CM_TrackedItem;
	theLabour			: CM_LabourRestriction;
	gridController		: CM_GridController;
	anLC				: CM_LocationsController;
	theBS				: CM_BlockStack;
	termArea			: CM_TerminalArea;
	hghtExceedObj		: CMIF_YardHeightExceeded;
	theObj				: Object;
	theDrawController	: YRD_ContainerDrawingController;
	tmpMode				: Integer;
begin


	theObj := self.myDrawingFrame.getObjectForPosition(self.origXPos.Integer, self.origYPos.Integer);

	if theObj = null then
		return;
	endif;
	
	theDrawController := self.myCurrentDrawingController;
	
	// PAR 15112
	if theObj.isKindOf(CM_LocationsController) then // empty location, check for 40 backends
		if not theObj.CM_LocationsController.allTrackedItems.isEmpty then
			if theDrawController.displayMode = DISPLAY_MODE_ACTUAL then
				tmpMode := REAL_MODE;
			elseif theDrawController.displayMode = DISPLAY_MODE_QUEUE then
				tmpMode := QUEUE_MODE;
			elseif theDrawController.displayMode = DISPLAY_MODE_PLAN then
				tmpMode := PLANNING_MODE;
			endif;
			
			theTI := theDrawController.get40FooterFromBackEnd(self.origYPos.Integer,theObj.CM_LocationsController, tmpMode);
		endif;
	endif;
	
	if theObj.isKindOf(CM_LocationsController) then
		anLC := theObj.CM_LocationsController;
		
		if theObj.isKindOf(CM_GridController) then
			gridController := theObj.CM_GridController;
		endif;
		
	elseif theObj.isKindOf(CM_BlockStack) then
		theBS := theObj.CM_BlockStack;
		
	elseif theObj.isKindOf(CM_LabourRestriction) then
		theLabour 	:= theObj.CM_LabourRestriction;
		termArea 	:= theLabour.myTerminalArea;

	elseif theObj.isKindOf(CM_FutureMove) then // PAR 18682 CCMS 1055
		theTI := theObj.CM_FutureMove.getTrackedItem(); // PAR 18682 CCMS 1055
	
	elseif theObj.isKindOf(CM_TrackedItem) then
		theTI := theObj.CM_TrackedItem;
	
	elseif theObj.isKindOf(CMIF_YardHeightExceeded) then	// PAR 21532 CCMS SFW 1025
		hghtExceedObj := theObj.CMIF_YardHeightExceeded;
	endif;
	
	self.mousePointer := MousePointer_HourGlass;
	
	if theTI &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);	
	
	// ### SUB BLOCK STACK 
	elseif theBS &lt;&gt; null then
		self.myAssistant.showLocationEnquiryForm(theBS, self.myMasterMenuAction, false, false);

	// ### LABOUR RESTRICTION
	elseif theLabour &lt;&gt; null then
		self.myAssistant.showRestrictionsForm(termArea,YRD_PadArea.AreaMode_Labour,theLabour,self.xmlFlipH,self.xmlFlipV, self.myMasterMenuAction);
	
	elseif hghtExceedObj &lt;&gt; null then	// PAR 21532 CCMS SFW 1025
		if theDrawController &lt;&gt; null then
			self.myAssistant.showHeightExceededForm(hghtExceedObj, theDrawController.getViewMode(), self.myMasterMenuAction);
		endif;
	
	else
		return;
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. Unknown DOUBLE CLICK");
	endif;
epilog
	self.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDFDragDrop" id="416f29e4-7f8c-43d9-8057-69e9a67e7a2a">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFDragDrop(frame: YRD_ContainerDrawingFrame input; win: Window input; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//7
// ---------------------------------------------------------------------------

vars

	theTIs : CM_TIArray;
	moveMode : Integer;	// 22 Aug 2011	NDL Par 28035
	obj : Object;
	gridDrawCont : CMUI_GridDrawingController;	// 22 Aug 2011	NDL Par 28035
	sourceGridAreasForm : YRD_GridAreasForm;
	sourceDrawingController : CMUI_GridDrawingController;	// 22 Aug 2011	NDL Par 28035
	
begin
	self.myDroppedTI := null;
	if win &lt;&gt; null then
		if win.userObject &lt;&gt; null then
			if win.userObject.class.name = "SHP_LoadList" then
				app.raiseCMException1(INVALID_MOVE_REQUEST, 'Cannot drag drop from Load List form.', null, null);
				return;
			endif;
		endif;
	endif;
	if self.myCurrentDrawingController.displayMode = DISPLAY_MODE_PLAN and self.myCurrentDrawingController.moveMode = REAL_MODE then
		app.raiseCMException1(INVALID_MOVE_REQUEST, Cr &amp;  'Cannot drag drop in INSTANT mode whilst displaying PLANNED cargo.', null, null);
		return;
	
	endif;
	if win.isKindOf(CMUI_GridAreaForm) or 
	   win.isKindOf(CMUI_PointDrawingFrame) or
	   win.isKindOf(CMUI_GridAreaFrame) or
	   win.isKindOf(CMUI_GridAreaForm2) or
	   win.isKindOf(CMUI_GridAreaDrawingFrame)
	   then
	   
		// 19 Aug 2011	NDL	Par 28035
		if self.isMultiCargoDrop( frame, win, x, y ) then
			return;
		endif;
			
		if self.myPreviousDrawingController &lt;&gt; null then
			create theTIs transient;
			self.myPreviousDrawingController.getAllSelectedTIs(theTIs);
			if  theTIs.size &gt; 1 then
				self.doGridAreaDragDropEventQdOS(theTIs,app.myDraggedTrackedItem);
				if theTIs.isEmpty then
					return;
				endif;
			endif;
		endif;

		self.doDropFromGridAreaForm(frame,win, x,y);
		
	endif;
	
	if win.isKindOf(YRD_RoadOperationsForm) then 
		self.doDropFromGridAreaForm(frame,win, x,y); // they basically do the same. This one is more comprehensive
	
	// 02 Sep 2011	NDL	Par 28035
	elseif win.isKindOf(CM_DataTable) then 
		if self.isMultiCargoDrop( frame, win, x, y ) then
			return;
		endif;
		self.doDropFromGridAreaForm(frame,win, x,y);
		
	endif;
	
	if app.myPassport.trxCompletedOK then
		app.isDragging := true;
	else
		app.isDragging := false;
	endif;
	
	if self.autoMask then
		if self.myCurrentDrawingController.autoMask then
			if not self.myCurrentDrawingController.allSelectorTIs.includes(self.myDroppedTI) then
				self.myCurrentDrawingController.allSelectorTIs.add(self.myDroppedTI);
			endif;
			self.doBtnAutoMaskClick(self.btnAutoMask,true);
			self.doBtnAutoMaskClick(self.btnAutoMask,false);
		endif;
		app.isDragging := false; // PAR 19505 NEW
	endif;
	
	frame.dragMode := DragMode_None;
	
	
epilog
	delete theTIs;
	frame.enableEvent("mouseMove",false);


end;</source>
        <Parameter name="frame" type="YRD_ContainerDrawingFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDFDragOver" id="884973c1-6d4f-4d0f-8fd0-e704b2ddee6f">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFDragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	maskTI 	 : CM_TrackedItem;
	targetTA : CM_TerminalArea;
	gridArea : YRD_GridArea;
	cdc : YRD_ContainerDrawingController;
begin

	// if entering the frame init the AM flag
	if state = Window.DragOver_Enter then
		if app.myMoveController &lt;&gt; null then
			app.myMoveController.isAutoMasked := false;
		endif;
	endif;


	if frame = null then
		return;
	endif;
	
	if self.frmInfoDrag.visible then
		self.frmInfoDrag.move(x,y,self.frmInfoDrag.width,self.frmInfoDrag.height);
	endif;

	if app.myMoveController = null then
		return;
	endif;
	
	
	self.setFocus();
	self.zOrder(1);
//	self.windowState := WindowState_Normal;//removed by cnwyl1 for par 12920
	
	if frame &lt;&gt; null then
		cdc := frame.YRD_ContainerDrawingFrame.getDrawingController();
	endif;

	if self.myCurrentDrawingController &lt;&gt; cdc then
		self.setMyCurrentDrawingController(cdc, true);
		app.myMoveController.isAutoMasked := false;
	endif;
	
	if state = Window.DragOver_Enter 
	and self.autoMask 
	and (not app.myMoveController.isAutoMasked) then
		if self.myCurrentDrawingController.autoMask then
			// auto masking on, colour up pad area for masked TI
			app.myMoveController.isAutoMasked := true;
			
			maskTI := app.myMoveController.myTrackedItem;
			if maskTI = null then
				return;
			endif;
			if cdc.allGridObjects.isEmpty then
				return;
			endif;
	
			self.doGridAreaDragOverAutoMask(cdc, maskTI);
		endif;
	endif;	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDFMouseDown" id="c7d39b2d-a1a3-4d79-85e4-ae5d82c7f8c0">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFMouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	db : YRD_ContainerGridAreaDockBar;
	anObject : Object;
	terminalArea : CM_TerminalArea;
begin
	
	self.origXPos := x;
	self.origYPos := y;
	frame.enableEvent(Frame::mouseMove.name, true);
	
	self.myDrawingFrame := frame.YRD_ContainerDrawingFrame;

	self.setMyCurrentDrawingController(frame.YRD_ContainerDrawingFrame.getDrawingController(), false);
	
	
	
	
		if myCurrentDrawingController &lt;&gt; null then
		terminalArea := self.myCurrentDrawingController.myTerminalArea.CM_TerminalArea;
endif;
	
	foreach anObject in self.allDockBars do
		db := anObject.YRD_ContainerGridAreaDockBar;
		db.myDrawingFrame.changeBackColor(self.defYardBackColUnselected);
	endforeach;
	frame.CMUI_GridAreaDrawingFrame.changeBackColor(self.defYardBackColSelected);
	frame.CMUI_GridAreaDrawingFrame.isDrawDeskTopRectangle := false;
	frame.CMUI_GridAreaDrawingFrame.isDrawAltSelectRectangle := false;
	frame.CMUI_GridAreaDrawingFrame.isDrawShiftSelectRectangle := false;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDFMouseMove" id="6ef6bdd2-fda1-415b-b04f-4a98c984cd38">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFMouseMove(frame: CMUI_GridAreaDrawingFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
31 Mar 2009	cnwkpd1	PAR #18982 - Fix Grid Area display and selection issues

*/

vars
	theTI		: CM_TrackedItem;
	root : CM_Root;
	lPicture : Picture;
	theTIs : CM_TIArray;
	anLC : CM_LocationsController;
	thePlanMove, theFM : CM_FutureMove;
	theLabour : CM_LabourRestriction;
	gridController : CM_GridController;
	theBS : CM_BlockStack;
	termArea : CM_TerminalArea;
	theObj : Object;
	bh : String;
	theDrawController : YRD_ContainerDrawingController;
	invalidObject : Boolean;
begin


	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	theObj := self.myDrawingFrame.getObjectForPosition(self.origXPos.Integer, self.origYPos.Integer);
	theDrawController := self.myCurrentDrawingController;
	
	if theObj = null then
		return;
	endif;
	
	//14/03/2011 cnwdz2 27138
	on Exception do app.handleDeletedObject(exception, theObj, invalidObject);
	
	//14/03/2011 cnwdz2 27138 start
	theObj.edition;
	if invalidObject then
		return;
	endif;
	//14/03/2011 cnwdz2 27138 end
	
	if theObj.isKindOf(CM_LocationsController) then
		anLC := theObj.CM_LocationsController;
		if theObj.isKindOf(CM_GridController) then
			gridController := theObj.CM_GridController;
		endif;
		
		theTI := theDrawController.get40FooterFromBackEnd(y,anLC,REAL_MODE);
		// important that this actually be the ti's primary location - validation in move code
		if theTI &lt;&gt; null then
			anLC := theTI.myPrimaryActualLocation;
		endif;
				
	elseif theObj.isKindOf(CM_BlockStack) then
		theBS := theObj.CM_BlockStack;
	elseif theObj.isKindOf(CM_FutureMove) then // PAR 19362
		theFM := theObj.CM_FutureMove; // PAR 19362
		theTI := theFM.getTrackedItem(); // PAR 19362
	elseif theObj.isKindOf(CM_LabourRestriction) then
		theLabour 	:= theObj.CM_LabourRestriction;
		termArea 	:= theLabour.myTerminalArea;

	elseif theObj.isKindOf(CM_TrackedItem) then
		theTI := theObj.CM_TrackedItem;
		if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
			anLC := theTI.myPrimaryActualLocation;
		elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
			anLC := theTI.myPrimaryPlannedLocation;
		elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
			anLC := theTI.myPrimaryQueuedLocation;
		endif;
		if anLC &lt;&gt; null and not anLC.isKindOf(CM_GridController) then		// PAR #18982
			app.msgBox("WARNING. " &amp; theTI.id &amp; " is not in the yard!" &amp; Cr &amp; Cr &amp; "Press F5 to refresh and try again!", "Move Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		endif;
	endif;

if app.isSpecial() and  theTI &lt;&gt; null then
	bh := theTI.id &amp; Cr &amp; theTI.getISOType() &amp; Cr &amp; theTI.voyageCode &amp; Cr &amp; theTI.dischargePortDescription &amp; Cr &amp; theTI.operatorCode;
//write bh;
	self.myCurrentDrawingController.setBubbleHelp(bh);
endif;

	if button = Window.MouseButton_Left 
	and frame.dragMode &lt;&gt; DragMode_Drag
	and app.dragDetected(x, y, self.origXPos, self.origYPos) then

		// PAR 19600 can only drag drop actual cargo in actual display mode
		// can drag drop planned items in planned display mode
		// cannot drag drop Qd items 
		
		if self.getDisplayMode() = DISPLAY_MODE_PLAN then
			if self.getMoveMode() &lt;&gt; PLANNING_MODE  or theObj.isKindOf(CM_TrackedItem) then
				app.msgBox(app.getErrorString(YOU_PLAN_ONLY), app.getErrorString(Move_mode), MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
		endif;
		if self.getDisplayMode() = DISPLAY_MODE_QUEUE then
			if self.getMoveMode() &lt;&gt; QUEUE_MODE  or theObj.isKindOf(CM_TrackedItem) then // PAR 19600
				app.msgBox(app.getErrorString(YOU_QUEUE_ONLY), app.getErrorString(Move_mode), MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
		endif;
		if self.getDisplayMode() = DISPLAY_MODE_ACTUAL and theObj.isKindOf(CM_FutureMove)  then // PAR 19600
			app.msgBox(app.getErrorString(Only_move_items_that_drawn_sol), app.getErrorString(Move_mode), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		/* PAR 19600 WAS
		// PAR 19362 can only drag drop actual cargo in actual display mode
		// can drag drop planned items in planned display mode
		// cannot drag drop Qd items 
		if self.getDisplayMode() &lt;&gt; DISPLAY_MODE_ACTUAL and (theTI &lt;&gt; null  and theFM = null) then
			return;
		endif;
		if self.getDisplayMode() &lt;&gt; DISPLAY_MODE_PLAN and theFM &lt;&gt; null  then
			return;
		endif;
		if self.getDisplayMode() = DISPLAY_MODE_PLAN and theFM &lt;&gt; null  then
			if theFM.isKindOf(CM_FutureMoveQueued) then
				return;
			endif;
		endif;
		*/

		
		
		create theTIs transient;
		
		if self.moveModeForm = QUEUE_MODE // PAR 17041
		and (not shift.isControlKeyPressed and  shift.isAltKeyPressed and not shift.isShiftKeyPressed) then // ALT KEY ONLY // PAR 17041
			//14 Sep 2009	NDL 	Par 20514	- Not always just Tis in this coll...
			//self.myCurrentDrawingController.allSelectedObjects.copy(theTIs);
			self.myCurrentDrawingController.getAllSelectedTis(theTIs);
	//	elseif self.moveModeForm = PLANNING_MODE and theTI &lt;&gt; null then
		elseif ( self.moveModeForm = PLANNING_MODE or self.moveModeForm = QUEUE_MODE ) and theTI &lt;&gt; null then	// 22 Aug 2011	NDL	Par 28035
			// Allow multiple containers to be selected for planning (wanted for rail)
			
			
			//10 Oct 2011	NDL	Par 28348
			if ( not shift.isControlKeyPressed )	// Ctrl key NOT pressed	
			and ( not shift.isAltKeyPressed	)// Shift key NOT pressed
			and ( app.dragDetected(x, y, self.origXPos, self.origYPos)	) // we are in drag mode
			and ( not self.myCurrentDrawingController.allSelectedObjects.isEmpty ) //there are other containers already selected
			then
				// we are dragging a container...
				//If this is one we had already selected, then we should carry on and queue or plan them all,
				// but if not, we should clear the existing collection, so we only move this one.
				if not self.myCurrentDrawingController.allSelectedObjects.includes(theTI) then
					self.myCurrentDrawingController.clearAllSelectedObjects();
				endif;
			endif;
			
			
			if self.myCurrentDrawingController.allSelectedObjects.size &gt; 1
			and self.myCurrentDrawingController.allSelectedObjects.includes(theTI) then
				//14 Sep 2009	NDL 	Par 20514	- Not always just Tis in this coll...
				//self.myCurrentDrawingController.allSelectedObjects.copy(theTIs);
				self.myCurrentDrawingController.getAllSelectedTis(theTIs);
				theTIs.remove(theTI);
			endif;
		
		else // PAR 17041
			self.myCurrentDrawingController.clearAllSelectedObjects(); // PAR 17041  
		endif;
		
		if theTIs.isEmpty then
			if theTI &lt;&gt; null then
				self.myCurrentDrawingController.selectObject(theTI,frame,false);
				theTIs.add(theTI);
			endif;
		endif;
		if not theTIs.isEmpty then
			if theTI = null then
				app.msgBox("Please drag the selected cargo from it's actual location","Move Error",MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
			// Par 10502
			// DVB Andrew just using the last dragged item rather than first array item
			// as this is the correct ti.
			//theTI := theTIs.first;
			if theTIs.includes(theTI) then
				theTIs.remove(theTI);
			endif;
			
			self.moveModeForm := self.myCurrentDrawingController.moveMode;
//			if self.moveModeForm =REAL_MODE then // PAR 17041
//				theTIs.clear; // PAR 17041
//			endif; // PAR 17041
			app.myDraggedTrackedItem := theTI;
			self.setMoveControllerSource(theTI);


			app.myMoveController.setMyOriginatingLocation(anLC);
			// if it is planned DLR discharge and a 40 they may have right clicked on the back end.
			// we must have the primary location of teh 40 so that the screen draws correctly
			if theTI.isRehandle and theTI.isAttributeTrue(TI_Attrib_IsForty) then
				thePlanMove := theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
				if thePlanMove &lt;&gt; null then
					anLC := thePlanMove.CM_FutureMovePlanned.allLocationsControllers.first;
					if anLC &lt;&gt; null and anLC.isKindOf(CM_GridController) then
						app.myMoveController.setMyOriginatingLocation(anLC);
					endif;
				endif;
			endif;									

			if not theTI.isRehandle then // PAR 22335
				// PAR 19600 - AUG2009AKB added this replan code.
				if app.myMoveController.moveMode = PLANNING_MODE and theFM &lt;&gt; null then
					app.myMoveController.isReplan := true;
					app.myMoveController.setMoveIndex(theTI.allPlannedFutureMoves.indexOf(theFM));
					app.myMoveController.setMyOriginatingLocation(theFM.getPrimaryLocation());
				elseif app.myMoveController.moveMode = QUEUE_MODE and theFM &lt;&gt; null then
					app.myMoveController.isReQueue := true;
					app.myMoveController.setMoveIndex(theTI.allQueuedFutureMoves.indexOf(theFM));
					app.myMoveController.setMyOriginatingLocation(theFM.getPrimaryLocation());
				endif;	
			endif;
			if not theTIs.isEmpty then
				app.myMoveController.setAllOtherTrackedItems(theTIs);
			endif;
			frame.dragMode := DragMode_Drag;
			root := app.myRoot;

			create lPicture transient;
			self.setPictureDragCursor(lPicture);
			if lPicture.picture &lt;&gt; null then
				frame.dragCursor := lPicture.picture;
			endif;
		endif;
	endif;
epilog
	delete lPicture;
	delete theTIs;
end;</source>
        <Parameter name="frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDFMouseUp" id="d202e5c0-e0da-4191-b0a4-8150f7215e53">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFMouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
31 Mar 2009	cnwkpd1	PAR #18982 - Fix Grid Area display and selection issues
01 Apr 2009	cnwkpd1	PAR #19367 - Fix 1090 exception in long click in Queued or Planned mode

*/

vars
	statMess : String;
	theFrame : CMUI_GridAreaFrame;
	thePIC : CMIF_PopupInfoController;
	theSBS : CM_BlockStack;
	theLabRest : CM_LabourRestriction;
	theCMObject : CM_Object;
	theTI : CM_TrackedItem;
	theLabour : CM_LabourRestriction;
	startTime : Time;
	gridController : CM_GridController;
	anLC : CM_LocationsController;
	theBS : CM_BlockStack;
	termArea : CM_TerminalArea;
	theObj : Object;
	theDrawController : YRD_ContainerDrawingController;
	tmpMode : Integer;
	bh : String;
	invalidObject  : Boolean;
	targetLocns : CM_LCArray;
begin
	theObj := self.myDrawingFrame.getObjectForPosition(x.Integer, y.Integer);
	theDrawController := self.myCurrentDrawingController;	
	
	if theObj = null then
		theDrawController.clearAllSelectedObjects();
		return;
	endif;
	
	//14/03/2011 cnwdz2 27138
	on Exception do app.handleDeletedObject(exception, theObj, invalidObject);
	
	//14/03/2011 cnwdz2 27138 start
	theObj.edition;
	if invalidObject then
		theDrawController.clearAllSelectedObjects();
		return;
	endif;
	//14/03/2011 cnwdz2 27138 end
	
	if theObj.isKindOf(CM_LocationsController) then
		anLC := theObj.CM_LocationsController;
		if theObj.isKindOf(CM_GridController) then
			gridController := theObj.CM_GridController;
		endif;
	elseif theObj.isKindOf(CM_BlockStack) then
		theBS := theObj.CM_BlockStack;
	elseif theObj.isKindOf(CM_FutureMove) then // PAR 18682 CCMS 1055
		theTI := theObj.CM_FutureMove.getTrackedItem(); // PAR 18682 CCMS 1055
		anLC := theObj.CM_FutureMove.getPrimaryLocation();		// PAR #18982
	elseif theObj.isKindOf(CM_LabourRestriction) then
		theLabour 	:= theObj.CM_LabourRestriction;
		termArea 	:= theLabour.myTerminalArea;
		anLC 		:= theObj.CM_LabourRestriction.allLocationControllers.first;
	
	elseif theObj.isKindOf(CM_TrackedItem) then
		theTI := theObj.CM_TrackedItem;
		if theDrawController.displayMode = DISPLAY_MODE_ACTUAL then
			anLC := theTI.myPrimaryActualLocation;
		elseif theDrawController.displayMode = DISPLAY_MODE_QUEUE then
			anLC := theTI.myPrimaryQueuedLocation;
		elseif theDrawController.displayMode = DISPLAY_MODE_PLAN then
			anLC := theTI.myPrimaryPlannedLocation;
		endif;


	endif;
//###

	

	if (frame.CMUI_GridAreaDrawingFrame.longLeftClick or self.frmPopupInfo.visible) // PAR 11408 added 'or self.frmPopupInfo.visible'
	and self.mnuGridHideMacro.caption = self.MNU_MACRO_SHOW // this means that the macro info is hidden
	and not app.isDragging then
		create thePIC transient;
//		theTermArea := anLC.myTerminalArea;			// PAR #19367
		theSBS := theBS.CM_SubBlockStack;
		theLabRest := theLabour;
		if theTI &lt;&gt; null then
			theCMObject := theTI;
		elseif theSBS &lt;&gt; null then
			thePIC.showEnquiryButton := true;
			self.frmPopupInfo.userObject := theSBS;
			self.btnPopupEnq.bubbleHelp := app.getErrorString(CMUI_Enquire_On) &amp; theSBS.id;
			theCMObject := theSBS;
		elseif theLabRest &lt;&gt; null then
			thePIC.showEnquiryButton := true;
			self.frmPopupInfo.userObject := theLabRest;
			self.btnPopupEnq.bubbleHelp := app.getErrorString(CMUI_Enquire_On) &amp; theLabRest.id;
			theCMObject := theLabRest;
		endif;

		thePIC.setForCreate(theCMObject, self.myCurrentDrawingController.displayMode, self.frmPopupInfo,self.tblPopupInfo,self.frmToolBarPopup,
								self.frmPopupInfoPic1,self.picExtraInfoTI1,self.btnPopupEnq);
		self.showPopupInfoFrame(thePIC);
	elseif button &lt;&gt; Button.MouseButton_Right then	//do only for left btn - JC 26/01/04
		if theObj.isKindOf(CM_YardAllocation) then
			self.showYardAllocation(theObj.CM_YardAllocation);
			return;
		else
			if theTI &lt;&gt; null then			// PAR #18982 - If we have clicked a CM_FutureMove, then need to dispaly the TI info
				self.showExtraInfo(theTI);
			else
				self.showExtraInfo(theObj);
			endif;
			self.picCargo.picture := self.showCargoPicture(theTI);
			
			if app.isSpecial() and  theTI &lt;&gt; null then
				bh := theTI.id &amp; Cr &amp; theTI.getISOType() &amp; Cr &amp; theTI.voyageCode &amp; Cr &amp; theTI.dischargePortDescription &amp; Cr &amp; theTI.operatorCode;
				self.myCurrentDrawingController.setBubbleHelp(bh);
			endif;

		endif;
	endif;

	if self.mnuMultiMove.checked then
		frame.YRD_ContainerDrawingFrame.handleMouseUpGridMultiMove(theObj,button,shift, x,y);	//23 Aug 2011	NDL	Par 28035
	else
		frame.YRD_ContainerDrawingFrame.handleMouseUp(theObj,button,shift, x,y); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
	endif;
	
	
	self.saveX := x.Integer;
	self.saveY := y.Integer;

	self.frmStatusLine.myFrameCaption.caption := null;
	
	
	if self.mnuMultiMove.checked then
		create targetLocns transient;
		self.getSelectedMultiMoveLocations( targetLocns );
		statMess := statMess &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; " " &amp; targetLocns.size.String;
	else
		if theTI &lt;&gt; null then
			statMess := theTI.id;
		endif;
		statMess := statMess &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; " " &amp; theDrawController.allSelectedObjects.size.String;
	endif;
	self.frmStatusLine.myFrameCaption.caption := statMess;

epilog
	frame.enableEvent("mouseMove",false);
	delete thePIC; // PAR 17818
	app.isDragging := false;
	delete targetLocns;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDOLFDragOver" id="fd86a178-9661-4a75-bcee-021030a39d86">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDOLFDragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	maskTI 	 : CM_TrackedItem;
	targetTA : CM_TerminalArea;
	gridArea : YRD_GridArea;
	cdc : YRD_ContainerDrawingController;
begin

	// if entering the frame init the AM flag
	if state = Window.DragOver_Enter then
	endif;

	if frame = null then
		return;
	endif;
	
	self.setFocus();
	self.zOrder(1);
	self.windowState := WindowState_Normal;
	
	if frame &lt;&gt; null then
		cdc := frame.YRD_ContainerDrawingFrame.getDrawingController();
	endif;

	if self.myCurrentDrawingController &lt;&gt; cdc then
		self.setMyCurrentDrawingController(cdc, false);
	endif;


end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDOLFMouseDown" id="b3030340-aeab-4476-b1bd-c0ea6ac85ed4">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDOLFMouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	db : YRD_ContainerGridAreaDockBar;
	anObject : Object;
begin
	frame.YRD_ContainerOverDrawingFrame.origXPos := x;
	frame.YRD_ContainerOverDrawingFrame.origYPos := y;
	
	frame.enableEvent(Frame::mouseMove.name, true);
	
	if frame.YRD_ContainerOverDrawingFrame.inEditMode then
		self.myDrawingFrame := frame.YRD_ContainerOverDrawingFrame.myContainerDrawingFrame;
	else
		self.myDrawingFrame := frame.YRD_ContainerOverDrawingFrame.myContainerViewingFrame;
	endif;

	self.setMyCurrentDrawingController(frame.YRD_ContainerOverDrawingFrame.getDrawingController(), false);
		
	self.doDFMouseDown(self.myDrawingFrame,button,shift,x,y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDOLFMouseMove" id="a2a13095-5a1e-439c-81c7-ef19873d7be6">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDOLFMouseMove(frame: CMUI_GridAreaDrawingFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	lPicture : Picture;
begin

	if button = Window.MouseButton_Left 
	and frame.dragMode &lt;&gt; DragMode_Drag
	and app.dragDetected(x, y, self.origXPos, self.origYPos) then
		frame.dragMode := DragMode_Drag;
		frame.dragCursor := self.picCursorDrag.picture;
	endif;
epilog

end;</source>
        <Parameter name="frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDOLFMouseUp" id="f9b5349c-e037-4087-8a0c-aeb2a06d905f">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDOLFMouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ydc : YRD_ContainerDrawingController;
	obj : Object;
	objs : ObjectArray;
	olf : YRD_ContainerOverDrawingFrame;
	ta		: Object;
	str		: String;
	isRebuild : Boolean;// ### PAR 10598
	
begin
	create objs transient;
	// ### ONLY WHAT WE ARE WORKING ON.
	ydc := self.myCurrentDrawingController;
	olf := ydc.getOverlayFrame(true);
	
	if olf &lt;&gt; null then
		olf.getObjects(objs,ydc);
	endif;

	if self.myYardAllocationForm &lt;&gt; null then
		str := self.getYardAllocString(objs);

		if str = null then
			self.myYardAllocationForm.ctrlYardAlloc.doClearLocations(self.myCurrentDrawingController.myTerminalArea.CM_GridArea); // ### ONLY WHAT WE ARE WORKING ON.
		endif;
		
		if objs.isEmpty() then
		else
		//	isRebuild	:=	self.myCurrentDrawingController.myTerminalArea.isKindOf(CM_ForkLiftStack); // ### PAR 10598 rebuild for FLS
			self.myYardAllocationForm.ctrlYardAlloc.doParseLocationString(str, true, isRebuild);// ### PAR 10598
		endif;
	endif;
epilog
	frame.refresh;
	delete objs;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDOLFMouseUpVIEW" id="921041ba-34df-4bf9-be04-57507373e924">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDOLFMouseUpVIEW(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ydc : YRD_ContainerDrawingController;
	obj : Object;
	objs : ObjectArray;
	olf : YRD_ContainerOverDrawingFrame;
	df : YRD_ContainerDrawingFrame;
	ta		: Object;
	str		: String;
	doRebuild : Boolean;// ### PAR 10598
	anObject : Object;
	idx, numRows : Integer;
	theTable : CM_ColourLegendTable;
begin

	ydc := self.myCurrentDrawingController;

	olf := ydc.getOverlayFrame(false);
	if olf &lt;&gt; null then
		obj := olf.getObjectForPosition(x.Integer, y.Integer);

		theTable := self.frmColLegendTIs.myLegendTable;
		if theTable.findObjectInRow(obj, idx) then
			theTable.row := idx;
			theTable.selectTheCurrentRow(theTable);
			theTable.click(theTable);
		endif;
	endif;
	df := ydc.getDrawingFrame();
	if df &lt;&gt; null then
//		df.mouseUp(df,button,shift,x,y);
	endif;
epilog
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDeleteKeyDown" id="58d278d9-30ee-49de-92dd-ced6eaa2b003">
        <source>doDeleteKeyDown();
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	yof : YRD_ContainerOverDrawingFrame;
begin
	if self.myCurrentDrawingController &lt;&gt; null then
		// if editing frame is visible, we are editing
		yof := self.myCurrentDrawingController.getOverlayFrame(true);
		if yof.visible then
			yof.doDelete();
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDropFromGridAreaForm" id="70913a6f-e467-459c-aad3-fb7caa90623e">
        <updating/>
        <source>doDropFromGridAreaForm(frame: YRD_ContainerDrawingFrame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 19/12/2014  cnwma1 PAR #35444 Container Disappears
// ---------------------------------------------------------------------------
vars
	gridController 		: CM_GridController;
	anLC 				: CM_LocationsController;
	theBS 				: CM_BlockStack;
	termArea 			: CM_TerminalArea;
	theObj 				: Object;
	theDrawController 	: YRD_ContainerDrawingController;
begin
	theObj := frame.getObjectForPositionClass(CM_LocationsController,x.Integer, y.Integer);
	if theObj = null then
		// PAR 20244. There is a gap between the location controller rectangles so it is possible to not find anything, so just shift over and try a again.
		theObj := frame.getObjectForPositionClass(CM_LocationsController,x.Integer - YRD_ContainerDrawingController.Spacing, y.Integer); 
	endif;

	theDrawController := frame.getDrawingController();

	if theObj = null then
		theObj := frame.getObjectForPosition(x.Integer, y.Integer);
	endif;

	if theObj = null then
		return;
	endif;

	if theObj.isKindOf(CM_LocationsController) then
		anLC := theObj.CM_LocationsController;
		termArea := anLC.myTerminalArea;
		if theObj.isKindOf(CM_GridController) then
			gridController := theObj.CM_GridController;
		endif;
	elseif theObj.isKindOf(CM_BlockStack) then
		theBS := theObj.CM_BlockStack;
		anLC := theBS.myLocationsController;
	endif;
	
	if anLC = null then						// 19/12/2014 cnwma1 PAR #35444  
		return;
	endif;

//##############
	if self.myCurrentDrawingController.flipHorizontal and gridController &lt;&gt; null then
		if not self.myTerminal.getConfig(YardFlippedDropOnRight).Boolean then
			if app.myDraggedTrackedItem = null then
				return;
			endif;
			if app.myDraggedTrackedItem.isAttributeTrue(TI_Attrib_IsForty) then
				if gridController.getNextControllerOfType(CM_GridController) = null then
					app.raiseCMException1(Suitabl_contain_longer_than, gridController.getFullId,null,null); // PAR 17386
					return;
				endif;
			endif;
		endif;
	endif;

	self.myDroppedTI := app.myDraggedTrackedItem;
	self.moveTrackedItemTarget(anLC);
epilog
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;
end;</source>
        <Parameter name="frame" type="YRD_ContainerDrawingFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaDragDropEventQdOS" id="30a50fea-d8b8-4025-879d-15e35218213d">
        <updating/>
        <source>doGridAreaDragDropEventQdOS(_theTIs : CM_TIArray input;_theDragTI : CM_TrackedItem) updating; 
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		This is for handling Queued Overstow multi select moves.
//				IF they have a stack of TIs Qd, but they want the TI at the bottom first, this code is to allow them to select 2 TIs and drag drop them 
//				elsewhere in the yard. If they are both already Qd, then the top TI will have an additional Qd move added to the other TIs Q Entry
//
// ---------------------------------------------------------------------------

vars
	theTI1, theTI2,theTI3	: CM_TrackedItem;
	theReturn,indTI1,indTI2,
	escKey, numQd			: Integer;
	anLC					: CM_LocationsController;
	notOverstow				: Boolean;
begin

	if self.moveModeForm &lt;&gt; QUEUE_MODE then
		return;
	endif;
	
	if _theTIs.size = 1 then
		return;
	endif;
	
	if _theTIs.size &lt;&gt; 2 then
		app.msgBox("You must have 2 queued Items for this operation","Queued Overstow Error",MsgBox_OK_Only);
		_theTIs.clear;
		self.keyDown(escKey,null); 
		return;
	endif;
	
	notOverstow := false;
	escKey := CMUI_Key_Esc;
	
	// DVB I think you should be able to attach an overstow move manually even if 
	// it isn't already queued up. 19/01/04
/*	foreach theTI1 in _theTIs do
		if theTI1.myPrimaryQueuedLocation &lt;&gt; null then
			numQd := numQd + 1;
		endif;
	endforeach;
	
	if _theTIs.size &lt;&gt; numQd then
		self.keyDown(escKey,null); 
		app.msgBox("You must have 2 queued Items for this operation","Queued Overstow Error",MsgBox_OK_Only);
		_theTIs.clear;
		return;
	endif;*/
	theTI1 := _theTIs[1];
	theTI2 := _theTIs[2];
	
	if theTI1.myPrimaryActualLocation = theTI2.myPrimaryActualLocation then
		anLC := theTI1.myPrimaryActualLocation;
		indTI1 := anLC.allTrackedItems.indexOf(theTI1);
		indTI2 := anLC.allTrackedItems.indexOf(theTI2);
		if indTI2 &gt; indTI1 then
			theTI3 := theTI1;
			theTI1 := theTI2;
			
			theTI2 := theTI3;
		endif;
		//at this point theTI1 is the one on top
	else
		notOverstow := true;
		/*	if theTI1 &lt;&gt; _theDragTI then	// changed to =
			theTI3 := theTI1;
			theTI1 := _theDragTI;
			theTI2 := theTI3;
		endif;
		*/
	endif;

	// if neither is Qd ask if they want to Q both items to the same location
	if theTI2.queueTask = null // PAR 17041
	and theTI1.queueTask = null then // PAR 17041
		if app.msgBox("Do you want to perform a multiple item queued move?", // PAR 17041
							"Multi Item Queued Move",MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_Yes then // PAR 17041
			return; // PAR 17041
		endif;
	endif;

	if theTI2.queueTask = null then
		app.msgBox(theTI2.id  &amp; " is not Queued.  Not valid for Manual Overstow Queue.",
							"Manual Overstow Queue",MsgBox_OK_Only + MsgBox_Information_Icon);
		_theTIs.clear;
		return;
	elseif notOverstow then
		app.msgBox(theTI2.id  &amp; " is not overstowed by " &amp; theTI1.id &amp; ".",
							"Manual Overstow Queue",MsgBox_OK_Only + MsgBox_Information_Icon);
		_theTIs.clear;
		return;
	endif;

	if app.myDraggedTrackedItem &lt;&gt; theTI1 then	//they must drag the top container - this is the one that will be queued
		app.msgBox(app.myDraggedTrackedItem.id  &amp; " is the overstowed item.  You must drag the item to be queued (" &amp; theTI1.id &amp; ").",
							"Manual Overstow Queue",MsgBox_OK_Only + MsgBox_Information_Icon);
		_theTIs.clear;
		return;
	endif;
		

	theReturn := app.msgBox("Create overstow Queued move for " &amp; theTI1.id  &amp; " and attach to queue entry for " &amp; theTI2.id &amp; "?",
							"Manual Overstow Queue Confirm",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);

	if theReturn = MsgBox_Return_No then
		_theTIs.clear;
		return;
	endif;

	app.myMoveController.myRTQueueEntry := theTI2.queueTask.myEntry;
	// Add clear so it is not a bulk move Par 10502
	app.myMoveController.allOtherTrackedItems.clear();
	app.myMoveController.isOverstowMove := true;
	app.myMoveController.setMyWorkListEntry(null);

end;</source>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_theDragTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaDragDropMulti" id="b7420348-3586-4b29-94f3-4212f5d334b3">
        <updating/>
        <source>doGridAreaDragDropMulti(	_frame: YRD_ContainerDrawingFrame input;
							_win: Window input;
							_moveMode : Integer;
							_theTIs : CM_TIArray input;
							_theDragTI : CM_TrackedItem;
							_x : Real;
							_y : Real
							):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	allCargoUNSorted : CM_TIArray;
	allCargoSorted : CM_TIArray;	// Selected cargo to be moved sorted into the outward decking order or equivalent.
	ti : CM_TrackedItem;
	msg : String;
	processedMoves : CM_TIArray;
	targetLocns : CM_LCArray;
	targetLocationStr : String;
	theObj : Object;
	anLC : CM_LocationsController;
	targetTermArea : CM_TerminalArea;
	doStatus : Boolean;
	statMess : String;
	statusLocns : CM_LCArray;
	multiMove : Boolean;

begin

	create allCargoUNSorted transient;
	create allCargoSorted transient;
	
	//filter out any cargo with existing moves of this mode
	if not self.gridAreaMultiDragUnsortedFilta(	allCargoUNSorted,	//_allCargoUNSorted : CM_TIArray io;
												_theTIs,	//_theTIs : CM_TIArray input;
												_theDragTI,	//_theDragTI : CM_TrackedItem;
												_moveMode	//_moveMode : Integer
												) then
		return true;
	endif;
	
	create processedMoves transient;
	create targetLocns transient;
	
	//get the Target Locations  and Target Location name for the messages
	if self.mnuMultiMove.checked then
		// Use the pre-selected targets only, regardless of where the user does the drop.
		self.getSelectedMultiMoveLocations( targetLocns );
		targetLocationStr := app.getErrorString(User_selected);	
		
		if targetLocns.isEmpty then
			msg := app.getErrorString1(No_Locations_preselected, self.mnuMultiMove.caption);
			app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
			return true;
		endif;
	
	else
		// get the locations from this point to the start/end of the area based on decking in rules.
		theObj := _frame.getObjectForPositionClass(CM_LocationsController,_x.Integer, _y.Integer);
		if theObj = null then
			// PAR 20244. There is a gap between the location controller rectangles so it is possible to not find anything, so just shift over and try a again.
			theObj := _frame.getObjectForPositionClass(CM_LocationsController,_x.Integer - YRD_ContainerDrawingController.Spacing, _y.Integer); 
		endif;
	
		if theObj = null then
			theObj := _frame.getObjectForPosition(_x.Integer, _y.Integer);
		endif;
	
		if theObj = null then
			return true;
		endif;
	
		if theObj.isKindOf(CM_LocationsController) then
			anLC := theObj.CM_LocationsController;
			targetTermArea := anLC.myTerminalArea;
			targetLocationStr := targetTermArea.id;
		endif;
		
		if targetTermArea = null then
			return true;
		endif;
		targetTermArea.getMultiMoveDeckingInLocsFrom(anLC,targetLocns);
		
	endif;	
	
	
	// sort the source cargo into the order we want to process it.
	self.gridAreaMultiDragCargoSort( 	_win,	//_win: Window input;
										allCargoUNSorted,	//_allCargoUNSorted : CM_TIArray;
										allCargoSorted	//_allCargoSorted : CM_TIArray io
										);
	
	multiMove := self.myAssistant.doBulkMoveToGridArea(	false,	//_noChargeMove : Boolean;
														null,	//_userAuthorityCode : String;
														_moveMode,	//moveMode : Integer;
														allCargoSorted,	//_allTrackedItems : CM_TIArray;
														targetLocns,	//_targetLocns : CM_LCArray;
														targetLocationStr,	//_targetLocationStr : String;
														processedMoves	//_processedMoves : CM_TIArray io
														);
														
	foreach ti in processedMoves do
		if deselectProcessedLocation(ti,_moveMode) then
			doStatus := true;
		endif;
	endforeach;
	
	if doStatus then
		create statusLocns transient;
		self.getSelectedMultiMoveLocations( statusLocns );
		statMess := statMess &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; " " &amp; statusLocns.size.String;
		self.frmStatusLine.myFrameCaption.caption := statMess;
	endif;
	
	return multiMove;
											
epilog

	delete processedMoves;
	delete targetLocns;
	delete statusLocns;
	
end;</source>
        <Parameter name="_frame" type="YRD_ContainerDrawingFrame" usage="input"/>
        <Parameter name="_win" type="Window" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_theDragTI" type="CM_TrackedItem"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaDragOverAutoMask" id="a13a767a-89c1-4b7c-bc65-0ff5ccf336ad">
        <source>doGridAreaDragOverAutoMask(_cdc : YRD_ContainerDrawingController input; _theMaskTI : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	dischargePort,
	commodityGroup,
	voyageCode	: String;
	mode 		: Integer;
	ts : TimeStamp;
begin

	if (not self.autoMask) then
		return;
	endif;
	
	if _theMaskTI = null then
		return;
	endif;
	
	mode 			:= self.getDisplayMode();
	dischargePort 	:= _theMaskTI.dischargePort;
	commodityGroup	:= _theMaskTI.commodityGroup;
	voyageCode 		:= _theMaskTI.voyageCode;	
	
	_cdc.allSelectorTIs.clear();
	_cdc.useSelectorObjects := true;
	_cdc.getAutoMaskTIs(mode, dischargePort, commodityGroup, voyageCode);
	

epilog
end;</source>
        <Parameter name="_cdc" type="YRD_ContainerDrawingController" usage="input"/>
        <Parameter name="_theMaskTI" type="CM_TrackedItem"/>
    </JadeMethod>
