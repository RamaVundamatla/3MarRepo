    <JadeMethod name="isLocationTopLeft" id="792a4bd7-97a4-4235-a768-6cee1665ed09">
        <source>isLocationTopLeft(cell : Point) : Boolean protected;
// Is this cell the top left call of a location
vars
	location : CM_LocationsController;
	locationTopLeft : Point;
begin
	location := self.getCell(cell.x, cell.y).myLocation;
	if location = null then
		return false;
	endif;
	
	locationTopLeft := location.CM_IrregularBlockController.region.first;
	return locationTopLeft.x = cell.x and locationTopLeft.y = cell.y;		
end;
</source>
        <access>protected</access>
        <Parameter name="cell" type="Point"/>
        <ReturnType type="Boolean"/>
