//
// cnwrs1 TFS 3116
// 09 Mar 2017	cnwrs1	TFS3116 only match on a release item once
// 16 Mar
//
constants
	ShipName = "CCMS1913";//Was MAERSK DUNFARE
	VoyageName = "CCMS1913VOY";
	RELEASE1 = 'ACD0278846';
	RELEASE2 = 'ACD0281728';
	RELEASE3 = 'ACD0282044';
	OPERATOR = 'ANL';
	SENDER1	= 'ANLCOPARN';
	SENDER2 = 'ANL';
	PARTY1 = 'Anl Coparn Unit Tests';
	PARTY2 = 'Anl Coparn Unit Tests2';
	PARTY3 = 'Anl Coparn Unit Tests3';
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	ediFile : CM_EDIFile;
	releaseReq : CM_BulkRelease;
	releaseItem : CM_ReserveDetail;
	text : String;
	releaseItems : Integer;
	tempStr : String;
	operator : CM_Operator;
	code : String;
	ediParty : CM_EDIParty;
	rules : CM_EDIPartyCoparnRules;
	ts1	: TimeStamp;
	ts2	: TimeStamp;
begin
	// disable cutoffs - they can stop a loadDB 
	self.disableAllEDIVoyageCutoffs;
	code := self.getTerminal.code;
	self.deleteReleaseRequest(RELEASE1); 
	self.deleteReleaseRequest(RELEASE2); 
	self.deleteReleaseRequest(RELEASE3); 
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
