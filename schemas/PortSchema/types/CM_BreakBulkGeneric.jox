    <JadeMethod name="getDisplayStringForAttribute" id="38c3ce75-43d2-49d9-993e-b03dca5a9cdc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 23/20/2009	cnwdap1		PAR #21139 Return colour from self, rather than product
// 23/02/2010	cnwdap1		PAR #22171 Width, Height and Length now all come from superclass
//								(MyWidth, MyHeight and MyLength are still all dealt with at this level -
//								 differentiating between product/cargo sub-type attributes and tracked item attributes
// 19 May 2010	cnwkpd1		PAR #20728 - remove isValidObject calls for performance
// 19/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 05 May 2016	cnwns1		TFS 488 - Multi Timezone Support
// 11 May 2022	jlika1		TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
// 04 Oct 2023	navma1 		ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
// 31 Oct 2023	navma1 		ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
vars
	tmpLC		: CM_LocationsController;
	prod		: CM_Product;
	type 		: String;					// PAR #31155
	str			: String;					// PAR #31155
begin
	if _attrName = ETRow_MyProduct then						//31.10.2023 navma1 #60920
		prod := self.myProduct;
		if prod &lt;&gt; null then
			return prod.code &amp; ' - ' &amp; prod.description;
		endif;
		return null;
		
	elseif _attrName = ETRow_MyProductDescription then	    //31.10.2023 navma1 #60920
		prod := self.myProduct;
		if prod &lt;&gt; null then
			return prod.description;
		endif;
		return null;
	
	elseif _attrName = ETRow_MyWidthString or _attrName = ETRow_WidthString then
		return self.widthString;
	   
	elseif _attrName = ETRow_MyHeightString or _attrName = ETRow_HeightString then
		return self.heightString;
		
	elseif _attrName = ETRow_MyLengthString or  _attrName = ETRow_LengthString then
		return self.lengthString;
	elseif _attrName = ETRow_Type or  _attrName = ETRow_MyType then
		return self.type;
	elseif _attrName = ETRow_NumItems then	//22 May 2013	NDL	- CCMS 2274 Break Bulk
		return self.totalQuantity.String;
	elseif  _attrName = ETRow_MyWidth or
	   _attrName = ETRow_MyHeight or
	   _attrName = ETRow_MyLength or
	   _attrName = ETRow_Quantity or
	   _attrName = ETRow_MyQuantity or
	   _attrName = ETRow_Density or
	   _attrName = ETRow_MyDensity or  
	   _attrName = ETRow_MyVolume or
	   _attrName = ETRow_MyWeight or
   	   _attrName = ETRow_UnsplitVolume or
	   _attrName = ETRow_UnsplitWeight then
		return self.zGetDisplayProductDetails(_attrName);				//31.10.2023 navma1 #60920
	 	
	elseif _attrName = ETRow_Colour then	// PAR #211339
		return self.colour;					// PAR #211339

	elseif _attrName = ETRow_CurrentArea then
		tmpLC := self.getPrimaryLocation(REAL_MODE);
		if tmpLC &lt;&gt; null then //might be in a container or elsewhere
			return tmpLC.myTerminalArea.id;
		endif;
		return null;
		
	elseif _attrName = ETRow_CurrentRow then
		tmpLC := self.getPrimaryLocation(REAL_MODE);
		if (tmpLC &lt;&gt; null) and (tmpLC.isKindOf(CM_WarehouseRowController)) then
			return tmpLC.CM_WarehouseRowController.id;
		endif;
		return null;
	elseif _attrName = ETRow_LastReleasedDT then
		return self.systemToLocalTime(self.lastReceivedDT).shortCurrentLocaleFormat;// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_LastReceivedDT then	
		return self.systemToLocalTime(self.lastReleasedDT).shortCurrentLocaleFormat;// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	elseif _attrName = ETRow_ReleaseDT then
		if self.myReleaseBOL &lt;&gt; null then		// and global.isValidObject(self.myReleaseBOL) then - inversed, can't be invalid
			return self.systemToLocalTime(self.myReleaseBOL.dateTime).String;// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		return null;
	elseif _attrName = ETRow_UnsplitQuantity then
		if self.unsplitQuantity &gt; 0 then
			return self.unsplitQuantity.String;
		endif;
		return null;
	
	elseif _attrName = ETRow_DimType then
		return self.type;
	elseif  _attrName = ETRow_Amount then
		if self.isBulkByQuantity then
			return self.totalQuantity.asStringJMT;
		endif;
		return null;	
	// jlika1 TFS 53316 --&gt;
	elseif _attrName = ETRow_Diameter then
		return self.getDiameter().asStringJMT(); 								// ### TFS 54021 29June2022 NAVPW1
	elseif _attrName = ETRow_Grade then		
		return self.getGrade(); 												// ### TFS 54021 29June2022 NAVPW1
	elseif _attrName = ETRow_Grammage then
		return self.getGrammage().asStringJMT();								// ### TFS 54021 29June2022 NAVPW1
	elseif _attrName = ETRow_RollingLength then
		return self.getRollingLength().asStringJMT();							// ### TFS 54021 29June2022 NAVPW1
	
	/*Always Add Above This method*/
	elseif _attrName.isMeasurementType then										// PAR #31155	//04.10.2023 navma1 #59638
		_attrName.getRowNameMeasureType(str, type);								// PAR #31155
		return self.getMeasurementStringForAttrib(str, type, _short);			// PAR #31155
	endif;
	
	
	return inheritMethod(_attrName, _short);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
