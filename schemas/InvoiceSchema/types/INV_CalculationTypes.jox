    <JadeMethod name="initTableEscalatingRange" id="52e8fcc8-9055-46a7-8ebc-bd6a36df033c">
        <source>initTableEscalatingRange();
// ---------------------------------------------------------------------------
// Created:		May 2012 CCMS 1279 Escalating Storage
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTable : CM_EntryTable;
begin
	

	self.tblRange.move(0,self.chkRelFSD.top + self.chkRelFSD.clientHeight+5, self.frmRange.clientWidth,self.frmRange.clientHeight -(self.chkRelFSD.top + self.chkRelFSD.clientHeight+5));

	theTable := self.tblRange;
	theTable.rows := 0;
	theTable.columns:= 3;
	theTable.accessColumn(COLUMN_FROM).inputType := Table.InputType_Default;
	theTable.accessColumn(COLUMN_TO).inputType := Table.InputType_Default;
	theTable.accessColumn(COLUMN_PER_DAYS).inputType := Table.InputType_Default;
	theTable.addItem("From" &amp; Tab &amp; "To" &amp; Tab &amp; "Every x Days");		// 33404 reword heading
	theTable.fixedRows := 1;
	theTable.fixedColumns := 0;
	theTable.userInputEnabled := true;
	theTable.accessColumn(COLUMN_FROM).inputType := Table.InputType_TextNumeric;
	theTable.accessedColumn.maxLength := 8;
	theTable.accessColumn(COLUMN_TO).inputType := Table.InputType_TextNumeric;
	theTable.accessedColumn.maxLength := 8;
	theTable.accessColumn(COLUMN_PER_DAYS).inputType := Table.InputType_TextNumeric;
	theTable.accessedColumn.maxLength := 4;
	theTable.accessColumn(COLUMN_FROM).width := 70;
	theTable.accessColumn(COLUMN_TO).width := 70;

end;</source>
    </JadeMethod>
