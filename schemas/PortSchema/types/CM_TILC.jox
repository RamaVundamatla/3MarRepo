    <JadeMethod name="hasMonitoredOnboardTIs" id="eb50d2f6-1eac-4d79-925a-abfb7f1001d3">
        <source>hasMonitoredOnboardTIs() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
16 September 2024		jlizm1	Initial creation TFS 66095 Don't show non operational reefers in VOL

*/

vars
	tiSet 	: CM_TISet;
	ti 		: CM_TrackedItem;
	
begin
	create tiSet transient;
	self.getAllOnboardTIs(tiSet);
		
	foreach ti in tiSet discreteLock do
		if ti.monitorConnection then
			return true;
		endif;
	endforeach;

epilog
	delete tiSet;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasOnlyOnboardMAFIs" id="7dab2e64-3a92-4aec-ba9b-50016d68b714">
        <source>hasOnlyOnboardMAFIs() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2024	jlier1	Initial creation 65459

*/

vars
	lc : CM_TILCController;
	ti : CM_TrackedItem;
	mafiCount,nonMAFICount : Integer;
begin

	foreach lc in self.allLCs discreteLock do
		foreach ti in lc.allTrackedItems discreteLock do
			if ti.isMAFI then
				mafiCount:=mafiCount +1;
			else
				nonMAFICount:=nonMAFICount+1;
			endif;
		endforeach;
	endforeach;

	return nonMAFICount = 0 and mafiCount &gt; 0;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasOtherTrackedItems" id="2b32e11d-b0af-471a-912f-c84df361ffd6">
        <source>hasOtherTrackedItems(): Boolean;
// ---------------------------------------------------------------------------
// Created:		05 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anLC : CM_TILCController;
begin

	foreach anLC in self.allLCs discreteLock do
		if not anLC.allTrackedItems.isEmpty then
			return true;
		endif;
	endforeach;

	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
