    <JadeMethod name="addToolbarControls" id="9fd8f9f2-8de1-42e1-97d0-e72cfbf8f09d">
        <updating/>
        <source>addToolbarControls() updating, protected;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFind, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnFind_click" id="bdc5b347-ba27-46ac-be81-f3ae42637422">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFind_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		30 December 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	txtData.selLength 	:=	0;
	
	txtData.showFindDialogJmt(true, true);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
