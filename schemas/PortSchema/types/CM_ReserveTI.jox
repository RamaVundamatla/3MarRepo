    <JadeMethod name="getInstructionsForContext" id="9f306bad-1397-45a1-ae21-0a1094c2ef06">
        <source>getInstructionsForContext(_instructions: CM_InstructionsIssuedSet io; _passingObject: Object; _context: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2023 navnk30 ChangeRequest 60646: EUP | Mobile DD - [53891.060] - Special Instructions in the Mobile App

*/

vars
	ti	: CM_TrackedItem;
begin
	inheritMethod(_instructions, _passingObject, _context);
	
	ti := self.getTI();
	if _context = Truck_Load or
		_context = Pack_by_Request or
		_context = Pack_Cargo or
		_context = Rail_Load then
		if ti &lt;&gt; null then
			_instructions.tryAddIfNotNull(ti.myInstructions);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
