    <JadeMethod name="createTALevelColours" id="ea949893-620b-4f2b-9997-8fc395d2b68f">
        <source>createTALevelColours();
// ---------------------------------------------------------------------------
// Created:		July 2005 By Andrew Bishop cnwab1
//
// Purpose:		Set some default terminal area level heights
//
// ---------------------------------------------------------------------------

vars
	endTS	: Boolean;	
begin

	if (not process.isInTransactionState) then
		// this should never occur if JMTRelease has been
		// run correctly but is done here for security
		endTS := true;
		beginTransaction;
	endif;
	self.coloursForTALevels[1] := 8421504;
	self.coloursForTALevels[2] := 8421440;
	self.coloursForTALevels[3] := 65535;
	self.coloursForTALevels[4] := 4210816;
	self.coloursForTALevels[5] := 16777215;
	self.coloursForTALevels[6] := 32768;
	self.coloursForTALevels[7] := 32768;
	self.coloursForTALevels[8] := 16711680;
	self.coloursForTALevels[9] := 16711680;
	self.coloursForTALevels[10] := 32896;
	self.coloursForTALevels[11] := 32896;
	self.coloursForTALevels[12] := 65280;
	self.coloursForTALevels[13] := 65280;
	self.coloursForTALevels[14] := 16711935;
	self.coloursForTALevels[15] := 16711935;
	self.coloursForTALevels[16] := 12615680;
	self.coloursForTALevels[17] := 12615680;
	self.coloursForTALevels[18] := 33023;
	self.coloursForTALevels[19] := 33023;
	self.coloursForTALevels[20] := 255;
	self.coloursForTALevels[21] := 255;

epilog
	if endTS then
		commitTransaction;
	endif;

end;</source>
