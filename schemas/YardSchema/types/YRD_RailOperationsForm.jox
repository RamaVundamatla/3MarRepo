    <JadeMethod name="deleteCurrentJobEntry" id="a66c3375-e673-4120-91ef-b0b3b017c0f1">
        <updating/>
        <source>deleteCurrentJobEntry() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwndl1	Initial creation

*/

vars
	job : CM_Job;
	obj : Object;
begin

	obj := self.mnuDeleteCurrentEntry.userObject;
	if obj = null then
		return;
	endif;
	if CM_Job.hasInstance(obj) then 
		job := obj.CM_Job;
	endif;
	if job = null then
		return;
	endif;
	self.myCurrentJob := job;

	self.doDeleteJob();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayAllWLEsForObj" id="62df4c74-da74-49be-a561-891d803a7ded">
        <updating/>
        <source>displayAllWLEsForObj(_object : CM_Object)updating;
//--------------------------------------------------
// Created:	10 October 2003 By: cnwgd1
//--------------------------------------------------
vars

begin

	// Do not show wles for jobs in build priority
	if _object &lt;&gt; null then
		if _object.isKindOf(CM_RailJSInOutRake) then
			if _object.CM_RailJSInOutRake.inOut.outwards = Rail_JSIO_Type_Build then
				return;
			endif;
		elseif _object.isKindOf(CM_RailJSInOut) then
			if _object.CM_RailJSInOut.outwards = Rail_JSIO_Type_Build then
				return;
			endif;
		elseif _object.isKindOf(CM_RailJob) then
			if  _object.CM_RailJob.inOutRakeSheet &lt;&gt; null then
				if _object.CM_RailJob.inOutRakeSheet.inOut.outwards = Rail_JSIO_Type_Build then
					return;
				endif;
			endif;
		endif;
	endif;
	
	inheritMethod(_object);
end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doAddReleaseRequest" id="9b66a2e9-6e15-402d-849b-28bb77d881b6">
        <source>doAddReleaseRequest();
// ---------------------------------------------------------------------------
// Created:     27 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//14 June 2023 navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
// ---------------------------------------------------------------------------

vars
	bulkRelease : CM_BulkRelease;
begin

	create bulkRelease transient;//form cleans up
	self.myAssistant.releaseRequestAdd(bulkRelease, BR_TYPE_RAIL, self.myMasterMenuAction,null);			//14.6.2023 navhl20 #58634

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddToBuildPriority" id="d4d98753-ff4f-4188-a780-82795aac4997">
        <updating/>
        <source>doAddToBuildPriority(_theTI	: CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/11/2012	cnwdap1		PAR #30762 CCMS QNS 2233 Stop COU being set up
// ---------------------------------------------------------------------------

vars
	proxyYRequest, realYRequest : CM_Request;
//	lTI	: CM_TrackedItem;
	lConObj	: CM_ConsigneeConsignor;
	lconsignee				:String;
	lconsignorVoyageCode	:String;
	lDeliveryNumber			:String;
	lDoorsForward, lClean		:Boolean;
	leirNumber, lISOType, lMask		:String;
	lisReceipt				:Boolean;
	lneedCOU, lHeavy		:Boolean;
	lneedGenerator, lCheckISO			:Boolean;
	lreasonCode, lNumRequested, lAVG	:Integer;
	lRemarks, 
	lFreightForwarder, 
	lFreightPayee, 
	lOperator		:String;
	rtnValue			:Boolean;
	lvoyageCode			:String;
	lObj : Object;
	lDate : Date;
	proxyJob, realJob : CM_Job;
	lDoorsDirection		: Integer;
	idx : Integer;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	// ###########################################
	// Get the data off the screen
		
	lOperator := _theTI.myOperator.code.trimBlanks;
	lvoyageCode := _theTI.myVoyage.code.trimBlanks;
	lconsignorVoyageCode	:= null;
	lisReceipt				:= false;
//	lneedCOU				:= _theTI.CM_Container.isPortHole();						// PAR #30762 
	lneedGenerator			:= false;
	lConObj := null;	// do not update
	lreasonCode	:= DEL_NULL;
		
	// ###########################################
	// CREATE Jobs and request
	create proxyJob as CM_RailJob transient;
	proxyJob.CM_RailJob.setProxyRailJob(null, lconsignorVoyageCode,
										leirNumber, lvoyageCode,
										null, null,
										Rail_JSIO_Type_Build,
										self.myTerminal, null);

	create proxyYRequest as CM_TIRequest transient;
	proxyYRequest.CM_TIRequest.setProxy(lClean, lconsignorVoyageCode,
										leirNumber, lconsignee,
										lDoorsDirection, null,
										lFreightForwarder, lFreightPayee, lisReceipt,
										lISOType, lOperator,
										lNumRequested, lreasonCode,
//										lHeavy, lMask, lneedCOU,						// PAR #30762
										lHeavy, lMask, false,							// PAR #30762
										lneedGenerator,	lDate,
										lvoyageCode, lCheckISO,
										proxyJob, null, lAVG, null,
										null, null, _theTI,
										app.getMyUserCode(),
										null);

	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateJobAndRequest(proxyJob, realJob,
									   proxyYRequest, realYRequest,
									   _theTI, lConObj, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Build_priority), app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	if proxyJob &lt;&gt; null then
		delete proxyJob;
	endif;
	if proxyYRequest &lt;&gt; null then
		delete proxyYRequest;
	endif;

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAddWagon" id="43c90855-b84a-45c6-ae13-c1bf3313715d">
        <source>doAddWagon();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 March 2010	cnwas3	par 23258

*/

vars
	wagonForm : YRD_TrainWagonForm;
	wagon : CM_Wagon;
	trainForWagonCombo : CM_Train;
	mode : Integer;
begin	
	
	mode := YRD_TrainWagonForm.Mode_Add;
	
	app.mousePointer := MousePointer_HourGlass;
	
	wagonForm := app.getForm(YRD_TrainWagonForm.name).YRD_TrainWagonForm;
	if wagonForm = null then
		wagonForm := app.loadForm(YRD_TrainWagonForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TrainWagonForm;
	endif;
	
	if wagonForm = null then
		return;
	endif;
	
	self.setNavigatorHeading(app.getErrorString(Wagon_maintenance)); 
	wagonForm.setParentForm(self);
	wagonForm.setMyTerminal(self.myTerminal);	
	wagonForm.initialiseForm(self.myCurrentTrain, null, mode);
	wagonForm.show;
		
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAssignSelectedJobsToRake" id="0029d150-f3b3-4916-b882-9550749c71f5">
        <updating/>
        <source>doAssignSelectedJobsToRake(_menuItem: MenuItem input) updating;
//-----------------------------------------
// Created: December 2004 By: cnwgd1
//-----------------------------------------
vars
	result			: Integer;
	userObject		: Object;
	doAutoPlan		: Boolean;
	railJob			: CM_RailJob;
	targetType		: Integer;
	targetRake		: CM_RailJSInOutRake;
	tmpRailJobs,
	tmpJobsWithWarnings	: CM_RailJobArray;
begin

	userObject := _menuItem.userObject;
	app.mousePointer := MousePointer_HourGlass;
	
	self.getAllSelectedRailJobs(); // PAR 22037
	
	if CM_RailJSInOutRake.hasInstance(userObject) then
		targetRake := userObject.CM_RailJSInOutRake;
		targetType := targetRake.inOut.outwards;
		doAutoPlan := targetType = Rail_JSIO_Type_Out;
	elseif CM_RailJob.hasInstance(userObject) then
		if not self.allSelectedRailJobs.includes(userObject.CM_RailJob) then
			self.allSelectedRailJobs.add(userObject.CM_RailJob);
		endif;
		targetRake := self.myTerminal.myRailJobSheet.getDefaultBuildPriorityJS();
		targetType := targetRake.inOut.outwards;
		doAutoPlan := false;

	else
		return;
	endif;
	
	create tmpRailJobs transient;
	create tmpJobsWithWarnings transient;

	//copy and clear
	self.allSelectedRailJobs.copy(tmpRailJobs);
	self.allSelectedRailJobs.clear;
	
	if self.myCurrentRailJob &lt;&gt; null then
		if (not tmpRailJobs.includes(self.myCurrentRailJob)) then
			tmpRailJobs.add(self.myCurrentRailJob);
		endif;
	endif;

	while true do
		app.myTrxUA.trxUpdateRailJobsRakeTransfer(tmpRailJobs, tmpJobsWithWarnings, targetRake, doAutoPlan, targetType, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			//result := app.showErrorWarningDialog('Rail Line Transfer', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr); //- cnwmd1, CCMS 1067, Par 19710
			result := app.showErrorWarningDialog(app.getErrorString(Rail_line_transfer), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr); //+ cnwmd1, CCMS 1067, Par 19710
			if result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				tmpRailJobs.clear;
				tmpJobsWithWarnings.copy(tmpRailJobs);
				tmpJobsWithWarnings.clear;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	delete tmpJobsWithWarnings;
	delete tmpRailJobs;
	app.mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnPrint" id="98040137-9b22-48fb-90e5-e9cd0071864d">
        <updating/>
        <source>doBtnPrint() updating;
//----------------------------------------------------------------
//	Created:	18 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpRailJobs		: CM_RailJobArray;
begin

	if self.optPrintList.value then
		self.doPrintRelease();
		return;
	endif;
	
	self.getAllSelectedRailJobs(); // PAR 20447
	
	if self.allSelectedRailJobs.isEmpty then
		//select something to print
		app.msgBox(app.getErrorString(Pleas_selec_some_from_list_tha), app.getErrorString(Nothing_Selected), MsgBox_OK_Only);
		return;
	endif;
		
	create tmpRailJobs transient;
	self.allSelectedRailJobs.copy(tmpRailJobs);
	
	if self.optPrintISORelWS.value then
		//self.printReleaseWorksheet(tmpRailJobs, "Rail Worksheet - Empty Release"); //- cnwmd1, CCMS 1067, Par 19710
		self.printReleaseWorksheet(tmpRailJobs, app.getErrorString(Rail_workshe_empty_release)); //+ cnwmd1, CCMS 1067, Par 19710
	elseif self.optPrintImpRelWS.value then
		//self.printReleaseWorksheet(tmpRailJobs, "Rail Worksheet - Full Release");	//- cnwmd1, CCMS 1067, Par 19710
		self.printReleaseWorksheet(tmpRailJobs, app.getErrorString(Rail_workshe_full_release));	//+ cnwmd1, CCMS 1067, Par 19710
	endif;

epilog
	delete tmpRailJobs;
	self.allSelectedRailJobs.clear;
	self.frmPrint2.visible := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarMouseUp" id="d2e8f6d3-b855-41a3-bdc8-893adb3074a4">
        <updating/>
        <source>doBtnToolBarMouseUp(jadeMask: JadeMask input) updating;

vars

begin
	inheritMethod(jadeMask);
	
	if jadeMask.index = VIEW_LEFT_TOP 
	or jadeMask.index = VIEW_RIGHT_TOP 
	or jadeMask.index = VIEW_LEFT_BOTTOM 
	or jadeMask.index = VIEW_RIGHT_BOTTOM then
		self.doScrollToCorners(jadeMask.index);
	endif;	
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildAttachCaption" id="221dfefb-8c33-48ec-bb49-eea75e3f0cdf">
        <updating/>
        <source>doBuildAttachCaption(_theTI : CM_TrackedItem; _theAction : Integer io) : String updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	theContainer : CM_Container;
	theCOU, theCaption : String;
	
begin
	if _theTI &lt;&gt; null then
		if _theTI.isKindOf(CM_Container) then
			theContainer := _theTI.CM_Container;
			if theContainer.isPortHole then
				theCOU := theContainer.couId.trimBlanks;
				if theCOU.trimBlanks = null then
					theCOU := "COU"; // DO NOT TRANSLATE
				endif;
				if theContainer.hasCOU then
					_theAction := ACTION_DISCONNECT;
					//theCaption := theContainer.id &amp; " Detach From " &amp; theCOU ; //- cnwmd1, CCMS 1067, Par 19710
					theCaption := app.getErrorString2(Detach_From_id, theContainer.id, theCOU) ; //+ cnwmd1, CCMS 1067, Par 19710
				else
					_theAction := ACTION_CONNECT;
					//theCaption := theContainer.id &amp; " Attach To " &amp; theCOU; //- cnwmd1, CCMS 1067, Par 19710
					theCaption := app.getErrorString2(Attach_To_id, theContainer.id, theCOU); //+ cnwmd1, CCMS 1067, Par 19710
				endif;
			endif;
		endif;				
	endif;

	return theCaption;
end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theAction" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuAutoplanTrain" id="2d0909f6-1d5e-4e25-ac97-13039b7c2df4">
        <source>doBuildMenuAutoplanTrain() protected;
/*
----------   ----------  --------------------------------------------------
Created:	20 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
19/2/2009	 cnwcp2		 PAR# 18073 - incorrect terminal when using the app method call
----------   ----------  --------------------------------------------------
*/
vars
	train			: CM_Train;
	mnuChild,
	mnuMaster	: MenuItem;
	idx,
	mnuIndex 	: Integer;
	

begin
	// ##############################################
	// Build up menu of current trains to autoplan the box to
	mnuMaster := self.mnuAutoplanTrain;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	self.mnuAutoplanTrainSub.visible := true;
	foreach train in self.myTerminal.allTrainsOnTerminal do
		if train.isNullTrain() then
			continue;
		endif;
		idx := idx + 1;
		mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuAutoplanTrainSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(idx); // Clone menu
		mnuChild.caption := self.myAssistant.displayEntryTrain(train);
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := train.description;
		mnuChild.userObject := train;
	endforeach;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBuildMenuBoxcar" id="15022c6f-e4f8-4a62-9a7f-503c70ac4f59">
        <source>doBuildMenuBoxcar( _boxcarVisit : CM_Wagon );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	self.mnuCargo.visible := true;
	
	self.mnuEnquiry.visible := false;
	self.mnuLocationEnquiry.visible := true;
	//self.mnuLocationEnquiry.userObject := _boxcarVisit.allLocationsControllers.first;
	self.mnuLocationEnquiry.userObject := _boxcarVisit.allLocationsControllersArray[1];	//04 Dec 2014	NDL	Par 35345

epilog

end;</source>
        <Parameter name="_boxcarVisit" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuCargo" id="4fd7f9c1-c07a-4b9c-88dc-4e56a256f357">
        <updating/>
        <source>doBuildMenuCargo(ti : CM_TrackedItem) protected, updating;
// ---------------------------------------------------------------------------
// Created:      01 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 16/06/2010	cnwcs5	par 24342 - new dform for maintaining stops
// 25/01/2013	cnwdap1	PAR #31018 CCMS POL 2223 Added menu to disconnect reefers on power during transit
vars
	theAction : Integer;
	menuItemSwapCaption : String;
	useTaskForm : Boolean;

begin

	self.mnuCargo.visible := true;
	self.mnuEnquiry.userObject := ti;
	
	self.mnuUnplan.userObject := ti;
	self.mnuUnplan.helpKeyword := "LOAD"; // DO NOT TRANSLATE
	if self.mySDF &lt;&gt; null then
		if self.mySDF.displayMode = DISPLAY_MODE_PLAN then
			self.mnuUnplan.helpKeyword := "DISCHARGE"; // DO NOT TRANSLATE
		endif;
	endif;	
	if ti.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then 
		self.mnuUnplan.visible := true;
		//self.mnuUnplan.caption := ti.id &amp; " Unqueue"; //- cnwmd1, CCMS 1067, Par 19710
		self.mnuUnplan.caption := app.getErrorString1(Unqueue_Item, ti.id); //+ cnwmd1, CCMS 1067, Par 19710
	elseif ti.getPrimaryLocation(PLANNING_MODE) &lt;&gt; null then
		self.mnuUnplan.visible := true;
		//self.mnuUnplan.caption := ti.id &amp; " Unplan"; //- cnwmd1, CCMS 1067, Par 19710
		self.mnuUnplan.caption := app.getErrorString1(Unplan_Item, ti.id); //+ cnwmd1, CCMS 1067, Par 19710
	endif;

	self.mnuLocationEnquiry.userObject := ti.getPrimaryLocation(self.moveModeForm);
	
	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuCargoTaskAdd.visible := true;
		self.mnuCargoTaskComplete.visible := true;
		self.mnuCargoTaskRemarks.visible := true;
	else
		self.mnuTaskAdd.visible := true;
		self.mnuTaskComplete.visible := true;
	endif;
	self.mnuStops.visible := true;
	self.mnuTaskAdd.userObject := ti;
	self.mnuTaskComplete.userObject := ti;
	self.mnuStops.userObject := ti;
	
	self.doBuildMnuTasksAdd(ti);	
	self.doBuildMnuTasksComplete(ti);	
	// par 24342 - self.doBuildMnuStops(ti);	
	
/*	// sgp 12 August 2003 : COUs no longer used
	if ti.isKindOf(CM_Container) then
		self.mnuAttach.caption := self.doBuildAttachCaption(ti,theAction);
		if ti.CM_Container.hasCOU then
			self.mnuAttach.visible := true;
			self.mnuAttach.userObject := ti;
		endif;
		if ti.CM_Container.isPortHole then
			self.mnuAttach.visible := true;
			self.mnuAttach.userObject := ti;
		endif;
	endif;
*/	
	if not ti.isKindOf(CM_Container) then
		return;
	endif;
	
	//Par8435 - Cannot connect to power while on a wagon
	/*self.mnuConnect.caption := self.doBuildConnectCaption(ti,theAction);
	if self.mnuConnect.caption &lt;&gt; null then
		if ti.CM_Container.isPortHole then
			self.mnuConnect.visible := true;
			self.mnuConnect.userObject := ti;
		endif;
		if ti.CM_Container.requiresPower then
			self.mnuConnect.visible := true;
			self.mnuConnect.userObject := ti;
		endif;
	endif;*/
	
	self.mnuLCL.visible := true;
	self.mnuLCL.userObject := ti;
	//self.mnuLCL.caption := ti.id &amp; " Pack/Unpack" &amp; '...'; //- cnwmd1, CCMS 1067, Par 19710
	self.mnuLCL.caption := app.getErrorString1(Pack_unpack_Item, ti.id); //+ cnwmd1, CCMS 1067, Par 19710
	
	self.mnuCargoRemarks.visible := true;
	self.mnuCargoRemarks.userObject := ti;
	//self.mnuCargoRemarks.caption := ti.id &amp; " Remarks" &amp; '...'; //- cnwmd1, CCMS 1067, Par 19710
	self.mnuCargoRemarks.caption := app.getErrorString1(Remarks_Item, ti.id); //+ cnwmd1, CCMS 1067, Par 19710
	// PAR #31018 show a Disconnect menu item for connected reefers on the train						// PAR #31018
	if ti.getOnPower and ti.getOnPowerDuringTransit and self.mnuUnplan.helpKeyword = "DISCHARGE" then	// PAR #31018
		self.mnuCargoDiscon.visible := true;															// PAR #31018
		self.mnuCargoDiscon.caption := "Disconnect " &amp; ti.id &amp; "...";									// PAR #31018
		self.mnuCargoDiscon.userObject := ti;															// PAR #31018
	endif;																								// PAR #31018
	
	//11 Aug 2009	NDL	CCMS 1094
	if self.allowCargoPositionSwap( menuItemSwapCaption ) then
		self.mnuCargoPositionSwap.caption := menuItemSwapCaption;
		self.mnuCargoPositionSwap.visible := true;
	else
		self.mnuCargoPositionSwap.visible := false;
	endif;
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuUnplan.visible := false;
		self.mnuCargoTaskAdd.visible := false;
		self.mnuCargoTaskComplete.visible := false;
		self.mnuCargoTaskRemarks.visible := false;
		self.mnuStops.visible := false;
		self.mnuLCL.visible := false;
		self.mnuCargoRemarks.visible := false;
		self.mnuCargoDiscon.visible := false;		
		self.mnuCargoPositionSwap.visible := false;
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doBuildMenuNullWagon" id="d9061f3f-522a-4a46-a15c-40d5a04fbdaf">
        <updating/>
        <source>doBuildMenuNullWagon(frame:Frame input;_x, _y : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theRow, theEnd, idx : Integer;
	theX, theY : Real;
	foundPoint,
	tmpPoint	: CMUI_GridPoint;
	tmpRow		: CMUI_GridRow;
	theRailLine : CM_RailLine;		
	lCaption	: String;
	mnuChild, mnuChildSub	: MenuItem;
	theWagon : CM_Wagon;
	mnuIndex 	: Integer;
	allWagonClasses, theMenuObjects : ObjectArray;
	aWagonClass : CM_WagonClass;
	anObject : Object;
	theWagonArea: YRD_WagonArea;
	
begin
	// clear out any objects created in the wagon menus
	self.doClearTransientObjects();

	self.mnuWagonConfirm.visible := false;

	foreach idx in 1 to  50  do
		mnuChild := mnuWagonConfirm.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if frame = null or not frame.isKindOf(CMUI_GridAreaFrame) then
		return;
	endif;
	
	if frame.CMUI_GridAreaFrame.myGridArea = null or
			not frame.CMUI_GridAreaFrame.myGridArea.isKindOf(YRD_WagonArea) then
		return;
	endif;

	theWagonArea := frame.CMUI_GridAreaFrame.myGridArea.YRD_WagonArea;
	theRailLine := theWagonArea.myRailLine;
	
	if theRailLine = null then
		return;
	endif;

	/*create allWagonClasses transient;
	foreach aWagonClass in app.myRoot.allWagonClasses do
		allWagonClasses.add(aWagonClass);
	endforeach;*/
	// #########################################
	// #########################################
	// #########################################
	// #########################################
	// #########################################
	// WAGON NEW ADD, via maintenance form

	self.mnuWagonConfirm.visible := true;
	self.mnuWagonConfirm.userObject := theRailLine;
	//self.mnuWagonConfirm.caption := "Confirm Wagon To " &amp; theRailLine.getIdString &amp; '...'; //- cnwmd1, CCMS 1067, Par 19710
	self.mnuWagonConfirm.caption := app.getErrorString1(Confirm_wagon_to, theRailLine.getIdString); //+ cnwmd1, CCMS 1067, Par 19710
	
	theEnd := theRailLine.maximumWagons;
	if theEnd &gt; 50 then
		theEnd := 50;
	endif;
	
	foreach idx in 1 to  theEnd  do
		mnuChild := mnuWagonConfirm.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;
	
	foreach idx in 1 to  theEnd  do

		theWagon := null;
		if theRailLine.allWagons.size &gt;= idx then
			theWagon := theRailLine.allWagons[idx];
		endif;
		
		if theWagon &lt;&gt; null and theWagon.confirmed then
			continue;
		endif;
		
		//lCaption := "Position " &amp; idx.String ; //- cnwmd1, CCMS 1067, Par 19710
		lCaption := app.getErrorString1(Position_Num, idx.String); //+ cnwmd1, CCMS 1067, Par 19710
		mnuChild := mnuWagonConfirm.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuWagonConfirm.loadSubMenu(idx); // Clone menu
		endif;
		mnuChild.caption := lCaption;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := idx.String;
		mnuChild.userObject := theRailLine;
	endforeach;

	// sgp 17 July 2003 : disable paint and edit menus
	// #########################################
	// #########################################
	// #########################################
	// #########################################
	// #########################################
	// WAGON PAINT
	
/*	self.mnuWagonPaint.visible := true;
	self.mnuWagonPosition.visible := false;
	self.mnuWagonClass.visible := false;
	self.mnuWagonPaint.caption := "Paint New Wagon To " &amp; theRailLine.id;
	
	theEnd := theRailLine.maximumWagons;
	if theEnd &gt; 50 then
		theEnd := 50;
	endif;
	
	foreach idx in 1 to  50  do
		mnuChild := mnuWagonPaint.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;
	
	foreach idx in 1 to  50  do
		mnuChild := mnuWagonPosition.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;
	mnuIndex := theEnd + 10;
	foreach idx in 1 to  theEnd  do

		theWagon := null;
		if theRailLine.allWagons.size &gt;= idx then
			theWagon := theRailLine.allWagons[idx];
		endif;
		
		if theWagon &lt;&gt; null then
			continue;
		endif;
		
		lCaption := "Position " &amp; idx.String ;
		mnuChild := mnuWagonPaint.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild = null then
