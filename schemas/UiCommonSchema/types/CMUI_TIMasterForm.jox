    <JadeMethod name="initFromUserWindow" id="fc176502-38a5-4d4e-81fc-129228384cac">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/* ---------------------------------------------------------------------------
Created:	21 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
16/04/2018		cnwma1	Bug 37938: Bug from Functional Review of 7418
30 Apr 2018	NDL	TFS 38313
------------------------------------------------------------------------------*/
vars
	tmpTypeStr	: String;
begin
	
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.CargoType_Trailer.String ); 
	self.xmlStrTblDataTrailer := tmpTypeStr.trimCharacters(CrLf);

	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.CargoType_Generator.String );
	self.xmlStrTblDataGen := tmpTypeStr.trimCharacters(CrLf);

	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.CargoType_Container.String );
	self.xmlStrTblDataCont := tmpTypeStr.trimCharacters(CrLf);
	
	//06 Jul 2009	NDL	CCMS 1067
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.CargoType_Wagon.String );
	self.xmlStrTblDataWagon := tmpTypeStr.trimCharacters(CrLf);
	

/*	//16/04/2018		cnwma1	Bug 37938
	if self.modeStr = self.CargoType_Trailer.String then
		tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.CargoType_Trailer.String );
		self.xmlStrTblDataArray[CargoType_Trailer] := tmpTypeStr.trimCharacters(CrLf);
	elseif self.modeStr = self.CargoType_Generator.String then
		tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.CargoType_Generator.String );
		self.xmlStrTblDataArray[CargoType_Generator] := tmpTypeStr.trimCharacters(CrLf);
	elseif self.modeStr = self.CargoType_Container.String then
		tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.CargoType_Container.String );
		self.xmlStrTblDataArray[CargoType_Container] := tmpTypeStr.trimCharacters(CrLf);
	else
		//06 Jul 2009	NDL	CCMS 1067
		tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.CargoType_Wagon.String );
		self.xmlStrTblDataArray[CargoType_Wagon] := tmpTypeStr.trimCharacters(CrLf);
	endif; */
end;</source>
