	lX : Real;
begin

//	lX := (self.x1 + ((self.x2 - self.x1) / 2)) - ((self.label.length * 7) / 2); // all this puts the label in the middle
//	pFrame.drawTextAt(self.label, lX, TopTextMargin, Black);
