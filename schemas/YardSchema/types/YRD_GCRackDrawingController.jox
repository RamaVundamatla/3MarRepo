    <JadeMethod name="doDFContextMenu" id="3e635615-fc54-48aa-8c21-f50ac6b7c8de">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFContextMenu(frame: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		10 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myGCAreaEnquiryForm = null then
		return false;
	endif;
	return self.myGCAreaEnquiryForm.doDFContextMenu(frame, conwin, mouse, x, y);

end;</source>
