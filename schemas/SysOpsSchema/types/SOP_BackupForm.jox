end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCancel" id="636f41fe-fbce-4718-9bc6-f72bcdd14278">
        <source>doCancel() protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.btnSaveBase.enabled := false;
	self.btnEdit.enabled := true;
	self.btnCancelBase.enabled := false;
	if self.myBackup = null then
		self.btnBackup.enabled := false;
	else
		self.btnBackup.enabled := true;
	endif;
	self.tblBackup.userInputEnabled := false;	
	self.shtDBHistory.enabled := true;
	self.shtJournalHist.enabled := true;	
epilog
	//null object wrapper if there are no Back up objects in the system. 
	if self.myBackup &lt;&gt; null then
		self.unlock(self.myBackup);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEdit" id="818c7057-a7d1-4068-9041-81e9de7b5d3d">
        <source>doEdit() protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myBackup &lt;&gt; null then
		if not self.tryLock(self.myBackup, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			// Will wait for duration of timer before trying again.
			app.msgBox("Backup is currently busy", app.getErrorString(Backup), MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
			return;
		endif;
	endif;
	self.btnSaveBase.enabled := true;
	self.btnCancelBase.enabled := true;
	self.btnEdit.enabled := false;
	self.btnBackup.enabled := false;
	self.tblBackup.userInputEnabled := true;
	self.shtDBHistory.enabled := false;
	self.shtJournalHist.enabled := false;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="b0ac1072-e982-4bbf-b710-9408751195e2">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Oct 2008	cnwkpd1		PAR #18315 - Prevent share locks on backup collections
// 08 Mar 2010	cnwkpd1		PAR #22945 - calculate and store the elapsed time (in ms) 
//							that the refresh takes
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 03 Oct 2019	jlgrs1	TFS 46810 add Journal number to backup details
// ---------------------------------------------------------------------------

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	backupHistory			: CM_BackupHistory;
	count					: Integer;
	ls						: Boolean;
	startTime				: Decimal[20];
	msg : String;		// CCMS1150 cnwrs1 16 June 2011
begin
	startTime := app.relativeMachineTime();		// PAR #22945
	
	inheritMethod();
	app.cmsBeginLoad(ls);
	self.mousePointer := Window.MousePointer_HourGlass;
	self.tblJournalHist.clearAllData();
	self.tblDBHistory.clearAllData();
	if self.myBackup = null then // may not be setup as yet
		return;
	endif;
	
	count := 0;
	foreach backupHistory in self.myBackup.allBackupJournals reversed, discreteLock do			// PAR #18315
		self.displayJournalHistory(backupHistory);
		count := count + 1;
		if count &gt; 2000 then
			break;
		endif;
	endforeach;
	self.tblBackup.setValueByName(ETRow_JournalNumber, self.myBackup.journalNumber);
	count := 0;
	foreach backupHistory in self.myBackup.allBackupDBs reversed, discreteLock do				// PAR #18315
		self.displayDBHistory(backupHistory);
		count := count + 1;
		if count &gt; 2000 then
			break;
		endif;
	endforeach;
	if self.myBackup.status = BackupStatus_Abort then	// CCMS1150 cnwrs1 04 July 2011
		btnBackup.enabled := false;
		btnAbort.enabled := false;
	elseif self.myBackup.status = BackupStatus_Idle then	// CCMS1150 cnwrs1 04 July 2011
		btnBackup.enabled := true;
		btnAbort.enabled := false;
	else
		btnBackup.enabled := false;
		btnAbort.enabled := true;
	endif;

	self.lastRefreshTimeElapsed := (app.relativeMachineTime() - startTime).Integer;			// PAR #22945

	self.resetCaption(Xlat_0006969);	// CCMS1150 cnwrs1 16 June 2011
	if self.myBackup.status = BackupStatus_Processing or
	   self.myBackup.status = BackupStatus_Restarted then
		if self.myBackup.sdsSecondaryBackup then
			msg := "Backingup on SDS Secondary";
		elseif app.isSDSPrimaryDB then
			msg := "Backingup on SDS Primary";
		else
			msg := "Backingup";
		endif;
		self.setCaption(caption&amp;' ('&amp;msg&amp;')');
	endif;
epilog
	app.cmsEndLoad(ls);
	self.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doReset" id="118ca097-7377-48a5-a14b-5228d554c815">
        <source>doReset();

vars
	controller : BGP_Controller;
begin
	if app.msgBox("Are you sure you want to Reset the Backup Process " &amp; CrLf &amp;
				"This may crash any Backup that is currently underway?", 'Are you sure?', MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Cancel) &lt;&gt; MB_OK then
		return;
	endif;
	foreach controller in BGP_GenericController.instances do
		if controller.isDBBackup then	// CCMS1150 cnwrs1 04 July 2011
			app.myTrxUA.trxUpdateBGPBackupReset(app.myRoot.myBackup, controller);
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="36926ee8-6ee9-4031-b9f4-92932dbe343b">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.fldBackup.top := self.topMargin;
	self.fldBackup.height := self.clientHeight - self.topMargin;
	self.tblBackup.resetSize();
	self.shtDBHistory.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="f15f8329-06f5-4af3-8290-f9d0b4dc5747">
        <updating/>
        <source>doSave() protected, updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// 03 Oct 2019	jlgrs1	TFS 46810 add Journal number to backup details
// ---------------------------------------------------------------------------
vars
	proxyBackup, realBackup: CM_Backup;
	binaryBackupPath, dbBackupPath, journalLocalBackupPath, binaryRemoteBackupPath, dbRemoteBackupPath, journalRemoteBackupPath:String;
	dbCompress, dbOverwrite, dbVerify, debug, journalCompress, journalVerify, purgeDBJournals, purgeLocalJournals, purgeRemoteJournals, purgeSDSJournals: Boolean; 
    journalNumber, purgeJournalDays: Integer;
    result,ls: Boolean;
	sdsSecondaryBackup : Boolean; 	//cnwrs1 21 Jan 2010 ccms1150
	databaseWorkers : Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.cmsBeginLoad(ls);
	self.mousePointer := Window.MousePointer_HourGlass;


	dbBackupPath := self.tblBackup.getValueByName(ETRow_BackupPath).String;
	dbCompress := self.tblBackup.getValueByName(ETRow_DBCompress).Boolean;
	journalCompress := self.tblBackup.getValueByName(ETRow_JournalCompress).Boolean;
	journalLocalBackupPath := self.tblBackup.getValueByName(ETRow_JournalPath).String;
	journalRemoteBackupPath := self.tblBackup.getValueByName(ETRow_JournalRemotePath).String;
	journalVerify := self.tblBackup.getValueByName(ETRow_JournalVerify).Boolean;
	purgeDBJournals := self.tblBackup.getValueByName(ETRow_PurgeJournals).Boolean;
	purgeJournalDays := self.tblBackup.getValueByName(ETRow_PurgeJournalDays).Integer;
	purgeLocalJournals := self.tblBackup.getValueByName(ETRow_PurgeJournalsLocal).Boolean;
	purgeRemoteJournals := self.tblBackup.getValueByName(ETRow_PurgeJournalsRemote).Boolean;
	purgeSDSJournals := self.tblBackup.getValueByName(ETRow_PurgeSDSJournals).Boolean;
	sdsSecondaryBackup := self.tblBackup.getValueByName(ETRow_SDSSecondaryBackup).Boolean;
	databaseWorkers := self.tblBackup.getValueByName(ETRow_DatabaseWorkers).Integer;
	journalNumber := self.tblBackup.getValueByName(ETRow_JournalNumber).Integer;
	
	if self.myBackup = null then
		create proxyBackup transient;
		proxyBackup.setProxy(binaryBackupPath, dbBackupPath, journalLocalBackupPath, binaryRemoteBackupPath, dbRemoteBackupPath, journalRemoteBackupPath,
			dbCompress, dbOverwrite, dbVerify, debug, journalCompress, journalVerify, purgeDBJournals, purgeLocalJournals, purgeRemoteJournals, purgeSDSJournals,
			journalNumber, purgeJournalDays, sdsSecondaryBackup, databaseWorkers);
			
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxCA.trxCreateBackup(proxyBackup, realBackup, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				result := true;
				self.myBackup := realBackup;
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Backup),	app.myPassport, ErrWarnMode_AddUpdate);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			result := false;
			break;
			
		endwhile;
		
		
	else
		proxyBackup := self.myBackup.pxyCreateUpdateProxy();
		proxyBackup.setProxy(binaryBackupPath, dbBackupPath, journalLocalBackupPath, binaryRemoteBackupPath, dbRemoteBackupPath, journalRemoteBackupPath,
			dbCompress, dbOverwrite, dbVerify, debug, journalCompress, journalVerify, purgeDBJournals, purgeLocalJournals, purgeRemoteJournals, purgeSDSJournals,
			journalNumber, purgeJournalDays, sdsSecondaryBackup, databaseWorkers);
			
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateBackup(proxyBackup, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				result := true;
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Backup),	app.myPassport, ErrWarnMode_AddUpdate);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			result := false;
			break;
			
		endwhile;
		
	endif;
	
epilog
	app.cmsEndLoad(ls);
	self.mousePointer := Window.MousePointer_Default;
	delete proxyBackup;
	if result = true then	
		self.btnSaveBase.enabled := false;
		self.btnEdit.enabled := true;
		if self.myBackup = null then
			self.btnBackup.enabled := false;
		else
			self.btnBackup.enabled := true;
		endif;
		self.btnCancelBase.enabled := false;
		self.tblBackup.userInputEnabled := false;	
		self.shtDBHistory.enabled := true;
		self.shtJournalHist.enabled := true;	
	endif;
	if self.myBackup &lt;&gt; null then
		self.unlock(self.myBackup);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStartRefreshTimer" id="a67e85bf-e1e7-4ed9-82de-5eb7d12e3637">
        <updating/>
        <source>doStartRefreshTimer() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Mar 2010	cnwkpd1	PAR #22945 - Handle multiple consecutive refresh notes using a timer

*/

constants
	MinimumDelay	= 2000;
	
vars
	delay			: Integer;
	
begin
	if not self.refreshTimerStarted then
		// Make the delay at least twice the time it last took to refresh the tables, with a pre-defined minimum
		delay := self.lastRefreshTimeElapsed * 2;
		delay := delay.max(MinimumDelay);
		
		self.beginTimer(delay, Timer_OneShot, self.Timer_Refresh);
		self.refreshTimerStarted := true;
	endif;
	

epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fldBackup_querySheetChg" id="e9988bb4-b655-4367-b829-1c459161357e">
        <controlMethod name="CMUI_Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldBackup_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;
// -------------------------------------------
// Created August 2004 by cnwrs1
// -------------------------------------------
vars

begin
	if newSheet = self.shtBackup then
		self.btnEdit.enabled := true;
	else
		self.btnEdit.enabled := false;
	endif;
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEdit.enabled := false;
	endif;

	return true;
end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
