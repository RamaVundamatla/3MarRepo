    <JadeMethod name="isForCashReceipt" id="8b638e64-e84f-497e-af13-b6fe9e081059">
        <source>isForCashReceipt(_receipt : CM_CashReceipt) : Boolean;
/*

Purpose:			 // TFS 7611

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2017	jlgab1	Initial creation

*/

vars
	cp : CM_CashPayment;
begin
	foreach cp in self.allCashPayments do
		if cp.myCashReceipt = _receipt then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
