    <JadeMethod name="getUseAppSkins" id="72661c66-ec5c-485e-92b0-7aaf37ad8114">
        <source>getUseAppSkins():Boolean;
// --------------------------------------------------------------------------------
// Created:		29 September 2008 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether this User has the preferences
//				set to use application skins.
//
// Parameters:	None
//
// Returns:		True if the skins option is set, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	skin 		: String;
	isUsingSkin : Boolean;
	
begin
	isUsingSkin := false;
	
	skin := self.getStateData(ConfigGrp_System, UserAppSkins).String;
	
	if skin &lt;&gt; null then
		isUsingSkin := true;
	endif;
	
	return isUsingSkin;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getUserCargoType" id="42ad6138-434c-476d-8d90-ca8487fbba5e">
        <source>getUserCargoType(_cargoType : CM_CargoBOLType; _forEdit : Boolean) : CM_UserConfigCargoType;
/* 
 called from cargo enquiry, return the CM_User_CargoType if found
 otherwise a new transient instance populated from the _cargoType enquiry ent table definitions
 _forEdit parameter added Nov 2011 28374 to handle Log enquiry/edit 
*/
vars
	uctypeTransient,
	uctype	: CM_UserConfigCargoType;
begin
	uctype := self.allUserCargoTypes[self, _cargoType];
	if uctype &lt;&gt; null then
		create uctypeTransient transient;
		uctypeTransient.copyFrom(uctype, uctype.myUser, false);
		self.refreshUserCargoType(uctypeTransient);	// Nov 2011 from 28459 test, was uctype
		// add in the tranship table
		self.getUserCargoTypeTranship(uctypeTransient, _cargoType);
	else
		uctypeTransient := self.getUserCargoTypeDefault(_cargoType, _forEdit);
		if _forEdit then
			// add in the tranship table
			self.getUserCargoTypeTranship(uctypeTransient, _cargoType);
		endif;
	endif;
	
	return uctypeTransient;
end;
</source>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="_forEdit" type="Boolean"/>
        <ReturnType type="CM_UserConfigCargoType"/>
    </JadeMethod>
    <JadeMethod name="getUserCargoTypeDefault" id="8792ada3-2f90-4cbe-b135-36caede2f2a9">
        <source>getUserCargoTypeDefault(_cargoType : CM_CargoBOLType; _forEdit : Boolean) : CM_UserConfigCargoType;
/* 
 called from cargo enquiry, return a new transient instance populated from the _cargoType ent table definitions
 _forEdit parameter added Nov 2011 28374 to handle Log enquiry/edit 
*/
vars
	tabType		: Integer;
	defName		: String;
	tableDefs	: StringArray;
	uctype		: CM_UserConfigCargoType;
	uctab		: CM_UserConfigTab;
	ucattr		: CM_UserConfigAttribute;
	tableRoot	: CM_EntTableDataRoot;
	entTableDef	: EntTableDef;
	entRow		: EntTableRow;
begin
	create uctype transient;
	uctype.setup(self, _cargoType);
	uctype.isDefault := true;
	create tableDefs transient;
	tableRoot := app.myRoot.myEntTableDataRoot;
	if _forEdit then
		_cargoType.allEditTableDefs.copy(tableDefs);
	else
		_cargoType.allEnquiryEntTableDefs.copy(tableDefs);
	endif;
	if tableDefs.isEmpty then // just use a default def, if cargo.  If BOL, assume that they all have something set up??
		if _cargoType.isKindOf(CM_CargoType) then
			tableDefs.add(ETDef_DefaultCargoEnt);
		endif;
	endif;
	foreach defName in tableDefs do
		// 26555 moved from CM_ContainerEnqForm
	/*	if _cargoType.isKindOf(CM_CargoType) and
		   _cargoType.CM_CargoType.productType = ProductType_Vehicle then
			if defName = ETDef_WHGeneralData or
			   defName = ETDef_WHReceiveRelease then
				continue;
			endif;
		endif;*/
		entTableDef := tableRoot.allEntTableDefs[defName];
		if entTableDef &lt;&gt; null then
			tabType := 0;
			if defName = ETDef_ReeferData then
				tabType := 1;
			endif;
			create uctab transient;
			uctab.setup(entTableDef.description, entTableDef.name, tabType, uctype);
			foreach entRow in entTableDef.allEntTableRows do
				create ucattr transient;
				ucattr.setup(uctab, entRow);
			endforeach;
		endif;
	endforeach;
	
	return uctype;
epilog
	delete tableDefs;
end;</source>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="_forEdit" type="Boolean"/>
        <ReturnType type="CM_UserConfigCargoType"/>
    </JadeMethod>
    <JadeMethod name="getUserCargoTypeEditDefault" id="b46cddcf-72ef-4537-ad76-7cac9c8b67a1">
        <source>getUserCargoTypeEditDefault(_cargoType : CM_CargoBOLType) : CM_UserConfigCargoType;
/* 
 called from cargo enquiry config maintenance, return a new transient instance populated from the _cargoType ent table definitions
*/
vars
	tabType		: Integer;
	defName		: String;
	tableDefs	: StringArray;
	uctype		: CM_UserConfigCargoType;
	uctab		: CM_UserConfigTab;
	ucattr		: CM_UserConfigAttribute;
	tableRoot	: CM_EntTableDataRoot;
	entTableDef	: EntTableDef;
	entRow		: EntTableRow;
begin
	create uctype transient;
	uctype.setup(self, _cargoType);
	uctype.isDefault := true;
	create tableDefs transient;
	tableRoot := app.myRoot.myEntTableDataRoot;
	_cargoType.allEditTableDefs.copy(tableDefs);
	if tableDefs.isEmpty then // just use a default def, if cargo.  BOLs don't get into here.
		if _cargoType.isKindOf(CM_CargoType) then
			tableDefs.add(ETDef_DefaultCargoEnt);
		endif;
	endif;
	foreach defName in tableDefs do
		// 26555 moved from CM_ContainerEnqForm
	/*	if _cargoType.isKindOf(CM_CargoType) and
		   _cargoType.CM_CargoType.productType = ProductType_Vehicle then
			if defName = ETDef_WHGeneralData or
			   defName = ETDef_WHReceiveRelease then
				continue;
			endif;
		endif;*/
		entTableDef := tableRoot.allEntTableDefs[defName];
		if entTableDef &lt;&gt; null then
			tabType := 0;
			if defName = ETDef_ReeferData then
				tabType := 1;
			endif;
			create uctab transient;
			uctab.setup(entTableDef.description, entTableDef.name, tabType, uctype);
			if defName = ETDef_ReeferData then
				uctab.setTabType(1);
			endif;
			foreach entRow in entTableDef.allEntTableRows do
				create ucattr transient;
				ucattr.setup(uctab, entRow);
			endforeach;
		endif;
	endforeach;
	
	return uctype;
epilog
	delete tableDefs;
end;
</source>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <ReturnType type="CM_UserConfigCargoType"/>
    </JadeMethod>
    <JadeMethod name="getUserCargoTypeForEdit" id="23fc55e8-0f66-4936-9f5c-c7ac7140a376">
        <source>getUserCargoTypeForEdit(_cargoType : CM_CargoBOLType; _getDefault : Boolean) : CM_UserConfigCargoType;
/* 
 called from cargo enquiry config maintenance, return a transient copy of the CM_User_CargoType if found
 otherwise a new transient instance populated from the _cargoType edit ent table definitions
*/
vars
	uctype,
	uctypeTransient	: CM_UserConfigCargoType;
begin
	if not _getDefault then
		uctype := self.allUserCargoTypes[self, _cargoType];
	endif;
	if uctype &lt;&gt; null then
		uctypeTransient := app.createUpdateProxy(uctype).CM_UserConfigCargoType;
		self.refreshUserCargoType(uctypeTransient);
		return uctypeTransient;
	endif;
	
	return self.getUserCargoTypeEditDefault(_cargoType);
end;
</source>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="_getDefault" type="Boolean"/>
        <ReturnType type="CM_UserConfigCargoType"/>
    </JadeMethod>
    <JadeMethod name="getUserCargoTypeReefer" id="37ae196c-3452-4a54-8996-1bc30151bcc2">
        <source>getUserCargoTypeReefer(_uctype : CM_UserConfigCargoType) : CM_UserConfigCargoType;
// return a new reefer user config cargo type, if not already in the user config cargo type.
vars
	newType		: CM_UserConfigCargoType;
	uctab		: CM_UserConfigTab;
	ucattr		: CM_UserConfigAttribute;
	tableRoot	: CM_EntTableDataRoot;
	entTableDef	: EntTableDef;
	entRow		: EntTableRow;
begin
	if _uctype.isDefault then
		if _uctype.includesTable(ETDef_ReeferData) then
			return null;
		endif;
	else
		if _uctype.hasReeferTab() then
			return null;
		endif;
	endif;
	tableRoot := app.myRoot.myEntTableDataRoot;
	entTableDef := tableRoot.allEntTableDefs[ETDef_ReeferData];
	if entTableDef &lt;&gt; null then
		create newType transient;
		newType.setup(_uctype.myUser, _uctype.myCargoBOLType);
		create uctab transient;
		uctab.setup(entTableDef.description, entTableDef.name, 1, newType);
		foreach entRow in entTableDef.allEntTableRows do
			create ucattr transient;
			ucattr.setup(uctab, entRow);
		endforeach;
	endif;
	
	return newType;
end;
</source>
        <Parameter name="_uctype" type="CM_UserConfigCargoType"/>
        <ReturnType type="CM_UserConfigCargoType"/>
    </JadeMethod>
    <JadeMethod name="getUserCargoTypeTranship" id="8a618d72-e307-4c37-b0f1-c479f2328d17">
        <source>getUserCargoTypeTranship(_uctype : CM_UserConfigCargoType; _cargoType : CM_CargoBOLType);
// add the TranshipData ent table to the user config cargo type, if it is present in allEnquiryEntTableDefs for the cargo type 

constants
	TranshipData = "TranshipData";
vars
	uctab		: CM_UserConfigTab;
	ucattr		: CM_UserConfigAttribute;
	tableRoot	: CM_EntTableDataRoot;
	entTableDef	: EntTableDef;
	entRow		: EntTableRow;
begin
	// disable tranships for Voyage Commodity Planning as complex enough already - RJS - moved from CM_ContainerEnqForm
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
	
	if _cargoType &lt;&gt; null and
	   not _cargoType.allEnquiryEntTableDefs.includes(TranshipData) then
		return;
	endif;
	tableRoot := app.myRoot.myEntTableDataRoot;
	entTableDef := tableRoot.allEntTableDefs[TranshipData];
	if entTableDef &lt;&gt; null then
		create uctab transient;
		uctab.setup(entTableDef.description, entTableDef.name, 0, _uctype);
		foreach entRow in entTableDef.allEntTableRows do
			create ucattr transient;
			ucattr.setup(uctab, entRow);
		endforeach;
	endif;
end;
</source>
        <Parameter name="_uctype" type="CM_UserConfigCargoType"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
    </JadeMethod>
