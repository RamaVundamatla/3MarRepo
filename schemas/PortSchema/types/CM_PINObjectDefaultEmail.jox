    <JadeMethod name="getToAddressCol" id="9c6ad5fc-62f6-4b60-bf7e-0869235d79ca">
        <source>getToAddressCol(_toAddresses: CM_EmailEntityByTypeNameDict input);
//----------------------------------------------------------------
//	Created:	28 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	email	: CM_EmailEntity;
begin
	inheritMethod(_toAddresses);

	foreach email in self.allCarrierAddresses do
		if not _toAddresses.includes(email) then
			_toAddresses.add(email);
		endif;
	endforeach;

end;</source>
        <Parameter name="_toAddresses" type="CM_EmailEntityByTypeNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getToAddresses" id="aa2cc60b-55fe-4f00-b26e-3f952ace1b2a">
        <source>getToAddresses(): String;
//----------------------------------------------------------------
//	Created:	24 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	carrierAddresses	: String;
begin

	carrierAddresses := self.allCarrierAddresses.getAddresses.trimBlanks;
	
	if carrierAddresses = null then
		return inheritMethod();
	else
		return carrierAddresses &amp; ";" &amp; inheritMethod();
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="okToSend" id="2a875d52-5b60-4181-b7f0-e8eca030d9e5">
        <source>okToSend(): Boolean;
//----------------------------------------------------------------
//	Created:	28 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//check for a 'to' address
	if self.enabled then
		return self.allCarrierAddresses.isNotEmpty or inheritMethod; //- cnwmd1, Par 24232
	else
		return false;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAddresses" id="954cbf75-405f-4de1-bb5c-5a34b5904fe9">
        <updating/>
        <source>setAddresses(
	_terminal			: CM_Terminal;
	_carrier			: CM_Carrier;
	_consignee			: CM_ConsigneeConsignor;
	_defaultEmailType	: Integer ) : Boolean updating;

// Created by cnwdvb1 on 12 September 2006

vars
	emailController		: CMIF_EmailTemplateController;
	email				: CM_EmailEntity;
	pinDefaultEmail		: CM_PINObjectDefaultEmail;
begin
	// cnwrl1 30/07/2009 PAR 20349 - start of coding
	pinDefaultEmail	:= _terminal.getEmailDefaultsSettings( _defaultEmailType );
	if pinDefaultEmail = null then
		return false;
	endif;
	// cnwrl1 30/07/2009 PAR 20349 - end of coding
	
	self.allCarrierAddresses.clear();
	if self.myEmailController = null then
		create emailController transient;
		self.setEmailController(emailController);
	else
		return false;
	endif;
	
	self.myEmailController.allToAddresses.clear();
	
	if _carrier &lt;&gt; null and pinDefaultEmail.sendToCarrier then
		_carrier.allPINNotifyEmailAddresses.copy(self.myEmailController.allToAddresses);
	endif;
	
	if _consignee &lt;&gt; null and pinDefaultEmail.sendToConsignee then
		foreach email in _consignee.allPINNotifyEmailAddresses do
			if not self.myEmailController.allToAddresses.includes(email) then
				self.myEmailController.allToAddresses.add(email);
			endif;
		endforeach;
	endif;

	//epr par 28625 1/3/12
	self.myEmailController.freeTxtToAddesses := self.myEmailController.allToAddresses.getAddresses();

	if pinDefaultEmail.copyTo &lt;&gt; null then
		// if the copyTo field is not null then add these emails to
		// the CC Addresses, they should have been validated when added.
		self.myEmailController.freeTxtCcAddesses	:= pinDefaultEmail.copyTo;
	endif;
	
	return true;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_defaultEmailType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAddressesFromEmailTemplate" id="17466577-30bc-441d-9a70-5ed398ffd342">
        <updating/>
        <source>setAddressesFromEmailTemplate(_emailTemplate : CM_EmailTemplate) updating;
/* ---------------------------------------------------------------------------
Created:	15 April 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpEmailController	: CMIF_EmailTemplateController;
	
begin

	if _emailTemplate = null then
		app.raiseCMException2(MethodWithNullParam, method.name, class.name, null, null);
		return;
	endif;
	
	tmpEmailController	:= self.myEmailController;
	
	//collections
	tmpEmailController.allToAddresses.clear;
	tmpEmailController.allBccAddresses.clear;
	tmpEmailController.allCcAddresses.clear;
	if _emailTemplate.allToAddresses &lt;&gt; null then
		_emailTemplate.allToAddresses.copy(tmpEmailController.allToAddresses);
	endif;
	if _emailTemplate.allBCCAddresses &lt;&gt; null then
		_emailTemplate.allBCCAddresses.copy(tmpEmailController.allBccAddresses);
	endif;
	if _emailTemplate.allCCAddresses &lt;&gt; null then
		_emailTemplate.allCCAddresses.copy(tmpEmailController.allCcAddresses);
	endif;
	//free text
	tmpEmailController.freeTxtToAddesses	:= _emailTemplate.toAddresses;
	tmpEmailController.freeTxtBccAddesses	:= _emailTemplate.bccAddresses;
	tmpEmailController.freeTxtCcAddesses	:= _emailTemplate.ccAddresses;
	
end;</source>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a1144516-2256-4038-9cf3-e0064a62aa3a">
        <updating/>
        <source>setForCreate(
	_entTable			: String;
	_fields				: StringArray;
	_message			: String;
	_subject			: String;
	_name				: String;
	_objectType			: String;
	_type				: Integer;
	_terminal			: CM_Terminal;
	_copyTo				: String;					// cnwrl1 27/07/2009 PAR 20349
	_sendToCarrier		: Boolean;					// cnwrl1 27/07/2009 PAR 20349
	_sendToConsignee	: Boolean ) updating;		// cnwrl1 27/07/2009 PAR 20349
//----------------------------------------------------------------
//	Created:	21 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
//	inheritMethod(_entTable, _fields, _message, _subject, _name, _objectType, _type, _terminal);	// cnwrl1 27/07/2009 PAR 20349 - what it was
	inheritMethod(	_entTable,
					_fields,
					_message,
					_subject,
					_name,
					_objectType,
					_type,
					_terminal,
					_copyTo,
					_sendToCarrier,
					_sendToConsignee );
	
	if _type = PINEmail_Prenote then
		self.isPrenote := true;
		self.attachCartersNote := true;
	elseif _type = PINEmail_PrenoteCustomsInspect then
		self.isPrenote := true;
	endif;
	
end;
</source>
        <Parameter name="_entTable" type="String"/>
        <Parameter name="_fields" type="StringArray"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_objectType" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_copyTo" type="String"/>
        <Parameter name="_sendToCarrier" type="Boolean"/>
        <Parameter name="_sendToConsignee" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForDifferentCarrier" id="3b637377-cfac-401d-bd88-d72264e11087">
        <updating/>
        <source>setForDifferentCarrier(_carrier: CM_Carrier) updating;
//----------------------------------------------------------------
//	Created:	27 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	// I do not belive this method is actually used any more?
	if _carrier &lt;&gt; null then
//		self.setAddresses(app.getMyTerminal(), _carrier, null);	// cnwrl1 30/07/2009 PAR 20349 - what it was
		self.setAddresses( app.getMyTerminalDO_NOT_USE(), _carrier, null, PINEmail_ReleaseRequest );
	endif;
	
end;
</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a1134f75-80a5-44cd-b867-6eb7fda1c1ff">
        <updating/>
        <source>setForUpdate(_proxy: CM_PINObjectDefaultEmail) updating;
//----------------------------------------------------------------
//	Created:	23 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	inheritMethod(_proxy);
	
	if self.isPrenote then
		self.attachCartersNote := _proxy.attachCartersNote;
	endif;
	
end;</source>
        <Parameter name="_proxy" type="CM_PINObjectDefaultEmail"/>
    </JadeMethod>
    <JadeMethod name="setFromEmailTemplate" id="65f82586-1681-4fb3-bec9-ad8368c640bc">
        <updating/>
        <source>setFromEmailTemplate(_emailTemplate : CM_EmailTemplate) updating;
/* ---------------------------------------------------------------------------
Created:	15 April 2009	by cnwvu1

Purpose:	Par 19427. Get email info from persistent email template
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpEmailController	: CMIF_EmailTemplateController;
	defEmail			: CM_PINObjectDefaultEmail;
	terminal			: CM_Terminal;
	
begin

	if _emailTemplate = null then
		return;
	endif;
	
	if self.myEmailController &lt;&gt; null then	// when changing the carrier, we need to copy all attributes but adresses
	
		tmpEmailController	:= self.myEmailController;
		
		//collections
		tmpEmailController.allToAddresses.clear;
		tmpEmailController.allBccAddresses.clear;
		tmpEmailController.allCcAddresses.clear;
		if _emailTemplate.allToAddresses &lt;&gt; null then
			_emailTemplate.allToAddresses.copy(tmpEmailController.allToAddresses);
		endif;
		if _emailTemplate.allBCCAddresses &lt;&gt; null then
			_emailTemplate.allBCCAddresses.copy(tmpEmailController.allBccAddresses);
		endif;
		if _emailTemplate.allCCAddresses &lt;&gt; null then
			_emailTemplate.allCCAddresses.copy(tmpEmailController.allCcAddresses);
		endif;
		//free text
		tmpEmailController.freeTxtToAddesses	:= _emailTemplate.toAddresses;
		tmpEmailController.freeTxtBccAddesses	:= _emailTemplate.bccAddresses;
		tmpEmailController.freeTxtCcAddesses	:= _emailTemplate.ccAddresses;
	
	endif;
	
	self.allIncludedFields.clear;
	if _emailTemplate.allIncludedFields &lt;&gt; null then
		_emailTemplate.allIncludedFields.copy(self.allIncludedFields);
	endif;

	self.entTableName	:= _emailTemplate.entTableName;
	self.message		:= _emailTemplate.body;
	self.name			:= _emailTemplate.name;
	self.objectType		:= _emailTemplate.objectType;
	self.subjectLine	:= _emailTemplate.subject;
	self.type			:= _emailTemplate.type;
	
	// cnwrl1 29/07/2009 PAR 20349 - start of coding
	self.copyTo				:= _emailTemplate.copyTo;
	self.sendToCarrier		:= _emailTemplate.sendToCarrier;
	self.sendToConsignee	:= _emailTemplate.sendToConsignee;
	// cnwrl1 29/07/2009 PAR 20349 - end of coding
	
	//check for enabled
	terminal	:= _emailTemplate.myParent.CM_BulkRelease.myTerminal;
//	defEmail	:= terminal.getCarrierEmailDefaultsForType(_emailTemplate.type); // par 16733 AER 30/07/2008	// cnwrl1 30/07/2009 PAR 20349 - what it was
	defEmail	:= terminal.getEmailDefaultsSettings( _emailTemplate.type );
	if defEmail &lt;&gt; null then
		self.enabled	:= defEmail.enabled;
	endif;
	
end;</source>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate"/>
    </JadeMethod>
    <JadeMethod name="setProxyPINEmail" id="dbb75b46-2911-4ef5-bf91-2cb92e337e65">
        <updating/>
        <source>setProxyPINEmail(
	_subject			: String;
	_message			: String;
	_includedFields		: StringArray;
	_attachCN			: Boolean;
	_enabled			: Boolean;
	_copyTo				: String;
	_sendToCarrier		: Boolean;
	_sendToConsignee	: Boolean ) updating;
//----------------------------------------------------------------
//	Created:	21 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.setProxy( _subject, _message, _includedFields, _enabled, _copyTo, _sendToCarrier, _sendToConsignee );
	
	if not self.isPrenote then
		self.attachCartersNote := false;
	else
		self.attachCartersNote := _attachCN;
	endif;
	
end;</source>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_includedFields" type="StringArray"/>
        <Parameter name="_attachCN" type="Boolean"/>
        <Parameter name="_enabled" type="Boolean"/>
        <Parameter name="_copyTo" type="String"/>
        <Parameter name="_sendToCarrier" type="Boolean"/>
        <Parameter name="_sendToConsignee" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSubjectFieldsFromEmailDefau" id="4a2dfdda-5300-4438-b962-b7f362cea9d1">
        <updating/>
        <source>setSubjectFieldsFromEmailDefau(_emailDefaults : CM_PINObjectDefaultEmail) updating;
/* ---------------------------------------------------------------------------
Created:	28 April 2009	by cnwvu1

Purpose:	When deleting or creating a PIN, a Release Request email default is sent to the carrier.
			However, when there is a persistent email info stored on a bulk release (myEmailTemplate),
			then the system sends email info based on the myEmailTemplate.
			To know, whether the PIN has been created or deleted, myEmailTemplate info is replaced
			by email default values here:
			subject = "Release &amp; PIN" or "Release &amp; PIN deleted" (ignoring subject line)
			and all included fields.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpEmailDefaults	: CM_PINObjectDefaultEmail;
	
begin

	tmpEmailDefaults := _emailDefaults;
	if tmpEmailDefaults = null then
		app.raiseCMException2(MethodWithNullParam, method.name, class.name, null, null);
		return;
	endif;
	
	self.subjectLine		:= tmpEmailDefaults.subjectLine;

	self.allIncludedFields.clear;
	if tmpEmailDefaults.allIncludedFields &lt;&gt; null then
		tmpEmailDefaults.allIncludedFields.copy(self.allIncludedFields);
	endif;
	

end;</source>
        <Parameter name="_emailDefaults" type="CM_PINObjectDefaultEmail"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="6f558d13-0c55-49d1-8b76-c61275030200">
        <source>validateForUpdate();
//----------------------------------------------------------------
//	Created:	23 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod();

	if self.attachCartersNote and (not self.isPrenote) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'only prenotes can have Carters Note attached');
	endif;	

end;</source>
    </JadeMethod>
</Class>
