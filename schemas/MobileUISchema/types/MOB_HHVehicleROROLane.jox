    <JadeMethod name="translateForm" id="fac2b8aa-53e2-4367-9919-9e03a0bd616a">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 September 2016 10:44:14.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021180, locale);
	btnConfirm.translateCaption(Xlat_0021181, locale);
	btnDamage.translateCaption(Xlat_0021182, locale);
	btnLabel.translateCaption(Xlat_0021183, locale);
	btnReset.translateCaption(Xlat_0021184, locale);
	lblCargoId.translateCaption(Xlat_0021185, locale);
	lblNoDamage.translateCaption(Xlat_0021186, locale);
	lblShipCounts.translateCaption(Xlat_0021308, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="06520ac1-aa80-4606-8665-3639e7e64286">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

begin

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="2dfdf3a8-db4a-40f6-b0f0-714a95aca589">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if self.txtCargoId.text.trimBlanks = null then
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		if ( self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text )
		or ( self.myTrackedItem = null and self.txtCargoId.text &lt;&gt; self.lblCargoId.caption.toUpper )
		then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;
	

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
