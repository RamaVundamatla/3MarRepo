    <JadeMethod name="getPaymentType" id="93ead1e5-ff7d-4f00-839e-c7167481fa1f">
        <source>getPaymentType():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Mar 2019	jlgndl1	Initial creation	TFS 43405
04 Oct 2023	navma1  ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
*/

vars

	debtor		: CM_Debtor;
	invoiceLine : CM_InvoiceLine;
	cashPayment : CM_CashPayment;
	trxType 	: Integer;
	cashReceipt : CM_CashReceipt;
	ti			: CM_TrackedItem;
	proforma    : CM_ProformaDetails;
begin

	ti := self.myTrackedItem;
	
	if ti &lt;&gt; null then
		if not app.isInProformaMode then
			foreach cashPayment in ti.allCashPayments do
				proforma := cashPayment.myProformaDetail;					//04.10.2023 navma1 #59638
				
				if proforma &lt;&gt; null then
					trxType := proforma.transactionType;
					if trxType = self.type then
						cashReceipt := cashPayment.myCashReceipt;
						if cashReceipt &lt;&gt; null then
							return cashReceipt.paymentType;
						endif;
					endif;
				endif;
			endforeach;
		endif;
		
		foreach invoiceLine in self.allInvoiceLines do
			debtor := invoiceLine.debtor;
			if debtor &lt;&gt; null then
				break;
			endif;
		endforeach;
		
		if debtor &lt;&gt; null then
			return ti.getPaymentType(debtor);
		endif;
	endif;
	
	return PaymentType_None;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
