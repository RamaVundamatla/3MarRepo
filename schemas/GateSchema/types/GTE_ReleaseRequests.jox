    <JadeMethod name="cmbTiType_click" id="aaee0bc9-08a4-4ebb-a623-4d220a944dff">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTiType_click(combobox: ComboBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2007 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
21/10/2016	cnwdap1		TFS 2652 - change cargo type of teh proxy mySelectedObject when cargo type changes here
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
23/10/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
*/
vars
	cargoType	: CM_CargoType;
begin
	cargoType := combobox.listObject.CM_CargoType;
	if cargoType = null then
		return;
	endif;
	//epr par 32262 17/10/13
	self.resetMeasurementRows(self.tblEntry);	
	self.setViewForReleaseLineType(cargoType.id);
	
	//default it to pack child if cargo type not container- can be over-ridden		
	if cargoType.id &lt;&gt; TI_CargoType_Container then
		self.cmbPackType.text := app.packingTypeEnumToString(CM_ReserveDetail.PackType_Child);	
		self.tblEntry.setValueByName(ETRow_PackingType, self.cmbPackType.text);
	else
		self.cmbISOType.click(self.cmbISOType);
	endif;
	
	//par 17383 cnwjo3, need to add here because when creating new and changing from
	//default 'ISO Container' properties need to be set
	self.cmbProduct.setCargoType(self.cmbTiType.listObject.CM_CargoType);
	self.cmbProduct.setOperator(self.cmbOperator.myObject.CM_Operator);  //why myObject?  listObject is null at this point
	self.cmbProduct.setObject(cargoType.allProducts.first.CM_Product);
	
	self.cmbProduct.click(self.cmbProduct);
	
	self.tblEntry.setValueByControlName(cmbProduct.name, cmbProduct.text);
	self.tblEntry.hideRowByName(ETRow_ByTypeByWeight, false);	// 6/12/2023 navcs2 ChangeRequest 57537
	//epr TFS 41398 20/2/19
	if cargoType.isBulkByWeight then
		self.tblEntry.hideRowByName(ETRow_VolumeRequested, false);
		self.tblEntry.hideRowByName(ETRow_TotalRequested, false);
		self.tblEntry.showRowByName(ETRow_WeightRequested, false);
		self.tblEntry.setValueForMeasurement(ETRow_WeightRequested," " &amp; cargoType.myWeightMeasurementType.shortName);
	elseif cargoType.isBulkByVolume then
		self.tblEntry.showRowByName(ETRow_VolumeRequested, false);
		self.tblEntry.hideRowByName(ETRow_WeightRequested, false);
		self.tblEntry.hideRowByName(ETRow_TotalRequested, false);
		self.tblEntry.setValueForMeasurement(ETRow_VolumeRequested," " &amp; cargoType.myVolumeMeasurementType.shortName);
	else
		self.tblEntry.hideRowByName(ETRow_VolumeRequested, false);
		self.tblEntry.hideRowByName(ETRow_WeightRequested, false);
		if cargoType.isBreakBulk then									// 6/12/2023 navcs2 ChangeRequest 57537
			self.tblEntry.showRowByName(ETRow_ByTypeByWeight, false);	// 6/12/2023 navcs2 ChangeRequest 57537
			self.showWeightOrRequested();								// 28/12/2023 navcs2 ChangeRequest 57537
		else															// 6/12/2023 navcs2 ChangeRequest 57537
			self.tblEntry.showRowByName(ETRow_TotalRequested, false);	// 6/12/2023 navcs2 ChangeRequest 57537
		endif;															// 6/12/2023 navcs2 ChangeRequest 57537
	endif;
	
	if CM_ReserveSelection.hasInstance(self.mySelectedObject) then					// TFS 2652
		self.mySelectedObject.CM_ReserveSelection.setMyCargoType(cargoType);		// TFS 2652
	endif;
																		// TFS 2652
end;


</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
