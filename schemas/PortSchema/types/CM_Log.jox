    <JadeMethod name="changeSpecsToBOLOutSpecs" id="82b5da1d-c5f9-4d59-b8e0-f703b983e990">
        <updating/>
        <source>changeSpecsToBOLOutSpecs(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 02 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bolOutExt : CM_BOLExtLogOut;
begin
	if self.myReleaseBOL = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Release Docket is null. Contact Developer.');
		return;
	endif;
	
	bolOutExt := self.myReleaseBOL.myExtension.CM_BOLExtLogOut;
	
	self.setMyOperator(self.myReleaseBOL.myOperator);
	self.speciesCode	:= bolOutExt.logSpeciesCode;
	self.gradeCode 		:= bolOutExt.logGradeCode;
	self.lengthCode 	:= bolOutExt.lengthCode;
	self.typeCode		:= bolOutExt.logTypeCode;
	self.treatmentCode	:= bolOutExt.logTreatmentCode;
	
	self.setProductCode(_passport);	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="copyReceivedRoadTransFromReal" id="4bf5b565-b071-4c25-be35-5e8a4d0a03b2">
        <source>copyReceivedRoadTransFromReal(_logReal : CM_Log);
//--------------------------------------------------------------
//Created: 27 November 2007 By: cnwvu1,	Par 15436
//--------------------------------------------------------------
// 11/02/2013	cnwcs5	CCMS SFW 1294 / par 30855 - handle deferred updates plus simplify method
vars
	trx, clone			: CM_TITransaction;
	isSubTerminalsOn	: Boolean;
	passport			: CM_Passport;
	terminal			: CM_Terminal;
begin
	if _logReal = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, '_logReal is null', null, self);
	endif;
	
	terminal 			:= _logReal.myTerminal;
	isSubTerminalsOn 	:= app.isSubTerminalsOn(terminal);
	passport			:= app.myPassport;
	
	foreach trx in _logReal.allTransactions discreteLock do
		if trx.isKindOf(CM_ReceiveRoad) or (isSubTerminalsOn and trx.isKindOf(CM_SubTerminalReceive)) then
			// CCMS 1875 - need to clone sub-terminal receive as well
			clone	:= trx.cloneSelf(false);
			
			clone.setMyTrackedItem(self,null);
			
			passport.addTITransactionForDeferUpd (clone, terminal);
		endif;
	endforeach;
end;</source>
        <Parameter name="_logReal" type="CM_Log"/>
    </JadeMethod>
    <JadeMethod name="create" id="cc156cf1-27b3-42e4-83f1-ecf3b2157323">
