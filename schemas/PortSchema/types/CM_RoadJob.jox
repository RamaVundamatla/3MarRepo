    <JadeMethod name="unQueueJob" id="178ffb0a-1178-410f-b6ca-61199e1e3271">
        <updating/>
        <source>unQueueJob(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 28 May 2002 By: cnwgd1
// 14/06/2022 navcs2 ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
//--------------------------------------------------------------
vars
	wle : CM_WorkListEntry;
	rtqe : CM_RTQueueEntry;
begin
	inheritMethod(_passport);
	//unqueue each YardJob. 
	//ToDoWles shouldn't be queued to move in the first place so skip them if there are any
	foreach wle in self.workListEntries do
		if wle.isKindOf(CM_WOToDoWLE) then // 14/06/2022 navcs2 ChangeRequest 53038
			continue;
		endif;
	
		wle.unQueueWLE(_passport);
		
		if _passport.hasErrors then
			return; 
		endif;
	endforeach;	
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(RoadJob_Update_Event), self);
//	self.causeEvent(self.myTerminal.getTerminalEvent(RoadJob_Update_Event), false, self);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateReceiveTI" id="96d2646f-6374-494b-b798-f4beac4dc530">
        <source>updateReceiveTI(_trackedItem: CM_TrackedItem);
//27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
//12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
vars
	generator : CM_Generator;
	vvr		  : CM_VehicleVisitRecord;
begin
	
	//27.02.2018 cnwma1 ChangeRequest #36813
	if _trackedItem &lt;&gt; null then
		generator := _trackedItem.getGenerator();
	endif;
	//27.02.2018 cnwma1 ChangeRequest #36813
	
	if self.allReleaseTrackedItems.includes(_trackedItem) then
		self.allReleaseTrackedItems.remove(_trackedItem);
		
		if generator &lt;&gt; null  then
			if self.allReleaseTrackedItems.includes(generator) then //27.02.2018 cnwma1 ChangeRequest #36813
				self.allReleaseTrackedItems.remove(generator);
			endif;
		endif;
	endif;
	
	//changed order to avoid 1210 epr par 17088 2/7/08
	if (not self.allReceiveTrackedItems.includes(_trackedItem)) then
		self.allReceiveTrackedItems.add(_trackedItem);
		
		//27.02.2018 cnwma1 ChangeRequest #36813
		if generator &lt;&gt; null  then
			if (not self.allReceiveTrackedItems.includes(generator)) then
				self.allReceiveTrackedItems.add(generator);
			endif;
		endif;
		//27.02.2018 cnwma1 ChangeRequest #36813
	endif;
	
	vvr := self.myVehicleVisit;
	
	//th2 PAR 12458 - 12/0/09/2006 - synch the vehicle visit record collections
	if vvr &lt;&gt; null then
		if (not vvr.allReceivedTrackedItems.includes(_trackedItem)) then
			vvr.allReceivedTrackedItems.add(_trackedItem);
		endif;
		
		//27.02.2018 cnwma1 ChangeRequest #36813
		if generator  &lt;&gt; null then
			if (not vvr.allReceivedTrackedItems.includes(generator)) then
				vvr.allReceivedTrackedItems.add(generator);
			endif;
		endif;
		//27.02.2018 cnwma1 ChangeRequest #36813
		
		if vvr.allReleasedTrackedItems.includes(_trackedItem) then
			vvr.allReleasedTrackedItems.remove(_trackedItem);
			
			//27.02.2018 cnwma1 ChangeRequest #36813
			if generator &lt;&gt; null then
				if vvr.allReleasedTrackedItems.includes(generator) then
					vvr.allReleasedTrackedItems.remove(generator);
				endif;
			endif;
			//27.02.2018 cnwma1 ChangeRequest #36813
		endif;
	endif;			
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateReleaseTI" id="42757f8c-f616-42f6-b5d8-cb231c1452a6">
        <updating/>
        <source>updateReleaseTI(_trackedItem: CM_TrackedItem) updating;
//27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
//12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
vars
	gen : CM_Generator;
	vvr : CM_VehicleVisitRecord;
begin
	//epr TFS 40248 29/8/18
	if _trackedItem.canMergeBreakBulk then	
		return;
	endif;

	if _trackedItem &lt;&gt; null then
		gen := _trackedItem.getGenerator();
	endif;
	
	vvr := self.myVehicleVisit;
	
	//changed order to avoid 1210 epr par 17088 2/7/08
	if (not self.allReleaseTrackedItems.includes(_trackedItem)) then
			self.allReleaseTrackedItems.add(_trackedItem);			
			//27.02.2018 cnwma1 ChangeRequest #36813
			if gen &lt;&gt; null then
				if (not self.allReleaseTrackedItems.includes(gen)) then									
					self.allReleaseTrackedItems.add(gen);	
				endif;
			endif;
			//27.02.2018 cnwma1 ChangeRequest #36813
	endif;
	//th2 PAR 12458 - 12/0/09/2006 - synch the vehicle visit record collections
	//why wasn't this designed to just use self.myVehicleVisit.myRoadJob.allReceivedTrackedItems 
	//and allReleasedTrackedItems collections?? This causes unnecessary difficulty.
	if vvr &lt;&gt; null then
		if (not vvr.allReleasedTrackedItems.includes(_trackedItem)) then
			vvr.allReleasedTrackedItems.add(_trackedItem);			
			//27.02.2018 cnwma1 ChangeRequest #36813
			if gen &lt;&gt; null  then
				if (not vvr.allReleasedTrackedItems.includes(gen)) then
					vvr.allReleasedTrackedItems.add(gen);
				endif;
			endif;	
			//27.02.2018 cnwma1 ChangeRequest #36813
		endif;
	endif;			
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateReleaseTIForChassis" id="e04367d1-69c5-4337-a4a8-d60d2e46d927">
        <source>updateReleaseTIForChassis(_chassis : CM_TILC) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2009	cnwjk3	PAR 21458

We are releasing a chassis, so we need to also note any tracked items which are on that chassis

*/

vars
	lc 	: CM_TILCController; 
	ti	: CM_TrackedItem;
begin
	foreach lc in _chassis.allLCs do
		foreach ti in lc.allTrackedItems do
			// I wonder why the job and VVR have two separate collections??
			if not self.myVehicleVisit.allReleasedTrackedItems.includes(ti) then
				self.myVehicleVisit.allReleasedTrackedItems.add(ti);
			endif;
			if not self.allReleaseTrackedItems.includes(ti) then
				self.allReleaseTrackedItems.add(ti);
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_chassis" type="CM_TILC"/>
    </JadeMethod>
    <JadeMethod name="updateStatus" id="ee3fadf5-34f9-4f61-a211-db6ed9789c0c">
        <updating/>
        <source>updateStatus() updating;
//Check the contents of the WLE's, and updates the status of this job
//accordingly.
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 30/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 06/12/2021	navdap1		TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
// 20/07/2022   navcs2 		ChangeRequest 53932: MTN - Jobs Changes
vars
	wle :CM_WorkListEntry;
	ddWle : CM_WorkListEntry;			// TFS 51935
	futureMoves : ObjectArray;			// TFS 51935
	oldStatus : Integer;
begin
	oldStatus := self.status;
	inheritMethod();

	// 10/02/2011 cnwmh5 PAR 26925 
	// vehicleReleased is used as a flag to indicate if we haveset that the vehicle has 
	// had all its cargo handling interactions completed and is now free to move to the
	// out-gate/depart the terminal.
	//jlier1 MTN-34117 18/3/25 - deadlocks - resovled by only calling when needed
	if self.vehicleReleased = null then
		if  self.myVehicleVisit = null or  (oldStatus &lt;&gt; JOB_COMPLETE and self.status = JOB_COMPLETE)  then	
			self.recordVisit(false, true);
		endif;
	endif;

	// TFS 51935 Tidy up direct delivery WLEs
	//if self.status = JOB_COMPLETE and self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then		// TFS 52293
	if self.status = JOB_COMPLETE and self.isDirectDeliveryJob then											// TFS 52293
		create futureMoves transient;
		foreach wle in self.workListEntries do
			foreach ddWle in wle.allDirectDeliveryChildWLEs do
				if ddWle.isKindOf(CM_VoyageWLE) and ddWle.CM_VoyageWLE.subSeqNum &lt;&gt; null then	// TFS 52360
					continue;																	// TFS 52360
				endif;																			// TFS 52360
				if ddWle.myTrackedItem.hasBeenMerged then										// TFS 52360
					continue;																	// TFS 52360
				endif;																			// TFS 52360
				ddWle.setStatus(WLE_COMPLETED);
				if ddWle.myFutureMove &lt;&gt; null then
					futureMoves.add(ddWle.myFutureMove);
				endif;
			endforeach;
		endforeach;
		//self.clearDirectDeliveryChildren();																// TFS 52293
		futureMoves.purge;
	
	// navcs2 53932 20/07/2022
	//jlier1 MTN-34117 18/3/25 CM_WOExportReturnedWLE can not be part of a road job
	/*elseif self.status = JOB_COMPLETE then
		foreach wle in self.workListEntries do
			if wle.isKindOf(CM_WOExportReturnedWLE) then
				wle.setStatus(WLE_COMPLETED);
			endif;
		endforeach;*/
	endif;
	// TFS 51935 end
epilog
	delete futureMoves;		// TFS 51935
end;</source>
    </JadeMethod>
    <JadeMethod name="updateTICollections" id="a8b4ed51-f961-4aef-9753-491d112656e1">
        <updating/>
        <source>updateTICollections(_trackedItem: CM_TrackedItem; _extra :Any) updating;
//--------------------------------------------------------------
//Created: 11 February 2003 By: cnwgd1
//--------------------------------------------------------------
// 01/04/2010	cnwcs5	par 23383 - _extra parameter.  Could be:
//										- CM_WorklistEntry
//										- CM_Request
//										- Boolean (true = release, false = receival)
vars
	release :Boolean;
begin
	inheritMethod(_trackedItem, _extra);	// 01/04/2010 cnwcs5 par 23383
	
	if (not app.myPassport.noErrors) then
		return;
	endif;
// dh 28/5/2008 added these methods 
//	if self.isRelease then
	if _extra.isKindOf (CM_YardWLE) and _extra &lt;&gt; null then		// 01/04/2010 cnwcs5 par 23383
		release := not _extra.CM_YardWLE.isReceipt;				// 01/04/2010 cnwcs5 par 23383
	elseif _extra.isKindOf (CM_YardRequest) and _extra &lt;&gt; null then	// 01/04/2010 cnwcs5 par 23383
		release := _extra.CM_YardRequest.isReleaseType;			// 01/04/2010 cnwcs5 par 23383
	elseif _extra.isKindOf(Boolean) then						// 01/04/2010 cnwcs5 par 23383
		release := _extra.Boolean;								// 01/04/2010 cnwcs5 par 23383
	else														// 01/04/2010 cnwcs5 par 23383
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid parameter passed to method');// 01/04/2010 cnwcs5 par 23383
	endif;														// 01/04/2010 cnwcs5 par 23383
		
	if release then												// 01/04/2010 cnwcs5 par 23383
		updateReleaseTI(_trackedItem);
	else
		updateReceiveTI(_trackedItem);
	endif;

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_extra" type="Any"/>
    </JadeMethod>
    <JadeMethod name="updateTICollectionsUnassign" id="04747d4c-dd56-404b-8ec2-24e0f4886c90">
        <updating/>
        <source>updateTICollectionsUnassign(_trackedItem: CM_TrackedItem) updating;
//--------------------------------------------------
// Created:	23 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_trackedItem);
	if (not app.myPassport.noErrors) then
		return;
	endif;
	
	if self.isRelease then
		if self.allReleaseTrackedItems.includes(_trackedItem) then
			self.allReleaseTrackedItems.remove(_trackedItem);
		endif;
		//th2 PAR 12458 - 12/0/09/2006 - synch the vehicle visit record collections
		if self.myVehicleVisit &lt;&gt; null and self.myVehicleVisit.allReleasedTrackedItems.includes(_trackedItem) then
			self.myVehicleVisit.allReleasedTrackedItems.remove(_trackedItem);
		endif;
	else
		if self.allReceiveTrackedItems.includes(_trackedItem) then
			self.allReceiveTrackedItems.remove(_trackedItem);
		endif;
		//th2 PAR 12458 - 12/0/09/2006 - synch the vehicle visit record collections
		if self.myVehicleVisit &lt;&gt; null and self.myVehicleVisit.allReceivedTrackedItems.includes(_trackedItem) then
			self.myVehicleVisit.allReceivedTrackedItems.remove(_trackedItem);
		endif;
	endif;
	
	//jlier1 29/4/25 MTN-34677
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(RoadJob_Update_Event), self);
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateVehicleCarrier" id="2b0c56ee-8777-4d29-b74b-c1de65832bb8">
        <source>updateVehicleCarrier();
// ---------------------------------------------------------------------------
// Created:     30 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theVehicle	: CM_Vehicle;

begin

	theVehicle := self.myVehicle;
	if theVehicle &lt;&gt; null then
		theVehicle.setFromRoadJob(self);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="2745790a-ff43-4950-a6fe-b9f6ab23024e">
        <updating/>
        <source>validate(pUserObject : Object; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpBatNumber	: CM_BatNumber;
	tmpArea			: CM_TerminalArea;
	tmpAreaType		: CM_TerminalAreaType;
	truck			: CM_Vehicle;
	parentTA, 
	transferTA 		: CM_TerminalArea;
	request			: CM_Request;
begin
	if self.batNumber &lt;&gt; null then
		self.validateBatNumber(false, pUserObject);
	endif;
		
	if self.myCarrier = null then
	//	app.raiseCMException1(REQUIRED_FIELD, ETRow_Carrier, 'carrierId', pUserObject);
		app.raiseCMException1(Input_required_field_Required, ETRow_Carrier, 'carrierId', pUserObject); // cnwdb2	PAR 35364
	endif;

	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, ETRow_MyTerminal, ETRow_MyTerminal, pUserObject);
		app.raiseCMException1(Input_required_field_Required, ETRow_MyTerminal, ETRow_MyTerminal, pUserObject); // cnwdb2	PAR 35364
	endif;
		
	/*
	If this is re-instated then need to create carrier prior to in/out as is done with vehicle
	if self.carrierId &lt;&gt; null then
		if app.myRoot.allCarriers[self.carrierId] = null then
			app.raiseCMWarning1(WARN_NEW_CARRIER, self.carrierId, ETRow_Carrier, pUserObject, null);							
			//app.raiseCMException1(ERR_INVALID_CARRIER, self.carrierId, 'carrierId', pUserObject);
		endif;
	else
		app.raiseCMException1(REQUIRED_FIELD, ETRow_Carrier, 'carrierId', pUserObject);
	endif;
	*/
	
	if self.regNumber &lt;&gt; null then
		truck := self.myVehicle;
		if truck = null then
			app.raiseCMWarning1(VB_NEW_VEHICLE, self.regNumber, ETRow_RegNumber, pUserObject, self);
		else
			// do a check to see if the truck is already on site

		endif;
	else
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString (Vehicle), ETRow_RegNumber, pUserObject);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString (Vehicle), ETRow_RegNumber, pUserObject); // cnwdb2	PAR 35364
	endif;

	/*
	if self.roadTransAreaId &lt;&gt; null then
		if self.myTerminal &lt;&gt; null then // Par16766 AER 16/07/2008
			process.isVTAReference ('validating vta');
			// 10/08/2009 cnwcs5 - changed to use getVehicleTransferArea method in preperation for ccms1061 conversion
			tmpArea := self.getVehicleTransferArea;
			
			if tmpArea &lt;&gt; null then
				// LCL cargo can go to a Depot.  Need to do a cross check (possibly on the TI itself?)
				if tmpArea.type &lt;&gt; TA_TYPE_ROAD_TRANS and tmpArea.type &lt;&gt; TA_TYPE_DEPOT_LCL then
					process.isVTAReference ('Richard to answer question');
					app.raiseCMException1(ERR_INVALID_VTA, self.roadTransAreaId, 'roadTransAreaId', pUserObject);
				endif;
			endif;
		endif;
	else
	*/
	if self.myGate = null and self.roadTransAreaId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString (Gate), 'Gate/VTA', pUserObject);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString (Gate), 'Gate/VTA', pUserObject); // cnwdb2	PAR 35364
	endif;
	//endif;
	
	
end;</source>
        <Parameter name="pUserObject" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateBatNumber" id="6122b10d-f0b3-43df-b51f-8477ccb75f75">
        <updating/>
        <source>validateBatNumber(pSetIfNull : Boolean; pUserObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2001 by cnwrs2
//
// Purpose:     Determines if: 
//				1: BAT# String is null
//				2: BAT# String refers to non-existent BAT
//				3: BAT# String points to BAT already in use
//				Will also get and set the next free BAT number if required
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/2/01			AJA			Logical errors in the code
// ---------------------------------------------------------------------------
vars
	tmpBatNumber	: CM_BatNumber;
	
begin

	if self.batNumber = null then
		if pSetIfNull then
			//If asked to, get the next free bat number
			tmpBatNumber := self.myTerminal.getNextBatNumber();
			if tmpBatNumber &lt;&gt; null then
				self.batNumber := tmpBatNumber.code;
			else
				//There were no free BAT numbers to allocate
				app.raiseCMException1(ERR_NONEXT_BAT, self.batNumber, 'batNumber', pUserObject);
			endif;
		/*else
			//Bat number is invalid because there isn't one !
			app.raiseCMException1(ERR_INVALID_BAT, "No BAT Number", 'batNumber', pUserObject);*/
		endif;
	endif;
	
	tmpBatNumber := self.myTerminal.batNumbers[self.batNumber];
	
	if tmpBatNumber &lt;&gt; null then		//Valid BAT: Check if already in use
		if tmpBatNumber.myRoadJob &lt;&gt; null and tmpBatNumber.myRoadJob &lt;&gt; self then
			app.raiseCMException1(ERR_BAT_IN_USE, self.batNumber, 'batNumber', pUserObject);		
		endif;
		/*if tmpBatNumber.testInUse(self.myTerminal) then
			app.raiseCMException1(ERR_BAT_IN_USE, self.batNumber, 'batNumber', pUserObject);
		endif;*/
	else								//Invalid BAT String - because there isn't one!
		app.raiseCMException1(ERR_INVALID_BAT, "No BAT Number", 'batNumber', pUserObject);
	endif;
	
end;</source>
        <Parameter name="pSetIfNull" type="Boolean"/>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateForCancel" id="24bfb7ed-bdeb-4f89-b23e-83c6c480e0a6">
        <source>validateForCancel();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 November 2024		jlizm1	Initial creation MTN 33235 Delete current entry reverting already exported cargo

*/

vars
	wle	: CM_WorkListEntry;
	
begin
	if self.status = JOB_UNACTIONED or self.status = JOB_COMPLETE or self.allEntries.size = 0 then
		//Carry on.
	else
		app.setContinueCMExceptions(false);
		app.raiseCMException2(VB_JOB_NO_DELETE, self.jobId &amp; " oid - " &amp; self.String, self.statusString, null, null);
		return;
	endif;

	foreach wle in self.workListEntries do
		wle.validateForDeleteCurrentEntry();
	endforeach;
	
end;</source>
    </JadeMethod>
