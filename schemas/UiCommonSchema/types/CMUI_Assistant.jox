    <JadeMethod name="comboBoxHMSRelativeToTide" id="5af7f1f3-1e0e-4669-beff-51511c2a6aff">
        <source>comboBoxHMSRelativeToTide(pTbl : CM_EntryTable input; pAttrName : String; _water: String);
//-----------------------------------------------------------------------
//	Created:	29 January 2007 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	row : Integer;
	str	: String;
	
begin
	row := pTbl.getRow(pAttrName);

	if (not pTbl.isValidRow(row)) then
		return;
	endif;
	
	str	:=	"" &amp; Tab &amp;
			app.getErrorString(HMS_HighWater) &amp; Tab &amp; 
			app.getErrorString(HMS_LowWater);	

	pTbl.setComboValues(row, str); 
	pTbl.setValue(row, _water);
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="_water" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSResource" id="7abc20f3-6aac-4cff-b2d0-f9dbc538fc31">
        <source>comboBoxHMSResource(_cmb: ComboBox input; _resource: HMS_Resource; _resourceType : HMS_ResourceType; _harbour: HMS_Harbour);
//--------------------------------------------------------------
//Created: February 2005 By: cnwrs1
//--------------------------------------------------------------
vars

begin

	_cmb.clear();
	
	if _resourceType &lt;&gt; null then
		_cmb.listCollection(_resourceType.allResources, true, 0);
	elseif _resource &lt;&gt; null then
		_cmb.listCollection(_resource.myResourceType.allResources, true, 0);
	else	
		_cmb.listCollection(_harbour.allResources, true, 0);
	endif;
	
	if _resource &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_resource);
	endif;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_resource" type="HMS_Resource"/>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSResourceType" id="fc44b6ec-eeaa-46a1-bb82-814261c9736f">
        <source>comboBoxHMSResourceType(pCmb : ComboBox input; _resourceType : HMS_ResourceType);
//--------------------------------------------------------------
//Created: February 2004 By: cnwgd1
//--------------------------------------------------------------
vars

begin

