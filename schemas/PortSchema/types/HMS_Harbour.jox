    <JadeMethod name="getAllEmailAddresses" id="aa5c39e8-d3e2-4add-9b2a-5921aa3bf47a">
        <source>getAllEmailAddresses() : String;
/*

Date		Who		Reason
13 March 2017	cnwer1	Initial creation TFS 3418 - used in data dump

*/

vars
	emailAddress : CM_EmailAddress2;
	emailStr : String;
begin
	
	if self.myEmailGroup = null then
		return null;
	endif;
	
	
	foreach emailAddress in self.myEmailGroup.allEmailAddresses	 discreteLock do
		if emailStr = "" then
		
			emailStr := emailAddress.getOidString; 
		else
			emailStr := emailStr &amp; "," &amp; emailAddress.getOidString; 
		endif;
 
	endforeach;
	
	return emailStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="b8daaa25-55c7-4bbc-b52d-9ddf4841680f">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     May 2007 by cnwvu1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt				: String;
	tmpStr			: String;
	planNote		: HMS_PlanningNote;
	terminal		: CM_Terminal;
	tug				: HMS_Tug;
	wharfDisplayOrder:HMS_Wharf;
begin

	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

	foreach planNote in allHMSPlanningNotes do				
		if tmpStr = null then			
			tmpStr := planNote.dateOfNote.String;		
		else	
			tmpStr := tmpStr &amp;', ' &amp; planNote.dateOfNote.String;
		endif;	
	endforeach;		
	txt := txt &amp; 'HMSPlanningNotes' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;		
	tmpStr:=null;		
	
	foreach tug in allTugs do		
		if tmpStr = null then	
			tmpStr := tug.code;
		else	
			tmpStr := tmpStr &amp;', ' &amp; tug.code;
		endif;	
	endforeach;		
	txt := txt &amp; 'Tugs' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;		
	tmpStr:=null;		
	
	foreach terminal in self.allTerminalsByCode do
		if tmpStr = null then
			tmpStr := terminal.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; terminal.code;
		endif;
	endforeach;
	txt := txt &amp; 'Terminals' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	tmpStr:=null;

	foreach wharfDisplayOrder in allWharfDisplayOrderArray do		
		if tmpStr = null then	
			tmpStr := wharfDisplayOrder.code;
		else	
			tmpStr := tmpStr &amp;', ' &amp; wharfDisplayOrder.code;
		endif;	
	endforeach;		
	txt := txt &amp; 'WharvesDisplayOrder' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;		
	tmpStr:=null;		

	
	return txt;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBerthsUnassignedToRegion" id="aacec162-5afe-46f1-b14c-c708f94a32c1">
        <source>getBerthsUnassignedToRegion(_berthSet : ObjectSet input);
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	berth	: HMS_Berth;
begin
	if _berthSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _berthSet passed to method');
		return;
	endif;
	
	foreach berth in self.allBerths do
		if berth.myHarbourRegion = null then
			_berthSet.add(berth);
		endif;
	endforeach;
end;</source>
