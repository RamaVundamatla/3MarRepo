    <DbClassMap file="_usergui"/>
    <JadeMethod name="displayEntry" id="c2e2155a-053d-4750-9840-af4cd2558f57">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _srcLocn : CM_SourceLocation; lstIndex: Integer): String updating, clientExecution;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	
	if _srcLocn = null then
		return null;
	endif;

	if _srcLocn.notAvailableForEntry then
		if self.myObject &lt;&gt; _srcLocn then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
			
	return _srcLocn.code.String &amp; Tab &amp; _srcLocn.description;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_srcLocn" type="CM_SourceLocation"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="d0468219-3d97-44f2-beae-4d45af2918a9">
        <source>getCollectionJMT(): Collection protected;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpCodeGroup : CM_CodesByCodeDict;
begin
	if self.myOperator &lt;&gt; null then
		tmpCodeGroup := self.myOperator.getAllSrcLocn();
	endif;

	return tmpCodeGroup;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getObjectByCode" id="69ae8b82-eba1-4d92-90da-99a0f5daea21">
        <source>getObjectByCode(_paraString : String) : CM_SourceLocation;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnObj 	: CM_SourceLocation;
	obj		: Object;
	coll	: Collection;
	code	: String;
	token	: Integer;
begin
	coll := self.getCollectionJMT();
	if coll = null then
		return null;
	endif;
	
	token := 1;
	code := _paraString.getNextToken(token);
	foreach obj in coll.CM_CodesByCodeDict do
		if obj.CM_SourceLocation.code = code then
			return obj.CM_SourceLocation;
		endif;
	endforeach;

	return null;
end;</source>
        <Parameter name="_paraString" type="String"/>
        <ReturnType type="CM_SourceLocation"/>
    </JadeMethod>
    <JadeMethod name="init" id="4dd12b06-85d1-415a-a8fc-f82a81901083">
        <updating/>
        <source>init() updating, protected;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	: Collection;
	idx, 
	token		: Integer;
	saveText,
	code,
	tmpStr: String;
	obj			: Object;
	tmpObj		: CM_SourceLocation;
	isDeleted	: Boolean;
begin
	coll := self.getCollectionJMT();
	if coll = null then
		self.amInitialised := false;
		return;
	endif;
	isDeleted := true;
	
	// save the current text as calling listCollection
	// clears the current text
	if self.text &lt;&gt; null then
		token := 1;
		saveText := self.text;
		code := self.text.getNextToken(token);
	endif;
	
	foreach obj in coll.CM_CodesByCodeDict do
		if obj.CM_SourceLocation.code = code then
			isDeleted := false;
		endif;
		// 26956 Feb 2011 cnwjre1 don't show if flagged 'not available for entry'
		if not obj.CM_SourceLocation.notAvailableForEntry then
			self.addItem(obj.CM_SourceLocation.code &amp; Tab &amp; obj.CM_SourceLocation.description);
		endif;
	endforeach;

	if isDeleted and code &lt;&gt; null then
		self.addItem(code &amp; Tab &amp; "Deleted");
	endif;
	
	self.selLength := 1000;			
	idx := self.findString(1, saveText);

	if idx &gt; 0 then
		self.listIndex := idx;
		self.setEntryTableCell();
		self.text := saveText;
	else
		self.text := null;
	endif;
		
	self.amInitialised := true;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setObjectAndOperator" id="4ff34770-d93c-4c3a-8ecd-f189badf2283">
        <updating/>
        <source>setObjectAndOperator(_obj : Object; _operator : CM_Operator) updating;
// ---------------------------------------------------------------------------
// Created:     23 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if self.myOperator &lt;&gt; _operator then	
		self.myOperator := _operator;

		if _obj = null then
			self.text := null;
			self.amInitialised := false;
			// want collection to reset itslef which does not happen if obj is null. 
			self.myObject := _obj;
			self.zInit();
			
			if self.findObject(_obj) &gt; 0 then
				self.listObject := _obj;
			else
				self.clear();
			endif;	
			return;
		endif;	
	endif;

	// Forces a clear because we combo to populate.
	self.amInitialised := false;
	self.setObject(_obj);
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
