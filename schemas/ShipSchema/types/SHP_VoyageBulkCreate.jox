    <JadeMethod name="cmbVessel_displayEntry" id="e51c0600-2a30-455e-b8d8-849b53d32d58">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVessel_displayEntry(combobox: ComboBox input; pVessel: CM_Vessel; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	failedDAC  : CM_DataAccessController; 

begin

	if pVessel = null then
		return null;
	endif;
	
	if (not pVessel.canCreateVoyages) then
		return null;
	endif;
	if (not pVessel.isBarge) then
		return null;
	endif;
	
	if not pVessel.canUserAccessSelf(null, failedDAC, app.myPassport) then
		return null;
	endif;
	
	return pVessel.code &amp; Tab &amp; pVessel.name;		
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="pVessel" type="CM_Vessel"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
