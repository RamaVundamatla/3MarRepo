    <JadeMethod name="doHandleNotification" id="8f472aa1-f182-432a-9a65-e79db19cf8f7">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	dataLine	: String;
	custDocDetail : CM_CustomDocumentDetail;
	event : Integer;
	idx : Integer;
	theDataLine : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_CustomDocumentDetail) then
		custDocDetail := userInfo.CM_CustomDocumentDetail;
	elseif theObject.isKindOf(CM_CustomDocumentDetail) then
		custDocDetail := theObject.CM_CustomDocumentDetail;
	endif;
	
	if event = Event_CustDocDetailCreate then
		if custDocDetail &lt;&gt; null then			
			self.displayDetails();
		endif;
	elseif event = Event_CustDocDetailUpdate then
		if custDocDetail &lt;&gt; null then
			self.tblData.findObjectInRow(custDocDetail,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := custDocDetail.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	elseif event = Event_CustDocDetailDelete then
		self.tblData.removeItemObject(custDocDetail);
	endif;
	self.displayStatus();
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
