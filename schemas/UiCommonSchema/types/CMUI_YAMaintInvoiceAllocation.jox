        <updating/>
        <source>btnMap_click(btn: Button input) updating;
/*
Purpose:			
Date		Who		Reason
18 March 2015	cnwab1	Initial creation
*/

vars
	alloc : CM_InvoiceCargoAllocation;
begin

	alloc := self.myYardAllocation.CM_InvoiceCargoAllocation;

	if alloc = null then
		return;
	endif;
	
	self.myAssistant.showInvoiceCargoAllocMapping(alloc, null, alloc.class);
	
epilog

end;</source>
