    <JadeMethod name="setMyCurrentListObjects" id="a8c5b52e-4e78-4e18-ba6a-921236ce3846">
        <updating/>
        <source>setMyCurrentListObjects(_object : CM_Object) updating;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.myCurrentListObject := null;
	self.myCurrentLocation := null;
	self.myCurrentTrackedItem := null;
	self.myCurrentUserTerminalForMenu := null;
	self.myCurrentWLE := null;
	self.myCurrentJob := null;
		
	if _object = null then
		// Update the navigator
		self.setNavigatorHeading(self.caption); 
		return;
	endif;

	if _object.isKindOf(CM_LocationsController) then
		self.myCurrentLocation := _object.CM_LocationsController;
	elseif _object.isKindOf(CM_Job) then
		self.myCurrentJob := _object.CM_Job;		
	elseif _object.isKindOf(CM_Request) then
		self.myCurrentJob := _object.CM_Request.myJob;				
	elseif _object.isKindOf(CM_TrackedItem) then
		self.myCurrentTrackedItem := _object.CM_TrackedItem;
	elseif _object.isKindOf(CM_UserTerminal) then
		self.myCurrentUserTerminalForMenu := _object.CM_UserTerminal;
	elseif _object.isKindOf(CM_WorkListEntry) then
		self.myCurrentWLE := _object.CM_WorkListEntry;
		self.myCurrentTrackedItem := self.myCurrentWLE.myTrackedItem;
	endif;
		
	self.myCurrentListObject := _object.CM_Object;
	self.setNavigator(_object);	
		
end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setNavigator" id="0d06d445-98f6-40ec-8e18-24accb0aa39f">
        <updating/>
        <source>setNavigator(pObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lNavString : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if pObject = null then
		lNavString := self.caption;
	elseif pObject.isKindOf(CM_RailLine) then
		lNavString := pObject.CM_RailLine.getIdString &amp; " - Line"; 
	elseif pObject.isKindOf(CM_Rail) then
		lNavString := pObject.CM_Rail.id &amp; " - Area"; 
	elseif pObject.isKindOf(CM_Wagon) then
		lNavString := pObject.CM_Wagon.id &amp; " - Wagon";
	elseif pObject.isKindOf(CM_Job) then
		lNavString := pObject.CM_Job.jobId &amp; " - Job";
	elseif pObject.isKindOf(CM_TrackedItem) then
		lNavString := pObject.CM_TrackedItem.id;
	elseif pObject.isKindOf(CM_WorkListEntry) then
		lNavString := pObject.CM_WorkListEntry.getTreeDescription();
	elseif pObject.isKindOf(CM_Vehicle) then
		lNavString := pObject.CM_Vehicle.regNumber &amp; " - Vehicle";
	elseif pObject.isKindOf(CM_TerminalArea) then
		lNavString := pObject.CM_TerminalArea.id;
	else
		lNavString := self.caption;
	endif;			

	// Update the navigator
	self.setNavigatorHeading(lNavString); 

epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setStatusBarCaption" id="bc53f53b-026a-4978-8ce5-53f37f403ce5">
        <source>setStatusBarCaption();
//--------------------------------------------------------------
//Created: 04 February 2003 By: cnwgd1
//--------------------------------------------------------------
// 10/03/2011	cnmwh5	PAR #27142 - Move where handleDeleteObject is armed
vars
	isInvalid : Boolean;
begin
	
	if self.myCurrentWLE &lt;&gt; null then
		self.frmModeStatusBar.myFrameCaption.caption := self.myCurrentWLE.getFullDescription();
	elseif self.myCurrentJob &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, self.myCurrentJob, isInvalid); // 19710
		self.frmModeStatusBar.myFrameCaption.caption := self.myCurrentJob.statusString &amp; ' ' &amp; self.myCurrentJob.jobId;
	else
		self.frmModeStatusBar.myFrameCaption.caption := null;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTIColour" id="402f0019-8c7b-4fc4-a82b-0d516a46a369">
        <source>setTIColour(lHeight, idx : Integer);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if lHeight = 1 then
		lstJobs.itemForeColor[idx] := Black;
	elseif lHeight = 2 then
		lstJobs.itemForeColor[idx] := Blue;
	elseif lHeight = 3 then
		lstJobs.itemForeColor[idx] := Green;
	elseif lHeight = 4 then
		lstJobs.itemForeColor[idx] := Red;
	else
		lstJobs.itemForeColor[idx] := Mauve;
	endif;

end;</source>
        <Parameter name="lHeight" type="Integer"/>
        <Parameter name="idx" type="Integer"/>
    </JadeMethod>
