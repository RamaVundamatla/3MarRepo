    <JadeMethod name="setUpLocations" id="92b03881-e132-43ff-9bd6-a6d5030f0916">
        <updating/>
        <source>setUpLocations( locationsSet : CM_LCSet ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2015	cnwndl1	Initial creation	Par 36132

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	size : Integer;
	buttonCaption : String;
	buttonHeight : Integer;
	lc : CM_LocationsController;

begin

	if self.locationsSetSize &gt; 0 then
		foreach buttonNumber in 1 to self.locationsSetSize do
			menuButton := self.btnLocationsTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				delete menuButton;
			endif;
		endforeach;
		self.locationsSetSize := 0;
		buttonNumber := 0;
	endif;

							
	size := locationsSet.size;
	if size &lt; 2 then
		return;
	endif;
	
	buttonHeight := self.getScrollingButtonHeight();
	self.btnLocationsTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmLocations, self.btnLocationsTemp.height, self.scrLocations );
	
	foreach lc in locationsSet do
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnLocationsTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := lc;
		menuButton.caption := lc.getFullId;
		menuButton.enabled := true;
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	self.locationsSetSize := locationsSet.size;	
	
	self.btnLocationsTemp.visible := false;
	self.frmLocations.caption := null;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="locationsSet" type="CM_LCSet"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="85321a05-7f2b-4e54-a5b6-025a771b0ce6">
        <updating/>
