    <JadeMethod name="doDelete" id="18c4ba4f-d7f6-474c-b9f3-f80e58f47375">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin

	if self.myCurrentRateEntry = null then
		app.msgBox("Please select a rate entry to delete.","Confirm Delete",MsgBox_OK_Only);
		return;
	endif;
	while true do
	 	app.myTrxDA.trxDeleteRateEntry(self.myCurrentRateEntry, app.myPassport);
		 
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return ;
		else
			theReturn := app.showErrorWarningDialog("rate Entry Delete", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return ;
		endif;
		break;
	endwhile;
	
	self.setBaseRateEntry();	//17 Sep 2012	NDL	Par 30375
	
end;</source>
    </JadeMethod>
