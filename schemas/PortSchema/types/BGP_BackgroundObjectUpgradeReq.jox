<Class name="BGP_BackgroundObjectUpgradeReq" id="c5ea79aa-4326-4019-8852-436a82aeedf2">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Background Object Upgrader&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="action" id="fa4e5d90-5146-4377-9916-1160ebbcb3e8">
        <updating/>
        <source>action(): Boolean updating;
/*
Date		Who		Reason
16 March 2011	cnwndl1	Initial creation
10 Dec 2012		cnwcs5	ccms sfw 1294 / par 30855
*/
vars
	errCode		: Integer;
	errTxt		: String;
	array		: ObjectArray;
	obj			: Object;
begin

	on Exception do app.alertExceptionHandler(exception, null,  self.getErrorDesc(),errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);

	// find any object upgrade objects to be processed
	create array transient;
	
	CM_ObjectUpgrader.allInstances (array, null, true);
	
	foreach obj in array do
		if obj.isKindOf (CM_ObjectUpgraderCAMSTrx) then
			if obj.CM_ObjectUpgraderCAMSTrx.isComplete then
				// everything done.
				continue;
			endif;
			
			obj.CM_ObjectUpgraderCAMSTrx.runConversion (self, CM_ObjectUpgraderCAMSTrx.STYLE_BGP_CONVERSION);
		// 35678 delete extra zero-days future storage transactions
		elseif obj.isKindOf(CM_ObjectUpgraderFutureStorage) then
			if obj.CM_ObjectUpgraderFutureStorage.isComplete() then
				// everything done.
				continue;
			endif;
			
			obj.CM_ObjectUpgraderFutureStorage.doDelete ();
		endif;
	endforeach;	
epilog

	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	
	inheritMethod();
	
	delete array;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="183c177c-2d14-45fd-a005-8a1f923213fc">
        <source>getDisplay(): String;

vars
	str, detail : String;
	upgrader	: CM_ObjectUpgraderFutureStorage;

begin
	
	str := inheritMethod();
	detail := "Nothing to do";
	upgrader := CM_ObjectUpgraderFutureStorage.firstInstance;
	if upgrader &lt;&gt; null then
		detail := upgrader.deleteCount.String &amp; " unwanted future storage transactions deleted so far."  ;
	endif;
	return str &amp; Tab &amp; detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
