    <JadeMethod name="delete" id="69fb3367-ea51-4f05-8cfe-fdb9c6ed0af4">
        <updating/>
        <source>delete() updating;

// cleanup for proxies

vars
begin
	// proxy cleanup
	if myLayoutGraphic &lt;&gt; null then
		delete myLayoutGraphic;
	endif;
	allLocationsControllers.purge;
	allRestrictionsLocation.purge;
end;
</source>
