    <JadeMethod name="click" id="b1f75a99-8abf-493b-b68e-94df69d40bad">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(_table: Table input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     13 October 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/10/2009	cnwcs5		par 20806 - issues with expanding/collapsing
// ---------------------------------------------------------------------------
vars
	theRow, theCol	:Integer;	
begin
	// origXPos &amp; origYPos will have been set in superclass mouseDown method
	theRow 	:= _table.row;
	theCol	:= _table.column;
	
	if theRow &gt; _table.fixedRows and
		self.origXPos &gt;= 5 and
		self.origXPos &lt;= 15 and		
		_table.accessCell (theRow, theCol).picture &lt;&gt; null and
		self.isGroupingRow (theRow) then
		// it is a grouping row
		self.doExpandCollapse (theRow);
	endif;
		
	inheritMethod(_table);

epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="47a58f73-ebc6-49ee-8cc3-78cb75b76c23">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dblClick(_table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	:Integer;
begin 
	theRow := _table.row;
	
	// expand/collapse
	if theRow &gt; self.fixedRows and 
		(self.origXPos &lt; 5 or	// b4 picture
		self.origXPos &gt; 15) and	// after picture
		self.getGroupLevel (theRow) &gt; 0 then 
		self.doExpandCollapse (theRow);
	endif;
	
	inheritMethod(_table);

epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deleteRow" id="1bde8430-fbf6-4300-9ef1-f28d6ee56031">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>deleteRow(_row: Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     08 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_row);

	/*	if the item being removed is the last one in the group we need
	to remove the grouping value for it */
	self.doCheckForEmptyGroup (_row - 1);
	
epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCheckForEmptyGroup" id="e20dd6ac-8801-47d9-a1a8-b4a1c39a9c5c">
        <updating/>
        <source>doCheckForEmptyGroup(_row :Integer)updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//				If _row is a group heading with no lower level items then remove it
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	level	:Integer;
	str		:String;
begin
	if _row &lt;= self.fixedRows or _row &gt; self.rows then
		return;
	endif;
	
	level := self.getGroupLevel (_row);
	
	if level = 0 then
		return;	// not a group heading
	endif;
	
	if _row = self.rows or						// last row - empty group
		self.getGroupLevel (_row + 1) &lt;&gt; 0 then	// empty group
		
		str := self.getGroupValueForRow (_row);
		
		self.allGroupingValues.remove (str);
		
		self.deleteRow (_row);
		// now remove the group value from AllGroupingValues
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doExpandCollapse" id="5f53c6f6-6383-483d-b92c-3214c1e293e5">
        <updating/>
        <source>doExpandCollapse(_row :Integer)updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	doExpand			:Boolean;
	int, size, level	:Integer;
begin
	// the group is expanded if the '-' picture is showing
	doExpand 	:= self.accessCell(_row, 1).picture = app.myRoot.getConfig(PicYAMExpand).Binary;
	size		:= self.rows;					// # rows
	level 		:= self.getGroupLevel (_row);	// group level
	
	if _row = size then
		// it is the last row so nothing to do
		return;
	endif;
	
	foreach int in _row + 1 to size do
		if self.getGroupLevel (int) &gt;= level then
			// reached next group with same or higher level
			break;
		endif;
		// this is a sub-ordinate entry
		if doExpand then
			// we are expanding
			self.accessRow (int).visible := true;
		else
			// we are collapsing
			self.accessRow (int).visible := false;
		endif;
	endforeach;
	
	self.setExpandCollapse (not doExpand, _row);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doGroupHeadings" id="5644544f-930c-43db-adf9-afc5c5ac750a">
        <updating/>
        <source>doGroupHeadings(_obj :Object; _group :EntTableRow) updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// ---------------------------------------------------------------------------
constants
	BACKCOLOUR = LightBlue;
vars
	str			:String;
	coll		:StringArray;
	obj			:Object;
	null_value	:String;
begin
	null_value := app.getErrorString (Unknown);
	
	// get value for group key from object being added to the table.
	str := _obj.CM_Object.getDisplayStringForAttribute (_group.name, false);

	if str = null then
		str := null_value;
	endif;
	
	// do we already have a grouping for this value
	coll := self.allGroupingValues;
	
	if not coll.includes (str) then
		coll.add (str); 
		
		// now add an entry to the table for the grouping level
		if str &lt;&gt; null_value then
			obj := str.asObject;
		endif;
		
		if obj &lt;&gt; null then
			// add group heading starting in column 1 - don't use addItemObject
			row := self.addItem (self.getDisplayForGroup (obj.CM_Object));
			
			self.accessRow (row).itemObject := obj;
		else
			// add group heading starting in column 1 - don't use addItemObject
			row := self.addItem (self.getDisplayForGroup (str));	
		endif;
		
		self.stretch 							:= Table.Stretch_None_Picture_First;
		self.accessCell (row, 1).alignment 		:= Table.Alignment_Left_Middle;
		self.accessRow (row).marginLeft			:= 1;
		self.accessedRow.marginRight 			:= 1;
		self.accessedRow.marginTop 				:= 1;
		self.accessedRow.marginBottom			:= 2;	
		self.setExpandCollapse (false, row);	// show '-' as picture
		
		// set the grouping property value
		self.setCellValueByName (_group.name, row, str);
		
		self.accessRow (row).backColor 				:= self.getGroupRowBackgroundColor;
		self.accessCell (row, 1).mergeCells 		:= Table.MergeCells_Merge;
		self.accessCell (row, self.columns).text 	:= 1.String;// hidden sort column
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_group" type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="dump" id="2c4beaf6-073e-47aa-ba22-7285e19e974e">
        <source>dump():String;
// ---------------------------------------------------------------------------
// Created:     13 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row, col	:Integer;
	str			:String;
begin
	foreach row in 1 to self.rows do
		foreach col in 1 to self.columns do
			str := str &amp; ',' &amp; self.getCellText (row, col);
		endforeach;
		str := str &amp; CrLf;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getColumnForGroupingETRow" id="b85de45e-2af9-4386-8927-3d9c2549d32b">
        <source>getColumnForGroupingETRow():Integer protected;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
