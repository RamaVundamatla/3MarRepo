    <JadeMethod name="getNumOverstowsForTI" id="9cfb8f2c-ffe4-45b9-ba43-5a2c560fbeef">
        <source>getNumOverstowsForTI(_ti: CM_TrackedItem): Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2011	cnwdap1	Initial creation PAR #28223 CCMS MSL 1024 minimum number of tracked items to move if we need to move _ti
*/
vars
	idx 	: Integer;

begin
	if _ti = null then
		return 0;
	endif;
	
	idx := self.allTrackedItems.indexOf(_ti);
	if self.accessDirection = self.ACCESS_DIRECTION_NONE or idx = 0 then
		return 0;
	elseif self.accessDirection = self.ACCESS_DIRECTION_BOTH then
		return (idx - 1).min(self.allTrackedItems.size - idx);
	elseif self.accessDirection = self.ACCESS_DIRECTION_LEFT then
		return (idx - 1);
	elseif self.accessDirection = self.ACCESS_DIRECTION_RIGHT then
		return (self.allTrackedItems.size - idx);
	endif;
	
	return 0;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumQueuedPlannedActualTIs" id="0a0581f2-6841-471b-a08e-1f2b2e7c00b7">
        <source>getNumQueuedPlannedActualTIs(): Integer ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2010	cnwjk3	Initial creation

*/

vars
	num	: Integer;
begin
	num := self.allTrackedItems.size();
	num := num + self.allQueuedFutureMoves.size();
	num := num + self.allPlannedFutureMoves.size();
	return num;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
