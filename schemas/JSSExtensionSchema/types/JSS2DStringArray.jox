    <JadeMethod name="purge" id="d1469736-258d-4854-bda6-84d9185af4c4">
        <lockReceiver/>
        <updating/>
        <source>purge() updating, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
