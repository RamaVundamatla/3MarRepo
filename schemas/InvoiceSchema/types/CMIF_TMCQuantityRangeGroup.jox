    <JadeMethod name="getMethodOrder" id="ee4eb262-bc37-40ce-953f-fc75aad008a4">
        <source>getMethodOrder(_name : String) : Integer;
// 23659 add invoice mapping methods to extract
vars
	heading, str : String;
	idx : Integer;
begin
	foreach str in self.myTMCController.fullMethodNames do
		idx := idx + 1;
		if str = _name then
			return idx;
		endif;
	endforeach;
	
	return 0;

end;
</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
