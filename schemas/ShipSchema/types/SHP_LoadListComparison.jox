    <JadeMethod name="initQueryFrame" id="d5f52fdd-384f-47d9-bbe5-e0a2063a5810">
        <source>initQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//	27/07/2022	navkc1	ChangeRequest 53629: PNL-Cargo Comparison - Different fields save on close for Load List and Discharge List.
//
//	This is also the default setup for the query frame
vars
	sht	: CMUI_Sheet;
	association : CM_Association; //par 25235 cnwrs1 3 aug 2010
	obj : Object;
	str : String;
	list : ObjectSet;
begin	
	sht := self.shtQuery1;
	sht.visible := true;
	sht.caption := app.getErrorString(LoadListComparison);	
	
	
	sht := self.shtQuery2;
	sht.visible := true;
	sht.caption := app.getErrorString(FieldSettings);

	sht := self.shtQuery3;
	sht.visible := false;
	
	sht := self.shtQuery4;
	sht.caption := app.getErrorString(Operators);
	self.lstTblOperator.width := sht.clientWidth;
	self.lstTblOperator.height := sht.clientHeight;
	sht.visible := true;

	sht := self.shtQuery5;
	sht.visible := true;
	sht.caption := app.getErrorString(UpdateSettings);
	
	self.btnRunComparison.caption := "&amp;Run Comparison";
	self.btnRunComparison.bubbleHelp := "Run Comparison";
	

	self.setupIgnoreCodes(); //cnwrs1 CCMS 1137 08 June 2010
	self.mulSelectIgnore.formDisplayEntryMethodName := SHP_LoadListComparison::displayEntryString.name;
	self.mulSelectIgnore.availableHeading := app.getErrorString(Available);
	self.mulSelectIgnore.setAvailable(self.allIgnoreFieldsObjects, true);
	self.mulSelectIgnore.selectedHeading := app.getErrorString(Selected);
	
	self.setupUpdateCodes(); //cnwrs1 CCMS 1137 08 June 2010
	self.mulSelectUpdate.formDisplayEntryMethodName := SHP_LoadListComparison::displayEntryString.name;
	self.mulSelectUpdate.availableHeading := app.getErrorString(Available);
	self.mulSelectUpdate.setAvailable(self.allUpdateFieldsObjects, true);	
	self.mulSelectUpdate.selectedHeading := app.getErrorString(Selected);
	
	self.setupTranshipCodes(); //cnwrs1 CCMS 1137 08 June 2010
	self.mulSelTranship.formDisplayEntryMethodName := SHP_LoadListComparison::displayEntryString.name;
	self.mulSelTranship.availableHeading := app.getErrorString(Available);
	self.mulSelTranship.setAvailable(self.allTranshipFieldsObjects, true);	
	self.mulSelTranship.selectedHeading := app.getErrorString(Selected);
	self.lblSelectUpdate.backColor := self.backColor;
	self.lblSelectIgnore.backColor := self.backColor;

	/* 27/07/2022	navkc1	#53629	Move to self.setSelected() ----&gt;
	//par 25235 cnwrs1 3 Aug 2010
	create list transient;
	foreach obj in self.allIgnoreFieldsObjects do
		association := obj.CM_Association;
		str := "ignore" &amp; association.asString;
		if self.availableXML.cnEcGetTagValueOfName(str).Boolean then
			list.add(association);
		endif;
	endforeach;
	self.mulSelectIgnore.setSelected(list);

	list.clear();
	foreach obj in self.allUpdateFieldsObjects do
		association := obj.CM_Association;
		str := "update" &amp; association.asString;
		if self.availableXML.cnEcGetTagValueOfName(str).Boolean then
			list.add(association);
		endif;
	endforeach;
	self.mulSelectUpdate.setSelected(list);
	
	list.clear();
	foreach obj in self.allTranshipFieldsObjects do
		association := obj.CM_Association;
		str := "tranship" &amp; association.asString;
		if self.availableXML.cnEcGetTagValueOfName(str).Boolean then
			list.add(association);
		endif;
	endforeach;
	self.mulSelTranship.setSelected(list);
	// &lt;------ 27/07/2022	navkc1	#53629*/
	
	self.setSelected(); // 27/07/2022	navkc1	#53629
	
epilog
	//delete list;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTable" id="81f8707b-9876-4e2f-a563-50253ef46059">
        <updating/>
        <source>initTable(_etdef : String) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theRow, theCol,idx : Integer;
	theTable : CM_DataTable;
begin

	theTable := self.tblData;
	self.initTableData(_etdef);
	theTable.fixedColumns := 0;
	theTable.sortColumn[1] := 0;
	self.tblData.selectMode := Table.SelectMode_Multiple;
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;

	self.tblData.selectionType := Table.SelectMode_FixedRow;
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	
	//PAR 11657 Lorcan
	self.tblData.allowDragSelect := true;
	if not app.myPassport.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then
		self.hideTranshipColumn();
	endif;
end;</source>
        <Parameter name="_etdef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initiateCompare" id="d5eee48f-004a-4487-b8ff-8c42325a3575">
        <updating/>
        <source>initiateCompare(_isRefresh : Boolean) updating, protected;
//----------------------------------------------------------------
//	Created:	06 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*
Date		Who		Reason
14 Nov 2024	navah1	Bug 33399: MTN - Cargo Comparison - Warnings form missing Save button
*/
vars
	agentReturnOK	: Boolean;					// cnwrl1 09/08/2010 PAR 24337
	ediData			: CM_EDIDataLoadList;
	ignoreFields	: StringArray;
	operators		: CM_OperatorSet;
	cmifMonitor		: CMIF_Monitor;
	passport		: CM_Passport;
	compareStatus	: Integer;
	voyageProgress 	: CM_VoyageProgress;			//navra1 - TFS 65376 - 31st July 2024 - 1	
	oneOperator		: CM_Operator;					//navra1 - BUG 65924 - 30th Aug 2024
	comparisonAgent : CM_LoadListComparisonAgent;	//navra1 - BUG 65924 - 30th Aug 2024
	operatorOKToProceed : Boolean;					//navra1 - BUG 65924 - 30th Aug 2024
	allOperatorsOK : Boolean;						//navra1 - BUG 65924 - 30th Aug 2024
	ediTI			: CM_EDITrackedItem;			//navra1 - BUG 65924 - 30th Aug 2024
	opListNotOK		: StringArray;					//navra1 - BUG 65924 - 30th Aug 2024
	selectedLoadListOperators : CM_OperatorSet;		//navra1 - BUG 65924 - 30th Aug 2024
	tempListOperators : CM_OperatorSet;				//navra1 - BUG 65924 - 30th Aug 2024
	oper			: CM_Operator;					//navra1 - BUG 65924 - 30th Aug 2024
	ti 				: CM_TrackedItem;				//navra1 - DEFECT 66047 - 11th Sep 2024
	currPortDestCode : String;						//navra1 - DEFECT 66047 - 11th Sep 2024
	compareAgent 	: CM_LoadListComparisonAgent;	//navra1 - DEFECT 66047 - 11th Sep 2024
	failureDescription : String;					//navra1 - CR 66185 - 18th Sep 2024
	voyStage, voyStageToUpdate : CM_VoyageStage;	//navra1 - MTN-33017 - 11th Oct 2024
	voyStatus : CM_VoyageStatus;					//navra1 - MTN-33086 - 21st Oct 2024
	failedLoadListOperators : CM_OperatorSet;		//navra1 - MTN-33185 - 1th Nov 2024
	result			: Integer;						//14.11.2024 navah1 #33399
	view : String;									//navra1 - MTN-34348 - 13th March 2025
	viewSelected : Boolean;							//navra1 - MTN-34348 - 13th March 2025
	issueTypeCount : Integer;						//navra1 - MTN-34348 - 13th March 2025
	
begin
	self.tblData.allSelectedObjects.clear;	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	
	passport := app.myPassport;
	
	ediData := self.cmbLoadList.listObject.CM_EDIDataLoadList;
	
	if ediData = null then //there is no valid load list in the system or user selected none
		if self.comparisonMode = LOAD_COMPARISON then
			app.msgBox(app.getErrorString1(NothingSelected, app.getErrorString(Load_List)), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		else
			app.msgBox(app.getErrorString1(NothingSelected, app.getErrorString(Discharge_List)), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		endif;
		self.doShowSearcherClick();
		return;
	endif;
	
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	self.initModalDialog();
	
	//self.lblModalMessage.caption := Cr &amp; "Load List Comparison";
	//par 18603
	self.lblModalMessage.caption := Cr &amp; app.getErrorString(List_Comparison);
	self.frmModalDialog.visible := true;
	self.doWindowEvents(0);
	
	create ignoreFields transient;
	self.getIgnoreFields(ignoreFields);
	
	create operators transient;
	self.getOperators(operators);
	
	//reset before each run 
	self.rtsSaved := false;
	endNotificationForSubscriber(self);
	
	if self.comparisonMode = LOAD_COMPARISON then	//ccms 1096
	//if self.cmbComparison.text = self.CMP_EXPORTS then //ccms1690 cnwrs1 mar 2008
		compareStatus := TI_IMEX_STATUS_EXPORT;
	else
		compareStatus := TI_IMEX_STATUS_IMPORT;
	endif;
	//-----------------------------------
	// Do Comparision
	//-----------------------------------
//	self.myLLCAgent.doComparison(	ediData,		// cnwrl1 09/08/2010 PAR 24337 - what it was
	agentReturnOK	:= self.myLLCAgent.doComparison(
									ediData,
									self.myCurrentVoyage,
									ignoreFields,
//									self.chkISOGroup.value,  //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
									operators,
									compareStatus,
									self.chkInclOtherVoy.value,	//_includeOnSiteDiffVoyage : Boolean;	//19 May 2010	NDL	Par 24243
									self.chkExclImport.value,	//_excludeImportsAndStorage : Boolean;	//19 May 2010	NDL	Par 24243
									self.chkExclEmpty.value,	//_excludeEmpty : Boolean;	//19 May 2010	NDL	Par 24243
									passport); // CCMS 1221
	
	// cnwrl1 09/08/2010 PAR 24337 - start of coding
	if not agentReturnOK then
		self.doCmbVoyageBuild();		
		
		//navra1 - BUG 65924 - 30th Aug 2024 - start
		if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myVoyageProcess &lt;&gt; null and self.myCurrentVoyage.myVoyageProcess.isAutomaticProcess() then
			voyageProgress := self.myCurrentVoyage.myVoyageProgress;			
			if self.comparisonMode = LOAD_COMPARISON then
				foreach oneOperator in operators do
					failureDescription := "The load list or voyage has been deleted";										//navra1 - CR 66185 - 18th Sep 2024
					voyageProgress.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_LoadCompLoad, voyageProgress, oneOperator.code, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Discharge, null, null, ediData, null, "The load list or voyage has been deleted", failureDescription);	//navra1 - MTN-34348 - 13th March 2025
				endforeach;
			else
				foreach oneOperator in operators do
					failureDescription := "The discharge list or voyage has been deleted";										//navra1 - CR 66185 - 18th Sep 2024
					voyageProgress.createOrUpdateVoyageStage(CM_VoyageStage.VoyStage_DischCompLoad, voyageProgress, oneOperator.code, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Discharge, null, null, ediData, null, "The discharge list or voyage has been deleted", failureDescription);	//navra1 - MTN-34348 - 13th March 2025
				endforeach;
			endif;
		endif;
		//navra1 - BUG 65924 - 30th Aug 2024 - end
		
		return;
	endif;
	// cnwrl1 09/08/2010 PAR 24337 - end of coding
	
	if self.cmbView.text = null then
		self.cmbView.text := self.VIEW_MATCHING;
	endif;
	
	self.doShowView(self.cmbView.text,_isRefresh);
	
	self.reDoNotes();

	if self.chkAutoUpdateRTS.value then
		self.doRTSSave();
	endif;	
	
	//navra1 - DEFECT 66047 - 11th Sep 2024 - start	
	compareAgent := self.myLLCAgent;
	currPortDestCode := self.myLLCAgent.myVoyage.myTerminal.getConfig(PortDestCode).String.trimBlanks();
	foreach ti in compareAgent.myVoyage.allOnshipTIsByCargoTypeId discreteLock do		
		if compareStatus = TI_IMEX_STATUS_IMPORT and 					//if doing a discharge comparison
			ti.isImport and 											//ti is import cargo on the ship
			ti.dischargePort &lt;&gt; currPortDestCode then					//having discharge port other than current port - warn user				
				passport.addWarningFull(Inv_dis_por_not_in_disch_comp, app.getErrorString2(Inv_dis_por_not_in_disch_comp, ti.dischargePort, ti.id), 'discharge port', ti, ti);				
		endif;
	endforeach;  
	
	if passport.hasWarnings() then  	
		//app.showErrorWarningDialog('Cargo Comparison', passport, ErrWarnMode_Delete);					//14.11.2024 navah1 #33399
		result := app.showErrorWarningDialog('Cargo Comparison', passport, ErrWarnMode_CanAckWarnings); //14.11.2024 navah1 #33399
		if result &lt;&gt; IDOK then																			//14.11.2024 navah1 #33399
			return;
		endif;
		app.myPassport.clearErrorsWarnings();
	endif;
	//navra1 - DEFECT 66047 - 11th Sep 2024 - end
	
	//navra1 - BUG 65924 - 30th Aug 2024 - start
	if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myVoyageProcess &lt;&gt; null and self.myCurrentVoyage.myVoyageProcess.isAutomaticProcess() then
		voyageProgress := self.myCurrentVoyage.myVoyageProgress;
		comparisonAgent := self.myLLCAgent;		
		
		//if paused or not update status of comparison failure/success, //navra1 - MTN-33017 - 11th Oct 2024 - start		
		create selectedLoadListOperators transient;
		create tempListOperators transient;
		
		foreach ediTI in ediData.allEDITrackedItems do			
			oper := app.myRoot.allOperators[ediTI.CM_EDILoadListTI.operatorCode];			
			tempListOperators.addNoDuplicates(oper, false);
		endforeach;
		if self.lstTblOperator.allSelectedObjects.isEmpty then			//if you dont have any operators, do comparison for all operators on the load list
			tempListOperators.copy(selectedLoadListOperators);
		else															//if you have operators selected, curate the list to only compare for operators on the load list
			foreach oneOperator in operators do
				if tempListOperators.includes(oneOperator) then
					selectedLoadListOperators.add(oneOperator);
				endif;
			endforeach;
		endif;		
		
		//navra1 - MTN-33185 - 1th Nov 2024 - start
		// this method does these things -1)updates the voyageStage for each operator based on the comparison 
		//2) proceeds the voyage to the next stage based on the pause status
		//3)updates the voyage status depending upon a)if any operator has succeeded comparison and b)if the voyage is paused			
		self.updStgAndProceedBasedOnComp(voyageProgress, compareAgent, ediData, selectedLoadListOperators);
		//navra1 - MTN-33185 - 1th Nov 2024 - end
	endif;
	//navra1 - BUG 65924 - 30th Aug 2024 - end
	
	//navra1 - MTN-34348 - 13th March 2025 - start
	if self.myCurrentVoyage.isAutomaticProcess() and self.myLLCAgent &lt;&gt; null then
		view := self.VIEW_MATCHING;						//default view
		
		if self.myLLCAgent.allDiscrepancyTIs &lt;&gt; null and self.myLLCAgent.allDiscrepancyTIs.size() &gt; 0 then
			view := self.VIEW_DISCREPS;
			issueTypeCount := issueTypeCount + 1;			
		endif;
		
		if not viewSelected and self.myLLCAgent.allUnmatchedDBTIs &lt;&gt; null and self.myLLCAgent.allUnmatchedDBTIs.size() &gt; 0 then
			view := self.VIEW_NOT_IN_LIST;						//navra1 - MTN-34348/MTN-34467 - 25th Mar 2025
			issueTypeCount := issueTypeCount + 1;			
		endif;
		
		if self.myLLCAgent.allUnmatchedLLTIs &lt;&gt; null and self.myLLCAgent.allUnmatchedLLTIs.size() &gt; 0 then
			view := self.VIEW_NOT_IN_DB;						//navra1 - MTN-34348/MTN-34467 - 25th Mar 2025
			issueTypeCount := issueTypeCount + 1;			
		endif;
		
		//if there is more than 1 type of issue, default to matching cargo view - if there is only one type of issue show that view
		if issueTypeCount &gt; 1 then
			view := self.VIEW_MATCHING;
		endif;
		
		self.cmbView.text := view;		
		self.doShowView(view, _isRefresh);
	endif;	
	//navra1 - MTN-34348 - 13th March 2025 - end
	
epilog
	delete ignoreFields;
	delete operators;
	delete cmifMonitor;
	self.frmModalDialog.visible := false;
	delete opListNotOK;								//navra1 - BUG 65924 - 30th Aug 2024
	delete selectedLoadListOperators;				//navra1 - BUG 65924 - 30th Aug 2024
	delete tempListOperators;						//navra1 - BUG 65924 - 30th Aug 2024
end;</source>
