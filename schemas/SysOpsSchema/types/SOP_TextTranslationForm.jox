    <JadeMethod name="doPrintTranslations" id="105f43c0-773c-45f8-a6f8-e1b07406fa16">
        <source>doPrintTranslations(selectedLocale : CM_Locale; selectedCategories : XLAT_CategoryByConstantCategry; selectAllTranslations : Boolean) protected;

vars
	category			: XLAT_Category;
	translatableText	: XLAT_TranslatableText;
	report				: CMUI_TextTranslationPrint;
	now					: TimeStamp;
	source				: XLAT_TranslatableTextByNumber;
	results				: XLAT_SearchResults;
	tmpReport			: JadeReport;

begin
	app.mousePointer := MP_HOURGLASS;
	now := self.systemToLocalTime(app.actualTimeServer());	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support
	create tmpReport transient;
	app.printer.setMargins(Print_Landscape,5,5,5,5);
	app.printer.setReport(tmpReport);	//Capture for print preview.

	create report transient;
	
	report.fraDetail.width := app.printer.pageWidth - 10;
	report.tableDetail.width := app.printer.pageWidth - 10;
	
	report.initReportForLandscape(self.isDeveloperMode, selectedLocale);
	app.printer.setHeader(null);
	app.printer.setFooter(null);
	report.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.String;
	
	tmpReport.description := self.caption;
	report.picLogo.picture := app.getPicLogoPort; // The bitmap called rptlogo.bmp in reports/formats
	report.lblLocaleId.caption := selectedLocale.vLocaleIdAndDescription;

	foreach category in selectedCategories do
	
		report.printHeader(category);
		
		if selectAllTranslations then
			source := category.allTranslatableText;
		else
			results := self.myAgent.allSearchResults[category.constantCategoryName];
			if results &lt;&gt; null then
				source := results.allTranslatableText;
			endif;
		endif;
		if source = null then
			continue;
		endif;
			
		// Iterate the translatable text objects.
		foreach translatableText in source do
			report.addTableDetails(translatableText);
		endforeach; // translatableText

	endforeach;  // category

	app.printer.close;
	app.printPreview(tmpReport, true);

epilog
	delete report;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <access>protected</access>
        <Parameter name="selectedLocale" type="CM_Locale"/>
        <Parameter name="selectedCategories" type="XLAT_CategoryByConstantCategry"/>
        <Parameter name="selectAllTranslations" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRemoveFromTable" id="74270385-572f-4f89-bfce-a3deee90c384">
        <updating/>
        <source>doRemoveFromTable() updating, protected;

vars
	table 		: CM_TextTranslationTable;
