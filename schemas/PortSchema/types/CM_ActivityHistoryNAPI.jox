    <JadeMethod name="setForCreate" id="11077b73-9d88-40d1-ac7b-6c8c4593ab44">
        <updating/>
        <source>setForCreate(_proxy: CM_ActivityHistory) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/11/2020	jlgdap1		Initial creation TFS 50199 MTN Navis API - Audit Log
//
vars
	nApi : CM_ActivityHistoryNAPI;

begin
	inheritMethod(_proxy);
	
	nApi := _proxy.CM_ActivityHistoryNAPI;
	
	self.appName := nApi.appName;
	self.appVersion := nApi.appVersion;
	self.apiVersion := nApi.apiVersion;
	self.createdAt := nApi.createdAt;
	self.eventType := nApi.eventType;
	self.description := nApi.eventType;
	self.generalPayload := nApi.generalPayload;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_ActivityHistory"/>
    </JadeMethod>
