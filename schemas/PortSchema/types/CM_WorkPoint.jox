    <JadeMethod name="getDaysToCompleteWLE" id="b3dd7228-599d-40aa-9bd9-e67b678d0a00">
        <source>getDaysToCompleteWLE( _wle : CM_WorkListEntry ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2018	jlgndl1	Initial creation	TFS 40048

*/

vars

	ti : CM_TrackedItem;
	wpRate : CM_WorkPointCargoRates;
	trsfrType : CM_VoyageJobTransferType;
	notUsedTi : CM_TrackedItem;

begin

	ti := _wle.myTrackedItem;
	if ti = null then
		return 0.0;
	endif;
	
	wpRate := self.getDefinedTargetRate( _wle, trsfrType, notUsedTi );
	
	if wpRate = null then
		return 0.0;
	endif;
	
	return wpRate.getDaysToComplete( _wle, 0, false );
	
	
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDischargeLane" id="01ba8b51-737c-4eaf-89d7-f92f01d8b26e">
        <source>getDefaultDischargeLane( _raiseError : Boolean ): CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	cont : CM_LocationsController;

begin

/*	if self.myWorkPointInterchangeArea = null then
		return null;
	endif;
	
	return self.myWorkPointInterchangeArea.getDefaultLane; */
	
	//13 Jun 2012	NDL	Par 29621
	if self.myWorkPointInterchangeArea &lt;&gt; null then
		cont := self.myWorkPointInterchangeArea.getDefaultLane;
	endif;
	
	//if cont = null then	
	if cont = null and _raiseError then	//16 Mar 2016	NDL	TFS 1593
		app.raiseCMException1(Lanes_inter_area_inter_area_as,self.code, null, null);
	endif;
	
	return cont;
	
	
epilog

end;</source>
        <Parameter name="_raiseError" type="Boolean"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getDefinedTargetRate" id="10ccd589-168b-4307-ba6b-8c4f7bc0a648">
        <source>getDefinedTargetRate( _obj : CM_Object; _newTrsfrType : CM_VoyageJobTransferType; _ti : CM_TrackedItem output ):CM_WorkPointCargoRates;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2018	jlgndl1	Initial creation	TFS 37437
14 Jun 2018	NDL	TFS 39167

*/

constants

	Job_Type_Default : Integer = -1;
	Tsfr_Type_Default : Integer = 1;  // RORO 

vars

	voyageJob : CM_VoyageJob;
	cargoType : CM_CargoType;
	product : CM_Product;
	jobType : Integer;
	transferType : Integer;
	rate : CM_WorkPointCargoRates;
	useDefaultJobOnly : Boolean;
	
	wodCargoRequest : CM_WodCargoRequest;
	voyageWle : CM_VoyageWLE;

begin

	transferType := Tsfr_Type_Default;

	if _obj &lt;&gt; null and _obj.isKindOf( CM_VoyageJobSheet ) then
		if not _obj.CM_VoyageJobSheet.allJobsByJobNum.isEmpty then
			voyageJob := _obj.CM_VoyageJobSheet.allJobsByJobNum.first;
			jobType := Job_Type_Default;
			useDefaultJobOnly := true;
		endif;
	elseif _obj &lt;&gt; null and _obj.isKindOf( CM_VoyageJob ) then
		voyageJob := _obj.CM_VoyageJob;
	elseif _obj &lt;&gt; null and _obj.isKindOf( CM_WodCargoRequest ) then
		voyageJob := null;
		wodCargoRequest := _obj.CM_WodCargoRequest;
	elseif _obj &lt;&gt; null and _obj.isKindOf( CM_VoyageWLE ) then	//03 Aug 2018	NDL	TFS 40048
		voyageJob := null;
		wodCargoRequest := null;
		voyageWle := _obj.CM_VoyageWLE;
	endif;
	
	if voyageJob &lt;&gt; null then
		transferType := voyageJob.getTransferType;
		if not voyageJob.allReceiveTrackedItems.isEmpty then
			_ti := voyageJob.allReceiveTrackedItems.first;
			if not useDefaultJobOnly then
				jobType := JOB_TYPE_DISCHARGE;
			endif;
		elseif not voyageJob.allReleaseTrackeditems.isEmpty then
			_ti := voyageJob.allReleaseTrackeditems.first;
			if not useDefaultJobOnly then
				jobType := JOB_TYPE_LOAD;
			endif;
		elseif not voyageJob.allSOBTrackedItems.isEmpty then
			_ti := voyageJob.allSOBTrackedItems.first;
			if not useDefaultJobOnly then
				jobType := JOB_TYPE_SOB;
			endif;
		endif;
		
	elseif wodCargoRequest &lt;&gt; null then
		cargoType := wodCargoRequest.myCargoType;
		product := wodCargoRequest.myCargoSubType;
		transferType := wodCargoRequest.transferType;
		if wodCargoRequest.imexStatus = TI_IMEX_STATUS_IMPORT then
			jobType := JOB_TYPE_DISCHARGE;
		elseif wodCargoRequest.imexStatus = TI_IMEX_STATUS_EXPORT then
			jobType := JOB_TYPE_LOAD;
		else
			jobType := Job_Type_Default;
			useDefaultJobOnly := true;
		endif;
	
	elseif voyageWle &lt;&gt; null then	//03 Aug 2018	NDL	TFS 40048
		_ti := voyageWle.myTrackedItem;
		transferType := voyageWle.job.CM_VoyageJob.getTransferType;
		if voyageWle.isReceipt then
			jobType := JOB_TYPE_DISCHARGE;
		elseif voyageWle.isSOB then
			jobType := JOB_TYPE_SOB;
		else
			jobType := JOB_TYPE_LOAD;
		endif;
	endif;
	
	if _newTrsfrType &lt;&gt; null then
		transferType := _newTrsfrType.id;
	endif;
	
	
	if _ti &lt;&gt; null then
		cargoType := _ti.myCargoType;
		product := _ti.myProduct;
	endif;
	
	if cargoType &lt;&gt; null then
		//Look for an exact match first
		rate := self.allWorkPointRates.getAtKey( cargoType, product, self, jobType, transferType );
		if rate = null and not useDefaultJobOnly then
			//try with a non specific job type
			rate := self.allWorkPointRates.getAtKey( cargoType, product, self, Job_Type_Default, transferType );
		endif;
		if rate = null then
			//try with a non specific product
			rate := self.allWorkPointRates.getAtKey( cargoType, null, self, jobType, transferType );
		endif;
		if rate = null and not useDefaultJobOnly then
			//try with a non specific product AND non specific job type
			rate := self.allWorkPointRates.getAtKey( cargoType, null, self, Job_Type_Default, transferType );
		endif;
	endif;
	
	return rate;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_newTrsfrType" type="CM_VoyageJobTransferType"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="output"/>
        <ReturnType type="CM_WorkPointCargoRates"/>
    </JadeMethod>
    <JadeMethod name="getDefinedTargetRateStr" id="31d4588c-194c-41f6-bfe0-12cb1d3a44a7">
        <source>getDefinedTargetRateStr( _obj : CM_Object ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

	rate : CM_WorkPointCargoRates;
	ti : CM_TrackedItem;

begin

	rate := getDefinedTargetRate( _obj, null, ti );
	
	if rate &lt;&gt; null then
		return rate.getTargetRateStr();
	endif;
	
	//default behaviour when no rate found
	return self.targetRatePHLM.asStringJMT;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefinedTargetRateWeight" id="c08c3722-5c6d-40ba-a334-04b30441a61d">
        <source>getDefinedTargetRateWeight( _obj : CM_Object ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

	rate : CM_WorkPointCargoRates;
	ti : CM_TrackedItem;

begin

	rate := getDefinedTargetRate( _obj, null, ti );
	
	if rate &lt;&gt; null then
		if rate.targetRatePHWeight &gt; 0 then
			return rate.targetRatePHWeight.Integer;
		elseif rate.targetRatePHVolume &gt; 0 and ti &lt;&gt; null then
			return ( rate.targetRatePHVolume * ti.getDensity ).Integer;
		elseif rate.targetRatePHQuantity &gt; 0 and ti &lt;&gt; null then
			return ( rate.targetRatePHQuantity * ti.totalWeight ).Integer;
		endif;
	endif;
	
	//default behaviour when no rate found
	return self.targetRatePHWeight;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
