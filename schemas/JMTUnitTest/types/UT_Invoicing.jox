    <JadeMethod name="tInvTypeLineMapping" id="53f64d86-1422-4646-934c-3fe91e914abc">
        <source>tInvTypeLineMapping();
/*

Purpose:			Unit tests for CR 54566

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2022	navpw1	Initial creation TFS: 54571

*/

constants
	Ref							: String = UT_DSL.TFS54571;
	UT_Debtor					: String = "UT_" &amp; Ref &amp; "_Debtor";
	UT_Debtor2					: String = "UT_" &amp; Ref &amp; "_Debtor2";
	UT_InvoiceDesc				: String = "UT_" &amp; Ref &amp; "_InvoiceDesc1";
	UT_InvoiceDesc2				: String = "UT_" &amp; Ref &amp; "_InvoiceDesc2";
	UT_InvoiceDesc3				: String = "UT_" &amp; Ref &amp; "_InvoiceDesc3";
	UT_InvoiceLineDesc			: String = "UT_" &amp; Ref &amp; "_InvoiceLnDesc1";
	UT_InvoiceLineDesc2			: String = "UT_" &amp; Ref &amp; "_InvoiceLnDesc2";
	UT_ServiceRemarks			: String = "UT_" &amp; Ref;
	UT_CalculationTypeCode		: String = "UT_" &amp; Ref;
	UT_MeasurementTypeShortName : String = "UT_" &amp; Ref;
	UT_MeasurementTypeName		: String = "UT_" &amp; Ref;
	UT_GlCode					: String = "UT_" &amp; Ref &amp; "_GL2";
	UT_GlRemarks				: String = "UT_" &amp; Ref &amp; " GL Code";
	
vars
	pxyMapping,
	realMapping			: CM_InvoiceLineDescMapping;
	invoiceType,
	invoiceType2,
	invoiceType3		: CM_InvoiceDesc;
	invoiceLnType,
	invoiceLnType2		: CM_InvoiceLineDesc;
	debtor,
	debtor2				: CM_Debtor;
	mesType				: CM_MeasurementType;
	calcType			: CM_CalculationType;
	glCode 				: CM_GLCode;
	service,
	service2			: CM_Service;
	services			: CM_ServiceByNameDict;
	title				: String;
	
	pxyCreateMappings,
	realCreateMappings,
	pxyUpdateMappings,
	pxyDeleteMappings	: CM_InvLineDescMapByDebtorLType;
	
	terminal : CM_Terminal;
	bank : CM_Bank;
	
begin
	/*
	** Cleanup
	*/
	debtor := app.myRoot.myRootCompany.debtors[UT_Debtor];
	self.deleteDebtor(debtor);
	
	debtor2 := app.myRoot.myRootCompany.debtors[UT_Debtor2];
	self.deleteDebtor(debtor2);
	
	self.deleteInvoiceType(UT_InvoiceDesc);
	self.deleteInvoiceType(UT_InvoiceDesc2);
	self.deleteInvoiceType(UT_InvoiceDesc3);
	
	self.deleteInvoiceLineType(UT_InvoiceLineDesc, FORCED_ERASE);
	self.deleteInvoiceLineType(UT_InvoiceLineDesc2, FORCED_ERASE);
	
	self.deleteInvoiceService(UT_InvoiceLineDesc, FORCED_ERASE);
	self.deleteInvoiceService(UT_InvoiceLineDesc2, FORCED_ERASE);
	
	self.deleteCalculationType(UT_CalculationTypeCode, NORMAL_ERASE);
	
	self.deleteMeasurementType(UT_MeasurementTypeShortName);
	
	/*
	** Global Setup
	*/
	create services transient;
	
	debtor := self.addDebtor(UT_Debtor, PaymentType_None).CM_Debtor;
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(debtor, "Debtor");
	
	debtor2 := self.addDebtor(UT_Debtor2, PaymentType_None).CM_Debtor;
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(debtor2, "Debtor2");
	
	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, UT_MeasurementTypeShortName, Type_Weight, UT_MeasurementTypeName);
	self.assertNotNullMsg(mesType, "Measurement type " &amp; UT_MeasurementTypeName &amp; " not created");
	
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, UT_CalculationTypeCode, UT_CalculationTypeCode, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "UNITTEST", true, false, false, null, null, null, mesType);
	self.assertNotNullMsg(calcType, "Calculation type " &amp; UT_CalculationTypeCode &amp; " not created");
	
	self.deleteInvoiceGLCode(UT_GlCode);
	glCode := self.createInvoiceGLCode(UT_GlCode, UT_GlRemarks);
	service := self.createInvoiceService(UT_InvoiceLineDesc, UT_ServiceRemarks, calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service);
	
	invoiceType	:= self.createInvoiceType(UT_InvoiceDesc, InvoiceTypeGeneral);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(invoiceType, "Invoice Type");
	
	invoiceType2 := self.createInvoiceType(UT_InvoiceDesc2, InvoiceTypeGeneral);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(invoiceType, "Invoice Type2");
	
	invoiceType3 := self.createInvoiceType(UT_InvoiceDesc3, InvoiceTypeGeneral);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(invoiceType, "Invoice Type3");
	
	invoiceLnType := self.createInvoiceLineType(UT_InvoiceLineDesc, calcType, invoiceType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(invoiceLnType, "Invoice Line Type");
	
	services.clear();
	
	service2 := self.createInvoiceService(UT_InvoiceLineDesc2, UT_ServiceRemarks, calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service2);
	
	invoiceLnType2 := self.createInvoiceLineType(UT_InvoiceLineDesc2, calcType, invoiceType2, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(invoiceLnType2, "Invoice Line Type2");
	
	create pxyCreateMappings transient;
	create pxyUpdateMappings transient;
	create pxyDeleteMappings transient;
	
	terminal := self.getTerminal();
	bank := terminal.companies["DFBU"];
	
	/*
	############################################## Start Test 1 ##############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	
	Tests:
	1) Tests that trx saves an Invoice Line Type Mapping
	
	*/
	
	/*
	** Setup
	*/
	
	
	/*
	** Run
	*/
	create pxyMapping transient;
	pxyMapping.setProxy(self.myBank, debtor.CM_Debtor, invoiceLnType, invoiceType);
	app.myTrxCA.trxCreateInvoiceLineDescMap(pxyMapping, realMapping, app.myPassport);
	
	/*
	** Assert
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(realMapping);
	
	title := "Invoice Line Type Mapping - Test 1 - Single Creation - ";
	
	self.assertTrueMsg(realMapping.myDebtor &lt;&gt; null, title &amp; "myDebtor Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(realMapping.myInvoiceLineDesc &lt;&gt; null, title &amp; "myInvoiceLineDesc Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(realMapping.myInvoiceType &lt;&gt; null, title &amp; "myInvoiceType Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myDebtor.name = UT_Debtor, title &amp; "myDebtor Expected: '" &amp; UT_Debtor &amp; "' | Actual: '" &amp; realMapping.myDebtor.name &amp; "'");
	self.assertTrueMsg(realMapping.myInvoiceLineDesc.narration = UT_InvoiceLineDesc, title &amp; "myInvoiceLineDesc Expected: '" &amp; UT_InvoiceLineDesc &amp; "' | Actual: '" &amp; realMapping.myInvoiceLineDesc.narration &amp; "'");
	self.assertTrueMsg(realMapping.myInvoiceType.description = UT_InvoiceDesc, title &amp; "myInvoiceType Expected: '" &amp; UT_InvoiceDesc &amp; "' | Actual: '" &amp; realMapping.myInvoiceType.description &amp; "'");
	
	/*
	############################################### End Test 1 ###############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	*/
	
	/*
	############################################## Start Test 2 ##############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	
	Tests:
	1) Tests that trx updates an Invoice Line Type Mapping
	
	*/
	
	/*
	** Setup
	*/
	delete pxyMapping;
	pxyMapping := null;
	
	/*
	** Run
	*/
	pxyMapping := app.createUpdateProxy(realMapping).CM_InvoiceLineDescMapping;
	pxyMapping.setProxy(self.myBank, debtor.CM_Debtor, invoiceLnType, invoiceType2);
	app.myTrxUA.trxUpdateInvoiceLineDescMap(pxyMapping, app.myPassport);
	
	/*
	** Assert
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(realMapping);
	
	title := "Invoice Line Type Mapping - Test 1 - Single Update - ";
	
	self.assertTrueMsg(realMapping.myDebtor &lt;&gt; null, title &amp; "myDebtor Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(realMapping.myInvoiceLineDesc &lt;&gt; null, title &amp; "myInvoiceLineDesc Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(realMapping.myInvoiceType &lt;&gt; null, title &amp; "myInvoiceType Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myDebtor.name = UT_Debtor, title &amp; "myDebtor Expected: '" &amp; UT_Debtor &amp; "' | Actual: '" &amp; realMapping.myDebtor.name &amp; "'");
	self.assertTrueMsg(realMapping.myInvoiceLineDesc.narration = UT_InvoiceLineDesc, title &amp; "myInvoiceLineDesc Expected: '" &amp; UT_InvoiceLineDesc &amp; "' | Actual: '" &amp; realMapping.myInvoiceLineDesc.narration &amp; "'");
	self.assertTrueMsg(realMapping.myInvoiceType.description = UT_InvoiceDesc2, title &amp; "myInvoiceType Expected: '" &amp; UT_InvoiceDesc2 &amp; "' | Actual: '" &amp; realMapping.myInvoiceType.description &amp; "'");
	
	/*
	############################################### End Test 2 ###############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	*/
	
	/*
	############################################## Start Test 3 ##############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	
	Tests:
	1) Tests that trx deletes an Invoice Line Type Mapping
	
	*/
	
	/*
	** Setup
	*/
	
	/*
	** Run
	*/
	app.myPassport.setWarningsIgnored(true);
	app.myTrxDA.trxDeleteInvoiceLineDescMap(realMapping, app.myPassport);
	app.myPassport.setWarningsIgnored(false);
	
	/*
	** Assert
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	title := "Invoice Line Type Mapping - Test 1 - Single Delete - ";
	self.assertFalseMsg(app.isValidObject(realMapping), title &amp; "realMapping not deleted");
	
	/*
	############################################### End Test 3 ###############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	*/
	
	/*
	############################################## Start Test 4 ##############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	
	Tests:
	1) Tests that trx creates bulk Invoice Line Type Mappings
	
	*/
	
	/*
	** Setup
	*/
	delete pxyMapping;
	pxyMapping := null;
	
	//Clear mappings collection
	pxyCreateMappings.purge();
	pxyUpdateMappings.purge();
	pxyDeleteMappings.purge();
	
	//Create 1st Mapping add to collection
	create pxyMapping transient;
	pxyMapping.setProxy(self.myBank, debtor.CM_Debtor, invoiceLnType, invoiceType);
	pxyCreateMappings.add(pxyMapping);
	
	//Create 2nd Mapping add to collection
	create pxyMapping transient;
	pxyMapping.setProxy(self.myBank, debtor2.CM_Debtor, invoiceLnType2, invoiceType2);
	pxyCreateMappings.add(pxyMapping);
	
	/*
	** Run
	*/
	app.myTrxCA.trxCreateBulkInvLineDescMap(pxyCreateMappings, pxyUpdateMappings, pxyDeleteMappings, realCreateMappings, app.myPassport);
	
	/*
	** Assert
	*/
	
	//Validate realCreateMappings make sure not null, not empty, has 2 items and check each item is setup correctly
	self.assertNoTrxErrorsOrWarnings();
	
	title := "Invoice Line Type Mapping - Test 4 - Bulk Create - ";
	
	self.assertTrueMsg(realCreateMappings &lt;&gt; null, title &amp; "realCreateMappings Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realCreateMappings.isNotEmpty, title &amp; "realCreateMappings Expected: 'Not Empty' | Actual: 'Empty'");
	
	self.assertTrueMsg(realCreateMappings.size = 2, title &amp; "realCreateMappings size Expected: '2' | Actual: '" &amp; realCreateMappings.size.asStringJMT() &amp; "'");
	
	//Grab 1st Invoice Line Mapping based on debtor and line
	realMapping := realCreateMappings.getAtKeyGeq(debtor, invoiceLnType, null);
	
	self.assertTrueMsg(realMapping &lt;&gt; null, title &amp; "realMapping Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(not realMapping.isTransient, title &amp; "realMapping Expected: 'non transient' | Actual: 'transient'");
	
	self.assertTrueMsg(realMapping.myDebtor &lt;&gt; null, title &amp; "myDebtor Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myDebtor.name = UT_Debtor, title &amp; "myInvoiceType Expected: '" &amp; UT_Debtor &amp; "' | Actual: '" &amp; realMapping.myDebtor.name &amp; "'");
	
	self.assertTrueMsg(realMapping.myInvoiceLineDesc &lt;&gt; null, title &amp; "myInvoiceLineDesc Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myInvoiceLineDesc.narration = UT_InvoiceLineDesc, title &amp; "myInvoiceLineDesc Expected: '" &amp; UT_InvoiceLineDesc &amp; "' | Actual: '" &amp; realMapping.myInvoiceLineDesc.narration &amp; "'");
	
	self.assertTrueMsg(realMapping.myInvoiceType &lt;&gt; null, title &amp; "myInvoiceType Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myInvoiceType.description = UT_InvoiceDesc, title &amp; "myInvoiceType Expected: '" &amp; UT_InvoiceDesc &amp; "' | Actual: '" &amp; realMapping.myInvoiceType.description &amp; "'");
	
	//Grab 2nd Invoice Line Mapping based on debtor and line
	realMapping := realCreateMappings.getAtKeyGeq(debtor2, invoiceLnType2, null);
	
	self.assertTrueMsg(realMapping &lt;&gt; null, title &amp; "realMapping Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(not realMapping.isTransient, title &amp; "realMapping Expected: 'non transient' | Actual: 'transient'");
	
	self.assertTrueMsg(realMapping.myDebtor &lt;&gt; null, title &amp; "myDebtor Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myDebtor.name = UT_Debtor2, title &amp; "myInvoiceType Expected: '" &amp; UT_Debtor2 &amp; "' | Actual: '" &amp; realMapping.myDebtor.name &amp; "'");
	
	self.assertTrueMsg(realMapping.myInvoiceLineDesc &lt;&gt; null, title &amp; "myInvoiceLineDesc Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myInvoiceLineDesc.narration = UT_InvoiceLineDesc2, title &amp; "myInvoiceLineDesc Expected: '" &amp; UT_InvoiceLineDesc2 &amp; "' | Actual: '" &amp; realMapping.myInvoiceLineDesc.narration &amp; "'");
	
	self.assertTrueMsg(realMapping.myInvoiceType &lt;&gt; null, title &amp; "myInvoiceType Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myInvoiceType.description = UT_InvoiceDesc2, title &amp; "myInvoiceType Expected: '" &amp; UT_InvoiceDesc2 &amp; "' | Actual: '" &amp; realMapping.myInvoiceType.description &amp; "'");
	
	/*
	############################################### End Test 4 ###############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	*/
	
	/*
	############################################## Start Test 5 ##############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	
	Tests:
	1) Tests that trx updates bulk Invoice Line Type Mappings
	
	*/
	
	/*
	** Setup
	*/
	title := "Invoice Line Type Mapping - Test 5 - Bulk Update - Setup - ";
	
	delete realCreateMappings;
	
	//Purge Collections
	pxyCreateMappings.purge();
	pxyUpdateMappings.purge();
	pxyDeleteMappings.purge();
	
	//Find real object created in previous test
	realMapping := bank.allInvoiceLineDescMappings.getAtKeyGeq(debtor, invoiceLnType, null);
	
	self.assertTrueMsg(realMapping &lt;&gt; null, title &amp; "realMapping Expected: 'Not null' | Actual: 'null'");
	
	//Create proxy of it
	pxyMapping := app.createUpdateProxy(realMapping).CM_InvoiceLineDescMapping;
	
	//update the proxy
	pxyMapping.setPropertyValue(CM_InvoiceLineDescMapping::myInvoiceType.name, invoiceType3);
	
	//Add to the collection
	pxyUpdateMappings.add(pxyMapping);
	
	//Find real object created in previous test
	realMapping := bank.allInvoiceLineDescMappings.getAtKeyGeq(debtor2, invoiceLnType2, null);
	
	self.assertTrueMsg(realMapping &lt;&gt; null, title &amp; "realMapping Expected: 'Not null' | Actual: 'null'");
	
	//Create proxy of it
	pxyMapping := app.createUpdateProxy(realMapping).CM_InvoiceLineDescMapping;
	
	//update the proxy
	pxyMapping.setPropertyValue(CM_InvoiceLineDescMapping::myInvoiceType.name, invoiceType3);
	
	//Add to the collection
	pxyUpdateMappings.add(pxyMapping);
	
	/*
	** Run
	*/
	//Run the bulk trx
	app.myTrxCA.trxCreateBulkInvLineDescMap(pxyCreateMappings, pxyUpdateMappings, pxyDeleteMappings, realCreateMappings, app.myPassport);
	
	/*
	** Assert
	*/
	//Validate real objects make sure they still exist, check each item is setup correctly
	self.assertNoTrxErrorsOrWarnings();
	
	title := "Invoice Line Type Mapping - Test 5 - Bulk Update - ";
	
	//Grab 1st Invoice Line Mapping based on debtor and line
	realMapping := bank.allInvoiceLineDescMappings.getAtKeyGeq(debtor, invoiceLnType, null);
	
	self.assertTrueMsg(realMapping &lt;&gt; null, title &amp; "realMapping Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(not realMapping.isTransient, title &amp; "realMapping Expected: 'non transient' | Actual: 'transient'");
	
	self.assertTrueMsg(realMapping.myDebtor &lt;&gt; null, title &amp; "myDebtor Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myDebtor.name = UT_Debtor, title &amp; "myInvoiceType Expected: '" &amp; UT_Debtor &amp; "' | Actual: '" &amp; realMapping.myDebtor.name &amp; "'");
	
	self.assertTrueMsg(realMapping.myInvoiceLineDesc &lt;&gt; null, title &amp; "myInvoiceLineDesc Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myInvoiceLineDesc.narration = UT_InvoiceLineDesc, title &amp; "myInvoiceLineDesc Expected: '" &amp; UT_InvoiceLineDesc &amp; "' | Actual: '" &amp; realMapping.myInvoiceLineDesc.narration &amp; "'");
	
	self.assertTrueMsg(realMapping.myInvoiceType &lt;&gt; null, title &amp; "myInvoiceType Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myInvoiceType.description = UT_InvoiceDesc3, title &amp; "myInvoiceType Expected: '" &amp; UT_InvoiceDesc3 &amp; "' | Actual: '" &amp; realMapping.myInvoiceType.description &amp; "'");
	
	//Grab 2nd Invoice Line Mapping based on debtor and line
	realMapping := bank.allInvoiceLineDescMappings.getAtKeyGeq(debtor2, invoiceLnType2, null);
	
	self.assertTrueMsg(realMapping &lt;&gt; null, title &amp; "realMapping Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(not realMapping.isTransient, title &amp; "realMapping Expected: 'non transient' | Actual: 'transient'");
	
	self.assertTrueMsg(realMapping.myDebtor &lt;&gt; null, title &amp; "myDebtor Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myDebtor.name = UT_Debtor2, title &amp; "myInvoiceType Expected: '" &amp; UT_Debtor2 &amp; "' | Actual: '" &amp; realMapping.myDebtor.name &amp; "'");
	
	self.assertTrueMsg(realMapping.myInvoiceLineDesc &lt;&gt; null, title &amp; "myInvoiceLineDesc Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myInvoiceLineDesc.narration = UT_InvoiceLineDesc2, title &amp; "myInvoiceLineDesc Expected: '" &amp; UT_InvoiceLineDesc2 &amp; "' | Actual: '" &amp; realMapping.myInvoiceLineDesc.narration &amp; "'");
	
	self.assertTrueMsg(realMapping.myInvoiceType &lt;&gt; null, title &amp; "myInvoiceType Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realMapping.myInvoiceType.description = UT_InvoiceDesc3, title &amp; "myInvoiceType Expected: '" &amp; UT_InvoiceDesc3 &amp; "' | Actual: '" &amp; realMapping.myInvoiceType.description &amp; "'");
	
	/*
	############################################### End Test 5 ###############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	*/
	
	/*
	############################################## Start Test 6 ##############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	
	Tests:
	1) Tests that trx deletes bulk Invoice Line Type Mappings
	
	*/
	
	/*
	** Setup
	*/
	title := "Invoice Line Type Mapping - Test 5 - Bulk Update - Setup - ";
	
	delete realCreateMappings;
	
	//Purge Collections
	pxyCreateMappings.purge();
	pxyUpdateMappings.purge();
	pxyDeleteMappings.purge();
	
	//Find real object created in previous test
	realMapping := bank.allInvoiceLineDescMappings.getAtKeyGeq(debtor, invoiceLnType, null);
	
	self.assertTrueMsg(realMapping &lt;&gt; null, title &amp; "realMapping Expected: 'Not null' | Actual: 'null'");
	
	//Add to the collection
	pxyDeleteMappings.add(realMapping);
	
	//Find real object created in previous test
	realMapping := bank.allInvoiceLineDescMappings.getAtKeyGeq(debtor2, invoiceLnType2, null);
	
	self.assertTrueMsg(realMapping &lt;&gt; null, title &amp; "realMapping Expected: 'Not null' | Actual: 'null'");
	
	//Add to the collection
	pxyDeleteMappings.add(realMapping);
	
	app.myPassport.setWarningsIgnored(true);
	
	/*
	** Run
	*/
	//Run the bulk trx
	app.myTrxCA.trxCreateBulkInvLineDescMap(pxyCreateMappings, pxyUpdateMappings, pxyDeleteMappings, realCreateMappings, app.myPassport);
	
	/*
	** Assert
	*/
	//Validate real objects no longer exist
	self.assertNoTrxErrorsOrWarnings();
	
	title := "Invoice Line Type Mapping - Test 5 - Bulk Update - ";
	
	//Grab 1st Invoice Line Mapping based on debtor and line
	realMapping := bank.allInvoiceLineDescMappings.getAtKeyGeq(debtor, invoiceLnType, null);
	
	self.assertTrueMsg(realMapping = null, title &amp; "realMapping Expected: 'null' | Actual: 'not null'");
	
	//Grab 2nd Invoice Line Mapping based on debtor and line
	realMapping := bank.allInvoiceLineDescMappings.getAtKeyGeq(debtor2, invoiceLnType2, null);
	
	self.assertTrueMsg(realMapping = null, title &amp; "realMapping Expected: 'null' | Actual: 'not null'");
	
	/*
	############################################### End Test 6 ###############################################
	################################# 53978.050 Invoice Line Mapping updates #################################
	*/
	
epilog
	if pxyMapping &lt;&gt; null and global.isValidObject(pxyMapping) then
		delete pxyMapping;
	endif;
	
	if pxyCreateMappings &lt;&gt; null and pxyCreateMappings.isNotEmpty then
		pxyCreateMappings.purge;
	endif;
	
	if pxyUpdateMappings &lt;&gt; null and pxyUpdateMappings.isNotEmpty then
		pxyUpdateMappings.purge;
	endif;
	
	delete pxyCreateMappings;
	delete pxyUpdateMappings;
	delete pxyDeleteMappings;
	delete realCreateMappings;
	
	delete services;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvTypeSurcharges" id="a9c05e6e-6903-4dfe-a996-c3f18317ab29">
        <source>tInvTypeSurcharges();
/*

Purpose:			Unit tests for CR 54565

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
02 December 2022	navpw1	Initial creation TFS: 54571

*/

constants
	Ref							: String = UT_DSL.TFS54571;
	UT_Debtor					: String = "UT_" &amp; Ref &amp; "_DebtorSur";
	UT_InvoiceDesc				: String = "UT_" &amp; Ref &amp; "_InvoiceDescSur";
	UT_InvoiceLineDesc			: String = "UT_" &amp; Ref &amp; "_InvoiceLnDescSur";
	UT_InvoiceLineDescBB		: String = "UT_" &amp; Ref &amp; "_InvoiceLnDescSurBB";
	UT_InvoiceLineDescSur		: String = "UT_" &amp; Ref &amp; "_InvoiceLnDescSurcharge Line";
	UT_ServiceRemarks			: String = "UT_" &amp; Ref;
	UT_CalculationTypeCode		: String = "UT_" &amp; Ref;
	UT_CalculationTypeCodeBB	: String = "UT_" &amp; Ref &amp; "2";
	UT_GlCode					: String = "UT_" &amp; Ref &amp; "_GL";
	UT_GlRemarks				: String = "UT_" &amp; Ref &amp; " GL Code";
	UT_VesselId					: String = "UT_" &amp; Ref &amp; "_VESS00001";
	UT_VesselHoldsId			: String = "UT" &amp; Ref &amp; "VESSH1";
	UT_VoyageId					: String = "UT_" &amp; Ref &amp; "_VOY00001";
	UT_VoyageHoldsId			: String = "UT" &amp; Ref &amp; "VOYH1";
	UT_TransactionMapId			: String = "UT_" &amp; Ref;
	UT_CargoCommodity			: String = "FCL";
	UT_CargoCommodityBB			: String = "CLAY";
	UT_VesselDischLocn 			: String = "090488";
	UT_VesselDischLocn2 		: String = "090486";
	UT_VesselDischLocn3 		: String = "090484";
	UT_VesselHoldsDischLocn1 	: String = "0101";
	UT_VesselHoldsDischLocn2 	: String = "0102";
	UT_IsoType					: String = "2200";
	UT_TrackedItem1				: String = "UT" &amp; Ref &amp; "01";
	UT_TrackedItem2				: String = "UT" &amp; Ref &amp; "02";
	UT_TrackedItem3				: String = "UT" &amp; Ref &amp; "03";
	UT_TrackedItem4				: String = "UT" &amp; Ref &amp; "04";
	UT_TrackedItem5				: String = "UT" &amp; Ref &amp; "05";
	UT_BlockStackId 			: String = Ref &amp; "2B1";
	NullMSG						: String = " Expected: 'not null' | Actual: 'null'";
	UT_OperatorCode				: String = "UTSU";
	UT_CargoTypeCont			: String = "CONT";
	UT_CargoTypeBB				: String = "UT_BB_GC";
	
vars
	terminal					: CM_Terminal;
	bank						: CM_Bank;
	rootDebtor,
	debtor						: CM_Debtor;
	calcType,
	calcTypeBb					: CM_CalculationType;
	glCode 						: CM_GLCode;
	service,
	serviceBb					: CM_Service;
	services					: CM_ServiceByNameDict;
	invoiceType					: CM_InvoiceDesc;
	surchargesAndExemptions 	: CM_InvoiceTypeSurchargeExempt;
	invoiceLnType,
	invoiceLnTypeBb				: CM_InvoiceLineDesc;
	fileContent,
	fileName,
	title						: String;
	cargoMap					: CM_TranMap;
	operator					: CM_Operator;
	cargoType,
	cargoTypeBb					: CM_CargoBOLType;
	commodity,
	commodityBb					: CM_Commodity;
	vessel,
	vesselHolds					: CM_Vessel;
	voyage,
	voyageHolds					: CM_Voyage;
	
	realInvTypeDebtorSeparation	: CM_InvTypeDebtorSeparation;
	
	realSurchargeRate			: CM_InvTypeCargoMultiSurcharge;
	allCargoTypes				: CM_CargoTypeSet;
	allCommodities				: CM_CommoditySet;
	allDebtors					: CM_DebtorSet;
	allInvLineDescs				: CM_InvoiceLineDescSet;
	surInvLineType				: CM_InvoiceLineDesc;
	validFrom,
	validTo						: TimeStamp;
	invoice						: CM_Invoice;
	vesselLocations 			: StringArray;
	aPort 						: CM_Port;
	theSlot 					: CM_LocationsController;
	foundheight 				: Integer;
	ti1, ti2, ti3, ti4, ti5		: CM_TrackedItem;
	blockStack					: CM_BlockStack;
	tiSet						: CM_TISet;
	surchargeLines				: CM_InvoiceLineSet;
	surchargeMultiSet			: CM_InvTypeCargoMultSchByFromDT;
	
begin
	/*
	** Cleanup
	*/
	//delete tracked items
	self.deleteContainer(UT_TrackedItem1);
	self.deleteContainer(UT_TrackedItem2);
	self.deleteContainer(UT_TrackedItem3);
	
	// delete voyage
	self.deleteVoyage(UT_VoyageId);
	self.deleteVoyage(UT_VoyageHoldsId);
	
	//Delete Vessel
	self.deleteVessel(UT_VesselId);
	self.deleteVessel(UT_VesselHoldsId);
	
	//Delete Transaction Map
	self.deleteInvoiceTransactionMap(1, UT_TransactionMapId);
	
	debtor := app.myRoot.myRootCompany.debtors[UT_Debtor];
	self.deleteDebtor(debtor);
	
	self.deleteInvoiceType(UT_InvoiceDesc);
	
	self.deleteInvoiceLineType(UT_InvoiceLineDesc, FORCED_ERASE);
	self.deleteInvoiceLineType(UT_InvoiceLineDescSur, FORCED_ERASE);
	self.deleteInvoiceLineType(UT_InvoiceLineDescBB, FORCED_ERASE);
	
	self.deleteInvoiceService(UT_InvoiceLineDesc, FORCED_ERASE);
	self.deleteInvoiceService(UT_InvoiceLineDescBB, FORCED_ERASE);
	
	self.deleteCalculationType(UT_CalculationTypeCode, NORMAL_ERASE);
	self.deleteCalculationType(UT_CalculationTypeCodeBB, NORMAL_ERASE);
	
	//Terminal
	self.deleteTerminalArea(UT_BlockStackId);
	
	self.deleteOperator(UT_OperatorCode);
	
	/*
	** Global Setup
	*/
	title := "Invoice Surcharges - Global Setup - ";
	
	create services transient;
	create vesselLocations transient;
	create tiSet transient;
	create surchargeLines transient;
	create surchargeMultiSet transient;
	
	terminal := self.getTerminal();
	self.assertTrueMsg(terminal &lt;&gt; null, title &amp; "terminal" &amp; NullMSG);
	
	bank := terminal.companies["DFBU"];
	self.assertTrueMsg(bank &lt;&gt; null, title &amp; "bank" &amp; NullMSG);
	
	rootDebtor := bank.rootDebtor;
	self.assertTrueMsg(rootDebtor &lt;&gt; null, title &amp; "rootDebtor" &amp; NullMSG);
	
	debtor := self.addDebtor(UT_Debtor, PaymentType_None).CM_Debtor;
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(debtor &lt;&gt; null, title &amp; "debtor" &amp; NullMSG);
	
	calcType := self.createInvoiceCalcType(null, 0, UT_CalculationTypeCode, UT_CalculationTypeCode, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
											null, null, null, "UNITTEST", true, false, false, null, null, null, null);
	self.assertTrueMsg(calcType &lt;&gt; null, title &amp; "calcType" &amp; NullMSG);
	
	calcTypeBb := self.createInvoiceCalcType(null, INV_CALC_TYPE_QUANTITY, UT_CalculationTypeCodeBB, UT_CalculationTypeCodeBB, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
											null, null, null, "UNITTEST", true, false, false, null, null, null, null);
	self.assertTrueMsg(calcTypeBb &lt;&gt; null, title &amp; "calcTypeBb" &amp; NullMSG);
	
	self.deleteInvoiceGLCode(UT_GlCode);
	glCode := self.createInvoiceGLCode(UT_GlCode, UT_GlRemarks);
	service := self.createInvoiceService(UT_InvoiceLineDesc, UT_ServiceRemarks, calcType, glCode);
	self.assertTrueMsg(glCode &lt;&gt; null, title &amp; "glCode" &amp; NullMSG);
	self.assertTrueMsg(service &lt;&gt; null, title &amp; "service" &amp; NullMSG);
	
	serviceBb := self.createInvoiceService(UT_InvoiceLineDescBB, UT_ServiceRemarks, calcTypeBb, glCode);
	self.assertTrueMsg(serviceBb &lt;&gt; null, title &amp; "serviceBb" &amp; NullMSG);
	services.add(service);
	
	self.opts.addAssoc(UTINV_InvoiceTypeNarration, true);
	self.opts.addAssoc(UTINV_TriggerOnRelease, 0);
	self.opts.addAssoc(UTINV_Print1LineDay, false);
	invoiceType	:= self.createInvoiceType(UT_InvoiceDesc, InvoiceTypeGeneral);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(invoiceType &lt;&gt; null, title &amp; "invoiceType" &amp; NullMSG);
	self.opts.purge;
	
	surchargesAndExemptions := self.addInvTypeSurchargeExempt(invoiceType, 0, null, null);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(surchargesAndExemptions &lt;&gt; null, title &amp; "surchargesAndExemptions" &amp; NullMSG);
	
	invoiceLnType := self.createInvoiceLineType(UT_InvoiceLineDesc, calcType, invoiceType, services, "SDT1");
	self.assertTrueMsg(invoiceLnType &lt;&gt; null, title &amp; "invoiceLnType" &amp; NullMSG);
	
	surInvLineType := self.createInvoiceLineType(UT_InvoiceLineDescSur, calcType, invoiceType, services, "SDT1");
	self.assertTrueMsg(surInvLineType &lt;&gt; null, title &amp; "surInvLineType" &amp; NullMSG);
	
	services.clear();
	services.add(serviceBb);
	
	invoiceLnTypeBb := self.createInvoiceLineType(UT_InvoiceLineDescBB, calcTypeBb, invoiceType, services, "SDT1");
	self.assertTrueMsg(invoiceLnTypeBb &lt;&gt; null, title &amp; "invoiceLnTypeBb" &amp; NullMSG);
	
	//Override Rates
	beginTransaction;
	bank.getRootDebtorGroup().serviceRates[service].rateEntries.first.setCostPerUnit(50);
	bank.getRootDebtorGroup().serviceRates[serviceBb].rateEntries.first.setCostPerUnit(25);
	commitTransaction;
	
	//Create transaction map
		//Check data is valid
	fileContent := "TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?" &amp; CrLf &amp;
	"Cargo," &amp; UT_TransactionMapId &amp; ",(Default),(Default),(Default),Import,(Default)," &amp; UT_CargoCommodity &amp; ",Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,All," &amp; UT_InvoiceLineDesc &amp; CrLf &amp;
	"Cargo," &amp; UT_TransactionMapId &amp; ",(Default),(Default),(Default),Import,(Default)," &amp; UT_CargoCommodityBB &amp; ",Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,All," &amp; UT_InvoiceLineDescBB;
	
	self.transactionMapLoad(fileContent, UT_TransactionMapId);
	self.assertNoTrxErrorsOrWarnings();
	
	cargoMap := bank.myCurrentTranMapCargo[UT_TransactionMapId];
	self.assertTrueMsg(cargoMap &lt;&gt; null, title &amp; "cargoMap" &amp; NullMSG);
	
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	operator := self.addOperator(UT_OperatorCode, "UT_" &amp; Ref &amp; " Desc", false, null, null, debtor, false, false, false, false, false, false, false, false, false, false, null, null, null, null, false, false, null, null, null, null, false, false);
	self.assertTrueMsg(operator &lt;&gt; null, title &amp; "operator" &amp; NullMSG);
	
	cargoType := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(UT_CargoTypeCont);
	self.assertTrueMsg(cargoType &lt;&gt; null, title &amp; "cargoType" &amp; NullMSG);
	
	cargoTypeBb := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(UT_CargoTypeBB);
	self.assertTrueMsg(cargoTypeBb &lt;&gt; null, title &amp; "cargoTypeBb" &amp; NullMSG);
	
	commodity := app.myRoot.allCommodities[UT_CargoCommodity];
	self.assertTrueMsg(commodity &lt;&gt; null, title &amp; "commodity" &amp; NullMSG);
	
	commodityBb := app.myRoot.allCommodities[UT_CargoCommodityBB];
	self.assertTrueMsg(commodityBb &lt;&gt; null, title &amp; "commodityBb" &amp; NullMSG);
	
	//Create Vessel
	vessel := self.addVesselCellular(UT_VesselId, operator);
	self.assertTrueMsg(vessel &lt;&gt; null, title &amp; "vessel" &amp; NullMSG);
	
	//Create voyage
	voyage := self.addVoyageWithContainerStructur(UT_VoyageId, UT_VesselId, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg(voyage &lt;&gt; null, title &amp; "voyage" &amp; NullMSG);
	
	//Create Vessel
	vesselHolds := self.addVesselWithHolds(UT_VesselHoldsId, 5, 2);
	self.assertTrueMsg(vesselHolds &lt;&gt; null, title &amp; "vesselHolds" &amp; NullMSG);
	
	//Create voyage
	voyageHolds := self.addVoyageWithGeneralCargoStruc(UT_VoyageHoldsId, UT_VesselHoldsId, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 5);
	self.assertTrueMsg(voyageHolds &lt;&gt; null, title &amp; "voyageHolds" &amp; NullMSG);
	
	//Create debtor separation for a specific debtor and root debtor for invoice type
	realInvTypeDebtorSeparation := self.addInvTypeDebtorSeparation(debtor, null, true, false, false, false, false, false, false,false, surchargesAndExemptions);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(realInvTypeDebtorSeparation &lt;&gt; null, title &amp; "realInvTypeDebtorSeparation" &amp; NullMSG);
	
	realInvTypeDebtorSeparation := self.addInvTypeDebtorSeparation(rootDebtor, null, true, false, true, false, false, false, false,false, surchargesAndExemptions);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(realInvTypeDebtorSeparation &lt;&gt; null, title &amp; "realInvTypeDebtorSeparation" &amp; NullMSG);
	
	//Create surcharge for a specific debtor and root debtor for invoice type
	create allCargoTypes transient;
	create allCommodities transient;
	create allDebtors transient;
	create allInvLineDescs transient;
	
	allCargoTypes.add(cargoType.CM_CargoType);
	allCommodities.add(commodity);
	allDebtors.add(debtor);
	allInvLineDescs.add(invoiceLnType);
	
	validFrom := app.actualTimeAppServer.subtractHoursAndMinutes(24*7);
	validTo := validFrom.addYears(20);
	
	realSurchargeRate := self.addSurchargeRate(allCargoTypes, null, allCommodities, allDebtors, allInvLineDescs, 50, true, 100, 0,
												validFrom, validTo, surchargesAndExemptions, surInvLineType);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(realSurchargeRate &lt;&gt; null, title &amp; "realSurchargeRate" &amp; NullMSG);
	
	allDebtors.clear();
	
	realSurchargeRate := self.addSurchargeRate(allCargoTypes, null, allCommodities, allDebtors, allInvLineDescs, 50, true, 150, 0,
												validFrom, validTo, surchargesAndExemptions, surInvLineType);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(realSurchargeRate &lt;&gt; null, title &amp; "realSurchargeRate" &amp; NullMSG);
	
	allCargoTypes.clear();
	allCommodities.clear();
	allInvLineDescs.clear();
	
	allDebtors.add(debtor);
	allCargoTypes.add(cargoTypeBb.CM_CargoType);
	allCommodities.add(commodityBb);
	allInvLineDescs.add(invoiceLnTypeBb);
	
	realSurchargeRate := self.addSurchargeRate(allCargoTypes, null, allCommodities, allDebtors, allInvLineDescs, 5, false, 0, 50,
												validFrom, validTo, surchargesAndExemptions, surInvLineType);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(realSurchargeRate &lt;&gt; null, title &amp; "realSurchargeRate" &amp; NullMSG);
	
	allDebtors.clear();
	
	realSurchargeRate := self.addSurchargeRate(allCargoTypes, null, allCommodities, allDebtors, allInvLineDescs, 5, false, 0, 25,
												validFrom, validTo, surchargesAndExemptions, surInvLineType);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(realSurchargeRate &lt;&gt; null, title &amp; "realSurchargeRate" &amp; NullMSG);
	
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	self.assertTrueMsg(aPort &lt;&gt; null, title &amp; "aPort" &amp; NullMSG);
	
	//Create on site blockstack
	blockStack := self.addBlockStack(UT_BlockStackId, 999, null);
	self.assertTrueMsg(blockStack &lt;&gt; null, title &amp; "blockStack" &amp; NullMSG);
	
	/*
	############################################## Start Test 1 ##############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	
	Tests:
	1) Tests that Invoice has correct separation criteria for root debtor. Separated by voyage, cargo id
	
	*/
	
	/*
	** Setup
	*/
	//Create Cargo to use on voyage
	title := "Invoice Surcharges - Setup Test 1 - All Debtors - ";
	vesselLocations.add(UT_VesselDischLocn);
	voyage.findLocation(vesselLocations, false, theSlot, foundheight);
	ti1 := self.addContainerAtLocnDisch(UT_TrackedItem1, UT_IsoType, UT_CargoCommodity, TI_IMEX_STATUS_IMPORT, theSlot, aPort, voyage);
	self.assertTrueMsg(ti1 &lt;&gt; null, title &amp; "ti1" &amp; NullMSG);
	self.assertTrueMsg(ti1.cargoType = cargoType.id, "ti1 cargo type Expected: '" &amp; cargoType.id.asStringJMT() &amp; "' | Actual: '" &amp; ti1.cargoType.asStringJMT() &amp; "'");
	self.assertTrueMsg(ti1.commodity = UT_CargoCommodity, "ti1 commodity Expected: '" &amp; UT_CargoCommodity &amp; "' | Actual: '" &amp; ti1.commodity &amp; "'");
	self.assertTrueMsg(ti1.getImExStatus() = TI_IMEX_STATUS_IMPORT, "ti1 imex status Expected: '" &amp; TI_IMEX_STATUS_IMPORT.asStringJMT() &amp; "' | Actual: '" &amp; ti1.getImExStatus().asStringJMT() &amp; "'");
	
	vesselLocations.clear;
	
	self.moveCargo(ti1, null, blockStack.myLocationsController, app.myPassport);
	
	/*
	** Run
	*/
	title := "Invoice Surcharges - Run Test 1 - All Debtors - ";
	
	if ti1.invoiceLines.isNotEmpty then
		invoice := ti1.invoiceLines.first.invoice;
	endif;
	self.assertTrueMsg(invoice &lt;&gt; null, title &amp; "invoice" &amp; NullMSG);
	
	//Change invoice status pending
	self.updateInvoiceStatusSingle(invoice, CM_Invoice.INVOICE_PENDING, false, null, null, null, null, false);
	
	self.assertTrueMsg(invoice.status = CM_Invoice.INVOICE_PENDING,  title &amp; "invoice status Expected: '" &amp; CM_Invoice.INVOICE_PENDING.asStringJMT() &amp; "' | Actual: '" &amp; invoice.status.asStringJMT() &amp; "'");
	
	/*
	** Assert
	*/
	title := "Invoice Surcharges - Assert Test 1 - All Debtors - ";
	
	self.assertSurcharges(title, invoice, surchargeLines, surchargeMultiSet);
	
	/*
	############################################### End Test 1 ###############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	*/
	
	/*
	############################################## Start Test 2 ##############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	
	Tests:
	1) Tests that Invoice has correct separation criteria for specific debtor. Separated by voyage
	
	*/
	
	/*
	** Setup
	*/
	title := "Invoice Surcharges - Setup Test 2 - Specific Debtor - ";
	self.opts.addAssoc(UTTI_Operator, operator);
	vesselLocations.add(UT_VesselDischLocn2);
	voyage.findLocation(vesselLocations, false, theSlot, foundheight);
	ti2 := self.addContainerAtLocnDisch(UT_TrackedItem2, UT_IsoType, UT_CargoCommodity, TI_IMEX_STATUS_IMPORT, theSlot, aPort, voyage);
	self.assertTrueMsg(ti2 &lt;&gt; null, title &amp; "ti2" &amp; NullMSG);
	self.assertTrueMsg(ti2.cargoType = cargoType.id, "ti2 cargo type Expected: '" &amp; cargoType.id.asStringJMT() &amp; "' | Actual: '" &amp; ti2.cargoType.asStringJMT() &amp; "'");
	self.assertTrueMsg(ti2.commodity = UT_CargoCommodity, "ti2 commodity Expected: '" &amp; UT_CargoCommodity &amp; "' | Actual: '" &amp; ti2.commodity &amp; "'");
	self.assertTrueMsg(ti2.getImExStatus() = TI_IMEX_STATUS_IMPORT, "ti2 imex status Expected: '" &amp; TI_IMEX_STATUS_IMPORT.asStringJMT() &amp; "' | Actual: '" &amp; ti2.getImExStatus().asStringJMT() &amp; "'");
	vesselLocations.clear;
	
	vesselLocations.add(UT_VesselDischLocn3);
	voyage.findLocation(vesselLocations, false, theSlot, foundheight);
	ti3 := self.addContainerAtLocnDisch(UT_TrackedItem3, UT_IsoType, UT_CargoCommodity, TI_IMEX_STATUS_IMPORT, theSlot, aPort, voyage);
	self.assertTrueMsg(ti3 &lt;&gt; null, title &amp; "ti3" &amp; NullMSG);
	self.assertTrueMsg(ti3.cargoType = cargoType.id, "ti3 cargo type Expected: '" &amp; cargoType.id.asStringJMT() &amp; "' | Actual: '" &amp; ti3.cargoType.asStringJMT() &amp; "'");
	self.assertTrueMsg(ti3.commodity = UT_CargoCommodity, "ti3 commodity Expected: '" &amp; UT_CargoCommodity &amp; "' | Actual: '" &amp; ti3.commodity &amp; "'");
	self.assertTrueMsg(ti3.getImExStatus() = TI_IMEX_STATUS_IMPORT, "ti3 imex status Expected: '" &amp; TI_IMEX_STATUS_IMPORT.asStringJMT() &amp; "' | Actual: '" &amp; ti3.getImExStatus().asStringJMT() &amp; "'");
	vesselLocations.clear;
	self.opts.purge;
	
	tiSet.add(ti3);
	
	//Move Container to yard
	self.moveCargo(ti2, tiSet, blockStack.myLocationsController, app.myPassport);
	
	tiSet.clear(); //??Down here or move up
	
	/*
	** Run
	*/
	title := "Invoice Surcharges - Run Test 2 - Specific Debtor - ";
	if ti2.invoiceLines.isNotEmpty then
		invoice := ti2.invoiceLines.first.invoice;
	endif;
	self.assertTrueMsg(invoice &lt;&gt; null, title &amp; "invoice" &amp; NullMSG);
	
	//Change invoice status pending
	self.updateInvoiceStatusSingle(invoice, CM_Invoice.INVOICE_PENDING, false, null, null, null, null, false);
	self.assertTrueMsg(invoice.status = CM_Invoice.INVOICE_PENDING,  title &amp; "invoice status Expected: '" &amp; CM_Invoice.INVOICE_PENDING.asStringJMT() &amp; "' | Actual: '" &amp; invoice.status.asStringJMT() &amp; "'");
	
	/*
	** Assert
	*/
	title := "Invoice Surcharges - Assert Test 2 - Specific Debtor - ";
	
	self.assertSurcharges(title, invoice, surchargeLines, surchargeMultiSet);
	
	/*
	############################################### End Test 2 ###############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	*/
	
	/*
	############################################## Start Test 3 ##############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	
	Tests:
	1) Tests that Invoice creates correct surcharges for specific debtor by Amount (Line Total) and Surcharge Rate
		applyGreaterThanAmount = 200
		applyGreaterThanLineTotal = true
		surchargeAmount = 0
		surchargeRate = 100
	
	*/
	
	/*
	** Setup
	*/
	title := "Invoice Surcharges - Setup Test 3 - Specific Debtor - ";
	self.opts.addAssoc(UTTI_CommodityCode, commodityBb.code);
	vesselLocations.add(UT_VesselHoldsDischLocn1);
	voyageHolds.findLocation(vesselLocations, false, theSlot, foundheight);
	ti4 := self.addCargoBreakBulkAtLocation(UT_TrackedItem4, cargoTypeBb.CM_CargoType, 5, theSlot, aPort.code, TI_IMEX_STATUS_IMPORT, voyageHolds, operator);
	self.assertTrueMsg(ti4 &lt;&gt; null, title &amp; "ti4" &amp; NullMSG);
	self.assertTrueMsg(ti4.cargoType = cargoTypeBb.id, "ti4 cargo type Expected: '" &amp; cargoTypeBb.id.asStringJMT() &amp; "' | Actual: '" &amp; ti4.cargoType.asStringJMT() &amp; "'");
	self.assertTrueMsg(ti4.commodity = UT_CargoCommodityBB, "ti4 commodity Expected: '" &amp; UT_CargoCommodityBB &amp; "' | Actual: '" &amp; ti4.commodity &amp; "'");
	self.assertTrueMsg(ti4.getImExStatus() = TI_IMEX_STATUS_IMPORT, "ti4 imex status Expected: '" &amp; TI_IMEX_STATUS_IMPORT.asStringJMT() &amp; "' | Actual: '" &amp; ti4.getImExStatus().asStringJMT() &amp; "'");
	vesselLocations.clear;
	
	self.opts.purge;
	
	//Move Container to yard
	self.moveCargo(ti4, null, blockStack.myLocationsController, app.myPassport);
	
	/*
	** Run
	*/
	title := "Invoice Surcharges - Run Test 3 - Specific Debtor - ";
	if ti4.invoiceLines.isNotEmpty then
		invoice := ti4.invoiceLines.first.invoice;
	endif;
	self.assertTrueMsg(invoice &lt;&gt; null, title &amp; "invoice" &amp; NullMSG);
	
	//Change invoice status pending
	self.updateInvoiceStatusSingle(invoice, CM_Invoice.INVOICE_PENDING, false, null, null, null, null, false);
	self.assertTrueMsg(invoice.status = CM_Invoice.INVOICE_PENDING,  title &amp; "invoice status Expected: '" &amp; CM_Invoice.INVOICE_PENDING.asStringJMT() &amp; "' | Actual: '" &amp; invoice.status.asStringJMT() &amp; "'");
	
	/*
	** Assert
	*/
	title := "Invoice Surcharges - Assert Test 3 - Specific Debtor - ";
	
	self.assertSurcharges(title, invoice, surchargeLines, surchargeMultiSet);
	
	/*
	############################################### End Test 3 ###############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	*/
	
	/*
	############################################## Start Test 4 ##############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	
	Tests:
	1) Tests that Invoice creates correct surcharges for root debtor by Amount (Line Total) and Surcharge Rate
		applyGreaterThanAmount = 200
		applyGreaterThanLineTotal = true
		surchargeAmount = 0
		surchargeRate = 100
	
	*/
	
	/*
	** Setup
	*/
	title := "Invoice Surcharges - Setup Test 4 - All Debtors - ";
	self.opts.addAssoc(UTTI_CommodityCode, commodityBb.code);
	vesselLocations.add(UT_VesselHoldsDischLocn2);
	voyageHolds.findLocation(vesselLocations, false, theSlot, foundheight);
	ti5 := self.addCargoBreakBulkAtLocation(UT_TrackedItem5, cargoTypeBb.CM_CargoType, 5, theSlot, aPort.code, TI_IMEX_STATUS_IMPORT, voyageHolds, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertTrueMsg(ti5 &lt;&gt; null, title &amp; "ti5" &amp; NullMSG);
	self.assertTrueMsg(ti5.cargoType = cargoTypeBb.id, "ti5 cargo type Expected: '" &amp; cargoTypeBb.id.asStringJMT() &amp; "' | Actual: '" &amp; ti5.cargoType.asStringJMT() &amp; "'");
	self.assertTrueMsg(ti5.commodity = UT_CargoCommodityBB, "ti5 commodity Expected: '" &amp; UT_CargoCommodityBB &amp; "' | Actual: '" &amp; ti5.commodity &amp; "'");
	self.assertTrueMsg(ti5.getImExStatus() = TI_IMEX_STATUS_IMPORT, "ti5 imex status Expected: '" &amp; TI_IMEX_STATUS_IMPORT.asStringJMT() &amp; "' | Actual: '" &amp; ti5.getImExStatus().asStringJMT() &amp; "'");
	vesselLocations.clear;
	
	self.opts.purge;
	
	//Move Container to yard
	self.moveCargo(ti5, null, blockStack.myLocationsController, app.myPassport);
	
	/*
	** Run
	*/
	title := "Invoice Surcharges - Run Test 4 - All Debtors - ";
	if ti5.invoiceLines.isNotEmpty then
		invoice := ti5.invoiceLines.first.invoice;
	endif;
	self.assertTrueMsg(invoice &lt;&gt; null, title &amp; "invoice" &amp; NullMSG);
	
	//Change invoice status pending
	self.updateInvoiceStatusSingle(invoice, CM_Invoice.INVOICE_PENDING, false, null, null, null, null, false);
	self.assertTrueMsg(invoice.status = CM_Invoice.INVOICE_PENDING,  title &amp; "invoice status Expected: '" &amp; CM_Invoice.INVOICE_PENDING.asStringJMT() &amp; "' | Actual: '" &amp; invoice.status.asStringJMT() &amp; "'");
	
	/*
	** Assert
	*/
	title := "Invoice Surcharges - Assert Test 4 - All Debtors - ";
	
	self.assertSurcharges(title, invoice, surchargeLines, surchargeMultiSet);
	
	/*
	############################################### End Test 4 ###############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	*/
	
epilog
	delete services;
	delete allCargoTypes;
	delete allCommodities;
	delete allDebtors;
	delete allInvLineDescs;
	delete vesselLocations;
	delete tiSet;
	delete surchargeLines;
	delete surchargeMultiSet;
	self.resetDefaultTranMap();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceAPIConsol01" id="dfad61d4-f2b8-4a8e-8915-d57b72cbd038">
        <source>tInvoiceAPIConsol01();
/*
Purpose - NSW Invoice line types that have the same financial dimension, invoice line type and rate are grouped together	
Who - NAVAB1
Date - 08MAY2025
ADO - JIRA 34738
*/

constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice, transientInvoice	: CM_Invoice;

	calcType : CM_CalculationType;
	service100 : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType1, invLineType2, invLineType3		: CM_InvoiceLineDesc;
	invoiceLine		: CM_InvoiceLine;
	now             : TimeStamp;
	idx : Integer;
	ioClassActual : CM_ExtFinanceIO;
	ioClassForTest : CM_InvoiceAPINSW;
	taxCode : CM_TaxCode;
begin
	// set the default finance class
	ioClassActual := self.getTerminalConfig(FinancialIOClass).CM_ExtFinanceIO;
	ioClassForTest := CM_InvoiceAPINSW.firstInstance().CM_InvoiceAPINSW;
	self.setTerminalConfig(FinancialIOClass, ioClassForTest);

	
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	
	self.deleteInvoiceService("UT_ServiceCopy-1",0);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCon1",0);
	self.deleteInvoiceLineType("UT_LineTypeCon2",0);
	self.deleteInvoiceLineType("UT_LineTypeCon3",0);
	now := app.actualTime();
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);

	taxCode := bank.allTaxCodes["UT_TAX_1"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_1","UT_TAX_1", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_1");
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);	
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	service100 := self.createInvoiceService("UT_ServiceCopy-1","1- Unit test for Task 61635", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-1 not created");
	
	create services transient;
 	services.add(service100);
	
	invType := self.createInvoiceType("UT_InvTypeCopy", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeCopy not created");
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeCon1", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeCon1 not created");
	
	invLineType2 := self.createInvoiceLineType("UT_LineTypeCon2", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeCon2 not created");
	
	invLineType3 := self.createInvoiceLineType("UT_LineTypeCon3", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeCon3 not created");
	
	invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);	
	
	beginTransaction;
	invoice.sequenceNum := 999;
	invoice.status := CM_Invoice.INVOICE_POSTED_PENDING;
	commitTransaction;
	
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 12.34,invoice,"",now.date(),   999991, 2 ); // $24.68
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 12.34,invoice,"",now.date(),   999992, 2 ); // $24.68
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 12.34,invoice,"",now.date(),   999993, 2 ); // $24.68
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 12.34,invoice,"",now.date(),   999994, 2 ); // $24.68
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 12.34,invoice,"",now.date(),   999995, 2 ); // $24.68
	
		transientInvoice := invoice.cloneForConsolidation();
		invoice.getInvLinesConsRef4TypeRate(transientInvoice);	

		self.assertTrueMsg(transientInvoice.invoiceLines.size = 1, "Grouping has not worked.");
		
		idx := 1;
		foreach invoiceLine in transientInvoice.invoiceLines do
			if idx = 1 then
				self.assertTrueMsg(invoiceLine.totalAmount = 123.4, "Grouping amount is wrong 1 SBE 123.4 is " &amp; invoiceLine.totalAmount.String);
			endif;
			idx+=1;
		endforeach;
epilog
	

	if services &lt;&gt; null then
		beginTransaction;
			services.purge();
			delete services;
		commitTransaction;
	endif;
	self.deleteInvoice(invoice);
	self.deleteInvoice(transientInvoice);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceAPIConsol02" id="b87da13f-087a-483b-b030-e5975f44155e">
        <source>tInvoiceAPIConsol02();
/*
Purpose - 	NSW - Invoice lines that have the same financial dimension, but different invoice line types should be grouped by invoice line type
Who - NAVAB1
Date - 08MAY2025
ADO - JIRA 34738
*/

constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice, transientInvoice	: CM_Invoice;

	calcType : CM_CalculationType;
	service100 : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType1, invLineType2, invLineType3		: CM_InvoiceLineDesc;
	invoiceLine		: CM_InvoiceLine;
	now             : TimeStamp;
	idx : Integer;
	ioClassActual : CM_ExtFinanceIO;
	ioClassForTest : CM_InvoiceAPINSW;
	taxCode : CM_TaxCode;
begin
	// set the default finance class
	ioClassActual := self.getTerminalConfig(FinancialIOClass).CM_ExtFinanceIO;
	ioClassForTest := CM_InvoiceAPINSW.firstInstance().CM_InvoiceAPINSW;
	self.setTerminalConfig(FinancialIOClass, ioClassForTest);


	
	self.deleteInvoiceService("UT_ServiceCopy-1",0);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCon1",0);
	self.deleteInvoiceLineType("UT_LineTypeCon2",0);
	self.deleteInvoiceLineType("UT_LineTypeCon3",0);
	now := app.actualTime();
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	

	taxCode := bank.allTaxCodes["UT_TAX_1"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_1","UT_TAX_1", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_1");

	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);	
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	service100 := self.createInvoiceService("UT_ServiceCopy-1","1- Unit test for Task 61635", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-1 not created");
	
	create services transient;
 	services.add(service100);
	
	invType := self.createInvoiceType("UT_InvTypeCopy", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeCopy not created");
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeCon1", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeCon1 not created");
	
	invLineType2 := self.createInvoiceLineType("UT_LineTypeCon2", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeCon2 not created");
	
	invLineType3 := self.createInvoiceLineType("UT_LineTypeCon3", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeCon3 not created");
	
	invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);	
	
	beginTransaction;
	invoice.sequenceNum := 999;
	invoice.status := CM_Invoice.INVOICE_POSTED_PENDING;
	commitTransaction;
	
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 12.34,invoice,"",now.date(),   999991, 2 ); // $24.68
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 12.34,invoice,"",now.date(),   999992, 2 ); // $24.68
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 12.34,invoice,"",now.date(),   999993, 2 ); // $24.68
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType2, 12.34,invoice,"",now.date(),   999994, 2 ); // $24.68
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType2, 12.34,invoice,"",now.date(),   999995, 2 ); // $24.68
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType2, 12.34,invoice,"",now.date(),   999996, 2 ); // $24.68
	
	// Groups:
	// 999991, 999992 - $ 49.36
	// 999993 - $46.90
	// 999994 - $24.68
	// 999995 - $113.56
	// 999996, 999997 - $49.36
	
		transientInvoice := invoice.cloneForConsolidation();
		invoice.getInvLinesConsRef4TypeRate(transientInvoice);	

		self.assertTrueMsg(transientInvoice.invoiceLines.size = 2, "Grouping has not worked.");
		
		idx := 1;
		foreach invoiceLine in transientInvoice.invoiceLines do
			if idx = 1 then
				self.assertTrueMsg(invoiceLine.totalAmount = 74.04, "Grouping amount is wrong 1 SBE 74.04 is " &amp; invoiceLine.totalAmount.String);
			elseif idx = 2 then
				self.assertTrueMsg(invoiceLine.totalAmount = 74.04, "Grouping amount is wrong 2 SBE 74.04 is " &amp; invoiceLine.totalAmount.String);
			endif;
			idx+=1;
		endforeach;
epilog
	

	if services &lt;&gt; null then
		beginTransaction;
			services.purge();
			delete services;
		commitTransaction;
	endif;
	self.deleteInvoice(invoice);
	self.deleteInvoice(transientInvoice);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceAPIConsol03" id="7dace876-e86d-4745-84a0-fad4706b739a">
        <source>tInvoiceAPIConsol03();
/*
Purpose - 	Invoice lines that have the same financial dimension and invoice line types, but different rates should be grouped by rate
Who - NAVAB1
Date - 08MAY2025
ADO - JIRA 34738
*/

constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice, transientInvoice	: CM_Invoice;

	calcType : CM_CalculationType;
	service100 : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType1, invLineType2, invLineType3		: CM_InvoiceLineDesc;
	invoiceLine		: CM_InvoiceLine;
	now             : TimeStamp;
	idx : Integer;
	ioClassActual : CM_ExtFinanceIO;
	ioClassForTest : CM_InvoiceAPINSW;
	taxCode : CM_TaxCode;
begin
	// set the default finance class
	ioClassActual := self.getTerminalConfig(FinancialIOClass).CM_ExtFinanceIO;
	ioClassForTest := CM_InvoiceAPINSW.firstInstance().CM_InvoiceAPINSW;
	self.setTerminalConfig(FinancialIOClass, ioClassForTest);


	
	self.deleteInvoiceService("UT_ServiceCopy-1",0);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCon1",0);
	self.deleteInvoiceLineType("UT_LineTypeCon2",0);
	self.deleteInvoiceLineType("UT_LineTypeCon3",0);
	now := app.actualTime();
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);

	taxCode := bank.allTaxCodes["UT_TAX_1"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_1","UT_TAX_1", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_1");
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);	
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	service100 := self.createInvoiceService("UT_ServiceCopy-1","1- Unit test for Task 61635", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-1 not created");
	
	create services transient;
 	services.add(service100);
	
	invType := self.createInvoiceType("UT_InvTypeCopy", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeCopy not created");
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeCon1", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeCon1 not created");
	
	invLineType2 := self.createInvoiceLineType("UT_LineTypeCon2", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeCon2 not created");
	
	invLineType3 := self.createInvoiceLineType("UT_LineTypeCon3", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeCon3 not created");
	
	invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);	
	
	beginTransaction;
	invoice.sequenceNum := 999;
	invoice.status := CM_Invoice.INVOICE_POSTED_PENDING;
	commitTransaction;
	
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 12.34,invoice,"",now.date(),   999991, 2 ); // $24.68
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 12.34,invoice,"",now.date(),   999992, 2 ); // $24.68
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 45.00,invoice,"",now.date(),   999993, 2 ); // $90.00
	invoiceLine :=self.createManLineAPIConsol("Group One",invLineType1, 45.00,invoice,"",now.date(),   999994, 2 ); // $90.00

	// Groups:
	// 999991, 999992 - $ 49.36
	// 999993 - $46.90
	// 999994 - $24.68
	// 999995 - $113.56
	// 999996, 999997 - $49.36
	
		transientInvoice := invoice.cloneForConsolidation();
		invoice.getInvLinesConsRef4TypeRate(transientInvoice);	

		self.assertTrueMsg(transientInvoice.invoiceLines.size = 2, "Grouping has not worked.");
		
		idx := 1;
		foreach invoiceLine in transientInvoice.invoiceLines do
			if idx = 1 then
				self.assertTrueMsg(invoiceLine.totalAmount = 49.36, "Grouping amount is wrong 1 SBE 49.36 is " &amp; invoiceLine.totalAmount.String);
			elseif idx = 2 then
				self.assertTrueMsg(invoiceLine.totalAmount = 180.00, "Grouping amount is wrong 2 SBE 180 is " &amp; invoiceLine.totalAmount.String);
			endif;
			idx+=1;
		endforeach;
epilog
	

	if services &lt;&gt; null then
		beginTransaction;
			services.purge();
			delete services;
		commitTransaction;
	endif;
	self.deleteInvoice(invoice);
	self.deleteInvoice(transientInvoice);
	
end;</source>
