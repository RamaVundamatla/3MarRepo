    <JadeMethod name="isNoOutDoc" id="bb005591-031e-4960-8784-f9e58f3e6f84">
        <source>isNoOutDoc() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60762: Jade - Custom Doc Summary and Unit Tests

*/

vars

begin
	return self.outwardDocCode = null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isZero" id="328e66d8-8d81-4a8e-9a4c-e050b36c5cdb">
        <source>isZero() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60762: Jade - Custom Doc Summary and Unit Tests

*/

vars

begin
	return self.clearedQuantity = 0 and self.clearedVolume = 0 and self.clearedWeight = 0 and self.pendingQuantity = 0 and self.pendingVolume = 0 and self.pendingWeight = 0;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAmount" id="f0aca494-84af-468d-b511-34927eb25455">
        <updating/>
        <source>setAmount(_isInward: Boolean; _custDocDetail : CM_CustomDocumentDetail; _cmifPending : CMIF_CargoReviewCustDocDetail input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60762: Jade - Custom Doc Summary and Unit Tests

*/

vars
	
begin
	// Inward custom document 126. Clear is actually Pending.
	// We update the pending amount
	if _isInward or self = _cmifPending then
		if self.trackedBy = CMIF_CargoReviewCustDocAgent.TrackedByQuantity then
			self.pendingQuantity 	+= _custDocDetail.clearedQuantity;
		elseif self.trackedBy = CMIF_CargoReviewCustDocAgent.TrackedByVolume then
			self.pendingVolume 		+= _custDocDetail.clearedVolume;
		elseif self.trackedBy = CMIF_CargoReviewCustDocAgent.TrackedByWeight then
			self.pendingWeight 		+= _custDocDetail.clearedWeight;
		endif;
		return;
	endif;
	
	// This is Outward custom document
	// Update the cleared amount
	if self.trackedBy = CMIF_CargoReviewCustDocAgent.TrackedByQuantity then
		self.clearedQuantity 			+= _custDocDetail.clearedQuantity;
		// Also update the pending amount
		_cmifPending.pendingQuantity 	-= _custDocDetail.clearedQuantity;
	elseif self.trackedBy = CMIF_CargoReviewCustDocAgent.TrackedByVolume then
		self.clearedVolume 				+= _custDocDetail.clearedVolume;
		// Also update the pending amount
		_cmifPending.pendingVolume		-= _custDocDetail.clearedVolume;
	elseif self.trackedBy = CMIF_CargoReviewCustDocAgent.TrackedByWeight then
		self.clearedWeight 				+= _custDocDetail.clearedWeight;
		// Also update the pending amount
		_cmifPending.pendingWeight 		-= _custDocDetail.clearedWeight;
	endif;
	
	
	
	
	
	

epilog

end;</source>
        <Parameter name="_isInward" type="Boolean"/>
        <Parameter name="_custDocDetail" type="CM_CustomDocumentDetail"/>
        <Parameter name="_cmifPending" type="CMIF_CargoReviewCustDocDetail" usage="input"/>
    </JadeMethod>
</Class>
