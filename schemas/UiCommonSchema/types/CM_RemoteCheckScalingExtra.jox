<Class name="CM_RemoteCheckScalingExtra">
    <JadeMethod name="loadRemoteTable" id="03380b81-bedb-45bd-97bf-5fc7c39df368">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 07 April 2003 

vars

begin

	inheritMethod(_table);
	self.addRemoteRow(_table, 'ID', self.id, null);
	self.addRemoteRow(_table, 'Condition Code', self.conditionCode, null);
	self.addRemoteRow(_table, 'Min SED', self.minSED.String, null);
	self.addRemoteRow(_table, 'Max SED', self.maxSED.String, null);
	

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
