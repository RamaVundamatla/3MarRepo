    <JadeMethod name="translateForm" id="45ce9681-da15-4e55-9d81-c12cdec9bf38">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 November 2023 08:59:54.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025542, locale);
	btnEmailLayout.translateCaption(Xlat_0025543, locale);
	btnNew.translateCaption(Xlat_0025544, locale);
	btnRefresh.translateCaption(Xlat_0026189, locale);
	lblCarrier.translateCaption(Xlat_0025545, locale);
	lblCreationMethod.translateCaption(Xlat_0026190, locale);
	lblDate.translateCaption(Xlat_0025546, locale);
	lblDirection.translateCaption(Xlat_0025547, locale);
	lblDriver.translateCaption(Xlat_0025548, locale);
	lblEndDate.translateCaption(Xlat_0025549, locale);
	lblExtRef.translateCaption(Xlat_0025550, locale);
	lblOperator.translateCaption(Xlat_0026572, locale);
	lblRRId.translateCaption(Xlat_0025551, locale);
	lblRemarks.translateCaption(Xlat_0025552, locale);
	lblSlotType.translateCaption(Xlat_0025553, locale);
	lblSource.translateCaption(Xlat_0025554, locale);
	lblStartDate.translateCaption(Xlat_0025555, locale);
	lblStatus.translateCaption(Xlat_0025556, locale);
	lblSubCarrier.translateCaption(Xlat_0025557, locale);
	lblVbsId.translateCaption(Xlat_0025558, locale);
	lblVehicle.translateCaption(Xlat_0025559, locale);
end;</source>
