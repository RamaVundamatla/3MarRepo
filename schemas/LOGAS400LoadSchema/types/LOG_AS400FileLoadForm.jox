        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLoadedFiles_click(table: Table input) updating;

vars

begin

	setSelected(table.row);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
