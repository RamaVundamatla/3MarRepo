    <JadeMethod name="mnuAreaShow1_click" id="3275be56-46d1-4614-800d-5dc53cf4e93e">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAreaShow1_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2011	cnwndl1	Initial creation(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	termArea : CM_TerminalArea;
	cm_ObjectArray	: CM_ObjectArray;

begin

	termArea := menuItem.userObject.CM_TerminalArea;
	
	if termArea = null then
		return;
	endif;
	
	if termArea.isKindOf( CM_GridArea ) then
		
		create cm_ObjectArray transient;
		self.findLocationsFromObject( termArea, cm_ObjectArray );
		if cm_ObjectArray.isEmpty then
			return;
		endif;
		
		self.myAssistant.showYardGridAreasForm(	cm_ObjectArray,
												self.myCurrentDrawingController.getViewMode(),
												self.myMasterMenuAction,
												0);
												
	elseif termArea.isKindOf( CM_RoRoLaneArea ) then
											
		//20 Jan 2012	NDL	Par 28901										
		self.myAssistant.showRoRoLaneAreasForm(	termArea,
												self.myCurrentDrawingController.getViewMode(),
												self.myMasterMenuAction
												);	
												
	elseif termArea.isKindOf(CM_IrregularBlockArea) then
		
		self.myAssistant.showGeneralBlockAreaForm(	termArea.CM_IrregularBlockArea,
													self.myCurrentDrawingController.getViewMode(),
													self.myMasterMenuAction
													);
	endif;

epilog

	delete cm_ObjectArray;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
