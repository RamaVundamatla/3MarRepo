    <JadeMethod name="mnuFont_click" id="89826344-8a40-404b-b2a3-83995a9c2974">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFont_click(menuItem: MenuItem input) updating;

vars
	dialog : CMDFont;
	
begin
	create dialog;

	if txtLog.fontName &lt;&gt; null then
		dialog.fontName := txtLog.fontName;
	else
		dialog.fontName := app.fontName;
	endif;
	dialog.fontSize := txtLog.fontSize;
	dialog.fontBold := txtLog.fontBold;
	
	if dialog.open = 0 then
		txtLog.fontName := dialog.fontName;
		txtLog.fontSize := dialog.fontSize;
		txtLog.fontBold := dialog.fontBold;
	endif;
	
epilog
	delete dialog;
end;
</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showProgressDialog" id="f44b9507-8acf-4f37-81b5-82139d363a02">
        <updating/>
        <source>showProgressDialog()updating;

vars
	x, y		: Real;

begin
	x := 0;
	y := 0;
	self.windowToScreen(x, y);
	create progressDialog;
	progressDialog.left := x;
	progressDialog.top := y;
	beginNotification(progressDialog, ProgressDialog.CancelEvent, Response_Continuous, UserCancel);
	progressDialog.caption := self.caption;
	progressDialog.parent := self;
	progressDialog.noConfirmation := true;
	progressDialog.show;
	progressDialog.showProgress("Inititalising...", "", "");
end;
</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="6c51c7b1-6a7e-4163-8024-d8a3c00b2521">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars
	jstr : String;
begin

	if eventTag = JournalStart then
		jstr := "db" &amp; userInfo.Integer.padLeadingWith('0', 10) &amp; ".log";
		logMsg("  processing journal: " &amp; jstr);
		progressDialog.showProgress("Dumping Journal", jstr, "");
	elseif eventTag = JournalMissing then
		jstr := "db" &amp; userInfo.Integer.padLeadingWith('0', 10) &amp; ".log";
		logMsg("  journal: " &amp; jstr &amp; " not found");
	elseif eventTag = JobCompleted then
		logMsg("[Journal Dump Completed]");
		jdFinish();
	elseif eventTag = JobAborted then
		call getMessageText(userInfo.Integer, jstr, null);
		jstr := jstr &amp; "(" &amp; userInfo.Integer.String &amp; ")";
		logMsg("*** Worker terminated due to error: " &amp; jstr &amp; " ***");
		logMsg("*** Journal Dump Aborted ***");
		app.msgBox("Journal Dump Failed" &amp; CrLf &amp; jstr, caption, MsgBox_OK_Only + MsgBox_Stop_Icon);
		jdFinish();
	elseif eventTag = UserCancel then
		cancelJob();
	endif;

end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
