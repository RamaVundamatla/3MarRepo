    <JadeMethod name="doAuthenticateUser" id="d81c6119-9440-4e17-a925-169bcc5c8f66">
        <updating/>
        <source>doAuthenticateUser(_token : String output;
				   _errorMessage : String output;
				   _timeoutOccured : Boolean io) : Boolean protected , updating;
/*

Purpose:			Call the REST API authentication mechanism with the usercode and password on the receiver

Parameters:			Output _token if successful
					_errorMessage set if we received an error response from the service
					_timeoutOccured set to true if we got no response

Return Value:		True if the authentication was successful

Date		Who		Reason
22 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	xml				: JadeXMLDocument;
	xmlElement		: JadeXMLElement;
	jsonPostData	: String;
	jsonHelper		: CMIF_JsonHelper;
	jsonResponse	: String;
	xmlHelper		: CM_XmlHelperAgent;
	resultCode		: Integer;
	
begin
	// Create a Json request for the authenticate parameters
	create jsonHelper transient;
	create xml transient;
	xml.outputDeclaration := false;
	xml.addElement("root");
	xml.rootElement.addElement("username").setText(self.usercode);
	xml.rootElement.addElement("password").setText(self.password);
	jsonPostData := jsonHelper.convertXMLToJson(xml.writeToString());
	
	// Call authenticate
	jsonResponse := self.doSendHTTPRequest(self.restAPIAuthEndpoint,
										   "POST",
										   self.getAdditionalHeadersForHTTP(),
										   jsonPostData,
										   resultCode);
										   
	// Timeout or communication failure will return null response
	if jsonResponse = null then
		_timeoutOccured := true;
		return false;
	endif;
	
	// Now need to interpret the response to see if the authentication worked
	create xmlHelper transient;
	delete xml;
	create xml transient;
	xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(jsonResponse), xml);
	
	// Find token in response
	xmlElement := xml.findElementByTagName("token");
	if xmlElement &lt;&gt; null then
		_token := xmlElement.text();
		return true;
	endif;
	
	// No token found, so look for an error message
	xmlElement := xml.findElementByTagName("error");
	if xmlElement &lt;&gt; null then
		_errorMessage := xmlElement.text();
	else
		_errorMessage := 'Neither "token" nor "error" found in the response';
	endif;

	// And the authenticate did not work
	return false;
	
epilog
	delete xml;
	delete jsonHelper;
	
end;</source>
        <access>protected</access>
        <Parameter name="_token" type="String" usage="output"/>
        <Parameter name="_errorMessage" type="String" usage="output"/>
        <Parameter name="_timeoutOccured" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetupForWebServiceRequest" id="a0300b91-e91d-401e-9ffd-96247f06a31b">
        <source>doSetupForWebServiceRequest(_consumer: JadeWebServiceConsumer input; _request: ImportedWebServiceProxy input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_consumer, _request);

	// Each Inaportnet request has user and password fields required, so set them
	_request.setPropertyValue("user", self.usercode);
	_request.setPropertyValue("password", self.password);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_consumer" type="JadeWebServiceConsumer" usage="input"/>
        <Parameter name="_request" type="ImportedWebServiceProxy" usage="input"/>
    </JadeMethod>
    <JadeMethod name="entryRpkro" id="ded4b99d-0dc7-4982-ad3a-10d6136e5763">
        <updating/>
        <source>entryRpkro(_request : CMIF_IPNEntryRpkroRequest;
			_detailRequest : CMIF_IPNEntryRpkroDetailReq ) : CMIF_IPNEntryRpkroResponse  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
19 Jun 2019 jlger1	TFS 45207  - updates to entryRpkro
*/

vars
	response		: CMIF_IPNEntryRpkroResponse;
	realRequest	,
	realResponse	: ImportedWebServiceProxy;
	createdObjects	: ObjectSet;
	soapFault		: Boolean;
	jadeWebConsumer : JadeWebServiceConsumer;
begin
	create createdObjects transient;
	//epr TFS 45207 19/6/19
	if self.myIPNEntryRpkroConsumer &lt;&gt; null then
		jadeWebConsumer:=self.myIPNEntryRpkroConsumer;
		create realRequest as IPN1_EntryRpkroA_v1_3 transient;
		
		if _detailRequest &lt;&gt; null then
			create realRequest.IPN1_EntryRpkroA_v1_3.rpkroDetail transient;
			_detailRequest.copyToRealWSObject(realRequest.IPN1_EntryRpkroA_v1_3.rpkroDetail,createdObjects);
			createdObjects.add(realRequest.IPN1_EntryRpkroA_v1_3.rpkroDetail);
		endif;
	
	else
		jadeWebConsumer:=self.myIPNConsumer;
		create realRequest as IPN1_EntryRpkroA transient;
	endif;
	
	
	createdObjects.add(realRequest);
	
	_request.copyToRealWSObject(realRequest, createdObjects);
	
	realResponse := self.doSendWebServiceRequest(jadeWebConsumer,
												 method.name,
												 realRequest,
												 soapFault);
												 
	if realResponse &lt;&gt; null then
		create response transient;
		if realResponse.isKindOf(IPN1_EntryRpkroResponseA) then
			if realResponse.IPN1_EntryRpkroResponseA.entryRpkroResult &lt;&gt; null then
				if realResponse.IPN1_EntryRpkroResponseA.entryRpkroResult.zreturn &lt;&gt; null then
					response.setFromRealWSObject(realResponse.IPN1_EntryRpkroResponseA.entryRpkroResult.zreturn);
				endif;
			endif;
		elseif realResponse.isKindOf(IPN1_EntryRpkroResponseA_v1_3) then
			if realResponse.IPN1_EntryRpkroResponseA_v1_3.entryRpkroResult &lt;&gt; null then
				if realResponse.IPN1_EntryRpkroResponseA_v1_3.entryRpkroResult.zreturn &lt;&gt; null then
					response.setFromRealWSObject(realResponse.IPN1_EntryRpkroResponseA_v1_3.entryRpkroResult.zreturn);
				endif;
			endif;
		endif;
	elseif soapFault then
		create response transient;
		response.setValuesForSOAPFault();
	endif;
	
	return response;
	
epilog
	if createdObjects &lt;&gt; null then
		createdObjects.purge();
		delete createdObjects;
	endif;
	
end;</source>
        <Parameter name="_request" type="CMIF_IPNEntryRpkroRequest"/>
        <Parameter name="_detailRequest" type="CMIF_IPNEntryRpkroDetailReq"/>
        <ReturnType type="CMIF_IPNEntryRpkroResponse"/>
    </JadeMethod>
