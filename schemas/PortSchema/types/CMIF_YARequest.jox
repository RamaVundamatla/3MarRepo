// ---------------------------------------------------------------------------
// Created:		15 July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	yaData : CM_YAData;
	yaDataObjs : CM_YADataObjects;
	obj : Object;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_VoyagePlanCode );

