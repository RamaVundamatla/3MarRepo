<Class name="CMUI_RemoteDataEditManager" id="bb1c0a8e-d945-4fe0-8d59-b45a5c2ea939">
    <superclass name="CMUI_Transient"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allLoadedObjects" id="dc692295-6c7b-416e-9073-94b4e6ca6077">
        <memberTypeInverse/>
        <type name="CM_RemoteDataObjectArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="isArray" id="e9a70b1f-62f1-4de7-93c5-68831903d2eb">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myCurrentObject" id="ce09276c-96b7-43af-aa5c-11f5b922ddfc">
        <embedded/>
        <type name="CM_RemoteDataObject"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTable" id="a20f1b74-bbfb-4407-a78f-217926adf519">
        <embedded/>
        <type name="CM_EntryTable"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="back" id="a4693486-5b0f-4007-af9f-279a3f35e4de">
        <updating/>
        <source>back() : String updating;

vars
	remoteData	: CM_RemoteDataObject;

begin

	if not self.isArray then
		if self.allLoadedObjects.size &gt; 1 then
			self.allLoadedObjects.remove(self.myCurrentObject);
			remoteData := self.allLoadedObjects.last;
			if remoteData &lt;&gt; null then
				self.myCurrentObject := remoteData;
			endif;
		endif;
	endif;
	self.isArray := false;
	self.myCurrentObject.loadRemoteTable(self.myTable);
	return self.getDescription();
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doClick" id="340b85e5-e51a-482f-86bd-0d9c511cec38">
        <updating/>
        <source>doClick() : String updating;

vars


begin

	if self.myTable.itemObject &lt;&gt; null and 
		global.isValidObject(self.myTable.itemObject) then
		return  self.loadTable(self.myTable.itemObject.CM_RemoteDataObject);
	endif;
	return getDescription();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getArrayItemsFromTable" id="beb85c6c-d0fb-41c9-bcd0-9cec3a5ec27d">
        <source>getArrayItemsFromTable(_array : StringArray input) protected;

vars

	row : Integer;

begin

	_array.add(self.myTable.accessCell(1, (CM_EntryTable.ColumnValue - 1)).text);
	foreach row in 2 to self.myTable.rows do
		_array.add(self.myTable.accessCell(row,CM_EntryTable.ColumnValue).text);
	endforeach;	

end;</source>
        <access>protected</access>
        <Parameter name="_array" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="2dd86554-fd9c-4746-95ba-ae2b7b152b9a">
        <source>getDescription() : String protected;

vars

	string				: String;
	remoteDataObject	: CM_RemoteDataObject;

begin

	foreach remoteDataObject in self.allLoadedObjects do
		string := string &amp; remoteDataObject.getDescription() &amp; ' ...';
	endforeach;
	if self.isArray then
		string := string &amp; ' Items (' &amp; remoteDataObject.getNumberOfItems() &amp; ')';
	endif;
	return string;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="12a8ce62-be7c-4751-b3a0-58bb6814fc5a">
        <updating/>
        <source>initialize(_table : CM_EntryTable) updating;

vars

begin

	self.myTable := _table;

end;</source>
        <Parameter name="_table" type="CM_EntryTable"/>
    </JadeMethod>
    <JadeMethod name="loadTable" id="95bc6526-0857-4bd1-98a1-0c95fb075f97">
        <updating/>
        <source>loadTable(_remoteDataObject : CM_RemoteDataObject input) : String updating;

vars

	tmpRow	: Integer;

begin

	if _remoteDataObject &lt;&gt; null then 
		if _remoteDataObject = self.myCurrentObject then
			self.isArray := true;
			_remoteDataObject.loadRemoteArray(self.myTable);
		else
			_remoteDataObject.loadRemoteTable(self.myTable);
			self.myCurrentObject := _remoteDataObject;
			self.allLoadedObjects.add(_remoteDataObject);
		endif;
	endif;
	if self.myTable.rows &gt; 1 then
		self.myTable.row := 2;
	endif;
	return self.getDescription();

end;</source>
        <Parameter name="_remoteDataObject" type="CM_RemoteDataObject" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="save" id="7fc67bfa-7fe0-4318-bac9-72730c39aaae">
        <updating/>
        <source>save() : Boolean updating;

vars

	strArray	: StringArray;
	rtnValue	: Boolean;
	

begin

	if self.myCurrentObject &lt;&gt; null then
		if self.isArray then
			create strArray transient;
			self.getArrayItemsFromTable(strArray);
			app.myTrxUA.trxUpdateRemoteDataArray(strArray, self.myCurrentObject, app.myPassport);
		else
			app.myTrxUA.trxUpdateRemoteData(self.myTable, self.myCurrentObject, CM_EntryTable.ColumnValue, app.myPassport);
		endif;
	endif;

epilog
	delete strArray;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
