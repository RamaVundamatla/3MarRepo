    <JadeMethod name="setVTMISTransaction4Proxy" id="5324b9ee-bdf9-48a8-8417-d3d82ea5a547">
        <updating/>
        <source>setVTMISTransaction4Proxy(_pxyVTMISTrans : HMS_VTMISTransaction) updating;
