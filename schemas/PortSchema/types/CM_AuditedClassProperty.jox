    <JadeMethod name="setForCreate" id="0a70db82-cf52-4ca0-a2d9-ee7e1dc694cf">
        <updating/>
        <source>setForCreate(_class : Class; _propName, _niceName : String; _isAudited : Boolean; _root : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     01 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.className		:= _class.name;
	self.isAudited		:= _isAudited;
	self.niceName		:= _niceName;
	self.propertyName	:= _propName;
	
	self.myRoot			:= _root;

end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_niceName" type="String"/>
        <Parameter name="_isAudited" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
</Class>
