    <JadeMethod name="getExtraInfo" id="16cb7d91-af65-4540-889c-2629cc48e79e">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 25/06/2018   cnwma1	ChangeRequest 38635: PEL1 - SAP Cancellations
// 13/07/2018   cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
// 29/11/2018   cnwma1  ChangeRequest 42118: PEL1 - Generate tax number and invoice date
// 08/12/2018   cnwma1  Bug 42441: PEL1 - Missing Estimation ID WSDL 1.2 - Autocollection
// 17/12/2018	cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
// 22/07/2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 21/10/2019 	cnwma1  Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
// 30/01/2020   cnwma1	Bug 48416: ADP - Invoice lines not going to expected cash invoice
// 03/09/2020   cnwma1  Bug 49996: ASPA - Voyage Group Code - Issues
// 16/12/2021   navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link
// 18/02/2022	navsrk20 ChangeRequest 52771: EUP - INV - Invoice Notes (UI)
// 7 Nov 2022 	navrk21 Bug 55204: MTN - Accural Type for Debtor is incorrect
// 05 Jun 2025 	navma1 	MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
vars

	haveTotal		  : Boolean;
	payment			  : CM_CashPayment;
	block 			  : CM_DataContainerBlock;
	statusChangeAudit : CM_Audit;
	debitTotal,
	cashTotal		  : Decimal[23,6];    //21.10.2019 cnwma1 TFS #47081
	estimationID 	  : String;
	bolNo             : String;
	vesselSet		  : CM_VesselSet;
	vessel            : CM_Vessel;
	vslStr            : String;
	voyage			  : CM_Voyage;
	invProcess		  : CM_InvoiceProcess; 
begin
	
	voyage 		:= self.myVoyage;					//16.12.2021 navma1 #52580
	invProcess	:= self.getMyInvoiceProcess();		//05.06.2025 navma1 #MTN-34114
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Invoice_GC), DC_Label, 1, self);
	block.addNewItem(self.sequenceNum.String, DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Debtor_GC), DC_Label, 1, self.debtor);
	block.addNewItem(self.debtor.name, DC_Data, 1, self.debtor);
	
	if self.invoiceType &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Type), DC_Label, 1, self.invoiceType);
		block.addNewItem(self.invoiceType.description, DC_Data, 1, self.invoiceType);
	endif;
	
	// PAR 16787
	block := _dataContainer.addNewBlock;
	block.addNewItem("Purchase Order Number", DC_Label, 1, self);
	block.addNewItem(self.purchaseOrderNumber, DC_Data, 1, self);
	
	// ### TFS CR 58085 TASK 61346 11JAN2024 NAVAB1
	block := _dataContainer.addNewBlock;
	block.addNewItem("Debtor Ref", DC_Label, 1, self);
	block.addNewItem(self.debtorReference, DC_Data, 1, self);
	
	
	if voyage &lt;&gt; null then		//16.12.2021 navma1 #52580
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_VoyageExtra), DC_Label, 1, voyage);
		block.addNewItem(voyage.code &amp; " (" &amp; voyage.vesselName.trimBlanks &amp; ")", DC_Data, 1, voyage);
	
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Voyage_Arrived), DC_Label, 1, voyage);
		if voyage.arrivedDT.isValid then
			block.addNewItem(self.systemToLocalTime(voyage.arrivedDT).String, DC_Data, 1, voyage);// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			block.addNewItem(app.getErrorString(CM_Not_Arrived), DC_Data, 1, voyage);
		endif;
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Voyage_Departed), DC_Label, 1, voyage);
		if voyage.departedDT.isValid then
			block.addNewItem(self.systemToLocalTime(voyage.departedDT).String, DC_Data, 1, voyage);// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			block.addNewItem(app.getErrorString(CM_Not_Departed), DC_Data, 1, voyage);
		endif;
	endif;
	if self.invoiceType &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Accural_Type), DC_Label, 1, self.invoiceType);
		block.addNewItem(self. invoiceType.getAccrualTypeDescDebtor(self.debtor) , DC_Data, 1, self.invoiceType);		// 07.11.2022 navrk21 TFS 55204
	endif;

	if self.debtor.myTermsOfTrade &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem('Terms of Trade', DC_Label, 1, self.debtor.myTermsOfTrade);
		block.addNewItem(self.debtor.myTermsOfTrade.description, DC_Data, 1, self.debtor.myTermsOfTrade);
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Start_date), DC_Label, 1, null); // PAR 33199 changed to START from FROM
	if fromDT.isValid then
		block.addNewItem(self.systemToLocalTime(self.fromDT).String, DC_Data, 1, null);// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		block.addNewItem(app.getErrorString(CM_NotApplicable), DC_Data, 1, null);
	endif;
	

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(EndDate), DC_Label, 1, null); // PAR 33199 changed to END from TO
	if toDT.isValid then
		block.addNewItem(self.systemToLocalTime(self.toDT).String, DC_Data, 1, null);// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		block.addNewItem(app.getErrorString(CM_NotApplicable), DC_Data, 1, null);
	endif;
	
	// PAR 33199
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getInvoiceStatusString(invProcess, CM_Invoice.INVOICE_POSTED), DC_Label, 1, null); // TFS 39618
	if postedDT.isValid then
		block.addNewItem(self.systemToLocalTime(postedDT).String, DC_Data, 1, null);// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		block.addNewItem(app.getErrorString(CM_NotApplicable), DC_Data, 1, null);
	endif;


	
	if invProcess.allStatuses[CM_Invoice.INVOICE_PENDING] &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getInvoiceStatusString(invProcess, CM_Invoice.INVOICE_PENDING), DC_Label, 1, null); // TFS 39618
		if self.pendingDT.isValid then
			block.addNewItem(self.systemToLocalTime(pendingDT).String, DC_Data, 1, null);// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			block.addNewItem(app.getErrorString(CM_NotApplicable), DC_Data, 1, null);
		endif;
	endif;
	
	if invProcess.allStatuses[CM_Invoice.INVOICE_PREPEND] &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getInvoiceStatusString(invProcess, CM_Invoice.INVOICE_PREPEND), DC_Label, 1, null); // TFS 39618
		if self.prependDT.isValid then
			block.addNewItem(self.systemToLocalTime(prependDT).String, DC_Data, 1, null);// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			block.addNewItem(app.getErrorString(CM_NotApplicable), DC_Data, 1, null);
		endif;
	endif;
		
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Invoice_Status), DC_Label, 1, null);
	//if self.status &lt;&gt; CM_Invoice.INVOICE_POSTED then
	if not self.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759	
		block.addNewItem(app.getErrorString(CM_Provisional_Accounts), DC_Data, 1, null);
	else
		block.addNewItem( app.getErrorString(CM_Final_Accounts), DC_Data, 1, null);
	endif;	

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Number_Of_Items), DC_Label, 1, null);
	block.addNewItem((self.invoiceLines.size + self.allCashPayments.size).String, DC_Data, 1, null);

	 // ### JIRA 35790 01SEP2025 NAVAB1
	if app.isSpecial() then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Total Amount Static (special)", DC_Warning, 1, null);
		debitTotal := self.totalAmount;
		block.addNewItem(debitTotal.userCurrencyFormat($CM_InvoiceMoney), DC_Data, 1, null);

		block := _dataContainer.addNewBlock;
		block.addNewItem("Total Amount Dynamic (special)", DC_Warning, 1, null);
		debitTotal := self.getTotalAmount();
		block.addNewItem(debitTotal.userCurrencyFormat($CM_InvoiceMoney), DC_Data, 1, null);
		haveTotal := true;
	
	else
		if self.invoiceLines.size &lt;= 1000 then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Total_Amount), DC_Label, 1, null);
			debitTotal := self.getTotalAmount();
			block.addNewItem(debitTotal.userCurrencyFormat($CM_InvoiceMoney), DC_Data, 1, null);
			haveTotal := true;
		endif;	
	endif;
	
	// cash system
	if self.allCashPayments.size &gt; 0 then
		foreach payment in self.allCashPayments do
			if payment.voided then                    //30.01.2020 cnwma1 #48416
				continue;
			endif;
			cashTotal := cashTotal + payment.cashValue;
		endforeach;
		block := _dataContainer.addNewBlock;
		block.addNewItem("Cash Payments", DC_Label, 1, null);
		block.addNewItem(cashTotal.userCurrencyFormat($CM_InvoiceMoney), DC_Data, 1, null);
		if haveTotal then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Balance", DC_Label, 1, null);
			block.addNewItem((debitTotal - cashTotal).userCurrencyFormat($CM_InvoiceMoney), DC_Data, 1, null);
		endif;
	endif;
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Zero_Rate), DC_Label, 1, self.invoiceType);
	block.addNewItem(self.isZeroRatedTax.getYesNo , DC_Data, 1, self.invoiceType);

	statusChangeAudit:=self.getLastStatusChangeAudit();
	if statusChangeAudit &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Status_change_reason_code), DC_Label, 1, null);
		block.addNewItem(statusChangeAudit.statusChangeReasonCode , DC_Data, 1, null);
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Status_change_reason), DC_Label, 1, null);
		block.addNewItem(statusChangeAudit.clearingRemarks  , DC_Data, 1, null);
		
	endif;
	//26.6.2018 cnwma1 TFS #38635
	if self.paymentCode &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Invoice_payment_code), DC_Label, 1, null);
		block.addNewItem(self.paymentCode , DC_Data, 1, null);
	endif;
	
	if voyage &lt;&gt; null then
		if not voyage.isUsingDefaultProcessJMT then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Invoice_payment_status), DC_Label, 1, null);
			block.addNewItem(self.getPaymentStatusStr , DC_Data, 1, null);
		endif;
	endif;
	//13.7.2018 cnwma1 TFS 39698
		
	//13.7.2018 cnwma1 TFS 39698
	if self.myCashReceipt &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Cash_receipt), DC_Label, 1, null);
		block.addNewItem(self.myCashReceipt.externalInvoiceNumber , DC_Data, 1, null);
	endif;
	//18.7.2018 cnwma1 TFS 39698
	if self.externalTaxNumber &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Tax_Number), DC_Label, 1, null);
		block.addNewItem(self.externalTaxNumber , DC_Data, 1, null);
		
		block := _dataContainer.addNewBlock;
		block.addNewItem("Tax Date", DC_Label, 1, null);
		block.addNewItem(self.systemToLocalTime(self.taxDT).String , DC_Data, 1, null);
	endif;
	
	//08.12.2018 cnwma1 Bug #42441
	if self.paymentType = PaymentType_AutoCollection then
		estimationID := self.getEstimationsStrings(Cr);
		if estimationID &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Auto Collection Estimate(s)" , DC_Label, 1, null);
			block.addNewItem(estimationID , DC_Data, 1, null);
		endif;
	endif;
	//17.12.2018 cnwma1 TFS #38638
	if self.kinerjaDT &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Kinerja Date", DC_Label, 1, null);
		block.addNewItem(self.systemToLocalTime(self.kinerjaDT).String , DC_Data, 1, null);
	endif;
	
	//13 May 2019	NDL	TFS 44651
	if self.myOriginalAddFeesInvoice &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Original_fees_invoice), DC_Label, 1, null);
		block.addNewItem(self.myOriginalAddFeesInvoice.sequenceNum.String  , DC_Data, 1, null);
	elseif self.myAdditionalFeesInvoice &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Additional_fees_invoice), DC_Label, 1, null);
		block.addNewItem(self.myAdditionalFeesInvoice.sequenceNum.String, DC_Data, 1, null);
	endif;
	
	//22.07.2019 cnwma1 TFS #45577
	if self.myBillingAddress &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Address), DC_Label, 1, null);
		block.addNewItem(self.myBillingAddress.code.String &amp; ' - ' &amp; self.myBillingAddress.description , DC_Data, 1, null);
	endif;
	
	//03.09.2020 cnwma1 #49996
	if self.myBOL &lt;&gt; null then
		if app.myRoot.isClientASPA or app.isDevelopmentSystem then
			create vesselSet transient;
			bolNo := self.myBOL.number;
			self.myTerminal.getVesselsFormBOLs(vesselSet, bolNo);
			block := _dataContainer.addNewBlock;
			foreach vessel in vesselSet discreteLock do
				vslStr := vslStr &amp;  vessel.name &amp; Cr;
			endforeach;
		block.addNewItem(app.getErrorString(Vessels), DC_Label, 1, vessel);
		block.addNewItem(vslStr,DC_Data,1,vessel);
		endif;
	endif;
	//03.09.2020 cnwma1 #49996
	
	//16.12.2021 navma1 #52580
	if not self.allWorkOrders.isEmpty then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(WorkOrder), DC_Label, 1, self.allWorkOrders.first);
		block.addNewItem(self.allWorkOrders.listString(Comma,CM_WorkOrder::id.name) , DC_Data, 1, self.allWorkOrders.first);
	endif;
	
	//18.02.2022 navsrk20 #52771
	if self.myInvoiceNote &lt;&gt; null and self.myInvoiceNote.note &lt;&gt; "" then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Notes_Internal_Use), DC_Label, 1, null);
		block.addNewItem(self.myInvoiceNote.internalOnly.String,DC_Data,1,null);
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Invoice_notes), DC_Label, 1, null);
		block.addNewItem(self.myInvoiceNote.note,DC_Data,1,null);
	endif;
	
	// ### TFS CR 58085 TASK 61346 11JAN2024 NAVAB1
	if self.isTASCreditNote then
		block := _dataContainer.addNewBlock;
		block.addNewItem("TAS Credit Note", DC_Label, 1, self);
		block.addNewItem("true",DC_Data,1,self);
	endif;
	if self.isTASInvoice then
		block := _dataContainer.addNewBlock;
		block.addNewItem("TAS Invoice", DC_Label, 1, self);
		block.addNewItem("true",DC_Data,1,self);
	endif;
	
	//22/01/2023	navkc1 CR 62038 Task 62039
	block := _dataContainer.addNewBlock;
	block.addNewItem("Context", DC_Label, 1, self);
	block.addNewItem(self.context, DC_Data,1,self);
epilog
	delete vesselSet;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
