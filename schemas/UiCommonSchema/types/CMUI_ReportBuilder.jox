    <JadeMethod name="lstFormats_lostFocus" id="401f7b4d-5c35-474b-87ca-f5bacc006801">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstFormats_lostFocus(table: Table input) updating;
// -------------------------------------------
// Created 29 October 2004 by cnwdvb1
// -------------------------------------------
////11/07/2018 	jlgns1	Bug 39368: STWO - Report Profile Issue
vars

begin
	self.myAssistant.listTableLostFocus(self.tblReportDtl, self.saveRowHeight, self.lstFormats, 'formatDescription', false);
	
	//this does what we want so we'll use it even though the name is wrong
