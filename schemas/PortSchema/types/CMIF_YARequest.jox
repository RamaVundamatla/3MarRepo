    <JadeMethod name="isAvGrade_Match" id="eefcbccb-fcaa-47ab-98a8-abb932e28367">
        <source>isAvGrade_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 26 May 2005 by cnwdvb1
// -------------------------------------------
vars
begin

	// Undefined availablility grade. Take a look
	if self.allAvailabilityGrades.isEmpty() then
		return true;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YARequest::isAvGrade_Compare, null);
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
