    <JadeMethod name="getVoyageFromCombo" id="51f5e5a6-3c28-47b0-8bdb-97a09684e337">
        <source>getVoyageFromCombo(pCode : String) : CM_Voyage;
//Used now that we have a string array in the voyage combo, instead of
//using the listObject of the combo control
vars
	code : String;
	int : Integer;
begin
	
	if pCode = null then
		return null;
	endif;

	int := 1;
	
	//Get string to left of tab character. If no tab then code
	//will remain the same as pCode
	code := pCode.scanUntil(Tab, int);
	/* PAR 34886 backed out PAR 33780
	if int = 0 then // PAR 33780 testing direct deliveries for PAR 33644 notice that could not create new cargo on NWNP
		int := 1;
		code := pCode.scanUntil(" ", int); 
	endif;
	*/
	
	code := code.trimRight;
	return self.myTerminal.lookupVoyage(code, null, false);
end;</source>
        <Parameter name="pCode" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="goToNavObjectByCode" id="36f288ca-ad37-4e37-8975-ad41b6ca3b84">
        <source>goToNavObjectByCode(pCode : String);
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navObject	: CMUI_NavigatorObject;
	
begin

	app.mousePointer := Window.MousePointer_HourGlass;

	navObject := app.myController.getNavObjectByCode(pCode);

