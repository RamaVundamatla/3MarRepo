	self.tblCargoGrouped.allSelectedObjects.copy(jdoArray);
	
	foreach jdo in jdoArray do
		if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then
			value.Collection.copy(tiArray);
		endif;
	endforeach;
	
	if tiArray.isNotEmpty() then
		self.myAssistant.showXTABSummaryDefinitionForm( tiArray, false, false, false, true );
	endif;
	
epilog
	delete jdoArray;
	delete tiArray;
end;</source>
