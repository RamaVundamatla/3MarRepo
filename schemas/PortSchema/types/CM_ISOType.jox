    <JadeMethod name="getPicture" id="fc85b813-eb2b-45d8-ae5a-1928d6f92546">
        <source>getPicture(_myTerminal : CM_Terminal) : Binary;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePicture : Binary;
begin
	if not _myTerminal.getConfig(ShowCargoPicture).Boolean then
		return null;
	endif;

	thePicture := app.myRoot.getConfig(PicCargo20Stand).Binary; // DEFAULT

	if (self.is20ftLong or self.is30ftLong) then
		if self.isFlat then
			thePicture := app.myRoot.getConfig(PicCargo20Flat).Binary;
		elseif self.isHalfHeight then
			thePicture := app.myRoot.getConfig(PicCargoPlatform).Binary;
		elseif self.isOpenTop then
			thePicture := app.myRoot.getConfig(PicCargo20Open).Binary;
		elseif self.isPorthole then
			thePicture := app.myRoot.getConfig(PicCargo20Reefer).Binary;
		elseif self.isIntegral then
			thePicture := app.myRoot.getConfig(PicCargo20Integ).Binary;
		elseif self.isReefer then
			thePicture := app.myRoot.getConfig(PicCargo20Integ).Binary;
		elseif self.isGeneral then
			thePicture := app.myRoot.getConfig(PicCargo20Stand).Binary;
		elseif self.isCrib then
			thePicture := app.myRoot.getConfig(PicCargo20Stand).Binary;
		elseif self.isTank then
			thePicture := app.myRoot.getConfig(PicCargoTank).Binary;
		elseif self.isMachinery then
			thePicture := app.myRoot.getConfig(PicCargoGen).Binary;
		elseif self.isGeneral then
			thePicture := app.myRoot.getConfig(PicCargo20Stand).Binary;
		endif;
	elseif (self.is40ftLong or self.is45ftLong or self.is53ftLong) then
		if self.isFlat then
			thePicture := app.myRoot.getConfig(PicCargo40Flat).Binary;
		elseif self.is9ft6High then
			if self.isIntegral then
				thePicture := app.myRoot.getConfig(PicCargo40Hinteg).Binary;
			else
				thePicture := app.myRoot.getConfig(PicCargo40Hi).Binary;
			endif;
		elseif self.isOpenTop then
			thePicture := app.myRoot.getConfig(PicCargo40Open).Binary;
		elseif self.isIntegral then
			thePicture := app.myRoot.getConfig(PicCargo40Integ).Binary;
		elseif self.isReefer then
			thePicture := app.myRoot.getConfig(PicCargo40Integ).Binary;
		elseif self.isGeneral then
			thePicture := app.myRoot.getConfig(PicCargo40Stand).Binary;
		elseif self.isCrib then
			thePicture := app.myRoot.getConfig(PicCargo40Stand).Binary;
		elseif self.isTank then
			thePicture := app.myRoot.getConfig(PicCargoTank).Binary;
		elseif self.isMachinery then
			thePicture := app.myRoot.getConfig(PicCargoGen).Binary;
		elseif self.isGeneral then
			thePicture := app.myRoot.getConfig(PicCargo40Stand).Binary;
		endif;
	endif;
	return thePicture;
end;</source>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
