<Class name="CMQF_ExpSeqSummary" id="5ff6d8c2-57f3-48de-b1f6-21ce211daebe">
    <superclass name="CMQF_TrackedItem"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="cbeadc2c-e097-4720-8774-5b819f1edd6c">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		17 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ti		:	CM_TrackedItem;
	sti		:	CMIF_SummaryTI;
	tiSet	:	CM_TISet;
	breakOut		: Boolean;	
begin
	create tiSet transient;
	//need a voyage
	if self.getMyVoyage &lt;&gt; null then
		//search ship
		foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not tiSet.includes(ti) then
					tiSet.add(ti);
					create sti transient;
					self.setupSummaryObject(sti, ti);
					_collection.add(sti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
			
		endforeach;
		//search onsite
		foreach ti in self.getMyVoyage.allOnsiteTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not tiSet.includes(ti) then
					tiSet.add(ti);
					create sti transient;
					self.setupSummaryObject(sti, ti);
					_collection.add(sti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;
	endif;
epilog
	delete tiSet;	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="513fd74e-f688-4f5e-ba78-5249dd607fbc">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		17 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars

begin
	if (not CM_Log.hasInstance(_ti)) and
		_ti.myParent = null and					//no children please
	   //(_ti.isExport or _ti.isRehandle or _ti.isSOB) and							// PAR #25021
	   (_ti.isExport or _ti.isTranshipOutbound or _ti.isRehandle or _ti.isSOB) and	// PAR #25021
	   inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupSummaryObject" id="008de8af-c648-43c1-97c7-7c5badbddbd5">
        <source>setupSummaryObject(_summaryTI: CMIF_SummaryTI io;_ti: CM_TrackedItem) protected;
// ---------------------------------------------------------------------------
// Created:		17 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	_summaryTI.setTI(_ti);
	_summaryTI.setSequenced(true);
	_summaryTI.setTIFields();
	_summaryTI.setSummaryFields();
end;</source>
        <access>protected</access>
        <Parameter name="_summaryTI" type="CMIF_SummaryTI" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
