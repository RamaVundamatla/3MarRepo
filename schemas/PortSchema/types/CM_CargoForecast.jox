    <JadeMethod name="validateMe" id="c9ef25a8-fc2a-41a3-a8c5-c3f25dfcc410">
        <source>validateMe() protected;
/*

Purpose:			Validates that our mandatory fields are set

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
04 April 2022	navpw1	Initial creation TFS: 53132
06 Sep 2022 navtnr20 ChangeRequest 54505: MTN - Optional fields for Cargo Forecast on Voyage and Train
*/
vars
	terminal : CM_Terminal;		//06.09.2022 navtnr20 54505
	required : String;			//06.09.2022 navtnr20 54505
	idx 	: Integer;			//06.09.2022 navtnr20 54505
begin
	if self.myCargoType = null and self.myCommodity = null then
		//app.raiseCMException1(REQUIRED_FIELD, "cargo-type or commodity", null, null);		// 08.09.2022 navak20 TFS 54505
		app.raiseCMException(Input_req_cargo_type_commodity, null, null);	// 08.09.2022 navak20 TFS 54505
	endif;

	//start	06.09.2022 navtnr20 54505
	if self.myParent &lt;&gt; null then
		terminal := self.myParent.getMyTerminal;
	endif;
	idx := 1;
	if terminal &lt;&gt; null then
		required := terminal.getConfig(CargoForecastReqdFields).String;
	endif;
	
	if self.totalQuantity = null and required.pos(ETRow_Quantity, idx) &lt;&gt; null then
		app.raiseCMException(Input_required_field_quantity, null, null);
	endif;
	idx := 1;
	if self.totalVolume = null and required.pos(ETRow_Volume, idx) &lt;&gt; null then
		app.raiseCMException(Input_required_field_volume, null, null);
	endif;
	idx := 1;
	if self.totalWeight = null and required.pos(ETRow_TotalWeight, idx) &lt;&gt; null then
		app.raiseCMException(Input_required_field_weight, null, null);
	endif;
	//end 06.09.2022 navtnr20 54505
	
	if self.mode = null then
		app.raiseCMException1(REQUIRED_FIELD, "mode", null, null);
	endif;
	
	//06.09.2022 navtnr20 54505
	/*if self.totalWeight = null then
		app.raiseCMException1(REQUIRED_FIELD, "total-weight", null, null);
	endif;*/
	//06.09.2022 navtnr20 54505
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
