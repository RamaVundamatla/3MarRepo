    <JadeMethod name="showYardAllocationForm" id="fe3b3107-4d31-49df-9bf9-e1647577856d">
        <source>showYardAllocationForm(_blockStack : CM_BlockStack; _group : CM_YATemplateGroup;  _yalloc : CM_YardAllocation; _masterMenuAction : CMUI_MenuAction; _baseForm : CM_BaseForm input);
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theForm : CMUI_YardAllocationFormNonMDI;
begin

	if app.msgBox("This dialog is being deimplemented in 7.7.1, Are you sure you want to continue?", 'Old Stuff', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	
	theForm := app.myYardAllocationMaintForm;
	
	if not global.isValidObject(theForm) then
		theForm := app.loadForm(CMUI_YardAllocationFormNonMDI, CMUI_Assistant, false, false, false, self.myTerminal, _masterMenuAction).CMUI_YardAllocationFormNonMDI;
		app.myYardAllocationMaintForm := theForm;
	endif;
	
	if theForm = null then
		return;
	endif;

	if _group &lt;&gt; null then
		theForm.myYATemplateGroup := _group;
	endif;
	
	//theForm.show();//23 oct 2008 cnwdz2 par18290
	

	_baseForm.myYardAllocationForm := theForm;
	theForm.setCurrent(_yalloc,false);
	
	if _blockStack &lt;&gt; null and _yalloc = null then
		theForm.setForBlockStack(_blockStack);
	endif;
	
	theForm.handleMenusForModalDisplay();
	theForm.show(); //23 oct 2008 cnwdz2 par18290
end;</source>
        <Parameter name="_blockStack" type="CM_BlockStack"/>
        <Parameter name="_group" type="CM_YATemplateGroup"/>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_baseForm" type="CM_BaseForm" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showYardGridAreasForm" id="d6816cd3-5762-4a2b-a22b-5203550ec2e9">
        <source>showYardGridAreasForm( _objs : ObjectArray; _viewMode : Integer; _masterMenuAction : CMUI_MenuAction; _extraStackHeight : Integer );

/*

Purpose:			Show Yard Grid Areas for given Grid Controllers.

Parameters:			_objs is a collection of location controllers.

Return Value:		


Date				Who		Reason
18 November 2008	consw1	Initial creation
16 June 2009		consw1	PAR 19913 - SFW1067 Rail Simplifications
10 November 2009	cnwphb1	PAR 21532 CCMS SFW 1025 - Add extra stack height parameter
*/

constants
	AddParametersMethod = "addParameters";
	
vars
	enqForm : Form;
	aClass : Class;
	assistClass : Class;
	jrw : Schema;
	
	area : CM_TerminalArea;
	gc : CM_GridController;
	minColumn, maxColumn : Integer;
	minRow, maxRow : Integer;
	obj : Object;
	ta : CM_TerminalArea;
	terminalAreas : CM_TerminalAreaSet;
	
begin
	
	jrw := rootSchema.getSchema("YardSchema");
	aClass := jrw.getClass("YRD_GridAreasForm");
	assistClass := jrw.getClass("YRD_Assistant");
	
	enqForm := app.loadForm(aClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if enqForm = null then
		return;
	endif;

	if _objs = null then
		return;
	endif;

	create terminalAreas transient;
	
	foreach obj in _objs where obj.isKindOf(CM_GridController) do
		gc := obj.CM_GridController;
		if area = null then
			area := gc.myTerminalArea;
			minRow := gc.row;
			maxRow := gc.row;
			minColumn := gc.column;
			maxColumn := gc.column;
		elseif gc.myTerminalArea = area then
			minRow := minRow.min(gc.row);
			maxRow := maxRow.max(gc.row);
			minColumn := minColumn.min(gc.column);
			maxColumn := maxColumn.max(gc.column);
		elseif not terminalAreas.includes(gc.myTerminalArea) then
			terminalAreas.add(gc.myTerminalArea);
		endif;
	endforeach;
	
	if area = null then
		return;
	endif;

	enqForm.sendMsgWithParams( AddParametersMethod, area, minRow, maxRow, minColumn, maxColumn, _viewMode, _extraStackHeight );	// PAR 21532 CCMS SFW 1025
	
	if not terminalAreas.isEmpty then
		foreach ta in terminalAreas do
			area := null;
			foreach obj in _objs where obj.isKindOf(CM_GridController) and obj.CM_GridController.myTerminalArea = ta do
				gc := obj.CM_GridController;
				if area = null then
					area := ta;
					minRow := gc.row;
					maxRow := gc.row;
					minColumn := gc.column;
					maxColumn := gc.column;
				else
					minRow := minRow.min(gc.row);
					maxRow := maxRow.max(gc.row);
					minColumn := minColumn.min(gc.column);
					maxColumn := maxColumn.max(gc.column);
				endif;
			endforeach;
			enqForm.sendMsgWithParams( AddParametersMethod, area, minRow, maxRow, minColumn, maxColumn, _viewMode, _extraStackHeight );	// PAR 21532 CCMS SFW 1025
		endforeach;
	endif;

	enqForm.show(); 
	
epilog
	delete terminalAreas;
end;</source>
        <Parameter name="_objs" type="ObjectArray"/>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_extraStackHeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showYardGridAreasMultiArea" id="e2a0d47d-5ab6-45b3-b79e-ead143fa4858">
        <source>showYardGridAreasMultiArea( _objs : ObjectArray; _viewMode : Integer; _masterMenuAction : CMUI_MenuAction; _extraStackHeight : Integer );

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2018	jlgndl1	Initial creation  Testing TFS 36566

*/

constants

	AddParametersMethod = "addParameters";
	
vars

	enqForm : Form;
	aClass : Class;
	assistClass : Class;
	aSchema : Schema;
	
	area : CM_TerminalArea;
	gc : CM_GridController;
	topEdge : Integer;	// minimum column value
	bottomEdge : Integer;	// maximum column value
	leftEdge : Integer;  // minimum row value
	rightEdge : Integer;	// maximum row value
	obj : Object;
	ta : CM_TerminalArea;
	terminalAreas : CM_TerminalAreaSet;
	
	localGridControllers : CM_GridControllersByAreaColRow;
	taGCsToProcess : CM_GridControllersByAreaColRow;
	first : Boolean;
	prevRightEdge : Integer;
	
begin

	if _objs = null or _objs.isEmpty then
		return;
	endif;

	create terminalAreas transient;
	create localGridControllers transient;
	create taGCsToProcess transient;
	
	//create a local collection with just GC location controllers
	//and create a collection of Terminal areas.
	foreach obj in _objs where obj.isKindOf(CM_GridController) do
		gc := obj.CM_GridController;
		area := gc.myTerminalArea;
		if area = null then
			continue;
		endif;
		localGridControllers.addNoDuplicates( gc, false );
		
		if not terminalAreas.includes(area) then
			terminalAreas.add(area);
		endif;
	endforeach;
	
	if terminalAreas.isEmpty or localGridControllers.isEmpty then
		//nothing to do
		return;
	endif;
	
	//create the form
	aSchema := rootSchema.getSchema("YardSchema");
	aClass := aSchema.getClass("YRD_GridAreasForm");
	assistClass := aSchema.getClass("YRD_Assistant");
	enqForm := app.loadForm(aClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if enqForm = null then
		return;
	endif;

	//within each terminal area selected, find individual rectangular areas of location controllers
	//these will be individually displayed.
	// I.e. if a user choese two selected rectangles within a bigger terminal area,
	//the two small areas should be diplayed on individual panelks
	
	foreach ta in terminalAreas do
	
		while true do
		
			//build a local collection of all gc's for this terminal area
			//that have not yet been displayed.
			taGCsToProcess.clear();
			foreach gc in localGridControllers where gc.myTerminalArea = ta do
				taGCsToProcess.add( gc );
			endforeach;
			
			if taGCsToProcess.isEmpty then
				// We have no more to process for this terminal area.
				// break the while loop, so we try the next terminal area if there is one.
				break;
			endif;
			
			//we now have a coll of all GCs for this TA only.
			first := true;
			foreach gc in taGCsToProcess do	
			
				//write method.qualifiedName &amp; " " &amp; gc.row.String &amp; "," &amp; gc.column.String;
				if first then
					//we have the first gc in this rectangle, i.e. top left corner - set base info
					leftEdge := gc.row;  // left hand end
					rightEdge := gc.row;	// right hand end
					topEdge := gc.column; // top
					bottomEdge := gc.column;	// bottom
					prevRightEdge := gc.row; // last row proccessed.
					first := false;
					//write "first cell in the rectangle";
					continue; // to get the next gc.
					
				else
					if topEdge = gc.column then	// this gc is on the same line as the first gc
													// so we are looking for the last contiguous gc to the right of the first one
													// i.e. looking for the right hand end ( maxRow )
						if rightEdge + 1 = gc.row then
							// area still contiguous, becuase only 1 greater than the last gc on the first row
							// so increment the right hand value.
							rightEdge := gc.row;
							prevRightEdge := gc.row;
							//write "top contiguous";
							continue;
						else
							//still in the first line but no longer contiguous
							//write "top NOT contiguous";
							continue;
						endif;
						
					elseif bottomEdge + 1 = gc.column then // we have just skipped to the next line in the display
						// have just skipped down a single line in the dispay
						if leftEdge &lt;&gt; gc.row then
							//this one doesn't start at the same place as our rectangle, so must be a differnt rectangle.
							//time to display what we have up until this one
							//write "New Line, starts early - break";
							break;
						endif;
						if prevRightEdge &lt; rightEdge then
							//last one didn't get to the same place on the line as us, so this one is part of a different rectangle
							//time to display what we have up until this one
							//write "New Line, last line short - break";
							break;
						endif;
						
						// All good so far increment the bottom value
						prevRightEdge := gc.row;
						bottomEdge := gc.column;
						
					elseif bottomEdge = gc.column then	// we are in the 'current' bottom line of the rectangle 
						if prevRightEdge + 1 &lt;&gt; gc.row and prevRightEdge + 1  &lt;= rightEdge then
							bottomEdge := bottomEdge - 1;
							//write "right NOT contiguous we have a gap - prev right edge &lt;&gt; +1 ";
							break;
						endif;
						prevRightEdge := gc.row;	// record how far right we are
						
						if rightEdge &lt; gc.row then
							//outside our area of our rectangle too far right.
							//write "right NOT contiguous";
							continue;
						endif;
						//write "all good, in the zone...";

					endif;

				endif;
				
			endforeach;
			
			//At this point the min max values contain all the info we need to send to teh form
			// Tell the Main collection to get rid of teh gc controllers within the area that we ar eabout to
			// display, so that we don't look at thenm again when building up the next area to consider.
			localGridControllers.removeMatching( ta, leftEdge, rightEdge, topEdge, bottomEdge );

			//write "Display rectangle left, right = " &amp; leftEdge.String &amp; "," &amp; rightEdge.String &amp; "  top, bottom = " &amp; topEdge.String &amp; "," &amp; bottomEdge.String;			
			//tell teh form to display this rectangle.
			enqForm.sendMsgWithParams( AddParametersMethod, ta, leftEdge, rightEdge, topEdge, bottomEdge, _viewMode, _extraStackHeight );	// PAR 21532 CCMS SFW 1025
			
			if localGridControllers.isEmpty then
				break; // the endwhile
			endif;
		
		endwhile;
		
		if localGridControllers.isEmpty then
			break; // the endforeach
		endif;
		
	endforeach;
	
	enqForm.show(); 
	
epilog

	delete terminalAreas;
	delete localGridControllers;
	delete taGCsToProcess;
	
end;</source>
        <Parameter name="_objs" type="ObjectArray"/>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_extraStackHeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showYardLocationFromTI" id="0e363e35-d171-4359-8cc9-406e024bdb09">
        <source>showYardLocationFromTI(_ti : CM_TrackedItem; _masterMenuAction : CMUI_MenuAction);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2009	cnwphb1	Initial creation (PAR 21532 CCMS SFW 1025)

*/

vars
	theLC		: CM_LocationsController;
	theTA		: CM_TerminalArea;
	aForm		: CM_BaseForm;
	menuAction	: CMUI_MenuAction;
	theArea		: CM_TerminalArea;
	theTerminalArea	: CM_GridArea;
begin
	theLC := _ti.getPrimaryLocation(REAL_MODE);
	if theLC = null then
		return;
	endif;
	
	theTA := theLC.myTerminalArea;
	
	if theTA = null then
		return;
	endif;
	
	if theTA.isKindOf(CM_GridArea) then
		theTerminalArea := theTA.CM_GridArea;
		menuAction := app.myController.createMenuAction(PmYardAreaView, null, _masterMenuAction, self.myTerminal);
		if menuAction = null then
			return;
		endif;
		aForm := menuAction.goToObject(null, null, false, null).CM_BaseForm; 
		if aForm = null then
			return;
		endif;
		aForm.doInitializeWithTI(theTerminalArea,theLC,_ti);
		aForm.show;	
	elseif theTA.isKindOf(CM_Rail) then
	elseif theTA.isKindOf(CM_Pack) then
	
		menuAction := app.myController.createMenuAction(PmAdmLclpackView, null, _masterMenuAction, self.myTerminal);
		if menuAction = null then
			return;
		endif;
		aForm := menuAction.goToObject(null, null, false, null).CM_BaseForm; 
		if aForm = null then
			return;
		endif;
		aForm.show;	
	elseif theTA.isKindOf(CM_Building) then
	else			
		theArea := theTA;
		menuAction := app.myController.createMenuAction(PmYardLocationEnqView, null, _masterMenuAction, self.myTerminal);
		if menuAction = null then
			return;
		endif;
		aForm := menuAction.goToObject(null, null, false, null).CM_BaseForm; 
		if aForm = null then
			return;
		endif;
		aForm.sendMsgWithParams("showWithObject",theArea, false, false);
		aForm.show;	
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showYardRowEnquiryForm" id="e6508e36-cc3a-4c29-be03-b853370a0d78">
        <source>showYardRowEnquiryForm(_objs : ObjectSet; _masterMenuAction : CMUI_MenuAction; _enq : CM_EnquiryController; _clearUp : Boolean; _view : Integer; _move : Integer; _train : CM_Train);
// ---------------------------------------------------------------------------
// Created:		September 2005 By Andrew Bishop cnwab1
//
// Purpose:		#### NOTE ##### from the calling method DO NOT delete your '_objs : ObjectSet', that is delt with by the assistant!
//
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	enqForm : Form;
	aClass : Class;
	assistClass : Class;
	jrw : Schema;
	rowStr	: String;
	obj : Object;
	gRow : CM_GridRow;
	rows : CM_ObjectArray;
begin
	jrw := rootSchema.getSchema("YardSchema");
	aClass := jrw.getClass("YRD_GridAreaEnquiryForm");
	assistClass := jrw.getClass("YRD_Assistant");
	
	enqForm := app.loadForm(aClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if enqForm = null then
		return;
	endif;

	if _objs = null or  _objs.isEmpty then
		app.msgBox(app.getErrorString(Please_select_cargo_enquire),app.getErrorString(Yard_enquiry_error),MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	obj := _objs.first;
	if obj.isKindOf(CM_TrackedItem) then
		rows := self.getRowsFromTIs(_objs);
	else
		create rows transient;
		_objs.copy(rows);
	endif;

	if rows = null or  rows.isEmpty then
		app.msgBox(app.getErrorString(No_Cargo_found_yard),app.getErrorString(Yard_enquiry_error),MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	foreach obj in rows do
		gRow := obj.CM_GridRow;
		if rowStr = null then
			rowStr := gRow.myGridArea.id &amp; "/" &amp; gRow.label.trimBlanks;
		else
			rowStr := rowStr &amp; "/" &amp; gRow.myGridArea.id &amp; " " &amp; gRow.label.trimBlanks;
		endif;
	endforeach;
	
	enqForm.setPropertyValue("rowStr", rowStr);	
	enqForm.setPropertyValue("mySelectorEnquiryController", _enq);	
	enqForm.setPropertyValue("clearupSelectorQuery", _clearUp);	// DELETE CM_EnquiryController on close of Yard Row Enq form
	
	enqForm.setPropertyValue("onlySelectSelectorTIs", true);	
	
	// PAR 19913
	enqForm.setPropertyValue("initView", _view);
	enqForm.setPropertyValue("initMoveMode", _move); // index for PLANNING_MODE
	enqForm.setPropertyValue("myCurrentTrain", _train); 
	
	
	// #### NOTE ##### from the calling method DO NOT delete your '_objs : ObjectSet', that is delt with by the assistant!
	enqForm.userObject := _objs;
	enqForm.show(); 
	
epilog
	delete rows;
end;</source>
        <Parameter name="_objs" type="ObjectSet"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_enq" type="CM_EnquiryController"/>
        <Parameter name="_clearUp" type="Boolean"/>
        <Parameter name="_view" type="Integer"/>
        <Parameter name="_move" type="Integer"/>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="stopsListTableLostFocus" id="4278edba-3ab5-49b3-96aa-a102f791fc6c">
        <source>stopsListTableLostFocus(
	_table		: CM_EntryTable input;
	_saveHeight	: Real io;
	_listTable	: CMUI_StopsListTable );

/*
Date				Who		Reason
21 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	theRow			: Integer;
	entryTable		: CM_EntryTable;
	stopsListTable	: CMUI_StopsListTable;
	
begin
	entryTable		:= _table;
	stopsListTable	:= _listTable;
	theRow			:= entryTable.getRowByControlName( stopsListTable.name );
	
	if theRow &lt;= entryTable.fixedRows or theRow &gt; entryTable.rows then
		return;
	endif;
	
	entryTable.accessRow( theRow ).height	:= _saveHeight.Integer;
	stopsListTable.height					:= _saveHeight.Integer; 
	_saveHeight								:= 0;	// set to 0 so that can use in tbl.cellInputReady;
	entryTable.scrollBars					:= Table.ScrollBars_Both;
	
	entryTable.setValue( theRow, stopsListTable.getDisplayStringOfStops );
	
epilog
	
end;
</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_saveHeight" type="Real" usage="io"/>
        <Parameter name="_listTable" type="CMUI_StopsListTable"/>
    </JadeMethod>
    <JadeMethod name="stringsTableLostFocus" id="5d4c46b6-de98-474f-a18a-f8665306e00f">
        <source>stringsTableLostFocus(_table : CM_EntryTable input; _saveHeight : Real io; _stringsTable : CM_Table);

/*

Purpose:			Handle a lostFocus event for a strings table inside a CM_EntryTable
					by getting the string values and setting the value of the row from the 
					strings table

Return Value:		None


Date		Who		Reason
07 Sep 2004	by Jason Chapman  (cnwjc2)
26 May 2008	cnwkpd1	PAR #17183 - Rework to split out parent table row resizing

*/

vars
	theRow,
	idx			: Integer;
	str,
	tmpStr		: String;
	intRow		: Integer;
	entRowTrans	: EntTableRowTransient;

begin
	theRow := _table.getRowByControlName(_stringsTable.name);

	if (theRow &gt; _table.fixedRows) and (theRow &lt;= _table.rows) then
		_table.scrollBars := Table.ScrollBars_Both;
		
		foreach intRow in _stringsTable.fixedRows to _stringsTable.rows do
			tmpStr := _stringsTable.getCellText(intRow, 1).trimBlanks;
			if tmpStr = null then
				continue;
			endif;
			if str = null then
				str := tmpStr;	
			else
				str := str &amp; ', ' &amp; tmpStr;
			endif;
		endforeach;
		
		//+cnwml2 PAR24416
		entRowTrans := _table.accessRow(theRow).itemObject.EntTableRowTransient;
		if entRowTrans &lt;&gt; null then
			if entRowTrans.originalValue &lt;&gt; str then
				entRowTrans.hasChanged := true;
			else
				entRowTrans.hasChanged := false;
			endif;
		endif;
		_table.setValue(theRow, str);
	endif;
	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_saveHeight" type="Real" usage="io"/>
        <Parameter name="_stringsTable" type="CM_Table"/>
    </JadeMethod>
    <JadeMethod name="stringsTableQueryRowChange" id="0209a131-b414-4232-ab8d-ae41218f7721">
        <source>stringsTableQueryRowChange(_table : CM_EntryTable input; _saveHeight : Real io; _stringsTable : CM_Table);

/*

Purpose:			Handle a queryRowChange event for a CM_EntryTable from a strings table cell
					by calling the lostFocus code for the strings table, and restoring the entry table
					cell to its saved size
					
Return Value:		None


Date		Who		Reason
26 May 2008	cnwkpd1	PAR #17183 - Rework to split out parent table row resizing

*/

vars
	theRow		: Integer;

begin
	// First save off entered strings
	self.stringsTableLostFocus(_table, _saveHeight, _stringsTable);
	
	// Then restore the saved row height
	theRow := _table.getRowByControlName(_stringsTable.name);

	if (theRow &gt; _table.fixedRows) and (theRow &lt;= _table.rows) then
		_table.accessRow(theRow).height := _saveHeight.Integer;
		_saveHeight := 0;		// set to 0 so that can use in pTable.cellInputReady;
		_table.scrollBars := Table.ScrollBars_Both;
	endif;
	
	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_saveHeight" type="Real" usage="io"/>
        <Parameter name="_stringsTable" type="CM_Table"/>
    </JadeMethod>
    <JadeMethod name="tblImexStatus" id="f7414ed9-d6d7-4233-9ce8-d217224ddbef">
        <source>tblImexStatus(pTbl : CM_EntryTable input; pAttrName : String);
// ---------------------------------------------------------------------------
// Created:     02 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStatus	: CM_IMEXStatus;
	str			: String;
	
begin

	foreach tmpStatus in app.myRoot.allImexStatuses do
		str := str &amp; tmpStatus.description &amp; Tab;
	endforeach;
	//Remove last tab
	if str.length &gt; 0 and str[str.length] = Tab then
		str := str[1:str.length-1];
	endif;

	pTbl.setComboValues(pTbl.getRow(pAttrName), str);
						
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
    </JadeMethod>
    <JadeMethod name="tblVoyageStats" id="95a96e86-6fba-4226-aedf-e785e467beb8">
        <source>tblVoyageStats(_table : CM_DataTable input; _voyageStats : CMIF_VoyageStats input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	entDef : EntTableDef;
	jobStats : CMIF_JobSheetStats;
	entRow : EntTableRow;
	str : String;
	idx, colour, invColour : Integer;
	tableRow : JadeTableRow;
	crane: CM_Crane;
begin
	entDef:=app.myController.getEntTableDef(ETDef_VoyageStats);
	_table.clear;
	
	_table.setTblDataEntRowsFromDef(entDef);
	_table.stretchWidth := true;
	_table.stretchHeight := true;
	_table.userInputEnabled := true;
	foreach jobStats in _voyageStats.allJobSheetStats do
		crane:=jobStats.myJobSheet.CM_VoyageJobSheet.getMyCrane;
		if crane = null then
			continue;
		endif;
		str:=null;
		foreach entRow in entDef.allEntTableRows do
			str:=str  &amp; jobStats.getDisplayStringForAttribute(entRow.name,false) &amp; Tab;
		endforeach;
		idx :=_table.addItem(str);
		tableRow:=_table.accessRow(idx);
	
		colour:=crane.colour;
		invColour:=colour.getInverseColour;
		tableRow.backColor:=colour;
		tableRow.foreColor:=invColour;

		tableRow.itemObject := crane;
	endforeach;
	_table.resetHeight;
	_table.height:=_table.height + 2;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_voyageStats" type="CMIF_VoyageStats" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tisByProduct" id="8f702348-f566-4431-8053-6f91beeea319">
        <source>tisByProduct(	_product	: CM_Product; 
				_allItems 	: CM_TIArray input);
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     CNWTH2 reminder - in future may need to pass in allLocControllers to not include/include
//				to filter SOHLocations
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti				: CM_TrackedItem;
	sohLoc			: CM_SOHLocation;
	tiId			: String;
	found			: Boolean;
begin
	
	if _product = null then
		return;
	endif;
	
	if _allItems = null then
		return;
	endif;
	
	_allItems.clear();
	
	foreach sohLoc in _product.allSOHLocations discreteLock do
		/*
		if (not _availableLocations.includesKey(sohLoc.myLocationsController.CM_WarehouseRowController.id)) then
			continue;
		endif;
		*/
		foreach ti in sohLoc.allTrackedItems discreteLock 
			where ti.state &lt;&gt; TI_STATE_DELETED do // AKB2004NOV
			if ti.myParent &lt;&gt; null or
			   ti.myStockOrderTILine &lt;&gt; null then
				continue;
			endif;
			
			_allItems.add(ti);
		endforeach;
	endforeach;
	
	
end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_allItems" type="CM_TIArray" usage="input"/>
    </JadeMethod>
