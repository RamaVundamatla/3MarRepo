/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation

*/

vars

begin
	if self.checkChanged then	// 26608 Dec 2010 snap shot definition form issues
		self.cmbDefinition.listIndex := self.cmbDefinition.findObject(self.myCM_OutputFormat_SS);
		return;
	endif;
	self.hasChanged := false;
	self.resetFirstChange();

	self.myCM_OutputFormat_SS := cmbDefinition.listObject.CM_OutputFormat_SS;
	createMyProxyFormat( self.myCM_OutputFormat_SS );
	self.loadModeCombo();
	self.loadData();
epilog

end;</source>
