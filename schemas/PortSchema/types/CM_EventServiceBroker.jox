    <JadeMethod name="auditIdDisplay" id="33bd6729-e820-4a1e-8ba7-dd083fe04580">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jan 2017	cnwma1	Initial creation
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/


vars
	auditIdStr : String;
begin
	auditIdStr := self.auditId();								//31.03.2025 navma1 #MTN-34387
	
	if auditIdStr &lt;&gt; null then
		return 'Event Map' &amp; ' - ' &amp; auditIdStr;
	else
		return 'Event Map';
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="637bf137-7ba6-419c-9da6-c06287fbf539">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
	txt,
	tmpStr	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	tmpStr := self.getTranMapBreadCrumb;
	txt := txt &amp; 'Item Path' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	if self.myTranMap &lt;&gt; null then
		tmpStr := self.getEventClassName;
		txt := txt &amp; 'Event Type' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myTranMap.getBank &lt;&gt; null then
		tmpStr := self.myTranMap.getBank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	
	return txt;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="ceddd7ff-fb36-4a3e-b856-c32de6c448a1">
        <source>getBank() : CM_Bank;
