    <JadeMethod name="addGridLocation" id="a009f68f-7d90-432e-a915-4886022b1ac8">
        <source>addGridLocation(_row, _col : Integer; _lc : CM_LocationsController) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	key : String;
	gl  : CMIF_RDTGridLocation;
begin
	if _lc = null then
		return;
	endif;
	create gl transient;
	gl.row := _row;
	gl.col := _col;
	
	key := _lc.getOidAsString();
	self.addObjectForKey(self.allGridLocationsByLCoid, key, gl);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="addLocation" id="44e5011c-4abd-4b33-892b-ce1d785cbcfb">
        <source>addLocation(_row, _col : Integer; _lc : CMIF_RDTLocationDrawElement input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	key : String;
begin
	key := self.getRowColKey(_row, _col);
	_lc.setKey(key);
	_lc.initSizesOffsets(self.lcLeftGridOffsetFt, self.lcTopGridOffsetFt, self.lcWidthFt, self.lcHeightFt);					
	self.addObjectForKey(self.allLCsByGridPos, key, _lc);
	// Also add a mapping from location controller oid to the grid location - note that this mapping is only 
	// used for non-grided area to go from the target location to the grid square that it is residing in
	self.addGridLocation(_row, _col, _lc.myLocationsController);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_lc" type="CMIF_RDTLocationDrawElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addLocationWithHeight" id="dc7cdc3d-07d9-4f9c-a621-6328b3c99c5c">
        <source>addLocationWithHeight(_row, _col, _height : Integer; _lc : CMIF_RDTLocationDrawElement input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	key : String;
begin
	key := self.getRowColHeightKey(_row, _col, _height);
	_lc.setKey(key);
	
	//if _lc.myLocationsController.isKindOf(CM_GridController) then
	//	write method.name &amp; " key =&gt; lc: " &amp; key &amp; "=&gt;" &amp; _lc.myLocationsController.CM_GridController.getFullId();
	//endif;
	
	
	_lc.initSizesOffsets(self.lcLeftGridOffsetFt, self.lcTopGridOffsetFt, self.lcWidthFt, self.lcHeightFt);					
	self.addObjectForKey(self.allLCsByGridPos, key, _lc);
	// Also add a mapping from location controller oid to the grid location - note that this mapping is only 
	// used for non-grided area to go from the target location to the grid square that it is residing in
	self.addGridLocation(_row, _col, _lc.myLocationsController);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_lc" type="CMIF_RDTLocationDrawElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addObjectForKey" id="3d373090-0462-483a-a2d5-a192d66581f7">
        <source>addObjectForKey(_dict : CM_ExtKeyDictionary; _key : String; _obj : Object) : Object protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if _dict = null then
		return null;
	endif;
	
	
	_dict[_key] := _obj;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dict" type="CM_ExtKeyDictionary"/>
        <Parameter name="_key" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="addTI" id="aa918642-22f9-41e0-b1df-3eb0f1da40d7">
        <source>addTI(_row, _col : Integer; _ti : CMIF_RDTTIDrawElement input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	key : String;
begin
	key := self.getRowColKey(_row, _col);
	_ti.setKey(key);
	if self.mode = CMIF_RDTDrawElement.MODE_END then
		// Make it square...
		_ti.initSizesOffsets(self.tiLeftGridOffsetFt, self.tiTopGridOffsetFt, self.getWidthOfTIInFt(_ti.myTI), self.getWidthOfTIInFt(_ti.myTI));	
	else
		_ti.initSizesOffsets(self.tiLeftGridOffsetFt, self.tiTopGridOffsetFt, self.getWidthOfTIInFt(_ti.myTI), self.getLengthOfTIInFt(_ti.myTI));	
	endif;
	self.addObjectForKey(self.allTIsByGridPos, key, _ti);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_ti" type="CMIF_RDTTIDrawElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="build" id="cda70060-1d41-4b5d-9d1a-565c8dee9be8">
        <updating/>
        <source>build(_mode : Integer; _lc : CM_LocationsController; _ta : CM_TerminalArea; _leftCol, _rightCol, _topRow, _bottomRow : Integer; _scaleFactor : Real; _isLandscape, _flipH, _flipV : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars

begin
	self.validateModeAndFlip(_mode, _flipH, _flipV);
	self.mode := _mode;	
	self.clear();
	self.myTerminalArea := _ta;
	
	if mode = CMIF_RDTDrawElement.MODE_TOPDOWN then
		if _isLandscape then
			self.buildLandscapeTopDown(_lc, _ta, _leftCol, _rightCol, _topRow, _bottomRow, _scaleFactor);
		else
			self.buildPortraitTopDown(_lc, _ta, _leftCol, _rightCol, _topRow, _bottomRow, _scaleFactor);
		endif;
	elseif mode = CMIF_RDTDrawElement.MODE_FACE then
		if _isLandscape then
			self.buildLandscapeFace(_lc, _ta, _leftCol, _rightCol, _topRow, _bottomRow, _scaleFactor);
		else
			self.buildPortraitFace(_lc, _ta, _leftCol, _rightCol, _topRow, _bottomRow, _scaleFactor);
		endif;
	elseif mode = CMIF_RDTDrawElement.MODE_END then
		if _isLandscape then
			self.buildLandscapeEnd(_lc, _ta, _leftCol, _rightCol, _topRow, _bottomRow, _scaleFactor);
		else
			self.buildPortraitEnd(_lc, _ta, _leftCol, _rightCol, _topRow, _bottomRow, _scaleFactor);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_leftCol" type="Integer"/>
        <Parameter name="_rightCol" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
    </JadeMethod>
