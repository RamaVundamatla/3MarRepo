    <JadeMethod name="sysNotify" id="453d6dbf-2c20-4ebd-b161-2e2f4362d56c">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwns1	Initial creation

*/

vars

begin
	self.handleNotification(eventType, theObject, eventTag);
	//self.handleNotifications(eventType, theObject, eventTag, null);	// ### TFS 54311 18Oct2022 NAVPW1
epilog

end;</source>
