    <JadeMethod name="cmbTerminalAreaClick" id="257673a8-468e-4f27-b0ae-7c19f9e7dc63">
        <source>cmbTerminalAreaClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS	50906

*/

vars

	obj : Object;
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
	lcSet : CM_LCSet;
	index : Integer;

begin

	if self.cmbTerminalArea.listIndex &gt; 0 then
		ta := self.cmbTerminalArea.itemObject[  self.cmbTerminalArea.listIndex ].CM_TerminalArea;
	endif;
	
	self.cmbLocation.clear();
	self.cmbLocation.enabled := true;
	
	if ta &lt;&gt; null then
		if ta.isKindOf(CM_GeneralCargoAllocRowArea) then	//15 Jun 2021	NDL	TFS 51336
			create lcSet transient;
			ta.CM_GeneralCargoAllocRowArea.getAllRowGroupControllers( lcSet );
		else
			lcSet := ta.getLCSet();
		endif;
		foreach lc in lcSet discreteLock do
			index := self.cmbLocation.addItem( lc.getFullId() );
			self.cmbLocation.itemObject[index] := lc;
		endforeach;
		if self.cmbLocation.listCount = 1 then
			 self.cmbLocation.listIndex := 1;
			 self.cmbLocation.enabled := false;
		endif;
	
	else
		self.cmbLocation.enabled := false;
		
	endif;
	
	self.resetCmbCargoTypeOperator();
	
	self.enableButtons();

epilog

	if lcSet &lt;&gt; null and lcSet.isTransient then
		delete lcSet;
	endif;

end;</source>
    </JadeMethod>
