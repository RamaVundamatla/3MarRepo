    <JadeMethod name="translateForm" id="7273398d-d148-47d3-8302-2a352a7c74d5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014055, locale);
	btnAdd.translateCaption(Xlat_0014056, locale);
	btnAddDest.translateCaption(Xlat_0014057, locale);
	btnClear.translateCaption(Xlat_0014058, locale);
	btnDelete.translateCaption(Xlat_0014059, locale);
	btnDeleteDest.translateCaption(Xlat_0014060, locale);
	btnEdit.translateCaption(Xlat_0014061, locale);
	btnEditDest.translateCaption(Xlat_0014062, locale);
	btnSave.translateCaption(Xlat_0014063, locale);
	chxAutoAssign.translateCaption(Xlat_0014064, locale);
	chxAutoUnassign.translateCaption(Xlat_0014065, locale);
	grpDestination.translateCaption(Xlat_0014066, locale);
	grpReleaseDetail.translateCaption(Xlat_0014067, locale);
	grpSource.translateCaption(Xlat_0014068, locale);
	lblConsignee.translateCaption(Xlat_0014069, locale);
	lblConsignorVoy.translateCaption(Xlat_0014070, locale);
	lblDefaultGate.translateCaption(Xlat_0014071, locale);
	lblDefaultLane.translateCaption(Xlat_0014072, locale);
	lblDeliveryReasn.translateCaption(Xlat_0014073, locale);
	lblReleaseNum.translateCaption(Xlat_0014074, locale);
	lblSelectedTermA.translateCaption(Xlat_0014075, locale);
	lblSubTerminal.translateCaption(Xlat_0014076, locale);
	lbl_configName.translateCaption(Xlat_0014077, locale);
end;</source>
    </JadeMethod>
