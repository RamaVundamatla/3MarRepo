    <JadeMethod name="doMnuFormContextMenu" id="165280f7-311d-47eb-9f38-3f8365a0742f">
        <updating/>
        <source>doMnuFormContextMenu(table : CM_DataTable input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//-----------------------------------------
//
// Created : by cnwaer1 01 September 2008
//-----------------------------------------
vars
	isShowDataMenus		: Boolean;
	isDataValidRow		: Boolean;
	x1, y1				: Real;
begin
	isShowDataMenus	:=	(table = self.tblItems);
	
	self.mnuColumnOrganiser.visible := (table = self.tblItems);
	self.mnuColumnOrganiser.userObject := table;
	
	if isShowDataMenus then
		isDataValidRow	:=	(self.tblItems.row &gt; self.tblItems.fixedRows);
	endif;
	
	if app.isAllowedToInspect() then
		self.mnuSeperator.visible := true;									//+cnwml2 PAR19782 CCMS SFW 1079
		self.mnuTblInspectObject.visible	:=	true;
	else
		self.mnuSeperator.visible := false;									//+cnwml2 PAR19782 CCMS SFW 1079
		self.mnuTblInspectObject.visible	:=	false;
	endif;
		
	
	self.setupContextMenuItems(table);

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="23152ec7-68ad-4b51-baa7-2b75edcdec4c">
        <updating/>
        <source>doSave() : Boolean updating;
//14 January 2010	cnwml2
//23 Dec 2024	navbs1	Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created


vars
	result : Integer;
	errObj : CM_Error;
	newBOL : CM_BOL;
begin
	
	self.saveBOLDetails();
	
	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateBOL(self.myProxyBOL, newBOL, self, app.myPassport);
		else
			app.myTrxUA.trxUpdateBOL(self.myProxyBOL, true, self, app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK() then
			if self.myCurrentBOL = null then 			//23.12.2024 navbs1 #33524
				self.myCurrentBOL := newBOL;
			endif;
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.unloadForm();
			return true;
		else
			result := app.showErrorWarningDialog('BOL', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			
			errObj := app.myPassport.allErrorWarnings.first();
			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;
	endwhile;
	
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
