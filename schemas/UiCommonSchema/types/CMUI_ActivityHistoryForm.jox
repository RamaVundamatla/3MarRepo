    <JadeMethod name="doBtnPrintX" id="d10bbfbe-658a-4e23-8311-444748a8e823">
        <source>doBtnPrintX(pTable: Table input );
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lRow, lCol, idx, lLeft : Integer;
	lLine : String;
	lControl : Control;
begin
	self.frmReport.width := 690;
	self.frmReport.height := 25;
	self.frmReport.top := 5;
	self.frmReport.left := 5;
	self.frmReport.visible := true;
	foreach lCol in 1 to pTable.columns do
		lControl :=  lblReport.getControl(lCol);
		if lControl = null then
			lControl := lblReport.loadControl(lCol);
		endif;
		lControl.width := pTable.accessColumn(lCol).width;
		lControl.left := lLeft;
		lLeft := lLeft + lControl.width.Integer;
		lControl.height := 20; //pTable.accessRow(1).height;
		lControl.top := 1;
		lControl.fontName := pTable.fontName;
		lControl.fontSize := pTable.fontSize;
		lControl.visible := true;
		lControl.enabled := true;
		
	endforeach;
	foreach lRow in 1 to pTable.rows do
		lLine := null;
		foreach lCol in 1 to pTable.columns do
			lControl := lblReport.getControl(lCol);
			lControl.Label.caption := pTable.accessCell(lRow,lCol).text;
		endforeach;
		app.printer.print(self.frmReport);
	endforeach;
	app.printer.close;

end;</source>
        <Parameter name="pTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="1fceb1f5-f940-4e93-badd-bae5c465340a">
        <updating/>
        <source>doDelete() updating;
// 14/05/2012	cnwcs5	par 29450 - change in signature for trxDeleteActivityHistory
//								  - minor performance tweaks
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars

	obj		: Object;
	tempColl	: CM_ActivityByCreatedTsTypeDict;
	coll	: CM_ActivityByCreatedTsTypeDict;	// par 29450
	size	: Integer;							// par 29450
	msg 	: String;
	actHist : CM_ActivityHistory;
	today : Date;
	excludedCount : Integer;
	genSysAct : CM_ActivityHistoryGeneralSys;
	isDevEnviron : Boolean;
	
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin

	//06Mar 2015	NDL	Par 34583
	executeWhen JMTDevelopmentEnvironment;
	isDevEnviron := true;
	endExecuteWhen;
	
	today := app.actualTimeServer.Date;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	create coll transient;

	//06 Mar 2015	NDL	Par 34583
	if isDevEnviron then
		self.tblActivity.allSelectedObjects.copy (coll);
		
	else
		create tempColl transient;
		self.tblActivity.allSelectedObjects.copy (tempColl);
		foreach actHist in tempColl discreteLock do
			if actHist.activityType = ActivityHistoryGeneralSys then
				if actHist.CM_ActivityHistoryGeneralSys.earliestDeleteDate &gt; today then
					if genSysAct = null then
						genSysAct := actHist.CM_ActivityHistoryGeneralSys;
					endif;
					excludedCount := excludedCount + 1;
					continue;
				endif;
			endif;
			coll.add(actHist);
		endforeach;
		if excludedCount &gt; 0 then
			msg := excludedCount.String &amp; " " &amp; genSysAct.getTypeDescription &amp; " Activity History(s) were unable to be deleted because they are less than 90 days old.";
			app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only );
		endif;
	
	endif;

	size := coll.size;
	
	if size &lt;&gt; 0 then
		if size = 1 then
			msg := app.getErrorString2(ConfirmDelete, 'this', 'Activity History');
		else
			msg := app.getErrorString2(ConfirmDelete, 'these ' &amp; size.String, ' History Activities');
		endif;
		
		if app.msgBox(msg, app.getErrorString(Delete_Activity_History), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then	
			
			//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxDA.trxDeleteActitivityHistory(coll, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Activity History', app.myPassport, ErrWarnMode_Delete);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
		
		endif;
	endif;
	
epilog

	delete coll;
	delete tempColl;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="897d8087-1d69-49b5-a367-0c4ef45c4e03">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	app.mousePointer := MousePointer_HourGlass;
	inheritMethod();
	self.updateTableColumnFilters( self.tblActivity, null );	//13 Jul 2016	NDL Make Activity History form use column organiser
	self.haveToldUserTableActivityFull := false;	// 20 July 2010	NDL	Par 17868
	self.displayAllHistory();
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="32fd173e-72c4-41e9-a0b1-b763a04670e0">
