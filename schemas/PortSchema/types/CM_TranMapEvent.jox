    </JadeMethod>
    <JadeMethod name="healthCheckIsValid" id="6c5c1730-972e-4160-a3c6-1847c14ea5e7">
        <source>healthCheckIsValid(_agent : CMIF_InvoiceHealthAgent) : Boolean;
/*
Purpose:			
Date				Who			Reason
September 2017		CNWAB1		Initial creation
*/

vars
	message : String;
	resultType : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
// TFS 40620	invLineDescs : CM_InvoiceLineDescMapDict;
	invLineDescs : CM_InvoiceLineDescSet;// TFS 40620
	invLineDesc : CM_InvoiceLineDesc;
	paths : HugeStringArray;
	items : ObjectArray;
	bu : CM_Bank;
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, invLineDesc, invalid);

	
	bu := self.getBank();
	if bu = null then
		return true;
	endif;
	if not _agent.allBusinessUnits.includes(bu) then
		return true;
	endif;
	
//	term := self.getMyTerminal();
//	if term = null then
//		return true;
//	endif;
//	if not _agent.allTerminals.includes(term) then
//		return true;
//	endif;
	
	// ### CARGO  Calculation Type
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_CalcType) then
		resultType := CMIF_InvoiceHealthAgent.ResultType_CalcTypeEvent;
		invLineDescs := self.getAllMappedInvoiceLineTypes();
		
		foreach invLineDesc in invLineDescs do
			if  invLineDesc.myCalculationType &lt;&gt; null then
				if not invLineDesc.myCalculationType.isEventCalcType then
					create detail transient;
					detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_CalcType,"Line Type: '" &amp; invLineDesc.narration &amp;  "'", CMIF_InvoiceHealthAgent.ItemType_TranMapEvent, self.getMyTerminal(), resultType, self);
				endif;
			endif;
		endforeach;
		if invalid then
					create detail transient;
					detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_InvoiceLineType,"Line Type is Invalid Object", CMIF_InvoiceHealthAgent.ItemType_TranMapAlloc, self.getMyTerminal(), CMIF_InvoiceHealthAgent.ResultType_Invalid, self);
		endif;
		return false;
	endif;
	return true;
epilog
	delete invLineDescs;
end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="98b982fe-d0bc-429d-bbf7-e311cdbaa7f8">
        <updating/>
        <source>initialise(_bank : CM_Bank) updating;
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Date			Who		Reason
// 09 May 2019	jlgzm1	TFS 42038 changed collection keys to prevent 1099
// ---------------------------------------------------------------------------
vars
	eventSB, esb : CM_EventServiceBroker;
begin

	self.myBank := _bank;

	//eventSB := self.allEventServiceBrokers[CM_EventServiceBroker.DEFAULT_SB_MAP];
	//tfs42038 start
	foreach esb in self.allEventServiceBrokers do
		//would expect null/dafault eventType to be first in collection
		if esb.myEventType = null then
			eventSB := esb;
			break;
		endif;
	endforeach;
	//tfs42038 end
	if eventSB = null then
		create eventSB;
		eventSB.initialiseRes(self);
	endif;

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
