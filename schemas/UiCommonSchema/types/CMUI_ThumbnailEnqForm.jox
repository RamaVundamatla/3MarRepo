    <JadeMethod name="cmbCode_click" id="0f670801-97bc-4e92-b340-145d50e89d59">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCode_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     27 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.doShowThumbnail(combobox.listObject);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCode_displayEntry" id="1a02e145-d981-4f30-a02d-3ae31106d887">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCode_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:     27 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if obj.isKindOf(CM_Commodity) then
		return obj.CM_Commodity.code;
	elseif obj.isKindOf(CM_ISOType) then
		return obj.CM_ISOType.code;
	endif;
	
	return null;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbTable_click" id="da109280-ee8c-4b42-8fc5-c97c8e8ba285">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTable_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     27 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.doSelectTable();

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSelectTable" id="a2ebcec3-67f9-4013-a621-90c1cee69c38">
        <source>doSelectTable();
// ---------------------------------------------------------------------------
// Created:     27 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theTable	: String;
	
begin

	theTable := cmbTable.text;
	
	if theTable = CM_Commodity_Descr then
		cmbCode.listCollection(app.myRoot.allCommodities, true, 0);
	elseif theTable = CM_ISOType_Descr then
		cmbCode.listCollection(app.myRoot.allISOTypes, true, 0);
	else
		cmbCode.clear;
		tblView.clear;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowThumbnail" id="2601bc31-d285-415f-98af-230de165a5b7">
        <source>doShowThumbnail(obj : Object);
// ---------------------------------------------------------------------------
// Created:     27 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	tblView.clear;
	tblView.rows := 0;
	
	if obj.isKindOf(CM_Commodity) then
		obj.CM_Commodity.showThumbnail(tblView);
	elseif obj.isKindOf(CM_ISOType) then
		obj.CM_ISOType.showThumbnail(tblView);
	endif;
	
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initCmbTables" id="4578360e-0853-4dd6-b7dd-a0e80fc581f2">
        <source>initCmbTables();
// ---------------------------------------------------------------------------
// Created:     27 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	cmbTable.addItem(CM_Commodity_Descr);
	cmbTable.addItem(CM_ISOType_Descr);

end;</source>
    </JadeMethod>
