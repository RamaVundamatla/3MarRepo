        <Parameter name="_dateTimeEnd" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ad1b1449-7feb-43c1-a0f3-5ad253faeef1">
        <updating/>
        <source>setForCreate(_pxyEvent: CMEVT_VoyageEvent) updating;
/*

Date		Who		Reason
10/12/2014	cnwer1	Initial creation PAR
20/04/2017	cnwdap1	TFS 4174 LNX Additional Information in Voyage Events
*/

vars

begin
	self.setMyVoyage(_pxyEvent.myVoyage);
	self.setShiftFromProxy(_pxyEvent); // TFS 3217
	self.setJobDetailsFromProxy(_pxyEvent);				// TFS 4174
	
	inheritMethod(_pxyEvent);
	
	self.createAssociatedDelay( _pxyEvent );	//24 Aug 2018	NDL	TFS 40309 &amp; 05 Nov 2018	NDL	TFS 41711

epilog

end;</source>
        <Parameter name="_pxyEvent" type="CMEVT_VoyageEvent"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="fce88f70-f787-404d-85cd-0a42b74a8f6b">
        <updating/>
        <source>setForUpdate(_pxyEvent: CMEVT_VoyageEvent) updating;
/*

Date		Who		Reason
11/12/2014	cnwer1	Initial creation PAR
20/04/2017	cnwdap1	TFS 4174 LNX Additional Information in Voyage Events
08/06/2020  cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
29/07/2022	jlizm1	TFS 54165 EDI Voyage Events
*/

vars

begin

	inheritMethod(_pxyEvent);
	
	self.dateTimeEnd 		:= _pxyEvent.dateTimeEnd;		//nds TFS 3047 26/01/17
	self.remarks 			:= _pxyEvent.remarks;			//nds TFS 3047 26/01/17
	self.unitDescription 	:= _pxyEvent.unitDescription;	//nds TFS 3047 26/01/17
	self.myDebtor           := _pxyEvent.myDebtor;          //03/06/2020 cnwma1 TFS #49400
	self.weight 			:= _pxyEvent.weight;			// TFS 54165
	self.setShiftFromProxy(_pxyEvent); // TFS 3217
	self.setJobDetailsFromProxy(_pxyEvent);				// TFS 4174
	
	if self.myVoyage &lt;&gt; null then // PAR 35478
		if self.pxyGetProxyObject &lt;&gt; null then // PAR 35478
			self.myVoyage.causeEvent(EventTransaction_Update_Event,false,self); // PAR 35478
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyEvent" type="CMEVT_VoyageEvent"/>
    </JadeMethod>
