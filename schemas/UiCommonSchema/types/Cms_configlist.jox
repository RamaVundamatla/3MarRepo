    <JadeMethod name="showThumbnailData" id="83e497ac-4e16-42f2-9d9d-0fb20fdb2594">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
27 August 2008	concms1	Initial creation
*/

vars

begin
	tblThumb.rows := 0;
	
	tblThumb.addItem('Security Role' &amp; Tab &amp; tblData.accessCell (tblData.row, 1).text);
	tblThumb.addItem('Terminal' &amp; Tab &amp; tblData.accessCell (tblData.row, 2).text);
	
	tblGeneral.rows := 0;
	 tblGeneral.height := tblGeneral.parent.height; shtRoles.visible := false;
	tblGeneral.addItem('Security Role' &amp; Tab &amp; tblData.accessCell (tblData.row, 1).text);
	tblGeneral.addItem('Terminal' &amp; Tab &amp; tblData.accessCell (tblData.row, 2).text);
	tblGeneral.readOnly := true;
		tblInputTop.rows := 0;
	
	tblInputTop.addItem('Security Role' &amp; Tab &amp; tblData.accessCell (tblData.row, 1).text);
	tblInputTop.addItem('Terminal' &amp; Tab &amp; tblData.accessCell (tblData.row, 2).text);
epilog

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="b5820041-f1a5-44f2-a265-8fe3e9470e6f">
        <updating/>
        <source>tblDataDisplayRow(table: Table input; obj: Object): String updating;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
27 August 2008	concms1	Initial creation
*/

vars

begin
		return('Freight Forwarder' &amp; Tab &amp; 'Terminal One');
	return ('Freight Forwarder' &amp; Tab &amp; 'Terminal Two');
	return ('Operator' &amp; Tab &amp; '&lt;All&gt;');

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblData_click" id="203dabae-7ecc-4920-b789-f716e87ced24">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
27 August 2008	concms1	Initial creation
*/

vars

begin
	if table.row = 1 then
		tblData.rows := tblData.fixedRows;
		
		tblData.addItem ('Freight Forwarder' &amp; Tab &amp; 'Terminal One');
		tblData.addItem ('Freight Forwarder' &amp; Tab &amp; 'Terminal Two');
		tblData.addItem ('Operator' &amp; Tab &amp; '&lt;All&gt;');
	endif;
	
	

	table.setCellSelected (table.row, 1, true);
	table.setCellSelected (table.row, 2, true);
	self.showThumbnailData (null);
	
	frmDetailsBottom.visible := true;

epilog


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
