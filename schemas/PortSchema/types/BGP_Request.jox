    <JadeMethod name="getDisplay" id="8a248d1f-4aa5-4cac-bfd5-59e6f6e5f5a6">
        <source>getDisplay(): String;

// cnwdvb1 17 February 2003 

vars

	str	: String;

begin

	if global.isValidObject(self.myProcessingController) then
		str := '   -- Processing --';
	endif;
	return self.class.text.cnEcGetTagValueOfName('display') &amp; Tab &amp; self.createdDateTime.bgpDisplay() &amp; str &amp;
	Tab &amp; self.getDisplayErrors();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayErrors" id="97760643-db1e-4d78-ae26-cc2192936c58">
        <source>getDisplayErrors() : String protected;

vars

begin

	if self.errorCode &lt;&gt; 0 and self.errorText = null then
		return '(' &amp; self.errorCode.String &amp; ')';
	else
		return self.errorText;
	endif;
	return null;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
