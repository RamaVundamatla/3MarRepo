    <JadeMethod name="getTypeFromInputType" id="5d4edded-159b-4d29-bdb2-78adc0c4ad5a">
        <source>getTypeFromInputType(_inputType : Integer;
					 _typeStr,
					 _valuesDesc : String output) protected;

/*

Purpose:			Find the CM_DataExtractClass constant for the field type given
					the passed in ETRow inputType, and the possible values description

Parameters:			Input: inputType from ETRow
					Output: String class constant name for correct type
							possible Values Description for this type

Return Value:		Output parameters populated


Date		Who		Reason
11 May 2011	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	if _inputType = 104 then		// CM_BaseTable.InputType_Date
		_typeStr := "DATE";
		_valuesDesc := CM_DataExtractClass.DATE_POSSIBLEVAL;
	elseif _inputType = 105 then	// CM_BaseTable.InputType_Time
		_typeStr := "TIME";
		_valuesDesc := CM_DataExtractClass.TIME_POSSIBLEVAL;
	elseif _inputType = 101 then	// CM_BaseTable.InputType_Picture
		_typeStr := "BINARY";
	elseif _inputType = Table.InputType_CheckBox then
		_typeStr := "BOOLEAN";
		_valuesDesc := CM_DataExtractClass.BOOLEAN_POSSIBLEVAL;
	elseif _inputType = Table.InputType_SignedNumeric or
		   _inputType = Table.InputType_TextNumeric then
		_typeStr := "INTEGER";
		_valuesDesc := CM_DataExtractClass.INTEGER_POSSIBLEVAL;
	endif;
	
	if _typeStr = null then
		_typeStr := "STRING";
	endif;
	
	if _valuesDesc = null then
		_valuesDesc := "**** fill in with possible values description ****";
	endif;

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_inputType" type="Integer"/>
        <Parameter name="_typeStr" type="String" usage="output"/>
        <Parameter name="_valuesDesc" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="initDataExtract" id="1818a122-7600-4bec-9298-872b1fc7fadb">
        <updating/>
        <source>initDataExtract() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2011	#cnwdz2	 

*/

vars
	ti : CM_Container;
	className 	 : String;
	dataExtractClass : CM_DataExtractClass;
	toDeleteClasses  : CM_DataExtractClassSet;
	root : CM_DataExtractRoot;
begin	
	
	self.lockMutex("Init data extract types");	
	
	root := CM_DataExtractRoot.firstInstance;
	
	
	create toDeleteClasses transient;
	//app.myRoot.allDataExtractClasses.copy(toDeleteClasses);
	root.allDataExtractClasses.copy(toDeleteClasses);
	
	className := "Onsite Containers";
	self.maintainDataExtractClass(className, toDeleteClasses, CM_DataExtractOnsiteContainers);
	//root.dataExtractOrder.add(className);
	
	className := "Onsite Non-Container Cargo";
	self.maintainDataExtractClass(className, toDeleteClasses, CM_DataExtractOnsiteCargo);
	//root.dataExtractOrder.add(className);
	
	className := "Users";
	self.maintainDataExtractClass(className, toDeleteClasses, CM_DataExtractUsers);
	//root.dataExtractOrder.add(className);
	
	className := "voyages";
	self.maintainDataExtractClass(className, toDeleteClasses, CM_DataExtractVoyages);
	//root.dataExtractOrder.add(className);
	
	className := "Debtors";
	self.maintainDataExtractClass(className, toDeleteClasses, CM_DataExtractDebtors);
	//root.dataExtractOrder.add(className);
	
	className := "Email Addresses";
	self.maintainDataExtractClass(className, toDeleteClasses, CM_DataExtractEmails);
	//root.dataExtractOrder.add(className);
	
	// Delete non-existing classes.
	foreach dataExtractClass in toDeleteClasses do
		app.myTrxDA.trxDeleteDataExtractClass(dataExtractClass, app.myPassport);
	endforeach;
		
epilog
	self.unlockMutex;
	delete toDeleteClasses;
end;</source>
    </JadeMethod>
