    <JadeMethod name="canActionQTY" id="94662d3a-35c2-4c0b-a4be-d01390417277">
        <source>canActionQTY(_qty : Integer; _reserveDetail : CM_ReserveDetail): Boolean;

/*

Purpose: par 31428 properlly count the space on a bulk release reserve detail		

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2013	cnwrd1	Initial creation

*/

vars
	maxToRelease : Integer;
	beingReleased: Integer;
	aReq : CM_Request;
	delReq : CM_DeliveryRequest;
begin
	if _reserveDetail.isKindOf(CM_ReserveSelection) then
		// relase by type
		//add up all those released.
		beingReleased := beingReleased + _reserveDetail.getTotalReleased; //epr par 34406 25/6/14
		
		maxToRelease := _reserveDetail.getTotalRequested;
		
		//and those working current job
		foreach aReq in self.allRequestsBeingActioned do
		
			if aReq.isKindOf(CM_DeliveryRequest) then 
				delReq := aReq.CM_DeliveryRequest;
				//check if we are looking for the same reserve detail
				if delReq.myReserveDetail = _reserveDetail then
					//we are so add up the wle's
					beingReleased := beingReleased + delReq.getWLEQuantity;
				endif;
			endif;
		endforeach;
		
		//check if we have 'space' for _qty
		if ( beingReleased + _qty) &gt; maxToRelease then
			app.raiseCMException1(MTRequestExceedsNumBulkRequest, self.code, null, null);
			return false;
		else
			return true;
		endif;
	
	else
	//reserveTi..
		if _qty &gt; _reserveDetail.getTotalOutstanding then
			app.raiseCMException1(MTRequestExceedsNumBulkRequest, self.code, null, null);
			return false;
		endif;
	endif;


	return true;
epilog

end;</source>
        <Parameter name="_qty" type="Integer"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoEDIDelete" id="00cf50c0-203f-47a5-a427-9fecec744dbc">
        <source>canDoEDIDelete(_coparnRules :CM_EDIPartyCoparnRules; _error :Integer output):Boolean;
/*
Date		Who		Reason
26/04/2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
30/08/2012	cnwcs5	par 30097 - configure rules for blocked deletes
*/
vars
	status	:Integer;
	result	:Boolean;
begin
	if self.blockEDIUpdates then							// par 29481 May 2012
		_error := EDI_RELEASE_DEL_BLOCKED;		
	else
		status	:= self.status;
		
		if status = BR_PENDING then
			result := true;
			
		elseif status = BR_COMPLETE then
			if not _coparnRules.allowDelCompleted then		// par 30097 Aug 2012
				_error := EDI_RELEASE_DEL_COMPLETED;
			else											// par 30097 Aug 2012
				result := true;								// par 30097 Aug 2012
			endif;											// par 30097 Aug 2012
			
		elseif status = BR_ARCHIVE then
			if not _coparnRules.allowDelArchived then		// par 30097 Aug 2012
				_error := EDI_RELEASE_DEL_ARCHIVED;
			else											// par 30097 Aug 2012
				result := true;								// par 30097 Aug 2012
			endif;
			
		elseif status = BR_ACTIVE then
			if not self.allDeliveryRequests.isEmpty or
				not self.allRequestsBeingActioned.isEmpty or
				not self.allTrackedItemsReleased.isEmpty then
				// release is actioned
				if not _coparnRules.allowDelActioned then	// par 30097 Aug 2012
					_error := EDI_RELEASE_DEL_ACTIONED;
				else										// par 30097 Aug 2012
					result := true;							// par 30097 Aug 2012
				endif;										// par 30097 Aug 2012
			else
				result := true;
			endif;	
		endif;
	endif;
	
	return result;
epilog
	
end;</source>
        <Parameter name="_coparnRules" type="CM_EDIPartyCoparnRules"/>
        <Parameter name="_error" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoEDIUpdate" id="6e0756d2-b16f-4dc6-91c9-c02c698e2de9">
        <source>canDoEDIUpdate(_coparnRules :CM_EDIPartyCoparnRules; _error :Integer output):Boolean;
/*
Date		Who		Reason
26/04/2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
30/08/2012	cnwcs5	par 30097 - configure rules for blocked updates
*/
vars
	status	:Integer;
	result	:Boolean;
begin
	if self.blockEDIUpdates then							// par 29481 May 2012
		_error := EDI_RELEASE_UPD_BLOCKED;		
	else
		status	:= self.status;
		
		if status = BR_PENDING then
			result := true;
			
		elseif status = BR_COMPLETE then
			if not _coparnRules.allowUpdCompleted then		// par 30097 Aug 2012
				_error := EDI_RELEASE_UPD_COMPLETE;
			else											// par 30097 Aug 2012
				result	:= true;							// par 30097 Aug 2012
			endif;											// par 30097 Aug 2012
			
		elseif status = BR_ARCHIVE then
			if not _coparnRules.allowUpdArchived then		// par 30097 Aug 2012
				_error := EDI_RELEASE_UPD_ARCHIVED;
			else											// par 30097 Aug 2012
				result := true;								// par 30097 Aug 2012
			endif;											// par 30097 Aug 2012
			
		elseif status = BR_ACTIVE then
			if not self.allDeliveryRequests.isEmpty or
				not self.allRequestsBeingActioned.isEmpty or
				not self.allTrackedItemsReleased.isEmpty then
				// release is actioned
				if not _coparnRules.allowUpdActioned then		// par 30097 Aug 2012
					_error := EDI_RELEASE_UPD_ACTIONED;
				else										// par 30097 Aug 2012
					result := true;							// par 30097 Aug 2012
				endif;										// par 30097 Aug 2012
			else
				result := true;
			endif;	
		endif;
	endif;
	
	return result;
epilog
	
end;</source>
        <Parameter name="_coparnRules" type="CM_EDIPartyCoparnRules"/>
        <Parameter name="_error" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
