    <JadeMethod name="setupForm" id="860de12a-12ea-4433-9a26-e83109241dbc">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod();
	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.mode := self.modeString.Integer; 
	if self.mode = 0 then
		self.mode := self.Mode_Display;
	endif;
	self.doInitSDFs();
	self.doBuildTableLegend();
	self.mnuCargoHeight.visible := false;
	self.mnuHideLegend.caption := self.Menu_Hide_Legend;
	
	if self.mode = self.Mode_Display then
		self.yardStackColours.clear;
		if app.myRoot.coloursForTALevels.isEmpty then
			 app.myRoot.createTALevelColours();
		endif;
	 	app.myRoot.coloursForTALevels.copy(self.yardStackColours);
		self.setCaption(app.getErrorString(Overview));
		self.mnuSavePositions.visible := false;
	elseif self.mode = self.Mode_Edit then
		self.setCaption(app.getErrorString(Positions)); 
		self.mnuRestrictions.visible := false;
		self.mnuArea.visible := false;
		self.mnuCargoHeightAll.visible := false;
		self.mnuSavePositions.visible := true;
	endif;
	// Update the navigator
	self.setNavigatorHeading(self.caption); 

	self.scrollBars := self.ScrollBars_None;
//	self.doResize();
	self.mnuCargoHeight.caption := Menu_Heights_Show;
	self.picTerminal.visible := false;
	self.sptMain.transparent := true;
	self.sptMain.hideLeftControl(true);
	self.mnuCargoHeightAll.caption := self.Menu_Heights_Show;
	self.getXMLSettingsForSetup();
end;</source>
    </JadeMethod>
    <JadeMethod name="showDimensionsFrame" id="8191afb0-f6cc-4bcd-9292-dc9afb2f4c43">
        <updating/>
        <source>showDimensionsFrame() updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.frmDimensions.left := 50;
	self.frmDimensions.top := 100;
	self.tblDim.move(0,self.frmDimensionTB.height,self.frmDimensions.clientWidth,self.frmDimensions.clientHeight - self.frmDimensionTB.height);
	self.frmDimensions.zOrder(1);
	self.frmDimensions.visible := true;
end;</source>
    </JadeMethod>
