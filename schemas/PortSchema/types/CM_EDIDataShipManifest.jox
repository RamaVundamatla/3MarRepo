    <JadeMethod name="canBePartiallyLoaded" id="f4a2e75e-7084-4034-a59a-89b2d73dbaf7">
        <source>canBePartiallyLoaded(): Boolean protected;
//
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
//
vars

begin
	if self.getMyTerminal.getConfig(EdiShipManAllowPartial).Boolean then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeReprocessedByBGP" id="3373a1ca-287e-43df-9d34-02b973432ffe">
        <source>canBeReprocessedByBGP() : Boolean;
//
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
//
vars
	result		:Boolean;
	status		:Integer;
	purgeDate	:Date;
	createTS	:TimeStamp;
begin
	result := inheritMethod();
	
	if not result then
		status := self.status;
		
		if status = CM_EDIFile.EDI_STATUS_LOADED or	
			status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
			status = CM_EDIFile.EDI_STATUS_VERIFIED or 
	        status = CM_EDIFile.EDI_STATUS_LOCKERROR or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			
			if self.canBePartiallyLoaded then	
				result := true;
			endif;
		endif;
	endif;

	if result then
		if self.getEDIAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
			result := false;
		endif;
	endif;
/*	if result then
		// we may have passed the expiry for unprocessed files in which case we should not re-process it after all
		purgeDate := self.getUnprocessedExpiryDate(EDIUnprocReleaseExpiry);
		createTS := self.createdTime;
			
		if createTS.date &lt; purgeDate then
			// we are expired - we don't want to re-process
			app.writeLog('Release MultiLine EDI expired ' &amp; self.displayName &amp; ' created ' &amp; createTS.String &amp; ' purge date ' &amp; purgeDate.String, LogDebug3);
			result := false;
		endif;
	endif;*/

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
