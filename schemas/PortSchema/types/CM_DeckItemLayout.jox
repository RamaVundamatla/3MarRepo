/*
Date		    Who			Reason
17 May 2011	cnwas3	  Initial creation: CCMS 1031 par 27498
*/

vars

begin
	if self.myDeckItem &lt;&gt; null and self.myDeckItem.myDeck &lt;&gt; null then
		return self.myDeckItem.myDeck.code;
	elseif self.myDeckLayer &lt;&gt; null and self.myDeckLayer.myDeckLayout &lt;&gt; null and self.myDeckLayer.myDeckLayout.myDeck &lt;&gt; null then
		return self.myDeckLayer.myDeckLayout.myDeck.code;			
	endif;	
	return null;	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="e2ddb537-e8c2-448d-afa1-03303d08e3fe">
        <source>getName(): String;
/*
Purpose:			
Date		Who		Reason
24 August 2011	cnwab1	Initial creation
*/

vars
	lc : CM_VoyageROROController;
	req : CM_RORORequest;
begin

	// PAR 31166 - added the CODE

	if 	self.type = DeckItemLayoutType_Pillar then
		return app.getErrorString(Pillar).toUpper &amp; " " &amp; self.code;
	elseif self.type = DeckItemLayoutType_Power then
		return app.getErrorString(Power).toUpper &amp; " " &amp; self.code;
	elseif self.type = DeckItemLayoutType_Locn then
		return app.getErrorString(Location).toUpper &amp; " " &amp; self.code;
	elseif self.type = DeckItemLayoutType_Lane then
		return app.getErrorString(Lane).toUpper &amp; " " &amp; self.code;
	elseif self.type = DeckItemLayoutType_CCLoad then
		return app.getErrorString(Code_load).toUpper &amp; " " &amp; self.code;
	elseif self.type = DeckItemLayoutType_CCDischarge then
		return app.getErrorString(Code_disch).toUpper &amp; " " &amp; self.code;
	elseif self.type = DeckItemLayoutType_GCLoad then
		return app.getErrorString(GCLoad).toUpper &amp; " " &amp; self.code;
	elseif self.type = DeckItemLayoutType_GCDischarge then
		return app.getErrorString(GCDisch).toUpper &amp; " " &amp; self.code;
	elseif self.type = DeckItemLayoutType_Graphic then
		return app.getErrorString(Graphic).toUpper &amp; " " &amp; self.code;
	elseif self.isLocnDefnLayout() then
		return app.getErrorString(Location).toUpper &amp; " " &amp; self.code;
	elseif self.type = DeckItemLayoutType_Slot then
		return "Bay Slot";
		
	endif;
	return app.getErrorString(Unknown).toUpper;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
