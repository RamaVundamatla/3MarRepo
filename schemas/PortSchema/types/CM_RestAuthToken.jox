    <JadeMethod name="setForCreate" id="113dd96f-749f-40d8-9a63-40c7bc5559dd">
        <updating/>
        <source>setForCreate(_pxyToken : SelfType; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/09/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
//
vars

begin
	self.raiseExceptionIfTransient(method);
	
	self.setForUpdate(_pxyToken, _passport);
	
	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="_pxyToken" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a358008a-4503-40ff-aeaa-731991acc78a">
        <updating/>
        <source>setForUpdate(_pxyAuthToken : SelfType; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/09/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
//
vars

begin
	self.raiseExceptionIfTransient(method);
	
	self.guid 					:= _pxyAuthToken.guid;
	self.refreshGuid 			:= _pxyAuthToken.refreshGuid;
	self.tokenExpiryDateTime	:= _pxyAuthToken.tokenExpiryDateTime;
	self.refreshExpiryDateTime	:= _pxyAuthToken.refreshExpiryDateTime;
	self.scope 					:= _pxyAuthToken.scope;
	
	self.myTerminal 			:= _pxyAuthToken.myTerminal;
	self.myUser 				:= _pxyAuthToken.myUser;
epilog

end;</source>
        <Parameter name="_pxyAuthToken" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="09a6dfe0-c421-4761-ad47-f4bec51f3ce2">
        <updating/>
        <source>setProxy(_user : CM_User; _terminal : CM_Terminal; _scope, _guid, _refreshGuid : String; _tokenExpiry, _refreshExpiry : TimeStamp) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/09/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
//
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myUser := _user;
	self.myTerminal := _terminal;
	self.scope := _scope;
	self.guid := _guid;
	self.refreshGuid := _refreshGuid;
	self.tokenExpiryDateTime := _tokenExpiry;
	self.refreshExpiryDateTime := _refreshExpiry;
	
	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_scope" type="String"/>
        <Parameter name="_guid" type="String"/>
        <Parameter name="_refreshGuid" type="String"/>
        <Parameter name="_tokenExpiry" type="TimeStamp"/>
        <Parameter name="_refreshExpiry" type="TimeStamp"/>
    </JadeMethod>
