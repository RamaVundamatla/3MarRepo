    <JadeMethod name="getAllWodCargoRequests" id="e81e6001-4668-4d50-afbb-6d19a8009ac0">
        <source>getAllWodCargoRequests():CM_WodCargoRequestSet;
/*

Purpose:			

Parameters:			Here for Reportwriter onlty.....  If being used for any other reason, make sure you delete the transient

Return Value:		

Date		Who		Reason
05 November 2018	jlgndl1	Initial creation	TFS 41754

*/

vars

	allWodCargos : CM_WodCargoRequestSet;
	wo : CM_WorkOrder;
	woDtl : CM_WorkOrderDtl;
	wodCargoRequest : CM_WodCargoRequest;

begin

	create allWodCargos transient;

	foreach wo in self.allWorkOrders discreteLock do
		if not wo.isVoyageWorkOrder then
			continue;
		endif;
		if wo.isCancelled then
			continue;
		endif;
		foreach woDtl in wo.allWoDtls discreteLock do
			if woDtl.isKindOf( CM_WodCargoRequest ) then
				allWodCargos.addNoDuplicates( woDtl.CM_WodCargoRequest, false );
			elseif woDtl.isKindOf( CM_WodPermitRequest ) then
				foreach wodCargoRequest in woDtl.CM_WodPermitRequest.allCargoDetails do
					allWodCargos.addNoDuplicates( wodCargoRequest, false );
				endforeach;
			elseif woDtl.isKindOf( CM_WodShiftMovement ) then
				foreach wodCargoRequest in woDtl.CM_WodShiftMovement.allWodCargoRequests do
					allWodCargos.addNoDuplicates( wodCargoRequest, false );
				endforeach;
			elseif woDtl.isKindOf( CM_WodVoyageCargoRequest ) then
				foreach wodCargoRequest in woDtl.CM_WodVoyageCargoRequest.allCargoDetails do
					allWodCargos.addNoDuplicates( wodCargoRequest, false );
				endforeach;
			else
			endif;
		endforeach;
	endforeach;
	
	return allWodCargos;

epilog

end;</source>
        <ReturnType type="CM_WodCargoRequestSet"/>
    </JadeMethod>
    <JadeMethod name="getAllWorkPoints" id="60c68083-4675-4030-85ad-58093dad7445">
