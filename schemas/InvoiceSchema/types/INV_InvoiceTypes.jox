    <JadeMethod name="cmbSepInvoices_gotFocus" id="9823db4d-50c6-4ced-b670-6e43838c271f">
        <controlMethod name="ComboBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSepInvoices_gotFocus(combobox: ComboBox input) updating;
/* ---------------------------------------------------------------------------
Created:	09 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
30/09/2015		cnwdap1		PAR #36909 CCMS ADP 2537 Minimum Charge changes
------------------------------------------------------------------------------*/
vars

begin

	if self.myProxyObject &lt;&gt; null then 
		if self.myProxyObject.CM_InvoiceDesc.invoiceKey = CM_InvoiceDesc.Key_None then
			combobox.listIndex := 1;
		elseif self.myProxyObject.CM_InvoiceDesc.invoiceKey = CM_InvoiceDesc.Key_CargoItem then
			combobox.listIndex := 2;
		elseif self.myProxyObject.CM_InvoiceDesc.invoiceKey = CM_InvoiceDesc.Key_Voyage then
			combobox.listIndex := 3;
		elseif self.myProxyObject.CM_InvoiceDesc.invoiceKey = CM_InvoiceDesc.Key_BOL then		// PAR #36909
			combobox.listIndex := 4;															// PAR #36909
		elseif self.myProxyObject.CM_InvoiceDesc.invoiceKey = CM_InvoiceDesc.Key_VoyageGroup then // ### TFS 51219 25MAY2021 NAVAB1
			combobox.listIndex := 5; // ### TFS 51219 25MAY2021 NAVAB1
		else
			app.raiseUnexpectedProgramError( class.name, method.name, 'Unexpected combobox index' );
		endif;
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
