    <JadeMethod name="cnEcGetDuplicate" id="817ec9fa-69b0-4a15-89f2-b27e124dc1ee">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	agent : CM_ShippingAgent;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		agent := app.myRoot.allShippingAgentsByCode.getAtKey( code );
	endif;

epilog

	return agent;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="create" id="22b24097-9531-4fe2-9ba9-df7f92ed061f">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     23 July 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.isCodeGroupNOTRequired := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayForXlation" id="436d73b5-bfab-4a38-b9f6-b65327a2ac19">
        <source>displayForXlation(_codeFirst: Boolean): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 07 June 2023
TFS#		: 58320
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.description.trimBlanks&amp;']';
	else
		return self.description.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="0cc2f3a9-5a7e-4199-8915-0331e915e666">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     20 April 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt		: String;
	tmpStr	: String;
	cont	: CM_EmailAddress2;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach cont in self.allContacts do
		if tmpStr = null then
			tmpStr := cont.name;
		else
			tmpStr := tmpStr &amp; ', ' &amp; cont.name;
		endif;
	endforeach;
	txt := txt &amp; 'Contacts Selected' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="3f9d6184-e0fd-49ef-bcde-5b93ef38cf85">
        <source>getDescription():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2018	jlgma1	Bug 40273: PEL1 - Add "Shipping Agent description" to HMS_VoyageData class in Voyage view of JRW

*/

vars

begin
	return self.description;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="17ebbcdf-83eb-420d-aa21-c2ecb50fa7db">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	07 April 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	self.allContacts.copy(proxy.allContacts);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c6902789-fff2-4705-90b8-ced555c72164">
        <updating/>
        <source>setForCreate(pProxy: CM_ShippingAgent) updating;
// ---------------------------------------------------------------------------
// Created:     23 July 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pProxy);
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pProxy" type="CM_ShippingAgent"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="25a680af-5146-44a2-8a96-aa777d459e43">
        <updating/>
        <source>setForUpdate(_proxy: CM_ShippingAgent) updating;
// ---------------------------------------------------------------------------
// Created:     23 July 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_proxy);
	self.allContacts.clear();
	_proxy.allContacts.copy(self.allContacts);
end;</source>
        <Parameter name="_proxy" type="CM_ShippingAgent"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b8b07ef4-8f8c-4566-8e2d-b9b1e55f5a87">
        <updating/>
        <source>setProxy(pCode, pDescription : String; _notAvailableForEntry:Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setSuperClassDetailsForProxy(pCode, pDescription,_notAvailableForEntry,null);
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="fecff02e-6059-4cc5-96aa-b50193ea357f">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars
	propName	: String;

begin

	propName := _property.name;
	if propName = CM_Code::myCodeGroup.name or
	 propName = CM_Code::isCodeGroupNOTRequired.name then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="253b6292-0ad0-4ce3-bb70-33d20fa9716b">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     23 July 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allShippingAgentsByCode.includesKey(self.code) &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	inheritMethod();

end;</source>
    </JadeMethod>
</Class>
