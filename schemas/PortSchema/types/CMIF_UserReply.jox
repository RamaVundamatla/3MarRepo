<Class name="CMIF_UserReply" id="88135910-4b31-4dc9-81aa-ac3ff34d2af5">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <PrimAttribute name="defaultReply" id="d9ec0957-0ff3-48ba-9363-814f1d22fb2b">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="error" id="c5c11661-3864-4595-bec2-0328b5d1cedc">
        <embedded/>
        <type name="Integer"/>
        <text>This is the ERROR number returned if applicable. Added as result only reports exceptions</text>
    </PrimAttribute>
    <PrimAttribute name="pStateMachine" id="ff05f588-f819-46b2-92b4-7eb3c7c86093">
        <embedded/>
        <type name="Integer"/>
        <text>This is a pointer to a StateMachine* C++ object, used for iterative calls.</text>
    </PrimAttribute>
    <PrimAttribute name="possibleReplies" id="dc6e6d0a-d6fb-4ac7-b9af-c2e0803abba6">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="reply" id="cdba08dd-346b-455a-8549-9fa5d3f65a9c">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="state" id="d8f9252f-3b44-486a-b610-28994486d6d8">
        <embedded/>
        <type name="Integer"/>
        <text>Used to maitain which state the current move operation is in.
This can be one of : STATE_BEGINMOVE, STATE_QUERYMOVE, MOVE_DOMOVE, STATE_ABORTMOVE, STATE_ERRORMOVE, STATE_COMPLETEDMOVE</text>
    </PrimAttribute>
    <PrimAttribute name="warning" id="804e552a-9ef6-4052-af53-378c9ce05418">
        <embedded/>
        <type name="Integer"/>
        <text>All warnings from methods come back in here, RATHER than in Result as previously.</text>
    </PrimAttribute>
</Class>
