    <JadeMethod name="doSysNotify" id="8deacbf8-91ec-4494-a9aa-b04c089605a7">
        <updating/>
        <source>doSysNotify(_eventType: Integer; _object: Object; _eventTag: Integer) protected, updating;

// Created by cnwdvb1 on 30 June 2006

vars

	theRow		: Integer;
	table		: CM_DataTable;
	fixedRows	: Integer;
begin

	if not _object.isKindOf(CM_PackageHistoryHdr) then
		return;
	endif;
	
	if _eventType = Object_Delete_Event then
		table 		:= self.tblHistory;

		table.findObjectInRow(_object, theRow);
	
		fixedRows 	:= table.fixedRows;
		
		if theRow &lt;= fixedRows then
			return;
		endif;
	
		table.removeItem(theRow);
		
		if table.rows &gt; fixedRows then
			table.selectRow(fixedRows + 1, false);		
		endif;
		
	elseif _eventType = Object_Create_Event then
		self.tblDataDisplayRow(_object.CM_PackageHistoryHdr);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractHistory" id="0545530e-5a14-4b1b-8a55-76764f44fe60">
        <source>extractHistory() protected;

// Created by cnwdvb1 on 28 June 2006

vars

	history		: CM_PackageHistoryHdr;
	result		: Integer;
	obj			: Object;
	coll		: ObjectArray;
begin
	coll := self.tblHistory.allSelectedObjects;
	
	if coll.isEmpty() then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;
	endif;

	// Only letting user extract one at a time at the moment.
	foreach obj in coll do
		history := obj.CM_PackageHistoryHdr;
		result 	:= app.msgBox('Do you wish to extract the selected history - ' &amp; history.createdTime.shortCurrentLocaleFormat(), self.caption,  MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		
		if result &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
		history.extractHistoryDataToFile();
		return;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
