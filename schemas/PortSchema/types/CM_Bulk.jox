    <DbClassMap file="containr"/>
    <JadeMethod name="aggregate" id="22ac06cb-0e96-48db-b833-1e1e2028c041">
        <updating/>
        <source>aggregate(	_cargoToAggregate : CM_BreakBulkGeneric input;
			_pkgWeight : Decimal;
			_passport : CM_Passport input
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2014	cnwndl1	Initial creation

*/

vars

	aggregateWeight : Decimal [16,4];
	aggregateVolume : Decimal [16,4];

begin

	if _pkgWeight &gt; 0 then
		aggregateWeight := ( self.totalWeight + _cargoToAggregate.totalWeight ) - _pkgWeight;
	else
		aggregateWeight := self.totalWeight + _cargoToAggregate.totalWeight;
	endif;
	self.setTotalWeightWithoutTrans( aggregateWeight );
	
	if self.isBulkByVolume then
		aggregateVolume := self.totalVolume + _cargoToAggregate.totalVolume;
		self.setMyTotalVolume(aggregateVolume);
	endif;

	_cargoToAggregate.aggregate( self, _passport );

epilog

end;</source>
        <Parameter name="_cargoToAggregate" type="CM_BreakBulkGeneric" usage="input"/>
        <Parameter name="_pkgWeight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canMergeBreakBulk" id="2d7a1457-c638-4835-83f7-a8f2e523be0a">
        <source>canMergeBreakBulk(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/03/2014	cnwdap1		Initial creation PAR #33606 CCMS SFW 1366 Bulk
//
vars
	ct : CM_CargoType;
begin
	
	ct := self.myCargoType;
	
	if ct = null then
		return false;
	endif;
	
	if not  ct.allowDuplicates then
		return false;
	endif;
	
	if ct.isTrackByWeight then
		return self.totalWeight &gt; 0;
	else
		return self.totalVolume &gt; 0;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canSplitTotalQuantity" id="e182f251-5cd7-48b0-a1b4-10eec8187c06">
        <source>canSplitTotalQuantity(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/03/2014	cnwdap1		Initial creation PAR #33606 CCMS SFW 1366 Bulk
//
vars
	cType : CM_CargoType;
begin
	
	cType := self.myCargoType;
	
	if cType = null then
		return false;
	endif;
	
	if not cType.allowDuplicates then
		return false;
	endif;
	
	if cType.isTrackByWeight then
		return self.totalWeight &gt; null;
	else
		return self.totalVolume &gt; null;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createNewBulkNewId" id="c9ce7f86-b4d9-4625-843c-f569b258a4e3">
        <updating/>
        <source>createNewBulkNewId( _control : CMIF_MoveController input;
					_newIdForSplit : String;
					_includeStops ,
					_includeToDo,
					_includeDamage,
					_includeHaz : Boolean):CM_Cargo updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/04/2014	cnwndl1	Initial creation	CCMS 1366
24/02/2017	cnwdap1	TFS 3489 LNX DLR/SOB
*/

vars

	retVal : CM_Cargo;

begin

	retVal :=  self.splitBulk(_control, _newIdForSplit );
	
	if not _control.myPassport.hasErrors then
		if self.totalWeight = 0 then
			//self.mergeNullRefs( null, null);					// TFS 3489
			self.mergeNullRefs( null, null, null );				// TFS 3489
		endif;
	endif;
	
	retVal.updateDetailsFromCargoMulti(false,self,_includeStops,_includeToDo,_includeDamage,_includeHaz,_control.myPassport); // ### JIRA 35283 30JUN2025 NAVAB1
	
	return retVal;

epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_newIdForSplit" type="String"/>
        <Parameter name="_includeStops" type="Boolean"/>
        <Parameter name="_includeToDo" type="Boolean"/>
        <Parameter name="_includeDamage" type="Boolean"/>
        <Parameter name="_includeHaz" type="Boolean"/>
        <ReturnType type="CM_Cargo"/>
    </JadeMethod>
    <JadeMethod name="getBulkBreakBulkOverSupply" id="ea614870-60c5-495f-96f6-de588d6e668e">
        <source>getBulkBreakBulkOverSupply(_qty: Integer output; _weight: Decimal output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2017	jlgndl1	Initial creation	TFS 5701

*/

vars

	trans : CM_TITransaction;
	qty : Integer;
	weight : Decimal [16,3];
	total : Integer;

begin
	
	
	foreach trans in self.allTransactions reversed where trans.type = TRANS_TYPE_BREAKBULK_OVERAGE  do
		if trans &lt;&gt; null then
			if trans.CM_BBDiscrepancy.quantityChange &gt; 0 then
				qty := trans.CM_BBDiscrepancy.quantityChange;
				weight := trans.CM_BBDiscrepancy.weightChange;
				_qty := _qty + qty;
				_weight := _weight + weight;
			endif;
		endif;
	endforeach;
	
	return _qty &gt; 0 or _weight &gt; 0;

epilog

end;</source>
        <Parameter name="_qty" type="Integer" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBulkBreakBulkUnderSupply" id="b62d09e9-4dbd-419b-ab5b-5548bcc11398">
        <source>getBulkBreakBulkUnderSupply(_qty: Integer output; _weight: Decimal output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2017	jlgndl1	Initial creation	TFS 5701

*/

vars

	trans : CM_TITransaction;
	qty : Integer;
	weight : Decimal [16,3];
	total : Integer;

begin
	
	
	foreach trans in self.allTransactions reversed where trans.type = TRANS_TYPE_BREAKBULK_OVERAGE  do
		if trans &lt;&gt; null then
			if trans.CM_BBDiscrepancy.quantityChange &lt; 0 then
				qty := trans.CM_BBDiscrepancy.quantityChange * -1;
				weight := trans.CM_BBDiscrepancy.weightChange * -1;
				_qty := _qty + qty;
				_weight := _weight + weight;
			endif;
		endif;
	endforeach;
	
	return _qty &gt; 0 or _weight &gt; 0;

epilog

end;</source>
        <Parameter name="_qty" type="Integer" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBulkTrackByDisplayForWeight" id="65c5b28c-28b3-4cd5-bd6b-12b041727f2a">
        <source>getBulkTrackByDisplayForWeight(_showUnit : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2014	cnwndl1	Initial creation
*/

vars

	density : Decimal [16,4];
	ct		: CM_CargoType;
begin
	
	ct := self.myCargoType;
	if ct &lt;&gt; null then
		density := self.getDensity;
		return ct.getBulkTrackByDisplayForWeight( self.totalWeight, density, _showUnit); 
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getChargeQuantity" id="9b9262c9-d2fb-434b-ac68-5d276e48226d">
        <source>getChargeQuantity() : Real;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 07/09/2015	cnwdap1		PAR #36751 Only charge for the actual quantity moved
vars
	mergeSplit : CM_TITransaction;					// PAR #36751

begin
	if self.getAndUseMergeSplitQVW(mergeSplit) then													// PAR #36751
		if mergeSplit.isKindOf(CM_Merge) then														// PAR #36751
			return mergeSplit.CM_Merge.totalQuantity.max(mergeSplit.CM_Merge.totalQuantity * -1);	// PAR #36751
		elseif mergeSplit.isKindOf(CM_Split) then													// PAR #36751
			return mergeSplit.CM_Split.totalQuantity.max(mergeSplit.CM_Split.totalQuantity * -1);	// PAR #36751
		endif;																						// PAR #36751
	endif;																							// PAR #36751

	return self.totalQuantity;				// PAR #36751

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="746c5039-ac52-4d94-9997-4297f85afa4e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpLC		: CM_LocationsController;
	prod		: CM_Product;
	invalid		: Boolean;
	returnVal	: String;
	
begin
	if _attrName = ETRow_MyProduct or _attrName = ETRow_SubCargoType then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.code &amp; ' - ' &amp; self.myProduct.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyProductDescription then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.description;
		endif;
	
	//the following attrs may have a "multiplier" on the corresponding
	//product attribute that may need to be applied to produce te display value
	elseif  _attrName = ETRow_Quantity or
	   _attrName = ETRow_MyQuantity then
	     if self.myProduct &lt;&gt; null then 
			return self.myProduct.myQuantity.multiplyValue(self.quantity).String;
		endif;
	elseif _attrName = ETRow_MyWeight or
	   _attrName = ETRow_MyWidth or			// 27/06/2011 cnwar2 #27752
	   _attrName = ETRow_MyHeight or		// 27/06/2011 cnwar2 #27752
	   _attrName = ETRow_MyLength then		// 27/06/2011 cnwar2 #27752
	   
		prod := self.myProduct;
		if prod = null then
			prod := self.myCargoType.mySystemProductType;
		endif;
		if prod &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, prod, invalid);
			if _attrName = ETRow_MyWeight then
				returnVal := prod.getMyWeightDisplayValue(self.totalWeight).String;
			elseif _attrName = ETRow_MyWidth then
				returnVal := prod.getMyWidthDisplayValue(self.width).String;		// 27/06/2011 cnwar2 #27752
			elseif _attrName = ETRow_MyHeight then
				returnVal := prod.getMyHeightDisplayValue(self.height).String;		// 27/06/2011 cnwar2 #27752
			elseif _attrName = ETRow_MyLength then
				returnVal := prod.getMyLengthDisplayValue(self.length).String;		// 27/06/2011 cnwar2 #27752
			endif;
			
			if not invalid then
				return returnVal;
			endif;
		endif;
		
	elseif _attrName = ETRow_Colour then
	 	if self.myProduct &lt;&gt; null and self.myProduct.colour &lt;&gt; null then 
			return self.myProduct.colour.String;
		else 
			return null;
		endif;
	elseif _attrName = ETRow_DimType then
		return null;
	elseif _attrName = ETRow_Amount then
		if self.myCargoType &lt;&gt; null then
			return self.myCargoType.getBulkTrackByDisplayForWeight(self.totalWeight,self.getDensity,true);
		endif;
		return null;
	endif;

	return inheritMethod(_attrName, _short);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullName" id="20b51d1d-a309-48b3-a520-0590efb53823">
        <source>getFullName(_theMode: Integer): String;

// Created by cnwdvb1 on 08 February 2007


vars
	aLocationController : CM_LocationsController;
begin

	aLocationController := self.getPrimaryLocation(_theMode);
	if aLocationController &lt;&gt; null then
		return aLocationController.getFullId;// &amp; " " &amp; aLocationController.allTrackedItems.indexOf(self).String;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_theMode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumTEU" id="5b00e727-a467-40cf-b4c0-0fcd8c72ef5e">
        <source>getNumTEU(): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
28 July 2022	navsrk20	ChangeRequest 53917: MTN - Cargo Types TEUs for GC

*/

vars
	ct : CM_CargoType;
	teu : Decimal[23,4];
begin
	
	ct := self.myCargoType;
	if ct = null then
		return 0;
	endif;
			
	teu := ct.getTEUConversionValue(TEUConversionIndexGCBulk);
	if ct.teuMultiplier = TEUMultiplierIndexQ then
		if self.totalQuantity &lt;&gt; 0 then
			teu := self.totalQuantity/teu;
		endif;
	elseif ct.teuMultiplier = TEUMultiplierIndexW then
		if self.totalWeight &lt;&gt; 0 then
			teu := self.totalWeight/teu;
		endif;
	endif;
	
	return teu;
	
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getNumTEUDeci" id="decc4faf-f42a-4f06-873f-524999aca6b6">
        <source>getNumTEUDeci(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2022	navsrk20	Bug 54611: MTN - getNumTEUDeci not returning value as expected

*/

vars
	ct : CM_CargoType;
	teu : Decimal[23,2];
begin
	
	ct := self.myCargoType;
	if ct = null then
		return 0;
	endif;
			
	teu := ct.getTEUConversionValue(TEUConversionIndexGCBulk);
	if ct.teuMultiplier = TEUMultiplierIndexQ then
		if self.totalQuantity &lt;&gt; 0 then
			teu := self.totalQuantity/teu;
		endif;
	elseif ct.teuMultiplier = TEUMultiplierIndexW then
		if self.totalWeight &lt;&gt; 0 then
			teu := self.totalWeight/teu;
		endif;
	endif;
	
	return teu;
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getNumTEUOfQty" id="b4f68999-3377-4162-8b1d-170b455398de">
        <source>getNumTEUOfQty(_qty:Real): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
10 Aug 2022		navra1		TFS 53105

*/

vars
	ct : CM_CargoType;
	teu : Decimal[23,4];
begin
	
	ct := self.myCargoType;
	if ct = null then
		return 0;
	endif;
			
	teu := ct.getTEUConversionValue(TEUConversionIndexGCBulk);
	
	if _qty &lt;&gt; null then
		return _qty/teu;
	endif;
	
	//navra1 - 12th Aug 2022 - TFS 53105
	//If sent _qty is null, understand it as 0
	//return teu;	
	return 0;	
	
end;</source>
        <Parameter name="_qty" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="ee33d4aa-a634-42fd-862b-43170b391db1">
        <source>getPicture(): Binary;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePicture : Binary;
begin
	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
		return null;
	endif;

	thePicture := app.myRoot.getConfig(PicCargoBulk).Binary; 
	return thePicture;

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getShortDescriptions" id="9b35fcc7-e181-401d-9538-1a9254616d1b">
        <source>getShortDescriptions(desc1: String output; desc2: String output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2014	cnwndl1	Initial creation

*/

vars

	retStr1, retStr2 : String;
	ls, ws, hs, col : String;
	pieces : Integer;
	prod : CM_Product;
	prodAttr : CM_ProductAttr;
	descChar : String;
	measureType : CM_MeasurementType;
	weightStr : String;
	volumeStr : String;
	hazDets : String;

begin

	retStr1 := self.cargoTypeDescr;
	if self.myProduct &lt;&gt; null then
		if retStr1 &lt;&gt; null then
			retStr1 := retStr1 &amp; "/";
		endif;
		retStr1 := retStr1 &amp; self.myProduct.code;
	endif;
	
	prod := self.myProduct;
	if prod = null and self.myCargoType &lt;&gt; null then
		prod := self.myCargoType.mySystemProductType;
	endif;

	if prod &lt;&gt; null then
		if self.length &gt; 0 then
			descChar := "L";
			prodAttr := prod.getProdAttrFromName(ETRow_MyLength);
			if prodAttr &lt;&gt; null then
				if prodAttr.displayName &lt;&gt; null then
					descChar := prodAttr.displayName[1:1].toUpper;
				endif;
				measureType := prodAttr.myMeasurementType;
			endif;
			if measureType = null then
				measureType := app.getDefaultMeasurementForType(Type_Length);
			endif;
			ls := app.convertMeasurementForDisplay( measureType.shortName, self.length ) &amp; descChar;
		endif;
		
		if self.width &gt; 0 then
			descChar := "W";
			prodAttr := prod.getProdAttrFromName(ETRow_MyWidth);
			if prodAttr &lt;&gt; null then
				if prodAttr.displayName &lt;&gt; null then
					descChar := prodAttr.displayName[1:1].toUpper;
				endif;
				measureType := prodAttr.myMeasurementType;
			endif;
			if measureType = null then
				measureType := app.getDefaultMeasurementForType(Type_Width);
			endif;
			ws := app.convertMeasurementForDisplay( measureType.shortName, self.width )  &amp; descChar;
		endif;
		
		if self.height &gt; 0 then
			descChar := "H";
			prodAttr := prod.getProdAttrFromName(ETRow_MyHeight);
			if prodAttr &lt;&gt; null then
				if prodAttr.displayName &lt;&gt; null then
					descChar := prodAttr.displayName[1:1].toUpper;
				endif;
				measureType := prodAttr.myMeasurementType;
			endif;
			if measureType = null then
				measureType := app.getDefaultMeasurementForType(Type_Height);
			endif;
			hs := app.convertMeasurementForDisplay( measureType.shortName, self.height )  &amp; descChar;
		endif;
		
	endif;
	
	if ls &lt;&gt; null or ws &lt;&gt; null or hs &lt;&gt; null then
		if ls &lt;&gt; null then
			retStr2 := ls;
		endif;
		if ws &lt;&gt; null then
			if retStr2 &lt;&gt; null then
				retStr2 := retStr2 &amp; "x";
			endif;
			retStr2 := retStr2 &amp; ws;
		endif;
		if hs &lt;&gt; null then
			if retStr2 &lt;&gt; null then
				retStr2 := retStr2 &amp; "x";
			endif;
			retStr2 := retStr2 &amp; hs;
		endif;
	endif;
	
	if retStr2 &lt;&gt; null then
		retStr2 := retStr2 &amp; " ";
	endif;
	
	if self.isBulkByWeight then
		weightStr := self.getDefaultTotalWeightDisplay();		
		retStr2 := retStr2 &amp; "(" &amp; weightStr &amp; ") ";
	elseif self.isBulkByVolume then
		volumeStr := self.getDefaultTotalVolumeDisplay();		
		retStr2 := retStr2 &amp; "(" &amp; volumeStr &amp; ") ";
	endif;
	
	col := self.getColour();
	if col &lt;&gt; null then
		retStr2 := retStr2 &amp; col &amp; " ";
	endif;

	if mark.trimBlanks &lt;&gt; null then
		retStr2 := retStr2 &amp; mark &amp; " ";
	endif;

	if retStr1 = null or retStr2 = null then
		inheritMethod( desc1, desc2 );
	else	//19 Jun 2017	NDL	TFS 4587
		if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig( HhIncludeHazDet ).Boolean then
			hazDets := self.getDisplayStringForAttribute( ETRow_AllTIHazards, false );
		endif;
		if hazDets &lt;&gt; null then
			retStr2 := hazDets &amp; ", " &amp; retStr2;
		endif;
	endif;
	
	if retStr2 &lt;&gt; null then
		desc2 := retStr2;
	endif;
	
	if retStr1 &lt;&gt; null then
		desc1 := retStr1;
	endif;

epilog

end;</source>
        <Parameter name="desc1" type="String" usage="output"/>
        <Parameter name="desc2" type="String" usage="output"/>
    </JadeMethod>
