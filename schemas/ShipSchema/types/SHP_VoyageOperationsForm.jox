    <JadeMethod name="doBuildMnuCargo" id="37ba0db3-6576-4fa9-821e-1d1d1c8cfda1">
        <updating/>
        <source>doBuildMnuCargo(ti : CM_TrackedItem) protected, updating;
//-----------------------------------------
// Created: 15 October 2003 By: cnwgd1
//-----------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
16/06/2010	cnwcs5	par 24342 - no context menu for stops
10/02/2020	jlgka1 TFS 48449	SNO - No 'Assign to Intended TBA' Option When Discharged Container is in Queue.
								Make the condition similar to what's in CM_WorkListEntry::getRowColour.
============================================================================*/
vars

begin

	if ti = null then
		self.mnuCargo.visible := false;
		self.mnuEnquiry.userObject := null;		
		self.mnuLocationEnquiry.userObject := null;		
		self.mnuTaskAdd.userObject := null;		
		self.mnuTaskComplete.userObject := null;		
		self.mnuStops.userObject := null;										
		return;
	endif;
	
	//cnwmc5 - PAR #30979
	if not ti.isOnShip then
		self.mnuReturnCargo.visible := false;
	else
		self.mnuReturnCargo.visible := true;
	endif;

	self.mnuAssignToIntendedTBA.userObject := null;										
	self.mnuAssignToIntendedTBA.visible := false; // TFS 45590
	if ti.myMatchedTBA &lt;&gt; null then   // TFS 45590
	//and ti.myPrimaryQueuedLocation &lt;&gt; null then// TFS 45590 //jlgka1 TFS 48449
		self.mnuAssignToIntendedTBA.visible := true; // TFS 45590
		self.mnuAssignToIntendedTBA.userObject := ti;		 // TFS 45590								
	endif;
	if ti.myMatchedActual &lt;&gt; null then  // TFS 45590
	//and ti.myPrimaryPlannedLocation &lt;&gt; null then // TFS 45590 //jlgka1 TFS 48449
		self.mnuAssignToIntendedTBA.visible := true; // TFS 45590
		self.mnuAssignToIntendedTBA.userObject := ti;		 // TFS 45590								
	endif;

	self.mnuCargo.visible := true;
	self.mnuEnquiry.userObject := ti;
	self.mnuLocationEnquiry.userObject := ti.getPrimaryLocation(self.moveModeForm);

	self.mnuTaskAdd.visible := true;
	self.mnuTaskComplete.visible := true;
	self.mnuStops.visible := true;
	self.mnuTaskAdd.userObject := ti;
	self.mnuTaskComplete.userObject := ti;
	self.mnuCargoTaskAdd.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskComplete.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskRemarks.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskAdd.userObject := ti;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskComplete.userObject := ti;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskRemarks.userObject := ti;	//07 Oct 2015	NDL	Par 37011
	self.mnuStops.userObject := ti;
	
	self.doBuildMnuTasksAdd(ti);	
	self.doBuildMnuTasksComplete(ti);	
	// par 24342 self.doBuildMnuStops(ti);	
end;</source>
        <access>protected</access>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuInfoTable" id="18f06b24-6081-44db-82db-9c03e6b2ee99">
