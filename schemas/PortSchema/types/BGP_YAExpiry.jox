<Class name="BGP_YAExpiry" id="91f4e248-9694-4311-9285-7333dbf0b9bd">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Yard Allocation Auto Action&lt;/display&gt;
&lt;displayShort&gt;YA Auto Action&lt;/displayShort&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="action" id="a86bec59-3669-4743-a63a-de08b48c3be0">
        <updating/>
        <source>action(): Boolean updating;
// -------------------------------------------
// Created 03 May 2005 by cnwdvb1
// -------------------------------------------
vars
	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null,  self.getErrorDesc(),errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	self.checkAllocationExpiry();

epilog
	
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkAllocationExpiry" id="fff75fcd-40f9-494d-b349-fb13bdc530a0">
        <source>checkAllocationExpiry() protected;
// -------------------------------------------
// Created 03 May 2005 by cnwdvb1
// -------------------------------------------
vars

	root			: CM_Root;
	terminal		: CM_Terminal;
	yardAllocation	: CM_YardAllocation;
	deleteSet		: CM_YardAllocationSet;
	clearSet		: CM_YardAllocationSet;
	code			: String;

begin

	root := app.myRoot;
	
	create deleteSet transient;
	create clearSet transient;	//29 Jun 2011	NDL	Par 27786
	
	foreach terminal in root.allTerminals discreteLock do
		foreach yardAllocation in terminal.allYardAllocations discreteLock do
			self.sharedLock(yardAllocation);
			if yardAllocation.hasYardAllocationExpired() then
				//29 Jun 2011	NDL	Par 27786
				if yardAllocation.expiryType = YAExpiryType_VoyageClear then
					clearSet.add(yardAllocation);
				else
					deleteSet.add(yardAllocation);
				endif;
			else
				self.unlock(yardAllocation);
			endif;
		endforeach;
	endforeach;
	
	foreach yardAllocation in deleteSet do
		code := yardAllocation.code;
		app.myTrxDA.trxDeleteYardAllocation(yardAllocation, app.myPassport);
		if not app.myPassport.trxCompletedOK() then
			app.remoteErrorWarningToAlert('Unable to automatically delete yard allocation ' &amp; yardAllocation.code, 
										null, app.myPassport.allErrors, null, true, true);
		else
			app.createActivityHistory(ActivityHistoryGeneral, app.myPassport.myTerminal, null, 
			'Allocation ' &amp; code &amp; ' has expired and has been automatically deleted', false, false);
		endif;
	endforeach;
	
	//29 Jun 2011	NDL	Par 27786
	foreach yardAllocation in clearSet do
		code := yardAllocation.code;
		app.myTrxUA.trxClearYardAllocation(yardAllocation, app.myPassport);
		if not app.myPassport.trxCompletedOK() then
			app.remoteErrorWarningToAlert('Unable to automatically clear yard allocation ' &amp; yardAllocation.code, 
										null, app.myPassport.allErrors, null, true, true);
		else
			app.createActivityHistory(ActivityHistoryGeneral, app.myPassport.myTerminal, null, 
			'Allocation ' &amp; code &amp; ' has expired and has been automatically cleared', false, false);
		endif;
	endforeach;
	
epilog
	delete deleteSet;
	delete clearSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
