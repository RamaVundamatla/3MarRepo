    </JadeMethod>
    <JadeMethod name="isThereRoomForTi" id="b021bb9c-9a7f-4a7c-a638-cba24473d5ca">
        <source>isThereRoomForTi( _primaryWagonController : CM_WagonController; _ti : CM_TrackedItem ):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	primaryPortion : Integer;
	availableLengthFreeSpace : Integer;
	tiLen : Integer;
	wagon : CM_Wagon;
	iter : Iterator;
	wagCont : CM_WagonController;
	atHeight : Integer;

begin

	if _ti = null then
		return false;
	endif;
	
	if _primaryWagonController = null then
		return false;
	endif;

	if _primaryWagonController.offsetFlexi = 0 then
		primaryPortion := 10;
	else
		primaryPortion := (10 - _primaryWagonController.offsetFlexi).Integer;
	endif;
	
	availableLengthFreeSpace := primaryPortion;
	tiLen := _ti.getActualLength().Integer;
	
	if availableLengthFreeSpace &gt;= tiLen then
		return true;
	endif;
	
	wagon := _primaryWagonController.myWagon;
	if wagon = null then
		return false;
	endif;
	
	//15 Oct 2014	NDL	Par 35040
	atHeight := 1;
	if wagon.myWagonClass &lt;&gt; null and wagon.isFlatcar then
		if wagon.myWagonClass.maxNumInStack &gt; 1 and _primaryWagonController.allTrackedItems.size &lt; wagon.myWagonClass.maxNumInStack then
			atHeight := _primaryWagonController.allTrackedItems.size + 1;
		endif;
	endif;
	
	iter := wagon.allLocationsControllersArray.createIterator;
	iter.startAtObject(_primaryWagonController);
	while iter.next( wagCont ) do
		if wagCont = _primaryWagonController then
			//skip the starting one, we've already added it.
			continue;
		endif;
	//	if not wagCont.allTrackedItems.isEmpty then
		if wagCont.allTrackedItems.size &gt;= atHeight then
			//no more room.
			return false;
		else
			//found another 10 contiguous feet
			availableLengthFreeSpace := availableLengthFreeSpace + 10;
		endif;
		if availableLengthFreeSpace &gt;= tiLen then
			return true;
		endif;
	endwhile;
	
	return false;
	
epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_primaryWagonController" type="CM_WagonController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateTrackedItem" id="fa05f9fa-d7f5-4510-8a3f-9a430a3bbfc0">
        <source>populateTrackedItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars
	ti : CM_TrackedItem;
	wagon : CM_Wagon;
	wagonId : String;
begin

	ti := self.myMobileGenericAgent.myNextTiToAction;
	wagon := self.myMobileGenericAgent.myCurrentWagon;

	if wagon &lt;&gt; null then
		wagonId := wagon.id &amp; "  @  ";
	endif;
	
	if ti = null then
		self.cmbSearchItem.visible := true;
		self.txtId.visible := false;
		self.btnRemove.enabled := false;
		self.txtId.text := null;
		self.txtIsoType.text := null;
		self.lblCargoType.caption := null;
		self.lblLocation.caption := wagonId &amp; self.myMobileGenericAgent.myLocationsController.getFullId;
		self.btnSearch.visible := true;
		
	else
		self.cmbSearchItem.visible := false;
		self.txtId.visible := true;
		self.btnRemove.enabled := true and not wagon.confirmed;
		self.txtId.text := ti.id;
		self.txtIsoType.text := ti.getISOType;
		if ti.isKindOf(CM_Generator) then
			if self.txtIsoType.text = null then
				self.txtIsoType.text := "GEN";
			endif;
			self.txtIsoType.enabled := false;
		endif;
		self.lblCargoType.caption := ti.cargoTypeDescr;
		self.lblLocation.caption := wagonId &amp; ti.myPrimaryActualLocation.getFullId;
		self.btnSearch.visible := false;
		
	endif;

epilog

end;</source>
    </JadeMethod>
