	container22Obj := self.addCtrAtLocnDischWithBol(Container22, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, voyageNew.allPorts.first, voyageNew, "123456");		//UTOP - CARGRP2
