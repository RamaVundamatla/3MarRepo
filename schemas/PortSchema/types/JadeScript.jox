    <JadeMethod name="diBargeUnload" id="92d26ca0-42ba-4312-b394-ca8f8086a850">
        <source>diBargeUnload();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
08 November 2019	jlgdi1				Initial creation
*/

vars
	terminal : CM_Terminal;
	voyage : CM_Voyage;
	jobsheet : CM_VoyageJobSheet;
	transaction : CM_TITransaction;
	message : StringArray512;
	msgb : String;
	
begin
	terminal  := app.myRoot.getTerminalByName("Terminal Two");
	write "Terminal : " &amp; terminal.name;
	
	foreach voyage in CM_Voyage.instances do
		if voyage.isBarge then
			message.add(voyage.description);
			foreach jobsheet in voyage.allJobSheets do 
				// get the first hold job
				if (jobsheet.isKindOf(CM_VoyageHoldJobSheet)) and 
				   (jobsheet.myWorkPoint &lt;&gt; null) and 
				   (jobsheet.CM_VoyageHoldJobSheet.allShipReceivals.size &gt; 0)
				then 
					message.add(voyage.description &amp; " " &amp; 
					jobsheet.myWorkPoint.description &amp; " " &amp;
					jobsheet.CM_VoyageHoldJobSheet.allShipReceivals.size.asStringJMT());
					
					foreach transaction in jobsheet.CM_VoyageHoldJobSheet.allShipReceivals do
						message.add("Receive on " &amp; transaction.dateTime.asStringJMT());
					endforeach;
				endif;
			endforeach;		
		endif;
	endforeach;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="diCODECOAdhocRequest" id="ae80be86-a89a-44f7-9629-fa94dbd2fe59">
        <source>diCODECOAdhocRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2019	jlgdi1	Initial creation
*/

constants
	CAMProtocol : String = "UT_HSDCODECO";
	Terminal1	: String = 'MA';
		
	StartDate	: Date = '01/03/2020'.Date;
	EndDate1	: Date = '04/11/2020'.Date;
	StartTime	: Time = '18:19:00:000'.Time;
	EndTime		: Time = '18:30:00:000'.Time;

	/*
	StartDate	: Date = '04/11/2019'.Date;
	EndDate1	: Date = '04/11/2019'.Date;
	StartTime	: Time = '11:17:00:000'.Time;
	EndTime		: Time = '11:18:00:000'.Time;
	*/
	
vars
	camProtocol		: CM_CamProtocol;
	runDateTime		: TimeStamp;
	startDateTime	: TimeStamp;
	endDateTime		: TimeStamp;
	valDate			: Date;
	valTime			: Time;
	terminal		: CM_Terminal;
	camsController : CM_CamControllerAgent;
	
begin
	app.initialize();
	// setup start and end dates/time and protocol to use
	valDate := StartDate;
	valTime := StartTime;
	startDateTime.setDate(valDate);
	startDateTime.setTime(valTime);
	if not startDateTime.isValid() then
		write 'startDateTime is not valid';
		return;
	endif;
	
	valDate := EndDate1;
	valTime := EndTime;
	endDateTime.setDate(valDate);
	endDateTime.setTime(valTime);
	if not endDateTime.isValid() then
		write 'endDateTime is not valid';
		return;
	endif;
	
	runDateTime := app.actualTimeServer;
	app.hideDebug	:= false;			// false implies do not hide debugging - helps with display messages
	terminal		:= app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	
	camProtocol := terminal.camProtocols[CAMProtocol];
	if camProtocol = null then
		app.writeStatement("Cannot find required cam protocol description");
		return;
	endif;
	
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	
	on Exception do null global;
	
	app.setPassBackExceptions(true, true);
	create camsController transient;
	camsController.setMyTerminal(terminal);
	camsController.adhocTask(camProtocol, startDateTime, endDateTime, runDateTime, true, true);	//this does runs the adhoc cams
	
epilog
	delete camsController;
end;</source>
    </JadeMethod>
    <JadeMethod name="diCargoCheck" id="1cb8b587-4d91-45ba-8f1a-e3c51a817869">
        <source>diCargoCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2019	jlgdi1	Initial creation

*/

vars
	queryBuilderAgent : CM_QueryBuilderAgent;
	object : Object;
	validImexStatuses : IntegerArray;
	
	trackedItems : CM_TISet;
	cargoType : CM_CargoType;
	terminal : CM_Terminal;
	operator : CM_Operator;
	product : CM_Product;
	
	now : TimeStamp;
	theUser : CM_User;
	monitor	: CMIF_Monitor;
	
begin
	app.initialize();
	theUser := CM_Root.firstInstance.allUsers["JLGDI1"];
	app.myPassport.setMyUser(theUser);
	
	create trackedItems transient;
	create queryBuilderAgent transient;	
	create monitor transient;	
   	app.myPassport.setMyCMIFMonitor(monitor);
	//monitor.myParent := CM_Operator;
	
	terminal  := app.myRoot.getTerminalByName("Terminal Two");
	write "Terminal : " &amp; terminal.name;
	
	cargoType := app.myRoot.allCargoTypesById[22452];
	
	//app.myPassport.setMyCMIFMonitor(monitor);
	//app.myPassport.setMyTerminal(terminal);
	
	//cargoType := "2083.22698".asOid.CM_CargoType;
	write "Cargo Type : " &amp; cargoType.description;
	
	operator := "2312.29749".asOid.CM_Operator;
	write "Operator : " &amp; operator.description;
	
	//product := "".asOid.CM_Product;
	product := null;
	
	queryBuilderAgent.setResultArray(trackedItems);
	queryBuilderAgent.setQueryMode(cargoType);
	
	// Terminal = this terminal
	queryBuilderAgent.addCriteria(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, terminal);
	
	// Site / State = On Site
	queryBuilderAgent.addCriteria(CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, TI_STATE_NORMAL);
	
	// Imex Status = {Import, Storage}
	create validImexStatuses transient;
	validImexStatuses.add(TI_IMEX_STATUS_IMPORT);
	validImexStatuses.add(TI_IMEX_STATUS_STORAGE);
	queryBuilderAgent.addCriteria(CM_TrackedItem::imexStatus.name, CM_QueryOperator.Operator_IsOneOf, validImexStatuses);
	
	// NOT isChild
	queryBuilderAgent.addCriteria(CM_TrackedItem::isChild.name, CM_QueryOperator.Operator_Equal, null);
	
	// Available = yes
	queryBuilderAgent.addCriteria(CM_TrackedItem::isAvailable.name, CM_QueryOperator.Operator_Equal, AuditStringValue_Yes);
	
	// Operator
	queryBuilderAgent.addCriteria(CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, operator);
			
	// Cargo Type
	queryBuilderAgent.addCriteria(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
		
	// Cargo Sub Type
	if product &lt;&gt; null then 
		queryBuilderAgent.addCriteria(CM_TrackedItem::myProduct.name, CM_QueryOperator.Operator_Equal, product);
	endif;
	
	write "Start : " &amp; now.display();
	if queryBuilderAgent.query &lt;&gt; null then 
		queryBuilderAgent.doQuery();
	endif;
	write "Completed : " &amp; now.display();
	
	write queryBuilderAgent.allObjects.size.asStringJMT();
	
epilog
	delete trackedItems;
	delete queryBuilderAgent;
	delete monitor;
end;

/*	
vars
	trackedItem : CM_TrackedItem;
	
begin
	trackedItem := "4022.116972".asOid.CM_TrackedItem;
	if trackedItem &lt;&gt; null then	
		write "Terminal : " &amp; trackedItem.myTerminal.name;
		write "Onsite : " &amp; trackedItem.isOnSite().asStringJMT;
		write "Is Available : " &amp; trackedItem.isAvailable.asStringJMT;
		write "Is Child : " &amp; trackedItem.isChild().asStringJMT;
		if trackedItem.getImExStatus = TI_IMEX_STATUS_STORAGE then 
			write "Imex Status is Storage";
		elseif trackedItem.getImExStatus = TI_IMEX_STATUS_IMPORT then 
			write "Imex Status is Import";
		else
			write "Imex Status niether Storage nor Import";
		endif;
	endif;
end;
*/</source>
    </JadeMethod>
