/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2010	cnwmd1	Initial creation

*/

vars
	ts : TimeStamp;
begin
	if myTrackedItem = null then
		return null;
	endif;
	ts.setDate(myTrackedItem.packDate);
	ts.setTime(myTrackedItem.packTime);
	
	return ts;
epilog

