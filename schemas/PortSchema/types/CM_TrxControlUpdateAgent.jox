/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2014	cnwndl1	Initial creation
17 October 2022 navhl20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
*/

vars

	realType : CM_VehicleBookingTimeSlotType;
	expectedEdition:Integer;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	app.myUtilityUA.utlUpdateVBSlotType(pProxyCode, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxyCode" type="CM_VehicleBookingTimeSlotType" usage="input"/>
