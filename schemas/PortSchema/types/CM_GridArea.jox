    <JadeMethod name="setForCreate" id="3585abef-cec3-46ff-8195-e2c3ecc00752">
        <updating/>
        <source>setForCreate(_proxy : CM_GridArea input; _passport : CM_Passport input) updating;
//setForCreate(_proxy : CM_GridArea; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	concms1		ccms 1061 - Changed method signature to use proxy rather than controller
// ---------------------------------------------------------------------------
vars
	
begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	inheritMethod(_proxy, _passport);
	
	self.setForUpdate(_proxy);
	
	
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 51854 08FEB2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TERMINALAREA, self); // ### TFS 51854 08FEB2022 NAVAB1
	endif;
	
end;</source>
        <Parameter name="_proxy" type="CM_GridArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="aea7b243-d24a-41ea-ae86-f61d111fdf5a">
        <updating/>
        <source>setForUpdate(_proxy :CM_GridArea) updating;
//setForUpdate(_proxy : CM_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_proxy);
	
	
	self.use40ftIds			:= _proxy.use40ftIds;	// 08 Aug 2011	NDL Par 27308 - Moved up, used when updating the controllers 
	
	self.allGridControllersByRowColumn.purge;
	self.allGridColumns.purge;
	self.allGridRows.purge;
	self.setRowsColsAndControllers(_proxy);
	self.defaultDeckingStartType := _proxy.defaultDeckingStartType;
	
	//self.heightOfStack		:= _proxy.heightOfStack;
	self.setHeightOfStack( _proxy.heightOfStack );	//28 May 2012	NDL	Par 29604
	self.numberOfColumns	:= _proxy.numberOfColumns;
	self.numberOfRows		:= _proxy.numberOfRows;
	self.noAccessLeft		:= _proxy.noAccessLeft; // CCMS 1509
	self.noAccessRight		:= _proxy.noAccessRight; // CCMS 1509
	
	self.isAlignRight 		:= _proxy.isAlignRight; // PAR 18682 CCMS SFW 1055
	self.isSnapToBackend 	:= _proxy.isSnapToBackend; // PAR 18682 CCMS SFW 1055
	self.isSnapStrictGrid 	:= _proxy.isSnapStrictGrid; // PAR 18682 CCMS SFW 1055
//	self.use40ftIds			:= _proxy.use40ftIds; //epr CCMS 1076 20/8/09
	self.useSideAccessRules	:= _proxy.useSideAccessRules;	// PAR 21532 CCMS SFW 1025
	self.maxHeight			:= _proxy.maxHeight;	// par 27198 cnwjre1 Apr 2011

	setPreviousControllers();

end;</source>
        <Parameter name="_proxy" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateInUse" id="d8e673a2-7bf9-4b2f-bbb2-7dad2c03016d">
        <updating/>
        <source>setForUpdateInUse(_proxy: CM_GridArea; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// cnwcs5	21/07/2009	ccms 1061 - change method signature to use procy instead of controller

vars
	isUpdate : Boolean;

begin
	isUpdate := _proxy.pxyGetRealObject() &lt;&gt; null; // ### TFS 51854 08FEB2022 NAVAB1

	inheritMethod(_proxy, _passport);

	self.defaultDeckingStartType	:= _proxy.defaultDeckingStartType;
	//self.heightOfStack				:= _proxy.heightOfStack;
	self.setHeightOfStack( _proxy.heightOfStack );	//28 May 2012	NDL	Par 29604
	self.numberOfColumns			:= _proxy.numberOfColumns;
	self.numberOfRows				:= _proxy.numberOfRows;
	self.noAccessLeft				:= _proxy.noAccessLeft; // CCMS 1509
	self.noAccessRight				:= _proxy.noAccessRight; // CCMS 1509
	self.isAlignRight 				:= _proxy.isAlignRight; // PAR 18682 CCMS SFW 1055
	self.isSnapToBackend 			:= _proxy.isSnapToBackend; // PAR 18682 CCMS SFW 1055
	self.isSnapStrictGrid 			:= _proxy.isSnapStrictGrid; // PAR 18682 CCMS SFW 1055
	self.use40ftIds					:= _proxy.use40ftIds; //epr CCMS 1076 20/8/09
	self.useSideAccessRules			:= _proxy.useSideAccessRules;	// PAR 21532 CCMS SFW 1025
	self.maxHeight					:= _proxy.maxHeight;	// par 27198 apr 2011 cnwjre1
	self.setRowsColsAndControllers(_proxy);
	self.setPreviousControllers();
	
	
	if isUpdate then // ### TFS 51854 08FEB2022 NAVAB1
	
		if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 51854 08FEB2022 NAVAB1
			self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TERMINALAREA, self); // ### TFS 51854 08FEB2022 NAVAB1
		endif;
	
	endif;
	
end;</source>
        <Parameter name="_proxy" type="CM_GridArea"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setGridAreaProxy" id="17729787-78d3-49ca-9cd4-714067c626be">
        <updating/>
        <source>setGridAreaProxy(_id,
				_comment			: String; 
		 		_type 				: Integer;
		 		_rows 				: Integer;
		 		_cols 				: Integer;
		 		_height 			: Integer;
		 		_actAsReleasePoint : Boolean;
		 		_terminal			: CM_Terminal;
		 		_tmpAutoRestriction,
		 		_stockControlled,
				_hideFromOverView : Boolean;
				_deckingStartType: Integer;
				_noLeft, _noRight : Boolean;
				_snapLeft, _goRight, _snapStrict : Boolean;
				_allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
				_defaultInterchangeArea: CM_InterchangeArea;
				_use40ftIds, 
				_useSideAccessRules : Boolean;
				_leftlabel, 
				_rightLabel, 
				_topLabel, 
				_bottomLabel : String) updating;
/*

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
19 AUG 08	CNWER1		PAR 17760 - removed group sequence number
02 Feb 09	CNWER1		CCMS 1100 - allow RTGs to set top and bottom labels
26/05/2010	cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
*/
				
				
begin

	self.raiseExceptionIfNotTransient(method);
	self.setProxyTerminalArea(_id, _comment, _type, _actAsReleasePoint, _terminal, _tmpAutoRestriction, _stockControlled, _hideFromOverView, _allInterchangeAreas,_defaultInterchangeArea);
	self.numberOfRows := _rows;
	self.numberOfColumns := _cols;
	//self.heightOfStack := _height;
	self.setHeightOfStack( _height );	//28 May 2012	NDL	Par 29604
	self.defaultDeckingStartType := _deckingStartType;
	self.noAccessLeft			:= _noLeft; // CCMS 1509
	self.noAccessRight			:= _noRight; // CCMS 1509
	self.isSnapToBackend := _snapLeft; // PAR 18682 CCMS SFW 1055
	self.isAlignRight := _goRight; // PAR 18682 CCMS SFW 1055
	self.isSnapStrictGrid := _snapStrict; // PAR 18682 CCMS SFW 1055
	self.use40ftIds :=_use40ftIds; //epr CCMS 1076 RMGs
	self.useSideAccessRules	:= _useSideAccessRules;	// PAR 21532 CCMS SFW 1025
	self.pxySetLabels(	_leftlabel, 
						_rightLabel, 
						_topLabel, 
						_bottomLabel); 		//epr CCMS 1100 2/2/10
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_cols" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_actAsReleasePoint" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_tmpAutoRestriction" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_deckingStartType" type="Integer"/>
        <Parameter name="_noLeft" type="Boolean"/>
        <Parameter name="_noRight" type="Boolean"/>
        <Parameter name="_snapLeft" type="Boolean"/>
        <Parameter name="_goRight" type="Boolean"/>
        <Parameter name="_snapStrict" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
        <Parameter name="_use40ftIds" type="Boolean"/>
        <Parameter name="_useSideAccessRules" type="Boolean"/>
        <Parameter name="_leftlabel" type="String"/>
        <Parameter name="_rightLabel" type="String"/>
        <Parameter name="_topLabel" type="String"/>
        <Parameter name="_bottomLabel" type="String"/>
    </JadeMethod>
