    </MemberKey>
    <JadeMethod name="getChequeBanks" id="08561909-30b6-4de4-b8b0-e258cd9285b9">
        <source>getChequeBanks():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2013	cnwndl1	Initial creation	Par 33182

*/
vars

	workStr : String;
	cashReceipt : CM_CashReceipt;

begin

	foreach cashReceipt in self do
		if cashReceipt.chequeNumber = null then
			continue;
		endif;
		if workStr &lt;&gt; null then
			workStr := workStr &amp; ",";
		endif;
		workStr := workStr &amp; cashReceipt.chequeBank;
	endforeach;
	
	return workStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
