    <JadeMethod name="chkForeignIn_click" id="f067ad1b-d534-42a5-8687-6243d6d4d994">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkForeignIn_click(checkbox: CheckBox input) updating;
/*
Date		Who		Reason
04 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	if checkbox.value then
		self.grpForeignIn.visible := true;
	else
		self.grpForeignIn.visible := false;
	endif;
	
	self.setupControls (self.cmbType.getCurrentItemData);
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
