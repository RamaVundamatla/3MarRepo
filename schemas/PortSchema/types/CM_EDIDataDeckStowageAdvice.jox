    <JadeMethod name="verifyEDIDataTIs" id="ffe83d99-df97-4ad0-a2c1-7f645265afdc">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
/*
Purpose:			
Date		Who		Reason
02 November 2011	cnwab1	Initial creation
02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
*/

vars

begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
//	app.setContinueCMExceptions(false);	//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
	
	app.myTrxCA.trxCreateEDIDeckStowageAdvice(true,  self, _passport);
	if _passport.hasErrors then 
		return _passport.allErrors.size;
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="warnOnDBLoad" id="c4e38b43-c63c-4527-84a4-af18d4ca5a2e">
        <source>warnOnDBLoad(_message: String output; _flags: Integer output; _intCancel: Integer output);
/*
Purpose:			29884
Date				Who			Reason
JULY 2012		CNWAB1		Initial creation
*/
vars
	ediData : CM_EDITrackedItem;

	voy : CM_Voyage;
begin

	foreach ediData in self.allEDITrackedItems where ediData.class = CM_EDIVoyageHeaderTI do
		voy := ediData.CM_EDIVoyageHeaderTI.getVoyageObject();
		break;
	endforeach;

	if voy = null then
		return;
	endif;
	
	if voy.myROROStructure = null then
		return;
	endif;

	if voy.myROROStructure.hasLoadCC() then
		_message	:= app.getErrorString(WARN_EDI_LOAD_STOW);
		_flags		:= MsgBox_Yes_No + MsgBox_Question_Mark_Icon;
		_intCancel	:= MsgBox_Return_No;
	endif;
end;</source>
        <Parameter name="_message" type="String" usage="output"/>
        <Parameter name="_flags" type="Integer" usage="output"/>
        <Parameter name="_intCancel" type="Integer" usage="output"/>
    </JadeMethod>
</Class>
