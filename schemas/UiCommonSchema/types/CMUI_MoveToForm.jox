    <JadeMethod name="populateParents" id="dcf2c0e3-9901-4145-b3e4-f15996d9c85f">
        <updating/>
        <source>populateParents() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2014	cnwndl1	Initial creation	Par 34665

*/

vars

	moveModeTypeStr : String;
	moveMode : Integer;
	targetLoc : CM_LocationsController;
	ti : CM_TrackedItem;
	newIndex : Integer;
	refresh : Boolean;

begin

	moveModeTypeStr := self.tblMove.getValueByName(ETRow_MoveType).String;
	moveMode	:= app.moveModeStringToMoveMode(moveModeTypeStr);
	
	if moveMode &lt;&gt; INSTANT_PACK_MODE then
		self.cmbParent.clear();
		self.tblMove.hideRowByName(ETRow_Parent, false);
	
	else
		targetLoc := self.getTargetLocation(false);
		self.tblMove.showRowByName(ETRow_Parent, false);
		
		if targetLoc &lt;&gt; null then
			if self.cmbParent.listCount &lt; 1 then
				refresh := true;
			else
				ti := self.cmbParent.itemObject[1].CM_TrackedItem;
				if ti.myPrimaryActualLocation &lt;&gt; targetLoc then
					refresh := true;
				endif;
			endif;
			
			if refresh then
				self.cmbParent.clear();
				foreach ti in targetLoc.allTrackedItems do
					newIndex := self.cmbParent.addItem( ti.id );
					self.cmbParent.itemObject[newIndex] := ti;
				endforeach;
			endif;
		endif;
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="f53ea93d-c62b-48b3-a0c2-cdbff9b4b52d">
