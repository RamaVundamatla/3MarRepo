    <JadeMethod name="setForCreate" id="b92333dd-afbe-4548-ade1-7972f40b66c4">
        <updating/>
        <source>setForCreate(_pxyEmailTemplate : CM_EmailTemplate) updating;
// ---------------------------------------------------------------------------
// Created:     17 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.setForUpdate(_pxyEmailTemplate);

end;</source>
        <Parameter name="_pxyEmailTemplate" type="CM_EmailTemplate"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e5a62a30-e15f-4b09-89ef-82dcbc00adb2">
        <updating/>
        <source>setForUpdate(_pxyEmailTemplate : CM_EmailTemplate) updating;
// ---------------------------------------------------------------------------
// Created:     17 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//16/01/2023 navmv20 TFS 55307 Task 55514: Jade - Email Invoice Attachments Jade Code
vars

begin

	// commented. Par 19427 April 2009. It seemes not to be used - redundant.
	//self.myMenuUserReport := _pxyEmailTemplate.myMenuUserReport;

	self.allAttachedFilePaths.purge();
	_pxyEmailTemplate.allAttachedFilePaths.copy(self.allAttachedFilePaths);
	
	self.allBCCAddresses.clear();
	_pxyEmailTemplate.allBCCAddresses.copy(self.allBCCAddresses);
	
	self.allCCAddresses.clear();
	_pxyEmailTemplate.allCCAddresses.copy(self.allCCAddresses);	

	self.allToAddresses.clear();
	_pxyEmailTemplate.allToAddresses.copy(self.allToAddresses);

	self.bccAddresses 	:= _pxyEmailTemplate.bccAddresses;
	self.body			:= _pxyEmailTemplate.body;
	self.ccAddresses	:= _pxyEmailTemplate.ccAddresses;
	self.subject 		:= _pxyEmailTemplate.subject;
	self.toAddresses	:= _pxyEmailTemplate.toAddresses;
	
	self.useExtraInfoInSubjectLine := _pxyEmailTemplate.useExtraInfoInSubjectLine;
	
	//added. Par 19427 April 2009
	self.allIncludedFields.clear();
	_pxyEmailTemplate.allIncludedFields.copy(self.allIncludedFields);
	self.entTableName	:= _pxyEmailTemplate.entTableName;
	self.name			:= _pxyEmailTemplate.name;
	self.objectType		:= _pxyEmailTemplate.objectType;
	self.type			:= _pxyEmailTemplate.type;
	
	// cnwrl1 29/07/2009 PAR 20349 - start of coding
	self.copyTo				:= _pxyEmailTemplate.copyTo;
	self.sendToCarrier		:= _pxyEmailTemplate.sendToCarrier;
	self.sendToConsignee	:= _pxyEmailTemplate.sendToConsignee;
	// cnwrl1 29/07/2009 PAR 20349 - end of coding
	
	self.sendtoOperatorCargo := _pxyEmailTemplate.sendtoOperatorCargo;	//26 Apr 2018	NDL	TFS 38198
	self.sendtoOperatorVoyage := _pxyEmailTemplate.sendtoOperatorVoyage;	//26 Apr 2018	NDL	TFS 38198
	self.sendToOperatorCargoReqs := _pxyEmailTemplate.sendToOperatorCargoReqs;	//15 Oct 2018	NDL	TFS 41387
	self.attachFiles := _pxyEmailTemplate.attachFiles; //16/01/2023 navmv20 TFS 55307 TASK 55514
end;</source>
        <Parameter name="_pxyEmailTemplate" type="CM_EmailTemplate"/>
    </JadeMethod>
    <JadeMethod name="setFromObjectEmail" id="828c9510-6464-4420-bf6e-0a6ed0b64b4b">
        <updating/>
        <source>setFromObjectEmail(_objectEmail: CM_ObjectEmail) updating;
/* ---------------------------------------------------------------------------
Created:	15 April 2009	by cnwvu1

Purpose:	Par 19427. For storing email info on the DB
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
//16/01/2023 navmv20 TFS 55307 Task 55514: Jade - Email Invoice Attachments Jade Code
vars
	tmpObjectEmail		: CM_ObjectEmail;
	tmpEmailController	: CMIF_EmailTemplateController;
	
begin

	if _objectEmail = null then
		return;
	endif;
	tmpObjectEmail := _objectEmail;
	
	self.allToAddresses.clear;
	self.allBCCAddresses.clear;
	self.allCCAddresses.clear;
	
	if tmpObjectEmail.myEmailController &lt;&gt; null then
	
		//collections
		tmpEmailController	:= tmpObjectEmail.myEmailController;
		if tmpEmailController.allToAddresses &lt;&gt; null then
			tmpEmailController.allToAddresses.copy(self.allToAddresses);
		endif;
		if tmpEmailController.allBccAddresses &lt;&gt; null then
			tmpEmailController.allBccAddresses.copy(self.allBCCAddresses);
		endif;
		if tmpEmailController.allCcAddresses &lt;&gt; null then
			tmpEmailController.allCcAddresses.copy(self.allCCAddresses);
		endif;
		//free text
		self.toAddresses	:= tmpEmailController.freeTxtToAddesses;
		self.bccAddresses	:= tmpEmailController.freeTxtBccAddesses;
		self.ccAddresses	:= tmpEmailController.freeTxtCcAddesses;
		
		self.sendtoOperatorCargo := tmpEmailController.getSendtoOperatorCargo;	//24 Apr 2018	NDL	TFS 38198
		self.sendtoOperatorVoyage := tmpEmailController.getSendtoOperatorVoyage;	//24 Apr 2018	NDL	TFS 38198
		self.sendToOperatorCargoReqs := tmpEmailController.getSendToOperatorCargoReqs;	//15 Oct 2018	NDL	TFS 41387
	
	endif;
	
	self.allIncludedFields.clear;
	if tmpObjectEmail.allIncludedFields &lt;&gt; null then
		tmpObjectEmail.allIncludedFields.copy(self.allIncludedFields);
	endif;

	self.entTableName	:= tmpObjectEmail.entTableName;
	self.body			:= tmpObjectEmail.message;
	self.name			:= tmpObjectEmail.name;
	self.objectType		:= tmpObjectEmail.objectType;
	self.subject		:= tmpObjectEmail.subjectLine;
	self.type			:= tmpObjectEmail.type;
	
	// cnwrl1 29/07/2009 PAR 20349 - start of coding
	self.copyTo				:= tmpObjectEmail.copyTo;
	self.sendToCarrier		:= tmpObjectEmail.sendToCarrier;
	self.sendToConsignee	:= tmpObjectEmail.sendToConsignee;
	// cnwrl1 29/07/2009 PAR 20349 - end of coding
	
	//16/01/2023 TFS 55307 TASK 55514 - START
	if tmpObjectEmail.isKindOf(CM_InvStatusDefaultEmail) then
		self.attachFiles := tmpObjectEmail.CM_InvStatusDefaultEmail.attachFiles;  
	endif;
	//16/01/2023 TFS 55307 TASK 55514 - END
end;</source>
        <Parameter name="_objectEmail" type="CM_ObjectEmail"/>
    </JadeMethod>
    <JadeMethod name="setFromObjectEmailTI" id="b6fff0d5-f174-48ed-813a-26a03a14b898">
        <updating/>
        <source>setFromObjectEmailTI(_objectEmail: CM_ObjectEmail; _ti: CM_TrackedItem) updating;
//----------------------------------------------------------------
//	Created:	28 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpObjectEmail	: CM_ObjectEmail;
	tmpTI			: CM_TrackedItem;
	tmpToStr		: String;
begin

	tmpObjectEmail	:= _objectEmail;
	tmpTI			:= _ti;
	
	self.allAttachedFilePaths.clear;
	self.allBCCAddresses.clear;
	self.allCCAddresses.clear;
	self.allToAddresses.clear;
	
	self.toAddresses := tmpObjectEmail.getToAddresses();
	
	if tmpObjectEmail.myEmailController &lt;&gt; null then
		self.ccAddresses := tmpObjectEmail.myEmailController.freeTxtCcAddesses;
		self.bccAddresses := tmpObjectEmail.myEmailController.freeTxtBccAddesses;
	endif;
	
	self.subject := tmpTI.getObjectEmailSubject(tmpObjectEmail);
	self.body := tmpTI.getObjectEmailBody(tmpObjectEmail);

end;</source>
        <Parameter name="_objectEmail" type="CM_ObjectEmail"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMyParent" id="25dffbcc-1765-4327-8f79-1a90d30edce2">
        <updating/>
        <source>setMyParent( _parent : CM_Object ) updating;
/* ---------------------------------------------------------------------------
Created:	17 April 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="07474525-db58-4899-8c79-82653cf40c63">
        <updating/>
        <source>setProxy(	_toAddresses,
			_ccAddresses,
			_bccAddresses				: CM_EmailEntityByTypeNameDict;
			_fromAddress				: CM_EmailEntity;
			_freeTo,
			_freeCC,
			_freeBCC,
			_subject,
		 	_body 						: String;
		 	_useExtraInfoInSubjectLine	: Boolean
			) updating;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allToAddresses.clear();
	self.allCCAddresses.clear();
	self.allBCCAddresses.clear();
	if _toAddresses &lt;&gt; null then
		_toAddresses.copy(self.allToAddresses);
	endif;
	if _ccAddresses &lt;&gt; null then
		_ccAddresses.copy(self.allCCAddresses);
	endif;
	if _bccAddresses &lt;&gt; null then
		_bccAddresses.copy(self.allBCCAddresses);
	endif;
	
	self.myFromAddress := _fromAddress;
	
	self.toAddresses := _freeTo;
	self.ccAddresses := _freeCC;
	self.bccAddresses := _freeBCC;
	
	self.subject		:= _subject;
	self.body			:= _body;
	self.useExtraInfoInSubjectLine := _useExtraInfoInSubjectLine;
	
end;</source>
        <Parameter name="_toAddresses" type="CM_EmailEntityByTypeNameDict"/>
        <Parameter name="_ccAddresses" type="CM_EmailEntityByTypeNameDict"/>
        <Parameter name="_bccAddresses" type="CM_EmailEntityByTypeNameDict"/>
        <Parameter name="_fromAddress" type="CM_EmailEntity"/>
        <Parameter name="_freeTo" type="String"/>
        <Parameter name="_freeCC" type="String"/>
        <Parameter name="_freeBCC" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_body" type="String"/>
        <Parameter name="_useExtraInfoInSubjectLine" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyForEDIIssue" id="72200df9-1ff2-4bc9-9c55-bf020ede7217">
        <updating/>
        <source>setProxyForEDIIssue(_freeTo,
			_freeCC,
			_freeBCC,
			_subject,
		 	_body,
			_name : String;
			_include5 : Boolean;
			_included : StringArray) updating;
/*
Purpose:	

Date		Who		Reason
15 July 2024	navab1	CR 64617 TASK 64638
*/

vars

begin
	self.entTableName := ETDef_EDIEmailFields;
	self.name := _name;
	self.toAddresses := _freeTo;
	self.ccAddresses := _freeCC;
	self.bccAddresses := _freeBCC;
	
	self.subject		:= _subject;
	self.body			:= _body;
	self.allIncludedFields.clear();
	_included.copy(self.allIncludedFields);
	
	self.sendtoOperatorVoyage := _include5;
	
	self.type := PINEmail_EDIIssue;
epilog

end;</source>
        <Parameter name="_freeTo" type="String"/>
        <Parameter name="_freeCC" type="String"/>
        <Parameter name="_freeBCC" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_body" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_include5" type="Boolean"/>
        <Parameter name="_included" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setProxyForInvStatus" id="dd3dc282-8125-4420-bcf0-c9485818cba3">
        <updating/>
        <source>setProxyForInvStatus(_offset : Integer; _invStatus : Integer; _name : String) updating;
/*
Purpose:			

Date		Who		Reason
20 October 2021	navab1	TFS 52184
*/

vars

begin
	self.type := _offset + _invStatus;
	self.entTableName := ETDef_InvoiceStatusEmail;
	self.name := _name;
epilog

end;</source>
        <Parameter name="_offset" type="Integer"/>
        <Parameter name="_invStatus" type="Integer"/>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
