<Class name="CnEcPageHeadScriptTag" id="8a41c6a5-54c3-40ef-a9d9-6b4f6ba404fb">
    <superclass name="CnEcHtmlTagObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
