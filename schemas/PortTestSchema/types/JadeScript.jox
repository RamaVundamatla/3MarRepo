    <JadeMethod name="importObjects" id="63be8d90-8e4d-4c50-840c-c9af44066554">
        <source>importObjects(_classXMLName: String; _classNew: Class; _dirName: String; _phase: Integer) protected;
// ---------------------------------------------------------------------------
// Created:     10 March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	file: File;
	attributeBlock,
	referencesBlock,
	collectionsBlock,
	className,
	classTag,
	classTagEnd,
	classBlock,
	lineStr: String;
//	class: Class;
	newObj: CM_Object;
	cnt: Integer;
	theUser: CM_User;
	fileName: String;
	result: Boolean;	
	objArray: ObjectArray;
	object: Object;
	countError, countOK: Integer;
	classXMLName: String;
	methodName: String;
begin
	result := false;
	create objArray transient;
	if _phase = 0 then //only do this once per run
		_classNew.allInstances(objArray, 0, true);
		beginTransaction;
		foreach object in objArray do
			if global.isValidObject(object) then
				object.CM_Object.erase(NORMAL_ERASE);
			endif;
		endforeach;
		commitTransaction;
	endif;
	classXMLName := _classXMLName;
	if classXMLName = null then
		classXMLName := _classNew.name;
	endif;
	fileName := _dirName&amp;classXMLName&amp;'.xml';
//write fileName;
	create file transient;
	file.fileName := fileName;
	if not file.isAvailable() then
		write("fileName "&amp;fileName&amp;" was not found.");
		return;
	endif;
	file.kind := File.Kind_Unknown_Text; // 4/3/16  cnwns1 PAR 36286 unicode version
	file.openInput(fileName);
	
	if classXMLName = null then
		app.raiseUnexpectedProgramError(classXMLName, method.name, 'Class name passed in is null');
		return;
	endif;
	write classXMLName&amp;" to "&amp;_classNew.name;
	
//	class := currentSchema.getClass(_classNew.name);
	if _classNew = null then
		app.raiseUnexpectedProgramError(_classNew.name, method.name, 'Class with name "'&amp;_classNew.name&amp;'" could not be found');
		return;
	endif;
	
	classTag := '&lt;'&amp;classXMLName&amp;'&gt;';
	classTagEnd := '&lt;/'&amp;classXMLName&amp;'&gt;';
	app.writeLog('Started importing instances of '&amp;classXMLName&amp;' at '&amp;app.actualTimeServer.String, LogINFO);
	countError := 0;
	countOK := 0;
	
	while not file.endOfFile do
		lineStr := file.readLine();
		
		if lineStr = classTag then
			classBlock := classTag&amp;CrLf;
		else
			classBlock := classBlock&amp;lineStr&amp;CrLf;
		endif;
//write lineStr&amp;' '&amp;classTagEnd;		
		if lineStr = classTagEnd then
			
			attributeBlock := classBlock.cnEcGetTagValueOfName(classXMLName&amp;'Attributes');
			
			cnt := cnt + 1;
			create newObj as _classNew transient;
			newObj.CM_Object.importXML(classXMLName, classBlock);
			methodName := "load"&amp;_classNew.name[4:_classNew.name.length];
			result := self.sendMsgWithParams(methodName, newObj).Boolean;
/*			if _classNew = CM_AttributeArea then
//				result := self.loadAttributeArea(newObj.CM_AttributeArea);
			elseif _classNew = CM_AutoPlanTests then
//				result := self.loadAutoPlanTests(newObj.CM_AutoPlanTests);
			elseif _classNew = CM_BlockStack then
				result := self.loadBlockStack(newObj);
			elseif _classNew = CM_Building then
				result := self.loadBuilding(newObj.CM_Building);
			elseif _classNew = CM_CamGroup then
				result := self.loadCamGroup(newObj.CM_CamGroup);
			elseif _classNew = CM_CamProtocol then
				result := self.loadCamProtocol(newObj.CM_CamProtocol);
			elseif _classNew = CM_CargoTypeAttribPlan then
				result := self.loadCargoTypeAttribPlan(newObj.CM_CargoTypeAttribPlan);
			elseif _classNew = CM_Carrier then
				result := self.loadCarrier(newObj.CM_Carrier);
			elseif _classNew = CM_Commodity then
				result := self.loadCommodity(newObj.CM_Commodity);
			elseif _classNew = CM_CommodityGroup then
				result := self.loadCommodityGroup(newObj.CM_CommodityGroup);
			elseif _classNew = CM_ConsigneeConsignor then
				result := self.loadConsigneeConsignor(newObj.CM_ConsigneeConsignor);
			elseif _classNew = CM_ConsigneeConsignorGroup then
				result := self.loadConsigneeConsignorGroup(newObj.CM_ConsigneeConsignorGroup);
			elseif _classNew = CM_ContRange then
				result := self.loadContRange(newObj.CM_ContRange);
			elseif _classNew = CM_Country then
				result := self.loadCountry(newObj.CM_Country);
			elseif _classNew = CM_Crane then
				result := self.loadMachine(newObj.CM_Machine);
			elseif _classNew = CM_CraneTransferArea then
				result := self.loadCraneTransferArea(newObj.CM_CraneTransferArea);
			elseif _classNew = CM_DataAccessController then
//				result := self.loadDataAccessController(newObj.CM_DataAccessController);
			elseif _classNew = CM_Depot then
				result := self.loadDepot(newObj.CM_Depot);
			elseif _classNew = CM_EmailAddress2 then
				result := self.loadEmailAddress2(newObj.CM_EmailAddress2);
			elseif _classNew = CM_EmailGroup then
				result := self.loadEmailGroup(newObj.CM_EmailGroup);
			elseif _classNew = CM_ExternalOrganisation then
//				result := self.loadExternalOrganisation(newObj.CM_ExternalOrganisation);
			elseif _classNew = CM_ForkLiftStack then
				result := self.loadForkLiftStack(newObj.CM_ForkLiftStack);
			elseif _classNew = CM_GridShed then
				result := self.loadGridShed(newObj.CM_GridShed);
			elseif _classNew = CM_HazardClass then
				result := self.loadHazardClass(newObj.CM_HazardClass);
			elseif _classNew = CM_InternalOrganisation then
//				result := self.loadInternalOrganisation(newObj.CM_InternalOrganisation);
			elseif _classNew = CM_ISOType then
				result := self.loadISOType(newObj.CM_ISOType);
			elseif _classNew = CM_ISOTypeGroup then
				result := self.loadISOTypeGroup(newObj.CM_ISOTypeGroup);
			elseif _classNew = CM_JobType then
				result := self.loadJobType(newObj.CM_JobType);
			elseif _classNew = CM_LineGroupDebtor then
//				result := self.loadLineGroupDebtor(newObj.CM_LineGroupDebtor);
			elseif _classNew = CM_LogArea then
				result := self.loadLogArea(newObj.CM_LogArea);
			elseif _classNew = CM_Machine then
				result := self.loadMachine(newObj.CM_Machine);
			elseif _classNew = CM_MachineAvailability then
				result := self.loadMachineAvailability(newObj.CM_MachineAvailability);
			elseif _classNew = CM_MachineType then
				result := self.loadMachineType(newObj.CM_MachineType);
			elseif _classNew = CM_MoveMap then
				result := self.loadMoveMap(newObj.CM_MoveMap);
			elseif _classNew = CM_MovePlan then
//				result := self.loadMovePlan(newObj.CM_MovePlan);
			elseif _classNew = CM_MTGrade then
				result := self.loadMTGrade(newObj.CM_MTGrade);
			elseif _classNew = CM_Operator then
				result := self.loadOperator(newObj.CM_Operator);
			elseif _classNew = CM_OperatorGroup then
				result := self.loadOperatorGroup(newObj.CM_OperatorGroup);
			elseif _classNew = CM_Port then
				result := self.loadPort(newObj.CM_Port);
			elseif _classNew = CM_PortGroup then
				result := self.loadPortGroup(newObj.CM_PortGroup);
			elseif _classNew = CM_PredefinedRemark then
				result := self.loadPredefinedRemark(newObj.CM_PredefinedRemark);
			elseif _classNew = CM_PrinterDef then
				result := self.loadPrinterDef(newObj.CM_PrinterDef);
			elseif _classNew = CM_Rail then
				result := self.loadRail(newObj.CM_Rail);
			elseif _classNew = CM_RailLine then
//				result := self.loadRailLine(newObj.CM_RailLine);
			elseif _classNew = CM_RTDeviceHandHeld then
				result := self.loadRTDeviceHandHeld(newObj.CM_RTDeviceHandHeld);
			elseif _classNew = CM_RTDeviceScanner then
				result := self.loadRTDeviceScanner(newObj.CM_RTDeviceScanner);
			elseif _classNew = CM_RTDeviceVehicleMount then
				result := self.loadRTDeviceVehicleMount(newObj.CM_RTDeviceVehicleMount);
			elseif _classNew = CM_SecurityRoleSystem then
//				result := self.loadSecurityRoleSystem(newObj.CM_SecurityRoleSystem);
			elseif _classNew = CM_SecurityRoleTerminal then
//				result := self.loadSecurityRoleTerminal(newObj.CM_SecurityRoleTerminal);
			elseif _classNew = CM_ShippingLine then
				result := self.loadShippingLine(newObj.CM_ShippingLine);
			elseif _classNew = CM_Stevedore then
				result := self.loadStevedore(newObj.CM_Stevedore);
			elseif _classNew = CM_StopsTable then
				result := self.loadStopsTable(newObj.CM_StopsTable);
			elseif _classNew = CM_StraddleStack then
				result := self.loadStraddleStack(newObj.CM_StraddleStack);
			elseif _classNew = CM_SubBlockStack then
				result := self.loadSubBlockStack(newObj.CM_SubBlockStack);
			elseif _classNew = CM_SwapStack then
				result := self.loadSwapStack(newObj.CM_SwapStack);
			elseif _classNew = CM_Teklogix_Narrow then
				result := self.loadTeklogix_Narrow(newObj.CM_Teklogix_Narrow);
			elseif _classNew = CM_TemperatureConversion then
				result := self.loadTemperatureConversion(newObj.CM_TemperatureConversion);
			elseif _classNew = CM_TempRange then
				result := self.loadTempRange(newObj.CM_TempRange);
			elseif _classNew = CM_TerminalAreaGroup then
//				result := self.loadTerminalAreaGroup(newObj.CM_TerminalAreaGroup);
			elseif _classNew = CM_ToDoTaskDesc then
				result := self.loadToDoTaskDesc(newObj.CM_ToDoTaskDesc);
			elseif _classNew = CM_ToDoTaskDescGroup then
//				result := self.loadToDoTaskDescGroup(newObj.CM_ToDoTaskDescGroup);
			elseif _classNew = CM_ToDoTemplate then
				result := self.loadToDoTemplate(newObj.CM_ToDoTemplate);
			elseif _classNew = CM_Trade then
				result := self.loadTrade(newObj.CM_Trade);
			elseif _classNew = CM_Vehicle then
				result := self.loadVehicle(newObj.CM_Vehicle);
			elseif _classNew = CM_WagonClass then
				result := self.loadWagonClass(newObj.CM_WagonClass);
			elseif _classNew = CM_WarehouseRowArea then
				result := self.loadWarehouseRowArea(newObj.CM_WarehouseRowArea);
			elseif _classNew = CM_WeightRange then
				result := self.loadWeightRange(newObj.CM_WeightRange);
			elseif _classNew = CM_Xlation then
				result := self.loadXlation(newObj.CM_Xlation);
			elseif _classNew = CM_XlationTable then
//				result := self.loadXlationTable(newObj.CM_XlationTable);
			elseif _classNew = CM_YardTransferArea then
				result := self.loadYardTransferArea(newObj.CM_YardTransferArea);
			endif;
*/			if result then
				countOK := countOK + 1;
			else
				countError := countError + 1;
			endif;
			if cnt mod 200 = 0 then
				app.writeLog('Imported '&amp;cnt.String&amp;' instances of '&amp;_classNew.name&amp;' at '&amp;app.actualTimeServer.String, LogINFO);
			endif;
		endif;
	endwhile;
	
	app.writeLog('Finished importing instances of '&amp;_classNew.name&amp;' at '&amp;app.actualTimeServer.String, LogINFO);
	app.writeLog('Total instances of class '&amp;_classNew.name&amp;' input from file : '&amp;cnt.String, LogINFO);
	app.writeLog('  '&amp;_classNew.name &amp;' OK count='&amp;countOK.String&amp;' Error count='&amp;countError.String, LogINFO);
	write _classNew.name &amp;' OK count='&amp;countOK.String&amp;' Error count='&amp;countError.String;
	
epilog
	abortTransaction;
	file.close;
	delete file;
	delete objArray;	
end;</source>
        <access>protected</access>
        <Parameter name="_classXMLName" type="String"/>
        <Parameter name="_classNew" type="Class"/>
        <Parameter name="_dirName" type="String"/>
        <Parameter name="_phase" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="importSelective" id="1f484e95-39d0-4abd-88c3-b1cc9feaebb3">
        <source>importSelective();
// ---------------------------------------------------------------------------
// Created:     18 March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars
	dirName: String;
	theUser: CM_User;
begin
	on Exception do null global;
	app.initialize;
//	theUser := CM_Terminal.firstInstance.users["SUPERUSER"];
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.warningsAcknowledged	:= true;
	dirName := 'd:\JMTDemo\data\';
	if dirName = null then
		dirName := 'C:\temp\';
	elseif dirName[dirName.length] &lt;&gt; '\' then
		dirName := dirName &amp; '\';
	endif;
	self.importObjects(null,CM_AttributeArea, dirName, 0);
	self.importObjects(null,CM_AutoPlanTests, dirName, 0);
	self.importObjects(null,CM_CamProtocol, dirName, 0);
	self.importObjects(null,CM_CargoTypeAttribPlan, dirName, 0);
	self.importObjects(null,CM_DataAccessController, dirName, 0);
	self.importObjects(null,CM_ExternalOrganisation, dirName, 0);
	self.importObjects(null,CM_ForkLiftStack, dirName, 0);
	self.importObjects(null,CM_InternalOrganisation, dirName, 0);
	self.importObjects(null,CM_LineGroupDebtor, dirName, 0);
	self.importObjects(null,CM_Machine, dirName, 0);
	self.importObjects(null,CM_MachineAvailability, dirName, 0);
	self.importObjects(null,CM_MovePlan, dirName, 0);
	self.importObjects(null,CM_PrinterDef, dirName, 0);
	self.importObjects(null,CM_RailLine, dirName, 0);
	self.importObjects(null,CM_RTDeviceHandHeld, dirName, 0);
	self.importObjects(null,CM_RTDeviceVehicleMount, dirName, 0);
	self.importObjects(null,CM_SubBlockStack, dirName, 0);
	//self.importObjects(null,CM_Teklogix_Narrow, dirName, 0);		// TFS #43007 - Remove Teklogix	jlgmd1 22/01/2019
	self.importObjects(null,CM_TempRange, dirName, 0);
	self.importObjects(null,CM_ToDoTaskDesc, dirName, 0);
	self.importObjects(null,CM_ToDoTemplate, dirName, 0);
	self.importObjects(null,CM_Trade, dirName, 0);
//	self.importObjects(null,CM_Vehicle, dirName, 0);
	self.importObjects(null,CM_WagonClass, dirName, 0);
	self.importObjects(null,CM_WeightRange, dirName, 0);
	self.importObjects(null,CM_YardTransferArea, dirName, 0);
end;</source>
