    <JadeMethod name="getFilterDetailsAsString" id="34d5ebae-e741-4482-a0f2-9f225a840f4b">
        <source>getFilterDetailsAsString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation

*/

vars

	returnString : String;
	filterValue : String;
	size : Integer;
	last : String;

begin

	returnString := "'" &amp; self.entableRowHeading &amp; "'";
	
	if self.userEntered then
		returnString := returnString &amp; "  contains  '" &amp; self.filterValues.first &amp; "'";
	else
		size := self.filterValues.size;
		
		if size = 1 then
			returnString := returnString &amp; "  is  ";
		else
			returnString := returnString &amp; "  is one of  ";
			last := self.filterValues.last;
		endif;
		
		foreach filterValue in self.filterValues do
			if size = 1 then
				returnString := returnString &amp; "'" &amp; filterValue &amp; "'";
			elseif filterValue = last then
				returnString := returnString[1:returnString.length -2];
				returnString := returnString &amp; " or '" &amp; filterValue &amp; "'";
			else
				returnString := returnString &amp; "'" &amp; filterValue &amp; "', ";
			endif;
		endforeach;
	
	endif;
	
	return returnString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesFilterValue" id="d193a5f7-43aa-431e-a784-87ac85940d52">
        <source>includesFilterValue( _str : String ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if self.filterValues.includes( _str ) then
		return true;
	elseif _str = null and self.includesNull then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColumnFilterData" id="23b5e6d1-51b0-41c0-bc71-3150eccb10f0">
        <updating/>
        <source>setColumnFilterData(	_table : Table;
						_columnIndex : Integer;
						_entableRowHeading : String;
						_filterValues : StringArray;
						_userEntered : Boolean;
						_myDict : CM_ColumnFilterDict
						) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	

*/

vars

begin

	self.tableName := _table.name;
	self.columnIndex := _columnIndex;
	self.entableRowHeading := _entableRowHeading;
	self.setFilterValues( _filterValues, _userEntered );
	
	self.myDictionary := _myDict;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_columnIndex" type="Integer"/>
        <Parameter name="_entableRowHeading" type="String"/>
        <Parameter name="_filterValues" type="StringArray"/>
        <Parameter name="_userEntered" type="Boolean"/>
        <Parameter name="_myDict" type="CM_ColumnFilterDict"/>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="85f53383-8e93-4676-abc8-ee59501ce86a">
        <updating/>
        <source>setFilterValues( _filterValues : StringArray; _userEntered : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation

*/

vars

begin

	self.filterValues.clear();
	self.includesNull := false;
	if not _filterValues.isEmpty then
		_filterValues.copy( self.filterValues );
		self.includesNull := self.filterValues.includes(self.NullString);
	endif;
	self.userEntered := _userEntered;

epilog

end;</source>
        <Parameter name="_filterValues" type="StringArray"/>
        <Parameter name="_userEntered" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showInTable" id="51d05b68-84bf-401b-b62a-6c1b56d538ab">
        <source>showInTable( _str : String ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	userEnteredValue : String;

begin

	if self.userEntered then
		userEnteredValue := self.filterValues.first;
		if self.includesNull then
			return _str = null;
		endif;
		if _str.pos(userEnteredValue,1) &gt; 0 then
			return true;
		endif;
	
	elseif self.includesFilterValue(_str) then
		return true;
		
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
