    <JadeMethod name="btnCancel_click" id="56bd2bfb-fb48-4ec3-a2b2-d5d5f8b7eb54">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	modalResult	:=	1;
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="e3bed0cb-296c-4c3d-93f2-17a3bbf6221c">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doFormUpdate(false) then
		modalResult	:=	7;
		self.unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="c1695700-7ab7-4e2e-a4f2-a446f5bd11d2">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLicense	: JSSLKCustomerLicense;
	
begin
	self.aMyServiceObject.setEditForm(self);
	
	inheritMethod();
	
	theLicense	:=	self.aMyLicense;
	
	if theLicense = null then
		txtName.text	:=	null;
		txtKey.text		:=	null;
	else
		txtName.text	:=	theLicense.customerName;
		txtKey.text		:=	theLicense.registrationKey;
	endif;
	
	modalResult	:=	1;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="772099e7-460f-494a-8de3-b1088032aa3b">
        <updating/>
        <source>doFormUnload() updating, protected;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyServiceObject.setEditForm(null);
	
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="fc93dafc-d4f5-4ed6-abf4-1b7ad048c2dc">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTA				: JSSLKTransactionAgent;
	customerName		: String;
	licenseKey			: String;
	theCustomerLicense	: JSSLKCustomerLicense;
	theKey				: JSSLKey;
	productCode			: String;
	
begin
	if not self.doFormValidate(pIsDelete) then
		return false;
	endif;
	
	customerName	:=	txtName.text.trimBlanks();
	licenseKey		:=	txtKey.text.trimBlanks();
	
	create theKey transient;
	theKey.setServiceManager(self.aMyServiceManager);
	theKey.decompose(customerName, licenseKey);
	productCode	:=	theKey.data4.String;
	
	create theTA transient;
	theTA.setDoTransactionState(self.aMyServiceObject.isDoTransactionState);
	
	theCustomerLicense	:=	self.aMyRoot.allCustomerLicenses[customerName, productCode];
	
	if theCustomerLicense = null then
		theTA.trxCreateCustomerLicense(self.aMyServiceManager, customerName, productCode, licenseKey, self.aMyRoot, theCustomerLicense);
		self.aMyLicense	:=	theCustomerLicense;
	else
		theTA.trxUpdateCustomerLicense(	theCustomerLicense,
										theCustomerLicense.edition,
										self.aMyServiceManager,
										customerName,
										productCode,
										licenseKey,
										self.aMyRoot);
	endif;
	
	return inheritMethod(pIsDelete);
epilog
	delete theTA;
	delete theKey;
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFormValidate" id="693c2b72-8f77-4f91-97ba-af08abb0b92f">
        <updating/>
        <source>doFormValidate(pIsDelete:Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if txtName.text.trimBlanks() = null then
		app.msgBox("Please enter the Customer name.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	if txtKey.text.trimBlanks() = null then
		app.msgBox("Please enter the license registration key.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	return inheritMethod(pIsDelete);
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCustomerLicense" id="f491a42d-eab1-4a3e-8106-fb1a3d20c23f">
        <source>getCustomerLicense():JSSLKCustomerLicense;
// --------------------------------------------------------------------------------
// Created:		27 March 2003 by cnwdad1
//
// Purpose:		Returns the local reference to the Customer License object.
//
// Parameters:	None
//
// Returns:		A reference to the Customer License object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.aMyLicense;
end;</source>
        <ReturnType type="JSSLKCustomerLicense"/>
    </JadeMethod>
    <JadeMethod name="setCustomerLicense" id="6d5515a6-8141-42c6-ba0a-621e78976dfb">
        <updating/>
        <source>setCustomerLicense(pTheLicense:JSSLKCustomerLicense) updating;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Purpose:		Sets a reference to the Customer License object being edited.
//
// Parameters:	pTheLicense - A reference to the Customer License object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyLicense	:=	pTheLicense;
end;</source>
        <Parameter name="pTheLicense" type="JSSLKCustomerLicense"/>
    </JadeMethod>
</GUIClass>
