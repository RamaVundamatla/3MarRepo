    <JadeMethod name="doQuery" id="5b0c70c3-0844-4f90-86ba-ee7ba3c6196f">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ls						: Boolean;	
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	app.cmsBeginLoad(ls);

	self.tblInfo.rows := self.tblInfo.fixedRows;
	self.tblData.rows := self.tblData.fixedRows;

	self.displayTable();
	self.showCharges();
	self.caption := app.getErrorString(Wagon) &amp; " " &amp; app.getErrorString(Transactions) &amp; " - " &amp; self.getQueryCaption();
	

epilog
	app.cmsEndLoad(ls);	
	self.mousePointer := Window.MousePointer_Default;
end;</source>
