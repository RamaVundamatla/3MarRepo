    <JadeMethod name="getDisplayStringForAttribute" id="7fcbe2da-3f39-4851-b1de-1881350863fa">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation	TFS 5744

*/

vars
	aggAmount,
	lDetail : String;
	otherTI,
	theTI	: CM_TrackedItem;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
		
			theTI := self.myTrackedItem;
			otherTI := self.getOtherTrackedItem();
			lDetail := app.getErrorString(Packaged) &amp; " ";
			aggAmount:= self.getPackagedAmount;
			if aggAmount &lt;&gt; null then
				lDetail:=lDetail &amp; aggAmount &amp; " x ";
			endif;
			if self.action = ACTION_PACKAGE_CHILD then
				if otherTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; otherTI.id;
				endif;
				lDetail := lDetail &amp; " =&gt; ";
				if theTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; theTI.id;
				endif;
			elseif self.action = ACTION_PACKAGE_PARENT then
				if theTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; theTI.id;
				endif;
				lDetail := lDetail &amp; " =&gt; ";
				if otherTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; otherTI.id;
				endif;
			endif;
		
			lDetail := lDetail &amp; " " &amp; self.urNumber.String;			
			
			return lDetail;
			
		endif;

	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="4eb00353-3c3f-4e73-b10f-20bab782dd74">
        <source>getEnquiryRow(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation	TFS 5744

*/

vars
	lDetail : String;
	otherTI,
	theTI	: CM_TrackedItem;
	aggAmount : String;
	
begin

	theTI := self.myTrackedItem;

	otherTI := self.getOtherTrackedItem();
	
	lDetail := inheritMethod();
	lDetail := lDetail &amp; app.getErrorString(Packaged) &amp; " ";
	aggAmount:= self.getPackagedAmount;
	if aggAmount &lt;&gt; null then
		lDetail:=lDetail &amp; aggAmount &amp; " x ";
	endif;
	if self.action = ACTION_PACKAGE_CHILD then
		if otherTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; otherTI.id;
		endif;
		lDetail := lDetail &amp; " =&gt; ";
		if theTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; theTI.id;
		endif;
	elseif self.action = ACTION_PACKAGE_PARENT then
		if theTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; theTI.id;
		endif;
		lDetail := lDetail &amp; " =&gt; ";
		if otherTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; otherTI.id;
		endif;
	endif;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
