    <JadeMethod name="tStorageInclusiveSameDay" id="e61295a9-4565-4812-84fd-e77a9d20513d">
        <updating/>
        <source>tStorageInclusiveSameDay()updating;
// cnwrs1
//08 Mar 2016	cnwrs1	TFS 1479 create storage for inclusive dates over EOP
vars
	bs : CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	dateTime : TimeStamp;
	now : Date;
	agent : CM_AutoStorageTransactionAgent;
	term : CM_Terminal;
	user : CM_User;
	theSelector : CM_MenuUserQuery;
	selectorQuery : CM_MenuUserQuery;
	userQuery : CM_MenuUserQuery;
	financialPeriod	: CM_FinancialPeriodEnd;
	iter : Iterator;
	bgpStorage : BGP_StorageProcessorRequest;
	queryName : String;
	operator : CM_Operator;
	releaseRequest : CM_BulkRelease;
	vvr	: CM_VehicleVisitRecord;
	wle	: CM_WorkListEntry;
	cargoMap : CM_TranMap;
	services : CM_ServiceByNameDict;
	invType	: CM_InvoiceDesc;
	theService : CM_Service;
	calType1 : CM_CalculationType;
	invLineType1 : CM_InvoiceLineDesc;
	invLineType2 : CM_InvoiceLineDesc;
	invLineType3 : CM_InvoiceLineDesc;
	invLineType4 : CM_InvoiceLineDesc;
begin

	dateTime := app.actualTimeServer(); // 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	self.assertNotNull(operator);
	// block stack
//	bs := self.getTerminalArea("UTSTORE").CM_BlockStack;
	self.setInclusiveStorageConfig(true);
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);

	bs := self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStore1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStore2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStore3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStore4 has null INV TYPE");
	endif;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorage();

	// create a container with retrospective transactions
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs := addBlockStack("UTSTORE3", 100, null);

	// test container
	self.deleteContainer("UTMTSTORE01");
	cargo := self.getTrackedItem("UTMTSTORE01");
	self.assertNullMsg(cargo, "Container not deleted");
	cargo := self.addContainerAtLocnDisch("UTMTSTORE01", "22G1", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
//	dateTime.setDate(now.addDays(-1));
	self.resetTransactionDate(cargo, dateTime);
	queryName := "UT_UTMTSTORE01";
	
	iter := app.myRoot.myQueryMenuRoot.allMenuUserItemsWithAMenuItem.createIterator;
	while iter.next(userQuery) do
		if queryName = userQuery.heading then
			selectorQuery := userQuery;
			break;
		endif;
	endwhile;
//	beginTransaction;
//	selectorQuery.setPropertyValue("myTerminal", self.getTerminal);
//	commitTransaction;
//	beginTransaction;
//	create selectorQuery;
//	commitTransaction;
	

	
	term := self.getTerminal();
	user := app.getMyUser();
	foreach financialPeriod in CM_FinancialPeriodEnd.instances do
		if financialPeriod.isDefault then
			break;
		endif;
	endforeach;
	
	create agent transient;
	theSelector := selectorQuery;
//		beginTransaction;
//	delete selectorQuery;
//	commitTransaction;
	
/*	
	create bgpStorage transient;
	bgpStorage.setPropertyValue("myTerminal",term);
	bgpStorage.setPropertyValue("myUser",user);
	bgpStorage.setPropertyValue("myFinancialPeriod",financialPeriod);
	bgpStorage.setPropertyValue("mySelectorQuery",theSelector);
	
	bgpStorage.action();
*/	// gate out the continer
	self.opts.purge();
	self.opts.addAssoc("ISOType", "22G1");
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("Commodity", "MT");
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK01", "", "UTDRIVER1", cargo.CM_Container, true, self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()), null);
	self.assertNotNull(vvr);
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cargo);
	self.assertEqualMsg(releaseRequest.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');
	wle := vvr.myRoadJob.workListEntries.first;
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
	self.assertEqual(wle.myTrackedItem, cargo);

	self.moveQueuedCargo (wle);
	self.roadExit(vvr);
	self.assertNullMsg(vvr.vehicle.myPrimaryActualLocation, 'Vehicle is still on site');
	self.assertTrueMsg(releaseRequest.status = BR_COMPLETE, 'Release Should be completed'); 
	self.assertTrueMsg(releaseRequest.getTotalReleased = 1, 'Release should have 1 item released');  
epilog
//	beginTransaction;
//	delete selectorQuery;
//	commitTransaction;
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	delete iter;
	delete agent;
	delete bgpStorage;
	self.setInclusiveStorageConfig(false);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tStorageProcessorDeleteSelecto" id="df632142-416d-47c0-a94f-ffb6974b44c7">
        <updating/>
        <source>tStorageProcessorDeleteSelecto() updating;
// cnwer1
vars
	bs		: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	dateTime	: TimeStamp;

	agent	: CM_AutoStorageTransactionAgent;
	term	: CM_Terminal;
	user	: CM_User;
	theSelector,
	selectorQuery	: CM_MenuUserQuery;
	financialPeriod	: CM_FinancialPeriodEnd;
	iter		: Iterator;
	bgpStorage : BGP_StorageProcessorRequest;
begin
	// block stack
	bs:= self.addBlockStack("UTSTORE",0,null).CM_BlockStack;
	// create a container with retrospective transactions
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];

	// test container
	cargo := self.addContainerAtLocnDisch("UTMTSTORE01", "22G1", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aPort, voy);
	dateTime.setDate("22/06/2012".Date);
	self.resetTransactionDate(cargo, dateTime);

	beginTransaction;
	create selectorQuery;
	commitTransaction;
	

	
	term := self.getTerminal();
	user := app.getMyUser();
	foreach financialPeriod in CM_FinancialPeriodEnd.instances do
		if financialPeriod.isDefault then
			break;
		endif;
	endforeach;
	
	create agent transient;
	theSelector := selectorQuery;
		beginTransaction;
	delete selectorQuery;
	commitTransaction;
	
	
	create bgpStorage transient;
	bgpStorage.setPropertyValue("myTerminal",term);
	bgpStorage.setPropertyValue("myUser",user);
	bgpStorage.setPropertyValue("myFinancialPeriod",financialPeriod);
	bgpStorage.setPropertyValue("mySelectorQuery",theSelector);
	
	bgpStorage.action();

epilog
	delete iter;
	delete agent;
	delete bgpStorage;

end;</source>
    </JadeMethod>
    <JadeMethod name="tStorageQRMTest" id="984c42eb-34b4-4cb7-926f-ac279e928c14">
        <updating/>
        <source>tStorageQRMTest() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:     May 2016 from TFS 1746/1988

Purpose:     Test storage day calculations with prior charged storage to check quantity range map quantity calculations
        
Change Date	Who		Reason

8/3/22 	jlier1		TFS 52924 - PNL also double dip on storage charges
------------------------------------------------------------------------------*/
constants
	MaxCargo = 6;
vars
	baseDate,
	now		: Date;
	tranTS,
	tranTS2	: TimeStamp;
	count	: Integer;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	ti	: CM_TrackedItem;
	cargoId		: String;
	cargoIds	: StringArray;
	vessel	: CM_Vessel;
	voyage : CM_Voyage;
	trans	: CM_TITransaction;
	operator	: CM_Operator;
	allTIs		: CM_TISet;
	dd1Array : IntegerArray;
	dd2Array : IntegerArray;
	oldClient: String;
	index : Integer;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE");
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorage();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	deleteVoyage("UTVOY2");
	deleteVessel("UTBOAT2");
	vessel := addVesselCellular("UTBOAT2", operator);
	voyage := addVoyageWithContainerStructur("UTVOY2", "UTBOAT2", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	// ids with valid check digits
	create cargoIds transient;
	self.getCargoIds(cargoIds);
	foreach cargoId in cargoIds do
		count := count + 1;
		if count &gt; MaxCargo then
			break;
		endif;
		self.deleteContainer(cargoId);
	endforeach;
	// create cargo back-dated 10 days and with a charged storage after 3 days
	//	and a second charged storage from 4 to 9 days after create to check that each gets the correct quantity range map
	//	testing that the quantity calculation for the range map is the same as fr the subsequent invoice line
	baseDate := now - 7;	// first storage date
	tranTS.setDate(baseDate);
	create allTIs transient;

	count := 0;
	foreach cargoId in cargoIds do
		count := count + 1;
		if count &gt; MaxCargo then
			break;
		endif;
		ti := self.addOnsiteCargoForId2(cargoId, operator, 10);
		beginTransaction;
		ti.setMyVoyage(voyage, app.myPassport);
		foreach trans in ti.allTransactions do
			trans.setPropertyValue("voyage", voyage);
			trans.setPropertyValue("voyageCode", voyage.code);
			trans.setPropertyValue("myVoyageRelivant", voyage);
		endforeach;
		commitTransaction;
		self.createDatedChargedTransaction(ti, tranTS, TRANS_TYPE_STORAGE, true);
		baseDate := baseDate + 1;
		tranTS2.setDate(baseDate);
		self.createDatedChargedTransaction(ti, tranTS2, TRANS_TYPE_STORAGE, true);
		allTIs.add(ti);
	endforeach;
	
	create dd1Array transient;	//26 Jun 2020	NDL	TFS 49600
	create dd2Array transient;	//26 Jun 2020	NDL	TFS 49600
	
	count := 0;
	foreach ti in allTIs do
		count := count + 1;
		self.validateEscalatingCharges6(ti, count);
		dd1Array.add( self.getDoubeDippingValue( ti.getLastTransOfType( TRANS_TYPE_STORAGE ) ) );	//26 Jun 2020	NDL	TFS 49600
	endforeach;
	
/*	//26 Jun 2020	NDL	TFS 49600
	//oldClient := app.myRoot.client;
	oldClient := app.myRoot.licenseName;
	beginTransaction;
	//app.myRoot.setClient( Client_PortOtago );
	app.myRoot.setPropertyValue(CM_Root::licenseName.name, "Port Otago Ltd");
	commitTransaction;
	
	foreach ti in allTIs do
		dd2Array.add( self.getDoubeDippingValue( ti.getLastTransOfType( TRANS_TYPE_STORAGE ) ) );
	endforeach;
	
	foreach index in 1 to count do
		self.assertTrueMsg( ( dd1Array[count] + 1 ) = dd2Array[count], "Item [" &amp; count.String &amp; "] Port Otago Version should show 1 day more storage, they double dip on all storage trx records preceded by another storage trx." );
	endforeach;*/
	
epilog

	//26 Jun 2020	NDL	TFS 49600
	//if oldClient&lt;&gt; null and oldClient &lt;&gt; app.myRoot.client then
	if oldClient&lt;&gt; null and oldClient &lt;&gt; app.myRoot.licenseName then
		beginTransaction;
		//app.myRoot.setClient( oldClient );
		app.myRoot.setPropertyValue(CM_Root::licenseName.name, oldClient);
		commitTransaction;
	endif;

	self.resetDefaultTranMap();
	delete services;
	delete cargoIds;
	delete allTIs;
	delete dd1Array;		//26 Jun 2020	NDL	TFS 49600
	delete dd2Array;		//26 Jun 2020	NDL	TFS 49600
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tStorageRSTest" id="640adbe5-267d-4a65-b9e0-eda05d2339cc">
        <updating/>
        <source>tStorageRSTest() updating;
//
//08 Mar 2016	cnwrs1	TFS 1479 create storage for inclusive dates over EOP
//
vars
	bs : CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	dateTime : TimeStamp;
	now : Date;
	agent : CM_AutoStorageTransactionAgent;
	term : CM_Terminal;
	user : CM_User;
	theSelector : CM_MenuUserQuery;
	selectorQuery : CM_MenuUserQuery;
	userQuery : CM_MenuUserQuery;
	financialPeriod	: CM_FinancialPeriodEnd;
	iter : Iterator;
	bgpStorage : BGP_StorageProcessorRequest;
	queryName : String;
	operator : CM_Operator;
	releaseRequest : CM_BulkRelease;
	vvr	: CM_VehicleVisitRecord;
	wle	: CM_WorkListEntry;
	cargoMap : CM_TranMap;
	services : CM_ServiceByNameDict;
	invType	: CM_InvoiceDesc;
	theService : CM_Service;
	calType1 : CM_CalculationType;
	invLineType1 : CM_InvoiceLineDesc;
	invLineType2 : CM_InvoiceLineDesc;
	invLineType3 : CM_InvoiceLineDesc;
	invLineType4 : CM_InvoiceLineDesc;
	triggers : CM_StorageTriggerByType;
	includeFirstDay : Boolean;
	includeLastDay : Boolean;
	storageConfig : CM_StorageConfig;
	calendar : CM_Calendar;
	shipReceivalType : Integer;
	shipReleaseType	: Integer;
	chargedDaysWorking : Boolean;
	freeDaysWorking	: Boolean;
	deriveDebtorFrom : CM_DebtorType;
	dateTimeEOP : TimeStamp;
	lTime : Time;
	pxyFPDate : CM_FinancialPeriodDateTime;
	newFPDate : CM_FinancialPeriodDateTime;
	fpEnd : CM_FinancialPeriodEnd;
	tran : CM_Transaction;
	invLine : CM_InvoiceLine;
	eop : TimeStamp;
	aSBController : CMIF_ServiceBroker;
	bank : CM_Bank;
begin
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	self.assertNotNull(operator);
	self.deleteVehicle("UTTRUCK01");
	self.deleteStorageConfig( false );
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar2();
	create triggers transient;
	// set the options
	includeFirstDay := true;
	includeLastDay := true;
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, deriveDebtorFrom, triggers, true, 0, 0, 0);	// TFS 2570
	
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);

	bs := self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	beginTransaction;
//	invLineType1.bOneLinePerFinancialPeriod := true;
	commitTransaction;
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStore1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStore2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStore3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStore4 has null INV TYPE");
	endif;

	// Need to map to above invoice line types, using quantity ranges
//	self.tranMapLoadStorageStorage();
	bank := theService.bank;

	// create a container with retrospective transactions
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs := addBlockStack("UTSTORE3", 100, null);

	// test container
	self.deleteContainer("UTMTSTORE01");
	cargo := self.getTrackedItem("UTMTSTORE01");
	self.assertNullMsg(cargo, "Container not deleted");
	cargo := self.addContainerAtLocnDisch("UTMTSTORE01", "22G1", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	dateTime.setDate(dateTime.date.addDays(-10));
	self.resetTransactionDate(cargo, dateTime);
	// create storage transaction
	eop.setDate(eop.date.addDays(-6));
	eop.setTime("23:59:59:".Time);
	self.createStorageTransactions16(cargo, eop);
	eop.setDate(eop.date.addDays(+4));
	eop.setTime("23:59:59:".Time);
	self.createStorageTransactions16(cargo, eop);
	// gate out the continer
	self.opts.purge();
	self.opts.addAssoc("ISOType", "22G1");
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("Commodity", "MT");
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK01", "", "UTDRIVER1", cargo.CM_Container, true, self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()), null);
	self.assertNotNull(vvr);
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cargo);
	self.assertEqualMsg(releaseRequest.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');
	wle := vvr.myRoadJob.workListEntries.first;
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
	self.assertEqual(wle.myTrackedItem, cargo);

	self.moveQueuedCargo(wle);
	self.roadExit(vvr);
	self.assertNullMsg(vvr.vehicle.myPrimaryActualLocation, 'Vehicle is still on site');
	self.assertTrueMsg(releaseRequest.status = BR_COMPLETE, 'Release Should be completed'); 
	self.assertTrueMsg(releaseRequest.getTotalReleased = 1, 'Release should have 1 item released'); 
	
	

epilog
	self.deleteStorageConfig( true );
	self.resetDefaultTranMap();								// See Michael before removing
	delete triggers;
	delete services;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTASCreditNotePostValidate" id="b01f6932-9b83-4f6c-baed-b7949d4068dc">
        <source>tTASCreditNotePostValidate();
/*

Purpose:		This UT tests the validation of posting a TAS Credit Note.
				If there is a TAS Invoice with the same "exportCurrencyCode" as the Credit Note and TAS Invoice is NOT posted, MTN should raise an error.

Parameters:			

Return Value:		

Date		Who		Reason
23/01/2023	navkc1 CR 59146 Task 62129: Jade - TAS Credit Note Test

*/
constants
	LineTypeName = "UT_TASCN";
vars
	today		: Date;
	calcType1	: CM_CalculationType;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invType		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	bu 			: CM_Bank;
	invoice001,
	creditNote001 : CM_Invoice;
begin

	self.deleteInvoiceService(LineTypeName, FORCED_ERASE);
	self.deleteInvoiceLineType(LineTypeName, FORCED_ERASE);
	self.deleteInvoiceType(LineTypeName);
	
	self.assertNoTrxErrorsOrWarnings();
	
	calcType1 := app.myRoot.allCalculationTypesByCode['CCT00'];	// INV_CALC_TYPE_UNITY;
	self.assertNotNullMsg(calcType1, "Calculation type INV_CALC_TYPE_UNITY not found");

	// create new instances
	create services transient;
	invType := self.createInvoiceType(LineTypeName, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; LineTypeName &amp; " not created");

	service := self.createInvoiceService(LineTypeName, LineTypeName, calcType1, null);
	self.assertNotNullMsg(service, "Service " &amp; LineTypeName &amp; " not created");
	
	services.add(service);
	ild := self.createInvoiceLineType(LineTypeName, calcType1, invType, services, "SDT1");
	self.assertNotNullMsg(ild, "Invoice Line Type " &amp; LineTypeName &amp; " not created");
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	
	bu := self.getTerminal().getDefaultCompanyBank();
	
	
	// ### MANUAL INVOICE ONE
	invoice001 := self.createManualInvoice(bu,operator.debtor,null,invType,null);
	
	// ### MANUAL CREDIT NOTE ONE
	creditNote001 := self.createManualInvoice(bu,operator.debtor,null,invType,null);
	
	beginTransaction;
	invoice001.setContext(CM_Invoice.TAS);
	invoice001.setPropertyValue("exportCurrencyCode", "EXT01");
	
	creditNote001.setCategory(InvoiceCategory_CreditNote);
	creditNote001.setContext(CM_Invoice.TAS);
	creditNote001.setPropertyValue("exportCurrencyCode", "EXT01");
	commitTransaction;
	
	// ### MANUAL INVOICE LINES
	self.createManualInvoiceLineRate(invoice001, ild, 231.81056,null);
	self.createManualInvoiceLineRate(invoice001, ild, 231.16032,null);
	self.createManualInvoiceLineRate(invoice001, ild, 231.16032,null);
	self.assertTrueMsg(invoice001.invoiceLines.size = 3, "Invoice 01 should have 3 lines");
	
	self.createManualInvoiceLineRate(creditNote001, ild, 347.71584,null);
	self.createManualInvoiceLineRate(creditNote001, ild, 346.74048,null);
	self.createManualInvoiceLineRate(creditNote001, ild, 353.65944,null);
	self.createManualInvoiceLineRate(creditNote001, ild, 231.16032,null);
	self.assertTrueMsg(creditNote001.invoiceLines.size = 4, "Credit Note 01 should have 4 lines");
	
	// Update Credit Note status to Pending
	self.updateInvoiceStatus(creditNote001, CM_Invoice.INVOICE_PENDING, false, null, null, null, today, false);
	self.assertEqualMsg(creditNote001.status, CM_Invoice.INVOICE_PENDING, "Credit note status not updated to Pending");
	
	// We are expecting this error when posting Credit Note
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(This_credi_note_canno_poste_in); 
	
	// Now Post the Credit Note
	self.updateInvoiceStatus(creditNote001, CM_Invoice.INVOICE_POSTED, false, null, null, null, today, false);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Expected error not raised");
epilog
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTemperatureReading" id="924ce458-9c2a-4781-9730-11b6c568745f">
        <source>tTemperatureReading();
// cnwma1
// cnwjre1
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 27/09/2021	navdap1	TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
//
constants
	POWERED_REEFER = "2231";
vars
	ti	: CM_TrackedItem;
	iter	: Iterator;
	voyage	: CM_Voyage;
	voy1,
	voy2	: CM_Voyage;
	count	: Integer;
	dateTime	: TimeStamp;
	temp	: Real;

begin
	self.deleteContainer("CPAT111113");

	iter := self.getTerminal.allVoyagesByCode.createIterator();
	self.getTerminal.allVoyagesByCode.startKeyGeq(null, null, iter);
	while iter.next(voyage) do
		if voyage.archived or
		   voyage.isNullVoyage then
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			voy1 := voyage;
		elseif count = 2 then
			voy2 := voyage;
		else
			break;
		endif;
	endwhile;
	// Create a container
	ti := self.addContainer("CPAT111113",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE).CM_Container;
	
	beginTransaction;
	// change to a powered reefer and a commodity that requires power and isn't empty; also set the voyage to a known one
	ti.changeISOType(POWERED_REEFER, null, null);
	ti.setCommodity("AMFC");
	ti.changeVoyage(voy1, app.myPassport);
	ti.updateContentsStatus();
	
	commitTransaction;
	
	// load transaction map to get charging for readings, to voyage invoice type
	self.tranMapLoadVoyageTemp();
	
	// take a reading, back a day, and get an invoice line
	temp := -5.00;
	dateTime.date.addDays(-1);
	self.createTemperatureReading(ti, dateTime, temp, false);
	assertTrueMsg(ti.CM_Container.getAllTemperatureReadings.last.getTemperatureValue = -5.0,"Last Reading temperature not correct (1)");
	assertTrueMsg(ti.CM_Container.getAllTemperatureReadings.last.dateTime.date = dateTime.date,"Last Reading date not correct (1)");		// TFS 52081
	
	
	// change the voyage on the TI
	beginTransaction;
	ti.changeVoyage(voy2, app.myPassport);
	commitTransaction;
	
	// take a second reading on the next day and see where the invoice line goes (to the new voyage in both old and new code cases)
	temp := -7.00;
	self.createTemperatureReading(ti, dateTime, temp, false);
	assertTrueMsg(ti.CM_Container.getAllTemperatureReadings.last.getTemperatureValue = -7.0,"Last Reading temperature not correct (2)");
	assertTrueMsg(ti.CM_Container.getAllTemperatureReadings.last.dateTime.date = dateTime.date,"Last Reading date not correct (2)");		// TFS 52081
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTestCalcTypeAndRates" id="987a64e5-1b05-4d12-b2b2-c991ab50456e">
        <source>tTestCalcTypeAndRates();

/*

Purpose:		

Date			Who		Reason
11/05/2016		cnwmh5	Initial creation - Test calc type and rates with deletion of range
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
*/

vars

	calcType						: CM_CalculationType;
	proxyCalculationType            : CM_CalculationType;
	invService						: CM_Service;
	debtorNode						: CM_DebtorNode;
	rateEntry 						: CM_RateEntry;
	
	rangeArray						: IntegerArray;
	costArray						: DecimalArray;
	
	ts								: TimeStamp;
	costPerUnit						: Decimal[12,6];

begin

	ts.setDate("01/01/2016".Date);
	ts.setTime("00:00:00".Time);

	// create debtor
	self.deleteDebtor("UTMHCTRDEBT");
	debtorNode := self.addDebtor("UTMHCTRDEBT", PaymentType_None);
	self.assertNotNull(debtorNode);

	// create calculation type
	self.deleteCalculationType("UTMHCT1", NORMAL_ERASE);
	
	create rangeArray transient;
	rangeArray.add(1000);
	rangeArray.add(2000);
	rangeArray.add(3000);
	rangeArray.add(4000);
	
	self.opts.purge();
	self.opts.addAssoc("Ranges", rangeArray);
	calcType := self.addCalculationType(25, "UTMHCT1", "Michael's Test Calc Type", null, null, null, 0, 0, 0, 0, true, false, false, false,0, null, null);
	self.assertNotNull(calcType);
	
	// create service
	self.deleteInvoiceService("UTMHServiceCTR", FORCED_ERASE);
	invService := self.createInvoiceService("UTMHServiceCTR", null, calcType, null);
	self.assertNotNull(invService);
	
	// create rate history for the service
	create costArray transient;
	costArray.add(25.00);
	costArray.add(35.00);
	costArray.add(45.00);
	costArray.add(55.00);
	
	// create rates for debtor
	rateEntry := invService.debtorNodeRates.first.rateEntries.first;
	self.assertNotNull(rateEntry);
	self.updateInvoiceRateEntry(rateEntry.rate, rateEntry, ts, null, false, costArray, 0.00, 0.00, null,null);
	costPerUnit := rateEntry.getPropertyValue("costPerUnit").Decimal;
	self.assertEqualMsg(costPerUnit, "25.000000".Decimal, "costPerUnit (" &amp; costPerUnit.String &amp; ") &lt;&gt; 25.000000");
	
	// delete one of the ranges and try and update calc type
	beginLoad;
	proxyCalculationType := calcType.pxyCreateUpdateProxy();
	endLoad;
	
	rangeArray.removeAt(3);
	self.assertEqual(rangeArray.size, 3);
	costArray.removeAt(3);
	self.assertEqual(costArray.size, 3);
	
	proxyCalculationType.integerRange1.clear();
	rangeArray.copy(proxyCalculationType.integerRange1);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(ERR_CANNOT_DELETE_BANK);	
	app.myTrxUA.trxUpdateCalculationType(proxyCalculationType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrxError(ERR_CANNOT_DELETE_BANK);
	
epilog

	delete rangeArray;
	delete costArray;
	delete proxyCalculationType;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTranMapGroupings1" id="ac3d4c85-b433-466a-9fa3-6cec4bd4c1c9">
        <updating/>
        <source>tTranMapGroupings1() updating;
/*
Purpose:			

Date		Who		Reason
16 February 2023	navab1	TFS CR 56446 TASK 56447
*/
constants
	CargoTypeStr = "CANNONBALL";
