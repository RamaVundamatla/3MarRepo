    <JadeMethod name="cnwdad1_Test_BitMask" id="14f10279-971e-4af3-bb8b-d7229ade64c5">
        <source>cnwdad1_Test_BitMask();
// --------------------------------------------------------------------------------
// Created:		09 October 2002 by cnwdad3
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MAX_BYTE		: Integer = 1000;
	SHOW_WRITES		: Boolean = false;
	
vars
	bitMask			: Binary;
	maskLength		: Integer;
	permissionId	: Integer;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	// Pre-fill the mask.
	
	maskLength	:=	(MAX_BYTE div 8) + 1;
	bitMask[maskLength]	:=	0;
	
	// Set the permission bits, 8 permissions for each byte.
	// Permissions will be set randomly.
	
	foreach permissionId in 1 to MAX_BYTE do
		if app.random(1) = 1 then
			bitMask.cnEcSetBit(permissionId);
		endif;
	endforeach;
	
	write MAX_BYTE.String &amp; " permisions. Mask is " &amp; bitMask.length().String &amp; " bytes.";
	write bitMask;
	
	// Show the permission settings.
	
	foreach permissionId in 1 to MAX_BYTE do
		if bitMask.cnEcIsBit(permissionId) then
			if SHOW_WRITES then
				write "Permission " &amp; permissionId.String &amp; ": Set";
			endif;
		else
			if SHOW_WRITES then
				write "Permission " &amp; permissionId.String &amp; ": NOT SET";
			endif;
		endif;
	endforeach;
	
	// Clear one of the settings.
	
	foreach permissionId in 10 to MAX_BYTE do
		if bitMask.cnEcIsBit(permissionId) then
			bitMask.cnEcClearBit(permissionId);
			write "Permission " &amp; permissionId.String &amp; " unset.";
			break;
		endif;
	endforeach;
	
	foreach permissionId in 1 to MAX_BYTE do
		if bitMask.cnEcIsBit(permissionId) then
			if SHOW_WRITES then
				write "Permission " &amp; permissionId.String &amp; ": Set";
			endif;
		else
			if SHOW_WRITES then
				write "Permission " &amp; permissionId.String &amp; ": NOT SET";
			endif;
		endif;
	endforeach;
epilog
	write "Mask tested in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_CPUInfo" id="e1ac3925-c0e0-41d1-a8c3-49dd783eea84">
