    <JadeMethod name="setForCreate" id="f7f3019c-e4f2-48b9-8245-3a3d5e4bdc57">
        <updating/>
        <source>setForCreate(_user, _license, _client, _changes : String; _dateTime : TimeStamp) updating;
/*
Purpose:	

Date		Who		Reason
07 January 2026	navab1	JIRA 36920
*/

vars

begin
	self.changeNote := _changes;
	self.clientName := _client;
	self.dateTime := _dateTime;
	self.licenseName := _license;
	self.userCode := _user;
epilog

end;</source>
        <Parameter name="_user" type="String"/>
        <Parameter name="_license" type="String"/>
