    <JadeMethod name="valROROControlerUpdateRelease" id="266466a5-971c-4dea-a26d-76967c0bc0a6">
        <source>valROROControlerUpdateRelease(_theSlots : CM_LCArray; _reserveDetail : CM_ReserveDetail ; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2012	cnwrd1	Initial creation
24/04/2013			cnwmh5 #31460 - If not 20ft then don't require backend details
*/

vars
	bulkRelease 	: CM_BulkRelease;
	outstanding,
	numSlots		: Integer;
	aSlot			: CM_LocationsController;
	tmpSlot			: CM_VoyageROROController;
	tmpSlotRequest	: CM_RORORequest;
begin

	if _theSlots.size &gt; 0 then
		if _reserveDetail &lt;&gt; null and _reserveDetail.isKindOf( CM_ReserveSelection ) then
			bulkRelease := _reserveDetail.myReserveHeader;
			outstanding := bulkRelease.getTotalOutstanding();
			foreach aSlot in _theSlots do
				if not aSlot.isKindOf(CM_VoyageROROController) then
					continue;  //wrong kind of controller.
				endif;
				
				tmpSlot := aSlot.CM_VoyageROROController;
				tmpSlotRequest := tmpSlot.myRORORequestLoad;
				if tmpSlotRequest = null then
					continue;
				endif;
				
				if not tmpSlotRequest.getAttrIs20 and not tmpSlotRequest.getAttrIsBackend() then									// 24/04/2013 cnwmh5 #31460
					continue;
				endif;
				
				if not bulkRelease.allRequestsBeingActioned.includes( tmpSlotRequest ) then
					numSlots := numSlots + 1;	// slots not already selected for this release
				endif;
			endforeach;
			numSlots := numSlots + bulkRelease.allRequestsBeingActioned.size; // total of slots that would be assigned for the outstanding cargo
		endif;
		if numSlots &gt; outstanding then
			app.raiseCMWarning2(Too_Many_Slots_Assigned, outstanding.String, numSlots.String, null, null, null);
		endif;
	endif;


epilog

end;</source>
        <Parameter name="_theSlots" type="CM_LCArray"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valRORORequestQty" id="455b96b3-db6b-4564-91ae-d87cddc9b78f">
