    <JadeMethod name="doFrmLevelColourClick" id="2bd35c8c-e541-4ec7-85a9-9aacac13f389">
        <updating/>
        <source>doFrmLevelColourClick(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	cmdColor	: CMDColor;
	tmpCell	: JadeTableCell;
	tmpText	: String;
	theTable : CM_ColourLegendTable;
begin
	theTable := self.frmLegend.myLegendTable;

	create cmdColor transient;
	cmdColor.preventFullOpen := false;
	cmdColor.color := frame.backColor;

	if cmdColor.open = 0 then
		frame.backColor := cmdColor.color;
		frame.foreColor := frame.backColor.getInverseColour();
		
		theTable.accessCell(theTable.row,1).backColor := cmdColor.color;
		theTable.accessCell(theTable.row,1).foreColor := cmdColor.color.getInverseColour;
	endif;


end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doInitSDFs" id="15d50026-d4cf-46ae-8153-0edf5394c9d3">
        <source>doInitSDFs();
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theSDF,theBSDF : CMUI_ScrollableDrawingFrame;

begin
	// Twin the BGRD SDF to the main SDF, so that it scrolls when the main SDF scrolls
	theSDF := self.mySDF;
	
	// link the SDFs
//	self.mySDFTop.mySDF := self.mySDF;
	self.mySDFTop.visible := false; // this SDF is only used in EDIT mode for moving and rotating
	theSDF.mySDF := self.mySDFBackground;
	theSDF.myBottomRightFillerFrame.visible := true;
	theSDF.myParentForm := self;
	theSDF.myHLabels.visible := false;
	theSDF.myVLabels.visible := false;
	theSDF.caption := null;
	
	theBSDF := 	self.mySDFBackground;
	theBSDF.caption := null;
	theBSDF.myParentForm := self;
	theSDF.transparent := true;
	theBSDF.transparent := true;
	theSDF.myDrawingFrame.transparent := true;
	theBSDF.myDrawingFrame.transparent := true;
	theBSDF.myHLabels.visible := false;
	theBSDF.myVLabels.visible := false;
	theBSDF.myHScroll.visible := false;
	theBSDF.myVScroll.visible := false;

	if self.mode = self.Mode_Display then
		self.mySDFBackground.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_DisplayOnly;
		theSDF.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_DisplayOnly;
	elseif self.mode = self.Mode_Edit then
		self.mySDFBackground.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_DisplayOnly;
		theSDF.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_PolyMove;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuCargoHeightsAllClick" id="f6b75e91-5a57-42bf-ac49-b4d47b13031a">
        <updating/>
        <source>doMnuCargoHeightsAllClick(theMenuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theSegmentor : CMIF_RectangleSegments;
	thePolygons : ObjectArray;
	anObject, aPointObject : Object;
	thePoints, ourPoints : PointArray;
	aController : CM_LocationsController;
	aGridController : CM_GridController;
	aGridStack : CM_GridArea;
	idx,tmp, aRow, aCol, controllerIndex, numCargo, theColour, numRows, numCols: Integer;
	theFrame : CMUI_PointDrawingFrame;
	theGraphic : CM_LayoutGraphic;
begin
	if theMenuItem.caption = Menu_Heights_Show then
		self.btnFlipV.visible := true;
		self.btnFlipH.visible := true;
		theMenuItem.caption := Menu_Heights_Hide;
		self.xmlShowCargoHeights := true;
		self.doDrawCargoHeightsNormal();
		self.doDrawLabels();
		if self.xmlHideLegend then
			self.sptMain.hideLeftControl(true);
			self.mnuHideLegend.caption := self.Menu_Show_Legend;
		else
			self.mnuHideLegend.caption := self.Menu_Hide_Legend;
			self.sptMain.showLeftControl(10, true);
		endif;
	else
		self.btnFlipV.visible := false;
		self.btnFlipH.visible := false;
		self.xmlShowCargoHeights := false;
		theMenuItem.caption := Menu_Heights_Show;
		self.doDrawGraphics();
		self.sptMain.hideLeftControl(true);
	endif;

	self.doResize();
epilog

end;</source>
        <Parameter name="theMenuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuCargoHeightsClick" id="e985c78a-2c5a-4400-b175-57690ce23cee">
        <updating/>
        <source>doMnuCargoHeightsClick(theMenuItem : MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theSegmentor : CMIF_RectangleSegments;
	thePolygons : ObjectArray;
	anObject, aPointObject : Object;
	thePoints, ourPoints : PointArray;
	aController : CM_LocationsController;
	aGridController : CM_GridController;
	aGridStack : CM_GridArea;
	idx,tmp, aRow, aCol, controllerIndex, numCargo, theColour, numRows, numCols: Integer;
	theFrame : CMUI_PointDrawingFrame;
	theGraphic : CM_LayoutGraphic;
begin
	app.msgBox("Not Implemented.","Sorry",MsgBox_OK_Only);
	return;


	if theMenuItem.caption = Menu_Heights_Show then
		theMenuItem.caption := Menu_Heights_Hide;
		if self.xmlHideLegend then
			self.sptMain.hideLeftControl(true);
		else
			self.sptMain.showLeftControl(10, true);
		endif;
	else
		theMenuItem.caption := Menu_Heights_Show;
		self.sptMain.hideLeftControl(true);
	endif;
	self.doDrawGraphics();
	self.doResize();
epilog

end;</source>
        <Parameter name="theMenuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuChangeColourClick" id="b0b7e2e2-ba4d-446b-a8f3-badea3cbdb03">
        <source>doMnuChangeColourClick();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTable : CM_ColourLegendTable;
begin
	theTable := self.frmLegend.myLegendTable;
	if theTable.row &lt;= theTable.fixedRows 
	or theTable.row &gt; theTable.rows then
		return;
	endif;
	
	theTable.bubbleHelp := "DoubleClick to Select next colour";
	self.frmColours.centreHorizontallyInParent();
	self.frmColours.top := 100;
	self.frmColours.visible := true;
	self.frmColours.zOrder(1);
	self.doTableDblClick(theTable);
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuContext" id="4950b7b6-c82b-49b1-a4bf-648735731512">
        <updating/>
        <source>doMnuContext(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		callback from CMUI_ScrollableDrawingFrame - SDF
//
// ---------------------------------------------------------------------------

vars
	theTable : CM_ColourLegendTable;
begin
/*
	self.doVisibleMenus(true);
*/
	if cntrl.isKindOf(CMUI_ColourLegendFrame) then
		theTable :=	cntrl.CMUI_ColourLegendFrame.myLegendTable;
		self.mnuChangeColour.visible := false;
		
		if theTable.row &gt; theTable.fixedRows and theTable.row &lt;= theTable.rows then
			self.mnuChangeColour.visible := true;
			self.mnuChangeColour.caption := "Change &amp;Colour For '" &amp; theTable.accessCell(theTable.row,1).text &amp; "'...";
	
			return self.showContextMenu(self.mnuContext, cntrl, conwin, mouse, x, y);
		endif;
	endif;
	return true;
	
end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
