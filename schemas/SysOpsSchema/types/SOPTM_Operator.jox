    <JadeMethod name="addCodeGroup" id="e45f3290-d156-4515-82e7-037b10ebfec2">
        <updating/>
        <source>addCodeGroup() :Boolean updating;
// ---------------------------------------------------------------------------
// Created:     10 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm 							:SOP_TableMaintForm;
	codeGroup							:CM_CodeGroup;
	theOperator							:CM_Operator;
	selectedVMCodeGroup,				
	newVMCodeGroup						:SOPVM_CodeGroup;
	selectedVMCodeGroupType,
	newVMCodeGroupType,
	existingParentType					:SOPVM_CodeGroupType;
	vmObj,
	vmCodeGroup							:CMUI_ViewModelObject;
	index								:Integer;
	groupId								:Integer;
begin
	theForm := self.myForm;
	
	if theForm.lbAvailable.listObject &lt;&gt; null then
		if theForm.lbAvailable.listObject.isKindOf(SOPVM_CodeGroup) then
			selectedVMCodeGroup := theForm.lbAvailable.listObject.SOPVM_CodeGroup;
			selectedVMCodeGroupType := selectedVMCodeGroup.myParent.SOPVM_CodeGroupType; 
			codeGroup := theForm.lbAvailable.listObject.SOPVM_CodeGroup.myObject.CM_CodeGroup;
			theOperator := theForm.myCurrentObject.CM_Operator;
			
			/*
			if self.allSelectedVMObjects.includes(selectedVMCodeGroupType) or
				self.allSelectedVMObjects.includes(selectedVMCodeGroup) then
				//only one code from each group allowed
				return false;
			endif;
			*/
			foreach vmObj in self.allSelectedVMObjects do
				if vmObj.isKindOf(SOPVM_CodeGroup) then
					groupId := vmObj.SOPVM_CodeGroup.myObject.CM_CodeGroup.myCodeGroupType.id;
					if groupId = selectedVMCodeGroup.myObject.CM_CodeGroup.myCodeGroupType.id then
						return false;
					endif;
				endif;
			endforeach;
			
			create newVMCodeGroupType transient;
			create newVMCodeGroup transient;
			newVMCodeGroupType.initializeMe(selectedVMCodeGroupType.myObject,1,null);
			self.allSelectedVMObjects.add(newVMCodeGroupType);
			newVMCodeGroup.initializeMe(codeGroup, 2, newVMCodeGroupType);
			self.allSelectedVMObjects.add(newVMCodeGroup);
		
		//redisplay shuffled selected vmObjects by parent
			theForm.lbSelected.clear;
			foreach vmObj in self.allSelectedVMObjects do
				if vmObj.isKindOf(SOPVM_CodeGroupType) then
					index := theForm.lbSelected.addItem(vmObj.displayEntryListbox);
					theForm.lbSelected.itemLevel[index] := 1;
					theForm.lbSelected.itemExpanded[index] :=true;
					theForm.lbSelected.itemObject[index] :=  vmObj.SOPVM_CodeGroupType;
					foreach vmCodeGroup in vmObj.SOPVM_CodeGroupType.allChildren do
						index := theForm.lbSelected.addItem(vmCodeGroup.displayEntryListbox);
						theForm.lbSelected.itemLevel[index] := 2;
						theForm.lbSelected.itemExpanded[index] :=true;
						theForm.lbSelected.itemObject[index] :=  vmCodeGroup;
					endforeach; 
				endif;
			endforeach;
			
		elseif theForm.lbAvailable.listObject.isKindOf(SOPVM_CodeGroupType) then
			app.msgBox('You have selected to add a Code Group TYPE, rather than a code group.' &amp; CrLf &amp;
								'Please choose a code GROUP.','Error',0);
		endif;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addRecRestrict" id="222121c9-ddd4-400e-b59b-3cf1b34182a2">
        <source>addRecRestrict(_recCutoff : CM_ReceivalCutoffOpTerm);

/*
Date		Who		Reason
25 May 2009	cnwar2	Initial creation

*/
vars
	tmpTable : CM_DataTable;
	idx		 : Integer;
	
begin
	tmpTable := self.myForm.tblData5;
	tmpTable.accessMode := tmpTable.AccessMode_Cell;
	tmpTable.column := 1;
	
	foreach idx in tmpTable.fixedRows + 1 to tmpTable.rows do
		if tmpTable.accessCell(idx, 1).text = _recCutoff.myReceivalCutoffTermDef.code then
			tmpTable.row 		:= idx;
			tmpTable.column		:= 2;
			//20/03/2025	navkc1 JIRA Story MTN-34232
			if _recCutoff.isEDIType() then
				tmpTable.comboList &amp;=  Tab &amp; DefaultRelativeTo_ShipExch_Str &amp; Tab &amp; DefaultRelativeTo_RecCutOffStr;
			endif;
			tmpTable.comboIndex	:= _recCutoff.defaultRelativeTo;
			tmpTable.accessCell(idx, 3).text := _recCutoff.defaultEarliestReceival.asStringJMTWithPrecision(2,false) &amp; Tab &amp; 
												_recCutoff.defaultCutoff.asStringJMTWithPrecision(2,false) &amp; Tab &amp; 
												_recCutoff.defaultEarliestReceivalPN.asStringJMTWithPrecision(2,false) &amp; Tab &amp; //20/03/2025	navkc1 JIRA Story MTN-34232
												_recCutoff.defaultCutoffPN.asStringJMTWithPrecision(2,false); //20/03/2025	navkc1 JIRA Story MTN-34232
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_recCutoff" type="CM_ReceivalCutoffOpTerm"/>
    </JadeMethod>
