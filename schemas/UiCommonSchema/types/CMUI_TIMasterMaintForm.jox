    <JadeMethod name="lstTblStops_displayRow" id="3fcdf78f-d53c-473b-b8e9-f68a14dd0e9a">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTblStops_displayRow(table: Table input; theSheet: Integer; obj: CM_StopsTable; theRow: Integer; bcontinue: Boolean io):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2008	cnwrd1	Initial creation

*/

vars
	selected		: Boolean;

begin

	selected := self.lstTblStops.allSelectedObjects.includes(obj);

	if selected then
		return TableCheckBox_Selected  &amp; Tab &amp; obj.heading;
	else
		// DVB CCMS 1235
		if not (obj.isNotAvailableForEntry) then
			return  TableCheckBox_NotSelected &amp; Tab &amp; obj.heading;
		else
			return null;
		endif;
	endif;

//	return TableCheckBox_NotSelected &amp; Tab &amp; "lstTblStops :: displayRow()";
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="CM_StopsTable"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
