begin
	/*
	//01.07.2024 navhl20 #64969
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.allChildren.isNotEmpty() then
		foreach ti in self.myTrackedItem.allChildren do
			quant := quant + ti.totalQuantity;
		endforeach;
		return quant;
	endif;
	return inheritMethod();*/
	return self.quantity;			//01.07.2024 navhl20 #64969
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRequestType" id="d4d3c4aa-a5c7-4b44-9a17-7c1a88d90d37">
        <source>getRequestType(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who			Reason
14/06/2022 	navcs2 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

begin

	if self.job.myWODtl &lt;&gt; null then
		return REQ_TI_WORKORDER;
	else
		return REQ_TI_RELEASE;
	endif;


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
