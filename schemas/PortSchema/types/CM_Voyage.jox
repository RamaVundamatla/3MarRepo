    <JadeMethod name="checkOrdersForOperatorLoaded" id="453df167-af00-4185-b7f5-0a6ba10b0465">
        <source>checkOrdersForOperatorLoaded(_operator: CM_Operator): Boolean;
//--------------------------------------------------------------
//Created: 21 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bolOut : CM_BOLOut;
begin
	foreach bolOut in self.allBOLOutByTypeStatusNumDT do
		if bolOut.myOperator = _operator then
			//Logs are moved to the ship when the bolOut is created
