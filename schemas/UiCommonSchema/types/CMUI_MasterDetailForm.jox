    <JadeMethod name="zDoCancel" id="16475333-9698-4cd8-971e-f6e5dc8f013e">
        <updating/>
        <source>zDoCancel() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	masterTbl			: CM_DataTable;
	row,
	numRows				: Integer;
begin
	
	self.doCancel();

	self.mode := self.Mode_View;
	if self.myCurrentMasterObject = self.myCurrentMasterPxy then	// + dh 12/11/2007 par 15304
		self.myCurrentMasterObject := null;							// + dh 12/11/2007 par 15304
	endif;															// + dh 12/11/2007 par 15304
	self.tblDataMaster.removeItemObject(self.myCurrentMasterPxy);
	delete self.myCurrentMasterPxy;
	self.allDetailObjects.purge();
	self.allClonedControls.purge();
	self.tblMasterEnt.clearValues();
	self.tblDataMaster.setFocus();
	self.zSetControlsForView();
	self.zShowThumbnailData(self.myCurrentMasterObject);
	self.tblDataMaster.findObjectInRow(self.myCurrentMasterObject, row);
	self.tblDataMaster.selectRow(row,false);
		
epilog
	delete self.myCurrentMasterPxy;
	self.allDetailObjects.clear();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoDelete" id="4ae812c1-9a0e-4bd6-8936-4d003ce926dc">
        <updating/>
        <source>zDoDelete() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.mode &lt;&gt; self.Mode_View then
		return;
	endif;

	if self.myCurrentMasterObject = null then
		app.msgBox('You must select a ' &amp; self.getDataEntityDescription(true) &amp; ' to delete', app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if app.msgBox('Are you sure you wish delete the selected ' &amp; self.getDataEntityDescription(true) &amp; '?', 'Are you sure...', MsgBox_OK_Cancel) &lt;&gt; MB_OK then
		return;
	endif;
	
	if self.doDelete() then
		self.myCurrentMasterObject := null;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="a7b848e2-97a4-4fd1-ba85-829d327dc09a">
        <updating/>
        <source>zDoEdit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ls			: Boolean;
begin
	if self.myCurrentMasterObject = null then
		app.msgBox('You must select a ' &amp; self.getDataEntityDescription(true) &amp; ' to update first', 
					app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	app.cmsBeginLoad(ls);
	self.mode := self.Mode_Edit;
	delete self.myCurrentMasterPxy;
	self.myCurrentMasterPxy := app.createUpdateProxy(self.myCurrentMasterObject);	
	self.createDetailProxies();
	self.masterEdition := self.myCurrentMasterObject.edition;
	self.zSetControlsForAddEdit();

epilog
	endLoad;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoNew" id="f0dce103-0078-4857-b2ca-0d1c366819fb">
        <updating/>
        <source>zDoNew() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx			: Integer;
	masterTbl	: CM_DataTable;
begin
	self.mode := self.Mode_New;
	self.tblMasterEnt.clearValues();
	self.tblDetailEnt.clearValues();
	self.tblDataDetail.rows := self.tblDataDetail.fixedRows;
	
	masterTbl := self.tblDataMaster;
	if masterTbl.row &gt; masterTbl.fixedRows then
		masterTbl.accessRow(masterTbl.row).selected := false;
	endif;
	
	delete self.myCurrentMasterPxy;
	create self.myCurrentMasterPxy as self.getDataEntityClass(true) transient;
	idx := masterTbl.addItem('...');
	masterTbl.accessRow(idx).itemObject := self.myCurrentMasterPxy;
	masterTbl.selectRow(idx, true);
	masterTbl.row := idx;

	//masterTbl.accessRow(idx).selected := true;
	//masterTbl.topRow := idx;
	
	self.zSetControlsForAddEdit();
	
	if self.showTblDetailCount then
		self.staMain.caption := (self.tblDataDetail.rows - self.tblDataDetail.fixedRows).String &amp; ' ' &amp;
									self.getDataEntityDescription(false) &amp; ' listed';
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoRemoveDetail" id="ca166841-5295-439e-9b13-fcbc63c06588">
        <updating/>
        <source>zDoRemoveDetail() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	row, numObjRows, numRows  : Integer;
	table 	: CM_DataTable;
	selectedRowArray : BooleanArray;
	blnSelected : Boolean;
begin
	table := self.tblDataDetail;
	numRows := table.rows;

	if self.myCurrentDetailObject = null then
		// work out if more than one detail 
		numObjRows := numRows - table.fixedRows;
		
		if numObjRows &lt; 1 then 
			return; // should not be here 
		elseif numObjRows = 1 then 
			// only one detail so this must be the one they are trying to remove. 
			table.selectRow(numRows,false);
			self.myCurrentDetailObject := table.accessRow(numRows).itemObject;
			
		elseif numObjRows &gt; 1 then 
			// trying to remove a detail but none selected. 
			app.msgBox('You must select a ' &amp; self.getDataEntityDescription(false) &amp; 
					' to remove from the ' &amp; self.getDataEntityDescription(true) &amp; ' first.', 
					app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;

	if app.msgBox('Are you sure you want to remove the selected ' &amp; 
				self.getDataEntityDescription(false) &amp; '?', app.getErrorString(AreYouSure), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
		
	if self.mode = self.Mode_View then
		// must remember selected for removing as zDoEdit() clears the table and re-populates it. 
		create selectedRowArray transient;
		
		foreach row in table.fixedRows + 1 to table.rows do
			selectedRowArray.add(table.accessRow(row).selected);
		endforeach;	

		self.zDoEdit();	

		// reset selected rows. 
		row := table.fixedRows + 1;
		foreach blnSelected in selectedRowArray do 
			if blnSelected then 
				table.selectRow(row,false);
			endif;
			row := row + 1;
		endforeach;		
	endif;
	
	self.doRemoveDetailLine();
	
	if self.showTblDetailCount then
		self.staMain.caption := (self.tblDataDetail.rows - self.tblDataDetail.fixedRows).String &amp; ' ' &amp;
									self.getDataEntityDescription(false) &amp; ' listed';
	endif;
	
	self.myCurrentDetailObject := null;
	
epilog
delete selectedRowArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoSave" id="771aa284-ab79-4283-bdf4-5ffabe4cac50">
        <updating/>
        <source>zDoSave() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	numRows,
	row				: Integer;
	rtnValue 		: Boolean;
	newObject		: CM_Object;
	masterTbl		: CM_DataTable;
begin
	self.isUpdateComplete := false;
	rtnValue := self.doSave();
	
	if rtnValue then
		self.isUpdateComplete := true;	//notification timing hole plugged! =)
		self.tblDataMaster.removeItemObject(self.myCurrentMasterPxy);
		
		delete self.myCurrentMasterPxy;
		self.allDetailObjects.purge();
		self.allClonedControls.purge();
		self.zSetControlsForView();
		//this should happen when the notification from the save is received by the form
		//self.tblDataMaster.selectObject(self.myCurrentMasterObject, false);
		//self.zShowThumbnailData(self.myCurrentMasterObject);
		
	endif;
	
	return rtnValue;
epilog
	self.isUpdateComplete := true;	

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zDoSearch" id="fe43e62f-f559-4f18-9ba3-0fb17986a218">
        <updating/>
        <source>zDoSearch() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmifMonitor		: CMIF_Monitor;
begin
	app.mousePointer := Busy;
	
	if self.mode &lt;&gt; self.Mode_View then
		return;
	endif;
	
	self.tblDataMaster.rows := self.tblDataMaster.fixedRows;
	self.tblDataDetail.rows := self.tblDataDetail.fixedRows;
	self.tblMasterEnt.clearValues();
	
	delete app.myPassport.myCMIFMonitor;
	create cmifMonitor transient;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.myParent := self;
	self.initModalDialogueForSearch(cmifMonitor);
	self.setSearchValues();
	self.addObjectsToTable(cmifMonitor);
	
	if self.tblDataMaster.rows = self.tblDataMaster.fixedRows then
		app.msgBox(app.getErrorString(UiNo_Items_Found), app.getErrorString(UiNo_Results), MsgBox_Exclamation_Mark_Icon);
		self.tblSearch.setFocus();
	else
		self.zShowHideSearcher(false);
	endif;
	
epilog
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	app.mousePointer := Idle;

end;</source>
        <access>protected</access>
    </JadeMethod>
