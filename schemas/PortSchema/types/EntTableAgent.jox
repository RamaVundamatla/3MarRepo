    <JadeMethod name="addConstantDefToString" id="24047208-e326-4916-993a-0aa3873fcbd3">
        <source>addConstantDefToString(_str : String io; _name, _value, _text, _user : String) protected;
// ---------------------------------------------------------------------------
// Created:     24 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 July 2022	 navpw1		Added Modified timestamp and usercode, so we can see who modified it
// ---------------------------------------------------------------------------
vars
	modifiedTimeStamp : TimeStamp;
begin

	_str := _str &amp; CrLf &amp; 
			Tab &amp; _name &amp; ':' &amp; Tab &amp; "String = '" &amp; _value &amp; "';" &amp; CrLf &amp;
			Tab &amp; 'documentationText' &amp; CrLf &amp;
			'`' &amp; _text &amp; '`' &amp; CrLf &amp; CrLf;
	
	if _user &lt;&gt; null then
		modifiedTimeStamp := app.actualTimeServer;
		_str &amp;= Tab &amp; Tab &amp; 'setModifiedTimeStamp "' &amp; _user &amp; '" "5.2.08" ' &amp; modifiedTimeStamp.date.format("yyyy:MM:dd") &amp; ":" &amp; modifiedTimeStamp.time.format("HH:mm:ss") &amp; ';' &amp; CrLf &amp; CrLf;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String" usage="io"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_user" type="String"/>
    </JadeMethod>
    <JadeMethod name="addConstantsServer" id="1a970a72-0786-468a-9450-eae46e6ec57d">
        <executionLocation>server</executionLocation>
        <source>addConstantsServer(_defConstantStr, _grpConstantStr, _rowConstantStr, _viewConstantStr : String; _rtnStr : String output) : Integer protected, serverExecution;
// ---------------------------------------------------------------------------
// Created:     24 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
constants
	Hdr	: String = 	'jadeVersionNumber "5.2.08";' &amp; CrLf &amp;
					'schemaDefinition' &amp; CrLf &amp;
					'PortSchema subschemaOf BaseSchema partialDefinition, patchVersion=802, patchVersioningEnabled = true;' &amp; CrLf &amp;
					'constantDefinitions';
vars
	fil		: File;
	args	: StringArray;
	result	: Integer;
	rtnStr	: String;
		
begin

	result := -1;

	create fil transient;	
	fil.mode := File.Mode_Output; // 29/2/16  cnwns1 PAR 36286 unicode version
	
	fil.fileName := 'c:\temp\etLoad' &amp; app.actualTimeServer.Date.formatAsYYYYMMDD() &amp; app.actualTimeServer.Time.format('HHmmss') &amp; '.scm';// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	fil.writeLine(Hdr);

	rtnStr := rtnStr &amp; CrLf &amp; '  creating ' &amp; fil.fileName;

	if _defConstantStr &lt;&gt; null then
		fil.writeLine('categoryDefinition EntTableDefs');
		fil.writeLine(_defConstantStr);
	endif;

	if _grpConstantStr &lt;&gt; null then
		fil.writeLine('categoryDefinition EntTableGroups');
		fil.writeLine(_grpConstantStr);
	endif;

	if _rowConstantStr &lt;&gt; null then
		fil.writeLine('categoryDefinition EntTableRows');
		fil.writeLine(_rowConstantStr);
	endif;

	if _viewConstantStr &lt;&gt; null then
		fil.writeLine('categoryDefinition EntTableViews');
		fil.writeLine(_viewConstantStr);
	endif;
	
	fil.close;


	create args transient;
	args.add('path="' &amp; app.dbPath &amp; '"');			rtnStr := rtnStr &amp; CrLf &amp;  'path="' &amp; app.dbPath &amp; '"';
	args.add('schemaFile="' &amp; fil.fileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'schemaFile="' &amp; fil.fileName &amp; '"';
	args.add('ini="' &amp; app.getIniFileName &amp; '"');	rtnStr := rtnStr &amp; CrLf &amp;  'ini="' &amp; app.getIniFileName &amp; '"';
	args.add('server=multiuser');
	args.add('loadStyle=currentSchemaVersion');
	
	rtnStr := rtnStr &amp; CrLf &amp;  ' externalProcess = ' &amp; 
				node.createExternalProcess(app.getJadeInstallDir(), 'jadloadb.exe', args, null, false, true, result).String;
	rtnStr := rtnStr &amp; CrLf &amp;  ' jadloadb result = ' &amp; result.String;
	
	return result;
	
epilog
	_rtnStr := rtnStr;
	delete args;
	if fil &lt;&gt; null then
		fil.close;
//		f.purge;
	endif;
	delete fil;
	
end;</source>
        <access>protected</access>
        <Parameter name="_defConstantStr" type="String"/>
        <Parameter name="_grpConstantStr" type="String"/>
        <Parameter name="_rowConstantStr" type="String"/>
        <Parameter name="_viewConstantStr" type="String"/>
        <Parameter name="_rtnStr" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addError" id="50f221e3-a641-47e4-a3bc-9e2207de2c24">
        <source>addError(pErr : String) protected;
// ---------------------------------------------------------------------------
// Created:     18 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01 Mar 2010	cnwkpd1	PAR #22559 - Ent Table Row upgrade issues
// ---------------------------------------------------------------------------
vars

begin
	self.writeLogMessage(method.qualifiedName &amp; '  Error &gt;&gt; ' &amp; pErr);
	self.allErrorStrings.add(pErr);

end;</source>
        <access>protected</access>
        <Parameter name="pErr" type="String"/>
    </JadeMethod>
    <JadeMethod name="checkEntTableConsistency" id="90cfd923-08f6-488f-88cc-6eae53a21916">
        <source>checkEntTableConsistency() : Boolean;

/*

Purpose:			Check the consistency of the relationships bewteen the various EntTable objects 
					
Parameters:			None

Return Value:		True if check is done, false if setup is incorrect


Date		Who		Reason
02 Mar 2010	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	dataRoot		: EntTableDataRoot;
	baseScm 		: Schema;
	category 		: ConstantCategory;
	const 			: Constant;
	constDict		: ConstantNDict;
	xmlDoc			: JadeXMLDocument;
	group			: EntTableGroup;
	toDeleteArray	: EntTableArray;
	entitiesAccessed	: ObjectSet;
	iter			: Iterator;
	rowHeader		: EntTableRowHeader;
	row				: EntTableRow;
	def				: EntTableDef;		
	xlatCategory 	: XLAT_Category;
	translatableText : XLAT_EntityTableText;
	
begin
	if self.myEntTableDataRoot = null then
		return false;
	endif;
	
	dataRoot := self.myEntTableDataRoot;
	baseScm := rootSchema.getSchema(dataRoot.schemaName);

	xmlDoc := self.myXMLDoc;

	// Check all the rows
	foreach rowHeader in dataRoot.allEntTableRowHeadersByName do 
		foreach row in rowHeader.allEntTableRows do
			if row.myRoot = null then
				self.writeLogMessage('&gt;&gt;&gt;&gt; ERROR - myRoot is null for ' &amp; row.String);
			endif;
			if row.myEntTableText = null then
				self.writeLogMessage('&gt;&gt;&gt;&gt; ERROR - myEntTableText is null for ' &amp; row.String);
			else
				if row.myEntTableText.number &lt;&gt; row.number then
					self.writeLogMessage('&gt;&gt;&gt;&gt; ERROR - myEntTableText.number (' &amp; row.myEntTableText.number.String &amp; 
										 ') does not match number (' &amp; row.number.String &amp; ') for ' &amp; row.String);
				endif;
			endif;
		endforeach;
	endforeach;
	
	// Now need to scan all the translations in the EntTableRows category, and check that there
	// aren't any that are "hanging"
	xlatCategory := app.myRoot.allXLAT_Categories[EntTableRows];
	
	delete iter;
	iter := xlatCategory.allTranslatableText.createIterator();
	
	while iter.next(translatableText) do
		if translatableText.myEntTableRow = null then
			self.writeLogMessage('&gt;&gt;&gt;&gt; ERROR - myEntTableRow is null for ' &amp; translatableText.String &amp; " " &amp; translatableText.number.String);
		endif;
	endwhile;
	
	
epilog
	delete iter;		// PAR #26678

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="7e7236c5-2169-497b-96f9-898e9c535ec8">
