    <JadeMethod name="setupConfig" id="ffa764f5-520a-4f49-894b-e55bb0e09cce">
        <updating/>
        <source>setupConfig(_terminal: CM_Terminal input): Boolean updating;
//----------------------------------------------------------------
//	Created:	09 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	aEC	: CM_EDIConfig;
begin
	if _terminal.myEdiConfig &lt;&gt; null then
		return false;
	endif;

	beginTransaction;
	create aEC persistent;
		aEC.setForCreate(_terminal,null);	//YES, ROOT SHOULD BE NULL
	commitTransaction;
	return true;	
epilog

end;</source>
