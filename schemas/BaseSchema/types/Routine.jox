<Class name="Routine">
    <JadeMethod name="cnEcGetParameters" id="748a0056-4eb8-4898-9bed-39a61d19473f">
        <source>cnEcGetParameters():ParameterColl;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Returns a reference to the receiver's Parameter collection.
//
// Parameters:	None
//
// Returns:		A reference to the receiver's Parameter collection.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.parameters;
end;</source>
        <ReturnType type="ParameterColl"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetReturnType" id="9c987188-bb78-40c5-a49b-183cfe68bd10">
        <source>cnEcGetReturnType():Type;
// --------------------------------------------------------------------------------
// Created:		07 April 2005 by cnwdad1
//
// Purpose:		Returns a reference to the Type of the receiver's return value.
//
// Parameters:	None
//
// Returns:		A reference to the Type of the receiver's return value, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnTypeObj	: ReturnType;
	
begin
	returnTypeObj	:=	self.returnType;
	
	if returnTypeObj = null then
		return null;
	else
		return returnTypeObj.type;
	endif;
end;</source>
        <ReturnType type="Type"/>
    </JadeMethod>
</Class>
