<Class name="WSRamScripts" id="6e0760c3-e4a1-43a4-bbe4-b0e853575e11">
    <superclass name="JadeScript"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <JadeMethod name="xmlDefinitionOfClass" id="68430b2e-8e7b-4eb2-ae15-9d6c4a3dfe9d">
        <source>xmlDefinitionOfClass();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navra1	Initial creation

*/

vars
	str : String;
	invoice : CM_Invoice;
	prop : Property;
	subprop : Property;
	class : Class;
begin
	//create prenote transient;
	str := "***&lt;Invoice&gt;";
	foreach prop in WS_InvoiceDetails.getProperties do		
		if prop.isKindOf(PrimAttribute) then
			str := str &amp; CrLf &amp; prop.name &amp; '-' &amp; prop.type.name&amp;"("&amp;prop.getLength().String&amp;")";				
		else
			//write("not considering attibute " &amp; prop.name);		
			
			str := str &amp; CrLf &amp; "PROPERTY :     " &amp; prop.name &amp; '-' &amp; prop.type.name;
			if prop.isKindOf(BGP_RequestSet) then
				class := BGP_Request;
			elseif prop.isKindOf(CM_AuditObjectDictByTimestamp) then
				class := CM_AuditObject;
			elseif prop.isKindOf(CM_EWSActivityByDateTime) then
				//class := CM_EWSActivity;
			elseif prop.isKindOf(CM_FileDataSet) then
				class := CM_FileData;
			elseif prop.isKindOf(CM_InvoiceSet) then
				class := CM_Invoice;
			elseif prop.isKindOf(CM_WorkOrderSet) then
				class := CM_WorkOrder.class;
			elseif prop.isKindOf(CM_AuditObjectDictByTimestamp) then
				prop := prop;
			elseif prop.isKindOf(CM_AuditObjectDictByTimestamp) then
				prop := prop;
			elseif prop.isKindOf(CM_AuditObjectDictByTimestamp) then
				prop := prop;
			else
				prop := prop;
			endif;
			foreach subprop in class.getProperties do		
				str := str &amp; CrLf &amp; "         " &amp; subprop.name &amp; '-' &amp; subprop.type.name;
			endforeach;
		endif;
	endforeach;
	str := str &amp; "&lt;/Invoice&gt;";
	write str;
epilog
	delete invoice;
end;
</source>
    </JadeMethod>
</Class>
