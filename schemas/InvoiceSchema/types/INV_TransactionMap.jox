    <JadeMethod name="btnDebtorsSave_click" id="09131206-7612-4baa-83f7-9e45120caa97">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDebtorsSave_click(btn: Button input) updating;
// 24051
vars

begin
	// make sure a valid selection has been made.
	if self.lstDebtorsList.listObject = null then
		app.msgBox(	app.getString( Selection_value_required, app.getString( Debtors ) ),
						app.getString( Error ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		return;
	endif;
	
	if ( self.myCurrentMapTM &lt;&gt; null  or self.myCurrentMapTMBOL &lt;&gt; null )	//29 Nov 2019	NDL	TFS 47100
	and self.cmbDebtorTypes.listObject = null
	then
		app.msgBox(	app.getString( Selection_value_required, app.getString( Charges ) ),
						app.getString( Error ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		return;
	endif;
	
	self.doBtnListSaveClick();
end;
</source>
