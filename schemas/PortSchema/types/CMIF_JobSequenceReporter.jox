<Class name="CMIF_JobSequenceReporter" id="b11f9251-3da6-4e27-9c2c-71f335bc64eb">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allWLEs" id="08d47374-bc84-49b2-adca-ea7a2cadda8e">
