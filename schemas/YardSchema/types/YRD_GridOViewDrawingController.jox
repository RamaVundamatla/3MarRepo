    <JadeMethod name="isForOverview" id="6df8159c-bb4d-40af-b2f4-8de45d6c7e4b">
        <methodInvocation>mapping</methodInvocation>
        <source>isForOverview(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:		04 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
