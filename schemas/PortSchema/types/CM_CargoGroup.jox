    <JadeMethod name="getOnsiteAssignedCargo" id="63ed8750-13ab-479e-a730-6c9262b1aefe">
        <source>getOnsiteAssignedCargo( _tiSet : CM_TISet input; _clearCollFirst : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;

begin

	if _clearCollFirst then
		_tiSet.clear();
	endif;
	
	iter := self.allAssignedTrackedItems.createIterator;
	while iter.next( ti ) do
		if not ti.isOnSite then
			continue;
		endif;
		if ti.isNotified or ti.myPrimaryActualLocation = null then	
			continue;
		endif;
		_tiSet.addNoDuplicates( ti, false );
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_clearCollFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getOnsiteLocations" id="8c549078-ef93-4bf5-af5b-62cc87332c41">
        <source>getOnsiteLocations( _lcs : CM_LCSet input ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2025	navhl20 Bug MTN-34624: EUP | 53856 - Scanning App - further issues

*/

vars
	ti 				: CM_TrackedItem;
	lc 				: CM_LocationsController;
	locnStr 		: String;
	strArray 		: StringArray;
	intArray 		: IntegerArray;
	returnString 	: String;
	index 			: Integer;
	tiSet			: CM_TISet;
begin
	
	if self.allAssignedTrackedItems.isEmpty then
		return null;
	endif;
	
	create strArray transient;
	create intArray transient;
	
	create tiSet transient;
	self.allAssignedTrackedItems.copy(tiSet);
	
	foreach ti in tiSet discreteLock do
		lc 		:= null;
		locnStr := null;
		
		if ti.isOnSite then 
			lc := ti.myPrimaryActualLocation;
			if lc &lt;&gt; null then
				locnStr := lc.getFullId();
			endif;
		endif;
		
		if locnStr &lt;&gt;  null then
			if not strArray.includes( locnStr ) then
				if _lcs &lt;&gt; null and lc &lt;&gt; null then
					_lcs.add(lc);
				endif;
				strArray.add( locnStr );
				intArray.add( 1 );
			else
				index := strArray.indexOf( locnStr );
				intArray[index] := intArray[index] + 1;
			endif;
		endif;
	endforeach;
	
	if strArray.isEmpty then
		return null;
	endif;
	
	index := 0;
	foreach locnStr in strArray do
		index := index + 1;
		if returnString &lt;&gt; null then
			returnString := returnString &amp; ", ";
		endif;
		returnString := returnString &amp; locnStr &amp; " (x" &amp; intArray[index].String &amp; ")";
	endforeach;
	
	return returnString;
epilog
	delete strArray;
	delete intArray;
	delete tiSet;
end;</source>
        <Parameter name="_lcs" type="CM_LCSet" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPlannedLocation" id="502ef193-492a-41bd-8b9b-070d2ff6a324">
        <source>getPlannedLocation():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Feb 2024 navhl20 ChangeRequest 62406:[62534] EUP | Scanning App Cargo Group Overview Changes
18 Apr 2025	navhl20 Bug MTN-34624: EUP | 53856 - Scanning App - further issues
*/

vars
	strArr 			: StringArray;
	ti				: CM_TrackedItem;
	plannedLoc,	
	queuedLoc		: CM_LocationsController;
	planedLocStr,
	queuedLocStr	: String;
	tiSet			: CM_TISet;
begin
	
	create strArr transient;
	
	create tiSet transient;
	
	self.allAssignedTrackedItems.copy(tiSet);
	
	foreach ti in tiSet discreteLock do
		
		plannedLoc := ti.myPrimaryPlannedLocation;
		
		if plannedLoc &lt;&gt; null then
			planedLocStr := plannedLoc.getFullId();
			
			if not strArr.includes(planedLocStr) then
				strArr.add(planedLocStr);
			endif;
		endif;
	endforeach;
	
	if strArr.isNotEmpty then														//18.04.2025 navhl20 #34624
		return strArr.concatenate(Comma);
	endif;
	
	foreach ti in tiSet discreteLock do												//18.04.2025 navhl20 #34624
		
		queuedLoc := ti.myPrimaryQueuedLocation;
		
		if queuedLoc &lt;&gt; null then
			queuedLocStr := queuedLoc.getFullId();
			
			if not strArr.includes(queuedLocStr) then
				strArr.add(queuedLocStr);
			endif;
		endif;
	endforeach;
	
	return strArr.concatenate(Comma);												//18.04.2025 navhl20 #34624
epilog
	delete strArr;
	delete tiSet;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPreAssignedToScan" id="ee7a396c-f58b-4d28-be78-c211d7bb87b5">
        <source>getPreAssignedToScan( _strArray : StringArray input ):Integer;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
02 October 2018	jlgndl1		Initial creation	TFS 39186
13 Nov 2019		NDL			TFS 47298
14 Nov 2025		NAVBK1  	MTN 36541: STWR - Error message shown after successful Cargo Group completion in Mobile Apps (non-blocking)
03 Dec 2025 	navhl20 	Bug MTN-36780: STWR - Cargo Group Assign Move - item already assigned Info appears wrongly
*/

vars

	iter : Iterator;
	strArray : StringArray;
	obj : Object;
	cargoId : String;
	count : Integer;
	ti : CM_TrackedItem;
	invalid: Boolean;
	groupAssignment: CM_CargoGroupAssignment;
begin
	on Exception do app.handleDeletedObject( exception, ti, invalid );					//14.11.2025 navbk1 #36541
	
	if self.allPreAssignedCargoIdsDict.isEmpty then
		return 0;
	endif;
	
	create strArray transient;
	
	iter := self.allPreAssignedCargoIdsDict.createIterator;
	while iter.next( obj ) do
		cargoId := iter.getCurrentKey( 1 ).String;
		if cargoId &lt;&gt; null then															//03.12.2025 navhl20 #36780
			strArray.tryAdd( cargoId );
		endif;										
	endwhile;
	
	count := strArray.size;
	
	if count = 0 then
		return 0;
	endif;
	
	groupAssignment := self.getMyCargoGroupAssignment();								//14.11.2025 navbk1 #36541

	if groupAssignment &lt;&gt; null then
		foreach ti in groupAssignment.allProcessedTis discreteLock do
			invalid := false;
			cargoId := ti.id;
			if invalid then
				continue;
			endif;
			if strArray.tryRemove( cargoId ) then											//14.11.2025 navbk1 #36541
				//strArray.remove( cargoId );												//14.11.2025 navbk1 #36541
				//this one has been done
				count := strArray.size;
			endif;
			if count= 0 then
				return 0;
			endif;
		endforeach;
	endif;
	
	if _strArray &lt;&gt; null then
		foreach cargoId in strArray do
			_strArray.add( cargoId );
		endforeach;
	endif;
	
	return count;
epilog

	delete iter;
	delete strArray;

end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPreviousCustomDocument" id="1119cc76-5daf-4135-8ad5-04bb8e59660b">
        <source>getPreviousCustomDocument(_beforeThis : CM_CustomDocument) : CM_CustomDocument;
/*
Purpose:			

Date		Who		Reason
25 August 2023	navab1	CR 59942 TASK 59943 
*/

vars
	custDoc : CM_CustomDocument;
	custDocDetail, subDocDetail : CM_CustomDocumentDetail;
	ti : CM_TrackedItem;
begin
	foreach ti in self.allAssignedTrackedItems discreteLock do
		custDoc := ti.getPreviousCustomDocument(_beforeThis);
		if custDoc &lt;&gt; null then
			return custDoc;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_beforeThis" type="CM_CustomDocument"/>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="getReservations" id="de3704be-dff1-4a2b-9311-99dd2dd75130">
        <source>getReservations() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2023 navmv20 CR 58410 Task 58414: UI - Cargo Review - Grouping Table
24 November 2023 navmv20 Bug 61267: FR | EUP - Release Request by Type - Cargo Group &lt;&lt;53383&gt;&gt;
*/

vars
	reserveDetail : CM_ReserveDetail;
	reserveHeader : CM_BulkRelease;
	detailCode : String;
	returnStr : String;
begin

	foreach reserveDetail in self.allReserveDetailAssigned do
		reserveHeader := reserveDetail.myReserveHeader;
		detailCode := reserveHeader.code;
		if detailCode&lt;&gt; null then
			if returnStr.pos(detailCode,1) = 0 then
				if returnStr = null then
					//returnStr := detailCode //24/11/2023 navmv20 Bug 61267
					returnStr := detailCode &amp; " (" &amp; reserveDetail.totalRequested.asStringJMT() &amp; ")" ; //24/11/2023 navmv20 Bug 61267
				else
					//returnStr := returnStr &amp; ", " &amp; detailCode //24/11/2023 navmv20 Bug 61267
					returnStr := returnStr &amp; ", " &amp; detailCode &amp; " (" &amp; reserveDetail.totalRequested.asStringJMT() &amp; ")" ; //24/11/2023 navmv20 Bug 61267
				endif;
			endif;
		endif;
	endforeach;
	return returnStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReserveQuantity" id="c2369bc6-0ed1-4a25-a00a-d7355ec6ab96">
        <source>getReserveQuantity(_myReserveDetail : CM_ReserveDetail):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
12/06/2025	navrv30	MTN 35029 TPT | Release Request via Cargo Review with an Ownership Change
*/

vars
	reserveDetail, myReserveDetail : CM_ReserveDetail;
	totalRequested : Integer;
begin
	if _myReserveDetail &lt;&gt; null and _myReserveDetail.pxyIsProxy() then
		myReserveDetail := _myReserveDetail.pxyGetRealObject();
	else
		myReserveDetail := _myReserveDetail;
	endif;
		
	foreach reserveDetail in self.allReserveDetailAssigned do
		if myReserveDetail = reserveDetail then
			continue;
		endif;
		//12/06/2025	navrv30	MTN 35029
		if self.operatorCode &lt;&gt; reserveDetail.getOperator().code then
			continue;
		endif;
		totalRequested := totalRequested +reserveDetail.totalRequested;
	endforeach;
	return totalRequested;
epilog

end;</source>
        <Parameter name="_myReserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReserveQuantityForTI" id="61175b3f-e7aa-46e7-a12f-874546935bb9">
        <source>getReserveQuantityForTI(_trackedItem : CM_TrackedItem) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2025 navrv30 JIRA 33699 EUP| Reserved Qty and Details not showing up in COO and Cargo Review

*/


vars
	reserveDetail : CM_ReserveDetail;
	totalRequested : Integer;
	isExactMatch : Boolean;
begin	
		
	foreach reserveDetail in self.allReserveDetailAssigned do
		reserveDetail.doesTIMatchForRelease(_trackedItem, isExactMatch);
		if not isExactMatch then
			continue;
		endif;
		totalRequested := totalRequested +reserveDetail.totalRequested;
	endforeach;
	return totalRequested;
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReservedVolume" id="02688dc6-5b1b-4167-94dc-c825b40398c7">
        <source>getReservedVolume(_myReserveDetail : CM_ReserveDetail) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
12/06/2025	navrv30	MTN 35029 TPT | Release Request via Cargo Review with an Ownership Change
*/

vars
	reserveDetail,myReserveDetail : CM_ReserveDetail;
	reservedWeight,
	reserveVolume : Decimal[14,4];
begin
	if _myReserveDetail &lt;&gt; null and _myReserveDetail.pxyIsProxy() then
		myReserveDetail := _myReserveDetail.pxyGetRealObject();
	else
		myReserveDetail := _myReserveDetail;
	endif;
	
	foreach reserveDetail in self.allReserveDetailAssigned do
		if myReserveDetail = reserveDetail then
			continue;
		endif;
		//12/06/2025	navrv30	MTN 35029
		if self.operatorCode &lt;&gt; reserveDetail.getOperator().code then
			continue;
		endif;
		reservedWeight := reserveDetail.weightRequested;
		if reserveDetail.isKindOf(CM_ReserveSelection) then
			reserveVolume := reserveVolume + (reservedWeight / reserveDetail.getDensity());
		else
			reserveVolume := reserveVolume + (reservedWeight / reserveDetail.CM_ReserveTI.getTI().getDensity());
		endif;
	endforeach;
	return reserveVolume;
epilog

end;</source>
        <Parameter name="_myReserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getReservedVolumeForTI" id="c67049e4-4940-4c0b-9829-32a59808715a">
        <source>getReservedVolumeForTI(_trackedItem : CM_TrackedItem) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2025 navrv30 JIRA 33699 EUP| Reserved Qty and Details not showing up in COO and Cargo Review

*/

vars
	reserveDetail : CM_ReserveDetail;
	reservedWeight,
	reserveVolume : Decimal[14,4];
	isExactMatch : Boolean;
begin
	
	foreach reserveDetail in self.allReserveDetailAssigned do
		reserveDetail.doesTIMatchForRelease(_trackedItem, isExactMatch);
		if not isExactMatch then
			continue;
		endif;
		reservedWeight := reserveDetail.weightRequested;
		if reserveDetail.isKindOf(CM_ReserveSelection) then
			reserveVolume := reserveVolume + (reservedWeight / reserveDetail.getDensity());
		else
			reserveVolume := reserveVolume + (reservedWeight / reserveDetail.CM_ReserveTI.getTI().getDensity());
		endif;
	endforeach;
	return reserveVolume;
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getReservedWeight" id="8d46c7d1-10dd-47a5-83db-ac5f9b99193c">
        <source>getReservedWeight(_myReserveDetail : CM_ReserveDetail):Decimal;
