    <JadeMethod name="create" id="b7dbce88-a162-443f-9545-bf35de2b2978">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     22 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
