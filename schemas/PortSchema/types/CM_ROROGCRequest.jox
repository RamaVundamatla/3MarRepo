    <JadeMethod name="setForUpdateTI" id="b92cd203-4754-449c-9f42-15640a73ba26">
        <source>setForUpdateTI(_oldMoveType : Integer) protected;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	tmpTI		: CM_TrackedItem;
	tmpMoveType	: Integer;
	wle : CM_WorkListEntry;
	allTIs : CM_TIArray;
begin
	create allTIs transient;
	self.getAllTrackedItems(allTIs);

	foreach tmpTI in allTIs discreteLock do
		// we have to set the TI status if this IS a DLR or SOB back to DLR or SOB
		exclusiveLock(tmpTI);
		
		tmpMoveType := self.moveType;
	
		if self.isRehandle then
			// if DLR do not change the IMEX - Import Export Transit etc
			tmpTI.setTransitStatus(TI_TransitStatusDLR, true, app.myPassport);
		elseif self.isSoB then
			// if SOB do not change the IMEX - Import Export Transit etc
			tmpTI.setTransitStatus(TI_TransitStatusSOB, true, app.myPassport);
		elseif tmpMoveType = NULL_MOVETYPE then
			tmpTI.setTransitStatus(TI_TransitStatusNull, true, app.myPassport); // not DLR or SOB
	
			if _oldMoveType = DISCHARGE_MOVETYPE then
				if tmpTI.getImExStatus &lt;&gt; TI_IMEX_STATUS_TRANSHIP then		
					tmpTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
				endif;													
			elseif _oldMoveType = LOAD_MOVETYPE then
				if tmpTI.getImExStatus &lt;&gt; TI_IMEX_STATUS_TRANSHIP then		
					tmpTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
				endif;													
			else
				tmpTI.setImExStatus(TI_IMEX_STATUS_NULL);
			endif;
		endif;				
		
	endforeach;
	
	if self.myROROController &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(self.myROROController.myVoyage,app.myPassport.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),self.getFirstAllocation());
	endif;
epilog
	delete allTIs;
end;</source>
        <access>protected</access>
        <Parameter name="_oldMoveType" type="Integer"/>
    </JadeMethod>
</Class>
