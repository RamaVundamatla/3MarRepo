    <JadeMethod name="setupForm" id="9ec2eae5-8602-466a-be76-7c5708bd6491">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 27 mar 2018	jlgdap1	TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
// 27 Oct 2022  navrk21 Bug 55207: Rate Table - Toolbar buttons over Effective Date
vars
	aDate : Date;
begin

	self.useCtrlScroll := true;
	// 35872 get business unit from user if more than one
	//self.myAssistant.INV_Assistant.setCurrentBank();
	self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
	self.mode := self.Mode_Debtor;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.usesQueryFrame := true;
	self.mnuContextColourLegend.visible := false;
	self.mnuColumnOrganiser.visible := false;
	self.mnuInvUpdate.visible := true;
	self.mnuInvNew.visible := true;	// 24052
	self.mnuInvNew.caption := "&amp;New Rate...";
	self.addRegisteredKey(CMUI_Key_F8);	// 24052 F8 for New menu item
	self.mnuSendReportMain.visible := false;
	// 25348 temp until can save painted form ...
	self.btnServiceGroup.picture := self.btnServiceGroup.pictureDown;
	self.initServices();
	// This needs to be set before the inheritMethod because it is used in it to set mnuContextHide visibility.
	self.useTableInfo	:= true;		// July 2010 cnwjre1	24018 show macro info for rates
	self.doCmbBankBuild();
	
	inheritMethod();
	// Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
	self.mnuSendReportMain.visible := true;
	self.mnuSendReportAll.visible := true;
	self.mnuSendReportSelected.visible := true;
	self.mnuSendReportSeparator.visible := true;
	self.mnuSendReportSelected.visible := true;

	self.fldQuery.topSheet := self.shtQuery1;
	self.doComboTradeBuild();
	self.initServices();
	self.loadServices();
	
	aDate := self.systemToLocalTime(app.actualTimeServer).date();// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtDateDebtor.setDate(aDate);
	//self.txtDateTrade.setDate(aDate);					//07.06.2018 cnwma1 ChangeRequest #38953
	//self.txtDateVessel.setDate(aDate);				// TFS 37794
	//self.txtDateVesselType.setDate(aDate);		    //07.06.2018 cnwma1 ChangeRequest #38953
	//self.txtDateVisitType.setDate(aDate);			    //07.06.2018 cnwma1 ChangeRequest #38953
	//self.txtDateBerth.setDate(aDate);			   		//07.06.2018 cnwma1 ChangeRequest #38953
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_RATEENTRY_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_RATEENTRY_DELETE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_RATEENTRY_UPDATE), Response_Continuous, null);

	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_SERVICE_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_SERVICE_DELETE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_SERVICE_UPDATE), Response_Continuous, null);
	self.setEnableObjects(); // adm 040808 Par 17666
	
	// cnwrl1 PAR 19324 default the navigation entry now.
	self.setNavigatorHeading( self.caption );
	//07.06.2018 cnwma1 ChangeRequest #38953
	self.cmbBank.parent := self.frmQuery;
	self.lblBank.parent := self.frmQuery;
	self.lblDateDebtor.parent  := self.frmQuery;
	self.txtDateDebtor.parent  := self.frmQuery;
	
	self.lblBank.width := 80;
	self.cmbBank.width := 100;
	self.lblBank.left := 10;
	self.cmbBank.left :=100;
	self.lblBank.top := 45; // ### TFS 50421 17SEP2021 NAVAB1
	self.cmbBank.top := 45; // ### TFS 50421 17SEP2021 NAVAB1
	
	self.lblDateDebtor.width := 80;
	self.txtDateDebtor.width := 100;
	self.lblDateDebtor.left := 210;
	self.txtDateDebtor.left :=300;
	//self.lblDateDebtor.top := 30;	//27.10.2022 navrk21 TFS 55207
	//self.txtDateDebtor.top := 30;	//27.10.2022 navrk21 TFS 55207
	self.lblDateDebtor.top := 45;	//27.10.2022 navrk21 TFS 55207
	self.txtDateDebtor.top := 45;	//27.10.2022 navrk21 TFS 55207
end;</source>
    </JadeMethod>
    <JadeMethod name="showHistoryForm" id="e83ecee9-871d-4e62-b0b6-fae9c1c7a603">
        <updating/>
        <source>showHistoryForm(_asNew : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//				July 2010 24052 _asNew parameter added so can call the history form to show as 'New' in one click
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 27/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
	firstRun	: Boolean;
	irh			: INV_RateHistory;
	invalidForm : Boolean;
begin

	on Exception do app.handleDeletedObject(exception,  self.myRateHistoryForm,  invalidForm );  //cnwrd1 par #18133 13.10.08

	app.mousePointer := MP_HOURGLASS;
	if self.myRateHistoryForm = null then
		create irh;
		self.myRateHistoryForm := irh;
		irh.myRateTableForm := self;
		firstRun := true;
	else
		irh := self.myRateHistoryForm;
		irh.myCurrentDebtor := self.myCurrentDebtor; //cnwrd1 par #18133 13.10.08
	endif;
	
	if invalidForm then //cnwrd1 par #18133 13.10.08
		create irh;
		self.myRateHistoryForm := irh;
		irh.myRateTableForm := self;
		firstRun := true;	
	endif;
	
	irh.myCurrentBank := self.myCurrentBank;	// 35872 pass the bank as well
	irh.myCurrentDebtor := self.myCurrentDebtor;
	irh.myCurrentLineGroupDebtor := self.myCurrentLineGroupDebtor;
	irh.myCurrentService := self.myCurrentService;
	irh.myCurrentVessel := self.myCurrentVessel;				// TFS 37794
	irh.myCurrentVesselType := self.myCurrentVesselType; 		//07.06.2018 cnwma1 ChangeRequest #38953
	irh.myCurrentVisitType := self.myCurrentVisitType; 			//07.06.2018 cnwma1 ChangeRequest #38953
	irh.myCurrentBerth := self.myCurrentBerth; 					//07.06.2018 cnwma1 ChangeRequest #38953
	irh.myTerminal := self.myTerminal;
	irh.showNew := _asNew;			// 24052
	irh.effectiveDate := self.effectiveDate;	// 24052
	irh.lastEnteredDate := self.lastEnteredDate;	// 24052
	irh.createMyAssistant(INV_Assistant);
	if not firstRun and 
	   not _asNew then
		irh.doQuery();
	endif;
	irh.show;

epilog
	app.mousePointer := MP_DEFAULT;

end;</source>
        <Parameter name="_asNew" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_rowColumnChg" id="5c2c8a03-d071-47c0-8260-a8656c0acc8d">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_rowColumnChg(table: Table input) updating;

vars

begin
	inheritMethod(table);
	self.displayCell();
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1a47e35f-6831-4823-b986-3835e3d44d4f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 June 2018 08:57:47.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006214, locale);
	btnExtractCSV.translateBubbleHelp(Xlat_0002234, locale);
	btnExtractCSV.translateCaption(Xlat_0002239, locale);
	btnLoadCSV.translateBubbleHelp(Xlat_0009604, locale);
	btnLoadCSV.translateCaption(Xlat_0009605, locale);
	btnQueryDebtor.translateBubbleHelp(Xlat_0002235, locale);
	btnQueryDebtor.translateCaption(Xlat_0002240, locale);
	btnQueryShip.translateBubbleHelp(Xlat_0002236, locale);
	btnQueryShip.translateCaption(Xlat_0002241, locale);
	btnQueryToday.translateBubbleHelp(Xlat_0002237, locale);
	btnQueryToday.translateCaption(Xlat_0002242, locale);
	btnRefresh.translateBubbleHelp(Xlat_0002238, locale);
	btnRefresh.translateCaption(Xlat_0002243, locale);
	btnServiceGroup.translateBubbleHelp(Xlat_0015145, locale);
	btnServiceGroup.translateCaption(Xlat_0015146, locale);
	lblBank.translateCaption(Xlat_0020699, locale);
	lblDateDebtor.translateCaption(Xlat_0015147, locale);
	lblShippingLine.translateCaption(Xlat_0015149, locale);
	msgbBerthServ.translateCaption(Xlat_0022602, locale);
	msgbDebtors.translateCaption(Xlat_0015150, locale);
	msgbServices.translateCaption(Xlat_0015151, locale);
	msgbVessServ.translateCaption(Xlat_0022315, locale);
	msgbVessTypeServ.translateCaption(Xlat_0022603, locale);
	msgbVesselTypes.translateCaption(Xlat_0022604, locale);
	msgbVessels.translateCaption(Xlat_0022316, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="d7d404da-d804-4536-9929-0f6511f5cae3">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20 Feb 2018	jlgmd1		TFS 36954 SNO - Error in SCT2 Rate Table (Swap $CM_RateEntry.decimalPlaces for terminal config)
// 27 Mar 2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
	finObj : Object;
	theService : CM_Service;
	theRateEntry : CM_RateEntry;
	theDataLine : String;
	idx, theRow, theColumn : Integer;
	theQDate : Date;
	savedChargedEffTS : TimeStamp;
	dpl : Integer;
	symbol : Character;
begin

	// TFS 36954 MPD 20 Feb 2018
	dpl := self.getRateEntryDecimalPlaces;
	symbol := app.myRoot.getInvoiceCurrencySymbol.Character;

	//19 Sep 2012	NDL	Par 30375
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );

	if _event = EVENT_RATEENTRY_DELETE then
		self.doUpdateFromDelete(_obj); // PAR 18489
		return;
	endif;

	if _obj &lt;&gt; null 
	and (_event = EVENT_RATEENTRY_UPDATE or _event = EVENT_RATEENTRY_CREATE ) then
		
		/*//07.06.2018 cnwma1 ChangeRequest #38953
		if mode = self.Mode_Debtor then
			theQDate := self.txtDateDebtor.getDate();
		elseif self.mode = self.Mode_Vessel then			// TFS 37794
			theQDate := self.txtDateVessel.getDate();		// TFS 37794
		elseif self.mode = self.Mode_VesselType then			//07.06.2018 cnwma1 ChangeRequest #38953
			theQDate := self.txtDateVesselType.getDate();		//07.06.2018 cnwma1 ChangeRequest #38953
		elseif self.mode = self.Mode_VisitType then				//07.06.2018 cnwma1 ChangeRequest #38953
			theQDate := self.txtDateVisitType.getDate();		//07.06.2018 cnwma1 ChangeRequest #38953
		elseif self.mode = self.Mode_Berth then					//07.06.2018 cnwma1 ChangeRequest #38953
			theQDate := self.txtDateBerth.getDate();			//07.06.2018 cnwma1 ChangeRequest #38953
		else
			theQDate := self.txtDateTrade.getDate();
		endif;
		*/
		theQDate := self.txtDateDebtor.getDate(); 				//07.06.2018 cnwma1 ChangeRequest #38953
		theRateEntry := _obj.CM_RateEntry;
		// ### we query by date so if a new rate is entered for the future we might not want to show it.
		if theRateEntry.startTimestamp.date &gt; theQDate then
			return;
		endif;
		
		theService := theRateEntry.rate.service;
		self.tblData.findObjectInRow(theService,theRow);
		finObj := theRateEntry.rate.getObject();
		self.tblData.findObjectInColumn(finObj,theColumn);

		if theRow &gt; 0 and theColumn &gt; 0 then
			//self.tblData.accessCell(theRow,theColumn).text := theRateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp).userCurrencyFormat($CM_RateMoney);
			self.tblData.accessCell(theRow,theColumn).text := symbol &amp; theRateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp).asStringJMTWithPrecision(dpl, false);	// TFS 36954 MPD 20 Feb 2018
			self.tblData.accessedCell.fontBold := true;
			self.tblData.accessedCell.itemObject := theRateEntry; // PAR 18489
			// 24018 refresh macro info after edit
			self.displayExtraInfo();
		endif;
	elseif _event = EVENT_SERVICE_CREATE 
	or _event = EVENT_SERVICE_UPDATE 
	or _event = EVENT_SERVICE_DELETE then
		
		// PAR 31657
		if self.allSelectedServices.includes(_obj) then
			self.allSelectedServices.remove(_obj);
			self.setServicesAvailable();
		endif;
		self.loadServices();
	
		if self.mode = self.Mode_Debtor then
			if self.myCurrentDebtor &lt;&gt; null then
				self.internalQuery := true;
				self.doQuery();
			endif;
		else
			if self.myCurrentTrade &lt;&gt; null then
				self.internalQuery := true;
				self.doQuery();
			endif;
		endif;
	endif;
epilog
	app.setChargeRateEffectiveDate( savedChargedEffTS );	//19 Sep 2012	NDL	Par 30375
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="xHandlerFile" id="b013af46-2845-467e-b45d-d2ed7e94756d">
        <source>xHandlerFile(_exceptionObj:FileException):Integer protected;
// --------------------------------------------------------------------------------
// Created:		12 December 2008 by cnwdad1
//
// Purpose:		General file exception handler to report any errors and abort the
//				current action.
//
// Parameters:	_exceptionObj - A reference to the file exception object.
//
// Returns:		The abort action code.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMsg	: String;
	
begin
	errorMsg	:=	process.getErrorText(_exceptionObj.errorCode) &amp; ".";
	
	app.msgBox(errorMsg, app.getString(Error), MsgBox_Information_Icon + MsgBox_OK_Only);
	
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="FileException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
