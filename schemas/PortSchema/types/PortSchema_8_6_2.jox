    <JadeMethod name="defaultIdleTimeSettings" id="6f61bba6-4077-4615-bbda-ce1973021bff">
        <source>defaultIdleTimeSettings(_controller : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/09/2020	jlgdap1		Initial creation TFS 49316 MTN Machine Idle Time
//
vars
	terminal : CM_Terminal;

begin
