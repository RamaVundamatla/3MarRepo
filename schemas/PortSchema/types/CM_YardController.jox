    <JadeMethod name="getFullIdForTI" id="b7741662-d44e-409e-9cad-e89da053cbb5">
        <source>getFullIdForTI(_isTarget : Boolean) : String;
//Basically, same as getFullId, but also returns the height of a possible drop.
vars
	numInTarget	:	Integer;
	aStr	:	String;
begin

	aStr := inheritMethod(_isTarget);
	
	//epr par 26947 14/2/2011
	if self.myTerminalArea &lt;&gt; null and not
		self.myTerminalArea.isHeightRequiredForLabel then
		return aStr;
	endif;
	numInTarget := self.numTIs;
	if _isTarget then
		numInTarget := numInTarget + 1;
	endif;
	return aStr &amp; ' ' &amp; numInTarget.String;
end;</source>
        <Parameter name="_isTarget" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
