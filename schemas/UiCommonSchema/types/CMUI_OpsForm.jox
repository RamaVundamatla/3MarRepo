    <JadeMethod name="doMove_ForMode" id="c64ccb1f-9239-428f-9547-377e389d22c1">
        <updating/>
        <source>doMove_ForMode(_moveMode : Integer; _all : Boolean) updating;
//-----------------------------------------
// Created: May 2003 By: cnwgd1
//-----------------------------------------
//15/08/2019 	JLGNS1	ChangeRequest 45889: PEN - Move All Command in Road Operation
vars
	wleArray,
	wlesWithWarnings : CM_WLEArray;	
	result	: Integer;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create wleArray transient;
	
	if _all then
		
		if _moveMode = REAL_MODE then																																//ChangeRequest 45889
			if 	app.msgBox(app.getErrorString(Sure_want_move)  ,app.getErrorString(WLES_MOVE_ALL),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then//ChangeRequest 45889
				return;																																				//ChangeRequest 45889
			endif;																																					//ChangeRequest 45889
		endif;																																						//ChangeRequest 45889

		
		self.getAllWLEsInTable(wleArray);
	else
		self.getAllWLEsInTableSelected(wleArray);	
	endif;
	
	create wlesWithWarnings transient;

	while true do
		app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, _moveMode, false,null, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				//do show it here, ask Q below.
				result := 1;				
			else
				result := app.showErrorWarningDialog('Operations Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			endif;
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

	if app.myPassport.returnCode = INFO_NO_AUTOPLAN then
		if app.msgBox(app.getErrorString(app.myPassport.returnCode), "Information",
					 MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
		
epilog
	delete wlesWithWarnings;
	delete wleArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMove_Instant" id="d58f1208-c4da-410d-9a63-32c5b8d6da8d">
        <updating/>
        <source>doMove_Instant() updating;
//-----------------------------------------
//Created: November 2003 By: cnwgd1
//-----------------------------------------
vars
	wle : CM_WorkListEntry;
	wleArray,
	wlesWithWarnings : CM_WLEArray;	
	result	: Integer;
	effectiveTimeStamp : TimeStamp;	//25 Feb 2021	NDL	TFS 50837
	control : CMIF_WagonMoveController;	//25 Feb 2021	NDL	TFS 50837
begin
	if self.myCurrentWLE = null then
		app.msgBox(app.getErrorString(SelectItemToMove),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;	
	endif;
	app.mousePointer := MousePointer_HourGlass;
	wle := self.myCurrentWLE;
	create wleArray transient;
	wleArray.add(wle);

	create wlesWithWarnings transient;
	
	//25 Feb 2021	NDL	TFS 50837
	effectiveTimeStamp := null;
	create control transient;
	control.setEffectiveTimeStampOverride( null );
	if self.validateRetrospectiveTS( control ) then
		if control.effectiveTimeStamp.isValid then
			effectiveTimeStamp := control.effectiveTimeStamp;
		endif;
	endif;
		
	while true do
		app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, REAL_MODE, false, effectiveTimeStamp, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 
			and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				// don't show it here, ask Q below.
				result := 1;				
			else
				result := app.showErrorWarningDialog('Operations Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			endif;
			if app.myPassport.noErrors
			and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

	if app.myPassport.returnCode = INFO_NO_AUTOPLAN then
		if app.msgBox(app.getErrorString(app.myPassport.returnCode), "Information",
					 MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;

epilog
	delete wlesWithWarnings;
	delete wleArray;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMove_Unplan" id="6909d5a3-c254-43b9-b948-df63d9a9759c">
        <updating/>
