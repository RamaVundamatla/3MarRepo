    <JadeMethod name="addObjectsToTable" id="b0058c1a-c163-420f-91ae-f49366de54ca">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	bank		: CM_Bank;
	aInvoiceLineDesc : CM_InvoiceLineDesc;
	theInvoiceLineDescs :	CM_InvoiceLineDescByNarrDict;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
begin

	self.setMyDataClass();
	// 35872 do change of business unit
	bank := self.cmbBank.listObject.CM_Bank;
	if bank = null then
		return;
	endif;
	//epr TFS 2903 17/1/17
	self.setMyCurrentBank(bank);
	
	self.setCaption("Invoice Line Types " &amp; self.myCurrentBank.code); // 	TFS 2682
	theInvoiceLineDescs := self.myCurrentBank.invoiceLineDescriptors;
	tmpPassport := app.myPassport;
	
	// do need to show all line types to maintain the 'not available for entry' option
	foreach aInvoiceLineDesc in theInvoiceLineDescs do
		if self.includeObject(aInvoiceLineDesc, tmpPassport) then
			self.addObjectToTable(aInvoiceLineDesc, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="74f4688b-7e72-4201-8245-dd19f4fefc4f">
        <source>addToolbarControls() protected;
/*

Purpose:			Adds toolbar controls to the form

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912
06 September 2022	navpw1	TFS: 54564 (54379) - EUP - Inv Config - Debtor Currencies and Countries

*/

vars
	toolbar			: CMUI_Toolbar;
	
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnInvLineTranslations, CMUI_Toolbar.Control_Alignment_Left); // ### TFS 54564 (54379) 31Aug2022 NAVPW1
	toolbar.addButton(self.btnImportCSVTran, CMUI_Toolbar.Control_Alignment_Left); 		 // ### TFS 54564 (54379) 31Aug2022 NAVPW1
	toolbar.addButton(self.btnExportCSVTran, CMUI_Toolbar.Control_Alignment_Left); 		 // ### TFS 54564 (54379) 31Aug2022 NAVPW1
/*	//05/06/2024	navkc1 CR 63736 Task 63770 - Replaced with new control
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);
	
	self.txtFilterBox.parent := self.frmFilter;
	self.txtFilterBox.visible := true;
	self.txtFilterBox.left := 0;
	self.txtFilterBox.top := 2;

	toolbar.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);
*/	

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);				//05/06/2024	navkc1 CR 63736 Task 63770
	toolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);	//05/06/2024	navkc1 CR 63736 Task 63770
end;</source>
        <access>protected</access>
    </JadeMethod>
