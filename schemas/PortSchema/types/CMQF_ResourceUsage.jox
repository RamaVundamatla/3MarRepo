    <JadeMethod name="filterObjects" id="cdd12f0d-563d-45d6-84d4-b9f613f289dd">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2010	cnwndl1	Initial creation	CCMS MES 1006
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars

	startTS : TimeStamp;
	endTS : TimeStamp;
	terminal : CM_Terminal;
	iter : Iterator;
	trans : CM_TITransaction;
	breakOut : Boolean;
	resourceUsage : CM_ResourceTypeUsage;
	
	tiSet : CM_TISet;
	tiIter : Iterator;
	ti : CM_TrackedItem;
	
	theBookingRef : CM_BookingRef;

begin

	if self.getMyVoyage = null and self.cargoId = null and self.bookingRef = null and self.allToDoTaskDescs.isEmpty then
		if not self.startDate.isValid then
		// 	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Start_date), 'startDate', null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Start_date), 'startDate', null); // cnwdb2	PAR 35364
			return;
		endif;
		if not self.endDate.isValid then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(EndDate), 'endDate', null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(EndDate), 'endDate', null); // cnwdb2	PAR 35364
			return;
		endif;
	endif;

	startTS.setDate(self.startDate);
	startTS.setTime('00:00:00:000'.Time);
	endTS.setDate(self.endDate);
	endTS.setTime('23:59:59:999'.Time);
	
	foreach terminal in self.allTerminals do
		delete iter;
		
		if self.cargoId &lt;&gt; null then
			// get the initial set of trx based on a cargo id
			
			create tiSet transient;
			terminal.lookupAllTIsOfIdCargoType(	self.cargoId,
												null,
												tiSet, false, false,
												null);
			if tiSet.isEmpty then
				return;
			endif;
			tiIter := tiSet.createIterator;
			while tiIter.next( ti ) do
				iter := ti.allTransactions.createIterator;
				while iter.next( trans ) do
					if trans.allResourceUsages.isEmpty then
						continue;
					endif;
					foreach resourceUsage in trans.allResourceUsages do
						if self.checkStatusIncludesObject(resourceUsage, _passport, breakOut) then
							_collection.add( resourceUsage );
						endif;
						if breakOut then
							break;
						endif;
					endforeach;
				endwhile;
				delete iter;
			endwhile;
			delete tiIter;
			delete tiSet;
			
			continue;
		
		elseif self.bookingRef &lt;&gt; null then
			// get the initial set of trx based on a booking ref
			
			theBookingRef := terminal.getBookingReference(null, self.bookingRef, null);
			if theBookingRef = null or theBookingRef.allTIs.isEmpty then
				return;
			endif;
			tiIter := theBookingRef.allTIs.createIterator;
			while tiIter.next( ti ) do
				iter := ti.allTransactions.createIterator;
				while iter.next( trans ) do
					if trans.allResourceUsages.isEmpty then
						continue;
					endif;
					foreach resourceUsage in trans.allResourceUsages do
						if self.checkStatusIncludesObject(resourceUsage, _passport, breakOut) then
							_collection.add( resourceUsage );
						endif;
						if breakOut then
							break;
						endif;
					endforeach;
				endwhile;
				delete iter;
			endwhile;
			delete tiIter;
			
			continue;
			
		elseif self.getMyVoyage &lt;&gt; null then
			// get the initial set of trx based on a voyage
			
			tiIter := self.getMyVoyage.allOnshipTIsByCargoTypeId.createIterator;
			while tiIter.next( ti ) do
				iter := ti.allTransactions.createIterator;
				while iter.next( trans ) do
					if trans.allResourceUsages.isEmpty then
						continue;
					endif;
					foreach resourceUsage in trans.allResourceUsages do
						if self.checkStatusIncludesObject(resourceUsage, _passport, breakOut) then
							_collection.add( resourceUsage );
						endif;
						if breakOut then
							break;
						endif;
					endforeach;
				endwhile;
				delete iter;
			endwhile;
			delete tiIter;
			
			tiIter := self.getMyVoyage.allOnsiteTIsByIdCargoType.createIterator;
			while tiIter.next( ti ) do
				iter := ti.allTransactions.createIterator;
				while iter.next( trans ) do
					if trans.allResourceUsages.isEmpty then
						continue;
					endif;
					foreach resourceUsage in trans.allResourceUsages do
						if self.checkStatusIncludesObject(resourceUsage, _passport, breakOut) then
							_collection.add( resourceUsage );
						endif;
						if breakOut then
							break;
						endif;
					endforeach;
				endwhile;
				delete iter;
			endwhile;
			delete tiIter;
			
			continue;
			
		else
		
			// get the initial set of trx based on a cargo id
			iter := terminal.allTITransactions.createIterator;
			terminal.allTITransactions.startKeyGeq(startTS, 0, iter);
			while iter.next( trans ) do
				if trans.dateTime &gt; endTS then
					break;
				endif;
				if trans.allResourceUsages.isEmpty then
					continue;
				endif;
				foreach resourceUsage in trans.allResourceUsages do
					if self.checkStatusIncludesObject(resourceUsage, _passport, breakOut) then
						_collection.add( resourceUsage );
					endif;
					if breakOut then
						break;
					endif;
				endforeach;
			endwhile;
		
		endif;
		
	endforeach;
	
epilog

	delete iter;
	delete tiSet;
	delete tiIter;
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="f29cca8c-5585-4db0-8765-54fe33f2b6ba">
        <source>getMyVoyage():CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	voyage : CM_Voyage;
	edition : Integer;
	invalidObj : Boolean;

begin

	voyage := self.myVoyage;

	if voyage = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, voyage, invalidObj );
	edition := voyage.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return voyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="cf20f46e-a688-44dd-85bd-afcc54523030">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2017	cnwrh7	Initial creation

*/

vars
	strToDoTaskDesc	: String;
	todotaskDescArray : CM_ToDoTaskDescSet;
	toDoTaskDesc : CM_ToDoTaskDesc;
begin
	
	if _attrName = ETRow_Id then								//+TFS3515
		return self.cargoId;
	elseif _attrName = ETRow_BookingReference then
		return self.bookingRef;
	elseif _attrName = ETRow_Tasks then
		if not self.allToDoTaskDescs.isEmpty then
			create todotaskDescArray transient;
			self.getSelectedToDoTaskDescs(todotaskDescArray);
			foreach toDoTaskDesc in todotaskDescArray discreteLock do 
				if  strToDoTaskDesc = null then 
					strToDoTaskDesc := toDoTaskDesc.description;
				else
					strToDoTaskDesc :=  strToDoTaskDesc &amp; ", " &amp; toDoTaskDesc.description;
				endif;
			endforeach;
			return strToDoTaskDesc;
		else
			return null;
		endif;
	endif;
	return inheritMethod(_attrName, _getCalculatedDate, _oid);	
epilog
	delete todotaskDescArray;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedToDoTaskDescs" id="dd1ade8d-7003-4c4a-b603-56603d65e2c7">
        <source>getSelectedToDoTaskDescs( _todotaskDescArray : CM_ToDoTaskDescSet input )  ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
// 03/03/2017 cnwrh7         TFS3515       #TEMPLATE FOR TASK "TRASPORTI" NOT RUN CORRECTLY

*/

vars
	obj : Object;
begin
	if _todotaskDescArray = null then
		app.raiseCMException2( MethodWithNullParam, method.name, '_todotaskDescArray', null, null );
		return;
	endif;
	_todotaskDescArray.clear();
	
	foreach obj in self.allToDoTaskDescs do 
		if not obj.isKindOf( CM_ToDoTaskDesc ) then
			continue;
		endif;
		_todotaskDescArray.add( obj.CM_ToDoTaskDesc );
	endforeach;

epilog

end;</source>
        <Parameter name="_todotaskDescArray" type="CM_ToDoTaskDescSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="e94bb7c3-cf1c-4858-826e-e21d850465b8">
        <updating/>
        <source>includesObject(_resourceUsage: CM_ResourceTypeUsage; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	querySelf : CMQF_ResourceUsage;	
	retValue : Boolean;
	task : CM_ToDoTaskDesc;
		
begin

	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if not CM_ResourceTypeUsage.hasInstance(_resourceUsage) then
		return false;
	endif;
	
//	19 Oct 2010	NDL	Par 23800 / CCMS MES 1087	
	if (self.getMyVoyage &lt;&gt; null and (self.getMyVoyage.code &lt;&gt; _resourceUsage.getMyVoyageCode)) then
		return false;
	endif;
	if (self.cargoId &lt;&gt; null and (self.cargoId &lt;&gt; _resourceUsage.getCargoId)) then
		return false;
	endif;
	if (self.bookingRef &lt;&gt; null and (self.bookingRef &lt;&gt; _resourceUsage.getBookingRef)) then
		return false;
	endif;
	if not self.allToDoTaskDescs.isEmpty then
		task := _resourceUsage.getMyTaskDesc;
		if task = null or ( not self.allToDoTaskDescs.includes( task ) ) then
			return false;
		endif;
	endif;
	
	querySelf.numFound := querySelf.numFound + 1;
	return true;

epilog

end;

</source>
        <access>protected</access>
        <Parameter name="_resourceUsage" type="CM_ResourceTypeUsage"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="52179c8d-6c7f-4d3f-9420-daf216997e81">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
/*

Date		Who		Reason
10 September 2014	cnwer1	Initial creation PAR 34813

*/

vars
	eventData : CM_EventDataVoyage;
begin
	inheritMethod(_obj, _runDate, _allEventData);

	// This code sets the voyage for event driven schedules.
	// Have to do this for each appropriate class because they have different myVoyage references.
	eventData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventData &lt;&gt; null and eventData.myVoyage &lt;&gt; null then
		self.setMyVoyage( eventData.myVoyage );
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyage" id="ec805930-0cbd-40cf-b1de-719c93d6e01c">
        <updating/>
        <source>setMyVoyage( _voyage : CM_Voyage ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

begin

	self.myVoyage := _voyage;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
</Class>
