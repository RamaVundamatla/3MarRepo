    <JadeMethod name="getLocationTA" id="bcbc1716-dba6-4c19-a143-1842642214a4">
        <source>getLocationTA() : CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2017	jlgndl1	Initial creation	TFS 5744

*/

vars
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
begin
	self.myTerminal.findLocationFromString(self.location, true, tmpFoundLC, tmpFoundHeight);
	if tmpFoundLC &lt;&gt; null then
		return tmpFoundLC.myTerminalArea;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getOtherTrackedItem" id="ba590b0a-b49f-441a-90f1-7a73ce3b618f">
        <source>getOtherTrackedItem(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation	TFS 5744

*/

vars
	invalidTI		: Boolean;
	id				: String;
	othTrackedItem	: CM_TrackedItem;
begin
	othTrackedItem := self.otherTrackedItem;
	if othTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, othTrackedItem, invalidTI);
		// Dereference TI to check it is valid
		id := othTrackedItem.id;
	endif;
	
	if invalidTI then
		return null;
	endif;

	return othTrackedItem;
	
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getPackagedAmount" id="32ccf095-0601-4afb-a965-8a5fb87410d5">
        <source>getPackagedAmount() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation	TFS 5744

*/

vars
ct : CM_CargoType;
	product : CM_Product;
	ti	: CM_TrackedItem;
	density  	: Decimal[14,4];
	invalidObj : Boolean;
	totWeight : Decimal [14,4];
	totQty : Integer;
	invalidTrx : Boolean;
	otherPackagedTrx : CM_Packaged;
	amount : String;
	unit : String;
begin
	
	on Exception do app.handleDeletedObject( exception, self.otherTrackedItem, invalidObj );
	on Exception do app.handleDeletedObject( exception, otherPackagedTrx, invalidTrx );
	
	if self.action = ACTION_PACKAGE_PARENT then
		otherPackagedTrx := self.myChildPackaged;
		if self.otherTrackedItem &lt;&gt; null then
			ct := self.otherTrackedItem.myCargoType;
			if not invalidObj then
				density := self.otherTrackedItem.getDensity;
			endif;
			if otherPackagedTrx &lt;&gt; null then
				totWeight := otherPackagedTrx.totalWeight;
				totQty := otherPackagedTrx.totalQuantity;
			endif;
		endif;
	
	else
		otherPackagedTrx := self.myParentPackaged;
		ct := self.myTrackedItem.myCargoType;
		density:=self.myTrackedItem.getDensity;	
		totWeight := self.totalWeight;
		totQty := self.totalQuantity;
	endif;
	
	if ct &lt;&gt; null then
		if ct.isBreakBulkMulti then
			if totQty &gt; 1 then
				return totQty.asStringJMT;
				
			elseif totWeight &gt; 0 then
				if ct.myWeightMeasurementType &lt;&gt; null then
					unit := ct.myWeightMeasurementType.shortName;		
					amount := app.convertMeasurementForDisplay(unit, totWeight);
					if amount &lt;&gt; null then
						return amount &amp; Space &amp; unit;
					endif;
				endif;	
				
			endif;
			
		elseif ct.isBulkMulti then		
			return ct.getBulkTrackByDisplayForWeight( totWeight, density, true );
			
		endif;
	
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
