    <JadeMethod name="asDecimalJMT" id="b8d3ad66-da0b-460a-8408-4d4cbddde469">
        <source>asDecimalJMT() : Decimal;
// ---------------------------------------------------------------------------
// Created:     07 August 2007 by cnwrs2
//
// Purpose:     
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/08/2010	cnwdad1		PAR #20064.
// --------------------------------------------------------------------------------
constants
	JMTDecimalSeperator = ".";
vars
	decimalSeperator,
	thousandSeparator,
	tmpStr	: String;
	
begin
// cnwdad1 31/08/2010 - PAR #20064.
//	thousandSeparator := app.currentLocaleInfo.numericInfo.thousandSeparator;
//	decimalSeperator := app.currentLocaleInfo.numericInfo.decimalSeparator;
	thousandSeparator	:=	app.getMyLocaleInfoJMT().numericInfo.thousandSeparator;
	decimalSeperator	:=	app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	
	tmpStr := self;
	tmpStr.replaceChar(thousandSeparator.Character, " ");
	tmpStr := tmpStr.cnEcRemoveSubstring(" ");
	tmpStr.replaceChar(decimalSeperator.Character, JMTDecimalSeperator);
	 
	return tmpStr.Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="asDoubleQuotedString" id="ad5236ce-6d0b-4f6a-8be4-c7af2391ec2e">
        <source>asDoubleQuotedString() : String;
// ---------------------------------------------------------------------------
// Created:     13 May 2004 by cnwrs2
//
// Purpose:     Replace double quotes (") in string with ("") and
//				add double quote at front / back
// ---------------------------------------------------------------------------
vars

begin
	if self = null then
		return null;
	endif;
	return '"' &amp; self.replaceString('"', '""') &amp; '"';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asEDIReal" id="16d51e92-891e-4f7c-9625-b8b99831458d">
