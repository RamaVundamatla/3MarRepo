    <JadeMethod name="jhpClearRoadJobs" id="a1a66384-a9e2-439f-9a5f-b3918afbc230">
        <source>jhpClearRoadJobs();

vars
	rj:CM_RoadJob;
	gio:GateInOut2;
begin
	CM_RoadJob.instances.inspectModal;
	create gio;
	foreach rj in CM_RoadJob.instances do
		gio.zClearRoadJob(rj);
	endforeach;
epilog
	delete gio;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jhpDeleteOnsiteForNullVoyage" id="ba287c2b-88b2-406d-b4f2-ade94b6e3e76">
        <source>jhpDeleteOnsiteForNullVoyage();

vars
	lc			: CM_LocationsController;
	ta			: CM_TerminalArea;
	ti			: CM_TrackedItem;
begin
	app.initialize();
	//app.myPassport.setMyTerminal(app.myRoot.allTerminals['JBL']);
	app.myPassport.setMyUser(app.myRoot.allUsers['SUPERUSER']);
	ta := app.getMyTerminal.allTerminalAreasByTypeId[TA_TYPE_RTG, 'B'];
	app.isGarbageCollectionProcess := true;
	
	foreach lc in ta.allLocationsControllers do
		
		foreach ti in lc.allTrackedItemsById do
			if ti.myVoyage = app.myPassport.myTerminal.getNullVoyage() then
				beginTransaction;
				ti.erase(NORMAL_ERASE);
				commitTransaction;
			endif;
		endforeach;
	endforeach;
	
	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="jhpDeleteVoyage" id="f29f99f4-e743-44f3-be4f-22ad8cc8ffc4">
        <source>jhpDeleteVoyage();

vars
	i,j:Integer; s,t:String;
	tran:Ship; voyage:CM_Voyage;
begin
	app.initialize;

//	show remaining voyage instead of deleting one

	foreach voyage in app.getMyTerminal.allVoyagesByCode
	where   voyage.String.jtdContains(CM_Voyage.name) and voyage.code[1:3] = 'PTN' do
		write voyage.code&amp;" "&amp;voyage.allJobSheets.size.String;
	endforeach;
	return; /* */

	create tran;
	foreach voyage in app.getMyTerminal.allVoyagesByCode where voyage.code &gt;= 'PTN0001' and voyage.code &lt;= 'PTN0006' do
		tran.myVoyage := voyage;
		tran.zCleanUpShip;  // delete the voyage
//		break;
	endforeach;
	
epilog
	app.finalize;
	delete tran;
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpPfm" id="1093d667-001d-4317-bfc0-9e277fbcd4e3">
        <updating/>
        <source>jhpPfm() updating;
vars
	oldWay:Boolean;
	dts,dte,dt3:Decimal[19];
	s,t,u,v,tempString1:String;  i,j,k,l,base,reps,mag:Integer;
	gh:JmtGenerationHelper;  roi:RoadOpsInquiry;
begin
	write CrLf&amp;"Starting...";
	reps:=10000;
	app.initialize;
	create gh;
	create roi;

//	oldWay:=true;
	dts:=app.relativeMachineTime;
	foreach i in 1 to reps do
		if oldWay then
//			gh.repeatable:=true;  s:=gh.repeatable.String;
			roi.doNothing;
			roi.doNothing;
			roi.doNothing;
			roi.doNothing;
			roi.doNothing;
			roi.doNothing;
			roi.doNothing;
			roi.doNothing;
			roi.doNothing;
			roi.doNothing; /* */
		else
//			gh.setPropertyValue("repeatable",true);  s:=gh.getPropertyValue("repeatable").String;
			roi.sendMsg("doNothing");
			roi.sendMsg("doNothing");
			roi.sendMsg("doNothing");
			roi.sendMsg("doNothing");
			roi.sendMsg("doNothing");
			roi.sendMsg("doNothing");
			roi.sendMsg("doNothing");
			roi.sendMsg("doNothing");
			roi.sendMsg("doNothing");
			roi.sendMsg("doNothing"); /* */
		endif;
	endforeach;
	dte:=app.relativeMachineTime;
	write "&lt;"&amp;s&amp;"&gt;"&amp;"&lt;"&amp;t&amp;"&gt;";
	write ((dte-dts)/reps).roundedTo(3).String&amp;" ms/rep";

/*
			s:=t; s:=s&amp;u; s:=s&amp;v; s:=s&amp;w; s:=s&amp;x;
			s:=t&amp;u&amp;v&amp;w&amp;x;
	d2:=12345.60;
			d:=d2 mod 100;
			d:=d2 mod 100;
			d:=d2 mod 100;
			d:=d2 mod 10^2;
			d:=d2 mod 10^2;
			d:=d2 mod 10^2;
	r:R_Dhout;
	create r transient;
	r.a_diexm_thsbrnchno:=1234;
	r.a_diexm_thsaccntno:=12345678;
			tempString1:=r.sd_hash.pad(11,0);
			glb.complexMove(r.a_diexm_thsbrnchno.pad(4), 1, 4, 4, tempString1, 1, 11);
			r.sd_hash:=tempString1.Decimal;
			tempString1:=r.sd_hash.pad(11,0);
			glb.complexMove(r.a_diexm_thsaccntno.pad(8), 2, 7, 8, tempString1, 5, 11);
			r.sd_hash:=tempString1.Decimal;
			r.sd_hash:=r.a_diexm_thsbrnchno*10000000.0+r.a_diexm_thsaccntno mod 10000000;  // jhp 010215 pfm
	write r.sd_hash;
//			glb.setDcDate(s, 0, "CCYYMMDD", null, false);
//			k := glb.dc_daynum;
			glb.setDcDate(k.String, 0, "DAYNUM", null, false);
			s := glb.dc_yymmdd.pad(6);

//			dd.setDate(s[7:2].Integer,s[5:2].Integer,s[1:4].Integer);
//			k:=dd-glb.baseDate;
			dd:=glb.baseDate+k;
			s:=dd.format("yyMMdd");

			glb.gd_cdvstr:="123456789012345678";
			s:=glb.gd_cdvstr;
	write "&lt;"&amp;glb.gd_dgt1.String&amp;glb.gd_dgt2.String&amp;glb.gd_dgt3.String&amp;glb.gd_dgt4.String&amp;glb.gd_dgt5.String&amp;glb.gd_dgt6
	.String&amp;glb.gd_dgt7.String&amp;glb.gd_dgt8.String&amp;glb.gd_dgt9.String&amp;glb.gd_dgt10.String&amp;glb.gd_dgt11.String&amp;glb.gd_dgt12
	.String&amp;glb.gd_dgt13.String&amp;glb.gd_dgt14.String&amp;glb.gd_dgt15.String&amp;glb.gd_dgt16.String&amp;glb.gd_dgt17.String&amp;glb.gd_dgt18.String&amp;"&gt;&lt;&gt;";
	write glb.gd_four;
	write glb.gd_eight;


	ASBLincScreen.profStart and profReport:

	process.profilerStart;
	process.profilerReport(process.persistentApp.name
							&amp;"_"&amp;app.activeForm.name[3:end]
							&amp;"_"&amp;app.actualTimeAppServer.date.format("yyMMdd")
							&amp;"_"&amp;app.actualTimeAppServer.time.format("HHmmss")&amp;".log");
*/
epilog
	delete gh;
	delete roi;
	write "Finished";
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpRunGateInOut" id="92d6117a-5c57-41e0-94d6-b7973e3f6a42">
        <source>jhpRunGateInOut();

vars
	i,j:Integer; s,t:String;
	tran:GateInOut2;
begin
	app.controlLockAcquire;
	app.controlLockRelease;
	app.initialize;
	app.sequenceId:=5;
//	app.profileName:="GateInOut";
	create tran;
	tran.startup;
	foreach i in 1 to 20 do
		tran.loopCount:=i;
		return;
		app.doWindowEvents(4000);	tran.gio01_showInOutSheets;
		app.doWindowEvents(4000);	tran.gio03_enterGateInDetails;
		app.doWindowEvents(4000);	tran.gio04_rfidTagSwipeGateIn;
		app.doWindowEvents(4000);	tran.gio05_rfidTagFormProceed;
		app.doWindowEvents(4000);	tran.gio06_rfidTagSwipeGateLaneIn;
		app.doWindowEvents(4000);	tran.gio07_handHeldGateLaneIn;
		app.doWindowEvents(4000);	tran.gio08_rtgContainerInTake;
		app.doWindowEvents(4000);	tran.gio09_rtgContainerInDrop;
		app.doWindowEvents(4000);	tran.gio10_rtgContainerOutTake;
		app.doWindowEvents(4000);	tran.gio11_rtgContainerOutDrop;
		app.doWindowEvents(4000);	tran.gio12_rfidTagSwipeGateLaneOut;
		app.doWindowEvents(4000);	tran.gio13_handHeldGateLaneOut; /* */
	endforeach;
	tran.stop;
	//app.finalize; /* */
