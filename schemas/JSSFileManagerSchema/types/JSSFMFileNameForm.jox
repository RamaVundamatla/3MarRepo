    <JadeMethod name="btnCancelAll_click" id="203ddd50-a509-4301-a6ac-2d0a92e11632">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancelAll_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		02 July 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.modalResult	:=	self.JSS_MODAL_CANCEL_ALL;
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="63017edb-64cc-421c-9fec-19eb56a1b833">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		02 July 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.modalResult	:=	self.JSS_MODAL_CANCEL;
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="52aa6bfa-7595-46d9-8896-1597ca5ec551">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		02 July 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileName	: String;
	
begin
	fileName	:=	txtName.text.trimBlanks();
	
	if fileName &lt;&gt; null then
		self.aNewFileName	:=	self.getNewPathName(fileName);
		self.modalResult	:=	self.JSS_MODAL_UPDATE;
		unloadForm();
	endif;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="778f9d6d-ffd7-4f6f-9493-9c60a5c0d580">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 July 2002 by cnwdad1
//
// Purpose:		The standard JSS CoreSchema form initialization event method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.modalResult	:=	self.JSS_MODAL_CANCEL;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="92a8fcb1-b3d6-4f8b-95bc-da150785d511">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 July 2002 by cnwdad1
//
// Purpose:		The standard JSS CoreSchema form load event method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	newOrRename	: String;
	
begin
	inheritMethod();
	
	if self.aIsRename then
		newOrRename	:=	"Rename";
	else
		newOrRename	:=	"New";
	endif;
	
	if self.aIsFileNode then
		self.caption			:=	newOrRename &amp; " File";
		lblInstructions.caption	:=	"Please enter the new file name:";
	else
		self.caption			:=	newOrRename &amp; " Directory";
		lblInstructions.caption	:=	"Please enter the new directory name:";
	endif;
	
	if self.aIsRename then
		lblAction.caption		:=	"Renaming " &amp; self.aCurrentFileName &amp; "...";
		btnCancelAll.enabled	:=	true;
	else
		lblAction.caption		:=	"Creating directory in " &amp; self.aPathName &amp; "...";
		btnCancelAll.enabled	:=	false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getNewPathName" id="f8024ec3-7177-4cea-b573-8253df326f3b">
        <source>getNewPathName(pNodeName:String):String protected;
// --------------------------------------------------------------------------------
// Created:		18 July 2002 by cnwdad1
//
// Purpose:		Formats the entered file/directory name with the existing path name.
//
// Parameters:	pNodeName - The file/directory name entered by the user.
//
// Returns:		The full path name incorporating the name entered by the user.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	oldFilePath		: String;
	endPosition		: Integer;
	newPathName		: String;
	fileSeparator	: String;
	
begin
	if self.aIsUnix then
		fileSeparator	:=	JSS_SEPARATOR_UNIX;
	else
		fileSeparator	:=	JSS_SEPARATOR_WIN;
	endif;
	
	if self.aIsRename then
		oldFilePath		:=	self.aPathName;
		endPosition		:=	oldFilePath.reversePos(fileSeparator);
		newPathName		:=	oldFilePath[1:endPosition] &amp; pNodeName;
	else
		newPathName		:=	self.aPathName &amp; fileSeparator &amp; pNodeName;
	endif;
epilog
	return newPathName;
end;</source>
        <access>protected</access>
        <Parameter name="pNodeName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFileNameInfo" id="4987a482-fa6b-45bb-9f5d-565e4093db4a">
        <updating/>
        <source>setFileNameInfo(pFileName:String; pPathName:String; pIsUnix:Boolean; pIsFileNode:Boolean; pIsRename:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		02 July 2002 by cnwdad1
//
// Purpose:		Updates the file/directory name details.
//
// Parameters:	pFileName - The name of the file/directory.
//				pPathName - The path name of the file/directory.
//				pIsUnix - True if the file/path OS platform is Unix.
//				pIsFileNode - If true, the node is a file, otherwise it's a directory.
//				pIsRename - If true, the file/directory is being renamed, in which
//					case this form is being used to capture the new name, not the
//					name a new directory.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aCurrentFileName	:=	pFileName;
	self.aPathName			:=	pPathName;
	self.aIsUnix			:=	pIsUnix;
	self.aIsFileNode		:=	pIsFileNode;
	self.aIsRename			:=	pIsRename;
end;</source>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pPathName" type="String"/>
        <Parameter name="pIsUnix" type="Boolean"/>
        <Parameter name="pIsFileNode" type="Boolean"/>
        <Parameter name="pIsRename" type="Boolean"/>
    </JadeMethod>
</GUIClass>
