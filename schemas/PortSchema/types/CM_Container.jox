    <JadeMethod name="cloneForInterTerminalPreNote" id="53deb3b3-a64b-40b9-bb1c-6d6f748d0568">
        <updating/>
        <source>cloneForInterTerminalPreNote(_toTerminal: CM_Terminal; _transient : Boolean): CM_TrackedItem updating;
/*
Date			Who		Reason
14 October 2010	cnwndl1	Initial creation
09 October 2017	jlgmd1	TFS 7040 - 1090 when clearing rake

*/

vars
	cloneTrackedItem : CM_TrackedItem;
	vgmDetails 		 : CM_VGMDetails;
begin
			
	cloneTrackedItem := inheritMethod(_toTerminal,_transient);
	
	//if self.myVGMDetails &lt;&gt; null then		// TFS 7040
	if self.myVGMDetails &lt;&gt; null and cloneTrackedItem &lt;&gt; null then
		vgmDetails	:= self.myVGMDetails;
		cloneTrackedItem.setMyVGMDetails(self.weightCertifiedName,
										self.weightCertifiedReference,
										vgmDetails.vgmAuthSignature,
										vgmDetails.vgmCommsType,
										vgmDetails.vgmDocumentDetails,
										vgmDetails.vgmEDITransmission,
										vgmDetails.vgmElectronicMail,
										vgmDetails.vgmMail,
										vgmDetails.vgmPhone,
										vgmDetails.vgmTelefax,
										vgmDetails.vgmTelephone,
										vgmDetails.vgmDocsIssuedDT,
										vgmDetails.vgmDeterminationDT,
										null);
	endif;
	
	return cloneTrackedItem;
		
epilog

end;</source>
        <Parameter name="_toTerminal" type="CM_Terminal"/>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
