	transactions.add(global.getTiTxnTypeForClass(CM_DamageLocation).asStringJMT);
	transactions.add(global.getTiTxnTypeForClass(CM_RepairDetail).asStringJMT);
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, transactions, registeredCargoTypes, camTrainEventTypes, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::singleTransactionPerFile.name, false);	
	camProtocol.setLogExcludedTransactions(true);
	camProtocol.setLogIncludedTransactions(true);		
	
	extWebServiceDef := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_DamageAndRepair );	// TFS 58722
	if extWebServiceDef &lt;&gt; null and extWebServiceDef.isAPIDef then							// TFS 58722
		activeWebServiceDef := extWebServiceDef.CM_APIEndpointServiceDef;					// TFS 58722
	endif;																					// TFS 58722
	
	if activeWebServiceDef &lt;&gt; null then
		camProtocol.setMyWebServiceDef(activeWebServiceDef);
		
		
