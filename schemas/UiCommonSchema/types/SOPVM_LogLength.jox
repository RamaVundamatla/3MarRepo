//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return CM_LogLength;
end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="25881758-771d-4b57-9f9d-09305f51660d">
        <source>setupThumbnailDetails();
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if app.getMyUser.canDo(self.myForm.myTerminal, PmLogLengthSortCode) then
		self.myForm.shtTblInput1.caption := 'Details';
		self.myForm.shtTblInput1.visible := true;
		self.myForm.shtMultiSelect1.visible := false;
		self.myForm.shtMultiSelect2.visible := false;
		self.myForm.shtMultiSelect3.visible := false;
	
		self.myForm.initTblInput(myForm.tblInput1, ETDef_CodeMaintLength);
	else
		self.setupThumbnailDetails_Code();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="46e14ee5-e12f-480f-bb1a-4a6ad052beec">
        <updating/>
        <source>showThumbnail(_obj: CM_Object) updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if app.getMyUser.canDo(self.myForm.myTerminal, PmLogLengthSortCode) then
		self.setupThumbnailDetails();
		self.myForm.sptThumbEdit.enabled := true;
	
		self.myForm.tblInput1.enabled := true;
	
		self.myForm.tblInput1.clearValues;
		self.myForm.tblInput1.setValueByName(ETRow_Code, _obj.CM_Code.code);
		self.myForm.tblInput1.setValueByName(ETRow_Description, _obj.CM_Code.description);
		self.myForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, _obj.CM_Code.notAvailableForEntry);
		self.myForm.tblInput1.setValueByName(ETRow_SortKey, _obj.CM_LogLength.sortOrder);
	else
		self.showThumbnail_Code(_obj.CM_Code);
	endif;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
</Class>
