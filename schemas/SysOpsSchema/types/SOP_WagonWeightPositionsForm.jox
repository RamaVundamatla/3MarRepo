    <JadeMethod name="displayMeasurementFields" id="b6b11c71-1650-4c43-a30c-e2400b95cf77">
        <updating/>
        <source>displayMeasurementFields() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2013	cnwndl1	Initial creation	Par 32172

*/

vars

begin

	self.weightType := app.getDefaultMeasurementForType(Type_Weight);
	self.heightType := app.getDefaultMeasurementForType(Type_Height);
	
	self.tblDeckHeight1.setup(Type_Height, self.backColor);
	self.tblDeckHeight1.tabKey := J_key_Tab;
	self.tblDeckHeight1.visible := true;
	
	self.tblDeckHeight2.setup(Type_Height, self.backColor);
	self.tblDeckHeight2.tabKey := J_key_Tab;
	self.tblDeckHeight2.visible := true;
	
	self.tblDeckHeight3.setup(Type_Height, self.backColor);
	self.tblDeckHeight3.tabKey := J_key_Tab;
	self.tblDeckHeight3.visible := true;
	
	self.tblDeckHeight4.setup(Type_Height, self.backColor);
	self.tblDeckHeight4.tabKey := J_key_Tab;
	self.tblDeckHeight4.visible := true;
	
	self.tblMaxWeight1.setup(Type_Weight, self.backColor);
	self.tblMaxWeight1.tabKey := J_key_Tab;
	self.tblMaxWeight1.visible := true;
	
	self.tblMaxWeight2.setup(Type_Weight, self.backColor);
	self.tblMaxWeight2.tabKey := J_key_Tab;
	self.tblMaxWeight2.visible := true;
	
	self.tblMaxWeight3.setup(Type_Weight, self.backColor);
	self.tblMaxWeight3.tabKey := J_key_Tab;
	self.tblMaxWeight3.visible := true;
	
	self.tblMaxWeight4.setup(Type_Weight, self.backColor);
	self.tblMaxWeight4.tabKey := J_key_Tab;
	self.tblMaxWeight4.visible := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doApply" id="055ee250-5390-4783-ab59-f17cf9d81b65">
        <updating/>
        <source>doApply(_modalResult : Integer):Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/06/2009	cnwndl1	Initial creation
01/04/2010	NDL	Par 23556 - use 'asDecimalJMT()'
08/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
11 Sep 2013	NDL	Par 32172
*/
vars

	posi : CM_WagonPosition;
	result : Integer;
	
begin
	
	foreach posi in myProxyWagonPositionalRule.allWagonPositions do
		if posi.position = 1 then																													// PAR #31155
			posi.setProxy(	cmbLength1.text.Integer,	//_cargoLength : Integer;
							self.tblDeckHeight1.getConvertedValue,			//_deckHeight : Decimal;// PAR #31155
							self.tblMaxWeight1.getConvertedValue,	//_maxWeight : Decimal;	// PAR #31155
							posi.position,	//_position : Integer;
							myProxyWagonPositionalRule	//_myWagonPositionalRule : CM_WagonPositionalRule
							);
		elseif posi.position = 2 then																													// PAR #31155
			posi.setProxy(	cmbLength2.text.Integer,	//_cargoLength : Integer;
							self.tblDeckHeight2.getConvertedValue,			//_deckHeight : Decimal;// PAR #31155
							self.tblMaxWeight2.getConvertedValue,	//_maxWeight : Decimal;	// PAR #31155
							posi.position,	//_position : Integer;
							myProxyWagonPositionalRule	//_myWagonPositionalRule : CM_WagonPositionalRule
							);
		elseif posi.position = 3 then																													// PAR #31155
			posi.setProxy(	cmbLength3.text.Integer,	//_cargoLength : Integer;
							self.tblDeckHeight3.getConvertedValue,			//_deckHeight : Decimal;// PAR #31155
							self.tblMaxWeight3.getConvertedValue,	//_maxWeight : Decimal;	// PAR #31155
							posi.position,	//_position : Integer;
							myProxyWagonPositionalRule	//_myWagonPositionalRule : CM_WagonPositionalRule
							);
		elseif posi.position = 4 then
			posi.setProxy(	cmbLength4.text.Integer,	//_cargoLength : Integer;
							self.tblDeckHeight4.getConvertedValue,			//_deckHeight : Decimal;// PAR #31155
							self.tblMaxWeight4.getConvertedValue,	//_maxWeight : Decimal;	// PAR #31155
							posi.position,	//_position : Integer;
							myProxyWagonPositionalRule	//_myWagonPositionalRule : CM_WagonPositionalRule
							);
		endif;
		
	endforeach;
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	myProxyWagonPositionalRule.validateForUpdate();

	myParentForm.SOP_WagonPositionRuleForm.doRefreshTableRow( myProxyWagonPositionalRule );
	
	if app.myPassport.hasErrorsOrWarnings then
		result	:= app.showErrorWarningDialog(	app.getErrorString( Booking_Item ),
												app.myPassport,
												ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
		if  app.myPassport.hasErrors  or result &lt;&gt; IDOK  then
			return false;
		endif;
	endif;
	
	hasChanged := false;
	
	if _modalResult = IDOK then
		if self.isBaseFormModal then
			self.modalResult:=_modalResult;
		endif;
		self.unloadForm;
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_modalResult" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="a94e7f4d-fb9d-4b0f-be6b-edbf327d3e7b">
        <updating/>
        <source>doCancel() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwndl1	Initial creation

*/

vars

begin

	self.modalResult:=IDCANCEL;
	self.unloadForm;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doComboSelection" id="284f1f43-3dcd-4ca5-8b51-1540364d9e08">
        <updating/>
        <source>doComboSelection(_combo : CMUI_ComboBox) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwndl1	Initial creation

*/

vars

	length : Integer;
	
begin

	length := _combo.text.Integer;
	
	if _combo = cmbLength1 then
		if length &lt;= 20 then
			// There is no overlap with the next position,
			// enable it on case it was previously disabled
			grpPosition2.enabled := true;
			if cmbLength2.text.Integer = 0 then
				// If this is empty, there is the potential that the previous
				// value from the '_combo' extended into the next position too.
				// make it available just in case.
				grpPosition3.enabled := true;
			endif;
		elseif length &lt;= 40 then
			if cmbLength2.text.Integer = 0 then
				// If this is empty, there is the potential that the previous
				// value from the '_combo' extended into the next position too.
				// make it available just in case.
				grpPosition3.enabled := true;
			endif;
			// now unconditionally clear postion, because we overlap it.
			clearPosition(grpPosition2,false);
		elseif length &lt;= 60 then
			//unconditionally clear next 2 postions.
			clearPosition(grpPosition2,false);
			clearPosition(grpPosition3,false);
		endif;
		
	elseif _combo = cmbLength2 then
		if length &lt;= 20 then
			// There is no overlap with the next position,
			// enable it on case it was previously disabled
			grpPosition3.enabled := true;
			if cmbLength3.text.Integer = 0 then
				// If this is empty, there is the potential that the previous
				// value from the '_combo' extended into the next position too.
				// make it available just in case.
				grpPosition4.enabled := true;
			endif;
		elseif length &lt;= 40 then
			if cmbLength3.text.Integer = 0 then
				// If this is empty, there is the potential that the previous
				// value from the '_combo' extended into the next position too.
				// make it available just in case.
				grpPosition3.enabled := true;
			endif;
			// now unconditionally clear postion, because we overlap it.
			clearPosition(grpPosition3,false);
		elseif length &lt;= 60 then
			//unconditionally clear next 2 postions.
			clearPosition(grpPosition3,false);
			clearPosition(grpPosition4,false);
		endif;
		
	elseif _combo = cmbLength3 then
		if length &lt;= 20 then
			// There is no overlap with the next position,
			// enable it on case it was previously disabled
			grpPosition4.enabled := true;
		elseif length &lt;= 40 then
			// now unconditionally clear postion, because we overlap it.
			clearPosition(grpPosition4,false);
		elseif length &lt;= 60 then
			//unconditionally clear next 2 postions.
			clearPosition(grpPosition4,false);
		endif;
		
	elseif _combo = cmbLength4 then
		
	endif;
	
	hasChanged := true;
	
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doNext" id="65202b61-214a-4467-be99-fd6a937c5e34">
        <updating/>
        <source>doNext()protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwndl1	Initial creation

*/

vars
	
	currentPos : Integer;
	nextRule : CM_WagonPositionalRule;
	row : Integer;
	
	posi : CM_WagonPosition;
	pos : Integer;
	
	wagonPosRuleForm : SOP_WagonPositionRuleForm;
	wagonRuleSet : CM_WagonPositionalRuleSet;
	
begin

	wagonPosRuleForm := myParentForm.SOP_WagonPositionRuleForm;
	wagonRuleSet := wagonPosRuleForm.myPxyWagonClass.allWagonPositionalRules;
	
	currentPos := wagonRuleSet.indexOf(myProxyWagonPositionalRule);

	if not self.doApply(IDNEXT) then
		return;
	endif;
	
	if wagonRuleSet.size = currentPos then
		//there are no more, create a new rule
		create nextRule transient;
		nextRule.setProxy(	myProxyWagonPositionalRule.myWagonClass,	//_myWagonClass : CM_WagonClass;
							myProxyWagonPositionalRule.numberOfPositions,	//_numberOfPositions : Integer;
							null	//_allWagonPositions : CM_WagonPositionDict
							);
		
	else
		//find the next one in the table.
		row := wagonPosRuleForm.getRowForRule(myProxyWagonPositionalRule);
		nextRule := wagonPosRuleForm.tblWagonPos.accessRow(row + 1).itemObject.CM_WagonPositionalRule;
			
	endif;
	
	setMyWagonPositionalRule(nextRule, wagonPosRuleForm);
	loadData();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="3c129a48-9cbd-43b2-9444-65b16269c787">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
	grpPositions.left := 5;
	grpPositions.top := 5;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="8f222678-f005-47df-a9a2-262893d93bab">
        <updating/>
        <source>loadCombos() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwndl1	Initial creation

*/

vars

	size : Integer;
	maxLength : Integer;
	intArray : IntegerArray;
	int : Integer;
	
begin

	defaultDeckHeight := self.myProxyWagonPositionalRule.myWagonClass.deckHeight;

	cmbLength1.clear();
	cmbLength2.clear();
	cmbLength3.clear();
	cmbLength4.clear();

	size := self.myProxyWagonPositionalRule.numberOfPositions;
	if size &lt; 1 then
		return;
	endif;
	maxLength := size * 20;
	
	create intArray transient;
	intArray.add(Length10);
	intArray.add(Length20);
	intArray.add(Length30);
	intArray.add(Length40);
	intArray.add(Length45);
	intArray.add(Length53);
	
	cmbLength1.addItem(" ");
	foreach int in intArray where int &lt;= maxLength do
		cmbLength1.addItem( int.String );
	endforeach;
	
	if size &gt;= 2 then
		maxLength := (size - 1) * 20;
		cmbLength2.addItem(" ");
		foreach int in intArray where int &lt;= maxLength do
			cmbLength2.addItem( int.String );
		endforeach;
	endif;
	
	if size &gt;= 3 then
		maxLength := (size - 2) * 20;
		cmbLength3.addItem(" ");
		foreach int in intArray where int &lt;= maxLength do
			cmbLength3.addItem( int.String );
		endforeach;
	endif;
	
	if size &gt;= 4 then
		maxLength := (size - 3) * 20;
		cmbLength4.addItem(" ");
		foreach int in intArray where int &lt;= maxLength do
			cmbLength4.addItem( int.String );
		endforeach;
	endif;
	
epilog

	delete intArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadData" id="f7b1a673-0624-44bd-9a25-670b3502abc3">
        <updating/>
        <source>loadData() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/06/2009	cnwndl1	Initial creation
08/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
11 Sep 2013	NDL	Par 32172
*/
vars
	size : Integer;
	position : CM_WagonPosition;
	
begin

	size := self.myProxyWagonPositionalRule.numberOfPositions;
	
	grpPosition1.visible := (size &gt;= 1);
	grpPosition2.visible := (size &gt;= 2);
	grpPosition3.visible := (size &gt;= 3);
	grpPosition4.visible := (size &gt;= 4);
	
	clearPosition( grpPosition1, true );
	clearPosition( grpPosition2, true );
	clearPosition( grpPosition3, true );
	clearPosition( grpPosition4, true );
	
	// position 1.
	position := self.myProxyWagonPositionalRule.allWagonPositions.getAtKey(1);	
	if position &lt;&gt; null and not position.isEmpty then
		if position.cargoLength &gt; 0 then
			cmbLength1.listIndex := cmbLength1.findStringExact(1,position.cargoLength.String);
			self.tblMaxWeight1.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, position.maxWeight) &amp; Space &amp; self.weightType.shortName);
			self.tblDeckHeight1.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, position.deckHeight) &amp; Space &amp; self.heightType.shortName);// PAR #31155
		endif;
	endif;
	if position &lt;&gt; null and position.extendsBeyondPosition &gt; 0 then
		grpPosition2.enabled := false;
	endif;
	
	// position 2.
	position := self.myProxyWagonPositionalRule.allWagonPositions.getAtKey(2);	
	if position &lt;&gt; null and not position.isEmpty then
		if position.cargoLength &gt; 0 then
			cmbLength2.listIndex := cmbLength2.findStringExact(1,position.cargoLength.String);
			self.tblMaxWeight2.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, position.maxWeight) &amp; Space &amp; self.weightType.shortName);
			self.tblDeckHeight2.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, position.deckHeight) &amp; Space &amp; self.heightType.shortName);
		endif;
	endif;
	if position &lt;&gt; null and position.extendsBeyondPosition &gt; 0 then
		grpPosition3.enabled := false;
	endif;
	
	// position 3.
	position := self.myProxyWagonPositionalRule.allWagonPositions.getAtKey(3);	
	if position &lt;&gt; null and not position.isEmpty then
		if position.cargoLength &gt; 0 then
			cmbLength3.listIndex := cmbLength1.findStringExact(1,position.cargoLength.String);
			self.tblMaxWeight3.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, position.maxWeight) &amp; Space &amp; self.weightType.shortName);
			self.tblDeckHeight3.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, position.deckHeight) &amp; Space &amp; self.heightType.shortName);
		endif;
	endif;
	if position &lt;&gt; null and position.extendsBeyondPosition &gt; 0 then
		grpPosition4.enabled := false;
	endif;
	
	// position 4.
	position := self.myProxyWagonPositionalRule.allWagonPositions.getAtKey(4);	
	if position &lt;&gt; null and not position.isEmpty then
		if position.cargoLength &gt; 0 then
			cmbLength4.listIndex := cmbLength1.findStringExact(1,position.cargoLength.String);
			self.tblMaxWeight4.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, position.maxWeight) &amp; Space &amp; self.weightType.shortName);
			self.tblDeckHeight4.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, position.deckHeight) &amp; Space &amp; self.heightType.shortName);
		endif;
	endif;
	
	myParentForm.SOP_WagonPositionRuleForm.doRefreshTableRow( myProxyWagonPositionalRule );
	hasChanged := false;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="7faa08e6-5b9f-4d60-9a48-4d48185acfbb">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2009	cnwndl1	Initial creation

*/

vars
	result : Integer;
begin
	
	if hasChanged then
		result := app.msgBox(app.getErrorString(EditChangedAndClosing), self.caption &amp; " " &amp; app.getErrorString(Window_closing) &amp; " !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if result &lt;&gt; MsgBox_Return_Yes then
			cancel:=1;
		endif;	
	endif;
epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyWagonPositionalRule" id="9e2efca6-0b09-4bad-91fc-884c1078b3f9">
        <updating/>
        <source>setMyWagonPositionalRule( _rule : CM_WagonPositionalRule; _callingForm : CM_BaseForm ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwndl1	Initial creation

*/

vars

begin

	myProxyWagonPositionalRule := _rule;
	self.setParentForm(_callingForm);
	
epilog

end;</source>
        <Parameter name="_rule" type="CM_WagonPositionalRule"/>
        <Parameter name="_callingForm" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ec99141f-6997-43dc-b040-2f8d8e7069e2">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/06/2009	cnwndl1	Initial creation
08/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
11 Sep 2013	NDL	Par 32172
*/
vars
	form : SOP_WagonPositionRuleForm;
	str : String;
begin
	
	// starting size
	self.width := 655;
	self.height := 274;
	
	self.displayMeasurementFields();
	self.modalResult := IDCANCEL;
	inheritMethod();
	
	if self.myProxyWagonPositionalRule = null then
		btnCancel.click(btnCancel);
		return;
	else
		setCaption( self.myProxyWagonPositionalRule.getDisplayDetails(false) );
		
		lblMaxValues.caption := null;
		
		if self.myParentForm &lt;&gt; null then
			form := self.myParentForm.SOP_WagonPositionRuleForm;
		endif;
		if form &lt;&gt; null then
		//	if form.tblMaxCWeight.text.Decimal &gt; 0 then
			if form.tblMaxCWeight.text.asDecimalJMT &gt; 0 then	//22 Oct 2015	NDL	Par 36655
				str := form.lblCWeight.caption &amp; " " &amp; form.tblMaxCWeight.text &amp; " " &amp; self.weightType.shortName;	//lblCWeight already has units				// PAR #31155
			endif;
		//	if form.tblDeckHeight.text.Decimal &gt; 0 then
			if form.tblDeckHeight.text.asDecimalJMT &gt; 0 then	//22 Oct 2015	NDL	Par 36655
				if str &lt;&gt; null then
					str := str &amp; CrLf;
				endif;
				str := str &amp; form.lblHeight.caption &amp; " " &amp; form.tblDeckHeight.text &amp; " " &amp; self.heightType.shortName; // lblHeight already has units			// PAR #31155
			endif;
			lblMaxValues.caption := str;
		endif;

	endif;
	
	loadCombos();
	loadData();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="74a0761a-86bd-46c6-8c9a-26cbfbae2ab6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:54:39.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022884, locale);
	btnApply.translateCaption(Xlat_0011756, locale);
	btnCancel.translateCaption(Xlat_0011757, locale);
	btnNext.translateCaption(Xlat_0011758, locale);
	grpPosition1.translateCaption(Xlat_0011759, locale);
	grpPosition2.translateCaption(Xlat_0011760, locale);
	grpPosition3.translateCaption(Xlat_0011761, locale);
	grpPosition4.translateCaption(Xlat_0011762, locale);
//	grpPositions.translateCaption(Xlat_0023460, locale);
	lblDeckHeight1.translateCaption(Xlat_0011763, locale);
	lblDeckHeight2.translateCaption(Xlat_0011764, locale);
	lblDeckHeight3.translateCaption(Xlat_0011765, locale);
	lblDeckHeight4.translateCaption(Xlat_0011766, locale);
//	lblHeightUnit1.translateCaption(Xlat_0011767, locale);
//	lblHeightUnit2.translateCaption(Xlat_0011768, locale);
//	lblHeightUnit4.translateCaption(Xlat_0011770, locale);
	lblLength1.translateCaption(Xlat_0011771, locale);
	lblLength2.translateCaption(Xlat_0011772, locale);
	lblLength3.translateCaption(Xlat_0011773, locale);
	lblLength4.translateCaption(Xlat_0011774, locale);
	lblLengthUnit1.translateCaption(Xlat_0011775, locale);
	lblLengthUnit2.translateCaption(Xlat_0011776, locale);
	lblLengthUnit3.translateCaption(Xlat_0011777, locale);
	lblLengthUnit4.translateCaption(Xlat_0011778, locale);
	lblMaxWeight1.translateCaption(Xlat_0011779, locale);
	lblMaxWeight2.translateCaption(Xlat_0011780, locale);
	lblMaxWeight3.translateCaption(Xlat_0011781, locale);
	lblMaxWeight4.translateCaption(Xlat_0011782, locale);
//	lblWeightUnit1.translateCaption(Xlat_0011783, locale);
//	lblWeightUnit2.translateCaption(Xlat_0011784, locale);
//	lblWeightUnit3.translateCaption(Xlat_0011785, locale);
//	lblWeightUnit4.translateCaption(Xlat_0011786, locale);
end;</source>
    </JadeMethod>
</GUIClass>
