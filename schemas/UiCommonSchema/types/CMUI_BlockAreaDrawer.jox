    <JadeMethod name="getSelectedRegion" id="1cc46943-f248-48cf-9759-d073a91e6ea3">
        <updating/>
        <source>getSelectedRegion(region : PointArray io) updating;
// Return the list of points that describe the selected region
begin
	if self.bottomRight = null then
		self.bottomRight := self.topLeft;
	endif;
	region.clear();
	region.add(self.topLeft);
	region.add(self.bottomRight);
end;
</source>
