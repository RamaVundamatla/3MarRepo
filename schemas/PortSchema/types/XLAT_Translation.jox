    <JadeMethod name="update" id="d4b219a6-86f7-483b-9854-71efbb8eade7">
        <updating/>
        <source>update(_root : CM_Root; _translatableText : XLAT_TranslatableText; _locale : CM_Locale; _text, _shortText : String) updating;
/*
Date		Who		Reason
26 Nov 2008	cnwjk3	PAR 18506 - Need to be able to exclude parameters from the translation

*/

vars
	standardTextLocale : CM_Locale;

begin
	text := _text;
	shortText := _shortText;
	
	if self.myLocale &lt;&gt; _locale then
		self.myLocale := _locale;
	endif;
	if self.myTranslatableText &lt;&gt; _translatableText then
		self.myTranslatableText := _translatableText;
	endif;
	if self.myRoot &lt;&gt;_root then
		self.myRoot := _root;
	endif;

	// Remove locale translation if it the same as the standard text locale translation.
	// Also update the keyword index for the locale.
	standardTextLocale := app.myRoot.getLocale(StandardTextLocaleStr, false);
	if _locale &lt;&gt; standardTextLocale and 
	   text = _translatableText.vDefaultMessage and 
	   shortText = _translatableText.vDefaultShortMessage then
		text := "";
		shortText := "";
		_locale.updateKeywords(self, self.myTranslatableText.getGlobalConstantName);
		delete self;
	else
		_locale.updateKeywords(self, self.myTranslatableText.getGlobalConstantName);
		// cnwjk3 PAR 18506 26/11/08
		// We want to allow all but spaces to be saved
		//if allKeywords.size = 0 then
		if text.trimBlanks() = "" then
			delete self;
		endif;
		//endif;
	endif;

end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_translatableText" type="XLAT_TranslatableText"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_shortText" type="String"/>
    </JadeMethod>
    <JadeMethod name="vGlobalConstant" id="3d887e9a-6221-4d31-be93-35a9a38b5647">
