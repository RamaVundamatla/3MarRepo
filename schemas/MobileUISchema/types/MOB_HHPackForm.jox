    <JadeMethod name="bookingDisplayLine" id="2abb3263-97f3-4328-ba4b-a341df3d4464">
        <source>bookingDisplayLine( _obj : Object ) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	bookingRef : CM_BookingRef;
	operator : CM_Operator;
	voyage : CM_Voyage;
	str : String;

begin

	//bookingref, operator and voyage
	if CM_BookingRef.hasInstance( _obj ) then
		bookingRef := _obj.CM_BookingRef;
		operator := bookingRef.myOperator;
		voyage := bookingRef.myVoyage;
		str := bookingRef.bookingReference;
		if operator &lt;&gt; null then
			str := str &amp; " / " &amp; operator.code;
		endif;
		if voyage &lt;&gt; null then
			str := str &amp; " / " &amp; voyage.code;
		endif;
		return str;
	endif;
	
	return "Unknown object " &amp; _obj.String;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
