    <JadeMethod name="cmbCommodity_gotFocus" id="c7f01e3c-28e5-4ee0-b5e4-a64d2e5d1d2a">
        <controlMethod name="CMUI_ComboBoxObject::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCommodity_gotFocus(combobox: ComboBox input) updating;
/* ---------------------------------------------------------------------------
Created:	10 July 2009	by cnwvu1

Purpose:	CCMS 1080 PAR19704. Show only selected commodities.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	currentCommodity	: CM_Commodity;
	selectedCommodities	: CM_CommodityByCodeDict;
	cargoType			: CM_CargoType;
	
begin
	currentCommodity := self.cmbCommodity.listObject.CM_Commodity;

	// It can be null, when the form has just started. Trying to retrieve commodity code from proxy object
	if currentCommodity = null then	
		cargoType := self.myProxyObject.CM_CargoType;
		if cargoType &lt;&gt; null then
			if not cargoType.allCommodities.isEmpty then
				currentCommodity := cargoType.allCommodities[cargoType.defaultCommodityCode];
			else
				currentCommodity := app.myRoot.allCommodities[cargoType.defaultCommodityCode];
			endif;
		endif;
	endif;
	
	create selectedCommodities transient;
	self.mulSelectCommod.getSelected(selectedCommodities);	//PAR 19704. CCMS 1080 May 2009 cnwvu1
	
	self.myAssistant.comboBoxCommodityMultiSelected(self.cmbCommodity, selectedCommodities, currentCommodity);
	
	//cnwmc5 - PAR 30834
	//self.cmbCommodity.setInitialised(true);	// not to call getJMTCollection()- it populates all commodities
	self.cmbCommodity.setPopulated(true);
	
	
epilog
	delete selectedCommodities;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCommodity_lostFocus" id="c962e31a-015f-404f-a626-6a85e9880379">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCommodity_lostFocus(combobox: ComboBox input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/04/2015	cnwdap1	Initial creation PAR #36094 CCMS 1413 Cold Store Enhancements
15/09/2023	jlika1	MTN - Cargo Types - 1309 error after specifying Default Commodity Code and also adding it into Selected Commodities on Commodities tab
*/
vars
	currentCommodity : CM_Commodity;
	commodityDict : CM_CommodityByCodeDict;	
begin
	create commodityDict transient;
	
	// if the selected default commodity isn't in the list of commodities, add it
	currentCommodity := self.cmbCommodity.listObject.CM_Commodity;
	if currentCommodity &lt;&gt; null then
		self.mulSelectCommod.getSelected(commodityDict);
		if not commodityDict.includes(currentCommodity) then
			self.mulSelectCommod.addItem(self.mulSelectCommod.mySelectedListBox, currentCommodity);		
			self.mulSelectCommod.takeOutItem(self.mulSelectCommod.myAvailableListBox, currentCommodity);			
		endif;
	endif;
	
epilog
	delete commodityDict;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
