    <JadeMethod name="setNewTimeStampForDay" id="720a11cd-2ebb-4014-a6df-b73c27ca759d">
        <updating/>
        <source>setNewTimeStampForDay(isFutureScheduleProjection : Boolean; futureScheduleStartTs : TimeStamp) protected, updating;

// cnwdvb1 18 December 2002 
// R Barr  9/1//2006 Comalco -- new parameter isFutureScheduleProjection : Boolean indicates runTS should be
//								used to determine next schedule date/time, rather than current actual date/time

constants

	DaysInWeek = 7;
vars

	pos, first, dayOfWeek,
	after, nextDay, today 	: Integer;	
	haveTime				: Boolean;
	newTimeStamp			: TimeStamp;
	actualTime				: TimeStamp;
	
begin

	if self.allRunTimes.size = 0 then
		self.runTs := null;
	else
		if isFutureScheduleProjection and futureScheduleStartTs &lt;&gt; null then	// R Barr  9/1//2006 Comalco
			actualTime := futureScheduleStartTs;
		elseif isFutureScheduleProjection and runTs &lt;&gt; null then
			actualTime := runTs;
		else
			if self.startScheduleTs &gt; app.actualTimeServer() then
				//self.runTs := self.startScheduleTs;
				actualTime := self.startScheduleTs;
			else
				actualTime := app.actualTimeServer();
			endif;
		endif;
				
		newTimeStamp := null;
		// Get actual day of week 1-7.
		dayOfWeek := actualTime.date.dayOfWeek();
		if self.allRunDays.size = DaysInWeek then
			foreach pos in 1 to DaysInWeek do
				// Has this day been selected?
				if self.allRunDays[pos] then
					// Is the selected day after today?
					if pos &gt; dayOfWeek then
						after := pos;
						break;
					endif;
					// Get first day.
					if first = 0 then
						first := pos;
					endif;
					// Is it today?
					if dayOfWeek = pos then
						today := pos;
					endif;
				endif;
			endforeach;
			// Are we dealing with today?
			if today &lt;&gt; 0 then
				newTimeStamp.setDate(actualTime.date);
				// Do we have a time for today?
				haveTime := self.checkTimes(newTimeStamp, actualTime);
			endif;
			// We don't have a time yet. Because today isn't selected or there
			// the run time has passed.
			if not haveTime and (after &lt;&gt; 0 or first &lt;&gt; 0) then
				// Day is after today.
				if after &lt;&gt; 0 then
					// How many days do we add to get to next run time.
					nextDay := (after - dayOfWeek);
				// We have a day before today. Must be next week.
				elseif first &lt;&gt; 0 then
					// Get day next week.
					nextDay := ((DaysInWeek - dayOfWeek) + first);
				endif;
				newTimeStamp := actualTime.cnEcAddDays(nextDay);
				// Do we have a time for this day.
				haveTime := self.checkTimes(newTimeStamp, actualTime);
			endif;
		else
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'All Run Days Incorrect', null, null);
		endif;
		
		if haveTime then
			self.runTs := newTimeStamp;
		else
			self.runTs := null;
		endif;
	endif;

	if not self.checkEndTime then
		self.runTs := null;
		self.isActive := Schedule_Is_Inactive;
	else
		self.isActive := Schedule_Is_Active;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="isFutureScheduleProjection" type="Boolean"/>
        <Parameter name="futureScheduleStartTs" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setNewTimeStampForMonth" id="e60c1af7-40ff-4722-af23-3864ad094e4c">
        <updating/>
        <source>setNewTimeStampForMonth(isFutureScheduleProjection : Boolean; futureScheduleStartTs : TimeStamp) protected, updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
14/01/2003 cnwdvb1 
09/01/2006 R Barr				Comalco -- new parameter isFutureScheduleProjection : Boolean 
								indicates runTS should be used to determine next schedule date/time, 
								rather than current actual date/time
16/04/2019	jlgka1 	43863		Add the Flexibility of the Monthly schedule to have a reuccring option
								between 1 to 12.
============================================================================*/
vars

	day			: Integer;
	tempDate	: Date;
	timeStamp,
	actualTime	: TimeStamp;
	count		: Integer;
begin

	timeStamp := null;
	
//	if self.allRunTimes.first = null then PAR 18305
	if self.allRunTimes.isEmpty() then
		self.runTs := null;
	else	
		if isFutureScheduleProjection and futureScheduleStartTs &lt;&gt; null then	// R Barr  9/1//2006 Comalco
			actualTime := futureScheduleStartTs;
		elseif isFutureScheduleProjection and runTs &lt;&gt; null then
			actualTime := runTs;
		else
			actualTime := app.actualTimeServer;
		endif;
		tempDate := actualTime.date;
		while not timeStamp.isValid do
			count := count + 1;
			if self.dayOfMonth = 'START' then
				day := 1;
			elseif self.dayOfMonth = 'END' then
				day := tempDate.cnEcDaysInMonth;
			else
				day := self.dayOfMonth.Integer;
			endif;
		
			if day = 0 then
				self.runTs := null;
				timeStamp := null;
				break;
			endif;
			
			if day = tempDate.day then
				// Check time.
				timeStamp.setDate(tempDate);
				if not self.checkTimes(timeStamp, actualTime) then	
					tempDate := null;
				endif;				
			elseif day &lt; tempDate.day then
				//tempDate := tempDate.cnEcAddMonths(1); // jlgka1 TFS 43863
				tempDate := tempDate.cnEcAddMonths(self.recurValue); // jlgka1 TFS 43863
				tempDate.setDate(day, tempDate.month, tempDate.year);
			elseif day &gt; tempDate.day then
				tempDate.setDate(day, tempDate.month, tempDate.year);
			endif;
			
			timeStamp.setDate(tempDate);
			timeStamp.setTime(self.allRunTimes.first);
			tempDate := actualTime.date.cnEcAddMonths(self.recurValue); // jlgka1 TFS 43863
			//tempDate := actualTime.date.cnEcAddMonths(count); // jlgka1 TFS 43863
			if count &gt; 2 then
				break;
			endif;
		endwhile;
		if timeStamp.isValid then
			self.runTs := timeStamp;
		else
			// Error.
			self.runTs := null;
		endif;
	endif;

	if self.runTs = null then
		self.isActive := Schedule_Is_Inactive;
	else
		self.isActive := Schedule_Is_Active;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="isFutureScheduleProjection" type="Boolean"/>
        <Parameter name="futureScheduleStartTs" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setNewTimeStampForRecur" id="bc5389cf-e35a-4492-98fb-7468b428eb9e">
        <updating/>
        <source>setNewTimeStampForRecur(_isFutureScheduleProjection : Boolean; _futureScheduleStartTs : TimeStamp) protected, updating;

// cnwdvb1 18 December 2002 
// R Barr  9/1//2006 Comalco -- new parameter _isFutureScheduleProjection : Boolean indicates runTS should be
//								used to determine next schedule date/time, rather than current actual date/time

vars
	timeStamp				: TimeStamp;
	
begin
	if self.recurValue &lt; 1 then
		self.runTs := null;
	else	
		if self.startScheduleTs &gt; app.actualTimeServer() then
			self.runTs := self.startScheduleTs;
		else
			if _isFutureScheduleProjection and _futureScheduleStartTs &lt;&gt; null then	// R Barr  9/1//2006 Comalco
				timeStamp := _futureScheduleStartTs;
			elseif _isFutureScheduleProjection and self.runTs &lt;&gt; null then
				timeStamp := self.runTs;
			else
				timeStamp := app.actualTimeServer;
			endif;
			if self.recurUnit = self.RecurUnit_Seconds then
				self.runTs := timeStamp.cnEcAddSeconds(self.recurValue);
			elseif self.recurUnit = self.RecurUnit_Minutes then
				self.runTs := timeStamp.cnEcAddMinutes(self.recurValue);
			elseif self.recurUnit = self.RecurUnit_Hours then
				self.runTs := timeStamp.cnEcAddHours(self.recurValue);
			elseif self.recurUnit = self.RecurUnit_Days then
				self.runTs := timeStamp.cnEcAddDays(self.recurValue);
			else
				// Fixup for spelling error.
				if self.recurUnit = "Minite(s)" then
					self.recurUnit := CM_AutoSchedule.RecurUnit_Minutes;
					self.runTs := timeStamp.cnEcAddMinutes(self.recurValue);
				endif;
			endif;
		endif;
	endif;
	
	if not self.checkEndTime() then
		self.runTs := null;
		self.isActive := self.Schedule_Is_Inactive;
	else
		self.isActive := self.Schedule_Is_Active;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_isFutureScheduleProjection" type="Boolean"/>
        <Parameter name="_futureScheduleStartTs" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setNextRunTs" id="2ddec6b6-8811-4768-b124-a8b109f56890">
        <updating/>
        <source>setNextRunTs(_state : Integer; _isFutureScheduleProjection : Boolean; _futureScheduleStartTs : TimeStamp) updating;

// cnwdvb1 18 December 2002 
// R Barr  9/1//2006 Comalco -- new parameters
//							    _isFutureScheduleProjection : Boolean indicates runTS should be
//								used to determine next schedule date/time, rather than current actual date/time
//								_futureScheduleStartTS (optional) future schedule projection starts here
vars
	tsServer	: TimeStamp;

begin
	if self.selectionState = State_Event then
		if _state = Make_Inactive then
			self.isActive := self.Schedule_Is_Inactive;
		elseif _state = Make_Now then
			self.isActive :=  self.Schedule_Is_Active;
		endif;
		
		return;
	endif;
	
	if _state &lt;&gt; self.Make_Process then
		if _state = self.Make_Inactive then
			app.writeLog('Deactivating schedule ' &amp; self.description, LogINFO);
			self.runTs := null;
			self.isActive := self.Schedule_Is_Inactive;
			
			return;
			
		elseif _state = Make_Now then
			app.writeLog('Activating schedule ' &amp; self.description, LogINFO);
			
			tsServer := app.actualTimeServer();
			if self.isActive =  self.Schedule_Is_Active 
			and self.startScheduleTs &lt;= tsServer	// Par 18304 Mar 2009
			then
				self.runTs := tsServer;
				return;
			else
				// We want to carry on and set next start time
				// because we are reactivating.
			endif;
			
		endif;
	endif;
		
	if self.selectionState = State_Time then
		self.setNewTimeStampForRecur(_isFutureScheduleProjection, _futureScheduleStartTs);
	elseif self.selectionState = State_Day then
		self.setNewTimeStampForDay(_isFutureScheduleProjection, _futureScheduleStartTs);
	elseif self.selectionState = State_Date then 
		self.setNewTimeStampForMonth(_isFutureScheduleProjection, _futureScheduleStartTs);
	endif;
	
	self.isBeingActioned := false;
end;</source>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_isFutureScheduleProjection" type="Boolean"/>
        <Parameter name="_futureScheduleStartTs" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validate" id="532c7170-e4b2-4365-828f-37d41d32f65e">
        <source>validate();

/* Changes

Date		Name	TFS#	Description
============================================================================
16 Jan 2003 cnwdvb1 
16 Apr 2019	jlgka1 43863	Add validation for the Recurring value in Monthly Schedule.
18 Mar 2021	navdap1	TFS 50946 PRP Auto Delete of Yard Allocations
10 June 2022 navds20 TFS 53760 MTN - DuplicateItem not Translatable
============================================================================*/
vars
	task 		: CM_AutoTask;
	me,
	schedule	: CM_AutoSchedule;
	str			: String;
	isYAExpiry	: Boolean;				// TFS 50946
	term 		: CM_Terminal;			// TFS 50946
	ya 			: CM_YardAllocation;	// TFS 50946
	termIter,							// TFS 50946
	yaIter		: Iterator;				// TFS 50946
begin
	// TFS 50946 For a YA Expiry schedule, if it's going to run more than once a week or it's event-based,
	// need to check that no yard allocations have the "No Matching Cargo" Auto Action option
	// This auto action is very process-intensive so we don't want it running too often
	// Have to do this first, because Event-based checking does a return at line 97-ish
	foreach task in self.allAutoTasks where task.isKindOf(CM_AutoTaskYAExpiry) do 
		if self.failsYAExpiryCheck then
			termIter := app.myRoot.allTerminals.createIterator;
			while termIter.next(term) do
				delete yaIter;
				yaIter := term.allYardAllocatonsByCode.createIterator;
				while yaIter.next(ya) do
					if ya.expiryType = YAExpiryType_NoCargo then
						app.raiseCMException2(Yard_alloc_incompat_schedule, ya.code, term.code, null, null);
					endif;
				endwhile;
			endwhile;
		endif;
	endforeach;
	// TFS 50946 end

	if self.selectionState = State_Date then
		if self.dayOfMonth = null or
		self.dayOfMonth &lt;&gt; 'START' and
		self.dayOfMonth &lt;&gt; 'END' and
		self.dayOfMonth.Integer &gt; 31 or not self.allRunTimes.first &lt;&gt; null and not self.allRunTimes.first.isValid then
			app.raiseCMWarning1(AutoScheduleDateError, 'Problem with day of month or run time',  null, null, self);		
		endif;
		// jlgka1 TFS 43863 --&gt;
		if self.recurValue = null then
			app.raiseCMWarning(Input_required_field_RecrFld,null, null, self); 
		endif;
		
		if self.recurValue.Integer &lt; 1 or self.recurValue.Integer &gt; 12 then
			app.raiseCMException(Error_RecurringValueAutoSched, 'Problem with recurring value',  self);		
		endif;
		// jlgka1 TFS 43863 &lt;--
	elseif self.selectionState = State_Day then
		if not self.startScheduleTs.isValid then
			app.raiseCMWarning1(AutoScheduleDateError, 'Start date/time needs revising',  null, null, self);	
		endif;
		if self.allRunDays.size &lt;&gt; 7 then
			app.raiseCMWarning1(AutoScheduleDateError, 'Need 7 days of week',  null, null, self);	
		endif;
		
		if not self.allRunDays.includes(true) then
			app.raiseCMWarning1(AutoScheduleDateError, 'Need to select at least one day', null, null, self);
		endif;
		if self.endScheduleTs &lt;&gt; null and not self.endScheduleTs.isValid then
			app.raiseCMWarning1(AutoScheduleDateError, 'End date/time needs revising',  null, null, self);	
		endif;
	elseif self.selectionState = State_Time then
		if not self.startScheduleTs.isValid then
			app.raiseCMWarning1(AutoScheduleDateError, 'Start date/time needs revising',  null, null, self);	
		endif;
		if self.recurValue = null then
		//	app.raiseCMWarning1(REQUIRED_FIELD,  'Recur Value',null, null, self);		
			app.raiseCMWarning(Input_required_field_RecrFld,null, null, self); // cnwdb2	PAR 35364
		endif;
	
		if self.recurUnit = null then
	//		app.raiseCMWarning1(REQUIRED_FIELD,  'Recur Type',null, null, self);		
			app.raiseCMWarning(Input_required_field_rcrType,null, null, self); // cnwdb2	PAR 35364


		endif;
	elseif self.selectionState = State_Event then
		if self.eventDataType &lt;&gt; EventDataVoyage and
		   self.eventDataType &lt;&gt; EventDataInvoicing and
		   self.eventDataType &lt;&gt; EventDataVVR then		// 9/3/18 MAP TFS37340
		//	app.raiseCMWarning1(REQUIRED_FIELD, 'Event Data Type', null, null, self);
			app.raiseCMWarning(Input_required_field_eventData, null, null, self); // cnwdb2	PAR 35364


		endif; 
		// Don't want to check the end time.
		return;
	endif;
	if not checkEndTime then
		app.raiseCMWarning1(AutoScheduleDateError, 'End date/time needs revising',  null, null, self);	
	endif;
	
	me := self.pxyGetRealObject();
	
	foreach task in self.allAutoTasks do
		if not task.onlyBeOnOneScheduleTest() then
			foreach schedule in task.allAutoSchedules do
				if schedule &lt;&gt; me then
					str := schedule.description;
					//app.raiseCMWarning2(DuplicateItem, 'Task ' &amp; task.description, ' Schedule ' &amp; str, null,null, self); //10.06.2022 navds20 TFS 53760
					//Task_already_exists_schedul: Task %1 already exists for Schedule %2
					app.raiseCMWarning2(Task_already_exists_schedul,task.description, str, null,null, self); //10.06.2022 navds20 TFS 53760
					break;
				endif;
			endforeach;
		endif;
		//07 May 2021	NDL	TSF 50906
		if task.isKindOf( CM_AutoTaskLocationActivityBal ) then
			task.CM_AutoTaskLocationActivityBal.validateFrequency( self );
		endif;
	endforeach;
	
epilog
	delete termIter; 			// TFS 50946
	delete yaIter; 				// TFS 50946
end;</source>
    </JadeMethod>
</Class>
