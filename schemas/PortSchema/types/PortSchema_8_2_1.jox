        <source>specificPreStandard(pControllerObj: CnEcReleaseController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Nov 2012	cnwpjs1	Initial creation  PAR #30631 - Voyage Rationalisation

*/

vars

begin
	inheritMethod(pControllerObj);
	
	//specific stuff here
	
	migrateVoyagePermissions;

epilog

end;</source>
        <Parameter name="pControllerObj" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateCAMSTimestamp" id="bcc87e92-1ca6-47eb-9cf3-8b25ffd0bf30">
        <source>updateCAMSTimestamp(_controller :CnEcReleaseController; _file :File);
/*
Date			Who		Reason
10 Dec 2012		cnwcs5	Initial creation - CCMS 1294 / par 30855
*/
vars
	terminal	:CM_Terminal;
	upgrader	:CM_ObjectUpgraderCAMSTrx;
	str			:String;
begin	
	foreach terminal in app.myRoot.allTerminals do	
		// set terminal config opyion for Messina only
		if app.myRoot.isClientMessina then
			str	:= 'Setting Messina terminal config option';
			
			self.logMessage(str, _controller, _file);
			
			terminal.setConfig (CamsCreateTrxAudit, true);
		endif;
		/// so we are re-runnable make sure we dont already have an upgrader for this terminal	
		upgrader := null;
		
		foreach upgrader in CM_ObjectUpgraderCAMSTrx.instances do
			if upgrader.myTerminal = terminal then
				break;
			endif;
			
			upgrader := null;
		endforeach;
		
		if upgrader = null then
			str	:= 'Creating upgrader object for ' &amp; terminal.code;
			self.logMessage(str, _controller, _file);
			
			// create an upgrader object for the terminal
			beginTransaction;
			create upgrader persistent;
		
			upgrader.setTerminal (terminal);
			commitTransaction;
		endif;
		
		// perform 1st step of upgrade
		str	:= 'Running initial conversion for ' &amp; terminal.code;
		self.logMessage(str, _controller, _file);
			
		upgrader.runConversion (self, CM_ObjectUpgraderCAMSTrx.STYLE_INITIAL_CONVERSION);
	endforeach;
epilog
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="updateCargoTypeEntTables" id="68656c12-64fd-47f8-8318-70f5a0baa07e">
        <source>updateCargoTypeEntTables();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2013	cnwer1	Initial creation CCMS DPH 2274

*/

vars
	iter : Iterator;
	cargoType : CM_CargoType;
	root : CM_Root;
	
begin
	root := CM_Root.firstInstance;
	
	iter:=root.allCargoTypesById.createIterator;
	
	root.allCargoTypesById.startKeyGeq(TI_CargoBOLType_Max,iter);
	
	app.writeLog ('Updating User Cargo Types ent table defs', LogINFO);
	
	while iter.next(cargoType) do	
		if  cargoType.isSystemCargoBOLType then
			continue;
		endif;
		
		beginTransaction;
		cargoType.sendMsgWithParams(CM_CargoType::setProxyProductType.name,cargoType.productType);
		commitTransaction;
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="upgradeCoparnRulesExtraData" id="bfcfcee3-3669-432a-92ba-0110aa40641d">
        <source>upgradeCoparnRulesExtraData() protected;
/*
Date		Who		Reason
30 April 2013	cnwcs5	Initial Creation - par 31257
*/
constants
	ExtraData_BlockDelActioned = 'ExtraData_BlockDelActioned';
	ExtraData_BlockDelArchived = 'ExtraData_BlockDelArchived';
	ExtraData_BlockDelCompleted = 'ExtraData_BlockDelCompleted';
	ExtraData_BlockUpdActioned = 'ExtraData_BlockUpdActioned';
	ExtraData_BlockUpdArchived = 'ExtraData_BlockUpdArchived';
	ExtraData_BlockUpdCompleted = 'ExtraData_BlockUpdCompleted';
	ExtraData_DefaultReleaseStatus = 'ExtraData_DefaultReleaseStatus';
	ExtraData_ResetCompleted = 'ExtraData_ResetCompleted';
vars
	rules	:CM_EDIPartyCoparnRules;
	value	:Integer;
begin
	beginTransaction;
	// ok to use instances when we know there is no other DB updating taking place
	foreach rules in CM_EDIPartyCoparnRules.instances do
		if rules.allExtraData.isEmpty then
			// nothing to do
			continue;
		endif;
		
		global.getExtraData (rules.allExtraData, ExtraData_BlockDelActioned, value);
		rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelActioned.name, value.Boolean);
		
		global.getExtraData (rules.allExtraData, ExtraData_BlockDelArchived, value);
		rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelArchived.name, value.Boolean);
		
		global.getExtraData (rules.allExtraData, ExtraData_BlockDelCompleted, value);
		rules.setPropertyValue (CM_EDIPartyCoparnRules::allowDelCompleted.name, value.Boolean);
		
		global.getExtraData (rules.allExtraData, ExtraData_BlockUpdActioned, value);
		rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdActioned.name, value.Boolean);
		
		global.getExtraData (rules.allExtraData, ExtraData_BlockUpdArchived, value);
		rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdArchived.name, value.Boolean);
		
		global.getExtraData (rules.allExtraData, ExtraData_BlockUpdCompleted, value);
		rules.setPropertyValue (CM_EDIPartyCoparnRules::allowUpdCompleted.name, value.Boolean);
		
		global.getExtraData (rules.allExtraData, ExtraData_ResetCompleted, value);
		rules.setPropertyValue (CM_EDIPartyCoparnRules::resetCompletedOnQtyIncrease.name, value.Boolean);
		
		global.getExtraData (rules.allExtraData, ExtraData_DefaultReleaseStatus, value);
		rules.setPropertyValue (CM_EDIPartyCoparnRules::defaultReleaseStatus.name, value);
		
		// clear out all extra data
		rules.allExtraData.purge;
	endforeach;
	
	commitTransaction;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="upgradeTrailerTypes" id="a6cd32ed-9285-4b50-8c23-26fb32aa5f20">
        <source>upgradeTrailerTypes() protected;
/*
Date		Who		Reason
05 Dec 2012	cnwcs5	Initial creation - par 30852
*/
vars
	code		:String;
	type		:CM_TILCType;
	typeSet		:CM_TILCTypeSet;
	item		:CM_BookingRefItem;
	release		:CMGTE_Release;
	chassis		:CMGTE_TILC;
	classColl	:ClassColl;
	cls			:Class;
	obj			:Object;
begin
	//	*** WIP ***
	create typeSet transient;
	
	CM_TILCType.instances.copy (typeSet);
	
	if typeSet.size = 0 then
		// nothing to do
		return;
	endif;
	
	// I think there will be fewer CMGTE_TILC than CMGTE_Release or CM_BookingRefItem
	foreach chassis in CMGTE_TILC.instances do
		type := chassis.myTILCType;
		
		if type = null then
			continue;
		endif;
		
		if typeSet.includes (type) then 
			typeSet.remove (type);
			
			if typeSet.size = 0 then
				break;
			endif;
		endif;
	endforeach;
	
	if typeSet.size = 0 then
		// nothing to do
		return;
	endif;
	
	foreach release in CMGTE_Release.instances do
		type := release.myTILCType;
		
		if type = null then
			// this will be most of them
			continue;
		endif;
		
		if typeSet.includes (type) then 
			typeSet.remove (type);
			
			if typeSet.size = 0 then
				break;
			endif;
		endif;
	endforeach;
	
	if typeSet.size = 0 then
		// nothing to do
		return;
	endif;
	
	create classColl transient;
	
	CM_BookingRefItem.allSubclasses (classColl);
	
	foreach cls in classColl do
		foreach obj in cls.instances do
			item := obj.CM_BookingRefItem;
			type := item.myTrailerType;
			
			if type = null then
				// this will be most of them
				continue;
			endif;
			
			if typeSet.includes (type) then 
				typeSet.remove (type);
				
				if typeSet.size = 0 then
					break;
				endif;
			endif;
		endforeach;
	endforeach;
	
	// type set now includes those types that have no non-inversed references
	beginTransaction;
	foreach type in typeSet do
		type.setPropertyValue (CM_TILCType::hasNoNonInversedUsages.name, true);
	endforeach;
	commitTransaction;
epilog
	delete typeSet;
	delete classColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
