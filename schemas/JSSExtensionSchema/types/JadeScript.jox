    </JadeMethod>
    <JadeMethod name="cnwdad1_ListCategoryConstants" id="02ac1228-6668-478f-8709-e3a454430b31">
        <source>cnwdad1_ListCategoryConstants(pCategoryName:String);
// --------------------------------------------------------------------------------
// Created:		16 July 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allConstants	: ConstantNDict;
	theConstant		: Constant;

begin
	global.jssGetConstants(pCategoryName, allConstants);

	if allConstants &lt;&gt; null and (allConstants.jssIsNotEmpty()) then
		foreach theConstant in allConstants do
			write '"' &amp; pCategoryName &amp; '","' &amp; theConstant.name &amp; '","' &amp; theConstant.getSource() &amp; '"';
		endforeach;
	endif;
end;</source>
        <Parameter name="pCategoryName" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnwdad1_List_Class_Properties" id="392d1ef9-7177-4eef-8bb7-e94aa8a49d6e">
        <source>cnwdad1_List_Class_Properties();

vars
	theClass		: Class;
	theProperty		: Property;
	displayValue	: String;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	theClass	:=	JadeUserProfile;
	write theClass.name &amp; " Properties:" &amp; CrLf;
	
	foreach theProperty in theClass.allProperties() do
		displayValue	:=	theProperty.name &amp;
							" (" &amp; theProperty.type.name &amp; ")";
		
		if theProperty.isSystemObject() then
			displayValue	:=	displayValue &amp; " ***JADE***";
		endif;
		
		write displayValue;
	endforeach;
epilog
	write CrLf &amp; "Class Property list completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
