    <JadeMethod name="do715ConversionForOperators" id="65c886ea-2c06-4932-a84f-021268893d0f">
        <source>do715ConversionForOperators(pController: CnEcReleaseController);
// ---------------------------------------------------------------------------
// Created:     16 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	t	: CM_Terminal;
	op	: CM_Operator;

begin

	foreach t in CM_Terminal.instances do
		pController.logEntry('Converting operators for terminal ' &amp; t.code);

		foreach op in CM_Operator.instances do
			pController.logEntry('    - converting ' &amp; op.code);
//			op.createOperatorTermsForUpgrade(t);
		endforeach;
	endforeach;
	
end;</source>
        <Parameter name="pController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="doEventTransIntegrityCheck" id="e81acc1c-38a9-4c36-8780-d556986aab69">
        <updating/>
        <source>doEventTransIntegrityCheck(_controller: CnEcReleaseController) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	eventTrans			: CM_EventTransaction;
begin
	foreach eventTrans in app.myRoot.allEventsByDateTime do
		//validation should ensure this doesn't happen, but putting this in anyway
		if eventTrans.myTerminal &lt;&gt; null then
			_controller.logEntry('Event transaction reference integrity violation:' &amp; eventTrans.String);
			beginTransaction;
			eventTrans.setPropertyValue('myRoot', null);
			commitTransaction;
		endif;
	endforeach;

end;


</source>
        <access>protected</access>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixCMQFinvalidObjs" id="24df4401-c467-47dd-9f84-9d5052425d1c">
        <source>fixCMQFinvalidObjs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	schema : Schema;
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	
	propColl : PropertyColl;
	iterProp : Iterator;
	prop : Property;
	ref : Reference;
	collClass : CollClass;
	effectedClass : Type;
	
	iterClassInst : Iterator;
	classInstance : Object;
	propertyValueObject : Object;
	
	errorMess : String;
	invalid : Boolean;
	edition : Integer;
	
	collPropObjectsIter : Iterator;
	collection : Collection;
	
begin

	//get a collection of all of the classes in PortSchema so we can find all of the CMQF_FilterReports sub classes
	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;	
	classColl := schema.getAllClasses(false);
	
	on Exception do app.handleDeletedObject( exception, propertyValueObject, invalid );

	iterClass := classColl.createIterator;
	// iterate thru each of the classes.
	while iterClass.next( class ) do
		if not class.inheritsFrom( CMQF_FilterReports ) then
			//not a class we care about
			continue;
		endif;
		
		//get a collection of the properties on this class, so we can find all of the non-inversed references and collections to check
		propColl := class.allPropertiesUpTo(CMQF_FilterReports);
		iterProp := propColl.createIterator;
		while iterProp.next ( prop ) do
			if not prop.isKindOf(Reference) then
				// this property is not an object or a collection
				continue;
			endif;
			ref := prop.Reference;
			if ref.isKindOf(ExplicitInverseRef) then
				// this one is inversed, it will look after itself
				continue;
			endif;
			
			//Ok we have a non inversed collection or singleton that could cause us grief.
			if ref.getType.inheritsFrom( Collection ) then
				collClass :=  ref.getType.CollClass;
				//This one is a collection
				effectedClass := collClass.getMemberType;
				
				if effectedClass = null or effectedClass.isKindOf(PrimType) then
					//string arrays, integer arrays etc, can be created as references, but we are not interested in them.
					continue;
				endif;
				//should be a collection of objects
				iterClassInst := class.instances.createIterator;
				while iterClassInst.next( classInstance ) do
					invalid := false;
					collection := classInstance.getPropertyValue( ref.name ).Collection;
					if collection = null or collection.isEmpty then
						continue;
					else
						collPropObjectsIter := collection.createIterator;
						while collPropObjectsIter.next( propertyValueObject ) do
							edition := propertyValueObject.edition;
							if invalid then
								break;
							endif;
						endwhile;
						delete collPropObjectsIter;
						if invalid then
							beginTransaction;
							collection.removeInvalidObjects();
							commitTransaction;
						endif;
					endif;
				endwhile;
				delete iterClassInst;
				
			else
				//should be a singleton reference
				iterClassInst := class.instances.createIterator;
				while iterClassInst.next( classInstance ) do
					invalid := false;
					propertyValueObject := classInstance.getPropertyValue( ref.name ).Object;
					if propertyValueObject = null then
						continue;
					else
						edition := propertyValueObject.edition;
						if invalid then
							beginTransaction;
							classInstance.setPropertyValue( ref.name, null );
							commitTransaction;
						endif;
					endif;
				endwhile;
				delete iterClassInst;
			endif; 
			
		endwhile;
		delete iterProp;
		delete propColl;
		
	endwhile;
	
epilog

	delete classColl;
	delete iterClass;
	delete iterProp;
	delete iterClassInst;
	delete collPropObjectsIter;
	delete propColl;

end;</source>
    </JadeMethod>
    <JadeMethod name="getCamTriggerFields" id="72044cbf-eef4-45f4-a605-a43840d834f5">
        <source>getCamTriggerFields(_fields: CM_FieldByTypeSysNameDict input; _fieldClass: Class);

