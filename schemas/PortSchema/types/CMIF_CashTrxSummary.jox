    <JadeMethod name="addCMIFReceipt" id="bcee0b77-09f0-4c1e-b180-6b2c6c6a4452">
        <updating/>
        <source>addCMIFReceipt( cashReceipt : CM_CashReceipt ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	cmifReceipt : CMIF_CashReceipt;

begin

	create cmifReceipt transient;
	cmifReceipt.setBaseDetails( cashReceipt, self );
	self.allCashReceipts.add(cmifReceipt);		// 33161
	
	///self.incrementBalanceAtToDate( cmifReceipt.cashValue );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="cashReceipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="addDebtorTerminal" id="9c569944-1e7c-41c8-99ef-0f532a7d7a69">
        <updating/>
        <source>addDebtorTerminal( _drTerm : CM_DebtorTerminal ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 /08/2012	cnwndl1	Initial creation	Par 29968
19/05/2014	cnwjre1	34142 CCMS 2348 financial reporting remove opening, closing balance, refunds and journals as pre-payments are no longer used.
31/01/202   cnwma1 ChangeRequest 48428: JMT - Refactor Deleting Unused Cash Classes
*/

vars

	doFromDateCheck  : Boolean;
	doToDateCheck    : Boolean;
	iter 			 : Iterator;
	cash 			 : CM_Cash;
	receipt 		 : CM_CashReceipt;
	payment          : CM_CashPayment;
begin

	if _drTerm = null then
		return;
	endif;
	
	doFromDateCheck := fromDate.isValid;
	doToDateCheck   := toDate.isValid;
	
	iter := _drTerm.allConsolidatedCashTrx.createIterator;
	while iter.next( cash ) do
		if doFromDateCheck and cash.dateTime.Date &lt; self.fromDate then
			///self.addHistory( openingBalance, cash );
		elseif doToDateCheck and cash.dateTime.Date &gt; self.toDate then
			break; // post-dates the range we are considering
		else
			if cash.isReceipt then
				self.addCMIFReceipt( cash.CM_CashReceipt );
			elseif cash.isProformaPayment then
				self.addCMIFProforma( cash.CM_CashPayment );
			elseif cash.isPayment then
				self.addCMIFPayment( cash.CM_CashPayment );
			endif;
		endif;
	endwhile;
	delete iter;

	iter := _drTerm.allCashReceipts.createIterator;
	
	while iter.next( receipt ) do
		if doFromDateCheck and receipt.dateTime.Date &lt; self.fromDate then
			///self.addHistory( openingBalance, receipt );
		elseif doToDateCheck and receipt.dateTime.Date &gt; self.toDate then
			break; // post-dates the range we are considering
		else
			self.addCMIFReceipt( receipt ); 
		endif;
	endwhile;
	
	delete iter;
	

	
	iter := _drTerm.allCashPayments.createIterator;
	while iter.next( payment ) do
		if doFromDateCheck and payment.dateTime.Date &lt; self.fromDate then
			///self.addHistory( openingBalance, payment );
		elseif doToDateCheck and payment.dateTime.Date &gt; self.toDate then
			break; // post-dates the range we are considering
		else
			if payment.isProformaPayment then
				self.addCMIFProforma( payment );
			else
				self.addCMIFPayment( payment ); 
			endif;
		endif;
	endwhile;
	delete iter;
	

epilog

	delete iter;

end;</source>
        <Parameter name="_drTerm" type="CM_DebtorTerminal"/>
    </JadeMethod>
    <JadeMethod name="clear" id="439aae4d-7ab7-438c-bad0-531a59b54cb4">
        <updating/>
        <source>clear() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	if not self.allCashTransactions.isEmpty then
		self.allCashTransactions.purge();
	endif;
	self.allCashReceipts.clear();
	
	self.allSelectedDebtorTerminals.clear();
	self.allFilterDebtors.clear();
	self.allFilterTerminals.clear();
	
	self.balanceAtToDate := 0.0;
	
	self.fromDate := null;
	
	self.toDate := null;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getFilterDebtorString" id="3aafd5ec-625f-4432-abc4-5f7c0bed26bf">
        <source>getFilterDebtorString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	str : String;
	dr : CM_Debtor;

begin

	if self.allFilterDebtors.isEmpty then
		str := Any_String;
	else
		foreach dr in self.allFilterDebtors do
			if str &lt;&gt; null then
				str := str &amp; "," &amp; dr.name;
			else
				str := dr.name;
			endif;
		endforeach;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFilterTerminalString" id="32db6fb4-2e88-4468-9032-b3a9b34c2714">
        <source>getFilterTerminalString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2012	cnwndl1	Initial creation	Par 29968


*/

vars

	str : String;
	term : CM_Terminal;

begin

	if self.allFilterTerminals.isEmpty then
		str := Any_String;
	else
		foreach term in self.allFilterTerminals do
			if str &lt;&gt; null then
				str := str &amp; "," &amp; term.code;
			else
				str := term.code;
			endif;
		endforeach;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="incrementBalanceAtToDate" id="6ace3857-48aa-47fc-9792-8b7ca1076438">
        <updating/>
        <source>incrementBalanceAtToDate( _increment : Decimal ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2012	cnwndl1	Initial creation

*/

vars

begin

	self.balanceAtToDate := balanceAtToDate + _increment;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_increment" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setDates" id="2caa4743-b880-4dff-b2ca-369126427fc5">
        <updating/>
        <source>setDates( _fromDate : Date; _toDate : Date ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.fromDate := _fromDate;
	self.toDate   := _toDate;

epilog

end;</source>
