    <JadeMethod name="setColorsFromController" id="ae803e04-8603-4d22-9b1a-4a1f9849611a">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	
	self.frmLockDetails.backColor	:= self.backColor;
	self.grfLocks.backColor			:= self.colorControlBack;
	
	self.tblNodes.backColor := self.colorControlBack;
	self.tblNodes.accessRow(1).backColor := self.colorHeadingColumn;

	self.tblLocks.backColor := self.colorControlBack;
	self.tblLocks.accessRow(1).backColor := self.colorHeadingColumn;
	
	self.graphColor1	:= Blue;
	self.graphColor2	:= LightGreen;

end;</source>
