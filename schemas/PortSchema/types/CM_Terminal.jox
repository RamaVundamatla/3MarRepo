    <JadeMethod name="lookupTrailerPrenote" id="7791ab88-aa7c-4e93-9210-7dbaf79107b6">
        <source>lookupTrailerPrenote(_id : String; _cargoType : Integer) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     14 May 2014 by cnwer1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

