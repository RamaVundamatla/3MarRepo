    <JadeMethod name="getValueForObject" id="a7f7a89b-f6ae-449f-97ea-8a85bd8681cc">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars

begin
	if _obj.isKindOf(CM_Container) then
		return _obj.CM_Container.getFlatRackStatus;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
