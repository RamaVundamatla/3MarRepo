    <JadeMethod name="timerEvent" id="43a7662a-9370-47ff-921d-b4ca37989742">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if eventTag = Timer_Refresh then
		self.timerRefreshActive := false;
		self.updateTableElapsedTimes(true);
		self.beginTimerForRefresh();
	endif;
	
epilog

end;</source>
