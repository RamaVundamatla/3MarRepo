<Class name="CMQF_ImportsDel" id="ad9bdae9-8524-49e2-8d98-14cac84f291e">
    <superclass name="CMQF_Import"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="a831a3ad-f905-4401-bf01-ddab9ccfee09">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	tran			: CM_TITransaction;
	col				: CM_TITransactionByDateTypeDict;
	terminal		: CM_Terminal;
	endDateTime		: TimeStamp;
	breakOut		: Boolean;
begin
	endDateTime.setTime("23:59:59".Time);
	endDateTime.setDate(self.endDate);

	create col transient;
	//search for receivals
	foreach terminal in self.allTerminals do
		terminal.getTITxnsForTypeAll(TRANS_TYPE_RELEASE, self.startDate.TimeStamp, endDateTime, null , self ,col );
	endforeach;


	foreach tran in col do
		ti := tran.myTrackedItem;
		if ti &lt;&gt; null then		
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					self.doStats(ti);
				endif;
			endif;
		endif;
//		if breakOut then
//			return;
//		endif;
	
	endforeach;

epilog

	delete col;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="813f44fb-ac10-4017-81f4-269b52de6a68">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if (not _ti.isEmpty) and 
	inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
