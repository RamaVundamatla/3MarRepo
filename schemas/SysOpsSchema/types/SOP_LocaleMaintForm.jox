    <JadeMethod name="selectLocale" id="bddb962e-681e-41ef-97c3-1b2f5f8d1a21">
        <updating/>
        <source>selectLocale() updating;

vars

begin

	// new selected locale
	myLocale := tblLocales.accessRow(tblLocales.row).itemObject.CM_Locale;
	
	btnDelete.visible		:= true; // TFS 2198
	btnSetDefault.visible 	:= true; // TFS 2198
	self.btnEdit.visible	:= true; // TFS 2198
	
	self.mode := self.Mode_View;
	self.showFieldsForDoNewEdit(false);
	btnNew.visible := true;
	if myLocale = null then
		txtXlationCount.text := null;
		txtKeywordCount.text := null;
		btnDelete.enabled := false;
		btnSetDefault.enabled := false;
		btnEdit.enabled	:= false;
	else
		txtXlationCount.text 	:= myLocale.vTranslationCount.String;
		txtKeywordCount.text 	:= myLocale.vTranslationKeywordCount.String;
 // TFS 2198		btnDelete.visible		:= true;
 // TFS 2198		btnSetDefault.visible 	:= not self.myLocale.isUserDefined();
 // TFS 2198		self.btnEdit.visible	:= self.myLocale.isUserDefined();
	endif;
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		txtXlationCount.text := null;
		txtKeywordCount.text := null;
		btnDelete.enabled := false;
		btnSetDefault.enabled := false;
		btnEdit.enabled	:= false;
		self.btnNew.enabled:= false;
	endif;
	
epilog
	if self.myPxyLocale &lt;&gt; null then	//pxy &lt;&gt; null if pressed Edit and then select another locale in the list
		delete self.myPxyLocale;
	endif;
	self.mode := self.Mode_View;

end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e2b92e5d-5606-4ed5-aa13-b70db392948b">
        <updating/>
        <source>setupForm() updating;

vars

begin
	inheritMethod();

	handleMenusForModalDisplay; // hide menus
	setNavigatorHeading(caption);

	create agent transient;
	
	fillTable;
	loadLocales;
end;</source>
    </JadeMethod>
    <JadeMethod name="showFieldsForDoNewEdit" id="cde50b6e-08ef-4287-ae8c-d6184b77103d">
        <source>showFieldsForDoNewEdit( _show : Boolean ) protected;
/* ---------------------------------------------------------------------------
Created:	04 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.btnSave.visible		:= _show;
	self.cmbLocales.visible		:= _show;
	
	self.chkUserDefined.visible	:= _show;
	self.lblCode.visible		:= _show;
	self.lblDescription.visible	:= _show;
	self.txtCode.visible		:= _show;
	self.txtDescription.visible	:= _show;

	self.txtCode.text			:= null;
	self.txtDescription.text	:= null;

	if self.mode = Mode_Add then
		self.chkUserDefined.value	:= false;	// checkbox "User Defined" is always false by default
		self.doChkUserDefinedClick();	
	elseif self.mode = Mode_Edit then
		self.chkUserDefined.value	:= true;	// checkbox "User Defined" is always true when editting a user defined locale
		self.doChkUserDefinedClick();	
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblLocales_click" id="0de68b9f-9a06-4823-a3f0-3ec3254676de">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLocales_click(table: Table input) updating;

vars

begin
	selectLocale;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblLocales_rowColumnChg" id="79aa429d-63d1-4dde-8e99-e6161ca48881">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLocales_rowColumnChg( table : Table input ) updating;

/*
Date				Who		Reason
06 November 2009	cnwrl1	Initial creation as part of PAR 21193
*/
	
vars
	
begin
	// on row change display the translation summary.
	table.click( table );
	
epilog
	
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8514e9be-d6d9-47fa-aa10-43792b7ba892">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007047, locale);
	btnCancel.translateCaption(Xlat_0004874, locale);
	btnDelete.translateCaption(Xlat_0003855, locale);
	btnEdit.translateCaption(Xlat_0009684, locale);
	btnNew.translateCaption(Xlat_0003856, locale);
	btnSave.translateCaption(Xlat_0004875, locale);
	btnSetDefault.translateBubbleHelp(Xlat_0003852, locale);
	btnSetDefault.translateCaption(Xlat_0003853, locale);
	chkUserDefined.translateCaption(Xlat_0009685, locale);
	grpXlationSumary.translateCaption(Xlat_0004876, locale);
	lConstName.translateCaption(Xlat_0003857, locale);
	label4.translateCaption(Xlat_0003860, locale);
	lblCode.translateCaption(Xlat_0009686, locale);
	lblDescription.translateCaption(Xlat_0009687, locale);
	txtKeywordCount.translateBubbleHelp(Xlat_0003861, locale);
	txtXlationCount.translateBubbleHelp(Xlat_0003862, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="ffb1936b-f0c0-4a4b-a18f-287263add6c3">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars

begin

	delete agent;
	
	if self.myPxyLocale &lt;&gt; null then
		delete self.myPxyLocale;
	endif;
	
	inheritMethod;
end;</source>
    </JadeMethod>
</GUIClass>
