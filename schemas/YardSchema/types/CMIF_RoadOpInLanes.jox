    <JadeMethod name="addVehicleToDataTable" id="b42c11fd-8cd6-4a41-a59c-7f45a00b1c66">
        <source>addVehicleToDataTable(_vehicle: CM_Vehicle input);
/*
Purpose:			
Return Value:		

Date			Who		Reason
22 August 2006	cnwer1	Initial creation - PAR#xxxx
02 Sept 2009	cnwcs1	ccms 1061 - remove old VTA handling
*/
vars
	
begin
	// 25/09/2014 cnwar2 #34333
	if self.myRoadOpController.hideCompletedJobs then
		if not _vehicle.hasIncompleteRoadJobs then
			return;
		endif;
	endif;
	
	inheritMethod(_vehicle);
	
	if self.addDataTableObject(_vehicle) then	// cms10/09/2009
		if CM_GateAreaLaneController.hasInstance(_vehicle.myPrimaryActualLocation) then
			self.removeDataTableObject(_vehicle.myPrimaryActualLocation);
		endif;
	endif;										// cms10/09/2009
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
    </JadeMethod>
