		create proxyDelayTypeGrp transient;
		proxyDelayTypeGrp.setProxyDetails(delayTypeGroup,delayTypeGroup.description,delayTypeGroup.description);
		response.allCodes.add(proxyDelayTypeGrp);
	endwhile;

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up transients
	delete iter;
	
