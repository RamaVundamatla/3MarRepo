        <source>getVoyageCraneQueueMachines(_machines: CM_MachineByIdDict input; _includeCranes : Boolean) protected;
// -------------------------------------------
// Created 30 October 2003 by cnwdvb1
// -------------------------------------------
vars

	craneQueue : CM_RadioTelemetryQueue;
	
begin

	foreach craneQueue in self.allSubQueuesById do
		craneQueue.getPrimaryMachines(_machines, false,_includeCranes);
	endforeach;	


end;</source>
