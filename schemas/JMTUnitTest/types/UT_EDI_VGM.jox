    <JadeMethod name="xVGMCargoFieldUpdateDetails" id="0dd0ce7f-541e-4a87-8241-f64d42e74bd0">
        <source>xVGMCargoFieldUpdateDetails(_format : Integer; _containerId : String) : String;

/*

Purpose:		Various VGM options

Date			Who		Reason
19/05/2016		cnwmh5	Initial creation

*/

vars

	ediText						: String;

begin

	if _format = 1 then
		// set all fields
		ediText := 'ISO Container,' &amp; _containerId &amp; ',,isWeightCertified,Y' &amp; CrLf &amp;
			'ISO Container,' &amp; _containerId &amp; ',,weightCertifiedName,Jack The Ripper' &amp; CrLf &amp;
			'ISO Container,' &amp; _containerId &amp; ',,weightCertifiedReference, Minnie Dean';
	elseif _format = 2 then
		// remove certified name
		ediText := 'ISO Container,' &amp; _containerId &amp; ',,weightCertifiedReference,';	
	else 
		// clear all
		ediText := 'ISO Container,' &amp; _containerId &amp; ',,isWeightCertified,N' &amp; CrLf &amp;
			'ISO Container,' &amp; _containerId &amp; ',,weightCertifiedReference,' &amp; CrLf &amp;
			'ISO Container,' &amp; _containerId &amp; ',,weightCertifiedName,';
	endif;

	return ediText;

epilog

end;</source>
        <Parameter name="_format" type="Integer"/>
        <Parameter name="_containerId" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xVGMCargoOnShipDetails" id="87eb780e-44d9-48c2-ad11-227b631c5da8">
        <source>xVGMCargoOnShipDetails(_format : Integer; _containerId, _voyageId : String) : String;

/*

Purpose:		Various VGM options

Date			Who		Reason
19/05/2016		cnwmh5	Initial creation

*/

vars

	ediText						: String;

begin

	if _format = 1 then
		// set all fields
		ediText := 'ISO Container,' &amp; _containerId &amp; ',Import,AUSYD,,2200,MSK,4500,Y,Jesse James,Billy the Kid,GENL,' &amp; _voyageId &amp;',010482,A';
	elseif _format = 2 then
		// remove certified name
		ediText := 'ISO Container,' &amp; _containerId &amp; ',Import,AUSYD,,2200,MSK,4500,Y,,Billy the Kid,GENL,' &amp; _voyageId &amp;',010482,U';
	elseif _format = 2 then
	else 
		// clear all
		ediText := 'ISO Container,' &amp; _containerId &amp; ',Import,AUSYD,,2200,MSK,4500,,,,GENL,' &amp; _voyageId &amp;',010482,U';
	endif;

	return ediText;

epilog

end;</source>
