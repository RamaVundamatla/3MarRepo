    <JadeMethod name="getAuditProperties" id="6c51b787-23e5-4da6-9a10-e13fca8a00b9">
        <source>getAuditProperties(_otherObject : CM_Object; _action : Integer; _auditItems : ObjectArray io);

vars
	auditItem : CM_AuditItem;
	property : Property;
	popColl : PropertyNDict;
	object : Object;
	propStringBefore : String;
	propStringAfter : String;
begin
	if _auditItems = null then
		return; //should be exception
	endif;
	if _action &lt;&gt; AuditCreated and
	   _action &lt;&gt; AuditDeleted and
	   _action &lt;&gt; AuditUpdated then
		return; //should be exception
	endif;
	create popColl transient;
	self.class.getPropertiesAllSuperclass(popColl);
	foreach property in popColl do
		 if (not self.shouldAuditProperty(self.class, property)) or
		   (property.virtual) or
	       self.getPropertyValue(property.name) = null then
			continue;
		endif;
//		propStringAfter := self.getAuditProperty(property);
		propStringAfter := self.getAuditTextForProperty(property);
		if _otherObject &lt;&gt; null then //object update
			propStringBefore := _otherObject.getAuditProperty(property);
			if propStringAfter &lt;&gt; propStringBefore then
				create auditItem transient;	
				_auditItems.add(auditItem);		
				auditItem.setForCreate(null, property.getName(), propStringBefore, propStringAfter);
			endif;
		else //create or delete
			if propStringAfter &lt;&gt; null then
				create auditItem transient;	
				_auditItems.add(auditItem);	
				if _action = AuditCreated then	
					auditItem.setForCreate(null, property.getName(), null, propStringAfter);
				else
					auditItem.setForCreate(null, property.getName(), propStringAfter, null);
				endif;
			endif;
		endif;
	endforeach;
epilog
	delete popColl;
end;</source>
        <text>Not used as yet.</text>
        <Parameter name="_otherObject" type="CM_Object"/>
        <Parameter name="_action" type="Integer"/>
        <Parameter name="_auditItems" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAuditProperty" id="b21bcb69-3e3e-4760-8275-ef078ed308a9">
        <source>getAuditProperty(_property : Property) : String protected;
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	message : String;
	str : String;
	int : Integer;
	time : Time;
	decimal : Decimal[5,2];
	boolean : Boolean;
	binary : Binary;
	point : Point;
	object : Object;
	coll : Collection;
	iter : Iterator;
	invalid : Boolean;
	
begin
	if _property.isKindOf(Attribute) then
		message := null;		
		if _property.type = StringArray then
			foreach str in self.getPropertyValue(_property.getName).StringArray do
				message := message &amp; str &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = CM_StringArray then
			foreach str in self.getPropertyValue(_property.getName).CM_StringArray do
				message := message &amp; str &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = CM_LabelArray then
			foreach str in self.getPropertyValue(_property.getName).CM_LabelArray do
				message := message &amp; str &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = CM_ConsignCodeArray then
			foreach str in self.getPropertyValue(_property.getName).CM_ConsignCodeArray do
				message := message &amp; str &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = HugeStringArray then
			foreach str in self.getPropertyValue(_property.getName).HugeStringArray do
				message := message &amp; str &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = IntegerArray then
			foreach int in self.getPropertyValue(_property.getName).IntegerArray do
				message := message &amp; int.String &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = CM_IntegerArray then
			foreach int in self.getPropertyValue(_property.getName).CM_IntegerArray do
				message := message &amp; int.String &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = PointArray then
			foreach point in self.getPropertyValue(_property.getName).PointArray do
				message := message &amp; point.String &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = CM_PointArray then
			foreach point in self.getPropertyValue(_property.getName).PointArray do
				message := message &amp; point.String &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = TimeArray then
			foreach time in self.getPropertyValue(_property.getName).TimeArray do
				message := message &amp; time.String &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = DecimalArray then
			foreach decimal in self.getPropertyValue(_property.getName).DecimalArray do
				message := message &amp; decimal.String &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = BinaryArray then
//			foreach binary in self.getPropertyValue(_property.getName).BinaryArray do
//				message := message &amp; binary.String &amp; AuditStringSeparator;
//			endforeach;
		elseif _property.type = BooleanArray then
			foreach boolean in self.getPropertyValue(_property.getName).BooleanArray do
				message := message &amp; boolean.String &amp; AuditStringSeparator;
			endforeach;
		elseif _property.type = Binary then
		else
			message := self.getPropertyValue(_property.getName).String.trimBlanks;
		endif;
	else
		object := self.getPropertyValue(_property.getName()).Object;
		if object &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, object, invalid);
//		   global.isValidObject(object) then
			if object.isKindOf(CM_Object) then
				message := object.CM_Object.auditIdDisplay();
			elseif object.isKindOf(Collection) then
				coll := object.Collection;
				if not coll.isKindOf(VirtualColl) then
					message := null;
					if _property.type = StringArray then
						foreach str in coll.StringArray do
							message := message &amp; str &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = CM_StringArray then
						foreach str in coll.CM_StringArray do
							message := message &amp; str &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = CM_LabelArray then
						foreach str in coll.CM_LabelArray do
							message := message &amp; str &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = CM_ConsignCodeArray then
						foreach str in coll.CM_ConsignCodeArray do
							message := message &amp; str &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = HugeStringArray then
						foreach str in coll.HugeStringArray do
							message := message &amp; str &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = IntegerArray then
						foreach int in coll.IntegerArray do
							message := message &amp; int.String &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = CM_IntegerArray then
						foreach int in coll.CM_IntegerArray do
							message := message &amp; int.String &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = PointArray then
						foreach point in coll.PointArray do
							message := message &amp; point.String &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = CM_PointArray then
						foreach point in coll.PointArray do
							message := message &amp; point.String &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = TimeArray then
						foreach time in coll.TimeArray do
							message := message &amp; time.String &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = DecimalArray then
						foreach decimal in coll.DecimalArray do
							message := message &amp; decimal.String &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = BinaryArray then
						foreach binary in coll.BinaryArray do
							message := message &amp; binary.String &amp; AuditStringSeparator;
						endforeach;
					elseif _property.type = BooleanArray then
						foreach boolean in coll.BooleanArray do
							message := message &amp; boolean.String &amp; AuditStringSeparator;
						endforeach;
					else
						iter := coll.createIterator();
						message := null;
						if iter &lt;&gt; null then
							while (iter.next(object)) do
//								if global.isValidObject(object) and
								if object.isKindOf(CM_Object) then
									message := message &amp; object.CM_Object.auditIdDisplay() &amp; AuditStringSeparator;
								endif;
							endwhile;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
epilog
	delete iter;		// PAR #26678
	return message;
	
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="55f5fe84-d829-41ce-a6f7-b99c27f4e006">
        <source>getAuditText() : String;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Sep 2012	cnwkpd1		PAR #29274 - improve string concatenation performance
// ---------------------------------------------------------------------------
vars
	txt,
	propertyText			: String;
	p 						: Property;
	props 					: PropertyNDict;
	cls 					: Class;
	context : String;	//02 Apr 2019	NDL	TFS 44140
	activeForm : Form;	//02 Apr 2019	NDL	TFS 44140
	activeControl : Control;	//02 Apr 2019	NDL	TFS 44140
			
begin
	txt[10000] := '*';
	txt := null;
	cls := null;
	
	while true do
		if cls = null then
			cls := self.class;
		else
			//cls := cls.getPropertyValue("superclass").Class;
			cls := cls.getSuperclass();
		endif;
		if cls = null then
			break;
		endif;
		cls := cls.rootType;
		if cls = null or cls = CM_Object or cls = Object then
			break;
		endif;

		//props := cls.getPropertyValue("properties").PropertyNDict;
		props := cls.getProperties;
		if props = null or props.isEmpty then
			continue;
		endif;
		
		foreach p in props do
			if not self.shouldAuditProperty(cls, p) then
				continue;
			endif;

			// PAR #29274 - separate to two lines of code for more efficient String concatenation
			propertyText := self.getAuditTextForProperty(p);
			txt := txt &amp; propertyText;
		endforeach;
	endwhile;
	
/*	//02 Apr 2019	NDL	TFS 44140
	if app.applicationType = app.ApplicationType_GUI then
		activeForm := app.activeForm();
		if activeForm &lt;&gt; null then
			context := activeForm.name;
		else
			if app.name = HandHeldApp
			or app.name = VehicleMountedApp
			or app.name = VehicleMountedWithDevice1
			or app.name = HandHeldWithDevApp1
			then
				context := app.getHandHeldCurrentFormName();
			endif; 
		endif;
		if context = null then
			activeControl := app.activeControl();
			if activeControl &lt;&gt; null then
				activeForm := activeControl.form;
				if activeForm &lt;&gt; null then
					context := activeForm.name;
				endif;
			endif;
		endif;
	elseif app.isWebApp then
		context := app.name;
	endif; */
	context := app.getCurrentContextForAudit();	//03 Feb 2021	NDL	TFS 50152
	if context &lt;&gt; null then
		propertyText := self.formatAuditText(CM_AuditObject.CallingFormContext,context);
		txt := txt &amp; propertyText;
	endif;
	
	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForHugeStringArray" id="b63f59c2-a0ce-4e24-8b41-a4917ca91e7c">
        <source>getAuditTextForHugeStringArray(_hugeStringArray : HugeStringArray) : String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 29 March 2019
TFS#		: 44020
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	rtnStr		: String;
	stringValue	: String;
begin
	rtnStr[10000] := '*';
	rtnStr := null;
	
	foreach stringValue in _hugeStringArray do
		if stringValue &lt;&gt; null then
			rtnStr := rtnStr &amp; ',' &amp; stringValue;
		endif;
	endforeach;
	
	if rtnStr.length &gt;= 2 then
		// remove leading comma
		rtnStr := rtnStr[2:end];
	endif;
	
	return rtnStr;

end;</source>
        <Parameter name="_hugeStringArray" type="HugeStringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="876d36e1-b769-402e-9cf7-899432f9b5ce">
        <source>getAuditTextForProperty(_property : Property) : String;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27 Apr 2009	cnwkpd1		PAR #19543 - replace global.isValidObject with 
//							exception handler for performance
// ---------------------------------------------------------------------------

constants
	AuditNullString		: String = AuditStringSeparator &amp; '4' &amp; AuditStringSeparator &amp; 'null' &amp; AuditStringSeparator;

vars
	rootCls				: Class;
	propName,
	txt, 
	s					: String;
	typ 				: Type;
	obj 				: Object;
	d 					: Date;
	t 					: Time;
	ts 					: TimeStamp;
	invalidObject		: Boolean;
			
begin
	typ := _property.type;
	if typ = null then
		return null;
	endif;
	
	propName := _property.name;

	if typ = String then//most common check first
		s := self.getPropertyValue(propName).String.trimRight;
		txt := self.formatAuditText(propName, s);
	elseif typ = Boolean then
		// s := self.getPropertyValue(propName).Boolean.cnEcGetYesNo;
		// This has been done deliberately for performance reasons as the
		// call to cnEcGetYesNo uses a translatable string.  If a translation
		// is required then this should be done when the value is retrieved 
		// for display purposes
		if self.getPropertyValue(propName).Boolean then
			s := AuditStringValue_Yes;
		else
			s := AuditStringValue_No;
		endif;
		txt := self.formatAuditText(propName, s);
		
	elseif typ = Date then
		d := self.getPropertyValue(propName).Date;
		if d = null or (not d.isValid) then
			s := "null";
		else
			s := d.String;
		endif;
		txt := self.formatAuditText(propName, s);
		
	elseif typ = Time then
		t := self.getPropertyValue(propName).Time;
		if not t.isValid then
			s := "null";
		else
			s := t.String;
		endif;
		txt := self.formatAuditText(propName, s);
		
	elseif typ = TimeStamp then
		ts := self.getPropertyValue(propName).TimeStamp;
		if ts = null or (not ts.isValid) then
			s := "null";
		else
			s := ts.String;
		endif;
		txt := self.formatAuditText(propName, s);
		
	//th2 moved this condition aft as it might be a minority case, so only do the isKindOf if necessary
	elseif typ.isKindOf(Class) then
		rootCls := typ.rootType.Class;
		if rootCls &lt;&gt; null then
			if (rootCls = CM_Object or 
			   rootCls.inheritsFrom(CM_Object)) /*and
			   app.myAA.isAnAuditedClass(rootCls) removed 20May03 - rjs */
			   then
				obj := self.getPropertyValue(propName).Object;
				if obj = null then
					txt := propName &amp; AuditNullString;	//":4:null:";
				else
					on Exception do app.handleDeletedObject(exception, obj, invalidObject);		// PAR #19543
					s := obj.CM_Object.auditIdDisplay;
					if invalidObject then 														// PAR #19543
						txt := propName &amp; AuditNullString;	//":4:null:";
					else
						txt := self.formatAuditText(propName, s);
					endif;
				endif;
			elseif (rootCls = CM_ObjectArray or
			   rootCls.inheritsFrom(CM_ObjectArray)) then
				obj := self.getPropertyValue(propName).Object;
				if obj = null then
					txt := propName &amp; AuditNullString;	// ":4:null:";
				else
					s := obj.CM_ObjectArray.auditIdDisplay();
					if s = null then
						txt := propName &amp; AuditNullString;	// ":4:null:";
					else
						txt := self.formatAuditText(propName, s);
					endif;
				endif;
			elseif (rootCls = CM_MemberKeyDictionary or
			   rootCls.inheritsFrom(CM_MemberKeyDictionary)) then
				obj := self.getPropertyValue(propName).Object;
				if obj = null then
					txt := propName &amp; AuditNullString;	//":4:null:";
				else
					s := obj.CM_MemberKeyDictionary.auditIdDisplay();
					txt := self.formatAuditText(propName, s);
				endif;
			//else
			
			endif;
		endif;
	elseif typ &lt;&gt; Binary then
		s := self.getPropertyValue(propName).String.trimRight;
		txt := self.formatAuditText(propName, s);
	endif;

	return txt;
	
end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForStringArray" id="9640f928-9866-40b1-8c80-fcd42c5fe81f">
        <source>getAuditTextForStringArray(_sa : StringArray) : String;
// ---------------------------------------------------------------------------
// Created:     04 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnStr,
	s		: String;

begin
	rtnStr[10000] := '*';
	rtnStr := null;
	
	foreach s in _sa do
		if s &lt;&gt; null then
			rtnStr := rtnStr &amp; ',' &amp; s;
		endif;
	endforeach;
	
	if rtnStr.length &gt;= 2 then
		// remove leading comma
		rtnStr := rtnStr[2:end];
	endif;
	
	return rtnStr;

end;</source>
        <Parameter name="_sa" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextKnownProperty" id="3d853a61-3ebd-4b37-9f30-583e229a67f3">
        <source>getAuditTextKnownProperty(_props : PropertyNDict) : String;
/*
Purpose:	Use this if you know the properties that have been changed, or if you only want to target certain properties.
				Performance enhancement

Date		Who		Reason
13 March 2024	navab1	BUG 62926
*/

vars
	txt,
	propertyText			: String;
	p 						: Property;
			
begin
	txt[10000] := '*';
	txt := null;
		
	foreach p in _props do
		propertyText := self.getAuditTextForProperty(p);
		txt := txt &amp; propertyText;
	endforeach;

	return txt;

epilog

end;</source>
        <Parameter name="_props" type="PropertyNDict"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCreatedTimeLocalTZ" id="8f8b0d6e-9790-4fd1-9ca2-494bd0c3d09a">
