app.writeLog("jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' '&amp;self.String, 0);	
	self.zCheckOutput(protocol, theLines, self.zCICS1007_output);
epilog
	delete trxColl;
	delete theLines;
end;</source>
