    <JadeMethod name="displayRow" id="16d17a13-b85c-4ea5-8b5c-48e0bad17bd3">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io): String updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		04 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(table, theSheet, obj, theRow, bcontinue);
	
	if self.isCriteria then
		return obj.CM_YACriteria.getListDisplay();
	else
		return obj.CM_YABlock.getListDisplay();
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setYAControl" id="632e7b6e-38f0-4681-9b2a-7e645b1bb113">
        <updating/>
        <source>setYAControl(pYAControl:CMUI_YardAllocationControl; pIsCriteria:Boolean; pIsBlocks:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		15 March 2005 by cnwdad1
//
// Purpose:		Sets a reference to the owning Yard Allocation control.
//
// Parameters:	pYAControl - A reference to the Yard Allocation control.
//				pIsCriteria - True if the table will display Yard Allocation Criteria.
//				pIsBlocks - True if the table will display Yard Allocation Blocks.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myYAControl	:=	pYAControl;
	self.isCriteria		:=	pIsCriteria;
	self.isBlocks		:=	pIsBlocks;
end;</source>
        <Parameter name="pYAControl" type="CMUI_YardAllocationControl"/>
        <Parameter name="pIsCriteria" type="Boolean"/>
        <Parameter name="pIsBlocks" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="cc595099-243d-4da7-ade2-e8dd087aa670">
        <controlMethod name="CM_BaseTable::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	self.setMargins();

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
