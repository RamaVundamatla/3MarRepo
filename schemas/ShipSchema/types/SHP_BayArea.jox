    <JadeMethod name="isLastRowAHatchLidRow" id="582f27ff-9e0a-4d7e-8b09-ad22de1a3668">
        <source>isLastRowAHatchLidRow(_lastRow	 : CMUI_GridRow output) : Boolean;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	isLidRow : Boolean;
	lastRow			: CMUI_GridRow;
	aPoint : CMUI_GridPoint;
begin
	// work out if the last row is a hatch lid row
	isLidRow := false;
	if self.isKindOf(SHP_BayAreaAboveDeck) then
		lastRow := self.allGridRows.last;
		if lastRow &lt;&gt; null then
			aPoint := lastRow.allGridPointsByColumn.first;
			if aPoint &lt;&gt; null then
				isLidRow := aPoint.isKindOf(SHP_LidPoint);
			endif;
		endif;
	endif;
	_lastRow := lastRow;
	return isLidRow;
end;</source>
        <Parameter name="_lastRow" type="CMUI_GridRow" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveCellsLeft" id="2bde683e-d73d-4e04-8d3b-4476c3cac295">
        <source>moveCellsLeft();
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	17.03.2010	cnwas3		par 22949
// ---------------------------------------------------------------------------
constants
	MinColumn = 0;
vars

	lastColumn,//par 22949
	aColumn : CMUI_GridColumn;
	aBayCol : SHP_BayColumn;
	theColumns : ObjectArray;
	aPoint : CMUI_GridPoint;
	ordinal : Integer;
	anObject : Object;
	tmpCellDefn : CM_CellDefn; // PAR 10088
	rightmostPoint,//par 22949
	alignment : Real; // PAR 10088
begin
	create theColumns transient;
	
	if self.allSelectedPoints.size = 0 then
		return;
	endif;
	// we have selected Points, we want columns
	// So go through all of the selected points and collect their columns
	rightmostPoint := MinColumn;//par 22949
	foreach aPoint in self.allSelectedPoints do
		if aPoint.myGridColumn &lt;&gt; null then
			if not theColumns.includes(aPoint.myGridColumn) and aPoint.x1 &gt; rightmostPoint then //par 22949
				theColumns.clear();//par 22949
				rightmostPoint := aPoint.x1;//par 22949
				theColumns.add(aPoint.myGridColumn);
			endif;	
		endif;
	endforeach;
	
	ordinal := theColumns.first().CMUI_GridColumn.column;//par 22949
	
	//par 22949
	while ordinal &gt; 1 do
		ordinal := ordinal - 1;
		aBayCol := self.allGridColumns[ordinal].SHP_BayColumn;		
			if not theColumns.includes(aColumn) then				
				lastColumn := theColumns.last().CMUI_GridColumn;
				if lastColumn = null then	//move from the first column from the right					
					theColumns.add(aBayCol);
				elseif lastColumn.x1 = aBayCol.x2 then	//there's no gap between this column and the previous ones in theColumns
					theColumns.add(aBayCol);
				else							//stop adding columns,since we have found a gap already,so we'll only move the columns up until the gap
					break;
				endif;
			endif;		
	endwhile;
	
	
	foreach anObject in theColumns do
		alignment := anObject.SHP_BayColumn.allignment - .25;
		anObject.SHP_BayColumn.allignment := alignment; // PAR 10088
		anObject.SHP_BayColumn.myCell.setAlignment(alignment); // PAR 8541

		tmpCellDefn := anObject.SHP_BayColumn.myCell.getMyAftCell(); // PAR 10088
		if tmpCellDefn &lt;&gt; null then // PAR 10088
			tmpCellDefn.setAlignment(alignment); // PAR 10088
		endif;
	endforeach;	
/*	
	// work out the lowest ordinal
	foreach anObject in theColumns do
		if anObject.CMUI_GridColumn.column &lt; ordinal or ordinal = 0 then
			ordinal := anObject.CMUI_GridColumn.column;
		endif;
	endforeach;
	
	// heap in all cells &gt;= the lowest ordinal column
	foreach aColumn in self.allGridColumns do
		if aColumn.column &gt;= ordinal or ordinal = 0 then
			if not theColumns.includes(aColumn) then
				 theColumns.add(aColumn);
			endif;	
	
		endif;
	endforeach;	
*/	
	// now add .25 to all of these column/cells
	/*foreach anObject in theColumns do
		idx := self.allGridColumns.indexOf(anObject.SHP_BayColumn);
		if idx &gt; 1 then
			aBayCol := self.allGridColumns[idx - 1].SHP_BayColumn;
		endif;		
		if idx = 1 or anObject.SHP_BayColumn.allignment &gt; (aBayCol.allignment + 1) then
			alignment := anObject.SHP_BayColumn.allignment - .25; // PAR 10088 localise
			
			anObject.SHP_BayColumn.allignment := alignment;
			anObject.SHP_BayColumn.myCell.setAlignment(alignment); // PAR 8541

			tmpCellDefn := anObject.SHP_BayColumn.myCell.getMyAftCell(); // PAR 10088
			if tmpCellDefn &lt;&gt; null then // PAR 10088
				tmpCellDefn.setAlignment(alignment); // PAR 10088
			endif;

		endif;
	endforeach;	
	*///commented out par 22949

epilog
	delete theColumns;
end;</source>
    </JadeMethod>
    <JadeMethod name="moveCellsRight" id="8ea38eaa-2aed-4ee7-8d4a-e57dd30ca89d">
        <updating/>
        <source>moveCellsRight() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	MaxColumn = 500;
vars
	aColumn,
	lastColumn : CMUI_GridColumn;
	theColumns : ObjectArray;
	aPoint : CMUI_GridPoint;
	ordinal : Integer;
	anObject : Object;
	tmpCellDefn : CM_CellDefn; // PAR 10088
	leftmostPoint,		//par 22949
	alignment : Real; // PAR 10088
begin
	create theColumns transient;
	
	if self.allSelectedPoints.size = 0 then
		return;
	endif;
	// we have selected Points, we want columns
	// So go through all of the selected points and collect their columns
	// par 22949 - after discussing with andrew, only select the leftmost column
	leftmostPoint := MaxColumn;
	foreach aPoint in self.allSelectedPoints do
		if aPoint.myGridColumn &lt;&gt; null then
			//if not theColumns.includes(aPoint.myGridColumn) then
			if not theColumns.includes(aPoint.myGridColumn) and aPoint.x1 &lt; leftmostPoint then //par 22949
				theColumns.clear();//par 22949
				leftmostPoint := aPoint.x1;//par 22949
				theColumns.add(aPoint.myGridColumn);
			endif;	
		endif;
	endforeach;
	
	// work out the lowest ordinal
	/*foreach anObject in theColumns do
		if anObject.CMUI_GridColumn.column &lt; ordinal or ordinal = 0 then
			ordinal := anObject.CMUI_GridColumn.column;
		endif;
	endforeach;*/                                                //comented out because of par 22949,replace by the statement below	
	ordinal := theColumns.first().CMUI_GridColumn.column;	//if we're reached that far, we're bound to have at least one column in the collection
	// heap in all cells &gt;= the lowest ordinal column
	foreach aColumn in self.allGridColumns do
		if aColumn.column &gt; ordinal or ordinal = 0 then
			if not theColumns.includes(aColumn) then
				// theColumns.add(aColumn); commented out PAR 22949
				lastColumn := theColumns.last().CMUI_GridColumn;
				if lastColumn = null then	//move from the first column from the left					
					theColumns.add(aColumn);
				elseif lastColumn.x2 = aColumn.x1 then	//there's no gap between this column and the previous ones in theColumns
					theColumns.add(aColumn);
				else							//stop adding columns,since we have found a gap already,so we'll only move the columns up until the gap
					break;
				endif;
			endif;	
		endif;
	endforeach;	
	
	// now add .25 to all of these column/cells
	foreach anObject in theColumns do
		alignment := anObject.SHP_BayColumn.allignment + .25;
		anObject.SHP_BayColumn.allignment := alignment; // PAR 10088
		anObject.SHP_BayColumn.myCell.setAlignment(alignment); // PAR 8541

		tmpCellDefn := anObject.SHP_BayColumn.myCell.getMyAftCell(); // PAR 10088
		if tmpCellDefn &lt;&gt; null then // PAR 10088
			tmpCellDefn.setAlignment(alignment); // PAR 10088
		endif;
	endforeach;	

epilog
	delete theColumns;
end;</source>
    </JadeMethod>
    <JadeMethod name="selectBlock" id="cedeb798-9be7-432f-9b2e-94bf031ccb9a">
        <updating/>
        <source>selectBlock(_first: CMUI_GridPoint; _second: CMUI_GridPoint) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		PAR 8089
//
// ---------------------------------------------------------------------------

vars

	x1, x2, y1, y2	: Real;
	temp			: CMUI_GridPoint;

begin

	x1 := _first.x1;
	x2 := _first.x2;
	y1 := _first.y1;
	y2 := _first.y2;
	
	x1 := x1.min(_second.x1);
	x2 := x2.max(_second.x2);
	y1 := y1.min(_second.y1);
	y2 := y2.max(_second.y2);
	
	foreach temp in self.allGridPoints do
		if temp.locked then // AKB2002AUG
			continue;
		endif;
		if temp.isKindOf(SHP_BayPoint) then 
			if temp.SHP_BayPoint.bayDefnUnavailable then
				continue;
			endif;
		endif;
		if temp.x1 &gt;= x1 and temp.y1 &gt;= y1 and temp.x2 &lt;= x2 and temp.y2 &lt;= y2 then
			
			if not self.allSelectedPoints.includes(temp) then
				self.allSelectedPoints.add(temp);
			endif;
			temp.drawSelf(self.myGridAreaFrame);
		endif;
	endforeach;

end;</source>
        <Parameter name="_first" type="CMUI_GridPoint"/>
        <Parameter name="_second" type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="selectSinglePoint" id="57784733-fbea-4f8d-b5d7-701b76e5a6ca">
        <updating/>
        <source>selectSinglePoint(x: Real; y: Real): CMUI_GridPoint updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	gridPoint,aPoint,thePoint : CMUI_GridPoint;
	aTI : CM_TrackedItem;
	aBayArea : SHP_BayArea;
	aGridArea : CMUI_GridArea;
	aVJob : CM_VoyageJob;
	thePoints : CMUI_GridPointSet;
begin
	if app.myPassport.userCode = "CNWER1" then
		//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; x.String &amp; " " &amp; y.String );
		self.getRowColumnFromXY(x,y);
	endif;
	gridPoint := self.convertPositionToGridPoint(x, y);
	if gridPoint &lt;&gt; null then
		if gridPoint.locked then
			return gridPoint;
		endif;

		aTI := gridPoint.getTI(x,y);
		if aTI &lt;&gt; null then
			self.addRemoveTIToFromSelected(aTI);
		endif;

		if gridPoint &lt;&gt; null then
			if not self.allSelectedPoints.includes(gridPoint) then
				self.allSelectedPoints.add(gridPoint);
				thePoint := gridPoint;
			else
				self.allSelectedPoints.remove(gridPoint);
				thePoint := null;
			endif;
			gridPoint.drawSelf(self.myGridAreaFrame);
		endif;

	endif;

	if thePoint &lt;&gt;  null and thePoint.isKindOf(SHP_BayPoint) then
		if thePoint.SHP_BayPoint.bayDefnUnavailable and not self.displayMode = ShpDisplayMode_Defn then
			if self.allSelectedPoints.includes(thePoint) then
				self.allSelectedPoints.remove(thePoint);
			endif;
			return null;
		endif;

		// ##########
		// LOAD MODE
		if self.displayMode = ShpDisplayMode_ColCodeLoad and 
		   self.workingMode = SHP_VoyageAreaForm2.WorkMode_Job then
		   	aVJob := thePoint.SHP_BayPoint.colLoadMyJob;
			if aVJob &lt;&gt; null then
				create thePoints transient;
				self.getAllPointsForJob(aVJob,thePoints);
				foreach aPoint in thePoints do
					aBayArea := aPoint.myGridArea.SHP_BayArea;
					aBayArea.addPointToSelected(aPoint); //allSelectedPoints.add(aPoint);
					aPoint.drawSelf(aBayArea.myGridAreaFrame);
				endforeach;
			endif;
/*
			if thePoint.SHP_BayPoint.colLoadMyJob &lt;&gt; null then
				foreach aPoint in self.allGridPoints do
					if not aPoint.isKindOf(SHP_BayPoint) then
						continue;
					endif;
					if aPoint = thePoint then 
						continue;
					endif;
					if aPoint.SHP_BayPoint.colLoadMyJob = thePoint.SHP_BayPoint.colLoadMyJob then
						self.allSelectedPoints.add(aPoint);
						aPoint.drawSelf(self.myGridAreaFrame);
					endif;
				endforeach;
			endif;
*/
		endif;
		// ##########
		// DISCHARGE MODE
		if self.displayMode = ShpDisplayMode_ColCodeDisch and self.workingMode = SHP_VoyageAreaForm2.WorkMode_Job then
		   	aVJob := thePoint.SHP_BayPoint.colDischMyJob;
			if aVJob &lt;&gt; null then
				create thePoints transient;
				self.getAllPointsForJob(aVJob,thePoints);
				foreach aPoint in thePoints do
					aBayArea := aPoint.myGridArea.SHP_BayArea;
					aBayArea.addPointToSelected(aPoint); //allSelectedPoints.add(aPoint);
					aPoint.drawSelf(aBayArea.myGridAreaFrame);
				endforeach;
			endif;

/*
			if thePoint.SHP_BayPoint.colDischMyJob &lt;&gt; null then
				foreach aPoint in self.allGridPoints do
					if not aPoint.isKindOf(SHP_BayPoint) then
						continue;
					endif;
					if aPoint = thePoint then 
						continue;
					endif;
					if aPoint.SHP_BayPoint.colDischMyJob = thePoint.SHP_BayPoint.colDischMyJob then
						
						self.allSelectedPoints.add(aPoint);
						aPoint.drawSelf(self.myGridAreaFrame);
					endif;
				endforeach;
			endif;
		*/
		endif;
	endif;
		
	return thePoint;
epilog
	delete thePoints;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="setAttributeForSelected" id="d1c0237b-671a-438d-9400-bab5dc4b4a66">
        <updating/>
        <source>setAttributeForSelected(_attribute : String) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		Update the objects in response to click on the gui. Note this class was exported to JadeJiffys 4August2003
//
// ---------------------------------------------------------------------------

vars

	aPoint : CMUI_GridPoint;
	bayPoint : SHP_BayPoint;
	pxySD : CM_SlotDefn;
	pxySR : CM_SlotRequest;
	trxUpdateOK,isVesselDefn, colLoadForty  : Boolean;

begin

	if self.displayMode &lt;&gt; ShpDisplayMode_Defn then
		return false;		
	endif;
	
	trxUpdateOK := true;
	if self.allSelectedPoints.size = 0 then
		return true;
	endif;


	isVesselDefn := false;
	additionalCC := false;
	foreach aPoint in self.allSelectedPoints do
		if aPoint.isKindOf(SHP_BayPoint) then
			colLoadForty := false;
			bayPoint := aPoint.SHP_BayPoint;
			// ##################################
			// BAY DEFINITION
			if self.displayMode = ShpDisplayMode_Defn then
				trxUpdateOK := self.setAttributeForSelectedDefn(_attribute,bayPoint);
			endif;
			
			if not trxUpdateOK then
				break;
			endif;
			bayPoint.drawSelf(self.myGridAreaFrame);
		endif;
	endforeach;
	
epilog
	if pxySR &lt;&gt; null then
		delete pxySR;
	endif;
	if pxySD &lt;&gt; null then
		if not isVesselDefn then
			delete pxySD;
		endif;
	endif;
	return trxUpdateOK;
end;</source>
        <Parameter name="_attribute" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAttributeForSelectedDefn" id="9a489aa9-dce2-43a7-9cc9-616419552c77">
        <updating/>
        <source>setAttributeForSelectedDefn(_attribute : String;_bayPoint : SHP_BayPoint input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    21MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars

	 ls : Boolean;
	pxySD : CM_SlotDefn;
	trxUpdateOK,isVesselDefn  : Boolean;
begin
	if _bayPoint.mySlotDefn &lt;&gt; null then
		// update the actual slot defn
		// if the defn is transient it is a proxy already, and we are calling this from the vessel/voyage defn and not from the voyage work screen
		if _bayPoint.mySlotDefn.isTransient then
			pxySD := _bayPoint.mySlotDefn;
			isVesselDefn := true;
		else
			app.cmsBeginLoad(ls);
			pxySD := _bayPoint.mySlotDefn.pxyCreateUpdateProxy();
			app.cmsEndLoad(ls);
			isVesselDefn := false;
		endif;
		
		// PAR 18682 CCMS SFW 1055
		pxySD.setAnAttributeFromController(_attribute);
		_bayPoint.setAnAttributeFromController(_attribute);
		
		app.myTrxUA.trxUpdateSlotDefn(pxySD,app.myPassport);
		
		if not isVesselDefn then // do not delete if calling from vessel defn
			delete pxySD;
		endif;
		trxUpdateOK := app.myPassport.trxCompletedOK;
	endif;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	if not isVesselDefn then // do not delete if calling from vessel defn
		delete pxySD;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_bayPoint" type="SHP_BayPoint" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAttributeForSelectedDefnOLD" id="2e01ad2d-05bb-4f46-8f53-ad3519f544bc">
        <updating/>
        <source>setAttributeForSelectedDefnOLD(_attribute : String;_bayPoint : SHP_BayPoint input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    21MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars

	aPoint : CMUI_GridPoint;
	matchingBayArea : CMUI_GridArea;
	aString : String;
	matchingPoint : SHP_BayPoint;
	 ls : Boolean;
	pxySD : CM_SlotDefn;
	theSlotController : CM_SlotController;
	pxySR,realSlotRequest : CM_SlotRequest;
	theCargoID : Integer;
	theCommodityCode, theDPortCode : String;
	trxUpdateOK,isVesselDefn,isBackEnd  : Boolean;
	theMoveType : Integer;
begin
	if _bayPoint.mySlotDefn &lt;&gt; null then
		// update the actual slot defn
		// if the defn is transient it is a proxy already, and we are calling this from the vessel/voyage defn and not from the voyage work screen
		if _bayPoint.mySlotDefn.isTransient then
			pxySD := _bayPoint.mySlotDefn;
			isVesselDefn := true;
		else
			app.cmsBeginLoad(ls);
			pxySD := _bayPoint.mySlotDefn.pxyCreateUpdateProxy();
			app.cmsEndLoad(ls);
			isVesselDefn := false;
		endif;
		
		isBackEnd := _bayPoint.mySlotDefn.myBay.isAftBay;
		// ### FORTY FOOT PEN
		if _attribute = self.Attrib_Defn_40 then
			// we alway set the forty back to false as the setfor update will workout what to do with forty foot back and front on the definition
			_bayPoint.bayDefnFortyFoot := not _bayPoint.bayDefnFortyFoot;
			pxySD.setAttributes(pxySD.is30, pxySD.is53, pxySD.is45,_bayPoint.bayDefnFortyFoot,pxySD.power,pxySD.reefer, pxySD.watercooled,pxySD.unavailable,pxySD.doors20Aft,pxySD.doors40Aft,pxySD.mtOnly,pxySD.motor20Aft,pxySD.motor40Aft,pxySD.heavy, pxySD.voltageType);
			
		// PAR 16415 CCMS 1029
		// ### THIRTY FOOT PEN
		elseif _attribute = self.Attrib_Defn_30 then
			// we alway set the forty back to false as the setfor update will workout what to do with forty foot back and front on the definition
			_bayPoint.bayDefnThirtyFoot := not _bayPoint.bayDefnThirtyFoot;
			pxySD.setAttributes(_bayPoint.bayDefnThirtyFoot, pxySD.is53, pxySD.is45,_bayPoint.bayDefnFortyFoot,pxySD.power,pxySD.reefer, pxySD.watercooled,pxySD.unavailable,pxySD.doors20Aft,pxySD.doors40Aft,pxySD.mtOnly,pxySD.motor20Aft,pxySD.motor40Aft,pxySD.heavy, pxySD.voltageType);
		// ### FIFTY THREE FOOT PEN
		elseif _attribute = self.Attrib_Defn_53 then
			// we alway set the forty back to false as the setfor update will workout what to do with forty foot back and front on the definition
			_bayPoint.bayDefnFiftyThreeFoot := not _bayPoint.bayDefnFiftyThreeFoot;
			pxySD.setAttributes(pxySD.is30, _bayPoint.bayDefnFiftyThreeFoot, pxySD.is45,_bayPoint.bayDefnFortyFoot,pxySD.power,pxySD.reefer, pxySD.watercooled,pxySD.unavailable,pxySD.doors20Aft,pxySD.doors40Aft,pxySD.mtOnly,pxySD.motor20Aft,pxySD.motor40Aft,pxySD.heavy, pxySD.voltageType);
			
		// ### 20 DOOR PEN
		elseif _attribute = self.Attrib_Defn_D20 then
			_bayPoint.bayDefnDoorDirection20 := not _bayPoint.bayDefnDoorDirection20;
			pxySD.setProxyAttribute(not pxySD.doors20Aft,pxySD.doors40Aft,pxySD.fortyBack,pxySD.fortyFront, pxySD.motor20Aft,pxySD.motor40Aft,pxySD.power,pxySD.reefer,pxySD.mtOnly,pxySD.unavailable,pxySD.watercooled,pxySD.heavy, pxySD.voltageType);
		// ### 40 DOOR PEN
		elseif _attribute = self.Attrib_Defn_D40 then
			_bayPoint.bayDefnDoorDirection40 := not _bayPoint.bayDefnDoorDirection40;
			pxySD.setProxyAttribute( pxySD.doors20Aft,not pxySD.doors40Aft,pxySD.fortyBack,pxySD.fortyFront, pxySD.motor20Aft,pxySD.motor40Aft,pxySD.power,pxySD.reefer,pxySD.mtOnly,pxySD.unavailable,pxySD.watercooled,pxySD.heavy, pxySD.voltageType);
		// ### 20 MOTOR PEN
		elseif _attribute = self.Attrib_Defn_M20 then
			_bayPoint.bayDefnMotorDirection20 := not _bayPoint.bayDefnMotorDirection20;
			pxySD.setProxyAttribute(pxySD.doors20Aft,pxySD.doors40Aft,pxySD.fortyBack,pxySD.fortyFront,not pxySD.motor20Aft,pxySD.motor40Aft,pxySD.power,pxySD.reefer,pxySD.mtOnly,pxySD.unavailable,pxySD.watercooled,pxySD.heavy, pxySD.voltageType);
		// ### 40 MOTOR PEN
		elseif _attribute = self.Attrib_Defn_M40 then
			_bayPoint.bayDefnMotorDirection40 := not _bayPoint.bayDefnMotorDirection40;
			pxySD.setProxyAttribute(pxySD.doors20Aft,pxySD.doors40Aft,pxySD.fortyBack,pxySD.fortyFront, pxySD.motor20Aft, not pxySD.motor40Aft,pxySD.power,pxySD.reefer,pxySD.mtOnly,pxySD.unavailable,pxySD.watercooled,pxySD.heavy, pxySD.voltageType);
		// ### MT ONLY PEN
		elseif _attribute = self.Attrib_Defn_MTonly then
			_bayPoint.bayDefnMtOnly := not _bayPoint.bayDefnMtOnly;
			pxySD.setProxyAttribute(pxySD.doors20Aft,pxySD.doors40Aft,pxySD.fortyBack,pxySD.fortyFront,pxySD.motor20Aft,pxySD.motor40Aft,pxySD.power,pxySD.reefer,not pxySD.mtOnly,pxySD.unavailable,pxySD.watercooled,pxySD.heavy, pxySD.voltageType);
		// ### HEAVY PEN
		elseif _attribute = self.Attrib_Defn_Heavy then
			_bayPoint.bayDefnHeavy := not _bayPoint.bayDefnHeavy;
			pxySD.setProxyAttribute(pxySD.doors20Aft,pxySD.doors40Aft,pxySD.fortyBack,pxySD.fortyFront,pxySD.motor20Aft,pxySD.motor40Aft,pxySD.power,pxySD.reefer, pxySD.mtOnly,pxySD.unavailable,pxySD.watercooled, not pxySD.heavy, pxySD.voltageType);
		// ### VOLTAGE PEN
		elseif _attribute = self.Attrib_Defn_Voltage then
			_bayPoint.bayDefnVoltage := _bayPoint.bayDefnVoltage + 1;
			if _bayPoint.bayDefnVoltage &gt; 2 then
					_bayPoint.bayDefnVoltage := 0;
			endif;
			pxySD.setProxyAttribute(pxySD.doors20Aft,pxySD.doors40Aft,pxySD.fortyBack,pxySD.fortyFront,pxySD.motor20Aft,pxySD.motor40Aft,pxySD.power,pxySD.reefer, pxySD.mtOnly,pxySD.unavailable,pxySD.watercooled, pxySD.heavy, _bayPoint.bayDefnVoltage);
		// ### POWER PEN
		elseif _attribute = self.Attrib_Defn_Powered then
			_bayPoint.bayDefnPowered := not _bayPoint.bayDefnPowered;
			pxySD.setProxyAttribute(pxySD.doors20Aft,pxySD.doors40Aft,pxySD.fortyBack,pxySD.fortyFront,pxySD.motor20Aft,pxySD.motor40Aft,not pxySD.power,pxySD.reefer,pxySD.mtOnly,pxySD.unavailable,pxySD.watercooled,pxySD.heavy, pxySD.voltageType);
		// ### REEFER PEN
		elseif _attribute = self.Attrib_Defn_Reefer then
			_bayPoint.bayDefnReefer := not _bayPoint.bayDefnReefer;
			pxySD.setProxyAttribute(pxySD.doors20Aft,pxySD.doors40Aft,pxySD.fortyBack,pxySD.fortyFront,pxySD.motor20Aft,pxySD.motor40Aft,pxySD.power,not pxySD.reefer,pxySD.mtOnly,pxySD.unavailable,pxySD.watercooled,pxySD.heavy, pxySD.voltageType);
		// ### WATERCOOLED PEN
		elseif _attribute = self.Attrib_Defn_WC then
			_bayPoint.bayDefnWaterCooled := not _bayPoint.bayDefnWaterCooled;
			pxySD.setProxyAttribute(pxySD.doors20Aft,pxySD.doors40Aft,pxySD.fortyBack,pxySD.fortyFront,pxySD.motor20Aft,pxySD.motor40Aft,pxySD.power,pxySD.reefer,pxySD.mtOnly,pxySD.unavailable,not pxySD.watercooled,pxySD.heavy, pxySD.voltageType);
		// ### NOT AVAILABLE PEN
		elseif _attribute = self.Attrib_Defn_NA then
			_bayPoint.bayDefnUnavailable := not _bayPoint.bayDefnUnavailable;
			pxySD.setProxyAttribute(pxySD.doors20Aft,pxySD.doors40Aft,pxySD.fortyBack,pxySD.fortyFront,pxySD.motor20Aft,pxySD.motor40Aft,pxySD.power,pxySD.reefer,pxySD.mtOnly,not pxySD.unavailable,pxySD.watercooled,pxySD.heavy, pxySD.voltageType);
		endif;
		
		app.myTrxUA.trxUpdateSlotDefn(pxySD,app.myPassport);
		
		if not isVesselDefn then // do not delete if calling from vessel defn
			delete pxySD;
		endif;
		trxUpdateOK := app.myPassport.trxCompletedOK;
	endif;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	if not isVesselDefn then // do not delete if calling from vessel defn
		delete pxySD;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_bayPoint" type="SHP_BayPoint" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateArray" id="04829a7e-17d1-447a-a2c3-a18d0119b667">
        <updating/>
        <source>setForCreateArray(_array : StringArray512; _gridFrame : CMUI_GridAreaFrame input; _transitColour : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------

vars
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aSlot : CM_SlotDefn;
	aLid : CM_HatchLid;

	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aBayPoint		: SHP_BayPoint;
	theRow, theCol, pos,ordinal, alignment, lidTier  : Integer;
	theXMLTag : String;
begin

	self.drawMe 		:= true;
	self.transitColour	:= -1;
//	self.displayMode 			:= ShpDisplayMode_ColCodeLoad;

	self.myBay			:= _array[2].asOid.CM_Bay;
	self.row			:= _array[3].Integer;
	self.column			:= _array[4].Integer;
	self.label 			:= _array[5];
	self.bayID 			:= self.label;
	self.bayID40 		:= _array[6];
	self.ordinalHold	:= _array[7].Integer;
	self.numberSlotsOD	:= _array[8].Integer;
	self.numberSlotsUD	:= _array[9].Integer;
	_gridFrame.backColor	:= _array[10].Integer;

	self.transitColour 		:= _transitColour;
	if self.myGridAreaForm &lt;&gt; null then
		self.drawTheHoldVertical := true; //self.myGridAreaForm.SHP_VoyageAreaForm2.drawHoldVertical;
	endif;
	self.myGridAreaFrame	:= _gridFrame;
	
end;</source>
        <Parameter name="_array" type="StringArray512"/>
        <Parameter name="_gridFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_transitColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateArrayLids" id="0d11a219-8ef7-4247-89bd-f71d02a8a7e9">
        <updating/>
        <source>setForCreateArrayLids(_array : StringArray512; _theLidTier : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// for drawing a hatch lid create a point above each column in the grid and attach the lid to each of them
// that way on the click on the lid we know what object to look at.
// NOTE points get their X and Y from the column and row that they are referencing - the X and Y's  are virtual
// A point cannot span multiple columns or rows, so create lots of points all looking at the same thing, in this case a lid
// ---------------------------------------------------------------------------
vars
	tmpHatchLid 	: CM_HatchLid;
	cellODStart, 
	cellUDStart,
	cellODEnd,
	cellUDEnd 	: SHP_BayColumn;
	tmpGridCol 	: CMUI_GridColumn;

	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aLidPoint : SHP_LidPoint;
	theRow, theCol, pos,ordinal, alignment : Integer;
	theXMLTag : String;
	ordinalODStartCell, ordinalODEndCell : Integer;
	startsMidCell,endsMidCell : Boolean;
begin

	ordinalODStartCell 	:= _array[2].Integer;
	ordinalODEndCell 	:= _array[3].Integer;
	startsMidCell  		:= _array[6].Integer.Boolean;
	endsMidCell  		:= _array[7].Integer.Boolean;
	tmpHatchLid 		:= _array[8].asOid.CM_HatchLid;

	cellODStart := self.allGridColumns[ordinalODStartCell].SHP_BayColumn;
	cellODEnd := self.allGridColumns[ordinalODEndCell].SHP_BayColumn;
	cellUDStart := null;
	cellUDEnd := null;

	foreach tmpGridCol in self.allGridColumns do
		if tmpGridCol.column &gt;= ordinalODStartCell and tmpGridCol.column &lt;= ordinalODEndCell then
			// we check this in case the lids end mid cell or in our case mid column
			if tmpGridCol.allGridPointsByRow[_theLidTier] = null then
				create aLidPoint transient;
				aLidPoint.setForCreate( tmpGridCol.column,_theLidTier,self, cellODStart, cellODEnd,cellUDStart,cellUDEnd ,startsMidCell, endsMidCell,tmpHatchLid,tmpGridCol);
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="_array" type="StringArray512"/>
        <Parameter name="_theLidTier" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXML" id="6edf141e-e6cb-47eb-b608-d261a6c67624">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXML(_theXMLString: String; _transitColour : Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aSlot : CM_SlotDefn;
	aLid : CM_HatchLid;

	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aBayPoint		: SHP_BayPoint;
	theRow, theCol, pos,ordinal, alignment, lidTier  : Integer;
	theXMLTag : String;
begin
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("GO");
	theRow := theXMLTag[1:2].Integer;
	theCol := theXMLTag[3:2].Integer;
	self.column := theCol;
	self.row 	:= theRow;
	self.drawMe := true;
	self.transitColour := _transitColour;
//	self.displayMode := ShpDisplayMode_ColCodeLoad;
	if self.myGridAreaForm &lt;&gt; null then
		self.drawTheHoldVertical := true; //self.myGridAreaForm.SHP_VoyageAreaForm.drawHoldVertical;
	endif;
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("lb");
	if theXMLTag &lt;&gt; null then
		self.label := theXMLTag;
		self.bayID := theXMLTag;
	endif;

	theXMLTag := _theXMLString.cnEcGetTagValueOfName("BY");
	if theXMLTag &lt;&gt; null then
		self.myBay := theXMLTag.asOid.CM_Bay;
		self.drawingDefinition := _theXMLString;
	endif;
	
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("id40");
	if theXMLTag &lt;&gt; null then
		self.bayID40 := theXMLTag;
	endif;
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("SOD");
	if theXMLTag &lt;&gt; null then
		self.numberSlotsOD := theXMLTag.Integer;
	endif;
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("SUD");
	if theXMLTag &lt;&gt; null then
		self.numberSlotsUD := theXMLTag.Integer;
	endif;

	theXMLTag := _theXMLString.cnEcGetTagValueOfName("oh");
	if theXMLTag &lt;&gt; null then
		self.ordinalHold := theXMLTag.Integer;
	endif;

return;
/// ############################################################
/// ############################################################
/// drawing now done later for bays that need to be drawn
/// ############################################################
/// ############################################################

	// #################
	// CELLS
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("cl");
	if theXMLTag &lt;&gt; null then
		self.setForCreateXMLCells(theXMLTag);
	endif;
	// #################
	// TIERS
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("tr");
	if theXMLTag &lt;&gt; null then
		lidTier := self.setForCreateXMLTiers(theXMLTag);
	endif;
	// #################
	// LIDS
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("ld");
	if theXMLTag &lt;&gt; null then
		self.setForCreateXMLLids(theXMLTag,lidTier);
	endif;
	// #################
	// SLOTS
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("sl");
	if theXMLTag &lt;&gt; null then
		self.setForCreateXMLSlots(theXMLTag);
	endif;


end;</source>
        <Parameter name="_theXMLString" type="String"/>
        <Parameter name="_transitColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXMLCells" id="e6a971c8-4cc7-4fb2-bd5f-ce3435df8f02">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXMLCells(_theXMLString: String) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aSlot : CM_SlotDefn;

	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aBayPoint		: SHP_BayPoint;
	theRow, theCol, pos,ordinal : Integer;
	alignment : Real;
	theXMLTag, theLabel : String;
begin
	// #################
	// CELLS
	pos := 1;
	while (pos &lt;&gt; 0) do
		theLabel := _theXMLString.cnEcGetNextTagValueOfName("id",pos);  
		if pos = 0 then
			break;
		endif;
		ordinal :=  _theXMLString.cnEcGetNextTagValueOfName("ord",pos).Integer;
		alignment :=  _theXMLString.cnEcGetNextTagValueOfName("al",pos).Real;
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("CO",pos);  
		aCell := theXMLTag.asOid.CM_CellDefn;
		create aBayCol transient;
		aBayCol.setForCreate(theLabel, ordinal, self,alignment, aCell);
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("pw",pos);  
//		aBayCol.pileWeight := theXMLTag.Integer;
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("pwm",pos);  
		aBayCol.pileWeightMAX := (theXMLTag.Integer / 1000).Integer; // PAR 8423 divide by 1000

	endwhile;
end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXMLDetails" id="5d855462-a549-417a-80d7-5cdd87c26a93">
        <updating/>
        <source>setForCreateXMLDetails() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aSlot : CM_SlotDefn;
	aLid : CM_HatchLid;

	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aBayPoint		: SHP_BayPoint;
	pos, alignment, lidTier  : Integer;
	_theXMLString,
	theXMLTag : String;
begin

_theXMLString := self.drawingDefinition;

	self.isInitialized	:= true;

	// #################
	// CELLS
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("cl");
	if theXMLTag &lt;&gt; null then
		self.setForCreateXMLCells(theXMLTag);
	endif;
	// #################
	// TIERS
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("tr");
	if theXMLTag &lt;&gt; null then
		lidTier := self.setForCreateXMLTiers(theXMLTag);
	endif;
	// #################
	// LIDS
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("ld");
	if theXMLTag &lt;&gt; null then
		self.setForCreateXMLLids(theXMLTag,lidTier);
	endif;
	// #################
	// SLOTS
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("sl");
	if theXMLTag &lt;&gt; null then
		self.setForCreateXMLSlots(theXMLTag);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateXMLLids" id="b502adfb-2e91-4f79-a9a1-4681f2bc9c54">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXMLLids(_theXMLString: String;_theLidTier : Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
	// for drawing a hatch lid create a point above each column in the grid and attach the lid to each of them
	// that way on the click on the lid we know what object to look at.
	// NOTE points get their X and Y from the column and row that they are referencing - the X and Y's  are virtual
	// A point cannot span multiple columns or rows, so create lots of points all looking at the same thing, in this case a lid
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aLid : CM_HatchLid;
	cellODStart, cellUDStart,cellODEnd,cellUDEnd :	SHP_BayColumn;
	aGridCol : CMUI_GridColumn;

	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aLidPoint : SHP_LidPoint;
	theRow, theCol, pos,ordinal, alignment : Integer;
	theXMLTag : String;
	ordinalODStartCell, ordinalODEndCell : Integer;
	startsMidCell,endsMidCell : Boolean;
begin
	// #################
	// LIDS
	create aBayRow transient;
	aBayRow.setForCreate("ZZ",_theLidTier, self);
	pos := 1;
	while (pos &lt;&gt; 0) do
		ordinalODStartCell :=  _theXMLString.cnEcGetNextTagValueOfName("ODS",pos).Integer;
		if pos = 0 then
			break;
		endif;
		
		ordinalODEndCell :=  _theXMLString.cnEcGetNextTagValueOfName("ODE",pos).Integer;
		startsMidCell  :=  _theXMLString.cnEcGetNextTagValueOfName("SMC",pos).Integer.Boolean;
		endsMidCell  :=  _theXMLString.cnEcGetNextTagValueOfName("EMC",pos).Integer.Boolean;
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("LO",pos);  
		aLid := theXMLTag.asOid.CM_HatchLid;

		cellODStart := self.allGridColumns[ordinalODStartCell].SHP_BayColumn;
		cellODEnd := self.allGridColumns[ordinalODEndCell].SHP_BayColumn;
		cellUDStart := null;
		cellUDEnd := null;

		foreach aGridCol in self.allGridColumns do
			if aGridCol.column &gt;= ordinalODStartCell and aGridCol.column &lt;= ordinalODEndCell then
				// we check this in case the lids end mid cell or in our case mid column
				if aGridCol.allGridPointsByRow[_theLidTier] = null then
					create aLidPoint transient;
					aLidPoint.setForCreate( aGridCol.column,_theLidTier,self, cellODStart, cellODEnd,cellUDStart,cellUDEnd ,startsMidCell, endsMidCell,aLid,aGridCol);
				endif;
			endif;
		endforeach;
	endwhile;
	
end;</source>
        <Parameter name="_theXMLString" type="String"/>
        <Parameter name="_theLidTier" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXMLSlots" id="b1f273ba-0ad1-4320-9a43-49e5a0f2fe01">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXMLSlots(_theXMLString: String) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aSlot : CM_SlotDefn;
	aBayRow		: SHP_BayRow;
	aBayCol		: SHP_BayColumn;
	aBayPoint		: SHP_BayPoint;
	theRow, theCol, pos,ordinal, alignment : Integer;
	theXMLTag,theSlotTag : String;
	theXMLString: String;
	theLog : JadeLog;
begin

//	create theLog;
//	theLog.fileName := "SLOTS.TXT";
//	theLog.filePath := "C:\ship";
	
	theXMLString := _theXMLString;
//	theLog.info(theXMLString);
//	theLog.commitLog;
	// #################
	// SLOTS  
	pos := 1;
	while (pos &lt;&gt; 0) do

		theSlotTag := theXMLString.cnEcGetNextTagValueOfName("GP",pos);  
		if theSlotTag = null then
			break;
		endif;
		
		theXMLTag := theSlotTag.cnEcGetTagValueOfName("SD");  
		aSlot := theXMLTag.asOid.CM_SlotDefn;

		theXMLTag := theSlotTag.cnEcGetTagValueOfName("Ord");  
		theCol := theXMLTag[1:2].Integer;
		theRow := theXMLTag[3:2].Integer;

		theXMLTag := theSlotTag.cnEcGetTagValueOfName("na");  

		create aBayPoint transient;
		aBayPoint.setForCreateEmpty(theCol, theRow, self);
		aBayPoint.mySlotDefn := aSlot;
		aBayPoint.bayDefnUnavailable := theXMLTag.Integer.Boolean;
		aBayPoint.myBay := aSlot.myBay.CM_Bay;
		if aSlot.isKindOf(CM_SlotDefnVoyage) then
			aBayPoint.setController(aSlot.CM_SlotDefnVoyage.mySlotController);
		endif;
		aBayPoint.myBay.setGridXMLPoint(aBayPoint.bayFwdID,aBayPoint.bayAftID,	aBayPoint.bayIsAft,aBayPoint.bayIsForward,aBayPoint.bayType);
		
		aBayPoint.populateGridXMLdefn(theSlotTag);
		if pos = 0 then
			break;
		endif;
	endwhile;

end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXMLTiers" id="58a08e33-4619-43b4-a098-a84f28972fc7">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setForCreateXMLTiers(_theXMLString: String) : Integer updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTier : CM_TierDefn;
	aBayRow		: SHP_BayRow;
	theRow, theCol, pos,ordinal, alignment : Integer;
	theXMLTag, pileWait : String;
begin
	// #################
	// TIERS
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("id",pos);  
		if pos = 0 then
			break;
		endif;
		ordinal :=  _theXMLString.cnEcGetNextTagValueOfName("ord",pos).Integer;
		pileWait :=  _theXMLString.cnEcGetNextTagValueOfName("pw",pos).asStringJMT;
		
//		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("TO",pos);  
//		aTier := theXMLTag.asOid.CM_TierDefn;
		create aBayRow transient;
		aBayRow.setForCreate(theXMLTag,ordinal, self);
//		aBayRow.pileWeight := pileWait;
	endwhile;
	return ordinal + 1;
end;</source>
        <Parameter name="_theXMLString" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFrameHeight" id="5c4325ad-49cf-480a-9a80-da75c0783d23">
        <source>setFrameHeight();
// ---------------------------------------------------------------------------
// Created:     04 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.allGridRows.isEmpty then
		self.myGridAreaFrame.height := 20;
	else
		self.myGridAreaFrame.height := self.allGridRows.last.y2 + 20;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setGridRowColPosAfter" id="42c1352b-12e8-4648-8f36-4f7aa78c36d1">
        <updating/>
        <source>setGridRowColPosAfter() updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		Hatch lids are drawn in the above deck grid area.
//				if there are no slots on deck we still will have hatchlids.
//				I added this method so that the hatch lid row could be drawn at the bottom of the frame rather than at the top
//
// ---------------------------------------------------------------------------

vars

	tmpRow,lastRow			: CMUI_GridRow;
	tmpPos1,
	tmpPos2			: Real;	
	isLidRow, smallOutput, mediumOutput, largeOutput : Boolean;
begin
	// the last row is a lid row and there is only 1 row. This means that there are no slots
	// draw the lid at the bottom of the area, so that it is near the under deck area.
	if self.allGridRows.isEmpty or self.allGridRows.size &gt; 1 then
		return;
	endif;
	
	//12 Aug 2010	NDL	Par 24925 - Below deck there are no hatch lids.  1 actually means a row of slots!!
	if self.allGridRows.size = 1 and self.isKindOf(SHP_BayAreaBelowDeck) then
		return;
	endif;
	
	if not self.drawMe then
		self.totalPointWidth := 0;
		self.totalPointHeight := 0;
		return;
	endif;
	
	smallOutput :=  self.scaleXFactor = 1 or (self.amPrinting and self.scaleXFactor = self.PrintScaleSmall);
	mediumOutput := (self.amPrinting and self.scaleXFactor = self.PrintScaleMedium);
	largeOutput := (self.amPrinting and self.scaleXFactor = self.PrintScaleLarge);
	
	tmpRow :=self.allGridRows.first;
	tmpPos1 := self.myGridAreaFrame.height -  10;
	tmpPos2 := tmpPos1 + 10;
	tmpRow.setYPos(tmpPos1, tmpPos2);
	self.drawGridArea();
end;</source>
    </JadeMethod>
    <JadeMethod name="setGridRowColPositions" id="ad4ce17b-e407-426e-a2a7-3db86b788bc6">
        <updating/>
        <source>setGridRowColPositions() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRow,lastRow			: CMUI_GridRow;
	tmpCol			: CMUI_GridColumn;
	aPoint : CMUI_GridPoint;
	aBayRow		: SHP_BayRow;
	aBayCol			: SHP_BayColumn;
	lastPos,
	tmpPos1,
	tmpPos2			: Real;	
	count, theTopMargin 			: Integer;
	spacing			: Integer;
	theRowHeight,
	theColWidth : Real;
	lidPadding : Integer;
	isLidRow, smallOutput, mediumOutput, largeOutput : Boolean;
begin
	if not self.drawMe then
		self.totalPointWidth := 0;
		self.totalPointHeight := 0;
		return;
	endif;

//	smallOutput :=  self.scaleXFactor = 1 or (self.amPrinting and self.scaleXFactor = self.PrintScaleSmall);
	smallOutput :=  (self.amPrinting and self.scaleXFactor = self.PrintScaleSmall);
	mediumOutput := (self.amPrinting and self.scaleXFactor = self.PrintScaleMedium);
	largeOutput := (self.amPrinting and self.scaleXFactor = self.PrintScaleLarge);
	
	if largeOutput then
		theRowHeight := self.PrintScaleLargeHeight;
		theColWidth := self.PrintScaleLargeWidth;
	else
		theRowHeight := RowHeight *  self.scaleXFactor;
		theColWidth	 := ColWidth * self.scaleXFactor;
	endif;
	theTopMargin := self.getTopMargin();

	// work out if the last row is a hatch lid row
	isLidRow := isLastRowAHatchLidRow(lastRow);

	foreach tmpRow in self.allGridRows do
		// we do not zoom on hatch lids, i.e. they are always the same size. 
		//They started a bit lower down as well i.e. the 1st Y  does not start right next to the last rows 2nd Y
		// this is because we leave a gap for the pile weights which also do not zoom.
		if lastRow &lt;&gt; null and lastRow = tmpRow and isLidRow then
			if smallOutput or self.scaleXFactor = 1 then
				lidPadding := 2;
			elseif self.displayMode = ShpDisplayMode_Defn or smallOutput or mediumOutput then
				lidPadding := 2;
			else
				lidPadding := LidHeight;
			endif;
			// the last row is a lid row and there is only 1 row. This means that there are not slots
			// draw the lid at the bottom of the area, so that it is near the under deck area.
			if self.allGridRows.size = 1 then 
				tmpPos1 := self.myGridAreaFrame.height -  10;
				tmpPos2 := tmpPos1 + 10;
			else
				tmpPos1 := theTopMargin + ((tmpRow.row - 1) * theRowHeight) + lidPadding;
				tmpPos2 := tmpPos1 + 10;
			endif;
		else
			if smallOutput then
				tmpPos1 := theTopMargin + ((tmpRow.row - 1) * theRowHeight) - ((tmpRow.row - 1) * 1);
			else
				tmpPos1 := theTopMargin + ((tmpRow.row - 1) * theRowHeight) + ((tmpRow.row - 1) * spacing);
			endif;
			tmpPos2 := tmpPos1 + theRowHeight;
		endif;
		tmpRow.setYPos(tmpPos1, tmpPos2);
	endforeach;
	
	foreach tmpCol in self.allGridColumns do
		aBayCol := tmpCol.SHP_BayColumn;
		if smallOutput then
			tmpPos2 := 	((aBayCol.allignment) * theColWidth) + 2;
//			tmpPos1 := tmpPos2 - theColWidth - ((tmpCol.column - 1) * 1);
			tmpPos1 := tmpPos2 - theColWidth - 1; //((tmpCol.column - 1) * 1);
		else
			tmpPos2 := 	((aBayCol.allignment) * theColWidth) + LeftMargin;
			tmpPos1 := tmpPos2 - theColWidth;
		endif;
		tmpCol.setXPos(tmpPos1, tmpPos2);
		
	endforeach;

	if self.allGridColumns.isEmpty and self.amPrinting then
		tmpPos2 := 70;
	endif;
	if smallOutput then
		self.totalPointWidth := tmpPos2 + 2;
	else
		self.totalPointWidth := tmpPos2 + RightMargin;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setReferenceForSelected" id="7d43cfd5-31ac-4a59-bb4b-0b7ef173ab06">
        <updating/>
        <source>setReferenceForSelected(_theObject : CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	mtCommodity : CM_Commodity;

	aPoint 					: CMUI_GridPoint;
	aBayPoint 				: SHP_BayPoint;
	bayFrame 				: CMUI_GridAreaFrame;
	aString,theMTCode 		: String;
	ls 						: Boolean;
	theMoveType 			: Integer;
	theSlotController 		: CM_SlotController;
	pxySR,realSlotRequest 	: CM_SlotRequest;
	theCargoType,
	cargoType				: CM_CargoType;		//cnwas3 PAR 24273
	sr						: CM_SlotRequest;		//cnwas3 PAR 24273
	clPort					: CM_Port;		//cnwas3 PAR 24273
begin

	if self.allSelectedPoints.size = 0 then
		return;
	endif;
	
	if _theObject = null then
		return;
	endif;
	theCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container]; //default	
	foreach aPoint in self.allSelectedPoints do
		if aPoint.isKindOf(SHP_BayPoint) then
			aBayPoint := aPoint.SHP_BayPoint;
			if aBayPoint.bayDefnUnavailable then // PAR 8089
				continue;
			endif;
			if self.displayMode = ShpDisplayMode_ColCodeLoad then			
			// ##################################
			// LOAD COLOUR CODE
				theMoveType := LOAD_MOVETYPE;
				if aBayPoint.colLoadDLR then
					theMoveType := DLR_MOVETYPE;
				elseif aBayPoint.colLoadSOB then
					theMoveType := SOB_MOVETYPE;
				endif;
				if aBayPoint.myLocationsController &lt;&gt; null then
					theSlotController := aBayPoint.myLocationsController.CM_SlotController;
					sr := theSlotController.mySlotRequestLoad;		//cnwas3 PAR 24273 begin
					if sr = null 		
					or (sr &lt;&gt; null 
						and sr.myJob &lt;&gt; null 
						and sr.myJob.isJobComplete) then // REWORK JOB		//cnwas3 PAR 24273 end
						create pxySR transient;
						pxySR.setProxyForCreate(theSlotController, theMoveType,true,theCargoType, null);
						app.myTrxCA.trxCreateSlotRequest(pxySR,realSlotRequest, app.myPassport);
						delete pxySR;
					endif;
					
					app.cmsBeginLoad(ls);
					pxySR := theSlotController.mySlotRequestLoad.pxyCreateUpdateProxy();
					app.cmsEndLoad(ls);
					cargoType := pxySR.getAttrCargoType();			//cnwas3 PAR 24273
					if cargoType = null then						//cnwas3 PAR 24273
						aBayPoint.colLoadMyCargoType := theCargoType; //default
					else
						aBayPoint.colLoadMyCargoType := cargoType;	//cnwas3 PAR 24273
					endif;
					
					if _theObject.isKindOf(CM_CargoType) then
						aBayPoint.colLoadMyCargoType := _theObject.CM_CargoType;
						// PAR7496 AKB2004FEB ,pxySR.reefer
						pxySR.setProxyForUpdate(pxySR.doorsDirection,pxySR.motorDirection,theMoveType,pxySR.numSeqPortCustom,
												pxySR.numSeqStarboardCustom, pxySR.getAttrEmpty(),pxySR.fixed,pxySR.getAttrHalfHeight(),pxySR.getAttrHazardous(),
												pxySR.getAttrOverDimensioned(),pxySR.getAttrPowerRequired(),pxySR.sequenced,pxySR.unavailable,pxySR.getAttrWaterCooled(),pxySR.getAttrHiCubed(), 
												pxySR.getAttrIs40(),pxySR.fortyBack, // PAR 7899
												pxySR.getAttrDischargePort(),pxySR.getAttrCommodityGroup(),aBayPoint.colLoadMyCargoType);
					endif;
					if _theObject.isKindOf(CM_CommodityGroup) then
						theMTCode := app.myPassport.myTerminal.getDefaultEmptyCommodity();
						mtCommodity := app.myRoot.allCommodities[theMTCode];

						aBayPoint.colLoadEmpty := false;
						aBayPoint.colLoadMyCommodityGroup := _theObject.CM_CommodityGroup;

						if aBayPoint.colLoadMyCommodityGroup = mtCommodity.myCommodityGroup then
							aBayPoint.colLoadEmpty := true;
							aBayPoint.colLoadCommodityGroupCode := theMTCode;
						endif;
						// PAR7496 AKB2004FEB ,pxySR.reefer
						pxySR.setProxyForUpdate(pxySR.doorsDirection,pxySR.motorDirection,theMoveType,pxySR.numSeqPortCustom,
												pxySR.numSeqStarboardCustom,aBayPoint.colLoadEmpty,pxySR.fixed,pxySR.getAttrHalfHeight(),pxySR.getAttrHazardous(),
												pxySR.getAttrOverDimensioned(),pxySR.getAttrPowerRequired(),pxySR.sequenced,pxySR.unavailable,pxySR.getAttrWaterCooled(),pxySR.getAttrHiCubed(), 
												pxySR.getAttrIs40(),pxySR.fortyBack, // PAR 7899
												pxySR.getAttrDischargePort(),aBayPoint.colLoadMyCommodityGroup,aBayPoint.colLoadMyCargoType);
					endif;
					if _theObject.isKindOf(CM_Port) then
						aBayPoint.colLoadMyDischPort := _theObject.CM_Port;
						// PAR7496 AKB2004FEB ,pxySR.reefe
						pxySR.setProxyForUpdate(pxySR.doorsDirection,pxySR.motorDirection,theMoveType,pxySR.numSeqPortCustom,
												pxySR.numSeqStarboardCustom, pxySR.getAttrEmpty(),pxySR.fixed,pxySR.getAttrHalfHeight(),pxySR.getAttrHazardous(),
												pxySR.getAttrOverDimensioned(),pxySR.getAttrPowerRequired(),pxySR.sequenced,pxySR.unavailable,pxySR.getAttrWaterCooled(),pxySR.getAttrHiCubed(), 
												pxySR.getAttrIs40(),pxySR.fortyBack, // PAR 7899
												aBayPoint.colLoadMyDischPort,pxySR.getAttrCommodityGroup(),aBayPoint.colLoadMyCargoType);
					endif;
					app.myTrxUA.trxUpdateSlotRequest(pxySR,app.myPassport);
					delete pxySR;
				endif;
			endif; //ShpViewMode_ColCodeLoad 
			
			if app.myPassport.hasErrorsOrWarnings then
				return;
			endif;
			
			clPort := aBayPoint.colLoadMyDischPort;		//cnwas3 PAR 24273 begin
			if clPort &lt;&gt; null then
				aBayPoint.colLoadDischPortCode := clPort.code;
				aBayPoint.colLoadDischPortColour := clPort.colour;	//cnwas3 PAR 24273 end
			endif;
			if aBayPoint.colLoadMyCommodityGroup &lt;&gt; null then
				aBayPoint.colLoadCommodityGroupCode := aBayPoint.colLoadMyCommodityGroup.code;
			endif;
			// ################################################
			// IF we are in colour code load and we are setting/unsetting the 40 attribute then sort out the matching back end point
			if self.myGridAreaForm &lt;&gt; null then
				if self.myGridAreaForm.isKindOf(SHP_VoyageAreaForm2) then
					// IF this is a forty then copy every thing about it to the matching slot in the twin bay
					// if removing the 40 attribute then clear out the matching point
					if (self.displayMode = ShpDisplayMode_ColCodeDisch and aBayPoint.tiInfo40) then
						self.doUpdateFortyBackEndDisch(aBayPoint);
					elseif (self.displayMode = ShpDisplayMode_ColCodeLoad and  aBayPoint.colLoadFortyFoot) then
						self.doUpdateFortyBackEndLoad(aBayPoint);
					endif;
				endif;
			endif;
		endif;
	endforeach;
	self.drawSelf();

epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	if pxySR &lt;&gt; null then
		delete pxySR;
	endif;
end;</source>
        <Parameter name="_theObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setRowColumn" id="984a2b35-b21d-40ab-95de-dd3642b3bbec">
        <updating/>
        <source>setRowColumn(_theColumn : Integer; _theRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.column := _theColumn;
	self.row 	:= _theRow;
end;</source>
        <Parameter name="_theColumn" type="Integer"/>
        <Parameter name="_theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTransitColour" id="9f112ebb-2441-47d7-8cc4-ded83fbf1cb9">
        <updating/>
        <source>setTransitColour(_transitColor : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
