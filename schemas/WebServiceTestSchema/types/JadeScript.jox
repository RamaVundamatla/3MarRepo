<Class name="JadeScript">
    <JadeMethod name="createEDITestScripts" id="a9003c4f-81b5-4bbb-aaa0-b50682bc8ba8">
        <source>createEDITestScripts();

/*
Purpose:	To be able to test any EDI Web Message
*/

constants
	FileName		= 'c:\temp\aaa Web Testing File\SendEDI.csv';
	
vars
	index			: Integer;
	base64message	: String;
	ediFile			: File;
	control			: TestAppControl;
	session			: XMLSessionScript;
	payload			: XMLMessagePayload;
	
begin
	// Delete any old stuff lying around
	beginTransaction;
	control := TestAppControl.firstInstance;
	if control = null then
		create control;
	else
		control.allXMLSessionScripts.purge;
	endif;
	commitTransaction;
	
	// And again in case any floating objects
	beginTransaction;
	XMLSessionScript.instances.purge;
	commitTransaction;
	beginTransaction;
	XMLMessagePayload.instances.purge;
	commitTransaction;
	
	// Now create scripts - Use SingleWebServiceTestForm "Generate Script Code" to build this code
	beginTransaction;
		
	foreach index in 1 to 10 do
		create session;
		session.myTestAppControl	:= control;
		session.usercode			:= "CNWKPD1";
		session.password			:= "cnwkpd1";
		
		// sendEDI
		create ediFile transient;
		ediFile.kind := File.Kind_Binary;
		ediFile.openInput( FileName );
		base64message := ediFile.readBinary(ediFile.fileLength).base64Encode();
		
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTEDIService.name;
		payload.operationName		:= JMTEDIService::sendEDI.name;
		payload.message				:=	''
										&amp; ''
										&amp; '&lt;SendEDI&gt;'
										&amp; '&lt;ediRequest xsi:type="WS_SendEDIRequest"&gt;'
										&amp; '&lt;formName&gt; &lt;/formName&gt;'
										&amp; '&lt;clientRef&gt;status 17&lt;/clientRef&gt;'
										&amp; '&lt;message xsi:type="xsd:base64"&gt;'
										&amp; base64message
										&amp; '&lt;/message&gt;'
										&amp; '&lt;messageType&gt;PreNote&lt;/messageType&gt;'
										&amp; '&lt;synchronous&gt;false&lt;/synchronous&gt;'
										&amp; '&lt;/ediRequest&gt;'
										&amp; '&lt;/SendEDI&gt;';		
		
		// getEDIStatus
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTEDIService.name;
		payload.operationName		:= JMTEDIService::getEDIStatus.name;
		payload.message				:=	''
										&amp; ''
										&amp; '&lt;GetEDIStatus&gt;'
										&amp; '&lt;ediStatusRequest xsi:type="WS_EDIStatusRequest"&gt;'
										&amp; '&lt;formName&gt; &lt;/formName&gt;'
										&amp; '&lt;clientRef&gt;status 17&lt;/clientRef&gt;'
										&amp; '&lt;/ediStatusRequest&gt;'
										&amp; '&lt;/GetEDIStatus&gt;';	
	endforeach;
	
	commitTransaction;
	
epilog
	delete ediFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createSteinwegEDITestScripts" id="3e265d3a-bb5d-4a7a-80fe-b0222f8152f7">
        <source>createSteinwegEDITestScripts();

/*
Purpose:	To be able to test any EDI Web Message
*/

constants
	InputMessage	= ",2200,Export,BK01,BOL01,25000,CONT,GENL,,,CUSTSEAL1,UTOP,AUMEL,JPADO,,01/01/2010 12:45,BS2,REMSTEINWEG01,UT_CL_VOY1,,,CONT,25000";
		
vars
	index,
	messageNumber	: Integer;
	base64message	: String;
	ediFile			: File;
	control			: TestAppControl;
	session			: XMLSessionScript;
	payload			: XMLMessagePayload;
	
begin
	// Delete any old stuff lying around
	beginTransaction;
	control := TestAppControl.firstInstance;
	if control = null then
		create control;
	else
		control.allXMLSessionScripts.purge;
	endif;
	commitTransaction;
	
	// And again in case any floating objects
	beginTransaction;
	XMLSessionScript.instances.purge;
	commitTransaction;
	beginTransaction;
	XMLMessagePayload.instances.purge;
	commitTransaction;
	
	// Now create scripts - Use SingleWebServiceTestForm "Generate Script Code" to build this code
	beginTransaction;
		
	foreach index in 1 to 10 do
		create session;
		session.myTestAppControl	:= control;
		session.usercode			:= "CNWKPD1";
		session.password			:= "cnwkpd1";
		
		// setCurrentTerminal
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::setCurrentTerminal.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;SetCurrentTerminal xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:s1="http://tempuri.org/"&gt;'
					&amp; '&lt;terminal xsi:type="WS_Terminal"&gt;'
					&amp; '&lt;cmObjectEdition&gt;0&lt;/cmObjectEdition&gt;'
					&amp; '&lt;cmObjectId&gt; &lt;/cmObjectId&gt;'
					&amp; '&lt;code&gt;UT&lt;/code&gt;'
					&amp; '&lt;name&gt; &lt;/name&gt;'
					&amp; '&lt;/terminal&gt;'
					&amp; '&lt;/SetCurrentTerminal&gt;';

		foreach messageNumber in 1 to 10 do
					
			// sendEDI
			base64message := "UTST" &amp; index.String.padLeadingZeros(2) &amp; messageNumber.String.padLeadingZeros(3) &amp; InputMessage;
			base64message := base64message.Binary.base64Encode();
			
			// sendEDI
			create payload;
			payload.myXMLSessionScript	:= session;
			payload.serviceName			:= JMTEDIService.name;
			payload.operationName		:= JMTEDIService::sendEDI.name;
			payload.message				:= ''
					&amp; ''
					&amp; '&lt;SendEDI xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:s1="http://tempuri.org/"&gt;'
					&amp; '&lt;ediRequest xsi:type="WS_SendEDIRequest"&gt;'
					&amp; '&lt;formName&gt; &lt;/formName&gt;'
					&amp; '&lt;warningsAcknowledged&gt;false&lt;/warningsAcknowledged&gt;'
					&amp; '&lt;clientRef&gt; &lt;/clientRef&gt;'
					&amp; '&lt;message xsi:type="xsd:base64"&gt;'
					&amp; base64message
					&amp; '&lt;/message&gt;'
					&amp; '&lt;messageType&gt;SteinwegCargoOnsite&lt;/messageType&gt;'
					&amp; '&lt;synchronous&gt;true&lt;/synchronous&gt;'
					&amp; '&lt;/ediRequest&gt;'
					&amp; '&lt;/SendEDI&gt;';
			
		
		endforeach;
					
					
	endforeach;
	
	commitTransaction;
	
epilog
	delete ediFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createTestScripts" id="747e0043-48da-45bf-beff-1e70f51c3a91">
        <source>createTestScripts();

/*

Purpose:			


Return Value:		


Date		Who		Reason
02 November 2004	cnwkpd1	PAR #4801 - Web Service application

*/

vars
	control			: TestAppControl;
	session			: XMLSessionScript;
	payload			: XMLMessagePayload;
	i, j			: Integer;
	cargoId			: String;
	
begin
	// Delete any old stuff lying around
	beginTransaction;
	control := TestAppControl.firstInstance;
	if control = null then
		create control;
	else
		control.allXMLSessionScripts.purge;
	endif;
	commitTransaction;
		
	// And again in case any floating objects
	beginTransaction;
	XMLSessionScript.instances.purge;
	commitTransaction;
	beginTransaction;
	XMLMessagePayload.instances.purge;
	commitTransaction;

	// Now create scripts - Use SingleWebServiceTestForm "Generate Script Code" to build this code
	beginTransaction;
		
	foreach i in 1 to 10 do
	
		cargoId := 'SCRIPTEST' &amp; i.String;
		
		create session;
		session.myTestAppControl := control;
		
		session.usercode := "CNWKPD1";
		session.password := "cnwkpd1";

		// getCurrentTerminal
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getCurrentTerminal.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetCurrentTerminal xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:s1="http://tempuri.org/"/&gt;';
					
		// getActiveVoyages
/*		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getActiveVoyages.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetActiveVoyages/&gt;';
*/		
/*		// getCargoTypes
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getCargoTypes.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetCargoTypes/&gt;';
					
		// getEventRequestTypes
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getEventRequestTypes.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetEventRequestTypes/&gt;';
					
		// getEventStatuses
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getEventStatuses.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetEventStatuses/&gt;';		
		
		// getIMEXStatuses
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getIMEXStatuses.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetIMEXStatuses/&gt;';		
		
		// getISOTypes
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getISOTypes.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetISOTypes/&gt;';		
		
		// getOperators
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getOperators.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetOperators&gt;'
					&amp; '&lt;operatorsRequest&gt;'
					&amp; '&lt;voyageCode&gt;&lt;/voyageCode&gt;'
					&amp; '&lt;/operatorsRequest&gt;'
					&amp; '&lt;/GetOperators&gt;';
					
		// getOrganisations
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getOrganisations.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetOrganisations/&gt;';
					
		// getUsers
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getUsers.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetUsers/&gt;';
					
		// getCargoNotificationRequests
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTQueryService.name;
		payload.operationName		:= JMTQueryService::getCargoNotificationRequests.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetCargoNotificationRequests&gt;'
					&amp; '&lt;cargoNoteRequest&gt;'
					&amp; '&lt;allSelectedRequestTypes membership="WS_RequestType" size="1"&gt;'
					&amp; '&lt;WS_RequestType&gt;'
					&amp; '&lt;description&gt;Add HMS Voyage&lt;/description&gt;'
					&amp; '&lt;/WS_RequestType&gt;'
					&amp; '&lt;/allSelectedRequestTypes&gt;'
					&amp; '&lt;cargoId&gt;&lt;/cargoId&gt;'
					&amp; '&lt;cargoTypeId&gt;1&lt;/cargoTypeId&gt;'
					&amp; '&lt;fromDate/&gt;'
					&amp; '&lt;organisationName&gt;Jade Master Terminal&lt;/organisationName&gt;'
					&amp; '&lt;recipients&gt;&lt;/recipients&gt;'
					&amp; '&lt;reference&gt;&lt;/reference&gt;'
					&amp; '&lt;status&gt;-1&lt;/status&gt;'
					&amp; '&lt;toDate/&gt;'
					&amp; '&lt;userCode&gt;&lt;/userCode&gt;'
					&amp; '&lt;/cargoNoteRequest&gt;'
					&amp; '&lt;/GetCargoNotificationRequests&gt;';
					
		// createCargoNotifications
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUpdateService.name;
		payload.operationName		:= JMTUpdateService::createCargoNotifications.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;CreateCargoNotifications&gt;'
					&amp; '&lt;cargoCreateRequest&gt;'
					&amp; '&lt;allNotifyTimes membership="Time" size="1"&gt;'
					&amp; '&lt;/allNotifyTimes&gt;'
					&amp; '&lt;allRequestTypes membership="WS_RequestType" size="1"&gt;'
					&amp; '&lt;WS_RequestType&gt;'
					&amp; '&lt;description&gt;Add HMS Voyage&lt;/description&gt;'
					&amp; '&lt;/WS_RequestType&gt;'
					&amp; '&lt;/allRequestTypes&gt;'
					&amp; '&lt;cargoIds&gt;' &amp; cargoId &amp; '&lt;/cargoIds&gt;'
					&amp; '&lt;cargoTypeId&gt;1&lt;/cargoTypeId&gt;'
					&amp; '&lt;organisationName&gt;Jade Master Terminal&lt;/organisationName&gt;'
					&amp; '&lt;recipients&gt;kdouglas@jadeworld.com&lt;/recipients&gt;'
					&amp; '&lt;reference&gt;web test ref&lt;/reference&gt;'
					&amp; '&lt;remarks&gt;web test remarks&lt;/remarks&gt;'
					&amp; '&lt;/cargoCreateRequest&gt;'
					&amp; '&lt;/CreateCargoNotifications&gt;';					

		// updateCargoNotification
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUpdateService.name;
		payload.operationName		:= JMTUpdateService::updateCargoNotification.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;UpdateCargoNotification&gt;'
					&amp; '&lt;cargoUpdateRequest&gt;'
					&amp; '&lt;cargoId&gt;' &amp; cargoId &amp; '&lt;/cargoId&gt;'
					&amp; '&lt;cargoTypeId&gt;1&lt;/cargoTypeId&gt;'
					&amp; '&lt;organisationName&gt;Jade Master Terminal&lt;/organisationName&gt;'
					&amp; '&lt;requestType&gt;'
					&amp; '&lt;description&gt;Add HMS Voyage&lt;/description&gt;'
					&amp; '&lt;/requestType&gt;'
					&amp; '&lt;status&gt;0&lt;/status&gt;'
					&amp; '&lt;allNotifyTimes membership="Time" size="1"&gt;'
					&amp; '&lt;/allNotifyTimes&gt;'
					&amp; '&lt;recipients&gt;kdouglas@jadeworld.com&lt;/recipients&gt;'
					&amp; '&lt;reference&gt;updated ref&lt;/reference&gt;'
					&amp; '&lt;remarks&gt;updated remarks&lt;/remarks&gt;'
					&amp; '&lt;/cargoUpdateRequest&gt;'
					&amp; '&lt;/UpdateCargoNotification&gt;';					
					
		// deleteCargoNotification
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUpdateService.name;
		payload.operationName		:= JMTUpdateService::deleteCargoNotification.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;DeleteCargoNotification&gt;'
					&amp; '&lt;cargoDeleteRequest&gt;'
					&amp; '&lt;cargoId&gt;' &amp; cargoId &amp; '&lt;/cargoId&gt;'
					&amp; '&lt;cargoTypeId&gt;1&lt;/cargoTypeId&gt;'
					&amp; '&lt;organisationName&gt;Jade Master Terminal&lt;/organisationName&gt;'
					&amp; '&lt;requestType&gt;'
					&amp; '&lt;description&gt;Add HMS Voyage&lt;/description&gt;'
					&amp; '&lt;/requestType&gt;'
					&amp; '&lt;status&gt;0&lt;/status&gt;'
					&amp; '&lt;/cargoDeleteRequest&gt;'
					&amp; '&lt;/DeleteCargoNotification&gt;';					


		// doSearch
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::doSearch.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;DoSearch&gt;'
					&amp; '	&lt;s1:query&gt;'
					&amp; '		&lt;s1:formName&gt;Cargo Enquiry Search&lt;/s1:formName&gt;'
					&amp; '		&lt;s1:maxReturnedItems&gt;50&lt;/s1:maxReturnedItems&gt;'
					&amp; '		&lt;s1:myQueryRequest xsi:type="WS_TrackedItemQueryRequest"&gt;'
					&amp; '			&lt;s1:formName&gt;&lt;/s1:formName&gt;'
					&amp; '			&lt;s1:filterBOL&gt;&lt;/s1:filterBOL&gt;'
					&amp; '			&lt;s1:filterBookingRef&gt;&lt;/s1:filterBookingRef&gt;'
					&amp; '			&lt;s1:filterCarrier&gt;&lt;/s1:filterCarrier&gt;'
					&amp; '			&lt;s1:filterConsignee&gt;&lt;/s1:filterConsignee&gt;'
					&amp; '			&lt;s1:filterConsignor&gt;&lt;/s1:filterConsignor&gt;'
					&amp; '			&lt;s1:filterDateFrom&gt;&lt;/s1:filterDateFrom&gt;'
					&amp; '			&lt;s1:filterDateTo&gt;&lt;/s1:filterDateTo&gt;'
					&amp; '			&lt;s1:filterIMEX&gt;&lt;/s1:filterIMEX&gt;'
					&amp; '			&lt;s1:filterISOType&gt;&lt;/s1:filterISOType&gt;'
					&amp; '			&lt;s1:filterId&gt;1234&lt;/s1:filterId&gt;'
					&amp; '			&lt;s1:filterOperator&gt;&lt;/s1:filterOperator&gt;'
					&amp; '			&lt;s1:filterPIN&gt;&lt;/s1:filterPIN&gt;'
					&amp; '			&lt;s1:filterSite&gt;&lt;/s1:filterSite&gt;'
					&amp; '			&lt;s1:filterTAType&gt;&lt;/s1:filterTAType&gt;'
					&amp; '			&lt;s1:filterTerminalArea&gt;&lt;/s1:filterTerminalArea&gt;'
					&amp; '			&lt;s1:filterTiType&gt;1&lt;/s1:filterTiType&gt;'
					&amp; '			&lt;s1:filterTransportMode&gt;&lt;/s1:filterTransportMode&gt;'
					&amp; '			&lt;s1:filterVoyage&gt;&lt;/s1:filterVoyage&gt;'
					&amp; '			&lt;s1:filterYardLocation&gt;&lt;/s1:filterYardLocation&gt;'
					&amp; '		&lt;/s1:myQueryRequest&gt;'
					&amp; '		&lt;s1:startFrom&gt;1&lt;/s1:startFrom&gt;'
					&amp; '		&lt;s1:totalMatches&gt;&lt;/s1:totalMatches&gt;'
					&amp; '	&lt;/s1:query&gt;'
					&amp; '&lt;/DoSearch&gt;';
					
					
		// getOperatorsForVoyage
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getOperatorsForVoyage.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetOperatorsForVoyage&gt;'
					&amp; '&lt;voyageCode&gt;AORJC04&lt;/voyageCode&gt;'
					&amp; '&lt;/GetOperatorsForVoyage&gt;';					
					
		// getAboutContent
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTUserInterfaceService.name;
		payload.operationName		:= JMTUserInterfaceService::getAboutContent.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;GetAboutContent/&gt;';
					
*/		
		// logout
		create payload;
		payload.myXMLSessionScript	:= session;
		payload.serviceName			:= JMTSecureService.name;
		payload.operationName		:= JMTSecureService::logout.name;
		payload.message				:= ''
					&amp; ''
					&amp; '&lt;Logout xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:s1="http://tempuri.org/"/&gt;';
					
	endforeach;
	
	commitTransaction;
	

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteAllData" id="e4a3f404-15fc-4a3e-aad5-f61cd0965917">
