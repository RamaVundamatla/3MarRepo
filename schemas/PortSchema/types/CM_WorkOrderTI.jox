    <JadeMethod name="pxyCreateUpdateProxy" id="0a4b774e-b6b6-4b53-9872-beca2bd4e642">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date	   Who		Reason
05 Aug 2009	cnwmd1	Initial creation
20 Apr 2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when trying to create the proxy
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	proxy 			: SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	proxySource := app.createUpdateProxy(self.mySource).CM_WorkOrderTISource;
	proxySource.setMyParent(proxy);
	*/
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeTrackedItem" id="462ec210-4c6f-455b-92cb-372241e98555">
        <source>removeTrackedItem( _theTI : CM_TrackedItem);

/*

Purpose: The TI has been removed from a source item etc. Can only be 'removed' if it has not proceeeded anywhere from the first task.

Parameters:			

Return Value:		


Date		Who		Reason
04 Nov 2009	cnwrd1	Initial creation
24 Jan 2023	navma1 	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	theTask 	: CM_WorkOrderDtl;
	txnParams	: CMIF_WorkOrderTransController;
	theTI 		: CM_TrackedItem;
begin

	theTI := _theTI;

	if theTI = null then 
		return;
	endif;
	
	if not self.allTIs.includes( theTI ) then // I dont have this TI
		return;
	endif;
	
	create txnParams transient;
	
	theTask := self.getFirstTask;
	
	if theTask.CM_WorkOrderTIDtl.allAvailableTIs.includes( theTI) then
		theTask.CM_WorkOrderTIDtl.removeTIAvailable( theTI);
		
		txnParams.type := TRANS_TYPE_WORKORDER_UNASSIGN;
		txnParams.myWorkOrder := self;
		theTI.createTransaction(txnParams, app.myPassport);
	endif;
	//epr TFS 42924 8/2/19
	if self.allTIs.includes(theTI) then
		self.allTIs.remove( theTI);
	endif;
epilog
	delete txnParams;
end;
</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
