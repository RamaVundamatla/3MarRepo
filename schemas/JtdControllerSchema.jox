    <Function name="winBitBlt" id="a5d05622-d104-4234-a3b8-4e6afa359fd3">
        <entrypoint>BitBlt</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="gdi32"/>
        <source>winBitBlt
(
	hdcDest : Integer; // handle to destination DC
	nXDest  : Integer; // x-coord of destination upper-left corner
	nYDest  : Integer; // y-coord of destination upper-left corner
	nWidth  : Integer; // width of destination rectangle
	nHeight : Integer; // height of destination rectangle
	hdcSrc  : Integer; // handle to source DC
	nXSrc   : Integer; // x-coord of source upper-left corner
	nYSrc   : Integer; // y-coord of source upper-left corner
	dwRop   : Integer  // raster operation code
)
is BitBlt in gdi32;</source>
        <Parameter name="hdcDest" type="Integer"/>
        <Parameter name="nXDest" type="Integer"/>
        <Parameter name="nYDest" type="Integer"/>
        <Parameter name="nWidth" type="Integer"/>
        <Parameter name="nHeight" type="Integer"/>
        <Parameter name="hdcSrc" type="Integer"/>
        <Parameter name="nXSrc" type="Integer"/>
        <Parameter name="nYSrc" type="Integer"/>
        <Parameter name="dwRop" type="Integer"/>
    </Function>
