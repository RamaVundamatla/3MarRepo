    <JadeMethod name="doDelete" id="51100336-fb8e-4f51-bf34-b918fb5373c9">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
/*
Date		    Who			Reason
11 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

