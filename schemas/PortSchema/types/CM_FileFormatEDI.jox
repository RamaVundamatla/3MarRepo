    <JadeMethod name="findEDIDataType" id="a4d582c3-2a1f-4467-b80e-31ea97833096">
        <source>findEDIDataType(_ediDataClass: Class io; _type: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	terminal		: CM_Terminal;
	ediConfig		: CM_EDIConfig;
begin
//	_singleDataFile := false; // cnwrs1 Par 24207 ccms 1117 11 May 2010
	_type := self.ediDataType;
	terminal := app.getMyTerminalDO_NOT_USE;
	if terminal &lt;&gt; null then
		ediConfig := terminal.myEdiConfig;
	else
		ediConfig := app.myRoot.myEdiConfig;
	endif;	
	_ediDataClass := ediConfig.getEDIDataClassForType(self.ediDataType);

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_type" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="c70b98b7-efcd-464f-9520-11089aa35b2d">
        <updating/>
        <source>processFile(ediFile: CM_EDIFile input) protected, updating;
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars

begin


epilog

end;</source>
        <access>protected</access>
        <Parameter name="ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processFileData" id="06e0cf3d-1b96-4d1f-bca3-708b8d7acbd3">
        <updating/>
        <source>processFileData(_ediFile: CM_EDIFile input; _operator: CM_Operator; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 01 Aug 2012	cnwcs5	par 30136 - change usage of _file parameter
// 15 Apr 2014	cnwrs1	Par 33980 allow the hook code to set the edi file status
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	defOperator	: CM_Operator;
	tmpStr		: String;
	ediTI : CM_EDITrackedItem;
begin
	//set status
	app.myTrxUA.trxUpdateEDIFileStatus(_ediFile, CM_EDIFile.EDI_STATUS_LOADING, _passport);

	//check for operator before processing
	if _operator = null 
	and self.myOperator = null then
		tmpStr := app.getTerminologyAlternate(null, _passport.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
		//app.raiseCMException1(REQUIRED_FIELD, tmpStr, 'myOperator', null);
		app.raiseCMException2(ERR_INVALID_VALUE, tmpStr, "Check that the required operator (" &amp; self.operatorCode &amp; ") exists.", 'myOperator', null);
		return;
	endif; 
	
	defOperator := self.myOperator;		
	beginTransaction;
	//load
	if _operator &lt;&gt; null then
		self.myOperator := _operator;
		
	endif;
		
//	self.loadFile(file, _ediFile, 0);
	
	//process
	self.processFile(_ediFile);
	foreach ediTI in _ediFile.ediData.allEDITrackedItems do
		ediTI.setMyEDIConfig(_ediFile.ediData.ediConfig);
		ediTI.doTranslations(_ediFile.ediData.getXlationOperator());
	endforeach;
//	_ediFile.ediData.doTranslations();	
	
	self.myOperator := defOperator;
	app.cmsCommitTransaction(_passport);
	
	if _passport.allErrors.size = 0 then
		if _ediFile.fileStatus = CM_EDIFile.EDI_STATUS_UNPROCESSED or
		   _ediFile.fileStatus = CM_EDIFile.EDI_STATUS_LOADING then
			app.myTrxUA.trxUpdateEDIFileStatus(_ediFile, CM_EDIFile.EDI_STATUS_LOADED, _passport);
		endif;
	else
		app.myTrxUA.trxUpdateEDIFileStatus(_ediFile, CM_EDIFile.EDI_STATUS_LOADED_ERRORS, _passport);
	endif;
epilog
	if process.isInTransactionState then
		app.cmsCommitTransaction(_passport);
	endif;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1e253a91-b783-4db2-9a89-4d9ae1fb047d">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------------------------
//	Created:	17 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxy		: CM_FileFormatEDI;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();
	
	pxy.myOperator := self.myOperator;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateUser" id="a5ddd0df-0aa2-479e-a71c-77d704f126c0">
        <updating/>
        <source>setForUpdateUser(_name: String; _desc: String; _nolongerUsed: Boolean; _operator: CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	17 November 2005	by Jason Chapman  (cnwjc2)
//
//	We allow users to update a few things on these objects.  Operator
//
//----------------------------------------------------------------
vars

begin
	self.set(_name, _desc, _nolongerUsed);
	
	if _operator &lt;&gt; null then
		//must have an operator
		self.operatorCode := _operator.code;
		self.myOperator := _operator;
	endif;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_nolongerUsed" type="Boolean"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="f6f497d0-51bb-458e-9636-7f3c560248df">
        <updating/>
        <source>setFromXML(_xmlDoc: JadeXMLDocument; _key: Integer) updating;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	xmlElement		: JadeXMLElement;
	elemArray		: JadeXMLElementArray;
	operator		: CM_Operator;
begin
	//clean out first
	self.allFileFieldsByName.purge;
	self.allFileFieldsBySysName.purge;
	
	self.sequenceNumber := _key;
	
	xmlElement := _xmlDoc.getElementByTagName('FormatName');
	if xmlElement &lt;&gt; null then
		self.description := xmlElement.textData;
	endif;
	
	xmlElement := _xmlDoc.getElementByTagName('EDIDataType');
	if xmlElement &lt;&gt; null then
		self.ediDataType := xmlElement.textData.Integer;
	endif;
	
	if self.myOperator = null then
	//set new ones only
		xmlElement := _xmlDoc.getElementByTagName('XlationOperator');
		if xmlElement &lt;&gt; null then
			self.setOperator(xmlElement.textData);
		endif;
	endif;
	
	create elemArray transient;
	_xmlDoc.getElementsByTagName('FormatField', elemArray);
	
	foreach xmlElement in elemArray do
		self.addFileFieldNew(xmlElement);
	endforeach;
	
epilog
	delete elemArray;
	
end;</source>
        <Parameter name="_xmlDoc" type="JadeXMLDocument"/>
        <Parameter name="_key" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setOperator" id="ed74fe13-c689-4d60-b015-8db404ddd931">
        <updating/>
        <source>setOperator(_operatorCode: String) updating;
//----------------------------------------------------------------
//	Created:	12 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	opCode	: String;
begin

	opCode := _operatorCode;
	self.operatorCode := opCode;
	self.myOperator := app.myRoot.allOperators[opCode];
	
end;</source>
        <Parameter name="_operatorCode" type="String"/>
    </JadeMethod>
