    <JadeMethod name="getRotatedFlippedRowColText" id="5bcd0c23-e107-4939-a07b-f92bf45a248f">
        <source>getRotatedFlippedRowColText(_rowFrom, _rowTo, _colFrom, _colTo : String io;
							_taViewPos : CM_TerminalAreaViewPosition );

/*

Purpose:	A Method to take a loaction string, such as "01-02 C1-C2" and adjust it to reflect the rotated and flipped state of a TA 		

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2009	cnwjk3	SFW1030

*/

vars
	temp 	: String;
	
begin
	if _taViewPos = null then
		return;
	endif;
	if _taViewPos &lt;&gt; null then
		if _taViewPos.rotation = 90 then
			temp := _rowFrom;
			_rowFrom := _rowTo;
			_rowTo := temp;
		elseif _taViewPos.rotation = 180 then
			temp := _rowFrom;
			_rowFrom := _rowTo;
			_rowTo := temp;				

			temp := _colFrom;
			_colFrom := _colTo;
			_colTo := temp;
		elseif _taViewPos.rotation = 270 then
			temp := _colFrom;
			_colFrom := _colTo;
			_colTo := temp;
		endif;
		if _taViewPos.horizontalFlip then
			temp := _colFrom;
			_colFrom := _colTo;
			_colTo := temp;
		endif;
		if _taViewPos.verticalFlip then
			temp := _rowFrom;
			_rowFrom := _rowTo;
			_rowTo := temp;
		endif;
	endif;
epilog
end;</source>
        <Parameter name="_rowFrom" type="String" usage="io"/>
        <Parameter name="_rowTo" type="String" usage="io"/>
        <Parameter name="_colFrom" type="String" usage="io"/>
        <Parameter name="_colTo" type="String" usage="io"/>
        <Parameter name="_taViewPos" type="CM_TerminalAreaViewPosition"/>
    </JadeMethod>
