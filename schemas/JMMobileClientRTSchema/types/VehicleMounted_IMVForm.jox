    <JadeMethod name="loadTaskTable" id="28dc0094-273d-4b26-99df-baa2e76355e4">
        <updating/>
        <source>loadTaskTable() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theTable : Table;
	row : Integer;
begin
	theTable:=tblJobs;
	
	row:=theTable.fixedRows + 1;
	while row &lt;= theTable.rows do
		theTable.deleteRow(row);
	endwhile;
	
	app.myVehicleMountedIMVGuiAgent.loadTable(self.tblJobs);
	//this just updates the colors
	self.updateTableElapsedTimes();
	
	if theTable.rows &gt; theTable.fixedRows then
		if (not self.timerRefreshActive) then
			self.beginTimerForRefresh();
		endif;
	endif;
	
	self.setupDefaultButtons();
	

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupDefaultButtons" id="a68cbaf5-0582-48d7-8912-d1868a24fda0">
        <source>setupDefaultButtons();
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 Oct 2006	cnwer1	Initial creation - PAR#xxxx
30 Oct 2009	cnwer1	PAR 20701 reject now always enabled
*/
vars

begin
	self.btnComplete.enabled:=false;
	self.btnReject.enabled:=true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b4a6bf7e-14fc-4b40-b049-1c2b5c81da94">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	errorStr : String;
begin
	inheritMethod();
	
	if not app.isRunningOnCE then
		self.borderStyle := self.BorderStyle_Single;
		self.caption := 'IMV Dev mode (has control box)';
		self.height := self.height + 25;
	endif;
	
	self.setupTable;
	self.setupTaskCaption;
	self.loadReasonCombo;
	self.btnComplete.visible:= app.isDevelopmentSystem;
	self.btnAttach.visible:= app.isDevelopmentSystem;
	self.btnComplete.caption:="Complete";
	self.setupDefaultButtons;
	
	configElapsedTime:=app.myHandHeldGuiAgent.getTerminalConfig(HandHeldAgent.ConfigElapsedTimeExceeded).Integer;

	self.loadTaskTable();
	self.changeDefaultButtons(btnMsgOK,btnAccept);
	self.changeCancelButtons(btnMsgCancel,btnLogoff);
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupMsgFrameNew" id="3de3376a-1aa2-466a-8cf5-216ad0442a75">
        <updating/>
        <source>setupMsgFrameNew(_type : String;
					_containerId,
					_fromLoc, 
					_toLoc : String io;
					_ostow : Boolean;
					_canEditTo :Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
constants
	Complete = "Complete";
	Overstow = "Overstow";
	MoveLabel = " move of ";
	From = " from ";
	To = " to ";
	Unknown = "...";
vars
	moveString : String;
begin
	//initalise 
	lblRow.visible:=true;
	txtRow.visible:=_canEditTo;
	lblRow.visible:=_canEditTo;
	frmAccept.centreWindow();	
	
	fromLocationId:=_fromLoc;
	toLocationId:=_toLoc;
	if _ostow then	
		moveString:=Overstow;
	else
		moveString:=Complete;
	endif;
	if _canEditTo then
		txtRow.text:=toLocationId;
	endif;
	self.clearErrors;
	currentContainerId :=_containerId;
	self.lblMsg.caption:=moveString &amp; MoveLabel &amp; _containerId &amp; From  &amp; _fromLoc &amp; To &amp; _toLoc;

	self.frmAccept.visible:=true;
	self.changeDefaultButtons(btnAccept,btnMsgOK);
	self.changeCancelButtons(btnLogoff,btnMsgCancel);

epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_containerId" type="String" usage="io"/>
        <Parameter name="_fromLoc" type="String" usage="io"/>
        <Parameter name="_toLoc" type="String" usage="io"/>
        <Parameter name="_ostow" type="Boolean"/>
        <Parameter name="_canEditTo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupTable" id="6cfccd5d-45e7-4268-9a83-ea7c25704ded">
        <source>setupTable() protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theTable : Table;
begin
	theTable := self.tblJobs;
	
	theTable.rows := 0;
	theTable.columns := 10;
	theTable.selectMode := Table.SelectMode_CurrentRow;
	theTable.alignment := Table.Alignment_Center_Top;
	theTable.addItem(ColType &amp; Tab &amp; ColStatus &amp; Tab  &amp; ColDorDir &amp; Tab &amp; ColId &amp; Tab &amp; ColSource &amp; Tab &amp; ColTarget &amp; Tab &amp; ColTime &amp; Tab &amp; ColOstow &amp; Tab &amp; ColHaz &amp; Tab);
	theTable.columnVisible[10]:=false;
	theTable.sortColumn[1]:=10;
	theTable.sortAsc[1]:=true;
	theTable.fixedRows := 1;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTaskCaption" id="f53eca81-ea8d-44b2-90cf-d8e2ed847aca">
