<Class name="CMQF_ExpContLoad" id="04ddc630-1231-4839-816b-143fc1f145fe">
    <superclass name="CMQF_TrackedItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="b6583783-b34f-4e59-bb01-242df8854330">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		13 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ti				: CM_TrackedItem;
	sti				: CMIF_SummaryTI;
	tiSet			: CM_TISet;
	breakOut		: Boolean;
begin
	create tiSet transient;
	//need a voyage
	if self.getMyVoyage &lt;&gt; null then
		//search ship
		foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					tiSet.add(ti);
					create sti transient;
					self.setupSummaryObject(sti, ti);
					_collection.add(sti);
				endif;
			endif;
		//	if breakOut then
		//		return;
		//	endif;
		endforeach;
		//search onsite
		foreach ti in self.getMyVoyage.allOnsiteTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
		//	if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					tiSet.add(ti);
					create sti transient;
					self.setupSummaryObject(sti, ti);
					_collection.add(sti);
				endif;
			endif;
			
		//	if breakOut then
		//		return;
		//	endif;
		endforeach;
	endif;
epilog
	delete tiSet;	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="d4b71c1e-de1f-4313-b7f4-a690aa4135d5">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		13 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars

begin
	if (not CM_Log.hasInstance(_ti)) and
		_ti.myParent = null and
	   //(_ti.isExport or _ti.isRehandle or _ti.isSOB) and							// PAR #25021
	   (_ti.isExport or _ti.isTranshipOutbound or _ti.isRehandle or _ti.isSOB) and	// PAR #25021
	   inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupSummaryObject" id="88af1f28-4d7f-4ed7-a0c9-d6b155ce2b10">
        <source>setupSummaryObject(_summaryTI: CMIF_SummaryTI io;_ti: CM_TrackedItem) protected;
// ---------------------------------------------------------------------------
// Created:		17 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	_summaryTI.setTI(_ti);
	_summaryTI.setSequenced(false);
	_summaryTI.setTIFields();
	_summaryTI.setSummaryFields();
end;</source>
        <access>protected</access>
        <Parameter name="_summaryTI" type="CMIF_SummaryTI" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
