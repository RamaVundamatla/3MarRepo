    <JadeMethod name="doResize" id="447000f4-39f0-42a8-bae8-f930465e45fa">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	//This was placing the buttons such that they were half hidden
	//self.btnCancel.top := self.height - WinBottomMargin - self.btnCancel.height;
	self.btnCancel.top := self.lblTwo.top + self.lblTwo.height + VerticalSpacing;
	self.btnSave.top := self.btnCancel.top;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="c588da9d-7da5-439c-94e4-f89bd76d9749">
        <updating/>
        <source>doSave() : Boolean updating;
//--------------------------------------------------------------
//Created: 04 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	obj			: Object;
	mask		: String;
	needGen,
	needCOU,
	doorForward,
	heavy		: Boolean;
	aveGrades	: IntegerArray;
	pxyRequest 	: CM_DeliveryRequest;
	
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	app.mousePointer := MousePointer_HourGlass;
		
	pxyRequest := app.createUpdateProxy(self.myDeliveryRequest).CM_DeliveryRequest;	
	
	create aveGrades transient;
	
	foreach obj in self.lstMTGrade.allSelectedObjects do
		aveGrades.add(obj.CM_MTGrade.code);
	endforeach;
	
	mask := self.tblMain.accessCell(5,2).text;
	if self.tblMain.accessCell(1,2).text = '1' then
		needGen := true;
	endif;
	if self.tblMain.accessCell(2,2).text = '1' then
		needCOU := true;
	endif;
	if self.tblMain.accessCell(3,2).text = '1' then
		doorForward := true;
	endif;	
	if self.tblMain.accessCell(4,2).text = '1' then
		heavy := true;
	endif;	

	pxyRequest.setProxyAdditionalInfo(needGen, needCOU, doorForward, heavy, mask, aveGrades);
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateRequest(pxyRequest, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Additional Information', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;																				
	
	return true;
	
epilog
	delete pxyRequest;
	delete aveGrades;
	app.mousePointer := MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="4ee99772-7e89-4065-bb80-69435eecec06">
        <source>initTable();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;

begin
	self.tblMain.defaultRowHeight := 17;
	self.tblMain.rows := 0;	
	self.tblMain.columns := 2;
	self.tblMain.fixedColumns := 1;
	self.tblMain.fixed3D := false;
	self.tblMain.fixedRows := 0;
	self.tblMain.accessColumn(1).width := 100;
	self.tblMain.accessedColumn.backColor := self.clrOneDark.backColor;
	
	idx := self.tblMain.addItem("Generator");
	self.tblMain.accessCell(idx,2).inputType := Table.InputType_CheckBox;
//	self.tblMain.accessedCell.cellControl := chkGenerator.loadControl(1);
//	chkGenerator.getControl(1).backColor  := self.clrOne.backColor;
	
	idx := self.tblMain.addItem("Clip On Unit");
	self.tblMain.accessCell(idx,2).inputType := Table.InputType_CheckBox;
//	self.tblMain.accessedCell.cellControl := chkCOU.loadControl(1);
//	chkCOU.getControl(1).backColor  := self.clrOne.backColor;

	idx := self.tblMain.addItem("Doors Forward");
	self.tblMain.accessCell(idx,2).inputType := Table.InputType_CheckBox;
//	self.tblMain.accessedCell.cellControl := chkDoorForward.loadControl(1);
//	chkDoorForward.getControl(1).backColor  := self.clrOne.backColor;

	idx := self.tblMain.addItem("Heavy Duty");
	self.tblMain.accessCell(idx,2).inputType := Table.InputType_CheckBox;
//	self.tblMain.accessedCell.cellControl := chkHeavy.loadControl(1);
//	chkHeavy.getControl(1).backColor  := self.clrOne.backColor;

	idx := self.tblMain.addItem("Additional Mask");
	self.tblMain.accessRow(idx).alignment := Table.Alignment_Left_Top;
	self.tblMain.accessCell(idx,2).inputType := Table.InputType_TextBox;
	self.tblMain.accessColumn(2).backColor := self.clrOne.backColor;		
	
	idx := self.tblMain.addItem("Availability Grade");
	// CCMS 1235
//	self.tblMain.accessRow(idx).height := (app.myRoot.allAvailabilityGrades.size * 17);
	self.tblMain.accessRow(idx).height := (app.myRoot.allAvailableAvailabilityGrades.size * 17);
	self.tblMain.accessCell(idx,2).inputType := Table.InputType_TextBox;
	self.tblMain.accessedCell.cellControl := self.lstMTGrade;	

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="6055788c-fc8d-4b52-ba23-5ac216cacf17">
        <updating/>
        <source>loadDataForFirstTime()updating, protected;
//--------------------------------------------------------------
//Created: 04 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	str			: String;
begin
	
	str := app.getErrorString4(DeliveryRequestInfo,
							   self.myDeliveryRequest.deliveryNumber,
							   self.myDeliveryRequest.totalRequested.String,
							   self.myDeliveryRequest.isoType,
							   self.myDeliveryRequest.consigneeCode);
							   
	self.lblReqDesc.caption := str;
	
	if self.myDeliveryRequest.needGenerator then
		self.tblMain.accessCell(1,2).text := '1';
	endif;
	if self.myDeliveryRequest.needCOU then
		self.tblMain.accessCell(2,2).text := '1';
	endif;
	if self.myDeliveryRequest.doorsForward then
		self.tblMain.accessCell(3,2).text := '1';
	endif;
	if self.myDeliveryRequest.heavyRated then
		self.tblMain.accessCell(4,2).text := '1';
	endif;
	
	self.tblMain.accessCell(5,2).text := self.myDeliveryRequest.getIdsAsString;	
	self.myAssistant.setListTableMTGrade(lstMTGrade, self.myDeliveryRequest.allAvailabilityGrades);
	self.tblMain.accessCell(6,2).text := self.lstMTGrade.getSelectedString('code');			

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstMTGrade_displayRow" id="e7522676-4e40-4dc2-809c-bf9d9767f1bc">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstMTGrade_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
//--------------------------------------------------------------
//Created: 04 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	selected	: Boolean;
begin

	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	return self.myAssistant.displayEntryMTGradeList(obj.CM_MTGrade, selected);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
