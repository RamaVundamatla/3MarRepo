    <JadeMethod name="handleISOTypeObj" id="a23dd77c-66e9-4596-94ed-88fe43ecbc2e">
        <source>handleISOTypeObj(_isoTypeCode : String; _codesArray : StringArray input; _colorArray :IntegerArray input;_objArray : ObjectArray input);
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
