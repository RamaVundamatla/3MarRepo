    <JadeMethod name="populateFromVehicleBookingTS" id="8fbf36c2-66bc-4ebe-9a54-1e41fc5a0cd6">
        <updating/>
        <source>populateFromVehicleBookingTS( vbsts : CM_VehicleBookingTimeSlot ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2014	cnwndl1	Initial creation
14/09/2016	cnwma1	TFS #2619:SPT - Road Gate loading incorrect release/prenote details when entering the Reg Code
13/05/2022  navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
*/

vars

	vvr 		: CM_VehicleVisitRecord;
	driver	    : CM_DriverDetails;
	vehicle 	: CM_Vehicle;
	carrier,
	subCarrier : CM_Carrier;

begin

	if vbsts = null then
		return;
	endif;
	
	if self.myRealVVR = null then
		// don't do it if its already set up.
		vvr := vbsts.myVehicleVisitRecord;
	endif;
	if vvr &lt;&gt; null then
		self.txtVisitNumber.text := vvr.visitNumber;
		//self.doQuery();  // 14/09/2016 cnwma1 TFS #2619
		self.doQuery(vvr); // 14/09/2016 cnwma1 TFS #2619
		self.hasChanged := false;
	
		driver := vvr.myDriverDetails;
		vehicle := vvr.vehicle;
		carrier := vvr.getCarrier;
		subCarrier := vvr.getSubCarrier;			//13/05/2022 navhl20 TFS 53430 
	else
		driver := vbsts.myDriver;
		vehicle := vbsts.myVehicle;
		carrier := vbsts.myCarrier;
		subCarrier  := vbsts.mySubCarrier;			//13/05/2022 navhl20 TFS 53430 
	endif;
	
	
	
	//02 Dec 2014	cnwer1	par 35304
	if vehicle &lt;&gt; null then
		if self.txtRegno.visible  and self.txtRegno.text &lt;&gt; vehicle.regNumber then
			self.detailsChangedVehicle := true;
			self.txtRegno.text := vehicle.regNumber;
			if vehicle.state.trimBlanks &lt;&gt; null and self.txtState.text &lt;&gt; vehicle.state then
				self.txtState.text := vehicle.state;
			endif;
			self.onRegChanged();
		elseif self.cmbRegNo.visible then
			self.cmbRegNo.setIndexFromObject(vehicle);
			self.onRegChanged();
		endif;
	endif;
	
	if driver &lt;&gt; null then
		self.setDriverDetails(driver);
	endif;
	
	if carrier &lt;&gt; null and self.cmbCarrier.listObject &lt;&gt; carrier then
		self.detailsChangedVehicle := true;
		if self.cmbCarrier.findObject(carrier) = -1 then 
			self.cmbCarrier.addItemObject(carrier.description, carrier);
		endif;
		self.cmbCarrier.listObject := carrier;
		self.populateTblBulkRelease(carrier);
	endif;
	
	//Start 13/05/2022 navhl20 TFS 53430 
	if isSubCarrierEnabled then
		if subCarrier &lt;&gt; null and self.cmbSubCarrier.listObject &lt;&gt; subCarrier then
			self.detailsChangedVehicle := true;
			if self.cmbSubCarrier.findObject(subCarrier) = -1 then 
				self.cmbSubCarrier.addItemObject(subCarrier.description, subCarrier);
			endif;
			self.cmbSubCarrier.listObject := subCarrier;
		endif;
	endif;
	//End 13/05/2022 navhl20 TFS 53430 

epilog

end;</source>
        <access>protected</access>
        <Parameter name="vbsts" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="populateTblBulkRelease" id="95ac58c7-504c-4b72-be92-5886724780b3">
        <source>populateTblBulkRelease(pCarrier : CM_Carrier) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19/09/2011	cnwndl1	Initial creation	Par 24455
08/06/2022	navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
28/07/2025  navma1  MTN-35577  MTN - Error 1081 While doing Road Receive Transaction with CM_BulkReleaseByCodeDict
*/

vars

	tmpTable	: CM_DataTable;
	bulkRelease	: CM_BulkRelease;
	carrierCode : String;
	iter 		: Iterator;
	rowIdx		: Integer;
	str			: String;
	reserve 	: CM_ReserveDetail;
	firstTi		: CM_TrackedItem;
begin

	clearTblBulkRelease();
	self.btnRelAction.enabled := false;
	
	if pCarrier = null then
		return;
	endif;
	
	//Start 08/06/2022 navhl20 TFS 53430
	if pCarrier.isSubCarrier then
		return;
	endif;
	//End 08/06/2022 navhl20 TFS 53430
	
	//02 Aug 2016	NDL	TFS 2473
	if fldrDetails.topSheet &lt;&gt; self.shtTransfers or self.shtTransfers.enabled = false then
		return;
	endif;
	
	tmpTable    := self.tblBulkRelease;			
	carrierCode := pCarrier.code.trimRight;

	iter := self.myTerminal.allBulkReleaseByTypeByStByCd.createIterator();
	self.myTerminal.allBulkReleaseByTypeByStByCd.startKeyGeq(BR_TYPE_ROAD,BR_ACTIVE, null, null, iter); 
	
	while iter.next(bulkRelease) do
		if bulkRelease.type &lt;&gt; BR_TYPE_ROAD 
		or bulkRelease.status &lt;&gt; BR_ACTIVE then
			break;
		endif;
		if bulkRelease.carrierId.trimRight &lt;&gt; carrierCode then 
			continue;
		endif;
	
		foreach reserve in bulkRelease.allReserveDetails discreteLock do
			
			if reserve.isKindOf(CM_ReserveTI) then							//28.07.2025 navma1 #MTN-35577
				
				if reserve.allTrackedItemsReleased.isNotEmpty() then
					continue;
				endif;
				
				firstTi := reserve.getFirstTI(false);
				if firstTi &lt;&gt; null and firstTi.jobRoadRelease &lt;&gt; null then
					continue;
				endif;
				
				
			endif;
			
			str := reserve.getAttributeStringForDefArray(self.tblBulkRelease.allTblDataEntRows);
			
			if not self.tblBulkRelease.findObjectInRow(reserve, rowIdx) then
				self.tblBulkRelease.addItemObject(reserve, str);
			else
				self.tblBulkRelease.setCellText(rowIdx, 1, str);
			endif;
			
			self.tblBulkRelease.beginNotification(reserve, Object_Delete_Event, Response_Cancel, 0);
			
		endforeach;			

	endwhile;

epilog
	delete iter;		
end;</source>
        <access>protected</access>
        <Parameter name="pCarrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="populateTblTransfers" id="4da6e259-69ac-456d-8c24-f23f941e4d7f">
        <source>populateTblTransfers() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2011	cnwndl1	Initial creation	Par 24455

*/

vars

	ti : CM_TrackedItem;
	idx : Integer;
	str : String;
	entRow : EntTableRow;
	pos : Integer;
	gte : CMGTE_Entity;
	alreadyInItemsTable : Boolean;
	deleted : Boolean;
	onSiteTi : CM_TrackedItem;
	gteTi : CM_TrackedItem;
	tiDeleted : Boolean;

begin

	self.tblTransfers.rows := self.tblTransfers.fixedRows;
	
	on Exception do app.handleDeletedObject( exception, gte, deleted );
	on Exception do app.handleDeletedObject( exception, gteTi, tiDeleted );	//16 Mar 2012	NDL	Par 28495

	foreach ti in self.myTerminal.allInTransitTIsToByFromTypeId do
	
		if self.tblTransfers.findObjectInRow(ti, idx) then
			continue;
		endif;
		
		// Don't show items already in the processing list
		alreadyInItemsTable := false;
		if self.tblItems.rows &gt; self.tblItems.fixedRows then
			foreach pos in self.tblItems.fixedRows + 1 to self.tblItems.rows do
				deleted := false;
				gte := self.tblItems.accessRow(pos).itemObject.CMGTE_Entity;
				if gte.isCMGTE_Receival then
					//16 Mar 2012	NDL	Par 28495
					gteTi := gte.CMGTE_Receival.myTrackedItem;
					if gteTi &lt;&gt; null and gteTi.id = ti.id then
						alreadyInItemsTable := true;
						break;
					endif;
				endif;
				if deleted then
					continue;
				endif;
			endforeach;
		endif;
		if alreadyInItemsTable then
			continue;
		endif;
		
		// Don't show items already on site...
		onSiteTi := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq( ti.cargoType, ti.id);
		if onSiteTi &lt;&gt; null and onSiteTi.cargoType = ti.cargoType and onSiteTi.id = ti.id then
			continue;
		endif;
		
		str := null;
		foreach entRow in self.tblTransfers.allTblDataEntRows do
			str := str &amp; ti.getDisplayStringForAttribute(entRow.name, false) &amp; Tab;
		endforeach;
		idx := self.tblTransfers.addItem(str);
		self.tblTransfers.accessRow(idx).itemObject := ti;
		
	endforeach;
	
	self.btnTfrAction.enabled := false;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="15fd6089-cbb2-4884-8cba-c7d11ce0db2f">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/09/2009	cnwas3	Initial creation
09/02/2011	cnwdap1	PAR #26929 Don't save VVR if we're just closing the form
*/
vars

begin
	if self.hasChanged then
		if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			cancel := 1;
		endif;
	endif;
	/* PAR #26929 what it used to be
	if app.msgBox(app.getErrorString(WARNING_EXIT_SCREEN),app.getErrorString(Confirmation),MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then	
		cancel := 1;
	else
		if self.myRealVVR &lt;&gt; null then
			self.doUpdateVVRec();
		endif;
	endif;	*/
epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="releaseRequiresDriverIDCheck" id="0112257b-2e70-49c1-a3aa-87215acc3098">
        <updating/>
        <source>releaseRequiresDriverIDCheck() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/02/2020	jlgdap1		Initial creation TFS 48688 SNO Driver Identity Check for some variances in road gate process
// 13/06/2024	jlizm1		TFS 63908 Allow duplicate driver names
//
vars
	entity : CMGTE_Entity;
	checkID, relFull, relAll : String;
	showDriverCheck : Boolean;
	ti : CM_TrackedItem;

begin
	checkID := self.myTerminal.getConfig(RoadGateDriverIDCheck).String;
	if checkID &lt;&gt; null then
		relFull := app.getErrorString(Release_Full);
		relAll := app.getErrorString(All_Releases);
		if self.myRealVVR &lt;&gt; null then
			foreach entity in self.myRealVVR.allGateEntities where entity.isRelease do
				ti := entity.CMGTE_Release.myTrackedItem;
				if (checkID = relAll and entity.CMGTE_Release.cargoType = TI_CargoType_Container)
				or (checkID = relFull and ti = null and entity.CMGTE_Release.cargoType = TI_CargoType_Container and not entity.CMGTE_Release.mtOnly)
				or (checkID = relFull and ti &lt;&gt; null and ti.isContainer and not ti.isEmpty) then
					showDriverCheck := true;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if showDriverCheck then
		if self.myTerminal.getConfig(KnownTruckDriverRequired).Boolean then
			if not self.driverIDScanned and self.cmbDriver.enabled then
				self.cmbDriver.listIndex := -1;
			endif;
			
			self.cmbDriver.enabled := false;
			self.lblDriverCode.enabled := false;
			self.btnCheckID.left := self.cmbDriver.left + self.cmbDriver.width + 10;
		else
			if not self.driverIDScanned and self.txtDriverCode.enabled then
				self.txtDriverCode.text := null;
				self.txtDriverName.text := null;
			endif;
			
			self.cmbDriverCode.enabled := false;
			self.txtDriverCode.enabled := false;
			self.txtDriverName.enabled := false;
			self.lblDriverCode.enabled := false;
			self.lblDriverName.enabled := false;
			self.btnCheckID.left := self.txtDriverName.left + self.txtDriverName.width + 5;
		endif;
		if self.cmbDriver.listIndex &lt; 0 and self.txtDriverCode.text = null then
			self.btnCheckID.visible := true;
			self.driverIDScanned := false;
		endif;				
		if self.myTerminal.getConfig(ShowVehicleState).Boolean then
			self.btnCheckID.left := self.txtState.left + self.txtState.width + 5;
		endif;
	else
		if self.myTerminal.getConfig(KnownTruckDriverRequired).Boolean then
			self.cmbDriver.enabled := true;
			self.lblDriverCode.enabled := true;
		else
			self.txtDriverCode.enabled := true;
			self.txtDriverName.enabled := true;
			self.lblDriverCode.enabled := true;
			self.lblDriverName.enabled := true;
		endif;
		self.btnCheckID.visible := false;
		self.driverIDScanned := false;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resize" id="902f11a9-41ef-46e8-a744-0ee95d031c1f">
