    <JadeMethod name="pxyCreateUpdateProxy" id="4debc1ec-6078-42a1-a510-8cbe18f86343">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     02 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	prxyTermSubArea : CM_TerminalSubArea;
	completedOK		: Boolean;
begin
	
	prxyTermSubArea := inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return prxyTermSubArea;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete prxyTermSubArea;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e5f4d727-885c-4f81-98bc-70a5f10dbaa4">
        <updating/>
        <source>setForCreate(_pxyTerminalSubArea : CM_TerminalSubArea; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     03 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	self.myTerminalArea := _pxyTerminalSubArea.myTerminalArea;

	self.setForUpdate(_pxyTerminalSubArea);
end;</source>
        <Parameter name="_pxyTerminalSubArea" type="CM_TerminalSubArea"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="235ffee7-f600-49dc-977a-9dbf7111f931">
        <updating/>
        <source>setForUpdate(_prxTerminalSubArea : CM_TerminalSubArea) updating;
// ---------------------------------------------------------------------------
// Created:     03 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.id &lt;&gt; _prxTerminalSubArea.id then 
		self.id  := _prxTerminalSubArea.id; 
	endif;
	
	self.colour := _prxTerminalSubArea.colour;
	
	self.allYardControllers.clear();
	_prxTerminalSubArea.allYardControllers.copy(self.allYardControllers);
end;</source>
        <Parameter name="_prxTerminalSubArea" type="CM_TerminalSubArea"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="72a48821-8063-410f-bbde-66055a2cc7aa">
        <updating/>
        <source>setProxy(_description : String; _colour : Integer; _terminalArea : CM_TerminalArea; 
_yardControllers : CM_YardControllerSet)updating;
// ---------------------------------------------------------------------------
// Created:     03 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	self.id := _description[1:20];
	self.myTerminalArea := _terminalArea;
	self.colour := _colour;
	_yardControllers.copy(self.allYardControllers);

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_yardControllers" type="CM_YardControllerSet"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="51bc86e5-0070-4b4f-b199-25f514a0f2da">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     03 May 2005	cnwhjg1
//
// Purpose:  
//27/06/2022 		NAVDS20 			TFS 53760  DuplicateItem not Translatable   
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myTerminalArea.allSubAreas.includesKey(self.id) then 
		//app.raiseCMException2(DuplicateItem, self.id, app.getErrorString(TerminalArea) &amp; " - " &amp; self.myTerminalArea.id , null, null); //27/06/2022 NAVDS20 TFS 53760
		// %1 already exists for %2 - %3 : Already_exists_2
		app.raiseCMException2(Term_already_exists, self.id, self.myTerminalArea.id , null, null); //27/06/2022 NAVDS20 TFS 53760
	endif;
	
	
	self.validateForUpdate();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="07bd6c13-dcd7-4ac6-992c-eb98a84b9664">
