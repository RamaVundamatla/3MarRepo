    <JadeMethod name="validateForUpdate" id="f8784172-f006-410d-a2ef-8604863c9826">
        <source>validateForUpdate(pRealTerminalArea: CM_TerminalArea);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwjk3	Initial creation

*/

vars
	realTA : CM_RoRoLaneArea;
begin
	inheritMethod(pRealTerminalArea);
	
	realTA := self.pxyGetRealObject();
	if realTA &lt;&gt; null then
		if realTA.standardGap &lt;&gt; self.standardGap then
			if realTA.hasQueuedPlannedActualTIs() then
				app.raiseCMException(RoRo_StandardGapChangeError, null, null);
			endif;
		endif;
	endif;
	
	self.validateLanesForUpdate();
epilog

end;</source>
