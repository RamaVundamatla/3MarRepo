    <JadeMethod name="includeObject" id="9107e87f-53f6-41fc-9011-a793c5cf0ea0">
        <updating/>
        <source>includeObject(_obj: CM_DutyDoc; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	if self.filterBOL &lt;&gt; null and _obj.bol &lt;&gt; self.filterBOL then
		return false;
	endif;
	
	if self.filterBillNum &lt;&gt; null and not _obj.id.startsWith(self.filterBillNum) then
		return false;
	endif;
	
	if self.filterTicket &lt;&gt; null and not _obj.ticket.startsWith(self.filterTicket) then
		return false;
	endif;
	
	if self.cmbStatus.listIndex &gt; 0 and  _obj.status &lt;&gt; self.filterStatus then
		return false;
	endif;
	
	if self.filterDeliveryOrder &lt;&gt; null and _obj.deliveryOrder &lt;&gt; self.filterDeliveryOrder then
		return false;
	endif;
	
	if self.filterVoyage &lt;&gt; null and _obj.voyage &lt;&gt; self.filterVoyage then
		return false;
	endif;
	
	if self.filterConsignee &lt;&gt; null and _obj.consignee &lt;&gt; self.filterConsignee.code then
		return false;
	endif;
	
	if self.filterForwarder &lt;&gt; null and _obj.forwarder &lt;&gt; self.filterForwarder.code then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_DutyDoc"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
