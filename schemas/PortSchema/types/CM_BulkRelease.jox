    <JadeMethod name="getISOGroupFromType" id="23810296-3e54-4d55-ab2b-0cf4f8f17813">
        <source>getISOGroupFromType(): CM_ISOTypeGroup;

/*
Date			Who		Reason
18 March 2010	cnwar2	#22475 - if ISO Type is specified, return the associated ISO Group
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/
vars
	reserveDetail	: CM_ReserveDetail;
	isoGroup		: CM_ISOTypeGroup;
	ti				: CM_TrackedItem;
	
begin
	reserveDetail := self.allReserveDetails.first;
	if reserveDetail = null then
		return null;
	endif;
	
	if self.releaseByType then
		if reserveDetail.CM_ReserveSelection.myISOType &lt;&gt; null then
			isoGroup := reserveDetail.CM_ReserveSelection.myISOType.myISOTypeGroup;
		else
			isoGroup := reserveDetail.CM_ReserveSelection.myISOGroup;
		endif;
	else//release by ID - get the iso group off the tracked item
		//ti := reserveDetail.allTrackedItems.first;
		ti := reserveDetail.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
		if CM_Container.hasInstance(ti) then
			isoGroup := ti.getISOTypeGroup();
		endif;
	endif;
	
	return isoGroup;
end;</source>
        <ReturnType type="CM_ISOTypeGroup"/>
    </JadeMethod>
