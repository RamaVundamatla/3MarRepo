    <ImplicitInverseRef name="btnCancel" id="76e183a4-92cd-4614-b6de-5bd31946c8ea">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOK" id="802e226f-375d-4c8c-8961-17ad5b290530">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblPrompt" id="f5c881a8-6916-4413-b400-d2830bb90c27">
