    <JadeMethod name="autoToDoTaskDescDesc" id="fa9f9990-1868-49a7-835e-632c6c116d42">
        <methodInvocation>mapping</methodInvocation>
        <source>autoToDoTaskDescDesc(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.autoToDoTaskDesc &lt;&gt; null and global.isValidObject(self.autoToDoTaskDesc) then
			_value := self.autoToDoTaskDesc.description;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isObjectCorrectType" id="238fb19c-0fb2-439d-adab-be647ac760bb">
        <source>isObjectCorrectType(_obj : CM_Object) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     05 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _obj.isKindOf(CM_Root) then
		return true;
	endif;
	
	app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown class (' &amp; _obj.String &amp; ')');

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromPersistentData" id="84823597-a681-45a2-bbb1-107f22545458">
        <updating/>
        <source>setFromPersistentData(_root : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	propCol		: PropertyColl;
	prop		: Property;
	keyStr		: String;
	
begin
	inheritMethod(_root);
	propCol := self.class.allPropertiesUpTo(CMIF_Config);
	
	foreach prop in propCol do
		if self.isPropertyToIgnore(prop) then
			continue;
		endif;
		
		keyStr := self.getKeyStringForProperty(prop.name);
		
		if keyStr &lt;&gt; null then			
			self.setPropertyFromStringValue(prop, _root.getConfig(keyStr));
		else
			// need to handle as a special
			executeWhen JMTDevelopmentEnvironment;
			//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '&gt;&gt;&gt;&gt; special ' &amp; prop.name);
			endExecuteWhen;
		endif;
	endforeach;
epilog
	delete propCol;
end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="setXMLTagForType" id="b410b1fd-7bc1-4043-b46a-efa750d0ee82">
