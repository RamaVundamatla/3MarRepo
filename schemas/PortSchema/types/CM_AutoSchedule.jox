    </JadeMethod>
    <JadeMethod name="failsYAExpiryCheck" id="1bac050b-640d-45f9-b9e2-334d25d31b7a">
        <source>failsYAExpiryCheck() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/03/2021	navdap1		Initial creation TFS 50946 PRP Auto Delete of Yard Allocations
//
vars
	bool : Boolean;
	daysRun : Integer;

begin
	if self.selectionState = State_Event then
		// not allowed
		return true;
	elseif self.selectionState = State_Date then
		// this is monthly - this is fine
	elseif self.selectionState = State_Day then
		foreach bool in self.allRunDays where bool do
			daysRun := daysRun + 1;
		endforeach;
		if daysRun &gt; 1 or self.allRunTimes.size &gt; 1 then
			// runs more than one day a week or more than once a day - not allowed
			return true;
		endif;
	elseif self.selectionState = State_Time then
		// time-based - must be Monthly or Daily with more than 7 days apart
		if (self.recurUnit = CM_AutoSchedule.RecurUnit_Days and self.recurValue &lt; 7)
		or self.recurUnit.isOneOf(CM_AutoSchedule.RecurUnit_Hours, CM_AutoSchedule.RecurUnit_Minutes, CM_AutoSchedule.RecurUnit_Seconds)
		then
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getIsActiveString" id="218864df-4952-44d2-9c47-9bcdc29af2a7">
