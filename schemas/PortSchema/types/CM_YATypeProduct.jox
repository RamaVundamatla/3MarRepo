    <JadeMethod name="getAllCriteriaValues" id="8b5f6187-23a8-41d8-8864-b9adadfe24eb">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/09/2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// 29/06/2018	jlgdap1	TFS 39335 PEN Vehicle Visit Report Cargo Sub Type Filter
// --------------------------------------------------------------------------------
vars
	tmpTerminal		: CM_Terminal;
	tmpCargoType	: CM_CargoType;
	tmpCargoBOLType	: CM_CargoBOLType;
	product			: CM_Product;
	obj				: Object;
begin
	tmpTerminal := _terminalObj;

	// TFS 39335 This method used to default to showing everything if no terminal was provided,
	// and thn lookg at the dependent objects passed in. It's been changed to filter by dependent 
	// objects first, then look at whether or not it has a terminal
	if _allDependentObjs &lt;&gt; null 
	and _allDependentObjs.size &lt;&gt; 0 then
		foreach obj in _allDependentObjs do
			if obj.isKindOf(CM_CargoType) then
				foreach product in obj.CM_CargoType.allProducts do
					//epr TFS 1846 19/4/16
					if product.isNotActive then
						continue;
					endif;
					_allCriteriaValues.add(product);
				endforeach;
			endif;
		endforeach;
	else
		if tmpTerminal = null then
			foreach tmpCargoType in app.myRoot.allCargoTypesById do
				foreach product in tmpCargoType.allProducts do
					//epr TFS 1846 19/4/16
					if product.isNotActive then
						continue;
					endif;
					_allCriteriaValues.add(product);
				endforeach;
			endforeach;
		else
			foreach tmpCargoBOLType in tmpTerminal.allCargoBOLTypes where
					tmpCargoBOLType.isCargoType() do
					
					foreach product in tmpCargoBOLType.CM_CargoType.allProducts do
						//epr TFS 1846 19/4/16
						if product.isNotActive then
							continue;
						endif;
						_allCriteriaValues.add(product);
					endforeach;
			endforeach;
		endif;
	endif;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
