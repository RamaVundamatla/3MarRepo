____________________________________________________________________________</text>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssDecimal" id="24b6d933-b0d0-484c-99aa-86f09e98eade">
        <source>jssDecimal():Decimal;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver as a Decimal value.
//
// Parameters:	None
//
// Returns:		Decimal - the trimmed text cast to a Decimal value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.trimBlanks.jssRemoveSubstring(",").Decimal;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

