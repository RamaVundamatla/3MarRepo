    <JadeMethod name="calcTotals" id="42c88dd6-dc64-4a39-9307-53572f4da07a">
        <source>calcTotals();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	i, j, tot : Integer;

begin

	self.tblData.accessMode := 1;
	j := 2;
	while j &lt;= self.tblData.rows do
		self.tblData.row := j;
		i := 3;
		tot := 0;
		while i &lt; self.tblData.columns - 1 do
			self.tblData.column := i;
			tot := tot + self.tblData.text.Integer;
			i := i + 1;
		endwhile;
		if tot &lt;&gt; 0 then
			if (self.tblData.row mod 2 = 0 or self.tblData.row &gt; 36) and self.tblData.row &lt;&gt; 39 then  //rs 98/168
				self.tblData.column := self.tblData.columns - 1;
				self.tblData.text := tot.asStringJMT;
				self.tblData.alignment := 2;
			else
				self.tblData.column := self.tblData.columns;
				self.tblData.text := tot.asStringJMT;
				self.tblData.alignment := 2;
			endif;
		endif;
		j := j + 1;
	endwhile;

end;</source>
    </JadeMethod>
