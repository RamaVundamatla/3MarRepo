    <JadeMethod name="setupDriversTable" id="55367073-ed89-4a20-8bef-78114240e1b9">
        <updating/>
        <source>setupDriversTable() updating, protected;

vars
	jCol : JadeTableColumn;
	tbl : Table;
	i : Integer;
	
begin
	tbl := self.tblDrivers;

	tbl.autoRedraw := false;
		
	tbl.rows := tbl.fixedRows;

	tbl.accessCell(1, 2).text := "Transaction Count";
	tbl.accessCell(1, 5).text := ' '; // to stop merge cells
	tbl.accessCell(1, 9).text := "Errors";
	tbl.accessCell(1, 13).text := "Memory";
								 
	tbl.accessCell(2, 1).text := "Name" &amp; Tab &amp; "Reads" &amp; Tab &amp; "Updates" &amp; Tab &amp;
		"Total" &amp; Tab &amp; "Time" &amp; Tab &amp; "Total TPS" &amp; Tab &amp; "Read TPS" &amp; Tab &amp;
		"Update TPS" &amp; Tab &amp; "App" &amp; Tab &amp; "Excepts" &amp; Tab &amp; "Locks" &amp; Tab &amp;
		"Deads" &amp; Tab &amp; "Free MB" &amp; Tab &amp; "Free %";

	self.setDriversTableDefaultWidths;		
	
	foreach i in 2 to tbl.columns do
		jCol := tbl.accessColumn(i);

		jCol.alignment := Table.Alignment_Center;
		
		if i = 7  then
			jCol.backColor := self.ReadColor;
		elseif i = 8 then
			jCol.backColor := self.UpdateColor;
		elseif i &gt;= 9 and i &lt;= 12 then
			jCol.backColor := self.ErrorColor;
		endif;
	endforeach;

	tbl.accessCell(1, 2).mergeCells := Table.MergeCells_Merge;
	tbl.accessCell(1, 9).mergeCells := Table.MergeCells_Merge;
	tbl.accessCell(1, 13).mergeCells := Table.MergeCells_Merge;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupStatsTable" id="e01be805-08c9-4797-b5bc-9263a880d979">
        <updating/>
        <source>setupStatsTable() updating, protected;

vars
	tbl : Table;
	i : Integer;
	
begin
	tbl := self.tblStats;
	
	tbl.rows := tbl.fixedRows; // to empty the table first
	
	// queued lock statistics are supplied only from JADE 5.2
	
	if self.jadeVerRelease &gt;= 6 or (self.jadeVerRelease &gt;= 5 and self.jadeVerMajor &gt;= 2) then
		tbl.rows := 14;
	else
		tbl.rows := 13;
	endif;

	tbl.accessCell( 1, 2).text := "Sample" &amp; Tab &amp; "Total";
	tbl.accessCell( 2, 1).text := "Get Objects";
	tbl.accessCell( 3, 1).text := "Objects Created";
	tbl.accessCell( 4, 1).text := "Objects Deleted";
	tbl.accessCell( 5, 1).text := "Objects Updated";
	tbl.accessCell( 6, 1).text := "Objects Locked";
	tbl.accessCell( 7, 1).text := "Objects Unlocked";
	tbl.accessCell( 8, 1).text := "Committed Transactions";
	tbl.accessCell( 9, 1).text := "Aborted Transactions";
	tbl.accessCell(10, 1).text := "Begin Notifications";
	tbl.accessCell(11, 1).text := "End Notifications";
	tbl.accessCell(12, 1).text := "Delivered Notifications";
	tbl.accessCell(13, 1).text := "Server Executions";

	if self.jadeVerRelease &gt;= 6 or (self.jadeVerRelease &gt;= 5 and self.jadeVerMajor &gt;= 2) then
		tbl.accessCell(14, 1).text := "Queued Locks";
	endif;
		
	self.setStatsTableDefaultWidths;
		
	tbl.accessColumn(2).alignment := Table.Alignment_Right;
	tbl.accessColumn(3).alignment := Table.Alignment_Right;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTransTable" id="afecaab7-00c1-442c-8e89-69bd63ba1908">
        <updating/>
        <source>setupTransTable() updating, protected;

vars
	tbl : Table;
	i : Integer;
	
begin
	tbl := self.tblTrans;
	
	tbl.rows := tbl.fixedRows;

	tbl.accessCell(1, 3).text := "Percentage" &amp; Tab &amp; Tab &amp; "Errors";
								 
	tbl.accessCell(2, 1).text := "Name" &amp; Tab &amp; "Count" &amp; Tab &amp; "Type" &amp; Tab &amp;
		"Total" &amp; Tab &amp; "App" &amp; Tab &amp; "Excepts" &amp; Tab &amp; "Locks" &amp; Tab &amp; "Deads";
		
	self.setTransTableDefaultWidths;
		
	foreach i in 2 to tbl.columns do
		tbl.accessColumn(i).alignment := Table.Alignment_Center;
	endforeach;

	tbl.accessCell(1, 3).mergeCells := Table.MergeCells_Merge;
	tbl.accessCell(1, 5).mergeCells := Table.MergeCells_Merge;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="splitterHorz1_mouseDown" id="31455b98-a710-428c-afaf-4bd5f1ad5c52">
        <controlMethod name="Frame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>splitterHorz1_mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	self.splitterMoving := true;

	self.startRateGraphTimerOnSplitEnd := self.graphTimerRunning;
	self.stopGraphTimer;
	
	self.drawMode := 7; // xor
	self.autoRedraw := false;
	self.clipControls := false;
	self.drawWidth := 4;
	self.drawStyle := 0;
	self.mouseMileage := splitterHorz1.top;
	self.drawLine(0, self.mouseMileage + 3, self.clientWidth, self.mouseMileage + 3, White);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="splitterHorz1_mouseMove" id="bfa24ec7-21e4-4929-8b5d-9e1c71230393">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>splitterHorz1_mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	pos : Integer;
	h : Real;

begin
	if not self.splitterMoving then
		return;
	endif;
	
	h := self.splitterHorz2.top;
	pos := (self.splitterHorz1.top + y).Integer;
	if pos &lt; SplitSizeLimit or pos &gt; (h - SplitSizeLimit - splitterHorz1.height) then
		return;
	endif;
	
	self.drawLine(0, self.mouseMileage + 3, self.clientWidth, self.mouseMileage + 3, White);
	self.mouseMileage := pos;
	self.drawLine(0, self.mouseMileage + 3, self.clientWidth, self.mouseMileage + 3, White);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
