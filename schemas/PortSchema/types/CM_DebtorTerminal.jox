    <JadeMethod name="createCashReceipt" id="04abf45b-7886-4e47-a565-79114c4f7db3">
        <source>createCashReceipt(	_cashValue : Decimal;
					_chequeBank : String;
					_chequeBranch : String;
					_chequeNumber : String;
					_chequeDate : Date;
					_myPaymentMethod : CM_PaymentMethod
					): CM_CashReceipt;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation	 Par 29968

*/

vars

	pxyReceipt : CM_CashReceipt;
	realReceipt	: CM_CashReceipt;
	now : TimeStamp;
	sequenceNum : Integer;

begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	if self.allCashReceipts.isEmpty then
		sequenceNum := 1;
	else
		sequenceNum := self.allCashReceipts.last.sequenceNum + 1;
	endif;

	create pxyReceipt transient;
	pxyReceipt.setProxy(	_cashValue,	//_cashValue : Decimal;
							now,	//_dateTime : TimeStamp;
							app.getMyUser,	//_myUser : CM_User;
							sequenceNum,	//_sequenceNum : Integer;
							_chequeBank,	//_chequeBank : String;
							_chequeBranch,	//_chequeBranch : String;
							_chequeNumber,	//_chequeNumber : String;
							_chequeDate,	//_chequeDate : Date;
							_myPaymentMethod,	//_myPaymentMethod : CM_PaymentMethod;
							self,	//_myDebtorTerminal : CM_DebtorTerminal;
							0	//_paymentType : Integer
							);
						
	create realReceipt;
	realReceipt.setForUpdate(pxyReceipt);
	
	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(realReceipt);		// 9/5/18 MAP TFS37718

	return realReceipt;

epilog

	delete pxyReceipt;
	
end;</source>
        <Parameter name="_cashValue" type="Decimal"/>
        <Parameter name="_chequeBank" type="String"/>
        <Parameter name="_chequeBranch" type="String"/>
        <Parameter name="_chequeNumber" type="String"/>
        <Parameter name="_chequeDate" type="Date"/>
        <Parameter name="_myPaymentMethod" type="CM_PaymentMethod"/>
        <ReturnType type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="doConsolidateCashTransactions" id="928d2471-081b-4e35-a56a-4f72e6b9eea8">
        <updating/>
        <source>doConsolidateCashTransactions( _toDate : Date ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	cashPay : CM_CashPayment;
	cash : CM_Cash;

begin

	if not _toDate.isValid then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(EndDate), null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	// check the period doesn't include any pro formas.
	foreach cashPay in self.allCashPayments do
		if not cashPay.isProformaPayment then
			continue;
		endif;
		if cashPay.dateTime.Date &gt;= _toDate then
			break;
		endif;
		app.raiseCMException1(Archive_period_has_proforma, (_toDate - 1).Date.asStringJMT, null, null);
		return;
	endforeach;
	
	foreach cash in self.allCashReceipts do
		if cash.dateTime.Date &gt;= _toDate then
			break;
		endif;
		cash.setArchived(self, true);
	endforeach;
		
	foreach cash in self.allCashPayments do
		if cash.dateTime.Date &gt;= _toDate then
			break;
		endif;
		cash.setArchived(self, true);
	endforeach;
	
	self.setConsolidatedBalance();
	
epilog

end;</source>
        <Parameter name="_toDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="doUnConsolidateCashTransacts" id="73399f74-bc70-4ae2-a1b2-a9799e0ba3c2">
        <updating/>
        <source>doUnConsolidateCashTransacts( _fromDate, _toDate : Date ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012		cnwndl1	Initial creation	Par 29968
21 Oct 2019 		cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars
	cash 		: CM_Cash;
begin

	if not _fromDate.isValid then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Start_date), null, null);  // cnwdb2	PAR 35364
		return;
	endif;
	
	if not _toDate.isValid then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(EndDate), null, null);     // cnwdb2	PAR 35364
		return;
	endif;
	
	foreach cash in self.allConsolidatedCashTrx do
		if cash.dateTime.Date &lt; _fromDate then
			continue;
		endif;
		if cash.dateTime.Date &gt;= _toDate then
			break;
		endif;
		cash.setArchived(self, false);
	endforeach;
	
	self.setConsolidatedBalance();
	
epilog

end;</source>
        <Parameter name="_fromDate" type="Date"/>
        <Parameter name="_toDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="getCashReceiptsForDutyDoc" id="26fcf804-d566-4fb4-8a94-6cb61aa7480f">
        <source>getCashReceiptsForDutyDoc( _dutyDoc : CM_DutyDoc; _cashReceipts : CM_CashReceiptDict input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December	cnwndl1	Initial creation	Par 33182
04/03/2015	cnwmh5	Transient Leak

*/
vars

	iter : Iterator;
	cashReceipt : CM_CashReceipt;
	earliestDate : Date;

begin

	earliestDate := _dutyDoc.createdDate;

	iter := self.allCashReceipts.createIterator;
	while iter.back( cashReceipt ) do
		if cashReceipt.dateTime.Date &lt; earliestDate then
			break;
		endif;
		if cashReceipt.getDutyDocBillNumber = _dutyDoc.id then
			_cashReceipts.add( cashReceipt );
		endif;
	endwhile;

epilog
	delete iter;
end;
</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <Parameter name="_cashReceipts" type="CM_CashReceiptDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCreditAmount" id="86fc3230-3ae2-4833-8b55-8c12bd3b531b">
        <source>getCreditAmount(): Decimal;
// 37141 return the credit amount avaiable for cash receipts
/* Changes

Date		Name	TFS#	Description
============================================================================
17/05/2019	jlgka1	44724	Round off to 2 decimal.
21/10/2019  cnwma1  Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
============================================================================*/
vars
	amount	: Decimal[23, 6];	//21.10.2019 cnwma1 TFS #47081
	credit	: CM_CashCredit;
begin
	foreach credit in self.allCashCredits do
		amount := amount + credit.getCreditAvailable();
	endforeach;
	return amount ;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
