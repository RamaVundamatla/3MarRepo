    <JadeMethod name="fixCargoLocationsOnWagons" id="92bcef7a-eef3-4de2-bb70-ad94da661bab">
        <source>fixCargoLocationsOnWagons(_controller: CnEcReleaseController);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2024	jlier1	Initial creation 65100

*/

vars
	msg : String;
	iter : Iterator;
	wagonControllerID	: String;
	lc   : CM_LocationsController;
	terminal : CM_Terminal;
	cargo : CM_TrackedItem;
	cargoToUpdate : CM_TISet;
begin
	msg := "Fixing up Cargo Location IDs on wagons";

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " " &amp; msg &amp; " Starting", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(msg &amp; " Starting");
	endif;	
	
	foreach terminal in app.myRoot.allTerminals do
		delete iter;
		iter:=terminal.allOnsiteTIsByIdCargoType.createIterator;
		while iter.next(cargo) do
			lc := cargo.getPrimaryLocation(REAL_MODE);
			if lc = null then
				continue;
			endif;
			if not lc.isKindOf(CM_WagonController) then
				continue;
			endif;
			wagonControllerID:= lc.getFullId[1:30]; 
			if not cargo.locationId.startsWith(wagonControllerID) then								
					beginTransaction;
					cargo.setLocationId(wagonControllerID);
					commitTransaction;
			
			endif;
		endwhile;	
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Completed Fixing up Cargo Location IDs on wagons", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Fixing up Cargo Location IDs on wagons");
	endif;
	self.addScriptRun(method.name);
	
epilog
	delete iter;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateOperatorAllCGsByTerm" id="3d3fe304-5e4f-496f-9065-003dcabb4b28">
        <source>populateOperatorAllCGsByTerm(_updController : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 June 2025		jlizm1	Initial creation MTN 34778 Add terminal as key for operator cargo group collection

*/

vars
	cargoGroup		: CM_CargoGroup;
	objArray		: ObjectArray;
	operator		: CM_Operator;
	
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; "Populating Cargo Groups by Terminal for Operators", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Populating Cargo Groups by Terminal for Operators") ;	
	endif;
	
	create objArray transient;
	CM_Operator.allInstances(objArray, 0, true);
	
	beginTransaction;
	
	foreach operator in objArray as CM_Operator do
		if operator.allCargoGroups.size = operator.allCargoGroupsByTerminal.size then
			// either empty or already match, so skip
			continue;
		endif;
		
		foreach cargoGroup in operator.allCargoGroups as CM_CargoGroup do
			operator.allCargoGroupsByTerminal.addNoDuplicates(cargoGroup, false);
		endforeach;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Completed Populating Cargo Groups by Terminal for Operators", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed Populating Cargo Groups by Terminal for Operators") ;
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete objArray;
	
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setBestPickDTAndOverstows" id="70cec710-376f-458e-8525-1c6a8d7899ac">
        <source>setBestPickDTAndOverstows(_updController : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2025	jlier1	Initial creation 35632

*/

vars
	terminal : CM_Terminal;
	iter : Iterator;
	ti : CM_TrackedItem;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Setting Best Pick Date/Time to the Recieval DT", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Setting Best Pick Date/Time to the Recieval DT") ;	
	endif;
	
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals discreteLock do
		delete iter;
		iter := terminal.allOnsiteTIsByIdCargoType.createIterator;
		while iter.next( ti ) do
			if ti.myPrimaryActualLocation = null then
				continue;
			endif;
			ti.calcNumOverstows; //jlier1 JIRA# 35636
			if ti.bestPickDT &lt;&gt; null then
				continue;
			endif;
			if ti.receivedDT = null or not ti.receivedDT.isValid then
				continue;
			endif;
			ti.setPropertyValue(CM_TrackedItem::bestPickDT.name,ti.receivedDT);//not calling setBestPickDT because do not want a transaction
		endwhile;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Setting Best Pick Date/Time to the Recieval DT -complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry("Setting Best Pick Date/Time to the Recieval DT -complete") ;
	endif;

	self.addScriptRun(method.name);

epilog
	delete iter;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setEDIHSCodeValidConfig" id="7b022118-b7d2-474a-8987-b2988178c649">
        <source>setEDIHSCodeValidConfig(_controller : CnEcReleaseController);
/*

Purpose:			Set Terminal Config "EDI HS Code must be valid" to true for all terminals

Parameters:			

Return Value:		

Date				Who		Reason
04 July 2024		jlizm1	Initial creation TFS 64736 HS Code edi allow invalid codes

*/

vars
	terminal : CM_Terminal;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Initializing EDI HS Code Must be valid setting", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initializing EDI HS Code Must be valid setting") ;	
	endif;
	
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		terminal.setConfig(EdiHSCodeMustBeValid, true);
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Initializing EDI HS Code Must be valid setting complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Initializing EDI HS Code Must be valid setting complete") ;
	endif;

	self.addScriptRun(method.name);
	
epilog
	
end;</source>
