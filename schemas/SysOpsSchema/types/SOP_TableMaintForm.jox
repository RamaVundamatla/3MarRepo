/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	if _obj &lt;&gt; null then
		_objArray.addExclusive( _obj ); //will be just a vehicle or just a machine
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
