<Class name="CMIF_JsonTransportStatusMsgEUP" id="40434016-e519-4500-a87d-476038b9db16">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cams"/>
    <ImplicitInverseRef name="header" id="86f9304d-aea4-4a88-8072-899ef3a51c12">
        <embedded/>
        <type name="CMIF_JsonHeaderEUP"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="transports" id="427385c2-e786-416a-a5b8-7f3d28dd2095">
        <memberTypeInverse/>
        <type name="CMIF_JsonTransportStatusArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="buildHeader" id="e08f564c-64d9-4175-9cab-f5d055d21cc8">
        <updating/>
        <source>buildHeader(_trigger : CMEVT_TruckEvent; _camProtocol : CM_CamProtocol; _operatorCode : String; _vbs : CM_VehicleBookingTimeSlot) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2023	navmp20	ChangeRequest 56801: EUP - EDI Message Type - Transport Status Message Processing
22 Jun 2023	navdap1	TFS 58351 EUP - Receiver field and Carrier Code is always blank in the Transport Status message
25 Jun 2024 navmd1	TFS 61725 Fix Timestamps not being reported in UTC (as the mapper expects UTC/Zulu time)
*/

vars
	now : TimeStamp;
	op : CM_Operator;
	operator : CM_Operator;
	guid : String;
begin
	if _trigger = null then	
		return;
	endif;
	
	if self.header = null then
		create self.header transient;
	endif;
	
	if _trigger.myVisit &lt;&gt; null then
		self.header.sender := _trigger.myVisit.myTerminal.code;
		//self.header.receiver := damageInstance.myTrackedItem.operatorCode;							//navra1 - TFS 57338 - 28th Mar 2023
		operator := app.myRoot.allOperators[_operatorCode];
		if operator &lt;&gt; null and operator.debtor &lt;&gt; null then
			self.header.receiver := operator.debtor.externalReference;										//navra1 - TFS 57338 - 28th Mar 2023
		endif;
		if self.header.receiver = null then			// TFS 58351
			self.header.receiver := _operatorCode;	// TFS 58351
		endif;										// TFS 58351
	endif;
	
	self.header.date := now.localToUTCTime;
	self.header.type := _camProtocol.code;
	if _trigger.type = EVT_TruckCancellation then
		self.header.status := "CANCEL";
	else
		self.header.status := "CREATE";
	endif;
	if _trigger.type = EVT_TruckDeparture then
		self.header.number := _vbs.id &amp; 'Out';
	else
		self.header.number := _vbs.id &amp; 'In';
	endif;
	guid := self.generateGUID();
	self.header.id := guid;
epilog

end;</source>
        <Parameter name="_trigger" type="CMEVT_TruckEvent"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_vbs" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="delete" id="8e9e7659-795c-4aae-8a0d-35b5d89d71cb">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2023	navmp20	ChangeRequest 56801: EUP - EDI Message Type - Transport Status Message Processing

*/

vars
	transport : CMIF_JsonTransportStatusEUP;
begin
	if self.transports &lt;&gt; null and self.transports.size &gt; 0 then
		foreach transport in self.transports do
			if transport.carrierParty &lt;&gt; null then
				delete transport.carrierParty;
			endif;
			
			if transport.truckInfo &lt;&gt; null then
				delete transport.truckInfo;
			endif;
		endforeach;
	endif;
	
	if not self.transports.isEmpty then
		self.transports.purge();
	endif;
	
	if self.header &lt;&gt; null then 
		delete self.header;
	endif;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="generateGUID" id="e30491eb-0845-4fb0-99e3-7b3cb0b5d6a5">
        <source>generateGUID(): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2023	navmp20	ChangeRequest 56801: EUP - EDI Message Type - Transport Status Message Processing

*/

vars

begin
	return app.generateUuid(VariantMicrosoft).uuidAsString();
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJsonForTransportStatus" id="3fe7a7de-146e-44b1-a5c5-3631125d6be8">
        <source>getJsonForTransportStatus(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2023	navmp20	ChangeRequest 56801: EUP - EDI Message Type - Transport Status Message Processing
15 Aug 2024	navmd1	TFS 61725 Change to use JMTJadeJson so ISO 8601 dates are presented instead
*/

vars
	jsonHelper : JMTJadeJson;
begin
	create jsonHelper transient;
	return jsonHelper.generateJson(self, JadeJson.Format_Json_Microsoft);
epilog
	delete jsonHelper;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
