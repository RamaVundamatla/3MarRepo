    <JadeMethod name="addObjects" id="bc6bea98-72aa-4b9b-a07d-16daf2be9cc7">
        <source>addObjects( _cmifGrouping :CMIF_OutputGrouping );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2009	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	obj : Object;
	
begin

	if _cmifGrouping = null or _cmifGrouping.allObjects = null or _cmifGrouping.allObjects.isEmpty then
		return;
	endif;
	
	iter := _cmifGrouping.allObjects.createIterator;
	while iter.next( obj ) do
		if obj.isKindOf( CM_TrackedItem ) then
			self.addTrackedItem( _cmifGrouping,	obj.CM_TrackedItem );
		endif;
	endwhile;
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="_cmifGrouping" type="CMIF_OutputGrouping"/>
    </JadeMethod>
    <JadeMethod name="addTrackedItem" id="8aaf40e7-9e46-4af6-a363-9249d1984749">
        <source>addTrackedItem(_cmifGrouping : CMIF_OutputGrouping; _ti :CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:     07 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/08/2010 	cnwcs5 		par 23706 - include 'id' in saved values
// ---------------------------------------------------------------------------
vars

	obj : Object;
	cmifField : CMIF_OutputField;
	outputFormat : CM_OutputFormat_SS;
	xtabGrouping : CM_XTABGrouping;
	xtabField : CM_XTABField;
	propertyName : String;
	queryProperty : CM_QueryProperty;
	propertyValue : String;
	propNameAndValue : String;
	stringValues : String;
	error : Boolean;
	
begin

	on Exception do handleInvalidProperty( exception, error );

	outputFormat := self.mySnapshotData.myOutputFormat_SS;
	
	if outputFormat = null then
		return;
	endif;
	
	// add ti to allObjects collection
	self.allObjects.add( _ti );
	
	/* par 26336 cnwjo3.  no need to populate allValues anymore.
	
	// create string representing each of the  ti values that we have used
	stringValues := _ti.id &amp; ', ' &amp; _ti.String;	// 09/08/2010 cnwcs5 par 23706
	
	// loop thru each of the attributes that are the keys in the output format for this ti. (groupings)
	// get the name of the 'property or method' and the value of that attribute for this ti.
	foreach xtabGrouping in outputFormat.allGroupings do
		queryProperty := xtabGrouping.getQueryProperty;
		propertyValue := queryProperty.getValueForObject (_ti).String;
		propNameAndValue := xtabGrouping.propertyName &amp; " = '" &amp; propertyValue &amp; "'";
		stringValues := stringValues &amp; ", " &amp; propNameAndValue;
	endforeach;
	
	// loop thru each of the attributes that are the data fields in the output format for this ti. (fields)
	foreach obj in _cmifGrouping.allChildren do
		cmifField := obj.CMIF_OutputField;
		xtabField := outputFormat.allFields.getFieldFromHeading(cmifField.heading);
		queryProperty := xtabField.getQueryProperty;
		propertyValue := queryProperty.getValueForObject (_ti).String;
		propNameAndValue := xtabField.propertyName &amp; " = '" &amp; propertyValue &amp; "'";
		stringValues := stringValues &amp; ", " &amp; propNameAndValue;
	endforeach;
	
	self.allValues.add(stringValues[1:2000]);
	*/
	
epilog

end;</source>
        <Parameter name="_cmifGrouping" type="CMIF_OutputGrouping"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createSnapshotFieldFromCMIF" id="ed91cc75-95b8-4084-b373-9f0141308784">
        <source>createSnapshotFieldFromCMIF( _xtabField : CM_XTABField; _cmifField : CMIF_OutputField ):CM_SnapshotField;
/*
Purpose:		Create snapshot field of correct type based on xtab field
Parameters:			
Return Value:	Snapshot field	

Date		Who		Reason
08 December 2009	cnwndl1	Initial creation	CCMS 1023
12/02/2010	cnwcs5	par 22140 - New functions.  Simplified method
*/
vars
	cls		: Class;
	ssField : CM_SnapshotField;
begin
// 12/02/2010 cnwcs5 par 22140 - reworked follwoing block of code to simplify
	if _cmifField.isAverage then
		cls := CM_SnapshotField_Average;
	elseif _cmifField.isCount_True then
		cls := CM_SnapshotField_Count_True;
	elseif _cmifField.isCount_False then
		cls := CM_SnapshotField_Count_False;
	elseif _cmifField.isCount_Null then
		cls := CM_SnapshotField_Count_Null;
	elseif _cmifField.isCount_NotNull then
		cls := CM_SnapshotField_Count_NotNull;
	elseif _cmifField.isCount_Zero then
		cls := CM_SnapshotField_Count_Zero;
	elseif _cmifField.isCount_NotZero then
		cls := CM_SnapshotField_Count_NotZero;
		
	// NOTE COUNT MUST BE CHECKED AFTER SUBCLASSES OF COUNT 
	elseif _cmifField.isCount then
		// all count subclasses translate into a simple count
		cls := CM_SnapshotField_Count;
	elseif _cmifField.isMax then
		cls := CM_SnapshotField_Max;
	elseif _cmifField.isMin then
		cls := CM_SnapshotField_Min;
	elseif _cmifField.isSum then
		cls := CM_SnapshotField_Sum;

	endif;
	
	if self.isTransient then
		create ssField as cls transient;
	else
		create ssField as cls;
	endif;
// 12/02/2010 cnwcs5 par 22140 - end

	ssField.setFromCmifAndXtabFields(_cmifField, _xtabField);

	self.allFields.add(ssField);

	return ssField;
epilog

end;</source>
        <Parameter name="_xtabField" type="CM_XTABField"/>
        <Parameter name="_cmifField" type="CMIF_OutputField"/>
        <ReturnType type="CM_SnapshotField"/>
    </JadeMethod>
    <JadeMethod name="findSnapshotField" id="b4fb5608-2b8c-47d6-abd3-96a8fc45d93f">
        <source>findSnapshotField(_field :CM_XTABField):CM_SnapshotField;
// ---------------------------------------------------------------------------
// Created:     10 December 2009 by cnwcs5:1
// Purpose:     ccms 1023 - snapshot summaries 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	field	:CM_SnapshotField;
begin
	foreach field in self.allFields do
		if field.propertyName = _field.propertyName and
			field.getXTABFieldFunction = _field.function then
			return field;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_field" type="CM_XTABField"/>
        <ReturnType type="CM_SnapshotField"/>
    </JadeMethod>
    <JadeMethod name="getOutputFormat_SS" id="75054d3d-6420-40e8-94ab-49b4df7675ee">
        <source>getOutputFormat_SS():CM_OutputFormat_SS;
// ---------------------------------------------------------------------------
// Created:     14 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.mySnapshotData &lt;&gt; null then
		return self.mySnapshotData.myOutputFormat_SS;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_OutputFormat_SS"/>
    </JadeMethod>
