    <JadeMethod name="clickFile" id="ee4da78c-7549-4083-aefc-d4470396aa8e">
        <source>clickFile();

/*

Purpose:		Save the details to a file	

Date			Who		Reason
22/01/2013		cnwmh5	Initial creation

*/

vars

	outputText : String;
	line : String;
	outFile : File;
	fileLine : String;
	openDialog : CMDFileOpen;
	
	index					: Integer;
	level					: Integer;

begin

	create openDialog transient;
	openDialog.filter := 'All Files|*.txt';
	openDialog.filterIndex := 1;
	
	if openDialog.open() = 0 then
		
		create outFile transient;
		outFile.mode := File.Mode_Output;
		outFile.allowCreate := true;
		outFile.openOutput(openDialog.fileName);
		
		app.mousePointer := MP_HOURGLASS;

		foreach index in 1 to self.lstLogEntries.listCount do
		
			line := null;
			level := self.lstLogEntries.itemLevel[index];
			level := level - 1;
			while level &gt; 0 do
				line := line.trimBlanks() &amp; Tab;
				level := level - 1;
			endwhile;
			
			line := line.trimBlanks() &amp; self.lstLogEntries.itemText[index];
			outFile.writeLine(line);
		
		endforeach;
		
		outFile.close;
		
		app.msgBox("File '" &amp; outFile.fileName &amp; "' created",app.getErrorString(Complete),MsgBox_OK_Only);
	endif;
	
epilog

	app.mousePointer := MP_DEFAULT;

	delete outFile;

end;</source>
    </JadeMethod>
