    <JadeMethod name="getLocationType" id="45e7c0bc-d3c6-4517-b8b1-fdd38a752994">
        <source>getLocationType(_location: String; _lc: CM_LocationsController io) : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2012	cnwdw1	Initial creation
*/
vars
	locationController: CM_LocationsController;
	height : Integer;
	pos: Integer;
	ta: CM_TerminalArea;
begin
	self.myTerminal.findLocationFromString(_location, true, locationController, height);
	if locationController &lt;&gt; null then
		if _lc &lt;&gt; null then
			_lc := locationController;
		endif;
		return locationController.getType;
	endif;
	
	// Maybe a Rail Area - as there are no lcs associated with rail
	pos := 1;
	ta := self.myTerminal.allTerminalAreas[_location.getNextToken(pos)];
	if ta &lt;&gt; null and ta.isRail then
		return CM_LocationsController.Location_Type_RAIL;
	endif;
	
	return CM_LocationsController.Location_Type_UNKNOWN;
epilog

end;</source>
        <Parameter name="_location" type="String"/>
        <Parameter name="_lc" type="CM_LocationsController" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveAmount" id="9bb54588-46ce-4401-8687-e07de4cd998c">
        <source>getMoveAmount() : String;
/*

Date		Who		Reason
20 March 2014	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
	product : CM_Product;
	ti	: CM_TrackedItem;
	density  	: Decimal[14,4];
begin
	if not self.getCargoTypeAndSubType(ct,product) then
		return null;
	endif;
	
	if ct.isBreakBulkMulti then
		if self.totalQuantity &gt;  1 then
			return '(' &amp; self.totalQuantity.asStringJMT &amp; ') ';
		endif;
	elseif ct.isBulkMulti then
		ti:= self.myTrackedItem;
		density:=ti.getDensity;
		
		return '(' &amp; ct.getBulkTrackByDisplayForWeight( self.totalWeight,density,true) &amp; ') ';	
	else
		return null;
	endif;
		
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveFromHoldNumber" id="f2ec887c-3139-471a-9208-d28f01a880fd">
        <source>getMoveFromHoldNumber():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2013	cnwndl1	Initial creation	Par 32848

*/

vars

	strs : StringArray;
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
	
begin

	//Not a voyage move
	if self.voyage = null then
		return 0;
	endif;
	
	create strs transient;
	if self.sourceLocn.pos(Space,1) &gt; 0 then
		self.sourceLocn.getTokensForDelimiter(Space,strs);
		if strs[1] = self.voyage.code then
			//location includes the voyage code, so remove that bit...
			strs.removeAt(1);
		endif;
	else
		strs.add( self.sourceLocn );
	endif;
	
	self.voyage.findLocation(strs, true, tmpFoundLC, tmpFoundHeight);
	if tmpFoundLC = null or not tmpFoundLC.isGeneralCargoController then
		return 0;
	endif;
	
	return tmpFoundLC.CM_GeneralCargoController.hatch;
	
epilog

	delete strs;
	
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
