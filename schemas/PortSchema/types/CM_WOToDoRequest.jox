    <JadeMethod name="setForCreateInternal" id="23dc6342-49c9-4e3b-aed8-9d07e83e51d7">
        <updating/>
        <source>setForCreateInternal(_myJob: CM_WOToDoTaskJob; _toDoInternalJobParam: CMIF_WorkOrderJobParams) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Sep 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
27 Jan 2023	navcs2	ChangeRequest 54344:[54263] EUP - VAS Work Orders
19 Apr 2023 navma1  ChangeRequest 57326:[57327] EUP - VAS Task linked with Pack or Unpack Work Order
*/

vars

begin
	inheritMethod(_myJob, _toDoInternalJobParam);
	
	if _toDoInternalJobParam.myReserveDetail &lt;&gt; null then						//17.04.2023 navma1 #57326:[57327]
		self.myReserveDetail := _toDoInternalJobParam.myReserveDetail;
	endif;
epilog

end;</source>
        <Parameter name="_myJob" type="CM_WOToDoTaskJob"/>
        <Parameter name="_toDoInternalJobParam" type="CMIF_WorkOrderJobParams"/>
    </JadeMethod>
    <JadeMethod name="setProxyForToDoRequest" id="afae0077-6908-46fd-ada7-2af816adfe9a">
        <updating/>
        <source>setProxyForToDoRequest(_requestType : CM_ToDoRequestType; _userCode : String; _job : CM_Job) updating, protected;
// ---------------------------------------------------------------------------
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// Date				Who		Reason
// 28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
// ---------------------------------------------------------------------------
vars
	
begin

	self.setProxyForRequest(null, null, _job, _userCode);
	self.myToDoRequestType	:= _requestType;

end;</source>
        <access>protected</access>
        <Parameter name="_requestType" type="CM_ToDoRequestType"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="6d79a759-d8e7-42a4-a84b-b753673ffe1b">
        <source>typeString(): String;
// ---------------------------------------------------------------------------
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// Date				Who		Reason
// 28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
// ---------------------------------------------------------------------------
vars

begin

	if self.myToDoRequestType &lt;&gt; null then
		return self.myToDoRequestType.description;
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validate" id="e6675a73-7321-4c9a-bac8-62a8cc545ef6">
        <source>validate(pUserObject: Object);
// ---------------------------------------------------------------------------//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// Date				Who		Reason
// 28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pUserObject);

	if self.myToDoRequestType = null then
		app.raiseCMException(Input_required_field_toDoReqst, 'toDoRequestType', null);
	endif;

end;</source>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateToDoTaskStatus" id="8d935b57-1544-402a-ae4a-5bc6578880ee">
        <source>validateToDoTaskStatus(_newStatus : Integer);
//--------------------------------------------------------------
//  Date				Who		Reason
//  28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
//--------------------------------------------------------------
vars

begin
	if self.isComplete and not _newStatus = STATUS_COMPLETE then
		app.raiseCMException1(Err_InvalidType, _newStatus.String, null, null);
	endif;
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
</Class>
