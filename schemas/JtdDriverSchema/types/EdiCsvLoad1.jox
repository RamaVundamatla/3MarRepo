    <JadeMethod name="ecl018_CEF_picture_click" id="fe327319-c7cb-459c-adc6-368c0c895fa6">
        <updating/>
        <source>ecl018_CEF_picture_click():Integer updating;

vars
	picture:Picture;
begin
	myCMUI_EDIUserDefinedTypes_1.tblFieldMap.topRow:=5;
	app.doWindowEvents(shortPause);
	myCMUI_EDIUserDefinedTypes_1.tblFieldMap.topRow:=7;
	app.doWindowEvents(shortPause);
	myCMUI_EDIUserDefinedTypes_1.tblFieldMap.topRow:=4;
	app.doWindowEvents(shortPause);
	myCMUI_EDIUserDefinedTypes_1.tblFieldMap.topRow:=2;
	app.doWindowEvents(shortPause);
	myCMUI_EDIUserDefinedTypes_1.queryUnload(cancel, 0);
	if app.isValidObject(myCMUI_EDIUserDefinedTypes_1) then
		myCMUI_EDIUserDefinedTypes_1.unloadForm;  // 11:19:13
	endif;
	myCMUI_EDIUserDefinedTypes_1:=null;
	myCMUI_EDIForm_1.tblSearch.row:=1;
	myCMUI_EDIForm_1.tblSearch.column:=2;
	myCMUI_EDIForm_1.cmbFiltEdiType.gotFocus(myCMUI_EDIForm_1.cmbFiltEdiType);
	picture:=app.atcgGetAddedControl(myCMUI_EDIForm_1, 'Load New;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;144;-446;0;9;|').Picture;
	picture.mouseDown(picture, 1, 0, 13, 15);
	app.doWindowEvents(shortPause);
	picture:=app.atcgGetAddedControl(myCMUI_EDIForm_1, 'Load New;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;144;-446;0;9;|').Picture;
	picture.mouseUp(picture, 1, 0, 13, 15);
	app.doWindowEvents(shortPause);
	picture:=app.atcgGetAddedControl(myCMUI_EDIForm_1, 'Load New;picture;CMUI_ToolbarOverlay;0;-20;0;0;|;frame;CMUI_ToolbarButton;144;-446;0;9;|').Picture;
	app.doWindowEvents(shortPause);
	picture.click(picture);  // Load New  // 11:19:19
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
