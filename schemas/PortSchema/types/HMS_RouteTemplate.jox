    <JadeMethod name="getAuditText" id="d8f1add3-3a9e-4d48-8b0b-b9ff7ea307c8">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     May 2007 by cnwvu1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt		: String;
	tmpStr	: String;
	wayPoint: HMS_HarbourRegion;
	
begin

	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

	foreach wayPoint in self.allHarbourRegions do
		if tmpStr = null then
			tmpStr := wayPoint.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; wayPoint.code;
		endif;
	endforeach;
	txt := txt &amp; 'allHarbourRegions' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	tmpStr:=null;

	return txt;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
