    <JadeMethod name="checkCurrentUserHasAccess" id="81c8bb3b-24a9-486c-9ab3-bc4673c6c569">
        <updating/>
        <source>checkCurrentUserHasAccess(_permission : Integer) : Boolean updating;

/*

Purpose:			Check the current User has access to the passed in permission for
					the current terminal

Parameters:			JMT permission number

Return Value:		True if access OK, exception raised if access is not allowed


Date		Who		Reason
26 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	user			: CM_User;
	terminal		: CM_Terminal;

begin
	user := self.getMyUser();
	terminal := self.getMyTerminalDO_NOT_USE();

	if not user.canDo(terminal, _permission) then
		self.raiseCMException2(ERR_USER_NO_PERMISSION,
							   user.code, 
							   app.getPermissionName(_permission),
							   null, 
							   null);
		return false;
	endif;
	
	return true;
	

epilog

end;</source>
        <Parameter name="_permission" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
