    <JadeMethod name="pxyCreateUpdateProxy" id="82f4be40-963c-4f8a-8e80-38f5dfb3e280">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy

*/
vars
	proxyCraneMoveRates	: CM_CraneMoveRates;
	completedOK			: Boolean;
begin

	proxyCraneMoveRates:= inheritMethod();
	proxyCraneMoveRates.myCrane:=self.myCrane;
	proxyCraneMoveRates.myVessel:=self.myVessel;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyCraneMoveRates;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyCraneMoveRates;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d6b94af0-f199-4f78-8e35-7da103fd46f7">
        <updating/>
        <source>setForCreate(	_pxyCMR:CM_CraneMoveRates;
				_crane : CM_Crane;
				_vessel : CM_Vessel) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars



begin

	_pxyCMR.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_pxyCMR);
	if _vessel = null then		
		self.myCrane:=_crane;		
	else
		//need a new reference and 1 to many collection on cranes of vessel craneMoveRates
		self.myVesselCrane:=_crane;
		self.myVessel:=_vessel;
	endif;
epilog

end;</source>
        <Parameter name="_pxyCMR" type="CM_CraneMoveRates"/>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ee3625aa-9ee0-4488-89d0-190906a8263e">
        <updating/>
        <source>setForUpdate(_pxyCMR:CM_CraneMoveRates) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.ratePerHourSLOD:=_pxyCMR.ratePerHourSLOD;
	self.ratePerHourSLUD:=_pxyCMR.ratePerHourSLUD;
	self.ratePerHourTLOD:=_pxyCMR.ratePerHourTLOD;
	self.ratePerHourTLUD:=_pxyCMR.ratePerHourTLUD;
	self.ratePerHourOD  :=_pxyCMR.ratePerHourOD;

epilog

end;</source>
        <Parameter name="_pxyCMR" type="CM_CraneMoveRates"/>
    </JadeMethod>
    <JadeMethod name="setMyCrane" id="eada577c-1e73-49ff-9e5d-759ceb4e5c27">
        <updating/>
        <source>setMyCrane(_crane : CM_Crane) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwas3	Initial creation

*/

vars

begin
	if _crane &lt;&gt; null and self.myCrane &lt;&gt; _crane then
		self.myCrane := _crane;
	endif;
epilog

end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="980ed5ff-2f91-4683-88ce-a1a6db92d670">
        <updating/>
