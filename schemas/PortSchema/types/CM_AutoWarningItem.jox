        <length>51</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="minutesBeforeAlert" id="d1a254ab-d7f9-41b9-ab62-10add253a77b">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="webSiteConfigName" id="63fb76c2-42dd-467e-b5f7-2f5b3d27ccc9">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="set" id="ab91dbca-ad8a-44fc-881a-b91365c4a5ab">
        <updating/>
        <source>set(_minutesBeforeAlert:Integer;
	_alertFrequency:Integer;
	_className:String;
	_webSiteConfig : String) updating;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Standard method for setting the receiver proxy's property values.
//
// Parameters:	_minutesBeforeAlert - The number of minutes until an alert is sent.
//				_alertFrequency - The number of minutes between alerts.
//				_className - The name of the request class for the alert.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.minutesBeforeAlert	:=	_minutesBeforeAlert;
	self.alertFrequency		:=	_alertFrequency;
	self.webSiteConfigName	:=	_webSiteConfig;
	self.className			:=	_className;
end;</source>
        <Parameter name="_minutesBeforeAlert" type="Integer"/>
        <Parameter name="_alertFrequency" type="Integer"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_webSiteConfig" type="String"/>
    </JadeMethod>
    <JadeMethod name="setWebSiteConfigName" id="0c9e4efd-3111-47a3-bf48-c02ab84980a4">
        <updating/>
        <source>setWebSiteConfigName(_name : String) updating;

// Created by cnwdvb1 on 12 July 2007

vars

begin

	self.webSiteConfigName := _name;

	

end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
</Class>
