    <JadeMethod name="setLogicalFocus" id="16c6483a-edf3-4e95-a995-3ba11cdc7874">
        <source>setLogicalFocus() protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.fldMain.topSheet = self.shtBoom then
	elseif self.fldMain.topSheet = self.shtError then
		self.txtWrongData.setFocus;
	elseif self.frmMain.visible then
		self.txtVehicle.setFocus();
	elseif self.frmContInfo.visible then
		self.txtId.setFocus();
	elseif self.frmDamage.visible then
		self.tblDamage.setFocus();
	endif;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ce636e06-2c76-435d-811c-2216313bba24">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod();
	self.frmMain.zOrder(1);
	self.left := 0;
	self.top := 0;
	
	//epr 6/9/07 gdansk have not in lanes 7 &amp; 8
	self.optIn7.visible:=false;
	self.optIn8.visible:=false;
	//self.tblDamage.init();
	
	self.loadCmbRemarks();
	self.clearAllInfo();
	self.doShowFrmMain();
	
	self.lblJobInfo.caption := 'Waiting for vehicle ID match...';
	
	self.txtSealCust.maxLength := 35;
	self.txtSealCust.scrollVertical := true;
	self.txtSealOp.maxLength := 35;
	self.txtSealOp.scrollVertical := true;
	self.txtSealShip.maxLength := 35;
	self.txtSealShip.scrollVertical := true;
end;


</source>
    </JadeMethod>
