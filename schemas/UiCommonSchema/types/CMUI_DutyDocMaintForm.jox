    <JadeMethod name="setControlsForPermissions" id="263d460f-3484-46f6-a3a9-e05bbb24dfc6">
        <source>setControlsForPermissions() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwer1	Initial creation HAT 2189
02 September 2014  CNWMA1 PAR#34845 Container Filter by voyage
*/

vars

begin
	self.enableAllControls(true);
	self.cmbInvTerms.enabled:=self.myDutyDoc = null or self.myDutyDoc.allDutyDocItems.size = 0;  //epr par 31291  can only change when no duty doc items
	self.cmbVoyage.enabled:=self.myDutyDoc = null or self.myDutyDoc.allDutyDocItems.size = 0;	 // 02/09/2014 CNWMA1 PAR# 34845 
	self.cmbConsignee.enabled:=self.myDutyDoc = null or self.myDutyDoc.allDutyDocItems.size = 0; // 02/09/2014 CNWMA1 PAR# 34845  
	self.cmbBillType.enabled:=self.myDutyDoc = null or self.myDutyDoc.allDutyDocItems.size = 0;  // 02/09/2014 CNWMA1 PAR# 34845 
	//if it is a add can only set data entry
	self.chkDataEntry.enabled:=self.hasPermDataEntry;
	self.chkSupervisor.enabled:=self.myDutyDoc &lt;&gt; null and self.myDutyDoc.dutyDocUserId &lt;&gt; null and self.hasPermSupervisor;
	self.chkDocInCharge.enabled:=self.myDutyDoc &lt;&gt; null and self.myDutyDoc.supervisorUserId &lt;&gt; null  and self.hasPermDocInCharge;
	self.chkGroupSuper.enabled:=self.myDutyDoc &lt;&gt; null and self.myDutyDoc.docInChargeUserId &lt;&gt; null  and self.hasPermCustomsInspector;
	
	self.txtDeposit.enabled:=self.myDutyDoc &lt;&gt; null and self.hasPermCustomsInspector;
	self.txtCustRemarks.enabled:=self.myDutyDoc &lt;&gt; null and self.hasPermCustomsInspector;
	self.txtReason.enabled:=self.myDutyDoc &lt;&gt; null and self.hasPermCustomsInspector;
	self.cmbCustomsInsp.enabled:=self.myDutyDoc &lt;&gt; null and self.hasPermCustomsInspector;
	
	self.btnCharges.enabled:=self.cmbConsignee.text &lt;&gt; null;
	
	self.cmbStatus.enabled:=self.chkGroupSuper.enabled;
	
	if self.chkGroupSuper.enabled  then
		self.enableAllControls(false);
		self.chkDocInCharge.readOnly:=not (self.myDutyDoc &lt;&gt; null and self.myDutyDoc.supervisorUserId &lt;&gt; null  and self.hasPermDocInCharge);
		self.chkGroupSuper.readOnly:=false;
		self.cmbStatus.enabled:=true;
		self.txtReason.readOnly:=false;
		self.txtReason.enabled:=true;
		self.txtCustRemarks.readOnly:=false;
		self.txtCustRemarks.enabled:=true;
		self.cmbCustomsInsp.enabled:=true;
		self.btnSave.enabled:=true;
		self.btnDelete.enabled:=true;
		self.btnCurrentChrges.enabled:=true;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEffectiveDate" id="ddba69c8-d09e-4f57-b67f-25aa29ef927a">
        <source>setEffectiveDate();
/*

Purpose:			

