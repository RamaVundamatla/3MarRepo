    <JadeMethod name="setCMIF_Prenote" id="a74dd8f9-ed1a-45c2-afb3-3f1480b7f061">
        <source>setCMIF_Prenote(	_voyage	: CM_Voyage input;
					_cmifPrenote : CMIF_PreNote input
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 March 2018	jlger1	Initial creation
23 July 2018	jlgam15	TFS 39837 - Work Order Cargo Request more fields --&gt; added startDateTime, endDateTime, bol, loadPort
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
*/

vars
	cargoTypeObj        : CM_CargoType;
	product 			: CM_Product;
	holdLC 				: CM_LocationsController;
	operator 			: CM_Operator;
	consignee,
	consignor,
	freightForwarder : CM_ConsigneeConsignor;
	commodityObj			: CM_Commodity;
begin
	
	if _cmifPrenote = null then
		return;
	endif;
	
	
	cargoTypeObj:=self.getCargoType();
	
	if cargoTypeObj = null then
		app.raiseCMException1(Cargo_Type_Invalid, self.cargoType.String, null, null);
	
		return;
	endif;
	_cmifPrenote.myTerminal		:= app.myPassport.myTerminal;
	//_cmifPrenote.id				:= 	_cmifPrenote.myTerminal.generateNextCargoId(false,false);  //generate id // 1 Sept 2022 navmv20 TFS 54610
	_cmifPrenote.id				:= 	_cmifPrenote.myTerminal.generateNextCargoId(false,false,null); //1 Sept 2022 navmv20 TFS 54610
	_cmifPrenote.cargoType		:= cargoTypeObj.id;
	_cmifPrenote.billOfLading 	:= self.bolNumber;
	
	_cmifPrenote.dischargePort:= self.getDischargePortCode;
	_cmifPrenote.loadPort := self.getLoadPortCode;
	
	if self.consignee &lt;&gt; null then
		consignee:=self.getConsignor();
		if consignee &lt;&gt;  null then
			_cmifPrenote.consigneeCode :=consignee.code;
		else			
			_cmifPrenote.consigneeCode		:= self.consignee;
		endif;	
	endif;
	
	if self.consignor &lt;&gt; null then
		consignor:=self.getConsignor();
		if consignor &lt;&gt;  null then
			_cmifPrenote.consignorCode :=consignor.code;
		else			
			_cmifPrenote.consignorCode		:= self.consignor;
		endif;	
	endif;
	
	if self.freightForwarder &lt;&gt; null then
		freightForwarder:=self.getFreightForwarder();
		if freightForwarder &lt;&gt;  null then
			_cmifPrenote.freightForwarderCode :=freightForwarder.code;
		else			
			_cmifPrenote.freightForwarderCode		:= self.freightForwarder;
		endif;	
	endif;
	
	_cmifPrenote.imexStatus		:= self.imexStatus;		
	
	if self.operator &lt;&gt; null then
		operator:=self.getOperator;
		if operator &lt;&gt;  null then
			_cmifPrenote.operatorCode :=operator.code;
		else			
			_cmifPrenote.operatorCode		:= self.operator;
		endif;	
	endif;	
	_cmifPrenote.voyageCode			:= _voyage.code;		//cnwmc5 - 4 July 2014 - PAR 34503
	
	commodityObj:=self.getCommodity;
	if commodityObj &lt;&gt; null then
		_cmifPrenote.commodity:=commodityObj.code;
	endif;
	
	holdLC:=self.getHoldLocation;
	if holdLC = null then
		holdLC:=_voyage.myShipBlockStack;
	endif;
	if _cmifPrenote.imexStatus = TI_IMEX_STATUS_IMPORT then
		_cmifPrenote.transportMode:=TI_TRANSMODE_SHIP_STR;
		_cmifPrenote.stowageLocation:=holdLC.getFullId();
	else
		_cmifPrenote.transportMode:=TI_TRANSMODE_ROAD_STR;
	endif;
	//cmifPrenote.transportMode		:= self.transportMode;
	_cmifPrenote.imExStatus:=app.myRoot.allImexStatuses[_cmifPrenote.imexStatus];
				
	if cargoTypeObj.isBreakBulkMulti then
		_cmifPrenote.numberOfItems		:= self.totalQuantity;	//Total Quantity
	endif;
	
	if cargoTypeObj.isContainer then
		_cmifPrenote.isoType:=self.cargoSubType;
	elseif cargoTypeObj.isTrailer then
		_cmifPrenote.trailerType:= self.cargoSubType;
	else
		product:=self.getProduct;
		_cmifPrenote.myProduct	:=product;	
	endif;
	
	
	
	_cmifPrenote.setEmailDefaults();
	
	//epr TFS 7744 webportal over dimensions for containers and for every thing else the rest
	// needs to be done before setting the total weight for bulk by volume	
	
	_cmifPrenote.weightTotal		:= self.totalWeight.asDecimalFromWebInterface;
	//cnwmc5 - 13 March 2015 - PAR 35864
	if cargoTypeObj.isBulkByVolume then
		if product= null then		
			product := cargoTypeObj.mySystemProductType;		
		endif;
			
		_cmifPrenote.volumeTotal:=self.totalVolume.asDecimalFromWebInterface;
		_cmifPrenote.weightTotal := self.totalVolume.asDecimalFromWebInterface * product.myDensityDec.value;	// ### TFS 52193 22Nov2021 NAVPW1
	endif;
	if cargoTypeObj.useTareCargoWeight then
		_cmifPrenote.weightCargo :=self.cargoWeight.asDecimalFromWebInterface;
		_cmifPrenote.weightTare :=self.tareWeight.asDecimalFromWebInterface;
	endif;

	
	_cmifPrenote.validateForCreate(app.myPassport);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_cmifPrenote" type="CMIF_PreNote" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="d0c19483-07eb-49b2-ad46-550a5526bcc5">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodCargoRequest) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object

*/

vars 
	transferType  : CM_VoyageJobTransferType;
	dischPort : CM_Port;
	loadPort : CM_Port;
begin
	inheritMethod(_object);
	if _object.myCargoType &lt;&gt; null then
		self.cargoType:=_object.myCargoType.getOidAsString;
	endif;
	
	on Exception do app.handleDeletedObjectReferences(exception, _object);
	
	if _object.myCargoSubType &lt;&gt; null then
		self.cargoSubType:=_object.myCargoSubType.getOidAsString;
	endif;
	if _object.myConsignee &lt;&gt; null then
		self.consignee:=_object.myConsignee.getOidAsString;
	endif;
	if _object.myConsignor &lt;&gt; null then
		self.consignor:=_object.myConsignor.getOidAsString;
	endif;
	if _object.myFreightForwarder &lt;&gt; null then
		self.freightForwarder:=_object.myFreightForwarder.getOidAsString;
	endif;
	
	self.gangs:=_object.numGangs;
	self.imexStatus:=_object.imexStatus;
	if _object.myLocationsController &lt;&gt; null then
		self.holdLocation:=_object.myLocationsController.getOidAsString;
	endif;
	self.totalWeight:=_object.totalWeight.asStringForWebInterface;
	self.totalVolume:=_object.totalVolume.asStringForWebInterface;
	self.totalQuantity:=_object.totalQuantity;
	self.cargoWeight:=_object.weightCargo.asStringForWebInterface;
	self.tareWeight:=_object.weightTare.asStringForWebInterface;
	self.estimatedEndDT := _object.estimatedEndTS.asStringForWebInterface;
	self.estimatedStartDT :=  _object.estimatedStartTS.asStringForWebInterface;
	self.bolNumber := _object.bolNumber;
	
	if _object.myCommodity &lt;&gt; null then
		self.commodity:=_object.myCommodity.getOidAsString;
	endif;
	
	if _object.myOperator &lt;&gt; null then
		self.operator:=_object.myOperator.getOidAsString;
	endif;
	
	if _object.getMyWorkPoint &lt;&gt; null then
		self.workpoint:=_object.getMyWorkPoint.getOidAsString;
	endif;
	
	transferType := app.myRoot.allVoyageJobTransferTypes[_object.transferType];
	if transferType &lt;&gt; null then
		self.voyageJobTransferType:=transferType.getOidAsString;
	endif;
	
	dischPort:=app.myRoot.allPorts[_object.dischargePort];
	if dischPort &lt;&gt; null then
		self.dischargePort:=dischPort.getOidAsString;
	endif;
	
	loadPort:=app.myRoot.allPorts[_object.loadPort];
	if loadPort &lt;&gt; null then
		self.loadPort:=loadPort.getOidAsString;
	endif;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_WodCargoRequest"/>
    </JadeMethod>
    <JadeMethod name="setProxyJobParams" id="dc21da5b-7aca-4f1a-85aa-96268e907923">
        <source>setProxyJobParams(		_voyage : CM_Voyage input;
						_pxyJobParams : CMIF_VoyageJobParams input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2018	jlger1	Initial creation

*/

vars

	pxyJob  : CM_VoyageHoldJob;
	jobType : Integer;
	jobNum 	: String;
	jobSheet : CM_VoyageJobSheet;
	holdLocation : CM_GeneralCargoController;
	workpoint : CM_WorkPoint;
begin
	holdLocation:=self.getHoldLocation();

	if holdLocation = null then
		app.raiseCMException(Input_requir_voyage_hold_field,null,null);
		return;
	endif;
	
	if holdLocation.myGCVoyage &lt;&gt; _voyage.myGeneralCargoVoyage then
		app.raiseCMException(Input_requir_voyage_hold_field,null,null);
		return;
	endif;
	
	
	workpoint:=self.getWorkPoint();
	if workpoint = null then
		app.raiseCMException(Input_required_field_workPoint,null,null);
		return;
	endif;
	jobSheet :=_voyage.allJobSheets[workpoint.code];
	
	create pxyJob transient;
	pxyJob.setProxyVoyage(_voyage);
	if imexStatus = TI_IMEX_STATUS_EXPORT then
		//load
		jobType := JOB_TYPE_LOAD;
	else
		//discharge
		jobType := JOB_TYPE_DISCHARGE;
	endif;
		
	jobNum:=_voyage.getNextJobNumber(jobSheet,workpoint);
	pxyJob.setProxy(jobNum, jobType);
	pxyJob.setProxyVoyageHoldJob(workpoint.code, jobNum, null, null, false, jobType, null, null,_voyage.arrivedDT, _voyage.departedDT, 
								false,null, null, null,self.estimatedStartDT.asTimeStampFromWebInterface(),self.estimatedEndDT.asTimeStampFromWebInterface());		// TFS 3516

	pxyJob.setTransferType( self.getTransferType() );
	pxyJob.setNumOfGangs(self.gangs);
	
	if jobType = JOB_TYPE_LOAD then		
		_pxyJobParams.myLocation :=holdLocation;
	endif;
	_pxyJobParams.myVoyage:=_voyage;
	_pxyJobParams.myProxyJob:=pxyJob;
	_pxyJobParams.myWorkPoint:=workpoint;
	_pxyJobParams.myJobSheet :=jobSheet; //epr TFS 40032 3/8/18
	_pxyJobParams.craneID:=workpoint.code;
	_pxyJobParams.transitStatus := TI_TransitStatusNull;	
	_pxyJobParams.isDischarge:=jobType = JOB_TYPE_DISCHARGE;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_pxyJobParams" type="CMIF_VoyageJobParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyWodCargoRequest" id="9d9bf890-04a2-41ae-a39d-24621766cbe3">
        <source>setProxyWodCargoRequest(_pxyCargoRequest : CM_WodCargoRequest input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2018	jlger1	Initial creation 40032
30/10/2018	jlgdap1	TFS 41305 PEL1 Voyage and Cargo Operator in Web Portal
*/

vars	
	cargoTypeObj        : CM_CargoType;
	totalQuantity : Integer;
	cargoWeight,
	tareWeight,
	totalVolume : Decimal [14,4];
	totalWeight : Decimal [14,4];
	product 			: CM_Product;
	
	transferMode : Integer;
	operatorObj : CM_Operator;						// TFS 41305
begin
	cargoTypeObj:=self.getCargoType();
	
	if cargoTypeObj = null then
		app.raiseCMException1(Cargo_Type_Invalid, self.cargoType.String, null, null);
	
		return;
	endif;
	
	if cargoTypeObj.isContainer then
	//	_cmifPrenote.isoType:=self.cargoSubType;
	elseif cargoTypeObj.isTrailer then
	//	_cmifPrenote.trailerType:= self.cargoSubType;
	else
		product:=self.getProduct;
		//_cmifPrenote.myProduct	:=product;	
	endif;
	
	totalWeight:=self.totalWeight.asDecimalFromWebInterface;
	if cargoTypeObj.isBulkByVolume then
		if product= null then		
			product := cargoTypeObj.mySystemProductType;		
		endif;
		totalWeight:=self.totalVolume.asDecimalFromWebInterface * product.myDensityDec.value;		// ### TFS 52193 22Nov2021 NAVPW1
		totalVolume:=self.totalVolume.asDecimalFromWebInterface;
//	elseif cargoTypeObj.isBreakBulkMulti then
//		totalQuantity:=self.totalQuantity;
	endif;
	totalQuantity:=self.totalQuantity;	//05 Jun 2019	NDL	TFS 44773
	if cargoTypeObj.useTareCargoWeight then
		cargoWeight:=self.cargoWeight.asDecimalFromWebInterface;
		tareWeight:=self.tareWeight.asDecimalFromWebInterface;
	endif;
	
/*	if self.imexStatus = TI_IMEX_STATUS_IMPORT then
		transferTy:=TI_TRANSMODE_SHIP_STR;
	else
		transportMode:=TI_TRANSMODE_ROAD_STR;
	endif;*/
	
	// TFS 41305 Pelindo are using Operator Data Access Groups to govern access to 
	// various things in the web portal, but also want ALL operators to be available 
	// for selection when defining Discharge and Load Cargo Operators. 
	// So we can't do getOperator here because that does an access check which will fail
	operatorObj := self.operator.asOid.CM_Operator;							// TFS 41305		
	if operatorObj = null then												// TFS 41305
		operatorObj := app.myRoot.allOperators[self.operator];				// TFS 41305
	endif;
	
	_pxyCargoRequest.setProxyWodCargoRequest(self.getDischargePortCode,
											self.imexStatus,
											self.gangs,
											totalQuantity,
											totalVolume,
											totalWeight,
											 self.getTransferType(),
											 cargoWeight,
											tareWeight,
											product,
											cargoTypeObj,
											self.getCommodity,
											self.getConsignee,
											self.getConsignor,
											self.getFreightForwarder,
											self.getHoldLocation,
											//self.getOperator,				// TFS 41305
											operatorObj,					// TFS 41305
											self.getWorkPoint,
											null,
											null,
											self.getLoadPortCode,
											self.bolNumber,
											self.estimatedStartDT.asTimeStampFromWebInterface,
											self.estimatedEndDT.asTimeStampFromWebInterface);
											
													
	
	
epilog

end;</source>
        <Parameter name="_pxyCargoRequest" type="CM_WodCargoRequest" usage="input"/>
    </JadeMethod>
</Class>
