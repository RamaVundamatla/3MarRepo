    <JadeMethod name="loadCmbTrain" id="13738824-d08b-4d71-9dc4-2286cbdd9554">
        <source>loadCmbTrain() protected;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

