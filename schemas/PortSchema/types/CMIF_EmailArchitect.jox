    <JadeMethod name="addAttachment" id="e45e19a0-a83a-4442-a631-14e1ec9dd9ab">
        <updating/>
        <source>addAttachment(_mail : JadeDotNetType input; _fileName : String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 January 2024		navmd1	Initial creation TFS 55021 EASendMail Refactor

*/

vars
	exceptionOccurred 	: Boolean;
begin
	on Exception do self.handleExceptionsExt(exception, exceptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	self.sendMailHelper.addAttachment(_mail, _fileName.StringUtf8, self.logFileName, app.logLevel);
	
	return not exceptionOccurred;
	
end;</source>
        <Parameter name="_mail" type="JadeDotNetType" usage="input"/>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
