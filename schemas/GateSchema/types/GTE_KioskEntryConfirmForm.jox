end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnYes_click" id="73f7df01-3405-4586-99b7-3804b5d24438">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnYes_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.updateForm(false) then
		self.modalResult	:=	self.CNEC_MODAL_UPDATE;
		self.unloadForm();
	endif;
	
	app.beep();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSwapDoors" id="3cba7908-a53c-4d00-97aa-9c4ddb9b124f">
        <source>doSwapDoors() protected;
// --------------------------------------------------------------------------------
// Created:		02 August 2006 by cnwdad1
//
// Purpose:		Swaps the doors between front and back of the current container.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyCargoObj		: GTE_KioskProxyCargo;
	allProxyCargosObj	: GTE_KioskProxyCargoArray;
	
begin
	proxyCargoObj		:=	self.aMyProxyLoad.findCargoForId(self.getCurrentCargoId(), self.aCargoCount);
	allProxyCargosObj	:=	self.aMyProxyLoad.getProxyCargoArray(proxyCargoObj);
	
	proxyCargoObj.setCargoConfig(not proxyCargoObj.isDoorsBack);
	self.adjustContainerLayout(allProxyCargosObj);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getCurrentCargoId" id="e04362ac-77e8-4176-aec5-ab08ce63c68d">
        <source>getCurrentCargoId():String protected;
// --------------------------------------------------------------------------------
// Created:		26 September 2006 by cnwdad1
//
// Purpose:		Returns the Cargo ID of the current container that is being confirmed.
//
// Parameters:	None
//
// Returns:		The current Cargo ID, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cargoObj	: CM_Object;
	
begin
	cargoObj	:=	self.aMyCargoItem;
	
	if cargoObj.isKindOf(CM_TrackedItem) then
		return cargoObj.CM_TrackedItem.id;
	elseif cargoObj.isKindOf(CM_BulkRelease) then
		return cargoObj.CM_BulkRelease.code;
	else
		return null;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentContainer" id="026ff1a5-f39e-41b5-93e5-b375c1b64dc1">
        <source>getCurrentContainer():CMUI_ContainerLoad protected;
// --------------------------------------------------------------------------------
// Created:		26 September 2006 by cnwdad1
//
// Purpose:		Returns a reference to the container currently being confirmed.
//
// Parameters:	None
//
// Returns:		A reference to the current container control, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cargoId			: String;
	
begin
	cargoId	:=	self.getCurrentCargoId();
	
	if cargoId = null then
		return null;
	endif;
	
	if picLoad1.cargoId = cargoId then
		return picLoad1;
	elseif picLoad2.cargoId = cargoId then
		return picLoad2;
	elseif picLoad3.cargoId = cargoId then
		return picLoad3;
	elseif picLoad4.cargoId = cargoId then
		return picLoad4;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="CMUI_ContainerLoad"/>
    </JadeMethod>
