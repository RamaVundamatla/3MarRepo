    <JadeMethod name="validate" id="810b8e33-749d-489e-929d-d0e9af3346f1">
        <source>validate(_passport :CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2015	cnwrd1	Initial creation
22 May 2018 jlggb1	Add Release Rule TFS 36933

*/

vars
	ruleItem		:String;
	ruleFunction, 
	type			:Integer;
begin
	self.raiseExceptionIfNotTransient (method);
	
	ruleItem 	:= self.item;
	type 		:= self.myEDIPartyRules.getType;
	
	if ruleItem = null then
		app.raiseCMException (EDI_Party_Error6, null, null);
	elseif  type = EDIFileTypeX12_315_4010 and  
			(ruleItem = self.Item_B403 or ruleItem = self.Item_N903) then
			//ok
	else
		// we expect GUI to take care of this (including not passing in null values)
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Item is not supported');
	endif;
	
	ruleFunction := self.function;
	
	if ruleFunction = null then
		app.raiseCMException (EDI_Party_Error8, null, null);
	endif;
	
	if ruleItem = self.Item_B403 then
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Function_B403_StopAdd and 
			   ruleFunction &lt;&gt; self.Function_B403_StopRemove then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
	elseif ruleItem = self.Item_N903 then
		if ruleFunction &lt;&gt; null then
			if ruleFunction &lt;&gt; self.Function_N903_CreateRelease then
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Function is not supported');
			endif;
		endif;
	endif;
	
	if self.value = null and ruleItem = self.Item_B403 then
		app.raiseCMException (EDI_Party_Error7, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
