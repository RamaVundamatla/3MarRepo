    <JadeMethod name="cnEcAddItem" id="783d6202-a85a-4794-a9a7-4d5a92787a17">
        <updating/>
        <source>cnEcAddItem(pValue:String; pItemObj:Object) updating;
// --------------------------------------------------------------------------------
// Created:		19 October 2006 by cnwdad1
//
// Purpose:		Adds a row to the receiver, and sets the itemObject reference.
//
// Parameters:	pValue - The display value for the new row.
//				pItemObj - A reference to the new row's itemObject.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.addItem(pValue);
	
	if pItemObj &lt;&gt; null then
		self.accessRow(rowPointer).itemObject	:=	pItemObj;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
        <Parameter name="pItemObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="cnEcAlternateRowColors" id="47dffabc-9c0d-42fa-8826-d639754a2741">
        <updating/>
        <source>cnEcAlternateRowColors(pColor1:Integer; pColor2:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		13 October 2007 by cnwdad1
//
// Purpose:		Alternates the receiver's rows between the two specified colors.
//
// Parameters:	pColor1 - Start the first row with this color, and every second after that.
//				pColor2 - Start the second row with this color, and every second after that.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startRow	: Integer;
	maxRows		: Integer;
	rowPointer	: Integer;
	isAlternate	: Boolean;
	
begin
	startRow	:=	self.fixedRows + 1;
	maxRows		:=	self.rows;
	isAlternate	:=	false;
	
	foreach rowPointer in startRow to maxRows do
		if not isAlternate then
			self.accessRow(rowPointer).backColor	:=	pColor1;
			isAlternate	:=	true;
		else
			self.accessRow(rowPointer).backColor	:=	pColor2;
			isAlternate	:=	false;
		endif;
	endforeach;
end;</source>
        <Parameter name="pColor1" type="Integer"/>
        <Parameter name="pColor2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcCellBoolean" id="854ec5e7-a290-4881-ba6a-9ba5d4f1da53">
        <source>cnEcCellBoolean(pRowPointer:Integer; pColPointer:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		24 October 2006 by cnwdad1
//
// Purpose:		Returns the boolean value of a cell, provided that the cell's
//				input type is for a checkbox.
//
// Parameters:	pRowPointer - The row of the cell.
//				pColPointer - The column of the cell.
//
// Returns:		True or false, depending upon the state of the cell's checkbox.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.inputType = self.InputType_CheckBox then
		return self.getCellText(pRowPointer, pColPointer) = "1";
	else
		return false;
	endif;
end;</source>
        <Parameter name="pRowPointer" type="Integer"/>
        <Parameter name="pColPointer" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcClearAllCellObjects" id="4cb6b317-720c-4971-a395-9ccd6595c356">
        <updating/>
        <source>cnEcClearAllCellObjects(pIsDelete:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		30 March 2006 by cnwdad1
//
// Purpose:		Clears the itemObject for every cell in the receiver, and optionally
//				deletes them.
//
// Parameters:	pIsDelete - True if the objects are to be deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cellObj		: JadeTableCell;
	rowPointer	: Integer;
	rowStart	: Integer;
	rowMax		: Integer;
	colPointer	: Integer;
	colStart	: Integer;
	colMax		: Integer;
	
begin
	rowStart	:=	self.fixedRows + 1;
	rowMax		:=	self.rows;
	colStart	:=	self.fixedColumns + 1;
	colMax		:=	self.columns;
	
	foreach rowPointer in rowStart to rowMax do
		foreach colPointer in colStart to colMax do
			cellObj	:=	self.accessCell(rowPointer, colPointer);
			
			if pIsDelete then
				delete cellObj.itemObject;
			else
				cellObj.itemObject	:=	null;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="pIsDelete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcClearAllColumnObjects" id="1f2833ec-a7ad-4cd8-9258-61b8b99fe112">
        <updating/>
        <source>cnEcClearAllColumnObjects(pIsDelete:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		30 March 2006 by cnwdad1
//
// Purpose:		Clears the itemObject for all of the receiver's columns, and optionally
//				deletes them.
//
// Parameters:	pIsDelete - True if the objects are to be deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columnObj	: JadeTableColumn;
	colPointer	: Integer;
	colStart	: Integer;
	colMax		: Integer;
	
begin
	colStart	:=	self.fixedColumns + 1;
	colMax		:=	self.columns;
	
	foreach colPointer in colStart to colMax do
		columnObj	:=	self.accessColumn(colPointer);
		
		if pIsDelete then
			delete columnObj.itemObject;
		else
			columnObj.itemObject	:=	null;
		endif;
	endforeach;
end;</source>
        <Parameter name="pIsDelete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcClearAllRowObjects" id="0abb38c7-94bd-4f6f-94da-e6c9881df106">
        <updating/>
        <source>cnEcClearAllRowObjects(pIsDelete:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		30 March 2006 by cnwdad1
//
// Purpose:		Clears the itemObject for all of the receiver's rows, and optionally
//				deletes them.
//
// Parameters:	pIsDelete - True if the objects are to be deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowObj		: JadeTableRow;
	rowPointer	: Integer;
	rowStart	: Integer;
	rowMax		: Integer;
	
begin
	rowStart	:=	self.fixedRows + 1;
	rowMax		:=	self.rows;
	
	foreach rowPointer in rowStart to rowMax do
		rowObj	:=	self.accessRow(rowPointer);
		
		if pIsDelete then
			delete rowObj.itemObject;
		else
			rowObj.itemObject	:=	null;
		endif;
	endforeach;
end;</source>
        <Parameter name="pIsDelete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcClearColumnCellObjects" id="601b85a0-669f-4760-8282-9dd881d8978f">
        <updating/>
        <source>cnEcClearColumnCellObjects(pColumn:Integer; pIsDelete:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		30 March 2006 by cnwdad1
//
// Purpose:		Clears the itemObject for every cell in the receiver's specified
//				column, and optionally deletes them.
//
// Parameters:	pColumn - The column who's objects are to be cleared.
//				pIsDelete - True if the objects are to be deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cellObj		: JadeTableCell;
	rowPointer	: Integer;
	rowStart	: Integer;
	rowMax		: Integer;
	
begin
	if pColumn &lt;= self.fixedColumns or pColumn &gt; self.columns then
		return;
	endif;
	
	rowStart	:=	self.fixedRows + 1;
	rowMax		:=	self.rows;
	
	foreach rowPointer in rowStart to rowMax do
		cellObj	:=	self.accessCell(rowPointer, pColumn);
		
		if pIsDelete then
			delete cellObj.itemObject;
		else
			cellObj.itemObject	:=	null;
		endif;
	endforeach;
end;</source>
        <Parameter name="pColumn" type="Integer"/>
        <Parameter name="pIsDelete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcClearRowCellObjects" id="8d6b4e5d-cc91-4a41-ad84-cd24d43ec97a">
        <updating/>
        <source>cnEcClearRowCellObjects(pRow:Integer; pIsDelete:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		30 March 2006 by cnwdad1
//
// Purpose:		Clears the itemObject for every cell in the receiver's specified
//				row, and optionally deletes them.
//
// Parameters:	pRow - The row who's objects are to be cleared.
//				pIsDelete - True if the objects are to be deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cellObj		: JadeTableCell;
	colPointer	: Integer;
	colStart	: Integer;
	colMax		: Integer;
	
begin
	if pRow &lt;= self.fixedRows or pRow &gt; self.rows then
		return;
	endif;
	
	colStart	:=	self.fixedColumns + 1;
	colMax		:=	self.columns;
	
	foreach colPointer in colStart to colMax do
		cellObj	:=	self.accessCell(pRow, colPointer);
		
		if pIsDelete then
			delete cellObj.itemObject;
		else
			cellObj.itemObject	:=	null;
		endif;
	endforeach;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pIsDelete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcExportToCSV" id="bdd06450-03b7-4f08-827d-00be27796b87">
        <updating/>
        <source>cnEcExportToCSV(pFileObj:File input; pIsIncludeHeadings:Boolean):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		22 June 2005 by cnwdad1
//
// Purpose:		Exports the contents of the receiver's rows into a disk file, in
//				CSV format.
//
// Parameters:	pFileObj - A reference to the File object to be written to. Note
//					that this only needs to be instantiated, it does not need file
//					names and attributes to be set up (this method looks after that).
//
//				pIsIncludeHeadings - True if table headings should also be exported.
//
// Returns:		A reference to the File parameter, and, true if the export was
//				successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 15/12/2006	cnwdad1		Changed to use CardSchema's CSV-string format method on
//							the text of each cell.
// --------------------------------------------------------------------------------
// adm 200509 Par 19207  change abstract exception class
// 22/01/2018   cnwma1		Bug 36680: CSV export in cargo enquiry - Transaction screen doesn't work properly
vars
	rowPointer	: Integer;
	rowCount	: Integer;
	startRow	: Integer;
	colPointer	: Integer;
	colCount	: Integer;
	startCol	: Integer;
	cellValue	: String;
	csvRow		: String;
	
begin
	if not pFileObj.cnEcSetSaveName("",
									true,
									true,
									CNEC_FILE_FILTER_DATA &amp; "|" &amp; CNEC_FILE_FILTER_ALL) then
		return false;
	endif;
	
	if (not pFileObj.tryOpen) then
		CnEcBaseSchemaException.raise_(CNEC_X_13999, "Cannot open '" &amp; pFileObj.fileName &amp; "'");
		return false;
	endif;
	
	rowCount	:=	self.rows;
	colCount	:=	self.columns;
	
	if pIsIncludeHeadings then
		startRow	:=	1;
		startCol	:=	1;
		if self.name = "tblTrans" then  //22/01/2017 cnwma1 BUG #36680
			if self.parent &lt;&gt; null and self.parent.name="shtTransactions" then
				startCol	:=	3;
			endif;
		endif;
		
	else
		startRow	:=	self.fixedRows + 1;
		startCol	:=	self.fixedColumns + 1;
	endif;
	
	foreach rowPointer in startRow to rowCount where self.accessRow(rowPointer).visible do
		foreach colPointer in startCol to colCount where self.accessColumn(colPointer).visible do
			cellValue	:=	self.accessCell(rowPointer, colPointer).text;
			
			if colPointer = startCol then
				csvRow	:=	cellValue.cnFormatForCSVFile(false);
			else
				csvRow	:=	csvRow &amp; "," &amp; cellValue.cnFormatForCSVFile(false);
			endif;
		endforeach;
		
		pFileObj.writeLine(csvRow);
	endforeach;
	
	return true;
epilog
	pFileObj.close();
end;</source>
        <Parameter name="pFileObj" type="File" usage="input"/>
        <Parameter name="pIsIncludeHeadings" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindAndUpdateRow" id="38f246b3-8b57-4e6d-82e1-ac195d44d837">
        <updating/>
        <source>cnEcFindAndUpdateRow(pRowObject:Object; pCellValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		25 July 2000	By: cnwdad1
//
// Purpose:		Searches for pTheObject and updates the row using the pCellValue parameter.
//
// Parameters:	pRowObject - The object to find.
//				pCellValue (String) - The value to update the cell with.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex	: Integer;
	currentRow	: Integer;
	isSelected	: Boolean;

begin
	currentRow	:=	self.row;
	isSelected	:=	self.cnEcIsRowSelected(currentRow);

	if self.cnEcFindObject(pRowObject, 2, 1) then
		rowIndex	:=	row;
		deleteRow(rowIndex);
		addItemAt(pCellValue, rowIndex);
		self.cnEcSetItemObject(rowIndex, 1, pRowObject);
	endif;

	row := currentRow;

	if isSelected then
		self.row	:=	currentRow;
		self.cnEcSelectRow();
	endif;
end;</source>
        <Parameter name="pRowObject" type="Object"/>
        <Parameter name="pCellValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindObject" id="b7000ae1-f318-4083-a68b-fa76f48f331d">
        <updating/>
        <source>cnEcFindObject(pCellObject:Object; pStartRow:Integer; pStartColumn:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		25 July 2000	By: cnwdad1
//
// Purpose:		Searches the itemObject property values of the table entries for the object
//				specified in the pTheObject parameter, starting with pStartRow and pStartCol.
//				If the specified object is found True is returned.
//
// Parameters:	pCellObject - The object to find.
//				pStartRow - The cell row number from which to start searching.
//				pStartColumn - The cell column number from which to start searching.
//
// Returns:		True if the object was found, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex	: Integer;
	columnIndex	: Integer;
	rowCount	: Integer;
	columnCount	: Integer;

begin
	rowIndex	:=	pStartRow;
	columnIndex	:=	pStartColumn;
	columnCount	:=	self.columns;
	rowCount	:=	self.rows;

	foreach columnIndex in 1 to columnCount do
		self.column	:=	columnIndex;

		foreach rowIndex in 1 to rowCount do
			self.row	:=	rowIndex;

			if (self.itemObject = pCellObject) then
				return true;
			endif;			
		endforeach;
	endforeach;

	return false;		
end;</source>
        <Parameter name="pCellObject" type="Object"/>
        <Parameter name="pStartRow" type="Integer"/>
        <Parameter name="pStartColumn" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindObjectCell" id="d6ec8c20-63e0-4d14-8f7c-9e6685b19d23">
        <updating/>
        <source>cnEcFindObjectCell(pCellObject:Object):JadeTableCell updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's cells and returns the first
//				JadeTableCell who's itemObject matches the pValue parameter.
//
// Parameters:	pCellObject - The object to search for.
//
// Returns:		The JadeTableCell for the (first) cell with a matching object, or
//				null if the object isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	columnIndex		: Integer;
	startRow		: Integer;
	startColumn		: Integer;
	rowCount		: Integer;
	columnCount		: Integer;
	tableCellObj	: JadeTableCell;
	
begin
	startRow	:=	self.fixedRows + 1;
	startColumn	:=	self.fixedColumns + 1;
	rowCount	:=	self.rows;
	columnCount	:=	self.columns;
	
	foreach rowIndex in startRow to rowCount do
		foreach columnIndex in startColumn to columnCount do
			tableCellObj	:=	self.accessCell(rowIndex, columnIndex);
			
			if tableCellObj.itemObject = pCellObject then
				return tableCellObj;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="pCellObject" type="Object"/>
        <ReturnType type="JadeTableCell"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindObjectColumn" id="0745cdb3-9abe-4f50-a5a1-673de9b29325">
        <updating/>
        <source>cnEcFindObjectColumn(pColObject:Object):JadeTableColumn updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's columns and returns the first
//				JadeTableColumn who's itemObject matches the pValue parameter.
//
// Parameters:	pColObject - The object to search for.
//
// Returns:		The JadeTableColumn for the (first) column with a matching object,
//				or null if the object isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columnIndex		: Integer;
	startColumn		: Integer;
	columnCount		: Integer;
	columnObj		: JadeTableColumn;
	
begin
	startColumn	:=	self.fixedColumns + 1;
	columnCount	:=	self.columns;
	
	foreach columnIndex in startColumn to columnCount do
		columnObj	:=	self.accessColumn(columnIndex);
			
		if columnObj.itemObject = pColObject then
			return columnObj;
		endif;
	endforeach;
end;</source>
        <Parameter name="pColObject" type="Object"/>
        <ReturnType type="JadeTableColumn"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindObjectRow" id="b41fa378-0f03-46fa-ad19-a604f3c2efa7">
        <updating/>
        <source>cnEcFindObjectRow(pRowObject:Object):JadeTableRow updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's rows and returns the first
//				JadeTableRow who's itemObject matches the pValue parameter.
//
// Parameters:	pRowObject - The object to search for.
//
// Returns:		The JadeTableRow for the (first) row with a matching object, or
//				null if the object isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	startRow		: Integer;
	rowCount		: Integer;
	tableRowObj		: JadeTableRow;
	
begin
	startRow	:=	self.fixedRows + 1;
	rowCount	:=	self.rows;
	
	foreach rowIndex in startRow to rowCount do
		tableRowObj	:=	self.accessRow(rowIndex);
			
		if tableRowObj.itemObject = pRowObject then
			return tableRowObj;
		endif;
	endforeach;
end;</source>
        <Parameter name="pRowObject" type="Object"/>
        <ReturnType type="JadeTableRow"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindObjectRowNo" id="8eda07f3-abc6-4166-ae57-380ea6b4fa8d">
        <updating/>
        <source>cnEcFindObjectRowNo(pRowObject:Object):Integer updating;
// --------------------------------------------------------------------------------
// Created:		16 April 2001 by cnwdad1
//
// Purpose:		Searches the itemObject property values for each JadeTableRow in
//				the table for the specified pTheObject parameter.  If the specified
//				object is found, then it's row number is returned.
//
// Parameters:	pRowObject - The object to find.
//
// Returns:		The row number where the object was found, or zero it it's not found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
//
// ****************************************************************************
// * NOTE THAT THIS METHOD ONLY USES THE "itemObject" PROPERTY OF THE TABLE's *
// * "JadeTableRow".  IT DOES NOT CHECK THE "itemObject" PROPERTY OF ANY      *
// * INDIVIDUAL TABLE CELLS.                                                  *
// ****************************************************************************
//
vars
	rowPointer	: Integer;
	tableRowObj	: JadeTableRow;
	startRow	: Integer;
	rowCount	: Integer;
	
begin
	rowCount	:=	self.rows;
	startRow	:=	self.fixedRows + 1;
	
	foreach rowPointer in startRow to rowCount do
		tableRowObj	:=	self.accessRow(rowPointer);
		
		if tableRowObj.itemObject = pRowObject then
			return rowPointer;
		endif;
	endforeach;
	
	return 0;
end;</source>
        <Parameter name="pRowObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindStringCell" id="0c5e7b7c-af03-4d7a-92a9-58b316033f56">
        <updating/>
        <source>cnEcFindStringCell(pValue:String):JadeTableCell updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's cells and returns the first
//				JadeTableCell who's text matches the pValue parameter.
//
// Parameters:	pValue - The string to search for.
//
// Returns:		The JadeTableCell for the (first) cell with text matching pValue,
//				or null if the string isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	columnIndex		: Integer;
	startRow		: Integer;
	startColumn		: Integer;
	rowCount		: Integer;
	columnCount		: Integer;
	tableCellObj	: JadeTableCell;
	
begin
	startRow	:=	self.fixedRows + 1;
	startColumn	:=	self.fixedColumns + 1;
	rowCount	:=	self.rows;
	columnCount	:=	self.columns;
	
	foreach rowIndex in startRow to rowCount do
		foreach columnIndex in startColumn to columnCount do
			tableCellObj	:=	self.accessCell(rowIndex, columnIndex);
			
			if tableCellObj.text = pValue then
				return tableCellObj;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="JadeTableCell"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindStringColumn" id="f7d1d782-7f86-48e5-ae18-7a826f1f0b75">
        <updating/>
        <source>cnEcFindStringColumn(pValue:String):JadeTableColumn updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's columns and returns the first
//				JadeTableColumn with a cell who's text matches the pValue parameter.
//
// Parameters:	pValue - The string to search for.
//
// Returns:		The JadeTableColumn for the (first) column with a cell with text
//				matching pValue, or null if the string isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	columnIndex		: Integer;
	startRow		: Integer;
	startColumn		: Integer;
	rowCount		: Integer;
	columnCount		: Integer;
	
begin
	startRow	:=	self.fixedRows + 1;
	startColumn	:=	self.fixedColumns + 1;
	rowCount	:=	self.rows;
	columnCount	:=	self.columns;
	
	foreach rowIndex in startRow to rowCount do
		foreach columnIndex in startColumn to columnCount do
			if self.getCellText(rowIndex, columnIndex) = pValue then
				return self.accessColumn(columnIndex);
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="JadeTableColumn"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindStringRow" id="f13b9cdb-36d6-454b-a431-bff174c95a9f">
        <updating/>
        <source>cnEcFindStringRow(pValue:String):JadeTableRow updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's rows and returns the first
//				JadeTableRow with a cell who's text matches the pValue parameter.
//
// Parameters:	pValue - The string to search for.
//
// Returns:		The JadeTableRow for the (first) row with a cell with text matching
//				pValue, or null if the string isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	columnIndex		: Integer;
	startRow		: Integer;
	startColumn		: Integer;
	rowCount		: Integer;
	columnCount		: Integer;
	
begin
	startRow	:=	self.fixedRows + 1;
	startColumn	:=	self.fixedColumns + 1;
	rowCount	:=	self.rows;
	columnCount	:=	self.columns;
	
	foreach rowIndex in startRow to rowCount do
		foreach columnIndex in startColumn to columnCount do
			if self.getCellText(rowIndex, columnIndex) = pValue then
				return self.accessRow(rowIndex);
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="JadeTableRow"/>
    </JadeMethod>
    <JadeMethod name="cnEcFirstColumn" id="12c532f5-1bc6-4180-81ca-6be38731ec0a">
        <source>cnEcFirstColumn():Integer;
// --------------------------------------------------------------------------------
// Created:		15 September 2006 by cnwdad1
//
// Purpose:		Returns the first column in the receiver that is not fixed.
//
// Parameters:	None
//
// Returns:		A pointer to the first non-fixed column.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colPointer	: Integer;
	
begin
	colPointer	:=	self.fixedColumns + 1;
	
	if colPointer &gt; self.columns then
		return 0;
	else
		return colPointer;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcFirstRow" id="e17a2cd5-f6ff-4b46-b714-920895b7d5de">
        <source>cnEcFirstRow():Integer;
// --------------------------------------------------------------------------------
// Created:		15 September 2006 by cnwdad1
//
// Purpose:		Returns the first row in the receiver that is not fixed.
//
// Parameters:	None
//
// Returns:		A pointer to the first non-fixed row.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.fixedRows + 1;
	
	if rowPointer &gt; self.rows then
		return 0;
	else
		return rowPointer;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetCellObject" id="fc9335bc-d8ca-4b69-b366-cc7f6e117de9">
        <updating/>
        <source>cnEcGetCellObject(pRow: Integer; pCol: Integer): Object updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 by cnwdad1
//
// Purpose:		Returns a cell object from the specified row and column, whilst
//				preserving the currently selected cell(s).
//
// Parameters:	pRow - The cell row number.
//				pColumn - The cell column.
//
// Returns:		The requested cell's itemObject (Object).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex	: Integer;
	columnIndex	: Integer;
	cellObject	: Object;

begin
	rowIndex	:=	self.row;
	columnIndex	:=	self.column;
	cellObject	:=	self.cnEcGetItemObject(pRow, pCol);
	self.row	:=	rowIndex;
	self.column	:=	columnIndex;
	
	return cellObject;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCol" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetItemObject" id="47498ac1-5255-4e3d-82c3-ed6eed52b681">
        <updating/>
        <source>cnEcGetItemObject(pRow: Integer; pCol: Integer): Object updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 - cnEcGetItemObject
// By:			cnwdad1
//
// Purpose:		Returns a cell object from the specified row and column.
//
// Parameters:	pRow - The cell row number.
//				pColumn - The cell column.
//
// Returns:		itemObject (Object)
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if (pRow &gt; 0) and (pRow &lt;= self.rows) and (pCol &gt; 0) and (pCol &lt;= self.columns) then
		self.row	:=	pRow;
		self.column	:=	pCol;
		return self.itemObject;
	endif;

	return null;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCol" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetRowObject" id="6867fd84-70a3-41d2-afac-5986ebbe21ff">
        <source>cnEcGetRowObject():Object;
// --------------------------------------------------------------------------------
// Created:		06 October 2001 by cnwdad1
//
// Purpose:		Returns the itemObject of the JadeTableRow for the receiver's
//				currently selected row.
//
// Parameters:	None
//
// Returns:		The object for currently selected row.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	theObject	: Object;
	currentRow	: Integer;
	tableRowObj	: JadeTableRow;
	
begin
	tableObj	:=	self;
	currentRow	:=	self.row;
	
	if currentRow &gt; tableObj.fixedRows and currentRow &lt;= tableObj.rows then
		tableRowObj	:=	tableObj.accessRow(currentRow);
		theObject	:=	tableRowObj.itemObject;
	else
		theObject	:=	null;
	endif;
epilog
	return theObject;
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetRowString" id="e26525e3-5d4e-468c-9e67-c0aafa7a55bc">
        <source>cnEcGetRowString(pRowPointer:Integer):String;
// --------------------------------------------------------------------------------
// Created:		21 December 2007 by cnwdad1
//
// Purpose:		Returns a tab-delimited string of the specified row.
//
// Parameters:	pRowPointer - The row number to get the string for.
//
// Returns:		The tab-delimited row string, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowString	: String;
	cellText	: String;
	colPointer	: Integer;
	colCount	: Integer;
	isFirst		: Boolean;
	
begin
	colCount	:=	self.columns;
	isFirst		:=	true;
	
	foreach colPointer in 1 to colCount do
		cellText	:=	self.getCellText(pRowPointer, colPointer);
		
		if isFirst then
			rowString	:=	cellText;
			isFirst			:=	false;
		else
			rowString	:=	rowString &amp; Tab &amp; cellText;
		endif;
	endforeach;
	
	return rowString;
end;</source>
        <Parameter name="pRowPointer" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsInScrollZone" id="e9719bfc-b988-470d-91a7-9de83bc893c1">
        <source>cnEcIsInScrollZone(pXPos:Real; pYPos:Real; pBorder:Integer output):Boolean;
// --------------------------------------------------------------------------------
// Created:		19 May 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified coordinates
//				are within an estimated scroll zone, i.e. within a certain distance
//				from the edge of the receiver.
//
// Parameters:	pXPos - The x coordinate.
//				pYPos - The y coordinate.
//				pBorder - Returns a value indicating which border the coordinates
//					are near.
//
// Returns:		True if the coordinate is near the scroll zone, otherwise false.
//				The output parameter indicates which border the coordinates are near.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ScrollMargin	: Integer = 25;
	
begin
	if pXPos &lt;= ScrollMargin then
		pBorder	:=	self.CNEC_LEFT;
		return true;
	elseif pYPos &lt; ScrollMargin then
		pBorder	:=	self.CNEC_TOP;
		return true;
	endif;
	
	if pXPos &gt;= (self.clientWidth - ScrollMargin) then
		pBorder	:=	self.CNEC_RIGHT;
		return true;
	elseif pYPos &gt;= (self.clientHeight - ScrollMargin) then
		pBorder	:=	self.CNEC_BOTTOM;
		return true;
	endif;
	  
	return false;
end;</source>
        <Parameter name="pXPos" type="Real"/>
        <Parameter name="pYPos" type="Real"/>
        <Parameter name="pBorder" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsRowSelected" id="d627c3ff-6d3e-46da-8970-8e91c3ffd74f">
        <source>cnEcIsRowSelected(pRow:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		25 July 2000	By: cnwdad1
//
// Purpose:		Returns a flag to indicate whether the requested row is selected.
//
// Parameters:	pRow (Integer) - The cell row number.
//
// Returns:		True if the row is selected, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columnPointer	: Integer;
	columnCount		: Integer;

begin
	columnCount	:=	self.columns;

	foreach columnPointer in 1 to columnCount do
		if getCellSelected(pRow, columnPointer) then
			return true;
		endif;
	endforeach;

	return false;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsValidColumn" id="7880236e-993b-4730-8284-b2a52dc004db">
        <source>cnEcIsValidColumn(pColPointer:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		29 June 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified column is
//				a valid one.  Fixed columns are not considered valid, since useful
//				information is not normally stored in fixed columns.
//
// Parameters:	pColPointer - The index if the table column in question.
//
// Returns:		True if the column is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (pColPointer &gt; self.fixedColumns and pColPointer &lt;= self.columns);
end;</source>
        <Parameter name="pColPointer" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsValidRow" id="ea184622-ca40-427b-865e-eb00ada55581">
        <source>cnEcIsValidRow(pRowPointer:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		29 June 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified row is a
//				valid one.  Fixed rows are not considered valid, since useful
//				information is not normally stored in fixed rows.
//
// Parameters:	pRowPointer - The index if the table row in question.
//
// Returns:		True if the row is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (pRowPointer &gt; self.fixedRows and pRowPointer &lt;= self.rows);
end;</source>
        <Parameter name="pRowPointer" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcLastVisibleRow" id="334dde4d-4832-4b07-a3ac-0b5b19800fdb">
        <source>cnEcLastVisibleRow():Integer;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Returns a pointer to the last row of the receiver that is currently
//				visible.
//
// Parameters:	None
//
// Returns:		The number of the last visible row.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	// The Number of pixels that must be visible before we say the row is visible.
	NUM_PIXELS_CUTTOFF	: Real = 6;
	
vars
	pageHeight	: Real;
	verticalPos	: Real;
	rowPointer	: Integer;
	
begin
	pageHeight	:=	clientHeight;
	rowPointer	:=	1;
	
	while rowPointer &lt;= fixedRows do
		if rowVisible[rowPointer] then
			pageHeight	:=	pageHeight - rowHeight[rowPointer];
		endif;
		
		rowPointer	:=	rowPointer + 1;
	endwhile;

	rowPointer	:=	topRow;

	// Scan down the column to find the appropriate row.
	while true do
		if rowPointer &gt; rows then
			break;
		endif;
		
		if rowVisible[rowPointer] then
			verticalPos	:=	verticalPos + rowHeight[rowPointer];
		endif;
		
		if pageHeight &lt;= verticalPos then
			if (verticalPos - pageHeight) &lt; NUM_PIXELS_CUTTOFF then
				// We can see less than the top NUM_PIXELS_CUTTOFF pixels of the row so step back one.
				rowPointer	:=	rowPointer - 1;
			endif;
			
			break;
		else
			// Increment the row.
			rowPointer	:=	rowPointer + 1;
		endif;
	endwhile; 

	if rowPointer &gt; rows then
		rowPointer	:=	rows;
	endif;

	return rowPointer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcPrintReport" id="c969527e-be12-4db4-81d5-a7dd4111c8a4">
        <updating/>
        <source>cnEcPrintReport(pHeading1:String; pHeading2:String; pIsLandscape: Boolean; pIsPreview:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		Prints the receiver as a report, in landscape.
//
// Parameters:	pHeading1 - The primary heading of the report.
//				pHeading2 - The secondary heading of the report.
//				pIsLandscape - True if the report should be printed in landscape.
//				pIsPreview - True if a print preview is required.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	printFormObj	: CnEcPrintTableForm;
	timeNow			: TimeStamp;
	
begin
	app.mousePointer	:=	Busy;
	
	create printFormObj transient;
//	printFormObj.whiteBackground	:=	_whiteBG;
	app.printer.printPreview		:=	pIsPreview;
	
	if pIsLandscape then
		app.printer.setMargins(Print_Landscape, 0, 0, 10, 10);
	else
		app.printer.setMargins(Print_Portrait, 0, 0, 10, 10);
	endif;
	
	printFormObj.fraHeader.width		:=	app.printer.pageWidth;
	printFormObj.setHeaders(pHeading1, pHeading2);
	printFormObj.fraFooter.width		:=	app.printer.pageWidth;
	printFormObj.lblUserName.caption	:=	"User: " &amp; app.userName();
	printFormObj.lblUserName.cnEcCenterOnParentHorizontal();
	printFormObj.lblDatePrinted.caption	:=	timeNow.String;
//	printFormObj.isOrigTableColumnWidths	:=	_useOrigTableColumnWidths;

	app.printer.setHeader(printFormObj.fraHeader);
	app.printer.setFooter(printFormObj.fraFooter);
	
	printFormObj.printTable(self, pIsLandscape, null);
	
	app.printer.close();
epilog
	delete printFormObj;
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="pHeading1" type="String"/>
        <Parameter name="pHeading2" type="String"/>
        <Parameter name="pIsLandscape" type="Boolean"/>
        <Parameter name="pIsPreview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcRemoveObjectRow" id="4b691a96-0eac-46ee-9ebf-0128c1b33543">
        <updating/>
        <source>cnEcRemoveObjectRow(pObject:Object):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Removes the row containing the specified object.
//
// Parameters:	pObject - A reference to the object who's row to remove.
//
// Returns:		True if the remove was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	rowPointer	:=	self.cnEcFindObjectRowNo(pObject);
	
	if rowPointer &lt;&gt; CNEC_NULL_INDEX then
		self.removeItem(rowPointer);
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcResort" id="c7a72a84-b062-4704-b157-da60bdf680a3">
        <source>cnEcResort(pColumnList:ParamListType; pIsAscending:Boolean; pIsCased:Boolean):Boolean;
// --------------------------------------------------------------------------------
// Created:		24 May 2007 by cnwdad1
//
// Purpose:		Sorts up to six of the receiver's columns.
//
// Parameters:	pColumnList - The list of columns (integer indexes) to sort.  The
//					first will be for sort column 1, the second for sort column 2, etc.
//				pIsAscending - True if the sort is in ascending order, otherwise false.
//				pIsCased - True if the sort is case-sensitive, otherwise false.
//
// Returns:		True if the table was successfully sorted, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MAX_SORT_COLS	: Integer = 6;
	
vars
	paramCount		: Integer;
	paramPointer	: Integer;
	colPointer		: Integer;
	
begin
	paramCount	:=	app.getParamListTypeLength(pColumnList);
	
	if paramCount &lt; 1 or paramCount &gt; MAX_SORT_COLS then
		return false;
	endif;
	
	foreach paramPointer in 1 to paramCount do
		colPointer	:=	app.getParamListTypeEntry(paramPointer, pColumnList).Integer;
		self.sortColumn[paramPointer]	:=	colPointer;
		self.sortAsc[paramPointer]		:=	pIsAscending;
		self.sortCased[paramPointer]	:=	pIsCased;
	endforeach;
	
	self.resort();
	
	return true;
end;</source>
        <Parameter name="pColumnList" type="ParamListType"/>
        <Parameter name="pIsAscending" type="Boolean"/>
        <Parameter name="pIsCased" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcScrollMe" id="40c0a784-4ea2-473a-ac84-ddf776ef1461">
        <updating/>
        <source>cnEcScrollMe(pIsDown:Boolean; pIsPage:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		19 May 2006 by cnwdad1
//
// Purpose:		Scrolls the receiver.
//
// Parameters:	pIsDown - True if the receiver is to scroll down, otherwise it will
//					scroll up.
//				pIsPage - True if the receiver is to scroll one whole page, otherwise
//					the receiver will scroll just one row.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	scrollSize	: Integer;
	newTopPos	: Integer;
	rowsPerPage	: Integer;
	
begin
	//rowsPerPage	:=	self.clientHeight() div self.defaultRowHeight;
	rowsPerPage	:=	self.cnEcLastVisibleRow() - (self.topRow - 1);
	
	if pIsPage then
		scrollSize	:=	rowsPerPage;
	else
		scrollSize	:=	1;
	endif;
	
	if pIsDown then
		newTopPos	:=	self.topRow + scrollSize;
		
		if newTopPos &gt; self.rows then
			newTopPos	:=	self.rows - rowsPerPage;
		endif;
	else
		newTopPos	:=	self.topRow - scrollSize;
		
		if newTopPos &lt; 1 then
			newTopPos	:=	1;
		endif;
	endif;
	
	self.topRow	:=	newTopPos;
end;</source>
        <Parameter name="pIsDown" type="Boolean"/>
        <Parameter name="pIsPage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSelectAllRows" id="946de9fb-fa9e-4a14-9b57-d67605529bd4">
        <updating/>
        <source>cnEcSelectAllRows() updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad1
//
// Purpose:		This method will set all rows in the receiver to selected.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowCount			: Integer;
	rowPointer			: Integer;
	columnCount			: Integer;
	columnPointer		: Integer;
	firstNonFixedRow	: Integer;
	firstNonFixedColumn	: Integer;

begin
	firstNonFixedRow	:=	self.fixedRows + 1;
	rowCount			:=	self.rows;
	firstNonFixedColumn	:=	self.fixedColumns + 1;
	columnCount			:=	self.columns;
	
	foreach rowPointer in firstNonFixedRow to rowCount do
		foreach columnPointer in firstNonFixedColumn to columnCount do
			self.setCellSelected(rowPointer, columnPointer, true);	
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcSelectRow" id="99102eb2-9c21-4a1a-a329-9bb558d6713d">
        <updating/>
        <source>cnEcSelectRow() updating;
// --------------------------------------------------------------------------------
// Created:		19 April 1999 - cnEcSelectRow
// By:			cnwdad1
//
// Purpose:		This method will select all columns for the receiver's current row.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columnPointer		: Integer;
	columnCount			: Integer;
	firstNonFixedColumn	: Integer;

begin
	self.clearAllSelected;
	columnCount			:=	self.columns;
	firstNonFixedColumn	:=	self.fixedColumns + 1;

	if (self.row &gt; self.fixedRows) then
		foreach columnPointer in firstNonFixedColumn to columnCount do
			self.setCellSelected(self.row, columnPointer, true);	
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcSetCellBackColor" id="3a7add7a-c4f7-4720-a6a6-32c60a732b39">
        <updating/>
        <source>cnEcSetCellBackColor(pRow:Integer; pColumn:Integer; pColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 1999 - cnEcSetCellBackColor
// By:			cnwdad1
//
// Purpose:		Assigns the specified backcolor to a cell for the specified row and column.
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//				pColor (Integer) - The colour to assign to the cell's backcolor.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cRow	: Integer;
	cColumn	: Integer;
	mode	: Integer;

begin
	mode			:=	self.accessMode;
	self.accessMode	:=	Table.AccessMode_Cell;
	cRow			:=	self.row;
	cColumn			:=	self.column;
	self.row		:=	pRow;
	self.column		:=	pColumn;
	self.backColor	:=	pColor;
	self.row		:=	cRow;
	self.column		:=	cColumn;
	self.accessMode	:=	mode;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pColumn" type="Integer"/>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetCellForeColor" id="ac4f55bd-6051-42d4-a632-8a7fe25b3d8e">
        <updating/>
        <source>cnEcSetCellForeColor(pRow:Integer; pColumn:Integer; pColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 - cnEcSetCellForeColor
// By:			cnwdad1
//
// Purpose:		Assigns the specified forecolor to a cell for the specified row and column.
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//				pColor (Integer) - The colour to assign to the cell's forecolor.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cRow	: Integer;
	cColumn	: Integer;
	mode	: Integer;

begin
	mode			:=	self.accessMode;
	self.accessMode	:=	Table.AccessMode_Cell;
	cRow			:=	self.row;
	cColumn			:=	self.column;
	self.row		:=	pRow;
	self.column		:=	pColumn;
	self.foreColor	:=	pColor;
	self.row		:=	cRow;
	self.column		:=	cColumn;
	self.accessMode	:=	mode;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pColumn" type="Integer"/>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetCellObject" id="bab259a0-c668-4fc5-ba58-f9c3ab5d4087">
        <updating/>
        <source>cnEcSetCellObject(pRow:Integer; pColumn:Integer; pObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 - cnEcSetCellObject
// By:			cnwdad1
//
// Purpose:		Assigns the specified object to a cell for the specified row and
//				column, whilst preserving the currently selected cell(s).
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//				pObject (Object) - The object to assign to the cell.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cRow	: Integer;
	cColumn	: Integer;

begin
	cRow		:=	self.row;
	cColumn		:=	self.column;
	self.row	:=	pRow;
	self.column	:=	pColumn;
	self.cnEcSetItemObject(pRow, pColumn, pObject);
	self.row	:=	cRow;
	self.column	:=	cColumn;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pColumn" type="Integer"/>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetColumnWidths" id="869c9170-05da-4ee2-9c4a-82692267d401">
        <updating/>
        <source>cnEcSetColumnWidths(pColumnWidthArray:IntegerArray) updating;
// --------------------------------------------------------------------------------
// Created:		13 May 2000 by cnwdad1
//
// Purpose:		Sets the widths of the table's columns.
//
// Parameters:	pColumnWidthArray (IntegerArray) - An array of width percentages.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/*
	Each column's width will be set as a percentage of the
	table's overall width.  The column's width percentages
	should be specified sequentially as subscripts of the
	"pColumnWidthArray" array.
*/
vars
	saveAccessMode	: Integer;
	colWidth		: Integer;
	colIndex		: Integer;
	colCount		: Integer;
	tableColumns	: Integer;

begin
	if pColumnWidthArray = null or pColumnWidthArray.size() = 0 then
		return;
	endif;

	// First, count the number of visible columns, then work out a
	// default (average) width based upon that number of columns.

	saveAccessMode	:=	self.accessMode;
	self.accessMode	:=	Table.AccessMode_Column;
	colIndex		:=	1;
	tableColumns	:=	self.columns;

	foreach colIndex in 1 to tableColumns do
		if self.columnVisible[colIndex] then
			colCount := colCount + 1;
		endif;
	endforeach;

	colWidth	:=	self.width.Integer div colCount;	// Average the width;

	// Now set the column width(s).

	colCount	:=	self.columns;
	colIndex	:=	1;

	foreach colIndex in 1 to colCount do
		if colIndex &lt;= pColumnWidthArray.size() and self.columnVisible[colIndex] then
			colWidth := pColumnWidthArray[colIndex];

			if colWidth = 0 then
				self.columnWidth[colIndex] := colWidth;		// Use the default width.
			else
				self.columnWidth[colIndex] := ((colWidth * self.width.Integer) / 100).Integer;
			endif;
		endif;
	endforeach;

epilog
	self.accessMode := saveAccessMode;	// Restore the original accessMode.
end;</source>
        <Parameter name="pColumnWidthArray" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetItemObject" id="f7b4f21b-95d6-4a32-899a-70b2cf303265">
        <updating/>
        <source>cnEcSetItemObject(pRow:Integer; pColumn:Integer; pObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 - cnEcSetItemObject
// By:			cnwdad1
//
// Purpose:		Assigns the specified object to a cell for the specified row and column.
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//				pObject (Object) - The object to assign to the cell.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (pRow &gt; 0) and (pRow &lt;= self.rows) and (pColumn &gt; 0) and (pColumn &lt;= self.columns) then
		self.row		:=	pRow;
		self.column		:=	pColumn;
		self.itemObject	:=	pObject;
	endif;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pColumn" type="Integer"/>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetSelectedForObject" id="3be1e261-4468-4c98-b2e8-f46adaf9a1c8">
        <updating/>
        <source>cnEcSetSelectedForObject(pObject:Object):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		30 November 2007 by cnwdad1
//
// Purpose:		Sets the currently selected row to the row which contains the specified
//				object.  If no table contains the object reference, then no rows will
//				be selected.
//
// Parameters:	pObject - A reference to the object to find and select.
//
// Returns:		True if the row was successfully selected, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowObj	: JadeTableRow;
	
begin
	rowObj	:=	self.cnEcFindObjectRow(pObject);
	
	if rowObj &lt;&gt; null then
		rowObj.selected	:=	true;
		self.topRow		:=	rowObj.row;
	else
		self.clearAllSelected();
		return false;
	endif;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetSortAsc" id="ee4dd8ff-2aa1-42d2-8d42-26f5b9c4f506">
        <source>cnEcSetSortAsc(pSortOptionList:ParamListType):Boolean;
// --------------------------------------------------------------------------------
// Created:		24 May 2007 by cnwdad1
//
// Purpose:		Sets the sortAsc property for up to six of the receiver's columns.
//
// Parameters:	pSortOptionList - The list of boolean sort options to set, where true
//					will sort ascending and false will sort descending.  The first
//					will be for column 1, the second for column 2, etc.
//
// Returns:		True if the sort options are successfully set, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MAX_SORT_COLS	: Integer = 6;
	
vars
	paramCount		: Integer;
	paramPointer	: Integer;
	sortOption		: Boolean;
	
begin
	paramCount	:=	app.getParamListTypeLength(pSortOptionList);
	
	if paramCount &lt; 1 or paramCount &gt; MAX_SORT_COLS then
		return false;
	endif;
	
	foreach paramPointer in 1 to paramCount do
		sortOption	:=	app.getParamListTypeEntry(paramPointer, pSortOptionList).Boolean;
		self.sortAsc[paramPointer]	:=	sortOption;
	endforeach;
	
	return true;
end;</source>
        <Parameter name="pSortOptionList" type="ParamListType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetSortCased" id="56f24a14-0a98-4927-82ea-91fbc471a8c3">
        <source>cnEcSetSortCased(pSortOptionList:ParamListType):Boolean;
// --------------------------------------------------------------------------------
// Created:		24 May 2007 by cnwdad1
//
// Purpose:		Sets the sortCased property for up to six of the receiver's columns.
//
// Parameters:	pSortOptionList - The list of boolean sort options to set, where true
//					will sort case-sensitive and false will sort case-insensitive.
//					The first will be for column 1, the second for column 2, etc.
//
// Returns:		True if the sort options are successfully set, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MAX_SORT_COLS	: Integer = 6;
	
vars
	paramCount		: Integer;
	paramPointer	: Integer;
	sortOption		: Boolean;
	
begin
	paramCount	:=	app.getParamListTypeLength(pSortOptionList);
	
	if paramCount &lt; 1 or paramCount &gt; MAX_SORT_COLS then
		return false;
	endif;
	
	foreach paramPointer in 1 to paramCount do
		sortOption	:=	app.getParamListTypeEntry(paramPointer, pSortOptionList).Boolean;
		self.sortCased[paramPointer]	:=	sortOption;
	endforeach;
	
	return true;
end;</source>
        <Parameter name="pSortOptionList" type="ParamListType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetSortTypes" id="dd76970a-e735-47fa-ba51-7ad662e0d00c">
        <source>cnEcSetSortTypes(pSortTypeList:ParamListType):Boolean;
// --------------------------------------------------------------------------------
// Created:		24 May 2007 by cnwdad1
//
// Purpose:		Sets the sortType property for up to six columns.
//
// Parameters:	pSortTypeList - The list of (integer) sort type codes to set.  The
//					first will be for column 1, the second for column 2, etc.
//
// Returns:		True if the sort types are successfully set, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MAX_SORT_COLS	: Integer = 6;
	
vars
	paramCount		: Integer;
	paramPointer	: Integer;
	sortTypeCode	: Integer;
	
begin
	paramCount	:=	app.getParamListTypeLength(pSortTypeList);
	
	if paramCount &lt; 1 or paramCount &gt; MAX_SORT_COLS then
		return false;
	endif;
	
	foreach paramPointer in 1 to paramCount do
		sortTypeCode	:=	app.getParamListTypeEntry(paramPointer, pSortTypeList).Integer;
		self.sortType[paramPointer]	:=	sortTypeCode;
	endforeach;
	
	return true;
end;</source>
        <Parameter name="pSortTypeList" type="ParamListType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
