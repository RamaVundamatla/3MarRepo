    <JadeMethod name="getDisplayDetails" id="233a909f-370a-4579-b719-e039d26dc78a">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.sequenceNum.String;
	else
		if self.invoice = null then
			return self.sequenceNum.String;
		else
		return self.sequenceNum.String&amp;' invoice='&amp;self.invoice.getDisplayDetails(false);
		endif;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="17f71d7c-0714-4bd9-a254-93bcc2d01830">
        <source> getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 11/11/2009	cnwmh5	PAR21548 - Change so that if tracked items operator is invalid doesn't cause a UE 4
// 07/04/2010	cnwjre1	PAR 23277 CCMS 1922 additional columns in Invoice Lines form
// 19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
// 10/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// 29/04/2013	cnwcs5	par 30652 - remove resynch/resynchObject method calls
// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 19 Dec 2016  cnwma1	TFS #3061:PAR38462 DPH - invoicing discrepancy (37624)
// 10 Mar 2017	cnwrs1	TFS3684 - dont fine the chgarge rate if there isn't a charge
// 20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)
// 11 Sep 2018 	jlgrh7 	TFS #40454 : POL - Re: [Request ID :##RE-8692##] : Rates in Jade
// 15 Nov 2018	jlgrh7 	TFS #41530 STWO - Sort on amount columns in Invoice list and invoice line list screens
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 20 Sep 2019	jlgdi1	46043 Added Bill of Lading On Transaction
// 03 Jun 2020  cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 02 Sep 2020  cnwma1  Bug 49996: ASPA - Voyage Group Code - Issues
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
// 19 Mar 2021  cnwma1  ChangeRequest 50925: ASPA - New Total Column in Invoice Form
// 28 Oct 2021  navma1  ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
// 16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link
// 03 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 31 Aug 2022	navpw1	TFS: 54564 (54383) - EUP - Inv Config - Debtor Currencies and Countries
// 13 Oct 2022  navmv20 ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
// 02 Feb 2023  navvt20 TFS CR 56132 Task 56136: UI - Invoice Line List - UOM
//21 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id
//20 Apr 2023 navmk20	Bug 57665: EUP - (Minor) - Imex Status copies differently
// 16/08/2023 jlika1	EUP | New Cargo Item Fields Allocation and Invoicing support
//29 Aug 2023 navhl20   Bug 59917: FR | EUP FR 54086 - Inv Contract - Invoice Line Indication if contract was used.
// 05/09/2023 navcs2	Bug 59959: EUP | TAS Invoicing - Invoice API doesn't match whats defined in API spec
// 12 October 2023 navmv20 Bug 60507: FR | 54089 - Invoice Contracts - Contract details on Invoice Items list
// 24 October 2023	navpw1	TFS 60965 - Made performance changes to increase speed of loading invoice lines.
										//	Removed else statements and put returns outside, moved isMeasurementType check to bottom, modified spacing and new lines
// ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1 - from this point these fields are calculated when the invoice is updated, as each invoice line is created. 
//																			An upgrade script might have taken many hours to convert all existing invoices, lines etc. 
//																			So this change will use a value if it is not null else it will derive the value, as it always has done.
// ### TFS DEFECT 63913 01MAY2024 NAVAB1 make financial amount use the thousand seperator.
// 16 September 2025  navhn30 MTN-35575: MTN | Invoice List External Ref 4
// ---------------------------------------------------------------------------




	// #########################################################
	// ###### WHEN ADDING ANY NEW ETROWS 
	// ###### YOU MUST ADD SAME ETROWS TO SAME METHOD ON CM_CASHPAYMENT
	// ######
	// ###### THIS MIGHT BE TO ADD TO THE LIST TO GET FROM CM_TRACKEDITEM
	// ###### THIS MIGHT MEAN ADDING THE NEW ROW TO THE PART THAT RETURNS NULL
	// ###### THIS MIGHT MEAN ADDING TO GET THE SIMILAR VALUE FROM THE CASH PAYMENT
	// #########################################################			






vars
	statusChangeAudit 	: CM_Audit;
	type 			  	: String;
	str					: String;	
	roundDecimalOpt		: Integer;
	currentInvoice		: CM_Invoice;
	currentTrackedItem	: CM_TrackedItem;
	transactionBOL		: CM_BOLTransaction;
	transactionTI		: CM_TITransaction;
	desc : String;
begin
	if _attrName = ETRow_DateTime  then
		if self.chargeTime.isValid then
			return self.systemToLocalTime(self.chargeTime).asStringJMT();//05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		return null;
		
	elseif _attrName = ETRow_LineTotalAmount  then // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
			return self.totalAmount.asStringJMTWithPrecision(2,true); // static  ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
	elseif _attrName = ETRow_LineTotalRate  then // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
		return self.totalRate.asStringJMTWithPrecision(2,true); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
	elseif _attrName = ETRow_Status  then
		return self.getStatusDescription(self.status);
		
	elseif _attrName = ETRow_Length then
		return self.trackedItemLength.asStringJMTWithPrecision(2,false); // PAR 31615
		
	elseif _attrName = ETRow_LineTotal then								
		return self.lineTotal.asStringJMTWithPrecision(2, true);         // TFS 42409 
	elseif _attrName = ETRow_Rate then
		return self.zzGetRateStr(); // ### TFS CR 63369 TASK 63371 10APR2024 NAVAB1
	elseif _attrName = ETRow_Narration
	or  _attrName = ETRow_Narration200			//28.10.2021 navma1 #52163
	or  _attrName = ETRow_Narration300  then	// par 24035 narration length to 300
		return self.zzGetNarration();
		
	elseif _attrName = ETRow_Bank then
		return  self.bank.code;
		
	// ### TFS 60965 26Oct2023 NAVPW1 - Missing ETRow's
	elseif _attrName = ETRow_Quantity then
		return self.quantity.String;
		
	elseif _attrName = ETRow_Sequence then
		return self.sequenceNum.String;
		
	elseif _attrName = ETRow_QuantityNoMinMax then
		return self.quantityNoMinMax.String;
		
	// ### TFS 60965 26Oct2023 NAVPW1 - Missing ETRow's
	
	elseif _attrName = ETRow_Items  then
		return null;
		
	elseif _attrName = ETRow_InvoiceTypeCode  then
		return self.zzGetInvoiceTypeCode();
		
	elseif _attrName = ETRow_Ti  then
		return self.zzGetTiDetails();
		
	elseif _attrName = ETRow_Remarks300 then	// ### JIRA 33007 03DEC2024 NAVAB1
		return self.remarks;
// ### JIRA 33007 03DEC2024 NAVAB1	elseif _attrName = ETRow_Remarks then //Par 18659. Dec 2008 TRACKED ITEM REMARKS
// ### JIRA 33007 03DEC2024 NAVAB1		return self.zzGetTIRemarks();
	elseif _attrName = ETRow_RemarksCargo then //Par 18659. Dec 2008 TRACKED ITEM REMARKS
		return self.zzGetTIRemarks();
	elseif _attrName = ETRow_Terminal  then
		return self.zzGetTerminalCode();
		
	elseif _attrName = ETRow_EscalatingDays then	// CCMS 1279	
		return self.escalatingDays.String;
		
	elseif _attrName = ETRow_TranDeleted  then // PAR 20155
		return self.zzGetTransDeleted();
		
	elseif _attrName = ETRow_Transaction  then
		return self.getTransactionColumnDisplay();	//20 Mar 2019	NLD	TFS 43882
		
	elseif _attrName = ETRow_Description  then
		// ### JIRA 33007 03DEC2024 NAVAB1
		desc := self.invoiceLineDesc.narration;
		return desc;
		
	elseif _attrName = ETRow_DebtorCode  or _attrName = ETRow_Debtor then   //03/06/2020 cnwma1 TFS #49400
		return self.zzGetDebtorName();
		
	elseif _attrName = ETRow_EndDT  then	
		return self.systemToLocalTime(self.chargeTime).shortCurrentLocaleFormat();// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	elseif _attrName = ETRow_Overridden  then
		return overriddenChargeCount.String &amp; '  ';
		
	elseif _attrName = ETRow_SeqNumInvoice  then
		return self.zzGetSeqNumInvoice();
		
	elseif _attrName = ETRow_InvoiceLineNumber then	//18 May 2021	NDL	TFS 51194
		return self.sequenceNum.String;
		
	//FD For ccms 1107 : Add one more column for transport mode
	elseif _attrName = ETRow_RecMode  then
		return self.zzGetReceiptTransportMode();
		
	elseif _attrName = ETRow_DebtorConsol  then
		return self.zzGetDebtorConsol();
		
	elseif _attrName = ETRow_Operator then
		return self.zzGetOperator();

	elseif _attrName = ETRow_FreightForwarder then
		return self.zzGetFreightForwarderDesc();

	elseif _attrName = ETRow_Consignor  then
		return self.zzGetConsignorDesc();
		
	elseif _attrName = ETRow_Consignee  then
		return self.zzGetConsigneeDesc();

	elseif _attrName = ETRow_OperatorShip  then
		return self.zzGetShipOperatorDesc();
		
	elseif _attrName = ETRow_CustomsAgent  then
		return self.zzGetCustomsAgentName();
		
	elseif _attrName = ETRow_Voyage then		
		return self.zzGetVoyageCode();
		
	elseif _attrName = ETRow_ImexStatus then					// PAR #20778 
		return self.zzGetImexStatusDesc();
		
	// #########################################################
	// ###### WHEN ADDING ANY NEW ETROWS THAT GET DATA FROM TRACKEDITEM
	// ###### YOU MUST ADD SAME ETROWS TO SAME METHOD ON CM_CASHPAYMENT
	// #########################################################			
	elseif _attrName = ETRow_ReceivedDT or					// PAR #20778 
		   _attrName = ETRow_ReleasedDT or
		   _attrName = ETRow_DischargePort or
		   _attrName = ETRow_IsoType or
		   _attrName = ETRow_ReleaseDT or 				// ### TFS 60965 01Nov2023 NAVPW1
		   _attrName = ETRow_CargoIsTranship or			// ### TFS 60965 01Nov2023 NAVPW1
		   _attrName = ETRow_ImportVoyageCode or		// ### TFS 60965 01Nov2023 NAVPW1
		   _attrName = ETRow_ClientRef or				// ### TFS 60965 01Nov2023 NAVPW1
		   // ### TFS 60965 01Nov2023 NAVPW1
		   _attrName = ETRow_RadioTelemetryState or
		   _attrName = ETRow_CustomExportStop or
		   _attrName = ETRow_TransferTerminalFrom or
		   _attrName = ETRow_TransferTerminalTo or
		   _attrName = ETRow_TimeInTransit or
		   _attrName = ETRow_Id or
		   _attrName = ETRow_MySubTerminal or
		   _attrName = ETRow_Mark or
		   _attrName = ETRow_MarkNumber or
		   _attrName = ETRow_LocationId or
		   _attrName = ETRow_Photos or
		   _attrName = ETRow_OperatorCode or
		   _attrName = ETRow_MyVoyage or
		   _attrName = ETRow_HasToDoTasks or
		   _attrName = ETRow_HasRemarks or
		   _attrName = ETRow_Damaged or
		   _attrName = ETRow_DamageDetail or
		   _attrName = ETRow_IsClean or
		   _attrName = ETRow_PreTripDate or
		   _attrName = ETRow_AvailabilityGradeCode or
		   _attrName = ETRow_AvailabilityGradeDescr or
		   _attrName = ETRow_MyPlannedLocation or
		   _attrName = ETRow_MyPrimaryQueuedLocation or
		   _attrName = ETRow_LoadOrderStr or
		   _attrName = ETRow_CargoTypeDescr or
		   _attrName = ETRow_FreightForwarderCode or
		   _attrName = ETRow_MyProduct or
		   _attrName = ETRow_TotalQuantity or
		   _attrName = ETRow_MyTranshipToPort or
		   _attrName = ETRow_DestinationPort or
		   _attrName = ETRow_BookingReference or
		   _attrName = ETRow_VoyageArrivalDate or
		   _attrName = ETRow_IsControlledAtmosphere or
		   _attrName = ETRow_Oxygen or
		   _attrName = ETRow_CarbonDioxide or
		   _attrName = ETRow_CustomsEntryNumber or
		   _attrName = ETRow_CustomExportEntryNumber or
		   _attrName = ETRow_ImportReleasePIN or
		   _attrName = ETRow_ExportReleaseNumber or
		   _attrName = ETRow_Humidity or
		   _attrName = ETRow_Ventilation or
		   _attrName = ETRow_SealNum or
		   _attrName = ETRow_SealNumShippers or
		   _attrName = ETRow_ReceiptTransportMode or
		   _attrName = ETRow_ReleasedTransportMode or
		   _attrName = ETRow_CutoffTS or
		   _attrName = ETRow_EarliestRecTS or
		   _attrName = ETRow_Commodity or
		   _attrName = ETRow_CommodityGroup or
		   _attrName = ETRow_IsoTypeGroup or
		   _attrName = ETRow_TransitStatus or
		   _attrName = ETRow_IsHazardous or
		   _attrName = ETRow_IsOverDimensions or
		   _attrName = ETRow_CouType or
		   _attrName = ETRow_CompanyCode or
		   _attrName = ETRow_Height or
		   _attrName = ETRow_Width or
		   _attrName = ETRow_Site or
		   _attrName = ETRow_PlannedSite or
		   _attrName = ETRow_PlannedState or
		   _attrName = ETRow_State or
		   _attrName = ETRow_IsSecureExport or
		   _attrName = ETRow_ConsignorVoyageCode or
		   _attrName = ETRow_Carrier or
		   _attrName = ETRow_Wagon or
		   _attrName = ETRow_ReleasedDT or
		   _attrName = ETRow_DeliveryRelease or
		   _attrName = ETRow_ReleaseCarrier or
		   _attrName = ETRow_ReleaseWagon or
		   _attrName = ETRow_MyCustomsAgent or
		   _attrName = ETRow_AlternativeId or
		   _attrName = ETRow_HouseBillOfLading or
		   _attrName = ETRow_IsAvailable or
		   _attrName = ETRow_ContentsStatus or
		   _attrName = ETRow_WashDT or
		   _attrName = ETRow_IsHeavyDuty or
		   _attrName = ETRow_PackedDT or
		   _attrName = ETRow_SealNumCustoms or
		   _attrName = ETRow_UnpackedDT or
		   _attrName = ETRow_MyBulkReleaseAssigned or
		   _attrName = ETRow_IsReefer or
		   _attrName = ETRow_IsConnected or
		   _attrName = ETRow_Temperature or
		   _attrName = ETRow_MonitorConnection or
		   _attrName = ETRow_RequiresPower or
		   _attrName = ETRow_RequiresTemperature or
		   _attrName = ETRow_LastConnectDT or
		   _attrName = ETRow_CoolingType or
		   _attrName = ETRow_VoltageType or
		   _attrName = ETRow_CurtainsIn or
		   _attrName = ETRow_PlanningState or
		   _attrName = ETRow_ReadyToShip or
		   _attrName = ETRow_IsTranshipItem or
		   _attrName = ETRow_DischargeJobNum or
		   _attrName = ETRow_DischSeqNumber or
		   _attrName = ETRow_LoadPort or
		   _attrName = ETRow_LoadSeqNumber or
		   _attrName = ETRow_LoadJobNum or
		   _attrName = ETRow_BillOfLading or
		   _attrName = ETRow_AllSpecialLifts or
		   _attrName = ETRow_MyTrainAssigned or
		   _attrName = ETRow_IntendedReleaseMode or
		   _attrName = ETRow_CustomsReference    or
		   _attrName = ETRow_ReceiveVoyage       or
		   _attrName = ETRow_ReleaseVoyage       or
		   _attrName = ETRow_IsWeightCertified   or
		   _attrName = ETRow_WeightDeclared      or
		   _attrName = ETRow_SpecialStow         or 
		   _attrName = ETRow_ReceiveStevedore    or      //02.10.2020 cnwma1 TFS #50112
		   _attrName = ETRow_ReleaseStevedore    or    //02.10.2020 cnwma1 TFS #50112
		   _attrName = ETRow_CargoShippingLineCode or		// Jun 3, 2022 navak20 TFS 53204
		   _attrName = ETRow_CargoShippingLineDesc or		// Jun 3, 2022 navak20 TFS 53204
		   _attrName = ETRow_Itemised or
		   _attrName = ETRow_SecondaryBarcodeId or
		   _attrName = ETRow_SortingMethod
		   // ### TFS 60965 01Nov2023 NAVPW1
	// #########################################################
	// ###### WHEN ADDING ANY NEW ETROWS THAT GET DATA FROM TRACKEDITEM
	// ###### YOU MUST ADD SAME ETROWS TO SAME METHOD ON CM_CASHPAYMENT
	// #########################################################			
	then
		currentTrackedItem	:= self.trackedItem;
		transactionBOL		:= self.myTransactionBOL;
		if currentTrackedItem &lt;&gt; null then
			return currentTrackedItem.getDisplayStringForInvoiceLine(_attrName, _short);
			
		elseif transactionBOL &lt;&gt; null then
			if _attrName = ETRow_HouseBillOfLading
			or _attrName = ETRow_BillOfLading
			then
				return self.getDisplayStringForTrans(_attrName, _short, transactionBOL);
			endif;
		endif;
		
		return null;
		
	elseif _attrName = ETRow_StatusInvoiceManual then					// PAR #20778 
		currentInvoice := self.invoice;
		if currentInvoice &lt;&gt; null then
			return self.getDisplayStringForInvoice(ETRow_Status, _short, currentInvoice);
		endif;
		
		return null;
		
	// par 23277 CCMS 1922 add all of the other CM_TrackedItem table rows
	elseif _attrName = ETRow_ToDoTaskComplete then				//+cnwml2 PAR24029
		currentTrackedItem := self.trackedItem;
		if currentTrackedItem &lt;&gt; null then
			return currentTrackedItem.getToDoTasksDisplay(currentTrackedItem.allToDoTasksCompleted, false);
		endif;
		
		return null;
		
	elseif _attrName = ETRow_CargoDescription then
		currentTrackedItem := self.trackedItem;
		if currentTrackedItem &lt;&gt; null then
			return currentTrackedItem.description;
		endif;
		
		return null;
		
	elseif _attrName = ETRow_StatusChangeReason then
		statusChangeAudit:=self.getLastStatusChangeAudit;
		
		if statusChangeAudit &lt;&gt; null then
			return statusChangeAudit.clearingRemarks;
		endif;
		
		return null;
		
	elseif _attrName = ETRow_StatusChangeReasonCode then
		statusChangeAudit:=self.getLastStatusChangeAudit; // TFS 57665
		
		if statusChangeAudit &lt;&gt; null then
			return statusChangeAudit.statusChangeReasonCode;
		endif;
		
		return null;
		
	elseif _attrName = ETRow_Exported then					//22.07.2019 cnwma1 TFS #45577
		return  app.getYesBlank(self.exportedCount &lt;&gt; 0);
		
	elseif _attrName = ETRow_ExportCount then				//22.07.2019 cnwma1 TFS #45577
		return self.exportedCount.String;
		
	elseif _attrName = ETRow_TransactionBOL then	// 	46043
		transactionTI	:= self.myTransactionTI;
		transactionBOL	:= self.myTransactionBOL;
		if transactionTI &lt;&gt; null then
			return transactionTI.billOfLading;
		elseif transactionBOL &lt;&gt; null then
			return self.getDisplayStringForTrans(_attrName, _short, transactionBOL);
		endif;
		
		return null;
		
	elseif _attrName = ETRow_VesselName  then                 //03/06/2020 cnwma1 Tfs #49400
		return self.zzGetVesselName();
		
	elseif _attrName = ETRow_VesselCode  then                //03/06/2020 cnwma1 Tfs #49400
		return self.zzGetVesselCode();
		
	elseif _attrName = ETRow_LineTotalRounded  then 	 //19.03.2020 cnwma1 TFS #50925
		if self.getMyTerminal &lt;&gt; null then
			roundDecimalOpt := self.getMyTerminal.getConfig(InvoiceRoundLineTotal).Integer;
		endif;
		return self.lineTotal.asStringJMTWithPrecision(roundDecimalOpt, true);
		
	elseif _attrName = ETRow_NumPayments then			//12 Aug 2019	NDL	TFS 44261
		return self.allCashPayments.size.asStringJMT;
		
	elseif _attrName = ETRow_VoyageGroupCode then		//03/06/2020 cnwma1 Bug #49400
		return self.getVoyageGroupCode();
		
	elseif _attrName = ETRow_WorkOrders		then		//16.12.2021 navma1 #52580
		return self.invoice.allWorkOrders.listString(Comma,CM_WorkOrder::id.name);
		
	// ### TFS 54564 (54383) 31Aug2022 NAVPW1
	elseif _attrName = ETRow_Locale then
		return self.zzGetLocaleDesc();
		
	elseif _attrName = ETRow_Currency then
		return self.zzGetCurrencyTypeCode();
	// ### TFS CR 62992 TASK 62994 08APR2024 NAVAB1
	elseif _attrName = ETRow_TaxCodeStatic then
		return self.taxCode;
	elseif _attrName = ETRow_TaxDescriptionStatic then
		return self.taxDescription;
	elseif _attrName = ETRow_TaxGLCodeStatic then
		return self.taxGLCode;
	elseif _attrName = ETRow_TaxRateStatic then
		return self.taxRates;
	elseif _attrName = ETRow_TaxValueStatic then
		return self.taxValue.asStringJMTWithPrecision(2,true);
	elseif _attrName = ETRow_TaxTotalStatic then
		return self.taxTotal.asStringJMTWithPrecision(2,true);

	// ### TFS 54564 (54383) 31Aug2022 NAVPW1
	//START - 13/10/2022 navmv20 TFS 55005
	elseif _attrName = ETRow_TaxCode then
		return self.getTaxCodesAsString(false);
	elseif _attrName = ETRow_TaxDescription then
		return self.getTaxDescriptionsAsString(false);
	elseif _attrName = ETRow_TaxGLCode then
		return self.getTaxGLCodesAsString(false);
	elseif _attrName = ETRow_TaxExtRef then
		return self.getTaxExtRef1AsString(false);
	elseif _attrName = ETRow_TaxRate then
		return self.getTaxRatesAsString(false);
	elseif _attrName = ETRow_TaxValue then
		return self.getTotalTaxAmountForLine().asStringJMTWithPrecision(2,true);// ### TFS BUG 64017 07MAY2024 NAVAB1;
	elseif _attrName = ETRow_TaxTotal then
		return self.getLineTotalWithTax().asStringJMTWithPrecision(2,true);// ### TFS BUG 64017 07MAY2024 NAVAB1;
	elseif _attrName = ETRow_TaxOverridden then
		return self.getIsOverriddenTax().getYesNo();
	//END - 13/10/2022 navmv20 TFS 55005
	elseif _attrName = ETRow_TaxOverriddenCount then // ### TFS 55435 25NOV2022 NAVAB1
		return self.overriddenTaxCount.String; // ### TFS 55435 25NOV2022 NAVAB1
	elseif _attrName = ETRow_UomCode then // 2 Feb 2023 navvt20 TFS 56136
		//return self.uomCode.String; // 2 Feb 2023 navvt20 TFS 56136
	//start //21.02.2023 navtnr20 TFS CR 55648 Task 55663
		return self.getUomCode;
	elseif	_attrName = ETRow_UomDescription then
		return self.getUomDescription;
	elseif	_attrName = ETRow_InvoiceContractId	then
		return self.contractId;	
	//end //21.02.2023 navtnr20 TFS CR 55648 Task 55663:
    elseif _attrName = ETRow_UsedContractCalcType then							//30.8.2023 navhl20 #59917
        return self.usedContractCalcType.getYesNo;
    elseif _attrName = ETRow_UsedContractRate then								//30.8.2023 navhl20 #59917
        return self.usedContractRate.getYesNo;
	elseif _attrName = ETRow_ExternalReference1 then							// 05/09/2023 navcs2 Bug 59959				
        return self.externalRef1;
	elseif _attrName = ETRow_ExternalReference2 then							// 05/09/2023 navcs2 Bug 59959	
        return self.externalRef2;
	elseif _attrName = ETRow_ExternalReference3 then							// 05/09/2023 navcs2 Bug 59959		
        return self.externalRef3;
	elseif _attrName = ETRow_ExternalReference4 then							// 16/09/2025 navhn30 MTN-35575	
        return self.externalRef4;
	//12/10/2023 navmv20 Bug 60507 - start
	elseif _attrName = ETRow_CalcTypeDesc then
		return self.zzGetCalcTypeDesc();
	elseif _attrName = ETRow_CalculationType then
		return self.zzGetCalcType();
		
		
	 // ### TFS BUG 63997 07MAY2024 NAVAB1
	elseif _attrName = ETRow_CalcTypeDescStatic then
		return self.calculationTypeDesc;
	elseif _attrName = ETRow_CalcTypeTypeStatic then
		return self.calculationTypeType;
	elseif _attrName = ETRow_TaxExtRefStatic then
		return self.taxExtRef;

		//12/10/2023 navmv20 Bug 60507 - end
	elseif _attrName.isMeasurementType then             //03/06/2020 cnwma1 TFS #49400
		_attrName.getRowNameMeasureType(str, type);									
		return self.getMeasurementStringForAttrib(str, type, _short);
	elseif _attrName = ETRow_TaxTotalTen then //15/05/2025	navkc1 JIRA EPIC-34131 STORY-34820
		return self.getLineTotalWithTaxTen().String; // Not using asStringJMT because we want 10 decimals
	elseif _attrName  = ETRow_LineTotalTen then //15/05/2025	navkc1 JIRA EPIC-34131 STORY-34820
		return self.getLineTotalTen().String;	// Not using asStringJMT because we want 10 decimals
	elseif _attrName = ETRow_TaxValueTen then	//15/05/2025	navkc1 JIRA EPIC-34131 STORY-34820 
		return self.getTotalTaxAmountForLineTen().String; // Not using asStringJMT because we want 10 decimals
	elseif _attrName = ETRow_QuantityTen then //15/05/2025	navkc1 JIRA EPIC-34131 STORY-34820
		return self.getLineQuantityTen().String; // Not using asStringJMT because we want 10 decimals
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForInvoice" id="b45d6058-044a-4b02-86df-d8961b9e471a">
        <source>getDisplayStringForInvoice(_attrName : String; _short : Boolean; _invoice : CM_Invoice) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023	navpw1	Initial creation TFS: 60965

*/

vars
	currentInvoice		: CM_Invoice;
	
begin
	currentInvoice := _invoice;
	
	if _attrName = ETRow_Status then
		return currentInvoice.getStatusDescription(currentInvoice.status);
		
	endif;
	
	app.raiseUnexpectedProgramError(self.class.name, method.name, "Field Not implemented: " &amp; _attrName &amp; " For CM_InvoiceLine");
	
	return null;
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForTrans" id="dbde5168-8b6d-49af-b743-6b78439cc788">
        <source>getDisplayStringForTrans(_attrName : String; _short : Boolean; _bolTransaction : CM_BOLTransaction) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023	navpw1	Initial creation TFS: 60965

*/

vars
	bolTransaction	: CM_BOLTransaction;
	bol				: CM_BOL;
	
begin
	bolTransaction := _bolTransaction;
	
	if ( _attrName = ETRow_HouseBillOfLading
		or _attrName = ETRow_BillOfLading 
		or _attrName = ETRow_TransactionBOL) 
	then	// 	46043
		bol := bolTransaction.myBOL;
		if bol &lt;&gt; null then
			return bol.number;
		endif;
		
		return null;
		
	endif;
	
	app.raiseUnexpectedProgramError(self.class.name, method.name, "Field Not implemented: " &amp; _attrName &amp; " For CM_InvoiceLine");
	
	return null;
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <Parameter name="_bolTransaction" type="CM_BOLTransaction"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getElapsedDays" id="fe2959f7-75d7-4bec-ba09-09230bb53009">
        <source>getElapsedDays(_chargeByUnits : Integer; _chargedDaysWorking : Boolean; _storageConfig : CM_StorageConfig; _chargedDaysWorkingAndComp : Boolean) : Real protected;
/*

Purpose:		For 

Parameters:			

Return Value:		


Date			Who		Reason
04 October 2012	cnwjre1	Initial creation
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	chargeByUnitsStart,
	chargeByUnitsEnd	: Integer;
	value	: Real;
	startTime	: TimeStamp;
	endTime	: TimeStamp;

begin
	// CCMS DPH 2278
	if self.myTransactionTI.isKindOf(CM_FutureStorage) then
		value := self.myTransactionTI.CM_FutureStorage.daysCharged;
	else
		chargeByUnitsStart := _chargeByUnits;
		chargeByUnitsEnd := _chargeByUnits;
		startTime := self.myTransactionTI.getStartDateTimeFSD(chargeByUnitsStart, _storageConfig);
		endTime := self.myTransactionTI.getEndDateTimeFSD(chargeByUnitsEnd, _storageConfig);
		value := self.bank.evaluateDaysCalendar(startTime, endTime, _chargedDaysWorking, _chargedDaysWorkingAndComp, self.myTransactionTI);
		app.invLog(method.qualifiedName &amp; " startTime=" &amp; startTime.String &amp; " endTime=" &amp; endTime.String &amp; " value=" &amp; value.String, LogINFO.String);
	endif;
	if value &lt; 0 then
		value := 0;
	endif;
	return value;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_chargeByUnits" type="Integer"/>
        <Parameter name="_chargedDaysWorking" type="Boolean"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
        <Parameter name="_chargedDaysWorkingAndComp" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
