    <JadeMethod name="doDeleteCargoCheckItem" id="c215be7d-e242-4a4b-859e-4de9f6f8d6fa">
        <updating/>
        <source>doDeleteCargoCheckItem() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/01/2010	cnwdap1	Initial creation CCMS 1071 General Cargo
*/
vars
	theForm 		: SOP_TableMaintForm;
	theTable		: CM_DataTable;
	idx				: Integer;
	rtnValue 		: Boolean;
	cargoCheckItem	: CM_CargoCheckItem;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	theForm 	:= self.myForm;
	theTable 	:= theForm.tblCheckItems;
	// do we have a current parent object of the right type?
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	if not theForm.myCurrentObject.isKindOf(CM_CargoCheck) then
		return;
	endif;
	
	// have we got a selected object?
	foreach idx in theTable.fixedRows + 1 to theTable.rows do
		if theTable.accessRow(idx).selected then
			cargoCheckItem := theTable.accessRow(idx).itemObject.CM_CargoCheckItem;
			break;
		endif;
	endforeach;
	if cargoCheckItem = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteCargoCheckItem(cargoCheckItem, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.doLoadItemsTable();
			break;
		else
			theResult := app.showErrorWarningDialog('Cargo Check Items', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	rtnValue := app.myPassport.trxCompletedOK;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEditCargoCheckItem" id="93d37423-aab7-4f8a-b41e-89fce544efa8">
        <source>doEditCargoCheckItem();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/01/2010	cnwdap1	Initial creation CCMS 1071 General Cargo
*/
vars
	theForm				: SOP_TableMaintForm;
	theTable			: CM_DataTable;
	cargoCheckItemForm 	: SOP_CargoCheckItemForm;
	cargoCheckItem		: CM_CargoCheckItem;
	modalResult, idx	: Integer;
	
begin
	theForm 	:= self.myForm;
	theTable	:= theForm.tblCheckItems;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	if not theForm.myCurrentObject.isKindOf(CM_CargoCheck) then
		return;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	
	foreach idx in theTable.fixedRows + 1 to theTable.rows do
		if theTable.accessRow(idx).selected then
			cargoCheckItem := theTable.accessedRow.itemObject.CM_CargoCheckItem;
			break;
		endif;
	endforeach;
	if cargoCheckItem = null then
		return;
	endif;
	
	cargoCheckItemForm := app.loadForm(SOP_CargoCheckItemForm, theForm.myAssistant.class, false, false, true, self.myForm.myTerminal, null).SOP_CargoCheckItemForm;
	if cargoCheckItemForm = null then
		return;
	endif;
	
	cargoCheckItemForm.init(theForm.myCurrentObject.CM_CargoCheck, cargoCheckItem);
	modalResult := cargoCheckItemForm.showModal;
	
	if modalResult = IDOK then
		self.doLoadItemsTable();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadItemsTable" id="eaaa7dbd-14f2-4899-805e-82d9cfbf42eb">
        <source>doLoadItemsTable();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2010	cnwdap1	Initial creation
*/
vars
	theForm 	: SOP_TableMaintForm;
	theTable	: CM_DataTable;
	idx			: Integer;
	cargoCheck	: CM_CargoCheck;
	item		: CM_CargoCheckItem;

begin
	theForm 		:= self.myForm;
	theTable		:= theForm.tblCheckItems;
	
	theTable.clearAllData;
	cargoCheck 		:= theForm.myCurrentObject.CM_CargoCheck;
	foreach item in cargoCheck.allCargoCheckItems discreteLock do	//31 May 2012	NDL Par 29038		
		theTable.addItemObject(item, item.getDisplayString);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveCargoCheckItem" id="86534e43-a953-41a5-b6af-d7f5d13dcd59">
        <source>doMoveCargoCheckItem(_up : Boolean);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars
	theForm 		: SOP_TableMaintForm;
	theTable		: CM_DataTable;
	rtnValue 		: Boolean;
	cargoCheckItems	: CM_CargoCheckItemSet;
	idx, movedBy	: Integer;
	selectedItem,
	item			: CM_CargoCheckItem;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	theForm 	:= self.myForm;
	theTable	:= theForm.tblCheckItems;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	if not theForm.myCurrentObject.isKindOf(CM_CargoCheck) then
		return;
	endif;

	if theTable.rows &lt;= 2 then
		return;
	endif;
	// trying to move the first line up
	if theTable.accessRow(theTable.fixedRows + 1).selected and _up then
		return;
	endif;
	// trying to move the last line down
	if theTable.accessRow(theTable.rows).selected and not _up then
		return;
	endif;
	
	foreach idx in theTable.fixedRows + 1 to theTable.rows do
		if theTable.accessRow(idx).selected then
			selectedItem := theTable.accessedRow.itemObject.CM_CargoCheckItem;
			break;
		endif;
	endforeach;
	if selectedItem = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxMoveCargoCheckItem(selectedItem, _up, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.doLoadItemsTable();
			break;
		else
			theResult := app.showErrorWarningDialog('Cargo Check Item', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete cargoCheckItems;
end;</source>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNewCargoCheckItem" id="66cf7cd6-9110-4358-bf0d-53f3555d6435">
        <source>doNewCargoCheckItem();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars
	theForm				: SOP_TableMaintForm;
	cargoCheckItemForm 	: SOP_CargoCheckItemForm;
	modalResult 		: Integer;
	
begin
	theForm := self.myForm;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	if not theForm.myCurrentObject.isKindOf(CM_CargoCheck) then
		return;
	endif;

	cargoCheckItemForm := app.loadForm(SOP_CargoCheckItemForm, theForm.myAssistant.class, false, false, true, self.myForm.myTerminal, null).SOP_CargoCheckItemForm;
	if cargoCheckItemForm = null then
		return;
	endif;
	
	cargoCheckItemForm.init(theForm.myCurrentObject.CM_CargoCheck, null);
	modalResult := cargoCheckItemForm.showModal;
	
	if modalResult = IDOK then
		self.doLoadItemsTable();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="d1ad2e64-efce-4460-862a-7f8e3eed2da0">
        <updating/>
        <source>doSave(): Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars
	errObj						: CM_Error;
	name						: String;
	ignoreWarnings, rtnValue	: Boolean;
	proxyCargoCheck				: CM_CargoCheck;
	contextString				: String;
	context						: Integer;
	isNotAvailable				: Boolean;
	theForm						: SOP_TableMaintForm;
	cargoCheckItems				: CM_CargoCheckItemSet;
	idx							: Integer;

begin
    theForm := self.myForm; 
	create cargoCheckItems transient;

	contextString 	:= theForm.tblInput1.getValueByName(ETRow_Context).String;
	context 		:= app.cargoCheckContextStringToENum(contextString);
	foreach idx in 1 to theForm.lstSingleSelect1.listCount do
		cargoCheckItems.add(theForm.lstSingleSelect1.itemObject[idx].CM_CargoCheckItem);
	endforeach;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_CargoCheck transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	proxyCargoCheck := theForm.myProxyObject.CM_CargoCheck;
	proxyCargoCheck.setProxy(context, isNotAvailable, cargoCheckItems, app.myPassport);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCargoCheck(proxyCargoCheck, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCargoCheck(proxyCargoCheck, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
