    <JadeMethod name="getObjects" id="98237f4b-db74-48d7-a9bd-5a045d240d53">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navhl20 ChangeRequest 61960: FR | 57937 - [TKT: 61898] - Kiosk - US.080 'c' - Coded Instructions Missing from Additional question Criteria 

*/

vars
	instTypes		: CM_InstructionTypeByCodeDict;
	instType		: CM_InstructionType;
	terminal		: CM_Terminal;
begin
	terminal	:=	app.getMyTerminalDO_NOT_USE();
	instTypes 	:=  terminal.allInstructionTypes;
	
	foreach instType in instTypes do
		objects[instType.getYAIdentifier] := instType;
	endforeach;
epilog
	
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
