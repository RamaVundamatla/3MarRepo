    <JadeMethod name="canHaveRestrictions" id="086094c3-63c6-4bb5-b706-71122ad9ca2f">
        <source>canHaveRestrictions() : Boolean;
// ---------------------------------------------------------------------------
// Created:     13 December 2001 by cnwrs2
//
// Purpose:     
//
// Returns:     If this area can have labour or location restrictions
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/02/2010 	cnwcs5 		remove VTA references
// ---------------------------------------------------------------------------
vars
	theType	: Integer;
	
begin

	if self.myType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myType is null for ' &amp; self.String);
		return false;
	endif;

	theType := self.myType.type;

	if theType = TA_TYPE_RAIL_TRANS or
//	   theType = TA_TYPE_ROAD_TRANS or	25/02/2010 cnwcs5 remove VTA references
	   theType = TA_TYPE_CRANE_TRANS or
	   theType = TA_TYPE_DELETE or
	   theType = TA_TYPE_BUILDING then
	   	return false;
	endif;

	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeId" id="ec151fe5-f020-4b91-86aa-1180015c1923">
        <updating/>
        <source>changeId(_newId : String) updating, protected;
// from 33418 if the id changes, change the swap stack as well, to avoid confusing duplicate key exceptions and other associated ids
vars
	length	: Integer;
	str		: String;
	swapStackId	: String;
	lc			: CM_LocationsController;
	swapStack	: CM_SwapStack;
begin
	// Block Stack, change the locations controller ident which is the same as the terminal area
	if self.isKindOf(CM_BlockStack) then
		foreach lc in self.allLocationsControllers do
			lc.updateIdent(_newId);
		endforeach;
	endif;

	// need to update the swap stack id to match
	swapStack := self.swapStack;
	if swapStack &lt;&gt; null then
		length	:= CM_SwapStack::id.length;
		str 	:= _newId.trimBlanks;
		if str.length + 5 &gt; length then
			swapStackId := "SWAP_" &amp; _newId[1 : length-5] ;
		else		
			swapStackId := "SWAP_" &amp; str;
		endif;
		swapStack.updateId (swapStackId);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_newId" type="String"/>
    </JadeMethod>
    <JadeMethod name="checkRTQueueTaskUsage" id="ed44b8b1-6964-4074-8288-df7268e36dee">
        <source>checkRTQueueTaskUsage();
//Makes sure the current terminal area is NOT used in a task anywhere...

// ---------------------------------------------------------------------------
// Created:     ??? 
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//17/10/08		cnwer1		PAR 18102  - queues was de-implemted in 7.5.3 and replaced by allRTSubqueues but this method was never changed
//10/02/10		cnwer1		CCMS 1100 - removed global.isValidObject use
//08/03/11		cnwkpd1		PAR #27142 - Changes to app.handleDeletedObject arming
//21/03/11		cnwkpd1		PAR #27211 - ensure TA with RT Queue tasks can not be deleted
// ---------------------------------------------------------------------------
vars
	task	:	CM_RTQueueTask;
	tasks	:	CM_RTQueueTaskArray;
	masterQ : CM_MasterQueue;
	queue	:	CM_RadioTelemetryQueue;
	aMsg	:	String;
	loadStateSet : Boolean;
	invalidTask,
	invalidSource,
	invalidTarget : Boolean;
	sourceLocation,
	targetLocation  : CM_LocationsController;
	sourceParent,
	targetParent : CM_Object;
	queueId		: String;
	
begin
	if self.allSubRTQueues = null then
		return;
	endif;
	app.cmsBeginLoad(loadStateSet);
	if self.allSubRTQueues.size &gt; 0 then
		foreach queue in self.allSubRTQueues do
			aMsg := aMsg &amp; queue.id &amp; ", ";
		endforeach;	
		//----------------
		//Chop off trailing ","
		//----------------
		if aMsg &lt;&gt; null then
			aMsg := aMsg[1 : aMsg.length -2];
		endif;
		/*create except;
		except.resetMsgParams;
		except.setMsgParam(0, self.id.trimRight);
		except.setMsgParam(1, aMsg);
		except.errorCode := ERR_AREA_IN_QUEUE;
		raise except;*/
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_AREA_IN_QUEUE, self.id.trimRight, aMsg, null, null);
		return;		
	endif;	

	//epr par 19250 16/10/09
	if self.myTerminal = null then
		return;
	endif;
	
	create tasks transient;
	if self.myTerminal.radioTelemetry = null then
		//NO rt, there will not be any queues
		return;
	endif;
	//-----------------
	//Ask the masterQueue for all of its tasks
	//-----------------
	masterQ := self.myTerminal.radioTelemetry.masterQueue;
	if masterQ = null then
		return;
	endif;
	masterQ.getAllTasks(tasks);
	
	
	on Exception do app.handleDeletedObject(exception,task,invalidTask);
	on Exception do app.handleDeletedObject(exception,targetLocation,invalidTarget);
	on Exception do app.handleDeletedObject(exception,sourceLocation,invalidSource);
	//-----------------
	//If a task references us, then raise an exception
	//-----------------
	foreach task in tasks do

		invalidTask := false;
		invalidTarget := false;
		invalidSource := false;

		sourceLocation := null;
		targetLocation := null;
		
		sourceParent := null;
		targetParent := null;
		
		sourceLocation := task.sourceLocation;
		targetLocation := task.targetLocation;
		queueId := task.queueId.trimRight();
		
		if invalidTask then
			continue;
		endif;
		
		if sourceLocation &lt;&gt; null then
			sourceParent := sourceLocation.getParent();
		endif;

		if targetLocation &lt;&gt; null then
			targetParent := targetLocation.getParent();
		endif;
		
		if sourceParent = self or targetParent = self then	
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_AREA_HAS_TASK, self.id.trimRight, queueId, null, null);
			return;			
		endif;
	endforeach;
	
	
epilog
	app.cmsEndLoad(loadStateSet);
	delete tasks;
end;</source>
    </JadeMethod>
    <JadeMethod name="countAvailableMatchingTI" id="ca74c51c-0ae9-45d8-9895-7aecb7b39f32">
        <source>countAvailableMatchingTI( _yaRequest : CMIF_YARequest ) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwrd1	Initial creation

*/

vars
	result 			: Boolean;
	tiSet,
	tiSetNFM		: CM_TIArray;
	ti 				: CM_TrackedItem;
	iter 			: Iterator;
	rtqTask			: CM_RTQueueTask;
	aRequest		: CM_Request;
	agent  			: CM_YAAutoplanAgent;
	tmpRequest 		: CMIF_YARequest;
	count 			: Integer;
begin

	result := false; //I know but lets set it anyhow.
	
	create tiSet transient;
	create tiSetNFM transient;
	create tmpRequest transient;
	
	agent := app.myYAAgent;
	if agent = null then
		// have to create... !?!		
	endif;
	
	// get allt he ti's for the TA
	self.getTIs(tiSet, REAL_MODE);

	
	foreach ti in tiSet do
		if not ti.isQueued then   // if not queued
			tiSetNFM.add(ti); //add them to the collecton
		endif;
	endforeach;
	
	//tiSetNFM should be a collection of unqueued ti's for this TA.
	
	//now look through our allRTQueueTasks dict and find all unactioned director tasks
	
	iter :=self.allRTQueueTasks.createIterator;
	
	// rtq task type, and status
	self.allRTQueueTasks.startKeyGeq( TASK_DIRECTOR, TASK_UNACTIONED ,iter);

	
	while iter.next(rtqTask) do
		if rtqTask.status &lt;&gt; TASK_UNACTIONED or rtqTask.taskType &lt;&gt; TASK_DIRECTOR then
			break;
		endif;
		
		// should be processing unactioned director tasks here.
		
		// for each one we try to find a matching cargo item in tiSetNFM and if so we remove it.
		
		aRequest := rtqTask.myEntry.getMyRequest();
		
		if aRequest = null or not aRequest.isKindOf(CM_DeliveryRequest) then  // do we care what kind of request it is here? for YArequest?
		//if aRequest = null then
			// no request, or not delivery request so pass on
			continue;
		endif;
		
		// ok need to find and remove the first matching ti in tiSetNFM
		
		tmpRequest.clear();
		tmpRequest.initializeFromDeliveryRequest(aRequest.myTerminal, aRequest.CM_DeliveryRequest);		
		agent.initialise();
		agent.setCurrentYAAutoPlan(tmpRequest);  
		
		foreach ti in tiSetNFM do
							
			if ti.testAutoPlanRequestYA(agent) then
				//found a match
				tiSetNFM.remove(ti);
				break;
			endif;		
		endforeach;
		
	endwhile;
	
	// now we have all the ti's that are left available , need to find one that matches the CMIF
	agent.initialise();
	agent.setCurrentYAAutoPlan(_yaRequest);   // this all I need to do?
	
	foreach ti in tiSetNFM do			
		if ti.testAutoPlanRequestYA(agent) then
			//found a match
			count := count +1;
		endif;		
	endforeach;
	
	return count;
	
epilog
	delete iter;
	delete tiSet;
	delete tiSetNFM;
end;</source>
        <Parameter name="_yaRequest" type="CMIF_YARequest"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="273ca017-08bb-49a1-ac31-b1fc42758af0">
        <updating/>
        <source>create() updating;

vars
	anObj : CM_Object;
begin

	self.isEmpty := true;								// cnwmh5 04/04/2016 - Fix issue found in automated tests where not set correctly

	if self.isTransient then
		return;
	endif;
	
//	create anObj as CM_LayoutGraphic persistent;
//	self.layout := anObj.CM_LayoutGraphic;
	 //---------
 	//Create Autoplan test object
 	//---------
 	create anObj as CM_AutoPlanTests;
 	anObj.CM_AutoPlanTests.setForCreate(self);
 	
 	//save bumping self's edition the first time we put something into one of these collections
 	self.allLocationsControllers.instantiate();
 	self.allLCsArchived.instantiate();
 	self.allRestrictionsLabour.instantiate();
 	self.allRestrictionsLocation.instantiate();
 	
end;</source>
    </JadeMethod>
    <JadeMethod name="createDiscrepancy" id="1870044f-1aef-4259-90bf-3f066595201d">
        <updating/>
        <source>createDiscrepancy(text : String; ts : TimeStamp) : CM_LocationDiscrepancy updating;
// ---------------------------------------------------------------------------
// Created:     28 February 2001 by cnwdwq1
// Purpose: 
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	newDiscrep : CM_LocationDiscrepancy;
begin
