    <JadeMethod name="pipt" id="4758609a-dfc1-46fa-8b0a-d000e791a74f">
        <source>pipt();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2019	jlgma1	Initial creation

*/

vars
	invLine : CM_InvoiceLine;
	ti,ti2 : CM_TrackedItem;
	lFile      		: File;
	cashPayment : CM_CashPayment;
	cashValue   : String;
	cashDate    : String;
	paymentStatus : String;
	cashSize :String;
	zombie : String;
	result		: Boolean;
//	cashTotal,payAmount	: Decimal[16, 6];
	payment		: CM_CashPayment;
	cashTotal,payAmount	: Decimal[23, 6];
	isPaidFor : Boolean;
begin
	ti := "4022.312307".asOid.CM_TrackedItem;
	create lFile transient;
	lFile.fileName := "C:\TEMP\PIBT\" &amp;"Jan1802.csv";
    lFile.open;
	lFile.writeLine(
					"Invoice"            &amp; "," &amp;
					"Inv Line Seq"  	 &amp; "," &amp;
					"Line Desc "         &amp; "," &amp;
					"line Total"   		 &amp; "," &amp;
					"invLine Created DT" &amp;","  &amp;
					"invLine Voided"     &amp;","  &amp;
					"isPaid For"   	   	 &amp; "," &amp;
					"Payment Size" 	 	 &amp; "," &amp; 
					"payment Total"      &amp; "," &amp;
					"Payment Date "      &amp; "," &amp;
					"cashPayment Voided" &amp; "," &amp;
					"Zombie"
					);
	if ti &lt;&gt; null then
		foreach invLine in ti.invoiceLines do
			cashTotal := 0;
			
			foreach payment in invLine.allCashPayments do
				// 35232 skip voided payments
				if payment.voided then
					if payment.isManual then
						if payment.myTrackedItem &lt;&gt; null then
							if payment.myTrackedItem.state &lt;&gt; TI_STATE_MERGED then
								continue;
							endif;
						else
							continue;
						endif;
					else
					continue;
					
					endif;
				endif;
				cashTotal := cashTotal + payment.cashValue;
			endforeach;
	
		// from TFS 1808 testing round the values before comparing (was 880.00 paid, 880.000032 invoice line value so not showing as paid)
		if not invLine.isNegativeAmount then
			if cashTotal &lt;&gt; 0 or invLine.lineTotal &lt;&gt; 0  then //29/06/2017 cnwma1 TFS #4549
				isPaidFor := (cashTotal.roundedTo(2) &gt;= invLine.lineTotal.roundedTo(2));
			endif;
		else
			cashTotal := cashTotal*-1;
			if cashTotal &lt;&gt; 0 or invLine.lineTotal &gt; 0  then //29/06/2017 cnwma1 TFS #4549
				isPaidFor := (cashTotal.roundedTo(2) &gt;= invLine.lineTotal.roundedTo(2)*-1);
			endif;
		
		endif;
	
	
		
		if invLine.allCashPayments.size &gt; 0 then
			cashPayment	  := invLine.allCashPayments.first.CM_CashPayment;
			if cashPayment.myTrackedItem &lt;&gt; null then
				ti2 := cashPayment.myTrackedItem;
				zombie := ti2.state.String;
			endif;
			cashValue 	  := cashPayment.cashValue.String;
			cashDate      := cashPayment.createdTime.String.removeCommas();
			paymentStatus := cashPayment.voided.String;
		else
			zombie := Space;
			cashValue := Space;
			cashDate  := Space;
			paymentStatus := Space;
			cashSize := "0";
		endif;
		lFile.writeLine(
						invLine.invoice.sequenceNum.String 
				&amp; "," &amp; invLine.sequenceNum.String 
				&amp; "," &amp; invLine.invoiceLineDesc.narration
				&amp; "," &amp; invLine.lineTotal.String 
				&amp; "," &amp; invLine.createdTime.String.removeCommas()
				&amp; "," &amp; invLine.voided.String
				&amp; "," &amp; isPaidFor.String 
				&amp; "," &amp; invLine.allCashPayments.size.String 
				&amp; "," &amp; cashValue
				&amp; "," &amp; cashDate
				&amp; "," &amp; paymentStatus
				&amp; "," &amp; zombie
						);
		
		endforeach;
	endif;
	lFile.close;
epilog
	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="pipt2" id="8d32f61e-9864-4501-bef5-bfa9dffb98c0">
        <source>pipt2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2019	jlgma1	Initial creation

*/

vars
	proformaAgent : CM_CashInvoiceProformaAgent;
	invLine	      : CM_InvoiceLine;
	adjust        : Decimal[23,6];
	taxScreen,
	originalTax,
	taxAdjust	  : Decimal [12,2];
	charge        : CM_Charge;
	lFile      		: File;
begin
	create lFile transient;
	lFile.fileName := "C:\TEMP\" &amp;"Oct4-01.csv";
    lFile.open;
	
	originalTax := 11618.77;
	proformaAgent := "4203622.1".asOid.CM_CashInvoiceProformaAgent;
	if proformaAgent &lt;&gt; null then
		foreach invLine in proformaAgent.allCurrentInvLines discreteLock do
			
			adjust := invLine.lineTotal;
			foreach charge in invLine.charges do
				taxAdjust := charge.getTaxAmountForCharge();
				taxScreen := originalTax - taxAdjust;
			endforeach;
			lFile.writeLine(adjust.asStringJMT  &amp; Tab &amp; taxAdjust.asStringJMT  );
		endforeach;
		app.msgBox(taxScreen.asStringJMT,"",0);
	endif;
	lFile.close;
epilog
		delete lFile;
end;</source>
    </JadeMethod>
