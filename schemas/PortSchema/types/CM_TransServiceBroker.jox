    <JadeMethod name="auditIdDisplay" id="78c08e98-6787-4fe7-8d71-7174b2403ca0">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jan 2017	cnwma1	Initial creation
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/


vars
	auditIdStr : String;
begin
	auditIdStr := self.auditId();								//31.03.2025 navma1 #MTN-34387
	
	if auditIdStr &lt;&gt; null then
		return 'Transaction Type Map' &amp; ' - ' &amp; auditIdStr;
	else
		return 'Transaction Type Map';
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
