<CollClass name="StringArray">
    <JadeMethod name="jhpGetMinReleases" id="68503255-254c-468d-b21c-67f57d58ca65">
        <source>jhpGetMinReleases(minRelease1,minRelease2,special:String output);

vars
	s,t,u:String;
	sa:StringArray;
begin
	create sa transient;
	foreach s in self do
		if s = "all" or s = "ge6300" or s = "eq6312" then
			s := "ge6312";
		endif;
		if s = "bt63006399" then
			s := "ge6312";
		endif;
		if s = "le6309" or s = "eq6300;ge6306" then
			s := "ge6306";
		endif;
		if s = "eq7005" or s = "eq7006" or s = "le6399" then
			special := "drop";  // deprecate these tests
		endif;
		if s = "le7049" then
			special := s;
			s := "ge6312";
		endif;
		if s[1:6] = "eq7012" then
			s := "ge7012";
		endif;
		if s[3:4] = "7099" then
			s[3:4] := "7100";
		endif;
		if special = null and s[1:2] &lt;&gt; "bt" and s[1:2] &lt;&gt; "ge" and s[1:6] &lt;&gt; "eq7000" then  // check for unusual ones
			write s;
		endif;
		if s[3:4].Integer &lt; 6305 or s[3:4].Integer &gt; 9901 then  // check for bogus release levels
			write s;
		endif;
		
		/*if s[1:2] = "bt" and s[7:4] &lt;&gt; "6309" and s[7:4] &lt;&gt; "7049" and s[9:2] &lt;&gt; "99" then
			write s;
		endif;/**/
		if s[1:2] = "bt" and s[7:4] = "6309" or s = "bt70517098" then
			continue;  // deprecated releases
		endif;
		
		t := s[3:4];
		if sa.size &gt;= 1 and not sa.includes(t) then  // skip some redundant declarations
			if t = "7000" and sa[1][1:2] = "63"  // don't add 7000, just leave it as 6310 or whatever
			or t[1:2] = sa[1][1:2]  // combine for example 6306 and 6310
			or t[1:2] = "70" and t[1:4] &lt; "7009"  // not running le 7009 any more - leave as 63
			then
				//if t &lt;&gt; "7000" then write "dropping " &amp; t; endif;
				continue;
			endif;
		endif;
		if not sa.includes(t) then
			sa.add(t);
		endif;
	endforeach;
	
	foreach s in sa do
		u := u &amp; s &amp; ";";
	endforeach;
	//write u;
	
	if sa.size &lt;  1 then minRelease1 := "9999"; endif;
	if sa.size &gt;= 1 then minRelease1 := sa[1]; endif;
	if sa.size &gt;= 2 then minRelease2 := sa[2]; endif;
	if sa.size &gt;= 3 then minRelease2 := "too many releases"; endif;
epilog
	delete sa;
end;
</source>
        <Parameter name="minRelease1" type="String" usage="output"/>
        <Parameter name="minRelease2" type="String" usage="output"/>
        <Parameter name="special" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="jtdFind" id="3c652ab1-482e-4b52-9d21-688acb2ad2e8">
        <source>jtdFind(str : String) : Integer;

vars
	i 		: Integer;
	str2 	: String;
	str3	: String;
begin
	//  Case-insensitive find, returns array position of input string ///

	str2	:= str.toLower;

	foreach str3 in self do
		if str3.toLower = str2 then
			return self.indexOf(str3);
		endif;
	endforeach;

 	return 0;	
end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
