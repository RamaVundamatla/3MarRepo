    <JadeMethod name="getMessageTypeString" id="2288cd32-99b7-4b19-a9b6-adb77ea160d8">
        <source>getMessageTypeString(_messageType: Integer): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17 March 2023	navdap1		Initial creation TFS 
//
vars

begin
	if _messageType = INTRACON_RAILOUT then
		return "Train Departure";
	elseif _messageType = INTRACON_ROADOUT then
		return "Truck Departure";
	elseif _messageType = INTRACON_SHIPOUT then
		return "Voyage Departure";
	endif;
	
	return inheritMethod(_messageType);

epilog

end;</source>
        <Parameter name="_messageType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleasesAndBOLs" id="aa4808fd-5074-4e1c-8874-cf616cec72ec">
        <source>getReleasesAndBOLs(_ti : CM_TrackedItem; _event : CM_EventTransaction; _releaseMode : Integer; _releases : StringArray io; _bols : StringArray io) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/04/2023	navdap1		Initial creation TFS 57542 PRP - Suzano Delivery Communications File - Line Item Sales Order Item
//
vars
	br : CM_BulkRelease;
	resDet : CM_ReserveDetail;

begin
	_releases.clear;
	_bols.clear;
	
	// need to check a variety of things to see if this ti belongs to a release request we care about
	// first, ti.deliveryRelease
	br := _ti.myTerminal.allBulkReleasesByCodeDate.getAtKeyGeq(_ti.deliveryRelease, "31/12/3000 23:59".TimeStamp);
	if br &lt;&gt; null and br.code = _ti.deliveryRelease and br.getOperatorCode = self.SuzanoOperator then
		if (_releaseMode = TI_TRANSMODE_ROAD or _releaseMode = TI_TRANSMODE_RAIL) 
		or (_releaseMode = TI_TRANSMODE_SHIP and br.isShipType and br.myVoyage = _event.CMEVT_VoyageEvent.myVoyage) then
			if not _releases.includes(br.code) then
				app.writeLog(method.qualifiedName &amp; Tab &amp; _ti.id &amp; " allBulkReleasesByCodeDate - added release " &amp; br.code &amp; " with BOL '" &amp; _ti.billOfLading &amp; "'", LogDEBUG);
				_releases.add(br.code);
				_bols.add(_ti.billOfLading);
			endif;
		endif;
	endif;
	
	// next, ti.allReserveDetails and ti.allReserveDetailsReleased
	foreach resDet in _ti.allReserveDetailsReleased where resDet.myReserveHeader.getOperatorCode = self.SuzanoOperator do
		if (_releaseMode = TI_TRANSMODE_ROAD and resDet.myReserveHeader.isRoadType)
		or (_releaseMode = TI_TRANSMODE_RAIL and resDet.myReserveHeader.isRailType)
		or (_releaseMode = TI_TRANSMODE_SHIP and resDet.myReserveHeader.myVoyage = _event.CMEVT_VoyageEvent.myVoyage) then
			if resDet.isKindOf(CM_ReserveSelection) and not _releases.includes(resDet.myReserveHeader.code) then
				app.writeLog(method.qualifiedName &amp; Tab &amp; _ti.id &amp; " allReserveDetailsReleased - added release " &amp; resDet.myReserveHeader.code &amp; " with BOL '" &amp; _ti.billOfLading &amp; "'", LogDEBUG);
				_releases.add(resDet.myReserveHeader.code);
				_bols.add(_ti.billOfLading);
			endif;
		endif;
	endforeach;
	foreach resDet in _ti.allReserveDetails where resDet.myReserveHeader.myOperator.code = self.SuzanoOperator do
		if (_releaseMode = TI_TRANSMODE_ROAD and resDet.myReserveHeader.isRoadType)
		or (_releaseMode = TI_TRANSMODE_RAIL and resDet.myReserveHeader.isRailType)
		or (_releaseMode = TI_TRANSMODE_SHIP and resDet.myReserveHeader.myVoyage = _event.CMEVT_VoyageEvent.myVoyage) then
			if resDet.isKindOf(CM_ReserveSelection) and not _releases.includes(resDet.myReserveHeader.code) then
				app.writeLog(method.qualifiedName &amp; Tab &amp; _ti.id &amp; " allReserveDetails - added release " &amp; resDet.myReserveHeader.code &amp; " with BOL '" &amp; _ti.billOfLading &amp; "'", LogDEBUG);
				_releases.add(resDet.myReserveHeader.code);
				_bols.add(_ti.billOfLading);
			endif;
		endif;
	endforeach;
	
	// then ti.allBulkReleasesReleased
	foreach br in _ti.allBulkReleasesReleased where br.getOperatorCode = self.SuzanoOperator do
		if (_releaseMode = TI_TRANSMODE_ROAD and br.isRoadType)
		or (_releaseMode = TI_TRANSMODE_RAIL and br.myAssignedTrain = _event.CMEVT_TrainTransaction.myTrain)
		or (_releaseMode = TI_TRANSMODE_SHIP and br.myVoyage = _event.CMEVT_VoyageEvent.myVoyage) then
			if not _releases.includes(br.code) then
				app.writeLog(method.qualifiedName &amp; Tab &amp; _ti.id &amp; " allBulkReleasesReleased - added release " &amp; br.code &amp; " with BOL '" &amp; _ti.billOfLading &amp; "'", LogDEBUG);
				_releases.add(br.code);
				_bols.add(_ti.billOfLading);
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_event" type="CM_EventTransaction"/>
        <Parameter name="_releaseMode" type="Integer"/>
        <Parameter name="_releases" type="StringArray" usage="io"/>
        <Parameter name="_bols" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleDuplicateKey" id="8e6d514f-47c4-4d01-82b5-f565ef950b8b">
        <source>handleDuplicateKey(_exc : Exception; _obj : Object; _duplicateKey : Boolean io) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 August 2023	navpw1	Initial creation TFS: 59186 (59100)

*/

constants
	KeyAlreadyUsed	= 1310;
	
vars
	returnVal : Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	// initialised when the exception occurs, then it is not for us, so just pass back immediately
	if _obj = null then				
		return returnVal;
	endif;
	
	if _exc.errorCode = KeyAlreadyUsed then
		if _exc.errorObject = _obj or self.getOwnerForObject(_exc.errorObject) = _obj then
			// Set _invalidObject, and resume in the calling method, which will then
			// interrogate excOccurred, to identify an invalid/deleted object
			_duplicateKey := true;
			if _exc.resumable then
				returnVal := Ex_Resume_Next;
				
			endif;
		endif;
	endif;
	
epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_duplicateKey" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeEvent" id="1897c039-b575-4853-ac8c-a1985219fa47">
        <source>includeEvent(_eventTransaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/03/2023	navdap1		Initial creation TFS 56796 PPR Suzano EDI Delivery Communication
//
vars
	firstTI : CM_TrackedItem;
    visitRecord : CM_VehicleVisitRecord;
	voyage : CM_Voyage;
	train : CM_Train;
	wagon : CM_Wagon;
	tiTransaction : CM_TITransaction;
	result : Boolean;

begin
	if _eventTransaction.type = EVT_TrainDepart then
		train := _eventTransaction.getTrain;
		foreach wagon in train.allWagonsByOrderOutward do
			if not wagon.allTIsReleased.isEmpty then
				firstTI := wagon.allTIsReleased.first;
				break;
			endif;
		endforeach;
	elseif _eventTransaction.type = EVT_TruckDeparture then // Paper-only
 		visitRecord := _eventTransaction.getVehicleVisit;
		if visitRecord &lt;&gt; null then
			firstTI := visitRecord.allReleasedTrackedItems.first.CM_TrackedItem;
		endif;
    elseif  _eventTransaction.type = EVT_VoyageDeparture  then //Pulp-only
        voyage := _eventTransaction.getVoyage();
        if voyage &lt;&gt; null then
			foreach tiTransaction in voyage.allTITransactionsByTypeDT do
				if tiTransaction.isKindOf(CM_ReleaseShip) then
					firstTI := tiTransaction.myTrackedItem;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if firstTI &lt;&gt; null then
		if not _camProtocol.includeCargoType(firstTI.cargoType, _eventTransaction, _camAgent, _camAgent.logExcludedTransactions) then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_eventTransaction, 'Event transaction has incorrect cargotype');
			endif;
			return false;
		endif;
		if not _camProtocol.isCAMGroupMatchEvent(_eventTransaction, firstTI, _camAgent, _camAgent.logExcludedTransactions) then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_eventTransaction, 'Event transaction does not match cam group');
			endif;
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_eventTransaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEventType" id="879fbe71-1511-4f6a-a6b4-8848465c8658">
        <source>isEventType(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/03/2023	navdap1		Initial creation TFS 56796 PRP Suzano EDI Delivery Communication
//
vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEventTypeToBeProcessed" id="3594a4bf-9971-472f-a136-c57747312262">
        <source>isEventTypeToBeProcessed(_camProtocol: CM_CamProtocol; _trans: CM_EventTransaction): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/03/2023	navdap1		Initial creation TFS 56796 PRP Suzano EDI Dlivery Communication
//
vars
	result : Boolean;

begin
	result := inheritMethod(_camProtocol, _trans);
	if  result and
		_trans.type = EVT_VoyageDeparture and 
		_trans.getVoyage() = null then 
			return false; 
	endif;
	
	return result;
epilog

end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_trans" type="CM_EventTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="8f284b05-d2aa-4184-b71d-51ef60f3a052">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj: CM_Object; _transactions: CM_TITransactionSet) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/03/2023	navdap1		Initial creation TFS 56796 PRP - Suzano EDI - Delivery Confirmation
// 17 Jun 2025  navah1		Bug 34936: PRP - Missing Header field in Outbound EDI File (CAMS Message)
// 09 Oct 2025	navah1		Bug 35725: PRP - EDI CAMS Message Line Split Post-Upgrade to 22.0.24.17
vars
	camVoyage : CM_CamVoyage;
	camMessage : CM_CamMessage;
	outputStr : String;
	group3StrArray : HugeStringArray;
	prevMsg : String;
begin
	// We get here if the cams protocol has "Single Transaction Per File" unticked
	if _protocol.singleTransactionPerFile then
		return;
	endif;
	
	create group3StrArray transient;
	foreach camVoyage in _camFile.camVoyages do
		foreach camMessage in camVoyage.camMessages do
			//group3StrArray.clear; //17.06.2025 navah1 #34936 
			foreach outputStr in camMessage.group3 do 
				//09.10.2025 navah1 #35725 Start
				//outputStr.getTokensForDelimiterHuge(Cr, group3StrArray);  
				if outputStr.startsWith('1HDR') and prevMsg &lt;&gt; null then    
					outputStr := Cr &amp; outputStr;
				endif;
				prevMsg &amp;= outputStr; 						   			    
				if prevMsg.endsWith(Cr) then							   
					prevMsg.getTokensForDelimiterHuge(Cr, group3StrArray);  
					prevMsg := null;
				endif;
				//09.10.2025 navah1 #35725 End
			endforeach;
			if prevMsg &lt;&gt; null then //09.10.2025 navah1 #35725
				prevMsg.getTokensForDelimiterHuge(Cr, group3StrArray);  
				prevMsg := null;
			endif;
		endforeach; 
	endforeach;
	 
	//_camTaskHistory.setRawDataString(outputStr); //17.06.2025 navah1 #34936
	_camTaskHistory.setRawDataString(group3StrArray.concatenate(Cr)); //17.06.2025 navah1 #34936
epilog
	delete group3StrArray; 
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="processEvent" id="da3fe9b5-588a-417e-9ad8-f0df40e97159">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/03/2023	navdap1		Initial creation TFS 56796 PRP Suzano EDI Delivery Communication
// 12/04/2023	navdap1		TFS 57554 FR 56237 | Suzano Delivery Confirmation should report Vehicle Visit Number
// 19/04/2023	navdap1		TFS 57542 PRP - Suzano Delivery Communications File - Line Item Sales Order Item
// 20/06/2023	navpw1		TFS: 57876 (58721) - Fixed line item padding length, added transport sequential number and 
//													added header splitting by release request line number
// 20/07/2023	navpw1		TFS: 59206 - Fixed the suzano sequence number
// 14/08/2023	navdap1		TFS 59809 PRP 1310 Error Suzano EDI
// 17/08/2023	navdap1		TFS 59878 PRP - Suzano Delivery Communication CAMS 1310 error when a truck picks up cargo on more than one request line
// 20/09/2023	navdap1		TFS 60501 PRP - Suzano Download Communication file doesn't report all cargo
// 20/09/2023	navdap1		TFS 60589 PRP - Delivery File sent to Suzano does not match road receipt report that prints out
// 23/04/2024	jlizm1		TFS 62876 Shipment Number EDI
// 17/12/2024	navdap1		MTN-33683 PRP | Suzano Delivery Communication format changes
// 06/01/2025	navdap1		MTN-33672 PRP (JAX ) - EDI files did not process. System will not allow duplicate headers
//
constants
	RailOutSpecialStow		: String = "R_OUT";
	TransportModeRoad		: String = "0001";
	TransportModeRail		: String = "Z002";
	TransportModeShip		: String = "0003";
	TransportModeBarge		: String = "Z003";
	SequentialNumberRoad	: String = "01";
	SequentialNumberRail	: String = "02";
	
vars
	tisByRelease				: DynaDictionary;
	camMessage					: CM_CamMessage;
	train						: CM_Train;
	wagon						: CM_Wagon;
	vvr							: CM_VehicleVisitRecord;
	voyage						: CM_Voyage;
	ti							: CM_TrackedItem;
	bulkRelease					: CM_BulkRelease;
	xlatVoyageCode,
	xlatTerminalCode			: String;
	tiTrans						: CM_TITransaction;
	eventType					: CM_EventType;
	strMsg,
	headStr, detailStr, devStr,
	trailStr, dtdMsg, devMsg,
	message, lastRelease,
	release, id					: String;
	operator					: CM_Operator;
	found						: Boolean;
	releases					: StringArray;
	iter						: Iterator;
	header						: CMIF_SuzanoDeliveryHeader;
	detail						: CMIF_SuzanoDeliveryDetail;
	transportType, vehicleId,
	remarks, etaDate			: String;
	detailWeight				: Integer;
	messageCount				: Integer;
	idx							: Integer;
	transportId					: String;			// TFS 57554
	billsOfLading				: StringArray;		// TFS 57542
	bol, lastBol				: String;			// TFS 57542
	bolCount					: Integer;			// TFS 57542
	firstTime					: Boolean;			// TFS 57542
	shipmentNum					: String;
	
	reserveDetail,
	lastReserveDetail			: CM_ReserveDetail;	// ### TFS 57876 (58721) 20Jun2023 NAVPW1
	transportSequentialNumber	: String;			// ### TFS 57876 (58721) 20Jun2023 NAVPW1
	lineNumber					: Integer;			// ### TFS 59206 19July2023 NAVPW1
	duplicateKey				: Boolean;			// ### TFS 59186 (59100) 08Aug2023 NAVPW1
	duplicateKeyMsg				: String;			// ### TFS 59186 (59100) 08Aug2023 NAVPW1
	lastTransportCode			: String;		// TFS 59809
	lastLineNumber				: Integer;		// TFS 59878
	shipmentNumForDTD			: String;
	
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.type.asStringJMT);
	
    if _transaction = null then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'There is no Event transaction');
			return;
		endif;
	endif;
	
	operator := app.myRoot.allOperators[self.SuzanoOperator];
	if operator = null then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'There is no ' &amp; self.SuzanoOperator &amp; ' operator');
			return;
		endif;
	endif;
    
	// TFS 57542 Sales Order Item Number actually reflects what BOL a cargo item is assigned
	// i.e. if there are 3 cargo items in a releas, and they each have a different BOL,
	// then the sequence number will be 1 for the first cargo item, 2 for the second, etc
	// so change this dyna dict to be sorted by BOL
	create tisByRelease transient;
	tisByRelease.setMembership(CM_TrackedItem);
	tisByRelease.addExternalKey(String, 20, false, true);	// release request number
	//tisByRelease.addExternalKey(Integer, 6, false, true);	// release request line number	// TFS 57542
	tisByRelease.addExternalKey(String, 30, false, true);	// BOL number					// TFS 57542
	tisByRelease.addExternalKey(String, 30, false, true);	// ti id
	tisByRelease.endKeys(false);
	
	// for train departure, we're reporting on all TIs released on the train 
	// for truck departure, we're reporting on all TIs released on the truck
	// for voyage departure, we're reporting on all Export TIs released on the voyage
	create releases transient;
	//create lineNumbers transient;		// TFS 57542
	create billsOfLading transient;		// TFS 57542
	if _transaction.type = EVT_TrainDepart then		
		train := _transaction.getTrain;
		if train = null then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, 'There is no Train associated with the Train Departure transaction');
			endif;
			return;
		endif;
		
		foreach wagon in train.allWagonsByOrderOutward do
			foreach ti in wagon.allTIsReleased do
				//self.getReleasesAndLineNumbers(ti, _transaction, TI_TRANSMODE_RAIL, releases, lineNumbers);	// TFS 57542
				self.getReleasesAndBOLs(ti, _transaction, TI_TRANSMODE_RAIL, releases, billsOfLading);			// TFS 57542
				foreach idx in 1 to releases.size do
					if tisByRelease[releases[idx], billsOfLading[idx], ti.id] = null then						// TFS 57542
						tisByRelease.putAtKey(releases[idx], billsOfLading[idx], ti.id, ti);					// TFS 57542
					endif;
				endforeach;
			endforeach;
		endforeach;
		
		if tisByRelease.isEmpty then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, 'There was no Cargo released on the Train');
			endif;
			return;
		endif;
		_camAgent.logReasonForInclusion(_transaction, "Has " &amp; tisByRelease.size.String &amp; " cargo items to process");
		camMessage := self.getCamMessage(_camFile, null, null, INTRACON_RAILOUT, _camProtocol.singleContainerPerBGM);
		
	// Enstructure also use road release with a Special Stow code of "R_OUT" as a rail release
	elseif _transaction.type = EVT_TruckDeparture then
 		vvr := _transaction.getVehicleVisit;
		if vvr = null then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, 'There is no Vehicle Visit Record associated with the Truck Departure transaction');
			endif;
			return;
		endif;
		
		shipmentNum := vvr.getFirstShipmentNumber();
		
		foreach ti in vvr.allReleasedTrackedItems do
			//self.getReleasesAndLineNumbers(ti, _transaction, TI_TRANSMODE_ROAD, releases, lineNumbers);	// TFS 57542
			self.getReleasesAndBOLs(ti, _transaction, TI_TRANSMODE_ROAD, releases, billsOfLading);			// TFS 57542
			foreach idx in 1 to releases.size do
				if tisByRelease[releases[idx], billsOfLading[idx], ti.id] = null then						// TFS 57542
					tisByRelease.putAtKey(releases[idx], billsOfLading[idx], ti.id, ti);					// TFS 57542
				endif;
			endforeach;
 		endforeach;
		
		if tisByRelease.isEmpty() then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, 'There was no Cargo released on the Truck');
			endif;
			return;
		endif;
		_camAgent.logReasonForInclusion(_transaction, "Has " &amp; tisByRelease.size.String &amp; " cargo items to process");
		if tisByRelease.first.CM_TrackedItem.specialStow = RailOutSpecialStow then
			camMessage := self.getCamMessage(_camFile, null, null, INTRACON_RAILOUT, _camProtocol.singleContainerPerBGM);
		else
			camMessage := self.getCamMessage(_camFile, null, null, INTRACON_ROADOUT, _camProtocol.singleContainerPerBGM);
		endif;
		
    elseif  _transaction.type = EVT_VoyageDeparture  then		
		voyage := _transaction.getVoyage();
        xlatVoyageCode := voyage.myOperator.getXlationForeignCode(voyage.code, XLATION_TYPE_VOYAGETERMINAL, found);
		
        foreach tiTrans in voyage.allTITransactionsByTypeDT do
            if tiTrans.isKindOf(CM_ReleaseShip) and (not tisByRelease.includes(tiTrans.myTrackedItem)) then
				ti := tiTrans.myTrackedItem;
				//self.getReleasesAndLineNumbers(ti, _transaction, TI_TRANSMODE_SHIP, releases, lineNumbers);	// TFS 57542
				self.getReleasesAndBOLs(ti, _transaction, TI_TRANSMODE_SHIP, releases, billsOfLading);			// TFS 57542
				foreach idx in 1 to releases.size do
					if tisByRelease[releases[idx], billsOfLading[idx], ti.id] = null then						// TFS 57542
						tisByRelease.putAtKey(releases[idx], billsOfLading[idx], ti.id, ti);					// TFS 57542
					endif;
				endforeach;
           endif;
        endforeach;
		
		if tisByRelease.isEmpty() then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, 'There was no Cargo released on the Voyage');
			endif;
			return;
		endif;
		_camAgent.logReasonForInclusion(_transaction, "Has " &amp; tisByRelease.size.String &amp; " cargo items to process");
		camMessage := self.getCamMessage(_camFile, voyage.code, voyage.vesselName, INTRACON_SHIPOUT, _camProtocol.singleContainerPerBGM);
		
    else
		if _camAgent.logExcludedTransactions then
			eventType := app.myRoot.allEventTypesByType[_transaction.type];
			if eventType &lt;&gt; null then
				strMsg := eventType.name;
			else
				strMsg := _transaction.type.asStringJMT;
			endif;
			_camAgent.logReasonForExclusion(_transaction, 'The Event ' &amp; strMsg &amp; ' is not a Train, Truck or Voyage Departure Event');
		endif;
		return;
		
    endif;
	
	// we now have all the TIs associated with the event - build the file information
	// TIs are sorted in Sales Order Number (release request) then Sales Order Line (BOL) order
	// HEADER - 1HDR &amp; file creation date &amp; file creation time &amp; terminal code &amp; comments
	xlatTerminalCode := operator.getXlationForeignCode(_camProtocol.terminal.code, XLATION_TYPE_TERMINAL_BYOP, found);
	headStr := "1HDR:" &amp; _camAgent.runDateTime.formatAsYYYYMMDDHHmmSS &amp; xlatTerminalCode.cnEcPadTrailing(4, Space.Character);
	_camAgent.setDates(_camAgent.runDateTime.addSeconds(1), _camAgent.startDateTime, _camAgent.endDateTime);	// MTN-33672
	// DTD - Delivery Transoprt Data
	// 2DTD &amp; sales order &amp; sales order item &amp; delivery date &amp; sequential number &amp; transport type &amp; vehicle id &amp; quantity &amp; currency &amp; value &amp; remark &amp; carrier &amp; BOL &amp; ETA date
	firstTime := true;									// TFS 57542
	iter := tisByRelease.createIterator;
	while iter.next(ti) do
		iter.getCurrentKeys(release, bol, id);			// TFS 57542
		
		// TFS 57542 check bol against the last bol - if different, increment the bol count so we can set the Sales Order Line Number correctly
		if bol &lt;&gt; lastBol or firstTime then
			bolCount := bolCount + 1;
			firstTime := false;
		endif;
		// TFS 57542 end of this bit
		
		reserveDetail := ti.allReserveDetailsReleased.getReserveDetailForTi(release);	// ### TFS 57876 (58721) 20Jun2023 NAVPW1
		
		// ### TFS 59206 19July2023 NAVPW1
		if reserveDetail &lt;&gt; null and reserveDetail.isKindOf(CM_ReserveSelection) then
			lineNumber := reserveDetail.CM_ReserveSelection.lineNumber;						
		else	//Allows protection in case this is a release by id
			lineNumber := _camAgent.suzanoSeqNumber;
		endif;
		// ### TFS 59206 19July2023 NAVPW1
		
		if lastRelease &lt;&gt; release or lastReserveDetail &lt;&gt; reserveDetail then	// ### TFS 57876 (58721) 20Jun2023 NAVPW1
			// replace ti weight with total weight for the release
			if lastRelease &lt;&gt; null then
				//header := _camAgent.allSuzanoDeliveryHeaders["2DTD:", lineNumber, lastTransportCode];	// ### TFS 59206 19July2023 NAVPW1	// TFS 59809
				header := _camAgent.allSuzanoDeliveryHeaders["2DTD:", lastLineNumber, lastTransportCode];	// TFS 59878
				if header &lt;&gt; null then
					header.message[56:16] := detailWeight.asStringJMT.padLeadingZeros(16);
					app.writeLog("Changed weight on header " &amp; header.getOidString &amp; " to " &amp; header.message[56:16], LogDEBUG);	// TFS 59878
				endif;
			endif;
			//_camAgent.setSuzanoSeqNumber(_camAgent.suzanoSeqNumber + 1); // ### TFS 59206 19July2023 NAVPW1 - Commented out
			
			// ### TFS 59206 19July2023 NAVPW1
			if reserveDetail &lt;&gt; null and reserveDetail.isKindOf(CM_ReserveSelection) then
				_camAgent.setSuzanoSeqNumber(lineNumber);
			else	//Allows protection in case this is a release by id
				lineNumber := _camAgent.suzanoSeqNumber + 1;
				_camAgent.setSuzanoSeqNumber(lineNumber);
			endif;
			// ### TFS 59206 19July2023 NAVPW1
			
			transportType := null;
			bulkRelease := null;
			vehicleId := null;
			etaDate := null;
			bulkRelease := ti.myTerminal.allBulkReleasesByCodeDate.getAtKeyGeq(release, "31/12/2100 23:59".TimeStamp);
			if bulkRelease.code = release then
				remarks := bulkRelease.getRemarks();
			else
				remarks := null;
				bulkRelease := null;
			endif;
			if ti.releasedTransportMode = TI_TRANSMODE_RAIL then
				transportType := TransportModeRail;
				vehicleId := ti.getMyWagonRelease.myTrainOutwards.code;
				etaDate := _camAgent.runDateTime.date.addDays(6).formatAsYYYYMMDD;
				transportId := vehicleId;									// TFS 57554
				transportSequentialNumber := SequentialNumberRail;			// ### TFS 57876 (58721) 20Jun2023 NAVPW1
			elseif ti.releasedTransportMode = TI_TRANSMODE_ROAD then
				if ti.specialStow = RailOutSpecialStow then
					etaDate := _camAgent.runDateTime.date.addDays(6).formatAsYYYYMMDD;
					transportType := TransportModeRail;
					transportSequentialNumber := SequentialNumberRail;		// ### TFS 57876 (58721) 20Jun2023 NAVPW1
				else
					etaDate := _camAgent.runDateTime.date.addDays(1).formatAsYYYYMMDD;
					transportType := TransportModeRoad;
					transportSequentialNumber := SequentialNumberRoad;		// ### TFS 57876 (58721) 20Jun2023 NAVPW1
				endif;
				vehicleId := ti.allVisitRecords.last.regNumber;
				transportId := ti.allVisitRecords.last.visitNumber;			// TFS 57554
				// MTN-33683 Shipment Number no longer includes the visit number (but still includes the "pipe")
				//if shipmentNum &lt;&gt; null then
				//	transportId := transportId &amp; "|" &amp; shipmentNum;
				//endif;
				shipmentNumForDTD := "|" &amp; shipmentNum;
			elseif ti.releasedTransportMode = TI_TRANSMODE_SHIP then
				if ti.myVoyage.isBarge then
					transportType := TransportModeBarge;
					transportSequentialNumber := SequentialNumberRoad;		// ### TFS 57876 (58721) 20Jun2023 NAVPW1 - Not sure value for barge
				else
					transportType := TransportModeShip;
					transportSequentialNumber := SequentialNumberRoad;		// ### TFS 57876 (58721) 20Jun2023 NAVPW1 - Not sure value for ship
				endif;
				vehicleId := ti.voyageCode;
				vehicleId := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks , vehicleId, XLATION_TYPE_VOYAGETERMINAL, _camProtocol.terminal);
				etaDate := _camAgent.runDateTime.date.addDays(1).formatAsYYYYMMDD;
				transportId := vehicleId;									// TFS 57554
			endif;
			// MTN-33683 carrier no longer required
			//carrier := ti.releaseCarrier;
			//if carrier = null and bulkRelease &lt;&gt; null then
			//	carrier := bulkRelease.carrierId;
			//endif;
			//carrier := operator.getXlationForeignCode(carrier, XLATION_TYPE_CARRIER_BYOP, found);
			
			detailStr 	:= "2DTD:" &amp; 
							release[1:10].cnEcPadTrailing(10, Space.Character) &amp; 			// Sales Order (10 chars)	MTN-33683 truncate release number to 10
							//lineNumber.String.padLeadingZeros(6) &amp;						// Sales Order Item (6 chars)	// TFS 57542
							_camAgent.suzanoSeqNumber.padLeadingWith("0", 6) &amp;				// Sales Order Item (6 chars)	// TFS 57542
							ti.releasedDT.date.formatAsYYYYMMDD &amp;							// Delivery Date yyyymmdd
							//_camAgent.suzanoSeqNumber.padLeadingWith("0".Character, 2) &amp;	// Sequential Number (2 chars)
							transportSequentialNumber &amp;										// Sequential Number (2 chars) // ### TFS 57876 (58721) 20Jun2023 NAVPW1
							transportType &amp; 												// Transport Type
							vehicleId.cnEcPadTrailing(20, Space.Character) &amp;				// Vehicle id (20 chars)
							ti.totalWeight.Integer.asStringJMT.padLeadingZeros(16) &amp;		// Quantity 16 chars (tonnage with 3 dp, so just kg)
							"   " &amp; 														// Freight Currency (3 chars)
							"                " &amp;											// Freight Value (16 chars)
							transportId[1:20].cnEcPadTrailing(20, Space.Character) &amp;		// Terminal Control # (20 chars)	MTN-33683 now vehicle visit so Suzano / Enstructure can cross-reference IDs
							"1         " &amp;													// Carrier Code (10 chars)			MTN-33683 now just a "1"
							shipmentNumForDTD.cnEcPadTrailing(50, Space.Character) &amp;		// Shipment Id (50 chars)			MTN-33683 now just pipe and Shipment Id
							etaDate;														// ETA date yyyymmdd
							
			header := _camAgent.allSuzanoDeliveryHeaders["2DTD:", _camAgent.suzanoSeqNumber, vehicleId];	// TFS 59878
			if header = null then																			// TFS 59878
				create header transient;
				//header.setDetails(_transaction, "2DTD:", _camAgent.suzanoSeqNumber, vehicleId, transportType, detailStr, release, lineNumber.String);					// TFS 57542
				header.setDetails(_transaction, "2DTD:", _camAgent.suzanoSeqNumber, vehicleId, transportType, detailStr, release, _camAgent.suzanoSeqNumber.String);	// TFS 57542
				_camAgent.allSuzanoDeliveryHeaders.add(header);
				app.writeLog(method.qualifiedName &amp; Tab &amp; "1. Added header " &amp; header.getOidString &amp; " and detail " &amp; detailStr &amp; " to allSuzanoDeliveryHeaders for _transaction " &amp; _transaction.getOidString, LogDEBUG);
				detailWeight := null;
			// TFS 59878 more
			else
				detailWeight := header.message[56:16].Integer;
				app.writeLog("Setting detailWeight to " &amp; header.message[56:16] &amp; " from header " &amp; header.getOidString, LogDEBUG);
			endif;
			// TFS 59878 end of this bit
		endif;
		
		// detail line 
		// 2DEV: &amp; sales order &amp; sales order item &amp; delivery adte &amp; sequential number &amp; unit number &amp; quantity
		devStr := 	"2DEV:" &amp;
					release[1:10].cnEcPadTrailing(10, Space.Character) &amp; 					// Sales Order (10 chars)	MTN-33683 truncate release number to 10
					lineNumber.String.padLeadingZeros(6) &amp;									// Sales Order Item (6 chars)																// TFS 57542
					//bolCount.String.padLeadingZeros(6) &amp;									// Sales Order Item (6 chars) - actually a reflection of the number of BOLs in the release	// TFS 57542
					ti.releasedDT.date.formatAsYYYYMMDD &amp;									// Delivery Date yyyymmdd
					//_camAgent.suzanoSeqNumber.padLeadingWith("0".Character, 2) &amp;			// Sequential Number (2 chars)
					transportSequentialNumber &amp;												// Sequential Number (2 chars) // ### TFS 57876 (58721) 20Jun2023 NAVPW1
					ti.id[1:10].cnEcPadTrailing(10, Space.Character) &amp;						// Unit Number (10 chars)
					ti.totalWeight.rounded.asStringJMT.padLeadingZeros(16);					// Quantity 16 chars (tonnage delivered with 3 dp, so just kg)	// TFS 60589
					
		
		on Exception do self.handleDuplicateKey(exception, header.allDetails, duplicateKey);	// ### TFS 59186 (59100) 08Aug2023 NAVPW1
		
		create detail transient;
		//detail.setDetails(devStr, ti.id[1:10], _camAgent.suzanoSeqNumber.String, header);						// TFS 57542
		//detail.setDetails(devStr, ti.billOfLading, ti.id[1:10], _camAgent.suzanoSeqNumber.String, header);	// TFS 57542
		detail.setDetails(devStr, ti.billOfLading, ti.id, _camAgent.suzanoSeqNumber.String, header);			// TFS 60501
		
		if duplicateKey then
			duplicateKeyMsg := method.qualifiedName &amp; " Duplicate Key used: " &amp; ti.id[1:10] &amp; " | Tracked Item was not added to Suzano Delivery Communication message with Id: " &amp; ti.id &amp; " | Tracked Item id is too long for the message" &amp; Tab &amp; "Duplicate Key used";
			app.createAlert(duplicateKeyMsg, true);
			app.writeLog(duplicateKeyMsg, LogERROR);
			delete detail;
			duplicateKey := false;
		else
			detailWeight := detailWeight + ti.totalWeight.rounded;												// TFS 60589
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Added dev string " &amp; devStr &amp; " to header " &amp; header.getOidString &amp; ", detailWeight is " &amp; detailWeight.String, LogDEBUG);
		endif;
		
		on Exception do null;													// ### TFS 59186 (59100) 08Aug2023 NAVPW1
		
		lastRelease := release;
		lastReserveDetail := reserveDetail;
		lastBol := bol;						// TFS 57542
		lastTransportCode := vehicleId;			// TFS 59809
		lastLineNumber := _camAgent.suzanoSeqNumber;		// TFS 59858
	endwhile;
	
	// replace ti weight with total weight for the release
	if lastRelease &lt;&gt; null then
		header := _camAgent.allSuzanoDeliveryHeaders["2DTD:", _camAgent.suzanoSeqNumber, lastTransportCode];	// TFS 59809
		if header &lt;&gt; null then
			header.message[56:16] := detailWeight.asStringJMT.padLeadingZeros(16);
		endif;
	endif;
	
	// get the DTD / DEV sctions
	app.writeLog(method.qualifiedName &amp; Tab &amp; "processing event " &amp; _transaction.getOidString &amp; " - _camAgent has " &amp; _camAgent.allSuzanoDeliveryHeaders.size.String &amp; " headers", LogDEBUG);
	foreach header in _camAgent.allSuzanoDeliveryHeaders do
		app.writeLog(method.qualifiedName &amp; Tab &amp; "header " &amp; header.getOidString &amp; " is for event " &amp; header.myEventTransaction.getOidString &amp; ", _transaction is " &amp; _transaction.getOidString, LogDEBUG);
		app.writeLog(method.qualifiedName &amp; Tab &amp; "_camProtocol.isSingleTransPerFile is " &amp; _camProtocol.isSingleTransPerFile.String, LogDEBUG);
		if _camProtocol.isSingleTransPerFile and header.myEventTransaction &lt;&gt; _transaction then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Continuing", LogDEBUG);
			continue;
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "***** NOT Continuing *****", LogDEBUG);
		endif;
		dtdMsg := dtdMsg &amp; header.message &amp; Cr;
		messageCount := messageCount + header.allDetails.size + 1;
		foreach detail in header.allDetails do
			devMsg := devMsg &amp; detail.message &amp; Cr;
		endforeach;
	endforeach;
	
	// build the trailer
	trailStr := "9TRL:" &amp; (messageCount + 2).String.padLeadingZeros(4);
	
	// assemble the message
	message := headStr &amp; Cr &amp; dtdMsg &amp; devMsg &amp; trailStr;
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Adding " &amp; message &amp; " to camMessage type " &amp; camMessage.activity.String, LogDEBUG);
	self.addMessage(camMessage.group3, message);
	_camFile.incrementMessageCount();
	foreach idx in 1 to camMessage.group3.size do
		app.writeLog(method.qualifiedName &amp; Tab &amp; "camMessage.group3[" &amp; idx.String &amp; "] is " &amp; camMessage.group3[idx], LogDEBUG);
	endforeach;
	
epilog
	delete tisByRelease;
	delete releases;
	delete billsOfLading;		// TFS 57542
	delete iter;
end;</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
</Class>
