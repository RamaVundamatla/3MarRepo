    <JadeMethod name="buildMyPopupFormDef" id="4e9deaa7-c25a-4559-8888-3712a690aae4">
        <updating/>
        <source>buildMyPopupFormDef(_driverField:String) updating;
/*

Purpose:			Complete the build of the receiver from the formName

Parameters:			None

Return Value:		Self updated with all required build information


Date		Who		Reason
//17/09/2010 cnwdz2 par25439				
*/

vars
	rowsByNameDict	: DynaDictionary;
	entTableRow		: EntTableRow;
begin
	create rowsByNameDict transient;
	
	if self.formName = PreNotes then
		self.buildPrenoteRowByNameDict(rowsByNameDict);
		entTableRow := rowsByNameDict.getAtKey(ETRow_AllTIHazards).EntTableRow;		
		if entTableRow &lt;&gt; null and entTableRow.name = _driverField then 
			self.buildHazardsPopupGridPanel();			
		endif;
	endif;
epilog
	delete rowsByNameDict;
end;</source>
        <Parameter name="_driverField" type="String"/>
    </JadeMethod>
    <JadeMethod name="buildPreNoteDefinition_alt" id="0365d89e-5402-4c0d-92d1-3b85c9c514a0">
        <updating/>
        <source>buildPreNoteDefinition_alt() : WS_FormDefinitionResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2008	cnwkao1	Initial creation - this method is an alternative implementation of getPreNoteDefintion where we
					do not use our own dynadictionary to key the rows, but simply utilise the EntTableGroup.
					
					This is more efficient, but less explicit about where the rows are coming from (i.e. we access the rows 
					via the entTableDefinition in the other implementation).

*/
constants
	Main_Group_Desc			: String = "Main Details";
	Main_Group_Key			: String = "main";
	
	Voyage_Group_Desc		: String = "Voyage Details";
	Voyage_Group_Key		: String = "voyage";
	
	Port_Group_Desc			: String = "Port Details";				
	Port_Group_Key			: String = "port";
	
	
	Reefer_Chk_Group_Desc	: String = "Is Reefer";
	Reefer_Chk_Group_Key	: String = "isReefer";
	
	Dimen_Chk_Group_Desc	: String = "Dimensions";
	Dimen_Chk_Group_Key		: String = "dimensions";
	
vars	
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	dataStore		: String;
	resp			: WS_FormDefinitionResponse;
	mainRows		: StringArray;
	reefVisibleRows	: StringArray;
	reefToggleRows	: StringArray;	
	fieldDef		: WS_FieldDefinition;
	rowName			: String;
	readOnlyRows	: StringArray;
	voyageRows		: StringArray;
	portRows		: StringArray;
	dimensionRows	: StringArray; //new
	couRows			: StringArray; //new
	
begin
//	create resp transient;
//	resp.myFormDefinition		:= self;
	self.proxyClassName			:= WS_PreNoteUpdateRequest.name;	
	self.proxySearchClassName	:= WS_TrackedItem.name; 
	
	create mainRows transient;
	mainRows.add(ETRow_BookingReference);
	mainRows.add(ETRow_CargoType);
	mainRows.add(ETRow_IsoType); 
	mainRows.add(ETRow_IdTextBox); 	
	mainRows.add(ETRow_TransportMode); //+ KO - its required for creating pre-notes, unless we hardcode it to a specific mode type
	mainRows.add(ETRow_Commodity);
	mainRows.add(ETRow_WeightTotal);	
	mainRows.add(ETRow_SealNum);

	fieldDef := self.buildGroupHeader(Main_Group_Key, null, Main_Group_Desc); //hold above entries
	fieldDef.showTableColumn := Visibility_Invisible;
	
	create voyageRows transient;
	voyageRows.add(ETRow_ImexStatusString);
	voyageRows.add(ETRow_VoyageCode);
	voyageRows.add(ETRow_OperatorCode);
	voyageRows.add(ETRow_ShippingLineCode);

	fieldDef := self.buildGroupHeader(Voyage_Group_Key, null, Voyage_Group_Desc); //hold above entries
	fieldDef.showTableColumn := Visibility_Invisible;
	
	create portRows transient;
	portRows.add(ETRow_DischargePort); 
	portRows.add(ETRow_DestinationPort);
	portRows.add(ETRow_AllDischargePorts); //KO - optional ports
	portRows.add(ETRow_Consignor);
	portRows.add(ETRow_Consignee); 	
	portRows.add(ETRow_Carrier);		//KO - in spec, but not groupings
	
	
	fieldDef := self.buildGroupHeader(Port_Group_Key, null, Port_Group_Desc); //hold above entries
	fieldDef.showTableColumn := Visibility_Invisible;
		
	
	create reefVisibleRows transient;
	reefVisibleRows.add(ETRow_CarriageTempC);
	reefVisibleRows.add(ETRow_CoolingType);
	reefVisibleRows.add(ETRow_IsControlledAtmosphere);
	
	create reefToggleRows transient;
	reefToggleRows.add(ETRow_Oxygen);
	reefToggleRows.add(ETRow_CarbonDioxide);
	reefToggleRows.add(ETRow_Ventilation);
	
	/* KO - still need to finish
	create dimensionRows transient;
	dimensionRows.add(ETRow_Width);
	dimensionRows.add(ETRow_Height);
	dimensionRows.add(ETRow_Length);
	dimensionRows.add(ETRow_HasCOU);
	
	create couRows transient; //visibility is based on hasCOU
	couRows.add(ETRow_CouId);
	couRows.add(ETRow_CouISOType);
	couRows.add(ETRow_CouType);
	
	//parent for dimensionRows and couRows
	fieldDef := self.buildCheckableGroupHeader(Dimen_Chk_Group_Key, null, Dimen_Chk_Group_Desc);
	fieldDef.showTableColumn := Visibility_Invisible;
	*/
	
	create readOnlyRows transient;
	readOnlyRows.add(ETRow_BookingReference); //KO - JMT requested
	readOnlyRows.add(ETRow_CargoType);
	readOnlyRows.add(ETRow_TransportMode);
	readOnlyRows.add(ETRow_IdTextBox);
	readOnlyRows.add(ETRow_VoyageCode);
	
	fieldDef := self.buildCheckableGroupHeader(Reefer_Chk_Group_Key, null, Reefer_Chk_Group_Desc);
	fieldDef.showTableColumn := Visibility_Invisible;
	
	entTableGroup	:= CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_GateReceivals);
		
	//load each of the fields in order
	foreach rowName in mainRows do 
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName).EntTableRow;		
		if entTableRow &lt;&gt; null then //the trouble is that the main rows are included in all three tableDefs
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Main_Group_Key;
		endif;
	endforeach;
	
	
	foreach rowName in voyageRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName).EntTableRow;		
		if entTableRow &lt;&gt; null then 
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Voyage_Group_Key;
		endif;
	endforeach;
	
	foreach rowName in portRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName).EntTableRow;				
		if entTableRow &lt;&gt; null then 
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Port_Group_Key;
		endif;
	endforeach;
	
	
	foreach rowName in reefVisibleRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName).EntTableRow;			
		fieldDef := self.loadFieldFromRow(entTableRow);
		fieldDef.parent := Reefer_Chk_Group_Key;
		//fieldDef.visibilityToggleField := Reefer_Chk_Group; - Andrew didn't expect this value to be set when included in a checkable group header		
	endforeach;
	
	foreach rowName in reefToggleRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName).EntTableRow;	
		fieldDef := self.loadFieldFromRow(entTableRow);			
		fieldDef.parent := Reefer_Chk_Group_Key;
		fieldDef.visibilityToggleField := ETRow_IsControlledAtmosphere;
	endforeach;

	
	//set any additional details
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TransportMode);
	fieldDef.controlType	:= ControlType_ComboBox;
	
	foreach rowName in readOnlyRows do
		fieldDef := self.allFormFieldsByKey.getAtKey(rowName);
		fieldDef.readOnly	:= true;		
	endforeach;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_OperatorCode);
	fieldDef.dataReloadField := ETRow_VoyageCode;
	fieldDef.dataStore := JMTUserInterfaceService::getOperatorsForVoyage.name;
	
	
	return resp;	

	
epilog
	delete mainRows;
	delete reefVisibleRows;
	delete reefToggleRows;
	delete readOnlyRows;
	delete portRows;
	delete voyageRows;
	
end;</source>
        <ReturnType type="WS_FormDefinitionResponse"/>
    </JadeMethod>
    <JadeMethod name="buildPreNoteFormDefinition" id="d2b9f9cc-1785-4d08-8e6f-4e0dd8d636be">
        <updating/>
        <source>buildPreNoteFormDefinition() updating;

/*

Purpose:			Build the form definition for the PreNotes form

Parameters:			None

Return Value:		None


Date		Who		Reason
01 Sep 2008	cnwkao1	Initial creation - WS_FormDefinition::buildPreNoteDefinition_alt is an alternative approach,
					retrieving the ETRows from the Group rather than from the exact definition.
23 Dec 2008	cnwkpd1	PAR #17554 - Add dependency between ISO Type and Cargo Type 
14 Jun 2013	cnwdap1	PAR #31800 Extra fields for Portus JAX
17 Jun 2013	cnwdap1	PAR #31700 Added Number of Items for break bulk cargo
24 Sep 2013	cnwdap1	PAR #32215 CCMS DPH 2290 Nnew Car Attributes
05 Mar 2014	cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
28 Jul 2015	cnwdap1	PAR #36682 Added Expiry Date field in Reefer section
26 Sep 2016 cnwma1  TFS #2740 PAR #38255 POL - RIA - unable to enter negative temperatures in Reefer fields
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/

constants
	Hidden_Group_Key		: String = "prenote_hidden";
	
	Main_Group_Desc			: String = "Main Details";
	Main_Group_Key			: String = "main";
	
	//Voyage_Group_Desc		: String = "Voyage Details";
	//Voyage_Group_Key		: String = "voyage";
	
	Port_Group_Desc			: String = "Port Details";				
	Port_Group_Key			: String = "port";
	
	
	/*Reefer_Chk_Group_Desc	: String = "Is Reefer";
	Reefer_Chk_Group_Key	: String = "isReefer";*/

	Reefer_Group_Desc		: String = "Reefer Details";
	Reefer_Group_Key		: String = "reefer";
	
	
	Dimen_Chk_Group_Desc	: String = "Dimensions";
	Dimen_Chk_Group_Key		: String = "dimensions";
	
	Extra_Group_Desc		: String = "Extra Details";
	Extra_Group_Key			: String = "extra";
	
	Vehicle_Group_Desc		: String = "Vehicle Details";					// PAR #32215
	Vehicle_Group_Key		: String = "vehicle";							// PAR #32215
	
vars	
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	dataStore		: String;
	resp			: WS_FormDefinitionResponse;
	mainRows		: StringArray;
	extraRows		: StringArray;
	//reefVisibleRows	: StringArray;
	reeferRows		: StringArray;
	reefToggleRows	: StringArray;	
	fieldDef		: WS_FieldDefinition;
	rowsByNameDict	: DynaDictionary;
	rowName			: String;
	hiddenRows		: StringArray;
	readOnlyRows	: StringArray;
	//voyageRows		: StringArray;
	portRows		: StringArray;
	dimensionRows	: StringArray; //new
	couRows			: StringArray; //new
	numericFields	: StringArray; //new
	//defImexStatus	: CM_IMEXStatus; 
	//defCargoType	: CM_CargoType;
	madatoryFields	: StringArray;
	//defNullVoayge	: CM_Voyage;
	isSubTerminalsOn: Boolean;
	currentDate     : Date;
	currentTime     : Time;
	formLayout		: WS_FormLayout;
	visibleField    : String;
	//cnwmc5 - PAR 325465 - 13 Sep 2013
	sealType 		: CM_SealType;
	vehicleRows		: StringArray;									// PAR #32215
	
	a:Integer;
begin
	self.proxyClassName			:= WS_PreNoteUpdateRequest.name;	
	self.proxySearchClassName	:= WS_TrackedItem.name; 
	
	self.buildHiddenGroup(Hidden_Group_Key);
	create hiddenRows transient;
	hiddenRows.add(WS_ProxyObject::cmObjectId.name);
	hiddenRows.add(WS_ProxyObject::cmObjectEdition.name);
	hiddenRows.add(ETRow_MyBookingRefItem);
	hiddenRows.add(ETRow_CreationDateTime);
	
	foreach rowName in hiddenRows do
		self.buildHiddenField(rowName,Hidden_Group_Key);
	endforeach;
	
	create mainRows transient;
	mainRows.add(ETRow_BookingReference);							//cnwmc5 - 30 April 2014 - PAR 33988
	mainRows.add(ETRow_CargoType);
	//cnwmc5 - PAR 32450 - moved below cargo type
	mainRows.add(ETRow_MyProduct); //18/03/2010 cnwdz2 23232
	mainRows.add(ETRow_IsoType);									//cnwmc5 - 30 April 2014 - PAR 33988
	mainRows.add(ETRow_IdTextBox);
	mainRows.add(ETRow_WeightTotal);
	
	//epr TFS 1882 18/5/16
	mainRows.add(ETRow_IsWeightCertified);
	mainRows.add(ETRow_WeightCertifiedBy);
	mainRows.add(ETRow_WeightAuthorisedBy);
	
	mainRows.add(ETRow_VolumeTotal);	
	//cnwmc5 - 23 April 2014 - PAR 33988
	//mainRows.add(ETRow_NumItems);				// PAR #31700		//cnwmc5 - 23 April 2014 - PAR 33988
	mainRows.add(ETRow_TotalQuantity);								//cnwmc5 - 23 April 2014 - PAR 33988
	mainRows.add(ETRow_AlternativeId); 	//03 May 2013	NDL	Par 31506
	mainRows.add(ETRow_ImexStatusString);
	mainRows.add(ETRow_TransportMode); //+ KO - its required for creating pre-notes, unless we hardcode it to a specific mode type	
	mainRows.add(ETRow_VoyageCode);
	mainRows.add(ETRow_OperatorCode);
	mainRows.add(ETRow_DischargePort); 
	mainRows.add(ETRow_Commodity);	
	mainRows.add(ETRow_PinNo);
	
	//cnwmc5 - PAR 32465 - 13 Sep 2013 - checking against system seals table
	if not app.myRoot.allSealTypes["OPER"].notAvailableForEntry then
		mainRows.add(ETRow_SealNum);
	endif;
	
	//cnwmc5 - 22/01/2013 - CCMS 2238 - PAR #30765
	//cnwmc5 - PAR 32465 - 13 Sep 2013 - further checking against system seals table
	if not app.myRoot.allSealTypes["SHIP"].notAvailableForEntry then
		mainRows.add(ETRow_SealNumShippers);
	endif;
	if not app.myRoot.allSealTypes["VENT"].notAvailableForEntry then	
		mainRows.add(ETRow_SealNumVent);
	endif;
	if not app.myRoot.allSealTypes["CUST"].notAvailableForEntry then
		mainRows.add(ETRow_SealNumCustoms);
	endif;
	if not app.myRoot.allSealTypes[SealType_TerminalOperator].notAvailableForEntry then
		mainRows.add(ETRow_SealNumTerminalOperator);
	endif;
	if not app.myRoot.allSealTypes[SealType_Unknown].notAvailableForEntry then
		mainRows.add(ETRow_SealNumUnknown);
	endif;
	
	//14/06/2010 cnwdz2 par23027
	mainRows.add(ETRow_AllTIHazards);
	mainRows.add(ETRow_Remarks);
	mainRows.add(ETRow_ExpectedArrivalDate);
	mainRows.add(ETRow_ExpectedArrivalTime);	
	
	mainRows.add(ETRow_ClientRef);										// PAR #31800
	mainRows.add(ETRow_Colour);											// PAR #31800
	mainRows.add(ETRow_ItemDesc);									// PAR #31800
	mainRows.add(ETRow_Wagon);											// cnwmc5 - 24 June 2016 - TFS 2183
	
	fieldDef := self.buildGroupHeader(Main_Group_Key, null, Main_Group_Desc); //hold above entries
	fieldDef.showTableColumn := Visibility_Unavailable;

	create portRows transient;
	portRows.add(ETRow_DestinationPort);
	portRows.add(ETRow_Mark); //29/06/2011 cnwdz2 27784
	portRows.add(ETRow_MarkNumber);										// PAR #31800
	portRows.add(ETRow_AllDischargePorts); //KO - optional ports
	portRows.add(ETRow_Consignor);
	portRows.add(ETRow_Consignee); 		
	portRows.add(ETRow_Carrier);		//KO - in spec, but not groupings
	
	
	fieldDef := self.buildGroupHeader(Port_Group_Key, null, Port_Group_Desc); //hold above entries
	fieldDef.showTableColumn := Visibility_Unavailable;
		
	create reeferRows transient;
	reeferRows.add(ETRow_CarriageTempC);
	//25/05/2009 cnwdz2 par19748
	reeferRows.add(ETRow_PackTempC);
	reeferRows.add(ETRow_PackDate);
	reeferRows.add(ETRow_PackTime);
	reeferRows.add(ETRow_AllowableTimeOffPower);
	
	reeferRows.add(ETRow_Ventilation);
	reeferRows.add(ETRow_Humidity);
	reeferRows.add(ETRow_CoolingType);
	reeferRows.add(ETRow_Oxygen);  //added here for par 15301
	reeferRows.add(ETRow_CarbonDioxide); //added here for par 15301
	
	reeferRows.add(ETRow_ExpiryDate);			// PAR #36682
	
	fieldDef := self.buildGroupHeader(Reefer_Group_Key, null, Reefer_Group_Desc);
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	///* KO - still need to finish - JMT picking up this work now
	create dimensionRows transient;
	dimensionRows.add(ETRow_Width);
	dimensionRows.add(ETRow_Height);
	dimensionRows.add(ETRow_Length);
	//dimensionRows.add(ETRow_Volume); //26/08/2010 cnwdz2 25440		//cnwmc5 - 23 April 2014 - PAR 33988
	
	fieldDef := self.buildGroupHeader(Dimen_Chk_Group_Key, null, Dimen_Chk_Group_Desc);
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	create extraRows transient;
	isSubTerminalsOn := app.isSubTerminalsOn(app.myPassport.myTerminal);
	if isSubTerminalsOn then
		extraRows.add(ETRow_MySubTerminal);
	endif;

	extraRows.add(ETRow_HasAttachments);
	extraRows.add(ETRow_PurchaseOrder);													// PAR #33193
	extraRows.add(ETRow_ServiceOrder);													// PAR #33193
	
	fieldDef := self.buildGroupHeader(Extra_Group_Key, null, Extra_Group_Desc);
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	create vehicleRows transient;														// PAR #32215
	vehicleRows.add(ETRow_Make);														// PAR #32215
	vehicleRows.add(ETRow_Model);														// PAR #32215
	vehicleRows.add(ETRow_VehicleType);													// PAR #32215
	vehicleRows.add(ETRow_Year);														// PAR #32215
	vehicleRows.add(ETRow_TrackingNumber1);												// PAR #32215
	vehicleRows.add(ETRow_TrackingNumber2);												// PAR #32215
	vehicleRows.add(ETRow_DocsReceived);												// PAR #32215
	vehicleRows.add(ETRow_DocsSent);													// PAR #32215
	vehicleRows.add(ETRow_DocsCleared);													// PAR #32215
	vehicleRows.add(ETRow_DocsReturned);												// PAR #32215
	vehicleRows.add(ETRow_IsSelfPropelled);	//cnwmc5 - PAR 32680						// PAR #32215
	vehicleRows.add(ETRow_Doors);														// PAR #32215
	vehicleRows.add(ETRow_NewVehicle);													// PAR #32215
	fieldDef := self.buildGroupHeader(Vehicle_Group_Key, null, Vehicle_Group_Desc);		// PAR #32215
	fieldDef.showTableColumn := Visibility_Unavailable;									// PAR #32215
	
	create numericFields transient;
	numericFields.add(ETRow_WeightTotal);
	numericFields.add(ETRow_CarriageTempC);
	numericFields.add(ETRow_PackTempC);
	numericFields.add(ETRow_AllowableTimeOffPower);
	numericFields.add(ETRow_Oxygen);
	numericFields.add(ETRow_CarbonDioxide);
	numericFields.add(ETRow_Ventilation);
	numericFields.add(ETRow_Humidity);  //cnwjo3 par 19554
	numericFields.add(ETRow_Width);
	numericFields.add(ETRow_Height);
	numericFields.add(ETRow_Length);
	//numericFields.add(ETRow_Volume); //26/08/2010 cnwdz2 25440
	//numericFields.add(ETRow_NumItems);								// PAR #31700
	numericFields.add(ETRow_Year);														// PAR #32215
	numericFields.add(ETRow_Doors);														// PAR #32215
	numericFields.add(ETRow_VolumeTotal);								//cnwmc5 - 23 April 2014 - PAR 33988
	numericFields.add(ETRow_TotalQuantity);								//cnwmc5 - 23 April 2014 - PAR 33988

	//06/07/2009 cnwdz2 par 20233
	
	create madatoryFields transient;
	madatoryFields.add(ETRow_CargoType);
	madatoryFields.add(ETRow_IdTextBox);
	madatoryFields.add(ETRow_IsoType);
	madatoryFields.add(ETRow_TransportMode);
	madatoryFields.add(ETRow_MyProduct);
	madatoryFields.add(ETRow_Commodity);
	if isSubTerminalsOn then
		madatoryFields.add(ETRow_MySubTerminal);
	endif;
	madatoryFields.add(ETRow_VoyageCode);
	madatoryFields.add(ETRow_OperatorCode);
	madatoryFields.add(ETRow_DischargePort);
	madatoryFields.add(ETRow_WeightTotal);
	
	create readOnlyRows transient;
	readOnlyRows.add(ETRow_BookingReference); //KO - JMT requested
	readOnlyRows.add(ETRow_CarriageTempC);
	readOnlyRows.add(ETRow_CargoType);
	readOnlyRows.add(ETRow_IsoType);
	readOnlyRows.add(ETRow_ImexStatusString);
	readOnlyRows.add(ETRow_VoyageCode);
	readOnlyRows.add(ETRow_Ventilation);
	readOnlyRows.add(ETRow_OperatorCode);
	readOnlyRows.add(ETRow_DischargePort);
	readOnlyRows.add(ETRow_Commodity);
	//readOnlyRows.add(ETRow_Consignor);		//cnwmc5 - 22 Oct 2013 - PAR 32274
	readOnlyRows.add(ETRow_PinNo);
	readOnlyRows.add(ETRow_AlternativeId); 	//03 May 2013	NDL	Par 31506
	
	//the collections of rows aren't keyed - so building a dict of names
	create rowsByNameDict transient;
	self.buildPrenoteRowByNameDict(rowsByNameDict);//17/09/2010 cnwdz2 par25439
	
	
	//load each of the fields in order
	foreach rowName in mainRows do 
		entTableRow := rowsByNameDict.getAtKey(rowName).EntTableRow;		
		if entTableRow &lt;&gt; null then //the trouble is that the main rows are included in all three tableDefs
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Main_Group_Key;
		endif;
	endforeach;
	
	foreach rowName in portRows do
		entTableRow := rowsByNameDict.getAtKey(rowName).EntTableRow;		
		if entTableRow &lt;&gt; null then 
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Port_Group_Key;
		endif;
	endforeach;
	
	foreach rowName in reeferRows do
		entTableRow := rowsByNameDict.getAtKey(rowName).EntTableRow;		
		fieldDef := self.loadFieldFromRow(entTableRow);
		fieldDef.parent := Reefer_Group_Key;
		//fieldDef.visibilityToggleField := Reefer_Chk_Group; - Andrew didn't expect this value to be set when included in a checkable group header		
	endforeach;	
	
	foreach rowName in dimensionRows do
		entTableRow := rowsByNameDict.getAtKey(rowName).EntTableRow;		
		fieldDef := self.loadFieldFromRow(entTableRow);
		fieldDef.parent := Dimen_Chk_Group_Key;
		//fieldDef.visibilityToggleField := Reefer_Chk_Group; - Andrew didn't expect this value to be set when included in a checkable group header		
	endforeach;
	
	foreach rowName in extraRows do
		entTableRow := rowsByNameDict.getAtKey(rowName).EntTableRow;		
		fieldDef := self.loadFieldFromRow(entTableRow);
		fieldDef.parent := Extra_Group_Key;
		//fieldDef.visibilityToggleField := Reefer_Chk_Group; - Andrew didn't expect this value to be set when included in a checkable group header		
	endforeach;
		
	foreach rowName in vehicleRows do													// PAR #32215
		entTableRow := rowsByNameDict.getAtKey(rowName).EntTableRow;					// PAR #32215
		fieldDef := self.loadFieldFromRow(entTableRow);									// PAR #32215
		fieldDef.parent := Vehicle_Group_Key;											// PAR #32215
	endforeach;																			// PAR #32215
		
	//07/07/2009 cnwdz2 par 20233
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TransportMode);
	fieldDef.controlType	:= self.ControlType_ComboBox;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_AllTIHazards);
	fieldDef.controlType	:= self.ControlType_Custom_GridPanel;
	fieldDef.storeDescriptionField	:= WS_TIHazard::code.name;
	fieldDef.storeIdField	:= WS_TIHazard::code.name;			//cnwmc5 - 9 March 2015 - PAR 34346
	
	foreach rowName in readOnlyRows do
		fieldDef := self.allFormFieldsByKey.getAtKey(rowName);
		fieldDef.readOnly	:= true;	
	endforeach;
		
	foreach rowName in numericFields do
		fieldDef := self.allFormFieldsByKey.getAtKey(rowName);
		fieldDef.controlType := ControlType_NumericField;
	endforeach;
	
	//cnwmc5 - 26 Sep 2016 -  TFS #2740 PAR #38255
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CarriageTempC);
	fieldDef.controlType := ControlType_NegNumericField;
	// cnwma1 26 Sep 2016 - TFS #2740 PAR #38255
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_PackTempC);
	fieldDef.controlType := ControlType_NegNumericField;

	//set any additional details
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_PinNo);
	fieldDef.isHiddenInThumbnail := true;
	
	// Operator is dependent on Voyage
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_OperatorCode);
	fieldDef.dataReloadField := ETRow_VoyageCode;
	fieldDef.dataStore := JMTUserInterfaceService::getOperatorsForVoyage.name;
	
	// Discharge Port is dependent on Shipping Line
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_DischargePort);
	fieldDef.dataReloadField := ETRow_VoyageCode;
	fieldDef.dataStore := JMTUserInterfaceService::getPortsForVoyage.name;
	
	// ISO Type is dependent on Cargo Type
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsoType);
	fieldDef.dataReloadField := ETRow_CargoType;
	fieldDef.dataStore := JMTUserInterfaceService::getISOTypesForCargoType.name;
	
	//18/03/2010 cnwdz2 23232
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_MyProduct);
	fieldDef.dataReloadField := ETRow_CargoType;
	fieldDef.dataStore := JMTUserInterfaceService::getCargoSubtypesForCargoType.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_BookingReference);
	fieldDef.dataStore := JMTUserInterfaceService::getPrenoteFromBookingRef.name;	
	fieldDef.repeatedStoreField := WS_PrenoteFromBookRef.name;
	fieldDef.isUppercaseText := true;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IdTextBox);
	fieldDef.dataStore := JMTUserInterfaceService::getPrenoteFromCargoId.name;	
	fieldDef.repeatedStoreField := WS_PrenoteFromCargoId.name;
	fieldDef.readOnly			:= true;
	fieldDef.initialFieldForSaveNext := true;
	
	//20/12/2011 cnwdz2 par27891
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Remarks);
	fieldDef.controlType := ControlType_MultiTextBox;
	
	//reeferRows.add(ETRow_PackTime);
	//today := app.actualTimeServer.date;
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_PackDate);
	fieldDef.defaultId := currentDate.asStringJMT();
	fieldDef.defaultDescription := currentDate.asStringJMT();
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_PackTime);
	fieldDef.defaultId := currentTime.asStringJMT();
	fieldDef.defaultDescription := currentTime.asStringJMT();
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_HasAttachments);
	fieldDef.controlType := ControlType_Custom_Attachments;
	//fieldDef.showTableColumn := Visibility_Unavailable;
	
	//20/12/2011 cnwdz2	par27891
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_SealNum);
	if fieldDef &lt;&gt; null then
		fieldDef.maxTextLength := WS_TrackedItem::sealNum.length;
	endif;

	//cnwmc5 - 22/01/2013 - CCMS 2238 - PAR #30765
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_SealNumShippers);
	if fieldDef &lt;&gt; null then
		fieldDef.maxTextLength := WS_TrackedItem::sealNumShippers.length;
	endif;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_SealNumCustoms);
	if fieldDef &lt;&gt; null then
		fieldDef.maxTextLength := WS_TrackedItem::sealNumCustoms.length;
	endif;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_SealNumVent);
	if fieldDef &lt;&gt; null then
		fieldDef.maxTextLength := WS_TrackedItem::sealNumVent.length;
	endif;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_PurchaseOrder);				// PAR #33193
	if fieldDef &lt;&gt; null then														// PAR #33193
		fieldDef.maxTextLength := WS_TrackedItem::purchaseOrder.length;				// PAR #33193
	endif;																			// PAR #33193
																					// PAR #33193
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ServiceOrder);				// PAR #33193
	if fieldDef &lt;&gt; null then														// PAR #33193
		fieldDef.maxTextLength := WS_TrackedItem::serviceOrder.length;				// PAR #33193
	endif;																			// PAR #33193
	
	//cnwmc5 - 23 April 2014 - PAR 33988
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TotalQuantity);
	fieldDef.key := WS_TrackedItem::totalQuantity.name;
	
	//cnwmc5 - 30 April 2014 - PAR 33988
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_VolumeTotal);
	fieldDef.key := WS_TrackedItem::volume.name;
	
	//epr TFS 2378 18/7/16
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_WeightTotal);					
	if fieldDef &lt;&gt;  null and not app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmAdmWeightOverride) then
		fieldDef.readOnly := true;	
	endif;
	
	//epr tfs 1883 17/5/16
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_WeightAuthorisedBy);
	fieldDef.key := WS_PreNoteUpdateRequest::weightCertifiedName.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_WeightCertifiedBy);
	fieldDef.key := WS_PreNoteUpdateRequest::weightCertifiedReference.name;
	//06/07/2009 cnwdz2 par 20233
	self.buildMandatoryFields(madatoryFields);
	
epilog
	delete hiddenRows;
	delete mainRows;
	delete extraRows;
	delete reeferRows;
	delete reefToggleRows;
	delete rowsByNameDict;
	delete readOnlyRows;
	delete dimensionRows;
	delete couRows;
	delete numericFields;
	delete portRows;
	delete madatoryFields;
	delete vehicleRows;																	// PAR #32215
end;</source>
    </JadeMethod>
    <JadeMethod name="buildPreNoteFormLayout" id="4badfba2-a4cd-462d-8196-0407855b3066">
        <updating/>
        <source>buildPreNoteFormLayout(_layoutDriverName : String; _fieldValue : String) updating;

/*

Purpose:			Build the form definition for the PreNotes form

Parameters:			None

Return Value:		None


Date		Who		Reason
01 Sep 2008	cnwkao1	Initial creation - WS_FormDefinition::buildPreNoteDefinition_alt is an alternative approach,

*/

constants

vars	
	rowsByNameDict	: DynaDictionary;
	entTableRow		: EntTableRow;
begin
	create rowsByNameDict transient;
	self.buildPrenoteRowByNameDict(rowsByNameDict);
	
	create self.myFormLayout transient;
	
	if _layoutDriverName = ETRow_CargoType then
		if _fieldValue.Integer = 1 then
			entTableRow := rowsByNameDict.getAtKey(ETRow_Volume).EntTableRow;		
			if entTableRow &lt;&gt; null then //the trouble is that the main rows are included in all three tableDefs
				self.myFormLayout.hiddenfields.add(entTableRow.name);
			endif;
			
			entTableRow := rowsByNameDict.getAtKey(ETRow_MyProduct).EntTableRow;		
			if entTableRow &lt;&gt; null then //the trouble is that the main rows are included in all three tableDefs
				self.myFormLayout.hiddenfields.add(entTableRow.name);
			endif;
		endif;
	endif;
epilog
	delete rowsByNameDict;
end;</source>
        <Parameter name="_layoutDriverName" type="String"/>
        <Parameter name="_fieldValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="buildPreNoteSearchFormDef" id="1da8d1d9-ded6-4e8a-bb8b-fcffb25aec57">
        <updating/>
        <source>buildPreNoteSearchFormDef() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2008	cnwkao1	Initial creation

*/
constants
	Parent_Column1	: String = "column1";
	Parent_Column2	: String = "column2";
	
vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;	
	fieldDef		: WS_FieldDefinition;
	column1Rows		: StringArray; //perhaps a more appropriate collection should be used
	column2Rows		: StringArray;
	parent			: String;
	rowName			: String;
	
begin
	self.proxyClassName			:= WS_TrackedItemQueryRequest.name;
	self.proxySearchClassName	:= WS_TrackedItem.name;
	self.primarySearchLabel	    := "Pre-Notes ";
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_GateReceivals);
	
	//get the applicable definition
	entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_PreNoteFind);
	
	create column1Rows transient;
	//column1Rows.add(ETRow_FilterTransportMode);			//filterId
	//column1Rows.add(ETRow_FilterId);			//filterId
	column1Rows.add(ETRow_FilterId);			//filterId
	column1Rows.add(ETRow_FilterOperator);		//filterOperator
	column1Rows.add(ETRow_FilterPIN);			//filterPIN
	column1Rows.add(ETRow_FilterIMEXStatus);	//filterIMEXStatus
	//column1Rows.add(ETRow_FilterBookingRef);	//filterBookingRef - promoted to the primary search
	self.buildGroupHeader(Parent_Column1, null, null); //hold above entries
	
	
	create column2Rows transient;
	column2Rows.add(ETRow_FilterDateFrom);		//filterDateFrom
	column2Rows.add(ETRow_FilterDateTo);		//filterDateTo
	column2Rows.add(ETRow_FilterConsignee);		//filterConsignee
	column2Rows.add(ETRow_FiltConsignor);		//filtConsignor
	self.buildGroupHeader(Parent_Column2, null, null); //hold above entries
			
	//setup each row
	foreach entTableRow in entTableDef.allEntTableRows do
		fieldDef := self.loadFieldFromRow(entTableRow);	
	endforeach;
	
	//set any additional details
	foreach rowName in column1Rows do
		fieldDef := self.allFormFieldsByKey.getAtKey(rowName);
		fieldDef.parent := Parent_Column1;
	endforeach;
	
	foreach rowName in column2Rows do
		fieldDef := self.allFormFieldsByKey.getAtKey(rowName);
		fieldDef.parent := Parent_Column2;
	endforeach;
	
	entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(ETRow_FilterTransportMode);
	fieldDef := self.loadFieldFromRow(entTableRow);			
	fieldDef.parent := Parent_Column1;
	//fieldDef.defaultId	:= TI_TRANSMODE_ROAD_STR;
	//fieldDef.defaultDescription := TI_TRANSMODE_ROAD_STR;	
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FiltConsignor);
	fieldDef.key := WS_TrackedItemQueryRequest::filterConsignor.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterIMEXStatus);
	fieldDef.key := WS_TrackedItemQueryRequest::filterIMEX.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterId);
	fieldDef.isUppercaseText := true;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterBookingRef);
	fieldDef.isUppercaseText := true;
	
epilog
	delete column1Rows;
	delete column2Rows;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildPreferencesFormDef" id="a01e09f6-ab6c-4cd4-a157-6f2f971ef8b9">
        <updating/>
        <source>buildPreferencesFormDef() updating;

/*

Purpose:			Build the form definition for the preferences form

Parameters:			None

Return Value:		None


Date		Who		Reason
3 Feb 2009	cnwdz2	PAR #17554 

*/

constants

vars	
	entTableGroup	: EntTableGroup;
	resp			: WS_FormDefinitionResponse;
	fieldDef		: WS_FieldDefinition;
	rowName			: String;
	mainRows	: StringArray;
	entTableRow		: EntTableRow;
begin
	self.proxyClassName			:= WS_PreferenceUpdateRequest.name;	
	self.proxySearchClassName	:= WS_PreferenceResponse::preference.name; 	

	create mainRows transient;
	mainRows.add(ETRow_Terminal); 		
	
	//consolidate all the rows we are interested in - for this form they are spread throughout three table definitions
	entTableGroup	:= CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_GateReceivals);
	
	foreach rowName in mainRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then 
			fieldDef := self.loadFieldFromRow(entTableRow);	
		endif;
	endforeach;
	

epilog
	delete mainRows;	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildPrenoteRowByNameDict" id="cc9ee88f-6695-4ca1-8772-953bfe9e2c5c">
        <source>buildPrenoteRowByNameDict(rowsByNameDict : DynaDictionary io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2010	#cnwdz2	 

*/

vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
begin
	rowsByNameDict.setMembership(EntTableRow);
	rowsByNameDict.addMemberKey(EntTableRow::name.name, true, false);
	rowsByNameDict.endKeys(false);
	
	
	//consolidate all the rows we are interested in - for this form they are spread throughout three table definitions
	entTableGroup	:= CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_GateReceivals);
	entTableDef		:= entTableGroup.allEntTableDefsByName.getAtKey(ETDef_InMain);
	foreach entTableRow in entTableDef.allEntTableRows do
		rowsByNameDict.add(entTableRow);		
	endforeach;
	
	entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_PreNoteDataTbl);
	foreach entTableRow in entTableDef.allEntTableRows do
		if rowsByNameDict.getAtKey(entTableRow.name) = null then //disallow dups, for whatever reason they duplicate their rows
			rowsByNameDict.add(entTableRow);		
		endif;
	endforeach;
	
	entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_InExtra);
	foreach entTableRow in entTableDef.allEntTableRows do
		if rowsByNameDict.getAtKey(entTableRow.name) = null then 
			rowsByNameDict.add(entTableRow);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="rowsByNameDict" type="DynaDictionary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="buildReleaseImportFormDef" id="45105841-1e03-46f8-a7ab-5a31bcb1f924">
        <updating/>
        <source>buildReleaseImportFormDef() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2008	cnwkao1	Initial creation
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
constants
	Parent_Main_Key		: String = "main";
	Parent_Main_Desc	: String = "Main Details";
	
	Parent_Misc_Key		: String = "misc";
	Parent_Misc_Desc	: String = "Miscellaneous Details"; 
	
	//Parent_Stop_Key		: String = "stop";
	//Parent_Stop_Desc	: String = "Stops"; 
	
vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	mainRowNames	: StringArray;
	thumbRowNames	: StringArray;
	tblDataRowNames	: StringArray;
	fieldDef		: WS_FieldDefinition;
	rowsByNameDict	: DynaDictionary;
	rowName			: String;
	stopTable		: CM_StopsTable;
	
begin
	self.proxyClassName				:= WS_ReleaseImportUpdateRequest.name; // used by SOAP parser to create the correct type
	self.proxySearchClassName		:= WS_TrackedItem.name;

	
	/* - other candidates...
	ETDef_CargoEnqDefaultData
	ETDef_DefaultDataTable
	*/
	
	
	//get the applicable definition
	//ETDef_FullReleaseMain
	create mainRowNames transient;
	mainRowNames.add(ETRow_ReleaseCarrier);
	mainRowNames.add(ETRow_FreightForwarder);
	mainRowNames.add(ETRow_DeliveryReleaseNumber);
	mainRowNames.add(ETRow_CustomsEntryNumber);	
	//mainRowNames.add(ETRow_CustomsEntryCheckNo);
	mainRowNames.add(ETRow_MyCustomsAgent);
	mainRowNames.add(ETRow_CarrierRemarks);
	mainRowNames.add(ETRow_Remarks);
	//mainRowNames.add(ETRow_GeneratePinNo); //apparently gives you a new pin no... conflicts with pin no row
	
	//get the applicable definition
	//ETDef_FullReleaseThumb
	create thumbRowNames transient;
	thumbRowNames.add(ETRow_OverDimension);
	thumbRowNames.add(ETRow_PinNo);
	thumbRowNames.add(ETRow_CargoId);
	thumbRowNames.add(ETRow_OperatorCode);
	
	//get the applicable definition
	//ETDef_FullReleaseTblData
	create tblDataRowNames transient;
	//tblDataRowNames.add(ETRow_MyPinNo);
	//tblDataRowNames.add(ETRow_ContainerNumber);
	//tblDataRowNames.add(ETRow_OperatorCode);
	tblDataRowNames.add(ETRow_VoyageCode);
	//tblDataRowNames.add(ETRow_VoyageArrival);
	//tblDataRowNames.add(ETRow_CarrierCode); 11/06/2009 cnwdz2 par19885
	//tblDataRowNames.add(ETRow_ReleaseCarrier);
	tblDataRowNames.add(ETRow_Consignee);
	tblDataRowNames.add(ETRow_LoadPort);
	tblDataRowNames.add(ETRow_ToDoTasks);
	tblDataRowNames.add(ETRow_IsoTypeCode);
	tblDataRowNames.add(ETRow_CommodityGroup);
	tblDataRowNames.add(ETRow_CommodityGroupDesc);
	tblDataRowNames.add(ETRow_WeightTotal);
	//tblDataRowNames.add(ETRow_DeliveryReleaseNumber);
	//tblDataRowNames.add(ETRow_CarrierRemarks);
	//tblDataRowNames.add(ETRow_Remarks);
	tblDataRowNames.add(ETRow_Consignor);
	//tblDataRowNames.add(ETRow_Location); - not including this either see self.myTerminal.availableLocationsForType(tmpLCSearch, self.allToLocations, TA_TYPE_LOGAREA);
	tblDataRowNames.add(ETRow_CargoType);
	//tblDataRowNames.add(ETRow_ProductType); - not including this one
	tblDataRowNames.add(ETRow_BillOfLading);
	//tblDataRowNames.add(ETRow_FreightForwarderCode);
	
	//the collections of rows aren't keyed - so building a dict of names
	create rowsByNameDict transient;
	rowsByNameDict.setMembership(EntTableRow);
	rowsByNameDict.addMemberKey(EntTableRow::name.name, true, false);
	rowsByNameDict.endKeys(false);
	
	
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance().allEntTableGroups.getAtKey(ETGrp_GateReceivals);
	entTableDef		:= entTableGroup.allEntTableDefsByName.getAtKey(ETDef_FullReleaseMain);
	foreach entTableRow in entTableDef.allEntTableRows do
		rowsByNameDict.add(entTableRow);		
	endforeach;
	
	entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_FullReleaseThumb);
	foreach entTableRow in entTableDef.allEntTableRows do
		if rowsByNameDict.getAtKey(entTableRow.name) = null then //disallow dups, for whatever reason they duplicate their rows
			rowsByNameDict.add(entTableRow);		
		endif;
	endforeach;
	
	entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_FullReleaseTblData);
	foreach entTableRow in entTableDef.allEntTableRows do
		if rowsByNameDict.getAtKey(entTableRow.name) = null then 
			rowsByNameDict.add(entTableRow);
		endif;
	endforeach;

	//setup each row
	fieldDef := self.buildGroupHeader(Parent_Main_Key, null, Parent_Main_Desc);
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	foreach rowName in mainRowNames do
		entTableRow := rowsByNameDict.getAtKey(rowName).EntTableRow;
		if entTableRow &lt;&gt; null then
			fieldDef 		:= self.loadFieldFromRow(entTableRow);	
			fieldDef.parent := Parent_Main_Key;
		endif;	
	endforeach;
	
	fieldDef := self.buildGroupHeader(Parent_Misc_Key, null, Parent_Misc_Desc);
	fieldDef.showTableColumn := Visibility_Unavailable;
	foreach rowName in thumbRowNames do
		entTableRow := rowsByNameDict.getAtKey(rowName).EntTableRow;
		if entTableRow &lt;&gt; null then
			fieldDef 					:= self.loadFieldFromRow(entTableRow);		
			//fieldDef.showTableColumn	:= Visibility_OnlyInTableVisible;
			fieldDef.readOnly 			:= true;
			fieldDef.parent 			:= Parent_Misc_Key;
		endif;	
	endforeach;
	
	foreach rowName in tblDataRowNames do
		entTableRow := rowsByNameDict.getAtKey(rowName).EntTableRow;
		if entTableRow &lt;&gt; null then			
			fieldDef 					:= self.loadFieldFromRow(entTableRow);
			//fieldDef.showTableColumn	:= Visibility_OnlyInTableVisible;
			fieldDef.readOnly 			:= true;
			fieldDef.parent 			:= Parent_Misc_Key;
		endif;	
	endforeach;
	
	entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(ETRow_ToDoTasks);				
	if entTableRow &lt;&gt; null then //the trouble is that the main rows are included in all three tableDefs
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.readOnly 			:= true;
			fieldDef.parent := Parent_Misc_Key;
	endif;
	//set other details 
	//fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_GeneratePinNo);
	//fieldDef.showTableColumn := Visibility_Invisible;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CargoId);
	fieldDef.key := WS_TrackedItem::idTextBox.name;
	fieldDef.isUppercaseText := true;
	
	//17/04/2009 cnwdz2 par19482
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CommodityGroup); 
	fieldDef.key := WS_TrackedItem::comGroup.name;
	
	//17/04/2009 cnwdz2 par19482
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CommodityGroupDesc);
	fieldDef.key := WS_TrackedItem::comGroupDesc.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_WeightTotal);
	fieldDef.controlType := ControlType_NumericField;
	
	//fieldDef := self.buildGroupHeader(Parent_Stop_Key, null, Parent_Stop_Desc);
	//fieldDef.showTableColumn := Visibility_Unavailable;
	//Add stops... needs to follow the generic approach used for report params
	//foreach stopTable in app.myRoot.allStopsTable do
	//	if currentSession.myUser.canViewStop(currentSession.myCurrentTerminal, stopTable) then
	//		self.buildField(stopTable.code,
	//						stopTable.heading,//ETRow_Stops &amp; Tab &amp; stopTable.id.String,
	//						ControlType_CheckBox,
	//						Parent_Stop_Key,
	//						null,
	//						false,
	//						null,
	//						null,
	//						null,							
	//						null);						
	//	endif;			
	//endforeach;	
	//set any additional details
	entTableRow := entTableGroup.allEntTableRowsByName[ETRow_Carrier];//17/04/2009 cnwdz2 par19457 //11/06/2009 cnwdz2 par19885
	fieldDef := self.loadFieldFromRow(entTableRow);
	fieldDef.readOnly 			:= true;
	fieldDef.parent := Parent_Misc_Key;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsoTypeCode); //13/10/2009 cnwdz2 par20983
	fieldDef.key := WS_TrackedItem::isoType.name;
	
	entTableRow := entTableGroup.allEntTableRowsByName[ETRow_AllStops];
	fieldDef := self.loadFieldFromRow(entTableRow);
	fieldDef.key := WS_TrackedItem::stopsDescription.name;//17/04/2009 cnwdz2 par 19457
	//fieldDef.controlType := ControlType_ListBox;
	fieldDef.readOnly 			:= true;
	fieldDef.parent := Parent_Main_Key;
	fieldDef.controlType := ControlType_MultiTextBox;					//cnwmc5 - PAR 32753
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ToDoTasks);		//cnwmc5 - PAR 32753
	fieldDef.controlType := ControlType_MultiTextBox;					//cnwmc5 - PAR 32753
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Remarks);
	fieldDef.controlType := ControlType_MultiTextBox; //all text boxes on the JMT form are multi-line

	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_DeliveryReleaseNumber);
	fieldDef.isUppercaseText := true;
epilog
	delete mainRowNames;
	delete thumbRowNames;
	delete tblDataRowNames;
	delete rowsByNameDict;		// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="buildReleaseImportSrchFormDef" id="eafb1a1a-5aba-49e9-909f-b759cb4fedf9">
        <updating/>
        <source>buildReleaseImportSrchFormDef() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2008	cnwkao1	Initial creation

*/
constants
	Parent_Column1	: String = "column1";
	Parent_Column2	: String = "column2";
	
vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	rowNames		: StringArray;
	fieldDef		: WS_FieldDefinition;
	
begin
	proxyClassName 				:= WS_TrackedItemQueryRequest.name; // used by SOAP parser to create the correct type
	proxySearchClassName		:= WS_TrackedItem.name;
	self.primarySearchLabel		:= "Import Release ";
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_GateReceivals);
	
	//get the applicable definition
	entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_FullReleaseFind);	
	
	create rowNames transient;
	rowNames.add(ETRow_FilterId);
	
	rowNames.add(ETRow_FilterOperator);
	rowNames.add(ETRow_FilterVoyage);
	rowNames.add(ETRow_FilterConsignee);
	rowNames.add(ETRow_FilterCarrier);
	rowNames.add(ETRow_FilterTiType);
	rowNames.add(ETRow_FilterPIN);
	
	self.buildGroupHeader(	Parent_Column1,
							null,
							null);
							
	self.buildGroupHeader(	Parent_Column2,
							null,
							null);
	
	//setup each row
	foreach entTableRow in entTableDef.allEntTableRows where rowNames.includes(entTableRow.name) do
		fieldDef := self.loadFieldFromRow(entTableRow);			
		fieldDef.parent := Parent_Column1;
	endforeach;
	
	//set any additional details
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterId);
	fieldDef.parent := null; //the default search field
	fieldDef.isUppercaseText  := true;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterCarrier);
	fieldDef.parent := Parent_Column2;
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterTiType);
	fieldDef.parent := Parent_Column2;
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterPIN);
	fieldDef.parent := Parent_Column2;
	
	//setup defaults
	//fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterTiType);
	//fieldDef.defaultId := app.myPassport.myTerminal.defaultCargoType.String;
		
epilog
	delete rowNames;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildReleaseReqItemsIDForm" id="3f8e3a12-bee4-46ef-b626-fca810769d12">
        <updating/>
        <source>buildReleaseReqItemsIDForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 November 2014	cnwmc5	Initial creation

*/

vars	
	entTableGroup	: EntTableGroup;
	resp			: WS_FormDefinitionResponse;
	fieldDef		: WS_FieldDefinition;
	rowName			: String;
	mainRows	: StringArray;
	entTableRow		: EntTableRow;
begin
	self.proxyClassName			:= WS_AttachmentUpdateRequest.name;	
	self.proxySearchClassName	:= WS_Attachment.name; 	

	create mainRows transient;
	mainRows.add(ETRow_CargoType);
	mainRows.add(ETRow_CargoID);
	mainRows.add(ETRow_TotalQuantity);		//cnwmc5 - 18 Dec 2014 - PAR 35320
	mainRows.add(ETRow_WeightRequested); //epr TFS 1666 18/3/16
	mainRows.add(ETRow_VolumeRequested);  //epr TFS 1666 18/3/16
	mainRows.add(ETRow_IsReleased);
	
	//consolidate all the rows we are interested in - for this form they are spread throughout three table definitions
	entTableGroup	:= CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_GateReceivals);
	
	foreach rowName in mainRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then 
			fieldDef := self.loadFieldFromRow(entTableRow);	
		endif;
	endforeach;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CargoType);
	fieldDef.repeatedStoreField := WS_CargoType.name;
	
	//cnwmc5 - 18 Dec 2014 - PAR 35320
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TotalQuantity);
	fieldDef.key := WS_ReserveTI::totalQuantity.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsReleased);
	fieldDef.readOnly := true;
	fieldDef.controlType := ControlType_CheckBox;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_VolumeRequested);
	fieldDef.key := WS_ReserveTI::totalVolume.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_WeightRequested);
	fieldDef.key := WS_ReserveTI::totalWeight.name;
	
epilog
	delete mainRows;	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildReleaseReqItemsTypeForm" id="fa1a4a6b-aef8-4cbb-93a6-1b0dd3f4b11a">
        <updating/>
        <source>buildReleaseReqItemsTypeForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 November 2014	cnwmc5	Initial creation

*/

vars	
	entTableGroup	: EntTableGroup;
	resp			: WS_FormDefinitionResponse;
	fieldDef		: WS_FieldDefinition;
	rowName			: String;
	mainRows	: StringArray;
	entTableRow		: EntTableRow;
begin
	self.proxyClassName			:= WS_AttachmentUpdateRequest.name;	
	self.proxySearchClassName	:= WS_Attachment.name; 	

	create mainRows transient;
	mainRows.add(ETRow_CargoType);
	mainRows.add(ETRow_IsoType);
	mainRows.add(ETRow_IsoGroup);
	mainRows.add(ETRow_ProductType);	//cnwmc5 - 18 Dec 2014 - PAR 35320
	mainRows.add(ETRow_TotalRequested);
	mainRows.add(ETRow_WeightRequested); //epr TFS 1666 18/3/16
	mainRows.add(ETRow_VolumeRequested);  //epr TFS 1666 18/3/16
	mainRows.add(ETRow_Clean);
	mainRows.add(ETRow_HeavyDuty);
	mainRows.add(ETRow_Remarks);
	
	//consolidate all the rows we are interested in - for this form they are spread throughout three table definitions
	entTableGroup	:= CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_GateReceivals);
	
	foreach rowName in mainRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then 
			fieldDef := self.loadFieldFromRow(entTableRow);	
		endif;
	endforeach;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CargoType);
	fieldDef.repeatedStoreField := WS_CargoType.name;
	
	//cnwmc5 - 18 Dec 2014 - PAR 35320
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ProductType);
	fieldDef.dataReloadField := ETRow_CargoType;
	fieldDef.key := WS_ReserveSelection::product.name;
	fieldDef.dataStore := JMTUserInterfaceService::getCargoSubtypesForCargoType.name;
	
	//cnwmc5 - 18 Dec 2014 - PAR 35320
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsoType);
	fieldDef.dataReloadField := ETRow_CargoType;
	fieldDef.dataStore := JMTUserInterfaceService::getISOTypesForCargoType.name;
	 //epr TFS 1666 18/3/16
	 
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_VolumeRequested);
	fieldDef.key := WS_ReserveSelection::totalVolume.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_WeightRequested);
	fieldDef.key := WS_ReserveSelection::totalWeight.name;
	
epilog
	delete mainRows;	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildReleaseRequestFormDef" id="e8e3664a-faf3-4da0-aa09-47a4603f7b90">
        <updating/>
        <source>buildReleaseRequestFormDef() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 October 2008	cnwkao1	Initial creation
16/03/2015		cnwmh5	Transient Leaks
*/

constants
	General_Group	: String = "General";
	Location_Group	: String = "Location";
	Receive_Group	: String = "Receive/Release";
	Status_Group	: String = "Status";
	Reefer_Group	: String = "Reefer";
	ShipOps_Group	: String = "Ship Ops";
	Hidden_Group	: String = "rel_req_hidden";
	
vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	response		: WS_FormDefinitionResponse;	
	fieldDef		: WS_FieldDefinition;
	generalRows		: StringArray; //perhaps a more appropriate collection should be used
	readOnlyRows	: StringArray;		//cnwmc5 - 13 November 2014 - CCMS 2429
	hiddenRows		: StringArray;
	parent			: String;
	rowName			: String;
	
begin
	self.proxyClassName			:= WS_BulkReleaseUpdateRequest.name;		//cnwmc5 - 11 Bov 2014 - CCMS 2429
	self.proxySearchClassName	:= WS_BulkRelease.name;
	
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_GateReceivals);
	
	//cnwmc5 - 24 November 2014 - CCMS 2429
	self.buildHiddenGroup(Hidden_Group);
	create hiddenRows transient;
	hiddenRows.add(WS_ProxyObject::cmObjectId.name);
	hiddenRows.add(WS_ProxyObject::cmObjectEdition.name);
	
	foreach rowName in hiddenRows do
		self.buildHiddenField(rowName,Hidden_Group);
	endforeach;
	
	create generalRows transient;
	generalRows.add(ETRow_ReleaseNo);
	generalRows.add(ETRow_ReleaseByType);		//cnwmc5 - 21 November 2014 - CCMS 2429
	generalRows.add(ETRow_Type);				//cnwmc5 - 13 November 2014 - CCMS 2429
	generalRows.add(ETRow_StatusDesc);			//cnwmc5 - 13 November 2014 - CCMS 2429
	generalRows.add(ETRow_Booking);				//cnwmc5 - 1 June 2016 - TFS 2039
	generalRows.add(ETRow_OperatorCode);		//cnwmc5 - 6 November 2014 - CCMS 2429
	generalRows.add(ETRow_AllReserveDetails);	//cnwmc5 - 24 November 2014 - CCMS 2429
	generalRows.add(ETRow_MyPinNo);
	generalRows.add(ETRow_TotalRequested);
	generalRows.add(ETRow_DeliveredToDate);
	generalRows.add(ETRow_WeightTotal);			//cnwmc5 - 30 April 2014 - PAR 33988
	generalRows.add(ETRow_VolumeTotal);			//cnwmc5 - 30 April 2014 - PAR 33988
	generalRows.add(ETRow_BrItemsDelivered);
	generalRows.add(ETRow_CargoType);
	generalRows.add(ETRow_IsoType);
	generalRows.add(ETRow_VoyageCode);			//cnwmc5 - 26 November 2014 - CCMS 2429
	generalRows.add(ETRow_Carrier);				//cnwmc5 - 6 November 2014 - CCMS 2429
	generalRows.add(ETRow_Consignee);
	generalRows.add(ETRow_Consignor);			//cnwmc5 - 26 November 2014 - CCMS 2429
	generalRows.add(ETRow_RequestDate);
	generalRows.add(ETRow_RequestTime);			//cnwmc5 - 26 November 2014 - CCMS 2429
	generalRows.add(ETRow_DischargePort);
	generalRows.add(ETRow_MyTransferToTerminal);	//cnwmc5 - 2 March 2015 - PAR 35777
	generalRows.add(ETRow_Remarks);
	//generalRows.add(ETRow_WeightTotal);
	//generalRows.add(ETRow_Volume);
	
	//generalRows.add(ETRow_AvailabilityGradeCode);
	
	//generalRows.add(ETRow_EstimatedRequiredDate);
	//generalRows.add(ETRow_FreightPayerCode);
	//generalRows.add(ETRow_IsoGroup);
	//generalRows.add(ETRow_EmptyReleaseItemDescr);
	//generalRows.add(ETRow_QuantityRemaining);

	//generalRows.add(ETRow_Type);
	//generalRows.add(ETRow_VoyageCode);
	//generalRows.add(ETRow_LoadPort);

	//generalRows.add(ETRow_MyTransferToTerminal);
	//generalRows.add(ETRow_RequestsBeingActioned);
	//
	//generalRows.add(ETRow_MyOperatorGroup);
	//generalRows.add(ETRow_ReleaseByType);
	//
	//generalRows.add(ETRow_DoISOGroupCheck);
	
	//generalRows.add(ETRow_ConsignorVoyageCode);
	//generalRows.add(ETRow_DeliveryReason);
	//generalRows.add(ETRow_Clean);
	//generalRows.add(ETRow_RemoveStops);
	//generalRows.add(ETRow_AllMTGrades);
	//generalRows.add(ETRow_HeavyRated);
	//generalRows.add(ETRow_ImexStatusString);

	//generalRows.add(ETRow_PackLocation);
	//generalRows.add(ETRow_TotalPacked);
	//generalRows.add(ETRow_VoyageArrival);
	//generalRows.add(ETRow_BookingConfirmation);
	//generalRows.add(ETRow_DeliveryReleaseNumber);
	//generalRows.add(ETRow_PackProduct);
	//generalRows.add(ETRow_PackQuantity);
	//generalRows.add(ETRow_FreightForwarder);
	//generalRows.add(ETRow_BusinessUnit);
	
	fieldDef := self.buildGroupHeader(General_Group, null, General_Group); //hold above entries
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	//cnwmc5 - 13 November 2014 - CCMS 2429
	create readOnlyRows transient;
	readOnlyRows.add(ETRow_MyPinNo);
	readOnlyRows.add(ETRow_TotalRequested);
	readOnlyRows.add(ETRow_DeliveredToDate);
	readOnlyRows.add(ETRow_WeightTotal);
	readOnlyRows.add(ETRow_VolumeTotal);
	readOnlyRows.add(ETRow_BrItemsDelivered);
	readOnlyRows.add(ETRow_CargoType);
	readOnlyRows.add(ETRow_IsoType);
	
	foreach rowName in generalRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);	
		if entTableRow &lt;&gt; null then
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.parent := General_Group;	
			
			//cnwmc5 - 13 November 2014 - CCMS 2429
			//until maintenance is implemented - override complex details
			//fieldDef.readOnly				:= true;	
			//fieldDef.controlType			:= ControlType_TextBox; 
			//fieldDef.dataStore	 			:= null;
			//fieldDef.storeIdField			:= null;
			//fieldDef.storeDescriptionField	:= null;
			//fieldDef.repeatedStoreField		:= null;		
		endif;
	endforeach;
		
	foreach rowName in readOnlyRows do
		fieldDef := self.allFormFieldsByKey.getAtKey(rowName);
		fieldDef.readOnly := true;	
	endforeach;	

	//22/04/2009 cnwdz2 ccms1735
	if app.isSubTerminalsOn(app.myPassport.myTerminal) then	
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(ETRow_MySubTerminal);	
		if entTableRow &lt;&gt; null then
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.parent := General_Group;	
		endif;
	endif;
	
	//set any specific details
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ReleaseNo);
	fieldDef.isUppercaseText := true;
	fieldDef.initialFieldForSaveNext := true;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Remarks);
	fieldDef.controlType := ControlType_MultiTextBox; //all text boxes on the JMT form are multi-line
	
	//cnwmc5 - 30 April 2014 - PAR 33988
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_VolumeTotal);
	fieldDef.key := WS_BulkRelease::totalVolumeRequested.name;
	
	//cnwmc5 - 30 April 2014 - PAR 33988
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_WeightTotal);
	fieldDef.key := WS_BulkRelease::totalWeightRequested.name;
	
	
	//cnwmc5 - 6 November 2014 - CCMS 2429
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Carrier);
	fieldDef.key := WS_BulkRelease::carrier.name;	
	fieldDef.controlType := ControlType_ComboBox;
	fieldDef.storeIdField := WS_Carrier::code.name;
	fieldDef.storeDescriptionField := WS_Carrier::comboboxDescription.name;
	
	//cnwmc5 - 6 November 2014 - CCMS 2429
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_OperatorCode);
	fieldDef.key := WS_BulkRelease::operator.name;	
	fieldDef.controlType := ControlType_ComboBox;
	fieldDef.storeIdField := WS_Operator::code.name;
	fieldDef.storeDescriptionField := WS_Operator::comboboxDescription.name;
	
	//cnwmc5 - 6 November 2014 - CCMS 2429
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Consignee);
	fieldDef.key := WS_BulkRelease::consignee.name;	
	fieldDef.controlType := ControlType_ComboBox;
	fieldDef.storeIdField := WS_ConsigneeConsignor::code.name;
	fieldDef.storeDescriptionField := WS_ConsigneeConsignor::comboboxDescription.name;
	
	//cnwmc5 - 6 November 2014 - CCMS 2429
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_DischargePort);
	fieldDef.key := WS_BulkRelease::dischargePort.name;	
	fieldDef.controlType := ControlType_ComboBox;
	fieldDef.storeIdField := WS_Port::code.name;
	fieldDef.storeDescriptionField := WS_Port::description.name;
	
	//cnwmc5 - 13 November 2014 - CCMS 2429
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_StatusDesc);
	fieldDef.key := WS_BulkRelease::status.name;	
	fieldDef.controlType := ControlType_ComboBox;
	fieldDef.storeIdField := WS_BulkReleaseStatus::id.name;
	fieldDef.storeDescriptionField := WS_BulkReleaseStatus::description.name;
	fieldDef.dataStore := JMTUserInterfaceService::getBulkReleaseStatusMaint.name;
	fieldDef.repeatedStoreField := WS_BulkReleaseStatus.name;
	
	//cnwmc5 - 13 November 2014 - CCMS 2429
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Type);
	fieldDef.dataStore := JMTUserInterfaceService::getBulkReleaseTypesMaint.name;
	fieldDef.repeatedStoreField := WS_BulkReleaseType.name;
	fieldDef.defaultId := null;
	fieldDef.defaultDescription := null;
	
	//cnwmc5 - 13 November 2014 - CCMS 2429
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsoType);
	fieldDef.controlType := ControlType_TextBox;
	fieldDef.dataStore	 			:= null;
	fieldDef.storeIdField			:= null;
	fieldDef.storeDescriptionField	:= null;
	fieldDef.repeatedStoreField		:= null;
	
	//cnwmc5 - 13 November 2014 - CCMS 2429
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CargoType);
	fieldDef.controlType := ControlType_TextBox;
	fieldDef.dataStore	 			:= null;
	fieldDef.storeIdField			:= null;
	fieldDef.storeDescriptionField	:= null;
	fieldDef.repeatedStoreField		:= null;
	fieldDef.defaultId 				:= null;
	fieldDef.defaultDescription 	:= null;
	
	//cnwmc5 - 20 November 2014 - CCMS 2429
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_AllReserveDetails);
	fieldDef.controlType		:= self.ControlType_Custom_ReleaseReq;
	fieldDef.repeatedStoreField := WS_ReserveDetail.name;
	fieldDef.storeDescriptionField := WS_ReserveTI::cargoType.name;		//cnwmc5 - 27 Jan 2015 - PAR 35003
	fieldDef.storeIdField		:= WS_ReserveTI::cargoType.name;		//cnwmc5 - 27 Jan 2015 - PAR 35003
	
	//cnwmc5 - 26 November 2014 - CCMS 2429
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_RequestTime);
	fieldDef.controlType := self.ControlType_Custom_TimePicker;
	
	//cnwmc5 - 2 March 2015 - PAR 35777
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_MyTransferToTerminal);
	fieldDef.controlType := ControlType_ComboBox;
	fieldDef.dataStore := JMTUserInterfaceService::getTransferTerminals.name;
	fieldDef.key := WS_BulkRelease::destinationTerminal.name;
	fieldDef.repeatedStoreField := WS_Terminal.name;
	fieldDef.storeIdField := WS_Terminal::code.name;
	fieldDef.storeDescriptionField := WS_Terminal::name.name;
	
	//cnwmc5 - 1 June 2016 - TFS 2039
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Booking);
	fieldDef.dataStore 				:= JMTUserInterfaceService::getBookingReferencesForDisplay.name;
	fieldDef.key 					:= WS_BulkRelease::booking.name;
	fieldDef.repeatedStoreField 	:= WS_BookingReference.name;
	fieldDef.storeDescriptionField 	:= WS_BookingReference::bookingReference.name;
	fieldDef.storeIdField			:= WS_BookingReference::cmObjectId.name;
	
epilog
	delete generalRows;
	delete readOnlyRows;		//cnwmc5 - 13 November 2014 - CCMS 2429
	delete hiddenRows;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildReleaseRequestSrchFormDef" id="bc7a2d85-77cc-48ab-b7a7-51fbb1ef0a6f">
        <updating/>
        <source>buildReleaseRequestSrchFormDef() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 October 2008	cnwkao1	Initial creation

*/

constants
	Parent_Column1	: String = "column1";
	Parent_Column2	: String = "column2";
	
vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	fieldDef		: WS_FieldDefinition;
	column1Rows		: StringArray; //perhaps a more appropriate collection should be used
	column2Rows		: StringArray;	
	parent			: String;
	rowName			: String;
	
begin
	self.proxyClassName			:= WS_BulkReleaseQueryRequest.name;//there is no update object, only query
	self.proxySearchClassName	:= WS_BulkRelease.name;
	self.primarySearchLabel		:= "Release Request ";
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_GateReceivals);
	
	
	create column1Rows transient;
	column1Rows.add(ETRow_ReleaseNoCmb);
	//column1Rows.add(ETRow_FiltReleaseNo);
	column1Rows.add(ETRow_Type); //KO - this won't be included in the entTableDef will need to access from the entTableGroup
	
	//column1Rows.add(ETRow_FilterConsignor);
	
	//column1Rows.add(ETRow_FilterMTGrade);
	//column1Rows.add(ETRow_FilterDateRequestFrom);
	//column1Rows.add(ETRow_FilterDateRequestTo);
	
	self.buildGroupHeader(Parent_Column1, null, null); //hold above entries
	
	create column2Rows transient;
	//column2Rows.add(ETRow_FilterTiType);//09/09/2009 cnwdz2 20623
	column1Rows.add(ETRow_FilterOperator);
	column2Rows.add(ETRow_FilterCarrier);
	//column2Rows.add(ETRow_IsoGroup);
	//column2Rows.add(ETRow_FilterDateRequiredFrom);
	//column2Rows.add(ETRow_FilterTimeRequireFrom);
	//column2Rows.add(ETRow_FilterFreeText);
	//column2Rows.add(ETRow_FilterFreightForwarder);
	//column2Rows.add(ETRow_FilterBusinessUnit);
	//column2Rows.add(ETRow_FilterPIN);
	
	self.buildGroupHeader(Parent_Column2, null, null); //hold above entries
		
	
	//get the applicable definition 
	//entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_MTReleaseFind); //this is the appropriate def, however its more efficient to access them via the group
		
	foreach rowName in column1Rows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		fieldDef		:= self.loadFieldFromRow(entTableRow);
		fieldDef.parent := Parent_Column1;
	endforeach;
		
	foreach rowName in column2Rows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		fieldDef		:= self.loadFieldFromRow(entTableRow);
		fieldDef.parent := Parent_Column2;	
	endforeach;
	
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ReleaseNoCmb);
	fieldDef.parent := null; //primary search field
	fieldDef.isUppercaseText := true;
	
	//fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Type);
	//fieldDef.defaultDescription := app.getErrorString(BR_TYPE_DESCR_ALL);
	//fieldDef.defaultId := 1000.String;
	
	fieldDef := self.buildField(
					"view", 				//key				: String;
					app.getErrorString(BR_Status_View),				//label				: String;
					ControlType_ComboBox,								//controlType		: Integer;
					Parent_Column1,										//parent			: String;
					JMTUserInterfaceService::getBulkReleaseStatus.name,		//dataStore			: String;
					false,												//readOnly			: Boolean;
					null,												//dataList			: String;
					WS_BulkReleaseStatus::id.name,											//storeIdField		: String;
					WS_BulkReleaseStatus::description.name,										//storeDescField 	: String;
					WS_BulkReleaseStatus.name,										//repeatedStoreField: String
					BR_ACTIVE.String,
					app.getErrorString(BR_ACTIVE_XLTSTRING)					
					);
	//fieldDef.defaultDescription := app.getErrorString(BR_ACTIVE_XLTSTRING);
	//fieldDef.defaultId := BR_ACTIVE.String;
//	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterTimeRequireFrom);
//	fieldDef.controlType := ControlType_Custom_TimePicker;
	
epilog
	delete column1Rows;
	delete column2Rows;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildReportFormDefinition" id="2788fbfa-36c1-49b3-9108-fe0a207a7bc7">
        <updating/>
        <source>buildReportFormDefinition() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Sep 2008	cnwkao1	Initial creation
09 Mar 2009	cnwkpd1	PAR #19048 - Handle reports with no parameters
17 Mar 2009	cnwkpd1	PAR #19107 - Handle user defined reports properly (get the correct EntTableDef)
18 Jan 2012	cnwkpd1	PAR #28954 - Add in any user defined parameters

*/

constants
	Left_Col	: String = "leftColumn";
	Right_Col	: String = "rightColumn";
	InputType_Date	: Integer = 104;	//12 Dec 2017	NDL	TFS 8090
	
vars
	reportName		: String;
	report			: CM_QryReport;
	response		: WS_FormDefinitionResponse;
	fieldDef		: WS_FieldDefinition;
	visibleRows		: StringArray;
	index			: Integer;
	parent			: String;
	entTableDef		: EntTableDef;
	entView			: EntTableView;
	entRowArray 	: EntTableRowArray;
	entTableRow		: EntTableRow;
	isSystemReport	: Boolean;
	jrwReport		: JadeReportWriterReport;
	jrwManager		: JadeReportWriterManager;
	user			: CM_User;
	reportAgent	    : WebService_ReportAgent;
	reportParam		: CM_QueryReportParam;
	date			: Date;			//cnwmc5 - 20 June 2014 - PAR 34398
	defaultParamDesc : String;
begin
	reportName := formName;
	report := app.myRoot.getQryReport(reportName); //this will probably have to be modified to look at the user specific details
	if report = null then
		// Raise appropriate exception
		app.raiseCMException1(Report_Not_Found, 
							  reportName,
							  null, 
							  null);
		return;
	endif;
	
	// Check User has access to run this report
	user := app.getMyUser();
	if not user.canUserViewReport(report) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,
							  user.code,
							  app.getErrorString(Report),
							  report.reportName,
							  null, 
							  null);
		return;
	endif;	
	
	self.buildGroupHeader(Left_Col, null, null); 
	self.buildGroupHeader(Right_Col, null, null);
	
	create visibleRows transient;
	isSystemReport := false;
	if report.isKindOf(CM_QryReportUser) then //this subclass contains visibility information, with system reports all params are visible
		entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs.getAtKey(report.getETDefName());		// PAR #19107
		if entTableDef &lt;&gt; null then
			entRowArray := entTableDef.allEntTableRows;
		endif;
		report.CM_QryReportUser.allVisibleRows.copy(visibleRows);
		
	else
		isSystemReport := true;
		entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs.getAtKey(report.tableDefName);
		if entTableDef &lt;&gt; null then
			entView := entTableDef.allEntTableViews.getAtKey(report.tableDefViewName);
			if entView &lt;&gt; null then
				entRowArray := entView.allEntTableRows;				
			endif;
		endif;
	endif;
	
	create reportAgent transient;//- 30/04/2009 cnwdz2 par 19541
	
	if entRowArray &lt;&gt; null then					// PAR #19048
		foreach entTableRow in entRowArray do			
						
			//epr TFS 4644 9/6/17 
			fieldDef := self.loadReportFieldFromRow(entTableRow);	
	
			fieldDef.showTableColumn := Visibility_Invisible; //default marking as invisible
			if isSystemReport then //This isn't quite correct - system reports aren't maintainable, but their parameter visibility must be controlled elsewhere
				visibleRows.add(entTableRow.name); 
			endif;
			
			reportAgent.loadDefaultParameterByName(report.myFilterObject, entTableRow, entTableRow.name, fieldDef.defaultDescription, fieldDef.defaultId);	///19/07/2010 cnwdz2 24513
			fieldDef.setDefaultsForReports();
			
			
			//cnwmc5 - 11 July 2013 - PAR 31988
			if entTableRow.name = ETRow_BookingStatus then
				fieldDef.storeIdField := WS_BookingStatus::description.name;
			endif;
		endforeach;
	endif;
	
	// PAR #28954 - Add in any user defined parameter fields (can only be primitives)
	foreach reportParam in report.allQueryReportParams where reportParam.type &lt;&gt; Binary.number do
		
		fieldDef := self.buildField(reportParam.paramName,									// key					: String;
									reportParam.displayName,								// label				: String;
									self.translateControlTypeFromType(reportParam.type),	// controlType			: Integer;
									null,													// parent				: String;
									null,													// dataStore			: String;
									false,													// readOnly			: Boolean;
									null,													// dataList			: String;
									null,													// storeIdField		: String;
									null,													// storeDescField 		: String;
									null,													// repeatedStoreField	: String;	
									null,													// defaultId			: String;
									reportParam.getParamValue.String);						// defaultDesc			: String 
		
		fieldDef.setDefaultsForReports();						

		if reportParam.isVisible then
			visibleRows.add(reportParam.paramName);
		else
			fieldDef.showTableColumn := Visibility_Invisible;			
		endif;
	endforeach;

	//balance
	foreach index in 1 to visibleRows.size() do
		fieldDef	:= self.allFormFieldsByKey.getAtKey(visibleRows[index]);
		
		if fieldDef &lt;&gt; null then			// PAR #19048
			if index.isOdd() then
				parent := Left_Col;
			else
				parent := Right_Col;
			endif;
			
			fieldDef.parent 			:= parent;	
			fieldDef.showTableColumn	:= Visibility_Visible;
		endif;
	endforeach;
		
	//setup report profile if it is present
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ReportProfile);
	if fieldDef &lt;&gt; null and not report.jrwReportName.isEmpty() then
		jrwManager					:= app.createReportWriterManager();
		jrwReport					:= jrwManager.getReport(report.jrwReportName.first());
		if jrwReport &lt;&gt; null then
			fieldDef.controlType		:= ControlType_ComboBox;
			fieldDef.dataList			:= self.getReportProfileListStr(jrwReport);
			fieldDef.defaultDescription	:= jrwReport.getDefaultProfile();
			fieldDef.defaultId			:= fieldDef.defaultDescription;
			fieldDef.storeIdField		:= self.FieldType_DataList; //13/04/2010 cnwdz2 23421
			fieldDef.storeDescriptionField := self.FieldType_DataList;
		endif;
	endif;
	
	//output options
	//self.buildReportOutputControls();	- Sean doesn't want to do this at this point now, he wants a separate request
	
	//set dependancies for known fields (if they are present)
	self.setupFieldDependancies();
	
epilog
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	delete visibleRows;
	delete jrwManager;
	delete jrwReport;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildReportGroupControls" id="0f6ed175-f6d8-42ac-95a3-af7a36d4499e">
        <source>buildReportGroupControls(reportHeader : CM_MenuUserHdr) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 September 2008	cnwkao1	Initial creation

*/
constants
	FieldDef_Prefix : String = "hdr";
	FieldDef_Label	: String = "Select Reports";
	
vars
	headerName	: String;
	lstName		: String;
begin
	headerName	:= FieldDef_Prefix &amp; reportHeader.heading;
	lstName		:= reportHeader.heading;
	
	self.buildGroupHeader(headerName, null, lstName);
	
	self.buildField(lstName,
					FieldDef_Label,
					ControlType_ListBox,
					headerName,
					JMTUserInterfaceService::getReportsForReportHeader.name,
					false,
					null,
					WS_Report::id.name,
					WS_Report::description.name,//null,
					WS_Report.name,
					null,
					null);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="reportHeader" type="CM_MenuUserHdr"/>
    </JadeMethod>
    <JadeMethod name="buildReportOutputControls" id="35f5e368-6e6b-4117-a52c-d5f8d0c4613d">
        <source>buildReportOutputControls() protected;

/*

Purpose: 	Builds the common report output option controls.

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2008	cnwkao1	Initial creation

*/
constants
	OutOptGroup	: String = "outputOptions"; 
	
vars
	fieldDef	: WS_FieldDefinition;
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
begin
	self.buildGroupHeader(OutOptGroup, null, null);
	
	fieldDef := self.buildField(WS_ReportRunRequest::reportFormat.name,						//key					: String;
					"Report Format",											//label				: String;
					ControlType_ComboBox,										//controlType			: Integer;
					OutOptGroup,												//parent				: String;
					JMTUserInterfaceService::getReportOutputFormats.name,		//dataStore			: String;
					//JMTUserInterfaceService::getOutputFormatsForReport.name,	//dataStore			: String; - this method needs the report name to be passed in
					false,														//readOnly			: Boolean;
					null,														//dataList			: String;
					WS_ReportOutputFormat::id.name,								//storeIdField		: String;
					WS_ReportOutputFormat::description.name,					//storeDescField 		: String;
					WS_ReportOutputFormat.name,									//repeatedStoreField	: String
					JadeReportWriterReport.HTML.String,
					"On Screen"
					);
	//fieldDef.defaultId := JadeReportWriterReport.HTML.String;				
	//fieldDef.defaultDescription := "On Screen";
	
	fieldDef := self.buildField(WS_ReportRunRequest::isForeground.name,
								"Run in Foreground",
								ControlType_CheckBox,
								OutOptGroup,
								null,
								false,
								null,
								null,
								null,
								null,
								"true",	//cnwmc5 - PAR 32206
								"true" //15/07/2010 cnwdz2 24671	//cnwmc5 - PAR 32206
								);								
	//fieldDef.defaultDescription := "true";
	
	self.buildField(WS_ReportRunRequest::isEmailed.name,
					"Is Emailed",
					ControlType_CheckBox,
					OutOptGroup,
					null,
					false,
					null,
					null,
					null,
					null,
					null,
					null
					);
					//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_EventRequest);
	
	//get the applicable definition
	entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_EventRequestNotify); //this contains 12 rows
	entTableRow := entTableDef.allEntTableRows[entTableDef.getRowByName(ETRow_EmailAddresses)];
	fieldDef := self.loadFieldFromRow(entTableRow);
	/*fieldDef := self.buildField(WS_ReportRunRequest::emailAddresses.name,
								"Email Addresses",
								ControlType_MultiTextBox,
								OutOptGroup,
								null,
								false,
								null,
								null,
								null,
								null
								);
								*/
	fieldDef.parent := OutOptGroup;
	fieldDef.controlType := ControlType_Custom_Recipients;			
					
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildReportParameters" id="96afb80a-0efc-4776-becb-a44c2722f9e5">
        <updating/>
        <source>buildReportParameters() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2018	jlger1	Initial creation tfs 37479 copied from buildReportFormDefintion needed new method that deals with the time entTableRows
                         differently also does not return the group headers

*/
	
vars
	reportName		: String;
	report			: CM_QryReport;
	dependancy,
	fieldDef		: WS_FieldDefinition;
	entTableDef		: EntTableDef;
	entView			: EntTableView;
	entRowArray 	: EntTableRowArray;
	entTableRow		: EntTableRow;
	isSystemReport	: Boolean;
	jrwReport		: JadeReportWriterReport;
	jrwManager		: JadeReportWriterManager;
	user			: CM_User;
	reportAgent	    : WebService_ReportAgent;
	reportParam		: CM_QueryReportParam;
	allParams 		: WS_FormsFieldArray;
	allParamsByKey  : WS_FieldDefByKeyDict;
	indexSelf 		: Integer;
	indexDependancy : Integer;
	criteriaLine		: CM_SelectorCriteriaLine;
	criteriaLineHolder	: CM_QueryCriteriaLineHolder;
begin
	reportName := self.formName;
	report := app.myRoot.getQryReport(reportName); //this will probably have to be modified to look at the user specific details

	self.isWebportalReport:=true;
	if report = null then
		// Raise appropriate exception
		app.raiseCMException1(Report_Not_Found, 
							  reportName,
							  null, 
							  null);
		return;
	endif;
	
	// Check User has access to run this report
	user := app.getMyUser();
	if not user.canUserViewReport(report) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,
							  user.code,
							  app.getErrorString(Report),
							  report.reportName,
							  null, 
							  null);
		return;
	endif;	

	isSystemReport := report.isKindOf(CM_QryReportSystem);
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs.getAtKey(report.getETDefName());		// PAR #19107
	
	if entTableDef &lt;&gt; null then
		entView := entTableDef.allEntTableViews.getAtKey(report.tableDefViewName);
		if entView &lt;&gt; null then
			entRowArray := entView.allEntTableRows;	
		else
			entRowArray := entTableDef.allEntTableRows;
		endif;
	endif;
	
	create reportAgent transient;//- 30/04/2009 cnwdz2 par 19541
	create allParams transient;
	if entRowArray &lt;&gt; null then					// PAR #19048
		foreach entTableRow in entRowArray do			
			if not isSystemReport then
				if not report.CM_QryReportUser.allVisibleRows.includes(entTableRow.name) then
					continue;
				endif;
			endif;			
			//epr TFS 4644 9/6/17 
			fieldDef := self.loadReportFieldFromRow(entTableRow);	
			allParams.add(fieldDef);
			reportAgent.loadDefaultParameterByName(report.myFilterObject, entTableRow, entTableRow.name, fieldDef.defaultDescription, fieldDef.defaultId);	///19/07/2010 cnwdz2 24513
			fieldDef.setDefaultsForReports();
			
			
			if entTableRow.inputType = CM_BaseTable.InputType_Time then
				fieldDef.controlType :=ControlType_Custom_TimePicker;
			endif;
						
			//cnwmc5 - 11 July 2013 - PAR 31988
			if entTableRow.name = ETRow_BookingStatus then
				fieldDef.storeIdField := WS_BookingStatus::description.name;
			endif;
			
			//setup report profile if it is present
			if entTableRow.name = ETRow_ReportProfile and not report.jrwReportName.isEmpty() then
				jrwManager					:= app.createReportWriterManager();
				jrwReport					:= jrwManager.getReport(report.jrwReportName.first());
				if jrwReport &lt;&gt; null then
					fieldDef.controlType		:= ControlType_ComboBox;
					fieldDef.dataList			:= self.getReportProfileListStr(jrwReport);
					fieldDef.defaultDescription	:= jrwReport.getDefaultProfile();
					fieldDef.defaultId			:= fieldDef.defaultDescription;
					fieldDef.storeIdField		:= self.FieldType_DataList; //13/04/2010 cnwdz2 23421
					fieldDef.storeDescriptionField := self.FieldType_DataList;
				endif;
			endif;
			
		endforeach;
	endif;
	
	// PAR #28954 - Add in any user defined parameter fields (can only be primitives)
	foreach reportParam in report.allQueryReportParams where reportParam.type &lt;&gt; Binary.number and reportParam.isVisible do
		fieldDef := self.buildField(reportParam.paramName,									// key					: String;
									reportParam.displayName,								// label				: String;
									self.translateControlTypeFromType(reportParam.type),	// controlType			: Integer;
									null,													// parent				: String;
									null,													// dataStore			: String;
									false,													// readOnly			: Boolean;
									null,													// dataList			: String;
									null,													// storeIdField		: String;
									null,													// storeDescField 		: String;
									null,													// repeatedStoreField	: String;	
									null,													// defaultId			: String;
									reportParam.getParamValue.String);						// defaultDesc			: String 
		fieldDef.setDefaultsForReports();
		allParams.add(fieldDef);	
	endforeach;
	
	//TFS 45769 30/7/19
	if report.mySelectorQuery &lt;&gt; null then
		foreach criteriaLineHolder in report.mySelectorQuery.allCriteriaLineHolders discreteLock do 
			foreach criteriaLine in criteriaLineHolder.allCriteriaLines do 
				if criteriaLine.isUnavailableAtRunTime then
					continue;
				endif;
				if criteriaLine.myQueryOperator = null or 
					criteriaLine.myQueryProperty = null then
					continue;
				endif;
				
				fieldDef := self.loadReportFieldFromCritLine(criteriaLine);
				allParams.add(fieldDef);
			endforeach;
		endforeach;
	endif;	
	
	
	create allParamsByKey transient;
	allParams.copy(allParamsByKey);
	
	
	//epr make sure the dependencies are before the field it depends on
	foreach fieldDef in allParams do
		if self.allFormFields.includes(fieldDef) then
			continue;
		endif;
		if fieldDef.dataReloadField = null then
			fieldDef.myFormDefinition:=self;
		else
			indexSelf:= allParams.indexOf(fieldDef);
			dependancy := allParamsByKey.getAtKey(fieldDef.dataReloadField);
			if dependancy = null then
				fieldDef.dataReloadField:=null;
				fieldDef.myFormDefinition:=self;
				continue;
			endif;
			indexDependancy:=allParams.indexOf(dependancy);
			if indexDependancy &gt; indexSelf then
				dependancy.myFormDefinition:=self;
			endif;
			fieldDef.myFormDefinition:=self;
		endif;
	endforeach;

	
	
epilog
	delete allParamsByKey;
	delete allParams;
	delete jrwManager;
	delete jrwReport;
	delete allParams;

end;</source>
    </JadeMethod>
    <JadeMethod name="buildReportSelectionFormDef" id="e7e7aeca-a515-43bf-9232-aac2d3962a56">
        <updating/>
        <source>buildReportSelectionFormDef() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Sep 2008	cnwkao1	Initial creation
09 Mar 2009	cnwkpd1	PAR #19048 - Allow for reports that are not under a group heading
26 Mar 2009	cnwkpd1	PAR #19263 - Prevent 1035 exceptions for very long Terminal names

*/

vars
	userTerminal	: CM_UserTerminal;
	menuEntity		: CM_MenuEntity;	
	tmpHeader		: CM_MenuUserHdr;
	hasNonGroupReps	: Boolean;
	terminal		: CM_Terminal;
	
begin
	self.proxyClassName			:= WS_ReportsRequest.name;
	self.proxySearchClassName	:= WS_Report.name; //no searcher	
	
	terminal := app.getMyTerminalDO_NOT_USE();
	userTerminal := app.getMyUser().getUserTerminal(terminal);
	
	if userTerminal = null then
		//raise appropriate web service error - not sure which is more appropriate
		//app.raiseUnexpectedProgramError(class.name, method.name, 'Report menu root object has not been found for the current user.');
		app.raiseCMException(Repor_menu_root_objec_been_fou,null, null);
		
	else
		foreach menuEntity in userTerminal.myReportMenuRoot.allChildren do
			if menuEntity.hasWebReports() then
				if menuEntity.isKindOf(CM_MenuUserHdr) then
					self.buildReportGroupControls(menuEntity.CM_MenuUserHdr);
				elseif menuEntity.isKindOf(CM_MenuUserDtl) then
					hasNonGroupReps := true;
				endif;
			endif;
		endforeach;

		// PAR #19048 - If there are non-grouped web repoorts, then place them under a special header
		if hasNonGroupReps then
			create tmpHeader transient;
			tmpHeader.setHeading(app.getTerminalReportHeading());		// PAR #19263
			self.buildReportGroupControls(tmpHeader);
		endif;
	endif;
	
	
epilog
	delete tmpHeader;
	if self.myResponse &lt;&gt; null then
		self.myResponse.setErrorsFromPassport();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildUpdateRequestFormDef" id="a3a1f331-dcb0-463b-a156-b02f991dcf3e">
        <updating/>
        <source>buildUpdateRequestFormDef() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2008	cnwkao1	Initial creation
// tfs 2708 cnwns1 26/09/16 PAR38242 POL - query on permissions
*/
constants
	Hidden_Group_Key		: String = "stoprequest_hidden";
	
	Main_Group_Key		: String = "main";
	Main_Group_Desc		: String = "Main Details";
	
	Notify_Times		: String = "Notify Times";
	
vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	fieldDef		: WS_FieldDefinition;	
	hiddenRows,
	visibleRows		: StringArray;
	rowName			: String;
	
begin
	self.proxyClassName := WS_CargoStopUpdateRequest.name; // used by SOAP parser to create the correct type
	self.proxySearchClassName := WS_EventRequestStops.name; // used by SOAP parser to create the correct type
	
	self.buildHiddenGroup(Hidden_Group_Key);
	create hiddenRows transient;
	hiddenRows.add(WS_ProxyObject::cmObjectId.name);
	hiddenRows.add(WS_ProxyObject::cmObjectEdition.name);
	
	foreach rowName in hiddenRows do
		self.buildHiddenField(rowName,Hidden_Group_Key);
	endforeach;
	
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_EventRequest);
	
	//get the applicable definition
	entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_EventRequestWeb);
	
	create visibleRows transient;
	visibleRows.add(ETRow_MyCargoType);
	visibleRows.add(ETRow_CargoId);
	visibleRows.add(ETRow_Status);				//cnwmc5 - 22 April 2015 - PAR 36024
	visibleRows.add(ETRow_Stops); //was ETRow_Stops
	
	//cnwjo3 par 25843
	visibleRows.add(ETRow_AdditionalRequiredInfo);
	visibleRows.add(ETRow_ClearanceExpiryDate);
	
	visibleRows.add(ETRow_ToDoTasks);
	visibleRows.add(ETRow_Grade);
	visibleRows.add(ETRow_CargoRemarks);
	visibleRows.add(ETRow_MyOrganisation); //not included in spec, but required for search etc
	//visibleRows.add(ETRow_Status); ... not sure about this one
	
	fieldDef := self.buildGroupHeader(Main_Group_Key, null, "Main Details"); //hold above entries
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	/*	KO - maintenance fields that are on the form, but they aren't included in the spec.... they are included in a later version
	*/
	visibleRows.add(ETRow_IsClear);					//cnwmc5 - 21 May 2014 - CCMS 2289
	visibleRows.add(ETRow_AutoCleanup);	
	visibleRows.add(ETRow_Remarks);
	visibleRows.add(ETRow_Reference);
	
	
	visibleRows.add(ETRow_IsNotify);
	visibleRows.add(ETRow_EmailAddresses);

	
	foreach rowName in visibleRows do
		entTableRow := entTableDef.allEntTableRows[entTableDef.getRowByName(rowName)];
		fieldDef := self.loadFieldFromRow(entTableRow);
		fieldDef.parent := Main_Group_Key;	
		//it would seem that everything on the JMT Maint form is maintainable
		//if rowName &lt;&gt; ETRow_Remarks then// or rowName &lt;&gt; ETRow_EmailAddresses then
		//	fieldDef.readOnly := true;
		//endif;
	endforeach;
	
	//build the custom time picker control
	self.buildField(WS_CargoNoteUpdateRequest::allNotifyTimesString.name,		//key					: String;
					Notify_Times,											//label					: String;
					ControlType_Custom_TimePicker,								//controlType			: Integer;
					Main_Group_Key,														//parent				: String;
					null,														//dataStore				: String;
					false,														//readOnly				: Boolean;
					null,														//dataList				: String;
					null,														//storeIdField			: String;
					null,														//storeDescField 		: String;
					null,
					null,
					null//repeatedStoreField	: String
					);
					
	//set any additional details
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CargoId);
	fieldDef.controlType := self.ControlType_MultiTextBox;//29/10/2010 cnwdz2	26182
	fieldDef.isUppercaseText := true;

	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Stops);
	fieldDef.controlType := ControlType_ListBox;
	fieldDef.dataStore	:= JMTUserInterfaceService::getStopsForUpdateDelete.name;//TFS2708
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ToDoTasks);
	fieldDef.controlType :=  ControlType_ListBox;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Grade);
	fieldDef.controlType :=  ControlType_ComboBox;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsNotify);
	fieldDef.controlType := ControlType_CheckBox;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsClear);	//cnwmc5 - 21 May 2014 - CCMS 2289
	//fieldDef.key := WS_EventRequestStops::isClear.name;			//cnwmc5 - 21 May 2014 - CCMS 2289
	fieldDef.controlType := ControlType_CheckBox;
	
	 //10/09/2009 cnwdz2 20629
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_AutoCleanup);
	fieldDef.controlType := ControlType_CheckBox;
	fieldDef.key := WS_EventRequestStops::autoCleanUp.name;
	fieldDef.defaultId := "true";	//cnwmc5 - PAR 32206
	fieldDef.defaultDescription := "true";	//cnwmc5 - PAR 32206
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_EmailAddresses);
	//fieldDef.parent := ETRow_IsNotify;
	fieldDef.controlType := ControlType_Custom_Recipients;
	
	//fieldDef := self.allFormFieldsByKey.getAtKey(WS_CargoNoteUpdateRequest::allNotifyTimesString.name);
	//fieldDef.parent := ETRow_IsNotify;
	
	
	//setup defaults
	//fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_MyCargoType);
	//fieldDef.defaultId := app.myPassport.myTerminal.defaultCargoType.String;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Remarks);
	fieldDef.controlType := ControlType_MultiTextBox; //all text boxes on the JMT form are multi-line
	
	
	//cnwmc5 - 22 April 2015 - PAR 36024
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Status);
	fieldDef.controlType := ControlType_ComboBox;
	fieldDef.key := WS_EventRequestStops::status.name;
	fieldDef.storeIdField := WS_EventStatus::id.name;
	fieldDef.storeDescriptionField := WS_EventStatus::description.name;
	fieldDef.repeatedStoreField := WS_EventStatus.name;
	fieldDef.defaultId := EventRequestPending.asStringJMT();
	fieldDef.defaultDescription := EventRequestPendingStr;
	fieldDef.readOnlyAlways := true;
	fieldDef.readOnly := true;
	
epilog
	delete hiddenRows;
	delete visibleRows;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="buildUpdateRequestSearchForm" id="fa189d6c-1867-464f-a67a-d4cd8d38ea75">
        <updating/>
        <source>buildUpdateRequestSearchForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2008	cnwkao1	Initial creation

*/
	
vars
		
begin
	self.proxyClassName			:= WS_CargoStopQueryRequest.name; // used by SOAP parser to create the correct type
	self.proxySearchClassName	:= WS_EventRequestStops.name;
	self.primarySearchLabel		:= "Update Request ";
	self.buildCommonEventReqSearchDef(); //this search form definition is utilised for cargo note stop and cargo note request	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildVehicleBookingEnqSrchForm" id="afa16dee-6a97-4bae-a76a-2647a447b4eb">
        <updating/>
        <source>buildVehicleBookingEnqSrchForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Oct 2014	cnwmc5	Initial creation	Par 35008

*/

constants
	Parent_Column1	: String = "column1";
	Parent_Column2	: String = "column2";
	
	Hidden_Group_Key : String = "hidden";
	
vars
	entTableGroup	: EntTableGroup;
	entTableRow		: EntTableRow;	
	fieldDef		: WS_FieldDefinition;
	column1Rows		: StringArray; 
	column2Rows		: StringArray;
	hiddenRows		: StringArray;
	parent			: String;
	rowName			: String;
	now 			: Date;
	
begin
	self.proxyClassName			:= WS_VehicleBookingTimesRequest.name;
	self.proxySearchClassName	:= WS_VehicleBookingTimeslot.name;
	self.primarySearchLabel	    := "Vehicle Bookings Enquiry ";
	
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_VehicleSchedule);
	
	self.buildHiddenGroup(Hidden_Group_Key);
	create hiddenRows transient;
	hiddenRows.add(WS_VehicleBookingTimesRequest::isEnquiry.name);
	
	foreach rowName in hiddenRows do
		self.buildHiddenField(rowName,Hidden_Group_Key);
	endforeach;
	
	create column1Rows transient;
	column1Rows.add(ETRow_CarrierFilter);
	column1Rows.add(ETRow_DriverFilter);
	column1Rows.add(ETRow_Vehicle);
	column1Rows.add(ETRow_TsType);
	self.buildGroupHeader(Parent_Column1, null, null);
	
	create column2Rows transient;
	column2Rows.add(ETRow_FromDate);
	column2Rows.add(ETRow_ToDate);
	self.buildGroupHeader(Parent_Column2, null, null);
	
	foreach rowName in column1Rows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then
			fieldDef		:= self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Parent_Column1;	
		endif;
	endforeach;
		
	foreach rowName in column2Rows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then
			fieldDef		:= self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Parent_Column2;
		endif;
	endforeach;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CarrierFilter);
	fieldDef.key := WS_VehicleBookingTimesRequest::carrierFilter.name;
	fieldDef.defaultId := null;
	fieldDef.defaultDescription := null;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_DriverFilter);
	fieldDef.key := WS_VehicleBookingTimesRequest::driverFilter.name;
	fieldDef.dataReloadField := ETRow_CarrierFilter;
	fieldDef.controlType := ControlType_ComboBox;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Vehicle);
	fieldDef.key := WS_VehicleBookingTimesRequest::vehicleFilter.name;
	fieldDef.dataReloadField := ETRow_DriverFilter;
	fieldDef.controlType := ControlType_ComboBox;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FromDate);
	fieldDef.key := WS_VehicleBookingTimesRequest::fromDate.name;
	fieldDef.defaultId := now.asStringForWebInterface();
	fieldDef.defaultDescription := now.asStringForWebInterface();
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ToDate);
	fieldDef.key := WS_VehicleBookingTimesRequest::toDate.name;
	fieldDef.defaultId := now.asStringForWebInterface();
	fieldDef.defaultDescription := now.asStringForWebInterface();
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TsType);
	fieldDef.key := WS_VehicleBookingTimesRequest::typeFilter.name;
	fieldDef.controlType := ControlType_ComboBox;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(WS_VehicleBookingTimesRequest::isEnquiry.name);
	fieldDef.defaultId := "true";
	
epilog
	delete column1Rows;
	delete column2Rows;
	delete hiddenRows;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildVehicleBookingFormDef" id="9ba2c09f-7620-44a7-b354-699fb27ebaa9">
        <updating/>
        <source>buildVehicleBookingFormDef(_isEnquiry : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393

*/

constants
	Main_Group_Desc			: String = "Main Details";
	Main_Group_Key			: String = "main";
	
	Hidden_Group_Key		: String = "hidden";
	
vars	
	entTableGroup	: EntTableGroup;
	entTableRow		: EntTableRow;
	mainRows,
	readOnlyRows,
	hiddenRows		: StringArray;
	fieldDef		: WS_FieldDefinition;
	rowName			: String;
	
begin
	self.proxySearchClassName	:= WS_VehicleBookingTimeslot.name;
	self.proxyClassName			:= WS_VehicleBookingUpdateRequest.name;
	
	self.allowCreate := false;
	self.allowDelete := false;
	
	self.buildHiddenGroup(Hidden_Group_Key);
	create hiddenRows transient;
	hiddenRows.add(WS_ProxyObject::cmObjectId.name);
	hiddenRows.add(WS_ProxyObject::cmObjectEdition.name);
	
	foreach rowName in hiddenRows do
		self.buildHiddenField(rowName,Hidden_Group_Key);
	endforeach;
	
	create mainRows transient;
	mainRows.add(ETRow_FromDate);
	mainRows.add(ETRow_ToDate);
	mainRows.add(ETRow_Id);						//cnwmc5 - 29 Oct 2014 - PAR 35008
	mainRows.add(ETRow_TsType);					//cnwmc5 - 31 Oct 2014 - PAR 35008
	mainRows.add(ETRow_Carrier);
	mainRows.add(ETRow_Driver);
	mainRows.add(ETRow_Vehicle);
	//cnwmc5 - 31 Oct 2014 - PAR 35008
	if _isEnquiry then
		mainRows.add(ETRow_Arrived);
		mainRows.add(ETRow_Status);
	endif;
	mainRows.add(ETRow_ChkDelivery);
	mainRows.add(ETRow_CargoBookingIds);		//cnwmc5 - 29 Oct 2014 - PAR 35008
	mainRows.add(ETRow_Delivering);
	mainRows.add(ETRow_ChkPickup);
	mainRows.add(ETRow_CargoReleaseIds);		//cnwmc5 - 29 Oct 2014 - PAR 35008
	mainRows.add(ETRow_PickingUp);
	mainRows.add(ETRow_Remarks);

	fieldDef := self.buildGroupHeader(Main_Group_Key, null, Main_Group_Desc); //hold above entries
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_VehicleSchedule);
	
	//load each of the fields in order
	foreach rowName in mainRows do 
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);				
		if entTableRow &lt;&gt; null then
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Main_Group_Key;
			if rowName = ETRow_FromDate or rowName = ETRow_ToDate then
				fieldDef.readOnly := true;
			endif;
		endif;
	endforeach;
	
	//control type details
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Carrier);
	fieldDef.key := WS_VehicleBookingTimeslot::carrier.name;	
	fieldDef.controlType := ControlType_ComboBox;
	fieldDef.storeIdField := WS_ProxyObject::cmObjectId.name;
	fieldDef.storeDescriptionField := WS_Carrier::description.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Driver);
	fieldDef.key := WS_VehicleBookingTimeslot::driver.name;
	fieldDef.controlType := ControlType_ComboBox;
	fieldDef.dataReloadField := ETRow_Carrier;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Vehicle);
	fieldDef.key := WS_VehicleBookingTimeslot::vehicle.name;
	fieldDef.controlType := ControlType_ComboBox;
	fieldDef.dataReloadField := ETRow_Driver;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ChkDelivery);
	fieldDef.key := WS_VehicleBookingTimeslot::includesDelivery.name;	
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Delivering);
	fieldDef.key := WS_VehicleBookingTimeslot::allDeliveryTiIds.name;	
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ChkPickup);
	fieldDef.key := WS_VehicleBookingTimeslot::includesPickup.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_PickingUp);
	fieldDef.key := WS_VehicleBookingTimeslot::allPuTiIds.name;	
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Remarks);
	fieldDef.key := WS_VehicleBookingTimeslot::remarks.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FromDate);
	fieldDef.key := WS_VehicleBookingTimeslot::bookingTimeStart.name;	
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ToDate);
	fieldDef.key := WS_VehicleBookingTimeslot::bookingTimeEnd.name;	
	
	//cnwmc5 - 29 Oct 2014 - PAR 35008
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CargoBookingIds);
	fieldDef.key := WS_VehicleBookingTimeslot::allBookingIds.name;
	
	//cnwmc5 - 29 Oct 2014 - PAR 35008
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CargoReleaseIds);
	fieldDef.key := WS_VehicleBookingTimeslot::allBulkReleaseIds.name;
	
	//cnwmc5 - 30 Oct 2014 - PAR 35008
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Id);
	fieldDef.key := WS_VehicleBookingTimeslot::id.name;
	fieldDef.readOnly := true;
	
	//cnwmc5 - 31 Oct 2014 - PAR 35008
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TsType);
	fieldDef.key := WS_VehicleBookingTimeslot::timeSlotTypeString.name;
	fieldDef.readOnly := true;
	
	//cnwmc5 - 31 Oct 2014 - PAR 35008
	if _isEnquiry then
		fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Arrived);
		fieldDef.key := WS_VehicleBookingTimeslot::arrivedString.name;
		
		fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Status);
		fieldDef.key := WS_VehicleBookingTimeslot::statusString.name;
		fieldDef.defaultId := null;
		fieldDef.defaultDescription := null;
	endif;

epilog
	delete mainRows;
	delete hiddenRows;
end;</source>
        <Parameter name="_isEnquiry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildVehicleBookingSrchFormDef" id="34cb97d2-8ddb-4f93-a93d-726f1f190e12">
        <updating/>
        <source>buildVehicleBookingSrchFormDef() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393

*/

constants
	Parent_Column1	: String = "column1";
	Parent_Column2	: String = "column2";
	
vars
	entTableGroup	: EntTableGroup;
	entTableRow		: EntTableRow;	
	fieldDef		: WS_FieldDefinition;
	column1Rows		: StringArray; 
	column2Rows		: StringArray;
	parent			: String;
	rowName			: String;
	now 			: Date;
	
begin
	self.proxyClassName			:= WS_VehicleBookingTimesRequest.name;
	self.proxySearchClassName	:= WS_VehicleBookingTimeslot.name;
	self.primarySearchLabel	    := "Vehicle Bookings ";
	
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_VehicleSchedule);
	
	create column1Rows transient;
	column1Rows.add(ETRow_CarrierFilter);		//carrierFilter
	column1Rows.add(ETRow_DriverFilter);		//driverFilter
	column1Rows.add(ETRow_Vehicle);				//vehicleFilter
	column1Rows.add(ETRow_IncludeUnBooked);		//includeUnBooked
	self.buildGroupHeader(Parent_Column1, null, null); //hold above entries
	
	//build the main search field
	//fieldDef := self.loadFieldFromRow(entTableGroup.allEntTableRowsByName.getAtKey(ETRow_Carrier));
	
	create column2Rows transient;
	column2Rows.add(ETRow_TsType);		//cnwmc5 - 28 Oct 2014 - PAR 35008
	column2Rows.add(ETRow_FromDate);		//fromDate
	column2Rows.add(ETRow_ToDate);		//toDate
	self.buildGroupHeader(Parent_Column2, null, null); //hold above entries
	
	foreach rowName in column1Rows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then
			fieldDef		:= self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Parent_Column1;	
		endif;
	endforeach;
		
	foreach rowName in column2Rows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then
			fieldDef		:= self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Parent_Column2;
		endif;
	endforeach;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CarrierFilter);
	fieldDef.key := WS_VehicleBookingTimesRequest::carrierFilter.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_DriverFilter);
	fieldDef.key := WS_VehicleBookingTimesRequest::driverFilter.name;
	fieldDef.dataReloadField := ETRow_CarrierFilter;
	fieldDef.controlType := ControlType_ComboBox;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Vehicle);
	fieldDef.key := WS_VehicleBookingTimesRequest::vehicleFilter.name;
	fieldDef.dataReloadField := ETRow_DriverFilter;
	fieldDef.controlType := ControlType_ComboBox;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IncludeUnBooked);
	fieldDef.key := WS_VehicleBookingTimesRequest::includeUnBooked.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FromDate);
	fieldDef.key := WS_VehicleBookingTimesRequest::fromDate.name;
	fieldDef.defaultId := now.asStringForWebInterface();
	fieldDef.defaultDescription := now.asStringForWebInterface();
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ToDate);
	fieldDef.key := WS_VehicleBookingTimesRequest::toDate.name;
	fieldDef.defaultId := now.asStringForWebInterface();
	fieldDef.defaultDescription := now.asStringForWebInterface();
	
	//cnwmc5 - 28 Oct 2104 - PAR 35008
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TsType);
	fieldDef.key := WS_VehicleBookingTimesRequest::typeFilter.name;
	fieldDef.controlType := ControlType_ComboBox;
	
epilog
	delete column1Rows;
	delete column2Rows;
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlType" id="dd7d02cb-bd2f-43f5-9d17-ae9bc0e5472b">
        <source>getControlType(pVal : Integer; controlName: String) : String protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if pVal = Table.InputType_TextBox then
		if controlName.length &gt; 3 and controlName[1:3] = "cmb" then //hack to get the correct type
			return '2';
		endif;	
		return '0';
	elseif pVal = Table.InputType_TextNumeric then
		return '0';
	elseif pVal = Table.InputType_SignedNumeric then
		return '0';
	elseif pVal = Table.InputType_ComboBox then
		return '2';
	elseif pVal = Table.InputType_CheckBox then
		return '5';
	elseif pVal = CM_EntryTable.InputType_ColourSelection then
		return '0';
	elseif pVal = CM_EntryTable.InputType_Date then
		return '0';		
	elseif pVal = CM_EntryTable.InputType_Picture then
		return '0';
	elseif pVal = CM_EntryTable.InputType_PictureViewOnly then
		return '0';
	elseif pVal = CM_EntryTable.InputType_Time then
		return '0';				
	elseif pVal = CM_EntryTable.InputType_TimeStamp then
		return '0';						
	else
		return '0';
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pVal" type="Integer"/>
        <Parameter name="controlName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDSDetailsForRowName" id="7a50135e-c0c3-4fb3-ae54-1571399a5c06">
        <source>getDSDetailsForRowName(	rowName		 	: String;
						dataStore		: String output;
						dsIDField		: String output;
						dsDescField 	: String output;
						dsRepeatField	: String output;
						defaultId		: String output;
						defaultDesc		: String output);
/*
Date		Who		Reason
27 Aug 2008	cnwkao1	Initial creation
13 Mar 2009	cnwkpd1	PAR #19109 - Add comboboxDescription to Operator, Commodity and Carrier
27 may 2009 concms1	par 19768 - new shippling line parameters for vessel operations summary
11 Aug 2011	cnwdap1	PAR #27972 Bulk release type no longer translatable, replaced by string constants
30 Nov 2011 cnwcs5  CCMS POL 2122 /PAR 28696 - add unkown type
24 Sep 2013	cnwdap1	PAR #32215 CCMS DPH 2290 New Car Attributes
08 May 2019	jlgdap1	TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
28 Aug 2019	jlgdap1	TFS 45769 JMT Web Portal selector query parameters
04 Oct 2019	jlgdap1	TFS 46315 JMT Proforma Report Issue
16 Jan 2023 navma1	Bug 55319: AAT - Off site cargo not being included in reports from the web portal
*/
vars
	defCargoType    : CM_CargoType;
	defImexStatus	: CM_IMEXStatus; 
	defNullVoayge	: CM_Voyage;
	cargoFilterSite	: WS_CargoFilterSite;
	canViewRail,
	canViewRoad,
	canViewPacking,
	canViewShip,
	canViewUnknown  : Boolean;
	terminal 		: CM_Terminal;
	defCarrier 		: CM_Carrier;
	
begin
	terminal := app.myPassport.myTerminal; //+ cnwmd1 Par 25490
	
	if rowName = ETRow_CargoType or
	   rowName = ETRow_MyCargoType or
	   rowName = ETRow_FilterTiType then
		dataStore		:= JMTUserInterfaceService::getCargoTypes.name;
		dsIDField		:= WS_CargoType::id.name; 			//IDField_ID;	
		dsDescField		:= WS_CargoType::description.name; //DescField_Desc
		dsRepeatField	:= WS_CargoType.name;
		
		if rowName &lt;&gt; ETRow_FilterTiType then								//cnwmc5 - 6 Jan 2014 - PAR 32548
			defCargoType := app.myPassport.getDefaultCargoType();
			if defCargoType &lt;&gt; null then
				defaultId	:= defCargoType.id.asStringJMT();
				defaultDesc := defCargoType.description;	
			endif;
		endif;																//cnwmc5 - 6 Jan 2014 - PAR 32548
	//18/03/2010 cnwdz2 23232	
	elseif rowName = ETRow_MyProduct or
		   rowName = ETRow_FilterProduct or									//cnwmc5 - 16 Sep 2014 - PAR 34888
		   rowName = ETRow_ProductType  then								//cnwmc5 - 18 Dec 2014 - PAR 35320
	//cmb - code subclass - dependant on operator
		dataStore 		:= JMTUserInterfaceService::getCargoSubtypesForCargoType.name;
		dsIDField		:= WS_Product::code.name;							//dsIDField := "code";
		dsDescField		:= WS_Product::comboboxDescription.name;			//dsDescField := "description";
		dsRepeatField	:= WS_Product.name;
	elseif rowName = ETRow_Product	  then  								//epr TFS 37654 19/3/18 this is for reports
		dataStore 		:= JMTUserInterfaceService::getCargoSubtypesForSearch.name;
		dsIDField		:= WS_Product::code.name;							//dsIDField := "code";
		dsDescField		:= WS_Product::comboboxDescription.name;			//dsDescField := "description";
		dsRepeatField	:= WS_Product.name;
		
	elseif rowName = ETRow_IsoType or
			rowName = ETRow_IsoTypeCode or
		   rowName = ETRow_IsoTypeDesc or
		   rowName = ETRow_FilterISOType then
		dataStore		:= JMTUserInterfaceService::getISOTypes.name;
		dsIDField		:= WS_ISOType::code.name; 							//IDField_Code;		//dsIDField := "code";
		dsDescField		:= WS_ISOType::comboboxDescription.name; 			//DescField_Desc;	//dsDescField := "comboboxDescription";
		dsRepeatField	:= WS_ISOType.name;

	elseif rowName = ETRow_ImexStatusString or
		   rowName = ETRow_ImexStatus or
		   rowName = ETRow_FilterIMEXStatus or
		   rowName = ETRow_IMEXStatuses or
		   rowName = ETRow_FilterIMEX then
		dataStore		:= JMTUserInterfaceService::getIMEXStatuses.name;
		dsIDField		:= WS_IMEXStatus::code.name;						//IDField_Code;		//dsIDField := "code";
		dsDescField		:= WS_IMEXStatus::description.name; 				//DescField_Desc;	//dsDescField := "description";
		dsRepeatField	:= WS_IMEXStatus.name;
		
		if rowName = ETRow_ImexStatusString or //14/06/2010 cnwdz2 par24433
		   rowName = ETRow_ImexStatus or
		   rowName = ETRow_IMEXStatuses then
			defImexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]; //sep/2009 cnwdz2 20635
			if defImexStatus &lt;&gt; null then
				defaultId	:= defImexStatus.code.asStringJMT();
				defaultDesc := defImexStatus.description;	
			endif;
		endif;
		
	elseif rowName = ETRow_ShippingLineCode or
			rowName = ETRow_ShippingLine then	// par 19768
		dataStore		:= JMTUserInterfaceService::getShippingLines.name;
		dsIDField		:= WS_ShippingLine::code.name;						//IDField_Code;		//dsIDField := "code";
		dsDescField		:= WS_ShippingLine::description.name; 				//DescField_Desc;	//dsDescField := "description";
		dsRepeatField	:= WS_ShippingLine.name;
	
	elseif rowName = ETRow_VoyageCode then //18 Mar 2009	cnwdz2	PAR 19058 
		dataStore		:= JMTUserInterfaceService::getCurrentVoyages.name;
		dsIDField		:= WS_Voyage::code.name; 							//IDField_Code;		//dsIDField := "code";
		dsDescField		:= WS_Voyage::comboboxDescription.name; 			//DescField_Desc;	//dsDescField := "comboboxDescription";		
		dsRepeatField	:= WS_Voyage.name;
		defNullVoayge := terminal.allVoyagesNew.getAtKey(NULL_VOYAGE_CODE,null);
		if defNullVoayge &lt;&gt; null then
			defaultId	:= defNullVoayge.code;
			defaultDesc := defNullVoayge.code &amp; " " &amp; defNullVoayge.description;	
		endif;
	
	elseif rowName = ETRow_VoyageActual then //18 Mar 2009	cnwdz2	PAR 19058 
		dataStore		:= JMTUserInterfaceService::getGlobalVoyageActual.name;
		dsIDField		:= WS_VoyageGlobal::code.name; 						//IDField_Code;		//dsIDField := "code";
		dsDescField		:= WS_VoyageGlobal::comboboxDescription.name; 		//DescField_Desc;	//dsDescField := "comboboxDescription";		
		dsRepeatField	:= WS_VoyageGlobal.name;
	
	//18/05/2009 cnwdz2 par19257 changed ETRow_Voyage to ETRow_VoyageAllocated
	elseif rowName = ETRow_VoyageAllocated then //18 Mar 2009	cnwdz2	PAR 19058 
		dataStore		:= JMTUserInterfaceService::getGlobalVoyageAllocated.name;
		dsIDField		:= WS_VoyageGlobal::code.name; //IDField_Code;	//dsIDField := "code";
		dsDescField		:= WS_VoyageGlobal::comboboxDescription.name; //DescField_Desc;	//dsDescField := "comboboxDescription";		
		dsRepeatField	:= WS_VoyageGlobal.name;
		
	elseif rowName = ETRow_FilterVoyage or
		   rowName = ETRow_MyVoyage or
		   rowName = ETRow_Voyage then
		dataStore		:= JMTUserInterfaceService::getActiveVoyages.name;
		dsIDField		:= WS_Voyage::code.name; //IDField_Code;	//dsIDField := "code";
		dsDescField		:= WS_Voyage::comboboxDescription.name; //DescField_Desc;	//dsDescField := "comboboxDescription";		
		dsRepeatField	:= WS_Voyage.name;
	elseif rowName = ETRow_ReportVoyage then
		//epr 4644 9/6/17
		dataStore		:= JMTUserInterfaceService::getReportVoyages.name;
		dsIDField		:= WS_Voyage::code.name;
		dsDescField		:= WS_Voyage::comboboxDescription.name; 	
		dsRepeatField	:= WS_Voyage.name;
	elseif rowName = ETRow_Supplier or
		   rowName = ETRow_OperatorCode or
		   rowName = ETRow_Operator or
		   rowName = ETRow_FilterOperator then
		dataStore 		:= JMTUserInterfaceService::getOperatorsForSearch.name;
		dsIDField		:= WS_Operator::code.name;	//dsIDField := "code";
		dsDescField		:= WS_Operator::comboboxDescription.name;	//dsDescField := "description";
		dsRepeatField	:= WS_Operator.name;

	elseif rowName = ETRow_ReleaseCarrier or
		   rowName = ETRow_Carrier or
		   rowName = ETRow_FilterCarrier  or
		   rowName = ETRow_MyCarrier //jlier1 TFS 53807 13/6/22
		   then  //cnwmc5 - PAR 31393
		   //rowName = ETRow_CarrierCode then //17/04/2009 cnwdz2 par19457
		dataStore 		:= JMTUserInterfaceService::getCarriers.name;
		dsIDField		:= WS_Carrier::code.name;	//dsIDField := "code";
		dsDescField		:= WS_Carrier::comboboxDescription.name;	//dsDescField := "description";
		dsRepeatField	:= WS_Carrier.name;

	elseif rowName = ETRow_Commodity then
		dataStore 		:= JMTUserInterfaceService::getCommodities.name;
		dsIDField		:= WS_Commodity::code.name;	//dsIDField := "code";
		dsDescField		:= WS_Commodity::comboboxDescription.name;	//dsDescField := "description";
		dsRepeatField	:= WS_Commodity.name;
	
	//06/07/2009 cnwdz2 par 20233
	elseif rowName = ETRow_Consignee or
		   rowName = ETRow_FilterConsignee then
		dataStore		:= JMTUserInterfaceService::getConsigneesForSearch.name;
		dsIDField		:= WS_ConsigneeConsignor::code.name;	//dsIDField := "code";
		dsDescField		:= WS_ConsigneeConsignor::comboboxDescription.name;	//dsDescField := "description";
		dsRepeatField	:= WS_ConsigneeConsignor.name;
		
	elseif rowName = ETRow_DischargePort or
		   rowName = ETRow_DestinationPort or
		   rowName = ETRow_AllDischargePorts or
		   rowName = ETRow_LoadPort or
		   rowName = ETRow_MyTranshipToPort then //epr TFS 37654 19/3/18
		dataStore 		:= JMTUserInterfaceService::getPortsForSearch.name;
		dsIDField		:= WS_Port::code.name;	//dsIDField := "code";
		dsDescField		:= WS_Port::description.name;	//dsDescField := "description";
