    <JadeMethod name="newIdNotAlreadyUsed" id="66eba18b-5464-44bd-955a-04f409edd5e3">
        <source>newIdNotAlreadyUsed(_newId: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2018	jlgndl1	Initial creation	TFS 39142

*/

vars

	existingWO : CM_WorkOrder;

begin

	existingWO := self.myTerminal.allWorkOrders[ _newId];
	if existingWO = null then
		// no Work Order with the same id.
		return true;
	endif;

	return false;

epilog

end;</source>
        <Parameter name="_newId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
