<Class name="CM_Vehicle">
    <JadeMethod name="importMyReferencesXML" id="6863f94b-2a96-4b24-bdc1-82da9b996309">
        <updating/>
        <source>importMyReferencesXML(_referencesBlock: String) updating;

vars
	theCode: String;
begin
	theCode := _referencesBlock.cnEcGetTagValueOfName('carrier');
	self.carrier := app.myRoot.allCarriers[theCode];
	inheritMethod(_referencesBlock);
end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importXMLFixupPre" id="77eb2b74-1bdd-4b8a-9e0c-66997566ad8a">
        <updating/>
        <source>importXMLFixupPre() updating;

vars

begin
	self.myTerminal := CM_Terminal.firstInstance;
	inheritMethod();
end;</source>
    </JadeMethod>
</Class>
