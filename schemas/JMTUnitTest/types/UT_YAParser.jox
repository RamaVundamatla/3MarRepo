    <JadeMethod name="tCreateBlocks" id="4730fc36-0c98-49f4-a17e-dbb5b62741a2">
        <source>tCreateBlocks();
// cnwndl1
//08 September 2008	cnwdw1	
//
vars
	yaParser: CM_YAParser;
	proxyYA: CM_YardAllocation;
	stradStack: CM_StraddleStack;
	blocks: ObjectArray;
	locations: CM_LCArray;
	ya: CM_YardAllocation;
begin
	deleteTerminalArea("UTSTRD");
	stradStack := addStraddleStack("UTSTRD", 10, 5, 3);

	create blocks transient;
	create locations transient;
	locations.add(stradStack.allGridControllersByName["020002"]);
	locations.add(stradStack.allGridControllersByName["020003"]);
	locations.add(stradStack.allGridControllersByName["030002"]);
	locations.add(stradStack.allGridControllersByName["030003"]);
	blocks.add(locations);
	
	create yaParser transient;
	create proxyYA transient;

	yaParser.createBlocks(proxyYA, blocks);
	assertTrueMsg(yaParser.errorMessage = null, "yaParser error - " &amp; yaParser.errorMessage);
	assertTrueMsg(yaParser.allYABlocksIn.size = 1, "Not enough blocks");
	assertTrueMsg(yaParser.allYABlocksIn[1].allYardControllers.size = 4, "Not enough blocks");
epilog
	delete locations;
	delete blocks;
	if yaParser &lt;&gt; null then
		yaParser.allYABlocksIn.purge;
	endif;
	delete yaParser;
	delete proxyYA;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateTwoBlocks" id="31065a5f-4724-4873-908a-1a1d44cc6030">
        <source>tCreateTwoBlocks();
// cnwndl1
//08 September 2008	cnwdw1	
// Create two location blocks
vars
	yaParser: CM_YAParser;
	proxyYA: CM_YardAllocation;
	stradStack: CM_StraddleStack;
	blocks: ObjectArray;
	locations1: CM_LCArray;
	locations2: CM_LCArray;
	ya: CM_YardAllocation;
begin
	deleteTerminalArea("UTSTRD");
	stradStack := addStraddleStack("UTSTRD", 10, 5, 3);

	create blocks transient;
	create locations1 transient;
	locations1.add(stradStack.allGridControllersByName["020002"]);
	locations1.add(stradStack.allGridControllersByName["020003"]);
	locations1.add(stradStack.allGridControllersByName["030002"]);
	locations1.add(stradStack.allGridControllersByName["030003"]);
	blocks.add(locations1);
	
	create locations2 transient;
	locations2.add(stradStack.allGridControllersByName["080002"]);
	locations2.add(stradStack.allGridControllersByName["080003"]);
	locations2.add(stradStack.allGridControllersByName["090002"]);
	locations2.add(stradStack.allGridControllersByName["090003"]);
	blocks.add(locations2);
	
	create yaParser transient;
	create proxyYA transient;

	yaParser.createBlocks(proxyYA, blocks);
	assertTrueMsg(yaParser.errorMessage = null, "yaParser error - " &amp; yaParser.errorMessage);
	assertTrueMsg(yaParser.allYABlocksIn.size = 2, "Not enough blocks");
	assertTrueMsg(yaParser.allYABlocksIn[1].allYardControllers.size = 4, "Not enough blocks");
epilog
	delete locations1;
	delete locations2;
	delete blocks;
	if yaParser &lt;&gt; null then
		yaParser.allYABlocksIn.purge;
	endif;
	delete yaParser;
	delete proxyYA;
end;</source>
    </JadeMethod>
</Class>
