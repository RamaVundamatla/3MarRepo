<Class name="WS_TierDefn" id="687fdd90-c71d-46f7-8481-16cc20d419a3">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Internal use only. No external support</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="alignment" id="1021ed63-2cc0-43ae-bf6a-584d311cf8cc">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <ImplicitInverseRef name="allLayouts" id="32cc5356-e514-4fa5-81e7-5614892a628c">
        <memberTypeInverse/>
        <type name="WS_LayoutArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="label" id="311b3c8a-c6c1-46b4-83be-165590a80c66">
        <length>3</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="ordinal" id="1314ec8c-892b-41e0-9236-3391d8ae8265">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="ordinalDeck" id="2db6920a-ef38-4688-94c4-808c6f95849d">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="createProxy" id="35237098-a42c-42e2-8991-d9153f9670a7">
        <source>createProxy(_bay : CM_BayDefn);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	pxyTier : CM_TierDefn;
	onDeckBay,
	underDeckBay : CM_BayDefn;
	completedOK 	: Boolean;
	wsLayout 		: WS_Layout;
begin

	if self.ordinalDeck  = DeckOnDeck then
		onDeckBay:=_bay;
	else
		underDeckBay :=_bay;
	endif;
	
	create pxyTier transient;
	pxyTier.setProxy(self.label, self.ordinal, self.ordinal,onDeckBay,underDeckBay);
	
	foreach wsLayout in self.allLayouts discreteLock do
		wsLayout.createProxy(pxyTier);
	endforeach;
	completedOK:=true;
epilog
	if not completedOK then
		delete pxyTier;
	endif;
end;</source>
        <Parameter name="_bay" type="CM_BayDefn"/>
    </JadeMethod>
    <JadeMethod name="delete" id="18041567-5efe-4cb1-abcb-4321b06caa85">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlger1	Initial creation 7521

*/

vars

begin
	self.allLayouts.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="e8b6b586-9dc8-4d31-baeb-510115681007">
        <updating/>
        <source>setProxyFromObject(_object: CM_TierDefn) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwer1	Initial creation HAT 2189

*/

vars

begin

	self.label:=_object.id;
	self.ordinal:=_object.ordinal;
	if _object.overDeck &lt;&gt; null then
		self.ordinalDeck:=DeckOnDeck;
	else
		self.ordinalDeck:=DeckUnderDeck;
	endif;

	self.setProxyLayouts(_object);
epilog

end;</source>
        <Parameter name="_object" type="CM_TierDefn"/>
    </JadeMethod>
    <JadeMethod name="setProxyLayouts" id="917652d8-a593-4917-854a-3c4eb8a8439b">
        <source>setProxyLayouts(_tier : CM_TierDefn) protected;
/*

Date		Who		Reason
16 August 2013	cnwer1	Initial creation PAR

*/

vars
	wsLayout	: WS_Layout;
	layout 		: CM_BayItemLayout;
begin
	foreach layout in _tier.allBayItemLayouts discreteLock do
		create wsLayout transient;
		wsLayout.setProxyFromObject(layout);
		self.allLayouts.add(wsLayout);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tier" type="CM_TierDefn"/>
    </JadeMethod>
</Class>
