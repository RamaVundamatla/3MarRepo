    <JadeMethod name="requiresOverHangingBackend" id="19907dc0-5e80-45cf-bb6f-63fd7c323cf7">
        <source>requiresOverHangingBackend(_theTI: CM_TrackedItem): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

