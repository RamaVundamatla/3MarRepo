<Class name="CM_AttributePlan">
    <JadeMethod name="importPLXMLReference" id="d36bb80b-238f-4beb-afba-b3c7a7f011ce">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

