    <JadeMethod name="setConvertedDisplayValue" id="d786d9a9-7891-49c7-815a-101231fd5f80">
        <source>setConvertedDisplayValue(_table: CM_EntryTable input; _rowName: String; _rawValue: Decimal; _measureType: CM_MeasurementType) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgndl1	Initial creation	TFS 7216 moved up from SOP_TerminalAreaDefForm

*/

vars
	rawValue : Decimal [16,4];
	convertedValue : String;
	prefix : String;
	
begin

	rawValue := _rawValue;

	convertedValue := app.convertMeasurementForDisplay(_measureType.shortName, rawValue) &amp; Space &amp; _measureType.shortName;
	if not app.myRoot.getConfig(MeasuresSeparateLines).Boolean then
		self.getMultiValueConvertedString( rawValue, _measureType, convertedValue );
	endif;
	
	prefix := app.getMeasurementPrefixFromType( _measureType.measurementType );

	_table.setValueByName(_rowName, convertedValue);
	_table.setValueByName( prefix &amp; _rowName &amp; "_" &amp; _measureType.shortName, convertedValue );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_rawValue" type="Decimal"/>
        <Parameter name="_measureType" type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="setDoingMultiEdit" id="c889579c-35fc-4bbe-9344-98cfbd9ac676">
        <updating/>
        <source>setDoingMultiEdit() updating;
// ---------------------------------------------------------------------------
// Created:     03 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.doingMultiEdit := false;

	if self.multiSelect &lt;&gt; CM_BaseTable.MultiSelect_None and
	   tblData.allSelectedObjects.size &gt; 1 then
	   	if (not self.allowMultiSelectEdit) then
	   		app.msgBox('You must select only ONE item to edit', 'Error', MsgBox_OK_Only + MsgBox_Information_Icon);
	   		return;
	   	endif;
	   	self.doingMultiEdit := true;
		// If in multi-select we will get the details to edit from the last row selected
		// so store this in myCurrentObject
		if self.myCurrentObject = null or not self.isCurrentObjectInSelection then		//cnwmc5 - 30 July 2013 - PAR 31612
			self.myCurrentObject := tblData.allSelectedObjects.last.Object;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEditValueForRow" id="7d296e4e-ed95-4280-825a-18aeddee722e">
        <source>setEditValueForRow(_tbl : CM_EntryTable input; _entRowName: String; _obj: CM_Object): Boolean protected;
//----------------------------------------------------------------
//	Created:	21 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	ediValue	: String;
	setValue	: Boolean;
begin

	ediValue	:= _obj.getEditStringForAttribute(_entRowName, setValue);
	
	if setValue then
		_tbl.setValueByName(_entRowName, ediValue);
	endif;
	
	return setValue;
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
