    <JadeMethod name="addJobSheet" id="165baeba-b6ed-4475-a3db-a96ffa15b1ff">
        <source>addJobSheet(_js : CM_VoyageJobSheet);

vars

begin
	self.allJobSheets.add(_js);
	
	_js.sortWLEsForOverstowCheck();
end;
</source>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
    </JadeMethod>
    <JadeMethod name="checkOSAbsolute" id="b93150c3-3ca1-4c3b-a0d1-603f18e13744">
        <updating/>
        <source>checkOSAbsolute() updating;

vars
	wle : CM_WorkListEntry;
	vWLE : CM_VoyageWLE;
	js : CM_JobSheet;
	ti : CM_TrackedItem;
begin
	self.osMoveTotals.clear;
	
	self.mode := self.Mode_Absolute;
	// ### for each job sheet get total number of overstowTIs for different job sheet.
	foreach js in self.allJobSheets do
		self.allOverStowingTIs.clear;
		foreach wle in js.allWLEByOrder do
			ti := wle.myTrackedItem;
			ti.getOSTIsForDiffJobSheetAsWorkd(self.allOverStowingTIs, self);
			
		endforeach;
		self.osMoveTotals.atPut(self.mode,self.allOverStowingTIs.size);
	endforeach;
	
end;
</source>
    </JadeMethod>
