    <JadeMethod name="jhpConvertAllCurrent" id="00e649a6-3a62-471b-b7c3-666c4d568582">
        <source>jhpConvertAllCurrent();
//	creates a csv file with all stats counters
vars
	s,t,u,v:String;
	i,j,k:Integer;
	l:Integer64;
	ia:Integer64Array;
	firstTime:Boolean;
	ts,prevts:TimeStamp;
	f,g:File;
	ff:FileFolder;
	readCount:Integer;
begin
	create ia transient;
	firstTime := true;
	create f;
	create g;
	f.fileName := "u:\jp\TestGroupingSplitup\jommon_20151208_cnwjhp1_released_182140.log";
	f.usePresentationFileSystem := false;
	g.fileName := f.fileName.replace(".log", "_SysStats.csv");
	g.usePresentationFileSystem := false;
	g.mode := File.Mode_Output;
	f.kind := File.Kind_Unknown_Text;

	// find starting timestamp, build header line
	while not f.endOfFile do
		s := f.readLine;
		readCount  :=  readCount + 1;
//		if readCount mod 1000 = 0 then
//			write readCount;
//		endif;
//		continue;
		if s.contains("key=8") then
			i := 1;
			ts := s.scanUntil(" ", i).TimeStamp;
			foreach k in 1 to 3 do  // skip to first stats field
				s.scanUntil(";", i); i := i+1;
			endforeach;
			if firstTime then  // build header line
				t := "Date,Time,";
			else
				t := ts.logFormat.replace(" ", ",")[1:19] &amp; ",";  // build detail line
			endif;
			foreach k in 1 to 15 do  // 15 stats fields
				u := s.scanUntil(";", i); i := i+1;
				j := 1;
				if firstTime then  // build header line
					t := t &amp; u.scanUntil("[", j) &amp; ",";
					u.scanUntil("=", j); j := j+1;
					ia[k] := u[j:end].Integer64;
				else  // build detail line
					u.scanUntil("=", j); j := j+1;
					l := u[j:end].Integer64;
					t := t &amp; ((l - ia[k])/((ts - prevts).getMilliseconds/1000)).rounded.String &amp; ",";
					ia[k] := l;
				endif;
			endforeach;
			if firstTime then  // build header line
				t := t[1:t.length-1];
				firstTime := false;
			endif;
			//write ia.display;
			g.writeLine(t);
			//write ((ts - prevts).getMilliseconds/1000).rounded;
			prevts := ts;
			//break;
		endif;
	endwhile;

epilog
	delete f;
	delete g;
	delete ff;
	delete ia;
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpConvertAllCurrent2" id="97a75d19-e8cc-4918-afd5-c080d5ce8ee1">
        <source>jhpConvertAllCurrent2();
//	creates a csv file in the new TestGroupingSplitup format
vars
	tag,value,file,testsuite,testconfig,s,t,u,v,testName:String;
	queueType,minRelease1,minRelease2,special:String;
	i,j,k,pos,prevPos:Integer;
	f,g,h:File;
	ff:FileFolder;
	readCount:Integer;
begin
	write "";
	write "Starting";
	create f;
	create g;
	f.fileName := "u:\jp\TestGroupingSplitup\allcurrent.conf";
	f.usePresentationFileSystem := false;
	f.kind := File.Kind_Unknown_Text;
	
	g.fileName := f.fileName.replace("allcurrent.conf", "AllCurrent_jp.csv.txt");
	g.usePresentationFileSystem := false;
	g.mode := File.Mode_Output;
	g.writeLine("AutoTestName,QueueType,MinRelease1,MinRelease2,SpecialConditions");
	create h;
	h.usePresentationFileSystem := false;

	file := f.readString(f.fileLength);
	pos := 1;
	tag := file.getXMLTag(pos);  // high-level element is testsuite
	testsuite := file.getXMLValue(tag);
	write "tag=" &amp; tag &amp; Tab &amp; "length=" &amp; testsuite.length.String;
	
	pos := 1;
	while pos &lt; testsuite.length do
		readCount := readCount + 1;
		if readCount &gt;= 1777 then break; endif;
		prevPos := pos;
		tag := testsuite.getXMLTag(pos);
		testconfig := testsuite[prevPos:end].getXMLValue(tag);
		//write "";
		//write tag &amp; Tab &amp; testconfig.length.String &amp; Tab &amp; pos.String;
		//write testconfig.asXML(tag)[2:end];
		
		if tag &lt;&gt; "testconfig" then continue; endif;
		
		i := testconfig.pos("\\cnwchcs118\t$\svnrepocache\jade\plant\TestSuites\TestConfigs\FunctionalTests\jade\", 1);
		if i &gt; 0 then
			i := i + 84;
			testName := testconfig.scanUntil(".", i);
			if testconfig.contains("eptemplates") then
				testconfig.jhpGetTemplateQueueInfo(queueType, minRelease1, minRelease2, special);
			else
				testconfig.jhpGetExePlanQueueInfo(queueType, minRelease1, minRelease2, special);
			endif;
			
			if testName = "q_DbConvertToUnicode" then
				minRelease2 := "";
			elseif testName = "Upgrade63SU70" or testName = "Upgrade63HA70" then
				special := "le7049";
			endif;
			
			h.fileName:="\\cnwchcs118\t$\svnrepocache\jade\plant\TestSuites\TestConfigs\FunctionalTests\jade\" &amp; testName &amp; ".conf";
			if special &lt;&gt; "drop" and h.isAvailable and testName &lt;&gt; "AutoHumphrey63CSharp" and testName &lt;&gt; "q_physical_certify" then
				g.writeLine(testName &amp; "," &amp; queueType &amp; "," &amp;minRelease1 &amp; "," &amp; minRelease2&amp; "," &amp; special);
			endif;
		endif;
	endwhile;/**/

	write "Finished";
epilog
	delete f;
	delete g;
	delete h;
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpDoCmd" id="9bc35d0b-1b66-4558-8421-c9eb4e2a58a1">
        <updating/>
        <source>jhpDoCmd(cmd,cmdLog:String) updating;

vars
	result:String;
	i,j,retCode:Integer;
begin
	node.createExternalProcess(null,'cmd /c c:\cardinal\bin\datetime'&amp;cmdLog,null,null,false,true,retCode);
	node.createExternalProcess(null,'cmd /c echo '&amp;cmd&amp;cmdLog,null,null,false,true,retCode);
	node.createExternalProcess(null,'cmd /c '&amp;cmd&amp;cmdLog,null,null,false,true,retCode);
	result:=cmd&amp;" retCode="&amp;retCode.String&amp;" "&amp;process.userCode&amp;"@"&amp;process.userInfo;
	node.createExternalProcess(null,'cmd /c c:\cardinal\bin\datetime'&amp;cmdLog,null,null,false,true,retCode);
	app.logMessage(result);
end;</source>
        <Parameter name="cmd" type="String"/>
        <Parameter name="cmdLog" type="String"/>
    </JadeMethod>
    <JadeMethod name="jhpExtraDir" id="16a08c11-0f84-45ab-90b8-d26795ff5dfd">
        <updating/>
        <source>jhpExtraDir() updating;

vars
	f:File;
	i,j,k,files,folders,totalFiles,totalFolders:Integer;
	s,t:String;
begin
	app.logMessage(method.qualifiedName &amp; " Starting...");
	create f transient;
	f.usePresentationFileSystem:=false;
	f.maxRecordSize:=64000;
	f.fileName:="c:\thinbin\logs\robocopy.log";
	while not f.endOfFile do
		s:=f.readLine;
		if s.contains("*EXTRA Dir        -1	F:\results\manual\") then
			i:=s.pos("F:\results\manual\", 1);
			t:=s[i:end];
			app.logMessage("checking &lt;" &amp; t &amp; "&gt;");
			files:=0;
			folders:=0;
			jhpRemoveDir(t[1:t.length-1], files, folders);  // remove trailing backslash due to par 63447
			app.logMessage("deleted " &amp; files.String &amp; " files, " &amp; folders.String &amp; " folders");
			totalFiles:=totalFiles + files;
			totalFolders:=totalFolders + folders;
			//break;
		endif;
	endwhile;
	app.logMessage("deleted " &amp; totalFiles.String &amp; " files total, " &amp; totalFolders.String &amp; " folders total");
	app.logMessage(method.qualifiedName &amp; " Finished");
epilog
	delete f;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jhpFileSeek" id="50a4a5dc-1b2c-4e9d-abe0-469a7d65915b">
        <source>jhpFileSeek();
vars
	s,t,u,v,folderName,folderMask,include,exclude:String;
	i,j,k,l,tottime,subcount,totcount:Integer;
	last,startpos,lines:Decimal[23];
	presentationFileSystem,foundSection:Boolean;
	f,g:File;
	fn:FileNode;
	ff:FileFolder;
begin
	last:=6000001;
	lines:=3;

	create f;
	f.fileName:="\\cnwchcs4\t$\RMP5\RMP\RMP\Mappings\RoC_Company\RoC_Incorporation\1million_RoC_Company_Info_And_Address.csv";
	f.fileName:="C:\a\Jade pars\JADE_61305_1 (Test)\20140515_04.xml";
	f.fileName:="C:\a\aca\Migration_20140408\MigrationData\DemoIntel2014Q1\Data\RMP2a\StructuredRelationships\CsvConfigurationFile.csv";
	f.mode:=File.Mode_Input;
	f.maxRecordSize:=64000;
	presentationFileSystem:=true;
	//f.usePresentationFileSystem:=presentationFileSystem;
	write f.readString(f.fileLength).Binary.display; return;
	startpos:=f.fileLengthDec-last;
	startpos:=last;
	//f.seekDec(startpos - 100);
	//write startpos - 100;
	//write "&lt;" &amp; f.readString(500).Binary.display &amp; "&gt;"; return;
	//f.readLine;  // skip partial line
	while not f.endOfFile do
		s:=f.readString(100);
		write s.Binary.display;
		l:=l+1;
		if l &gt; lines then break; endif;
	endwhile;
	write f.lastModifiedTime;
epilog
	delete f;
	delete g;
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpFindChanges" id="c9ba04e3-2397-4efc-b697-5e21df247189">
        <source>jhpFindChanges();

vars
	c:Class;
	meth:Method;
begin
	foreach c in currentSchema.allClasses where c.name[1:11] = "TestProfile" do
		foreach meth in c.getPropertyValue("methods").MethodNDict do
			write meth.qualifiedName;
		endforeach;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jhpFindMissedTests" id="685a5352-6c3b-4529-8a58-0b343fa66f5b">
        <source>jhpFindMissedTests();

vars
	m:Machine;
	ff:FileFolder; fn:FileNode; f:File;
	thisConf,s:String;
	i,j:Integer;
begin
	write "tests missing from allcurrent.conf";
	create f transient;
	f.usePresentationFileSystem:=true;
	f.fileName:="T:\plant\TestingTools\suiteconfig\allcurrent.conf";
	
	thisConf:=f.readString(f.fileLength);
	f.close;
	
	create ff transient;
	ff.usePresentationFileSystem:=true;
	ff.mask:="*.conf";
	
	foreach i in 1 to 2 do
		if i = 1 then
			ff.fileName:=BankedTestStdLocation;
		else
			//ff.fileName:=JOOBTestStdLocation;
		endif;
		foreach fn in ff.files do
			f.fileName:=fn.fileName;
			if not thisConf.toLower.contains(f.fileName.toLower) and not f.fileName.contains("Spatial_Jade") and f.isAvailable then
				write 'missing test "'&amp;fn.fileName&amp;'"';
				f.close;
			endif;
		endforeach;
	endforeach;
	write "done";
epilog
	delete f;
	delete ff;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jhpFindPerlSubs" id="af080f4b-e3f5-44cb-99e7-7df968669ea4">
        <source>jhpFindPerlSubs();
vars
	s,t,u,v,subName:String;
	i,j,pos,subCount,lineNum,callCount,prevLineNum:Integer;
	f,g:File;
	fn:FileNode;
	ff:FileFolder;
begin
	create f;
	//f.fileName := "C:\a\TestFramework\perl\sources\jblworker.pl";
	//f.fileName := "U:\jp\TestFramework\changes\jblworker_no_split.pl";
	//f.fileName := "U:\jp\TestFramework\changes\jblcommon_jhp_AddElementSynopsis_2.pm";
	//f.fileName := "\\cnwchcs118\c$\thinbin\tools\dev\scripts\ppc.pl";
	//f.fileName := "u:\jp\TestFramework\jblautorun.pl";
	//f.fileName := "u:\jp\TestFramework\jblworker.pl";
	f.fileName := "u:\jp\TestFramework\jblcommon.pm";
	f.usePresentationFileSystem := false;
	s := f.readString(f.fileLength);
	f.close;
	write CrLf &amp; f.fileName;
	pos := 1;
	while true do
		pos := s.pos(CrLf &amp; "sub ", pos);
		if pos = 0 then break; endif;
		subCount := subCount + 1;
		if subCount &gt; 11115 then break; endif;  // loop controller
		pos := pos + 5;
		s.scanWhile(" ", pos);
		subName := s.scanUntil(" ([{" &amp; CrLf, pos);
		write CrLf;  // &amp; "sub " &amp; subName;
		//write "sub " &amp; subName; continue;  // to get just a sub name list
		
		callCount := 0;
		lineNum := 0;
		while not f.endOfFile do
			t := f.readLine;
			lineNum := lineNum + 1;
			if t.contains(subName) then
				j := 1;
				t.scanWhile(" 	", j);
				u := t.scanUntil("({ 	", j);
				if u &lt;&gt; "qw" and u &lt;&gt; "logit" and u &lt;&gt; "workoutfailuresummary" and u &lt;&gt; "proceed" then
					write lineNum.String &amp; " " &amp; t;
					callCount := callCount + 1;
					if callCount &gt; 8 then
						write "too many calls...";
						break;
					endif;
				endif;
			endif;
		endwhile;
		f.close;
	endwhile;
epilog
	delete f;
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpFindPerlSubsSize" id="6c0894c7-6d76-4ee8-a829-67d13cb9bd89">
        <source>jhpFindPerlSubsSize();
vars
	s,t,u,v,subName:String;
	i,j,pos,subCount,lineNum,callCount,prevLineNum:Integer;
	f,g:File;
	fn:FileNode;
	ff:FileFolder;
begin
	create f;
	//f.fileName := "C:\a\TestFramework\perl\sources\jblworker.pl";
	//f.fileName := "U:\jp\TestFramework\jblautorun.pl";
	f.fileName := "U:\jp\TestFramework\jblcommon_jhp_AddElementSynopsis.pm";
	//f.fileName := "C:\a\TestFramework\perl\scripts_check\jblworker.pl";
	f.usePresentationFileSystem := false;
	write CrLf &amp; "lineNum	size	subName		" &amp; f.fileName;
	subName := "initial stuff";
	while not f.endOfFile do
		t := f.readLine;
		lineNum := lineNum + 1;
		if t[1:3] = "sub" then
			write lineNum.padLeadingWith(" ", 6) &amp; Tab &amp; (lineNum - prevLineNum).padLeadingWith(" ", 6) &amp; Tab &amp; Tab &amp; subName;
			pos := 1;
			subName := t.scanUntil(" ", pos); pos := pos + 1;
			subName := t.scanUntil(" ", pos); pos := pos + 1;
			prevLineNum := lineNum;
		endif;
	endwhile;
epilog
	delete f;
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpFindResults" id="363df0cc-5811-4f29-a0f4-fb6b20168aac">
        <updating/>
        <source>jhpFindResults() updating;
//	Finds JADE tests contained in the execution plan that have not been executed in the last week.
vars
	ff:FileFolder; fn,fn2,fn3,fn4,fn5:FileNode; f:File;
	thisConf,s,t:String;
	i,j,prevStep:Integer;
	sa:StringArray;
	d:Date;
begin
	create sa transient;
	create ff transient;
	ff.usePresentationFileSystem:=false;
	ff.fileName:="t:\results";
	foreach i in 0 to 6 do
		ff.mask:=(d-i).Date.format("yyyyMMdd")&amp;"*";
		foreach fn in ff.files where fn.isKindOf(FileFolder) do
			foreach fn2 in fn.FileFolder.files do
				foreach fn3 in fn2.FileFolder.files do
					foreach fn4 in fn3.FileFolder.files do
						write fn4.fileName;
						foreach fn5 in fn4.FileFolder.files do
							//write fn5.name;
							if not sa.includes(fn5.name.toLower) then
								sa.add(fn5.name.toLower);
							endif;
						endforeach;
					endforeach;
				endforeach;
			endforeach;
		endforeach;
	endforeach;
	write sa.size.String &amp; " unique tests";

	create f transient;
	f.usePresentationFileSystem:=true;
	f.fileName:="T:\plant\TestingTools\suiteconfig\allcurrent.conf";
	while not f.endOfFile do
		s:=f.readLine.toLower;
		i:=s.pos("functionaltests\jade", 1) + 21;
		if i &gt; 21 then
			thisConf:=s.scanUntil(".", i);
			if not sa.includes(thisConf) then
				write "test not run: " &amp; thisConf;
			endif;
		endif;
	endwhile;
epilog
	delete f;
	delete ff;
	delete sa;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jhpJommonV2ExpandUserinfo" id="175f90db-bd1c-4d83-a2ed-46310152607b">
        <source>jhpJommonV2ExpandUserinfo();
//	replace JtdDriverExternalCloneApp/189 with Venrf/189/153/10/189 in TUI exception retry logs
//	requires a list of users - cut down from jommon.log, a section containing the users sheet you want to use (takes the last one, ignores other sections)
//	search for first occurrance of "userInfo=CNWCHCS" - that is when userInfo starts to be replaced by machine name for TUI
//	requires a LockRetries or DeadlockRetries file - basically a grep of *cn_log*.log for 'Locked by' or 'currently held by', delete top two lines
vars
	s,t,folderName,textFileName,usersFileName,include,exclude,userDesc,user:String;
	i,j,k,l,hits,hitsmax,userNum:Integer;
	presentationFileSystem,firstOnly,showFileName:Boolean;
	ts:TimeStamp; userNums:IntegerArray; users,userDescs:StringArray256;
	f,g,u:File; fn:FileNode; ff:FileFolder;
begin
	folderName:="G:\BenchMarkResults\tui\20100706_s54\R38a";
	folderName:="G:\BenchMarkResults\tui\20100709_s54\R38ULa";
	usersFileName:="R38ULa_jommon_users.log";
	textFileName:="R38ULa_LockRetries.txt";
	textFileName:="R38ULa_DeadlockRetries.txt";
	
	create userNums transient;
	create userDescs transient;
	create users transient;
	create f;
	f.mode:=File.Mode_Input;
	f.maxRecordSize:=32000;
	create u;
	u.mode:=File.Mode_Input;
	u.maxRecordSize:=32000;
	create g;
	g.mode:=File.Mode_Output;
	f.kind:=File.Kind_Unknown_Text;
	f.fileName:=folderName&amp;"\"&amp;textFileName;
	u.fileName:=folderName&amp;"\"&amp;usersFileName;
	f.usePresentationFileSystem:=true;
	u.usePresentationFileSystem:=true;
	g.fileName:=f.fileName.replace(".txt", "2.txt");
	g.usePresentationFileSystem:=true;
	while not u.endOfFile do
		s:=u.readLine&amp;" ";
		if s.contains("key=10;level=3;") then  // update user arrays
			t:="process=Process/187.";
			i:=s.pos(t, 1);
			if i &gt; 0 then
				j:=i+t.length;
				userNum:=s.scanUntil(";", j).Integer;
				//write userNum.String&amp;" "&amp;s[j:10];
				k:=userNums.indexOf(userNum);
				if k = 0 then
					userNums.add(userNum);
					users.add("");
					userDescs.add("");
					k:=userDescs.size;
					//write userNum.String&amp;" "&amp;userDesc;
				endif;
				t:="user=";
				i:=s.pos(t, 1);
				if i &gt; 0 then
					j:=i+t.length;
					users[k]:=s.scanUntil(";", j);
				endif;
				t:="userInfo=";
				i:=s.pos(t, 1);
				if i &gt; 0 then
					j:=i+t.length;
					//t:=s.scanUntil(";@", j)&amp;"/"&amp;userNum.String;  // if you want appSequenceId etc
					t:=s.scanUntil("/;@", j);
					if t[1:3].toLower &lt;&gt; "cnw" then  // don't overwite if it's just computer name
						userDescs[k]:=t[1:256];
					endif;
				endif;
			endif;
		endif;
	endwhile;
	
	while not f.endOfFile do
		s:=f.readLine&amp;" ";
		// replace user info
		t:="JtdDriverExternalCloneApp/";
		i:=s.pos(t, 1);
		if i &gt; 0 then
			j:=i+t.length;
			userNum:=s.scanUntil(": ", j).Integer;
			k:=userNums.indexOf(userNum);
			if k &gt; 0 then
				s:=s.replace(t&amp;userNum.String, userDescs[k]);
			endif;
		endif;
		// replace currently held by info (deadlocks)
		t:="app=JtdDriverExternalCloneApp";
		i:=s.pos(t, 1);
		if i &gt; 0 then
			t:="Process/187.";
			i:=s.pos(t, 1);
			if i &gt; 0 then
				j:=i+t.length;
				userNum:=s.scanUntil(" ", j).Integer;
				k:=userNums.indexOf(userNum);
				if k &gt; 0 then
					s:=s.replace("app=JtdDriverExternalCloneApp", "app="&amp;userDescs[k]);
				endif;
			endif;
		endif;
		// replace Locked by info (locks)
		t:="Locked by ";
		i:=s.pos(t, 1);
		if i &gt; 0 then
			j:=i+t.length;
			user:=s.scanUntil(" @", j);
			k:=users.indexOf(user);
			if k &gt; 0 then
				s:=s.replace(user, userDescs[k]);
			endif;
		endif;
		g.writeLine(s);
	endwhile;
	foreach i in 1 to userDescs.size do 
		write userNums[i].String&amp;" "&amp;users[i]&amp;" "&amp;userDescs[i];
	endforeach;/**/
	f.close;
	g.close;
	u.close;
epilog
	delete f;
	delete g;
	delete u;
	delete ff;
	delete userNums;
	delete users;
	delete userDescs;
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpJommonV2ToCsvDbFileAllReads" id="9d579fab-aee8-4f02-861e-42dbe38ee951">
        <source>jhpJommonV2ToCsvDbFileAllReads();
//	creates a csv file with selected DbFile stats counters
//	To use, run with setnum=1 for reads and a run for writes. Sort left to right in excel (by column sum) then chart the top ten.
//	If too many files, use setnum=5 and put the inclusion list in jhpJommonV2ToCsvGetFilenames.
vars
	s,t,u,v,readwrite,filename:String;
	filenames:StringArray;
	i,j,k,numfields,setnum:Integer;
	l,m:Integer64;
	ia:Integer64Array;
	presentationFileSystem,firstTime:Boolean;
	ts,prevts,tsStart,tsEnd:TimeStamp;
	f,g:File;
begin
	create ia transient;
	create filenames transient;
	jhpJommonV2ToCsvGetFilenames(filenames);
	firstTime:=true;
	create f;
	create g;
	f.fileName:="C:\a\ski\20081124_pfm\20090116\jommon_20090116_13836.log";
	f.fileName:="C:\a\ski\pfm_20081124\20090123\jommon\jommon_20090122.log";
	f.fileName:="G:\BenchMarkResults\uoc\20090619_uoc3\results_update\jommon_20090619_ServerTaskUser.log";
	f.fileName:="C:\a\jsms\Enrol test 2009 11\logs\20091119 combined run 60 mins\s3\jommon_20091119_cnwjre1.log";
	f.fileName:="G:\BenchMarkResults\uoc\20091124_uocs3\s3b\jommon_20091124b_cnwjre1.log";
	f.fileName:="C:\a\jmt\scalability 2009\work\11\6217_11a_jommon_20091221_cnwjhp1.log";
	f.fileName:="C:\a\jmt\scalability 2009\work\63\6305_11a_jommon_20100111_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\tui\20100414_s54\6217a\6217a_jommon_20100308_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\tui\20100414_s54\6305CSFa\6305CSFa_jommon_20100414_cnwjhp1.log";
	f.fileName:="G:\BenchMarkResults\mtl\20100409_s55\64Sa\64Sa_jommon_20100409_cnwjhp1.log";
	f.fileName:="\\cnwchcm24\cnwjbl$\BenchMarkResults\ElectricityAuthority\20130201a_9_normal_ftp3\jommon_20130201_cnwjbl1.log";
	f.fileName:="\\cnwchcm24\cnwjbl$\BenchMarkResults\ElectricityAuthority\20130129a_9_normal_ftp1\jommon_20130129_cnwjbl1.log";
	readwrite:="Writes";
	readwrite:="Reads";
	setnum:=1;
	//setnum:=5;
	
	g.fileName:=f.fileName.replace(".log", "_DbFileAll"&amp;readwrite&amp;setnum.String&amp;".csv");
	g.mode:=File.Mode_Output;

	// find starting timestamp, build header line
	while not f.endOfFile do
		s:=f.readLine&amp;";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;";
		if s.contains("key=39;level=1;") then
			i:=1;
			ts:=s.scanUntil(" ", i).TimeStamp;
			k:=0;
			if firstTime then  // build header line
				t:="Date,Time,";
			else
				t:=ts.logFormat.replace(" ", ",")[1:19]&amp;",";  // build detail line
			endif;
			while not f.endOfFile do
				s:=f.readLine&amp;";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;";
				if not s.contains("key=39;level=2;") then break; endif;
				//if not s.contains("fileName=_userscm;") then continue; endif;  // need to maintain counts per dbfile (ia[k])
				i:=1;
				foreach j in 1 to 5 do  // skip to desired stats field
					s.scanUntil(";", i); i:=i+1;
				endforeach;
				
				u:=s.scanUntil(";", i); i:=i+1;
				if readwrite = "Writes" then
					u:=s.scanUntil(";", i); i:=i+1;
				else
					s.scanUntil("=", i); i:=i+1;
				endif;
				s.scanUntil("=", i); i:=i+1;
				filename:=s.scanUntil(";", i);
				if  setnum = 1 and false
				or setnum = 2 and filename[1] &lt;&gt; "_" 
				or setnum = 3 and filename[1:5] &lt;&gt; "Lobj_" and filename[1:7] &lt;&gt; "Global_"
				or setnum = 4 and (filename[1] = "_" or filename[2] = "_" or filename[1:5] = "Lobj_" or filename[1:7] = "Global_")
				or setnum = 5 and not filenames.includes(filename)
				then continue; endif;

				k:=k+1;
				j:=1;
				if firstTime then  // build header line
					u.scanUntil("=", j); j:=j+1;
					ia[k]:=u[j:end].Integer64;
					t:=t&amp;filename&amp;",";
				else  // build detail line
					u.scanUntil("=", j); j:=j+1;
					l:=u[j:end].Integer64;
					t:=t&amp;((l - ia[k])/((ts - prevts).getMilliseconds/1000)).rounded64.String&amp;",";
					ia[k]:=l;
				endif;
			endwhile;
			if firstTime then  // build header line
				t:=t[1:t.length-1];
				firstTime:=false;
			endif;
			//write ia.display;
			g.writeLine(t);
			//write ((ts - prevts).getMilliseconds/1000).rounded;
			prevts:=ts;
			//break;
		endif;
	endwhile;
epilog
	delete f;
	delete g;
	delete ia;
	delete filenames;
end;</source>
    </JadeMethod>
