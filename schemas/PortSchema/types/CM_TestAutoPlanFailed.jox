<Class name="CM_TestAutoPlanFailed" id="f99e807f-4e67-473a-a8d2-71243138f5fa">
    <superclass name="CM_TestAutoPlanResult"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="TestAPTrans"/>
    <JadeMethod name="getDisplayStringForAttribute" id="968d5cd2-8273-4149-b78d-5ae97137bd94">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	invalidObject : Boolean;
	str : String;

begin

	if _attrName = ETRow_Reason then
	
		if self.myPrimeYardAllocation = null then
			return app.getErrorString(No_Allocation);
		endif;
		
		on Exception do app.handleDeletedObject(exception, self.myPrimeYardAllocation, invalidObject);		
		str := self.myPrimeYardAllocation.code;
		if invalidObject then
			return app.getErrorString(No_Space_Deleted);
		else
			//29 May 2014	NDL	Par 34246
			if self.myTrackedItem &lt;&gt; null
			and  self.myTrackedItem.myPrimaryActualLocation &lt;&gt; null
			and  self.myTrackedItem.myPrimaryActualLocation.isKindOf( CM_YardController )
			then
				if self.myPrimeYardAllocation.allYardControllers.includes( self.myTrackedItem.myPrimaryActualLocation.CM_YardController ) then
					return app.getErrorString1(AlreadyIn, "(" &amp; str &amp; ")" );
				endif;
			endif;
			return app.getErrorString1(No_Space, str);
		endif;
			
	else
		return inheritMethod(_attrName, _short);
		
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
