    <JadeMethod name="setForCreateFromTIs" id="a02fe653-80e0-43df-a803-3eb88ac4214f">
        <updating/>
        <source>setForCreateFromTIs(_tiDict: CM_TIByIdDict; _ediConfig : CM_EDIConfig input; _realEdiFile : CM_EDIFile input; _userCode: String) updating; // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	16 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ti : CM_TrackedItem;
begin
	
	self.setForCreateNoProxy(_ediConfig, null, null, _realEdiFile, _userCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010

	foreach ti in _tiDict do
		self.processTIs(ti, null);
	endforeach;


end;</source>
        <Parameter name="_tiDict" type="CM_TIByIdDict"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateNoProxy" id="b6f65b66-f013-45a6-aa3a-7828153e5b39">
        <updating/>
        <source>setForCreateNoProxy(_ediConfig : CM_EDIConfig input; _type, _ediFileCode: Integer; _realEdiFile : CM_EDIFile input; _userCode: String) updating; // cnwrs1 Par 24207 ccms 1117 11 May 2010

// cnwdvb1 29 January 2003 
/*
Date		Who		Reason
01/12/2011  cnwrs1  CCMS POL 2122 / PAR 28696 - add support for EDI Release Request processing
*/
vars

begin

	self.number	:= _ediConfig.nextSeqNumber();
	self.ediConfig := _ediConfig;
	if _realEdiFile &lt;&gt; null then
		if _realEdiFile.ediData = null then
			_realEdiFile.ediData := self;
		else
			_realEdiFile.allEDIData.add(self);	//ccms 2122 cnwrs1 01 dec 2011
		endif;
	endif;
	self.ediFileCode := _ediFileCode;	
	self.userCode := _userCode[1:10];
	if _type &lt;&gt; null then
		self.ediDataType := _type;
	else
		self.ediDataType := self.getEDIDataType();
	endif;
	self.processDate := self.createdTime.Date; //ccms1906
end;</source>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_ediFileCode" type="Integer"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
