    <JadeMethod name="setLevel" id="71245b08-62be-4386-a434-644c57c71392">
        <updating/>
        <source>setLevel(_level : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	childEntity		: CM_MenuEntity;
begin
	self.level := _level;
	foreach childEntity in self.allChildren do
		if childEntity.isKindOf(CM_MenuUserItem) then
			childEntity.CM_MenuUserItem.setLevel(_level +1);
		endif;
	endforeach;
end;</source>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
