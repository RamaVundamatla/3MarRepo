    <JadeMethod name="getOccursDT" id="d19d2aa9-b875-4068-b2e0-2f1e5d4df1ef">
        <source>getOccursDT() : TimeStamp;
/*

Purpose:			// TFS 40747 

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlgab1	Initial creation

*/

vars
	voyage : CM_Voyage;
begin
//TFS 41084	if self.startByDT.isValid then
//		return self.startByDT;
//	endif;
	
	if self.requiredByDT.isValid then // TFS 41084
		return self.requiredByDT; // TFS 41084
	endif;
		
	voyage := self.getMyVoyageObject();
	if voyage &lt;&gt; null then
		return voyage.arrivedDT;
	endif;
	
	return self.createdTime;
epilog

end;</source>
