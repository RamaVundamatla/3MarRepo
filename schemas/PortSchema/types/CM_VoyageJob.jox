    <JadeMethod name="archive" id="ad60cf9d-e8b3-4b41-a4f2-284bc14f0700">
        <updating/>
        <source>archive() updating;

//AJA 27/6/00: Rewritten from C++. Made more robust. Note that the job will be archived
//regardless of status and all WLEs are forced to be complete

//DQ 20 Feb 03. Rebuilt so it works with new Voyage structure.

vars
	request : CM_Request;
begin

    //De boat has gone baby. Da job is done
	self.changeStatus(JOB_COMPLETE);

	//WLE - TI links are taken care of in the erase method of the wle....

	foreach request in self.allRequests do
		request.archive();
		//Nb requests are deleted when the colour codes are removed
	endforeach;
	self.setRemarks(null); // pass in null will get auto remarks

end;</source>
    </JadeMethod>
    <JadeMethod name="autoLinkSlotsSOB" id="1362c887-5f61-489e-9b16-e2333dc1250f">
        <source>autoLinkSlotsSOB( 	_theJobParams :CMIF_VoyageJobParams input;
					_passport : CM_Passport input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03/08/2011	cnwer1	Initial creation CCMS MES 1033
02/10/2017	jlgdap1	TFS 7081 SNO Ensure move controller knows it's a rehandle
*/

vars
	theTerminal : CM_Terminal;
	moveControl : CMIF_MoveController;
	aSlotReq	: CM_SlotRequest;
	aLinkedSlotReq : CM_Request;
	theTI : CM_TrackedItem;
	tmpWLE, lWLE, dWLE : CM_WorkListEntry;
	theSource, theTarget : CM_LocationsController;
begin
	if _theJobParams.allSlotRequests.isEmpty then
		return;
	endif;

	theTerminal := _passport.myTerminal;
	// if this baby is linked to another request, cos of  SOB, then do the planning
	if not theTerminal.getConfig(AutoLinkSlotPlanSOB).Boolean then
		return;
	endif;
	
	create moveControl transient;
	moveControl.setMoveMode(PLANNING_MODE);
	
	foreach aSlotReq in _theJobParams.allSlotRequests do
		theTI := aSlotReq.getTrackedItem();
		if theTI = null then
			continue;
		endif;
		aLinkedSlotReq := aSlotReq.getLinkedRequest(aSlotReq.isReleaseType); // PAR 28968 getDLRSOBRequestLink();
		if aLinkedSlotReq &lt;&gt; null then
			aSlotReq.setSequenced(true);
			aLinkedSlotReq.setSequenced(true);
			tmpWLE := aLinkedSlotReq.allWorkListEntries.first;
			if tmpWLE &lt;&gt; null then
				tmpWLE.setMyTrackedItem(theTI);
			endif;
			if aSlotReq.getAttrIsDischarge() then
				theSource := aSlotReq.mySlotController;
				theTarget := aLinkedSlotReq.getLC(); // PAR 28968 mySlotController;
			else
				theSource := aLinkedSlotReq.getLC(); // PAR 28968 mySlotController;
				theTarget := aSlotReq.getLC(); // PAR 28968 mySlotController;
			endif;

			moveControl.setMyTrackedItem(theTI);

			// PAR 13904 change this to be the load WLE, makes the OOW 'non planned' totals correct
			if aSlotReq.isDischarge then
				if aLinkedSlotReq.isKindOf(CM_SlotRequest) then
					moveControl.mySlotRequest := aLinkedSlotReq.CM_SlotRequest;
				else
					moveControl.myVoyageRequest := aLinkedSlotReq.CM_VoyageRequest; // PAR 28968 
				endif;
				
				if not aSlotReq.allWorkListEntries.isEmpty then 
					dWLE := aSlotReq.allWorkListEntries.first;// PAR 13937
				endif;
				if not aLinkedSlotReq.allWorkListEntries.isEmpty then 
					lWLE := aLinkedSlotReq.allWorkListEntries.first;// PAR 13937
					moveControl.setMyWorkListEntry(lWLE); 
				endif;
			else
				if not aLinkedSlotReq.allWorkListEntries.isEmpty then 
					dWLE := aLinkedSlotReq.allWorkListEntries.first;// PAR 13937
				endif;
				moveControl.mySlotRequest := aSlotReq;
				if not aSlotReq.allWorkListEntries.isEmpty then
					lWLE := aSlotReq.allWorkListEntries.first;// PAR 13937
					moveControl.setMyWorkListEntry(lWLE);
				endif;
			endif;

			moveControl.setMyOriginatingLocation(theSource);
			moveControl.setMyToPrimaryLocation(theTarget); //theTarget
			moveControl.isReplan := theTI.isRehandle;													// TFS 7081
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveControl, _passport);
			dWLE.setLocations(lWLE.locationSource, lWLE.locationTarget); // PAR 13937
		endif;
	endforeach;
	
epilog
	delete moveControl;
end;</source>
        <access>protected</access>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calcCustomSequenceNumberOther" id="a142d793-c0ac-4f8f-bab5-02123c5d7855">
        <source>calcCustomSequenceNumberOther(_isStarboardBerthed : Boolean);
//-----------------------------------------------------
// Created: September 2004 By: cnwgd1 Reason: PAR 8919
//-----------------------------------------------------
vars
	tmpSlotRequest2,
	tmpSlotRequestRev,
	tmpSlotRequest : CM_SlotRequest;
	tmpRequestArray : CM_SlotRequestArray;
	tmpRequestDict : CM_SlotReqByBayDeckTierCell;
	tmpBay : CM_Bay;
	tmpDeck,
	tmpTier,
	idx,
	tmpSeqNumOther : Integer;
	firstTime : Boolean;
begin
	
	if self.allRequests.isEmpty then
		//nothing to do here
		return;
	endif;
	
	sharedLock(self);
	firstTime := true;
	
	// Put into deck/tier/cell order
	create tmpRequestDict transient;
	self.allRequests.copy(tmpRequestDict);

	create tmpRequestArray transient;
	
	foreach tmpSlotRequest  in tmpRequestDict do
		if firstTime then
			tmpBay := tmpSlotRequest.myBay;
			tmpDeck := tmpSlotRequest.ordinalDeck;
			tmpTier := tmpSlotRequest.ordinalTier;		
			firstTime := false;
		endif;

		// Stash all of same deck/tier
		if tmpSlotRequest.myBay = tmpBay
		and tmpSlotRequest.ordinalDeck = tmpDeck
		and tmpSlotRequest.ordinalTier = tmpTier then
			tmpRequestArray.add(tmpSlotRequest);
			continue;
		endif;
		
		// tier change, update all for tier
		idx := tmpRequestArray.size;		
		foreach tmpSlotRequest2 in tmpRequestArray do
			
			// work backwards through array to get corresponding sequence number
			tmpSlotRequestRev := tmpRequestArray[idx];
			idx := idx - 1;
						
			if _isStarboardBerthed then
				//tmpSeqNumOther := tmpSlotRequest2.numSeqStarBoard;
				tmpSeqNumOther := tmpSlotRequest2.numSeqStarboardCustom;
			else
				//tmpSeqNumOther := tmpSlotRequest2.numSeqPort;		
				tmpSeqNumOther := tmpSlotRequest2.numSeqPortCustom;
			endif;
			
			//Update reverse side
			tmpSlotRequestRev.setCustomSeqNumber(tmpSeqNumOther, (not _isStarboardBerthed));
			if _isStarboardBerthed then
				//tmpSeqNumOther := tmpSlotRequestRev.numSeqStarBoard;
				tmpSeqNumOther := tmpSlotRequestRev.numSeqStarboardCustom;
			else
				//tmpSeqNumOther := tmpSlotRequestRev.numSeqPort;		
				tmpSeqNumOther := tmpSlotRequestRev.numSeqPortCustom;
			endif;		
			
			//Update this side 
			tmpSlotRequest2.setCustomSeqNumber(tmpSeqNumOther, (not _isStarboardBerthed));
		endforeach;
		
		// move to next tier
		tmpRequestArray.clear();
		tmpBay := tmpSlotRequest.myBay;		 
		tmpDeck := tmpSlotRequest.ordinalDeck;
		tmpTier := tmpSlotRequest.ordinalTier;
		tmpRequestArray.add(tmpSlotRequest);
		
	endforeach;

	// final tier set, update all for tier
	idx := tmpRequestArray.size;		
	foreach tmpSlotRequest2 in tmpRequestArray do
		
		// work backwards through array to get corresponding sequence number
		tmpSlotRequestRev := tmpRequestArray[idx];
		idx := idx - 1;
					
		if _isStarboardBerthed then
			//tmpSeqNumOther := tmpSlotRequest2.numSeqStarBoard;
			tmpSeqNumOther := tmpSlotRequest2.numSeqStarboardCustom;
		else
			//tmpSeqNumOther := tmpSlotRequest2.numSeqPort;		
			tmpSeqNumOther := tmpSlotRequest2.numSeqPortCustom;		
		endif;
		
		//Update reverse side
		tmpSlotRequestRev.setCustomSeqNumber(tmpSeqNumOther, (not _isStarboardBerthed));
		if _isStarboardBerthed then
			//tmpSeqNumOther := tmpSlotRequestRev.numSeqStarBoard;
				tmpSeqNumOther := tmpSlotRequestRev.numSeqStarboardCustom;
		else
			//tmpSeqNumOther := tmpSlotRequestRev.numSeqPort;		
			tmpSeqNumOther := tmpSlotRequestRev.numSeqPortCustom;
		endif;		
		
		//Update this side 
		tmpSlotRequest2.setCustomSeqNumber(tmpSeqNumOther, (not _isStarboardBerthed));
	endforeach;

		
epilog
	delete tmpRequestDict;
	delete tmpRequestArray;	
end;</source>
        <Parameter name="_isStarboardBerthed" type="Boolean"/>
    </JadeMethod>
