    <JadeMethod name="getDataDisplay" id="c2421308-22d4-46cd-a665-5f950a276cef">
        <source>getDataDisplay(): String;
// ---------------------------------------------------------------------------
// Created:	16 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming
30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
*/

vars
	stopType : CM_Object;	//ChangeRequest 46721
	isInvalid: Boolean;
	returnVal : String;
	
begin
	if self.myEDIFileType &lt;&gt; null then
		if self.myEDIFileType.type = EDIFileTypeX12_350_4010
		or self.myEDIFileType.type = EDIFileTypeCAMIR_CustomsStatus then		//cnwmc5 - 11 July 2014 - CCMS 2353 PEN
			if self.myActionObject &lt;&gt; null then
				on Exception do app.handleDeletedObject(exception, self.myActionObject, isInvalid);		// PAR #27142	//ChangeRequest 46721
				returnVal := self.myActionObject.getEDIActionName();													//ChangeRequest 46721
				return returnVal;
				
			elseif self.actionText &lt;&gt; null then
				return self.actionText;
			elseif self.actionType = "Set Status Code" then 
				return self.actionNumber.asStringJMT();
			endif;
		elseif self.myEDIFileType.type = EDIFileType_CusRes
			or self.myEDIFileType.type = EDIFileType_XMLOneStopCust	//08 Sep 2016	NDL	TFS 2278 / 2670 then
			or self.myEDIFileType.type = EDIFileType_JMTInternal // TFS 39133
		then
			if self.myActionObject &lt;&gt; null then
				on Exception do app.handleDeletedObject(exception, self.myActionObject, isInvalid);	//14 Jul 2016	NDL	TFS 2287
				returnVal := self.myActionObject.getEDIActionName();
				return returnVal;
				//return self.myActionObject.getEDIActionName();
			endif;
		endif;
	endif;
	return "";
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="969d26c2-0c45-420b-8417-70f715c6261b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _attrName = ETRow_FileType then	//26 Sep 2018	NDL	TFS 40940
		return self.myEDIFileType.getCustomActionsName();
	elseif _attrName = ETRow_EDIFileType then
		return self.myEDIFileType.name[1:35];
	elseif _attrName = ETRow_ActionObject then
		return self.myActionObject.getEDIActionName();
	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	elseif _attrName = ETRow_Code then
		return self.keyword;
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_ActionType then
		return self.actionType;
	elseif _attrName = ETRow_ActionData then
		if self.myActionObject &lt;&gt; null then
			return self.getDataDisplay();
		else
			return null;
		endif;
	// ### TFS 58831 (58833) 05July2023 NAVPW1
	elseif _attrName = ETRow_RoleCode then
		return self.roleCode;
	// ### TFS 58831 (58833) 05July2023 NAVPW1
	endif;
	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes end.
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEdiFileType" id="578143e5-95c2-44aa-842c-4510ada31d41">
        <source>getEdiFileType() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
17 October 2023	navpw1	Initial creation TFS: 58986

*/

vars
	ediFileType : CM_EDIFileType;
	
begin
	ediFileType := self.myEDIFileType;
	
	if ediFileType = null then
		return null;
	endif;
	
	return ediFileType.type;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasValidActionType" id="448cab21-fedc-4fe0-be7e-e2e6eb05817b">
        <source>hasValidActionType() : Boolean;
// Created by 	cnwsh3
// Date 		25 September 2009
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 14/09/2009 	cnwsh3 		CCMS SFW1044 PARXXXX - AMS changes
//                          Check if the ediAction has a relevent action based on the edi file type
// 31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
vars

begin
	if self.myEDIFileType.type = EDIFileTypeX12_350_4010 
	or self.myEDIFileType.type = EDIFileTypeCAMIR_CustomsStatus then		//cnwmc5 - 10 July 2014 - CCMS 2353 PEN
		return self.actionType = EDIAction_None or
			self.actionType = EDIAction_Add or
			self.actionType = EDIAction_SetEntries or
			self.actionType = EDIAction_SetReleased or
			self.actionType = EDIAction_SubtractFromEntries or
			self.actionType = EDIAction_SubtractFromRelease or
			self.actionType = EDIAction_PlaceContHold or	//ChangeRequest 46721
			self.actionType = EDIAction_RemoveContHold or	//ChangeRequest 46721
			self.actionType = EDIAction_AddToDoTask or		//ChangeRequest 46721
//			self.actionType = EDIAction_CompleteToDoTask or	//ChangeRequest 46721 NOT USED
			self.actionType = EDIAction_DeleteToDoTask or	//ChangeRequest 46721
			self.actionType = EDIAction_PlaceHold or		
			self.actionType = EDIAction_RemoveHolds;			

	endif;

	return false;
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForBol" id="9aaa2d74-f1c4-4de1-913f-39ee88c85530">
        <source>isForBol():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2017	cnwndl1	Initial creation	TFS 3857
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
*/

vars

	ct : CM_CargoBOLType;
	criteria	: CM_YACriteria;

begin

	if self.myActionObject = null then
		return false;
	endif;
	
	if not self.myActionObject.isKindOf( CM_StopsTable ) then
		return false;
	else
		// START 17 Jul 2022	navsj20	TFS 53862
		//ct := self.myActionObject.CM_StopsTable.allCargoTypesNew.first;	
		if self.myActionObject.CM_StopsTable.myStopCriteria &lt;&gt; null then 
			foreach criteria in self.myActionObject.CM_StopsTable.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do	//27 Jul 2022	navsj20	TFS 53862
				ct := criteria.myYAData.CM_YADataObjects.allObjects.first.CM_CargoBOLType;																		//27 Jul 2022	navsj20	TFS 53862
			endforeach;																																			//27 Jul 2022	navsj20	TFS 53862
		endif;
		// END 17 Jul 2022	navsj20	TFS 53862
		if ct = null then
			return false;
		else
			return ct.isKindOf( CM_BOLType );
		endif;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForContainer" id="3c240507-f63b-4111-8cad-f6880a192b39">
        <source>isForContainer():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2019	jlgns1	Initial creation
6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
*/

vars

	//ct : CM_CargoBOLType;	//17 Jul 2022	navsj20	TFS 53862
	ct : Object;			//17 Jul 2022	navsj20	TFS 53862
	todo : CM_ToDoTaskDesc;
	cargType : CM_CargoType;
	criteria	: CM_YACriteria;
begin

	if self.myActionObject = null then
		return false;
	endif;
	
	if self.myActionObject.isKindOf( CM_StopsTable ) then
		//foreach ct in   self.myActionObject.CM_StopsTable.allCargoTypesNew do		//17 Jul 2022	navsj20	TFS 53862
		if self.myActionObject.CM_StopsTable.myStopCriteria &lt;&gt; null then																						//17 Jul 2022	navsj20	TFS 53862
			foreach criteria in self.myActionObject.CM_StopsTable.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do	//27 Jul 2022	navsj20	TFS 53862
				foreach ct in  criteria.myYAData.CM_YADataObjects.allObjects do 	//27 Jul 2022	navsj20	TFS 53862
					//if  ct.id = TI_CargoType_Container then						//17 Jul 2022	navsj20	TFS 53862
					if  ct.CM_CargoBOLType.id = TI_CargoType_Container then			//17 Jul 2022	navsj20	TFS 53862
						return true;
					endif;	
				endforeach;
			endforeach;	//27 Jul 2022	navsj20	TFS 53862
		endif;			//17 Jul 2022	navsj20	TFS 53862
		return false;
		
	elseif self.myActionObject.isKindOf( CM_ToDoTaskDesc ) then
		foreach cargType in  self.myActionObject.CM_ToDoTaskDesc.allCargoTypes do
			if cargType.id = TI_CargoType_Container then
				return true;
			endif;
		endforeach;
		
		return false;
	else
		return false;
	endif;		
	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="318aab76-8a3b-4eea-a9e7-8ba01149fe57">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxy	: CM_EDIAction;
	completedOK		: Boolean;
begin
	
	pxy := inheritMethod();
	pxy.myActionObject	:= self.myActionObject;
	pxy.myEDIFileType	:= self.myEDIFileType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
