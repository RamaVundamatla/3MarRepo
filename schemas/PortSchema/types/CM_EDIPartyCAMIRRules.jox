<Class name="CM_EDIPartyCAMIRRules" id="b79ce12a-9685-4c6d-8dd4-3231196c1cb8">
    <superclass name="CM_EDIPartyRules"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="isImport" id="a10206ab-8476-494a-a0d6-c423043d80f1">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="990fcabe-6ddf-4f3f-b0a9-e00ba93c9ba4">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars
	type : CM_EDIFileType;
begin
	// set file type
	type := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileTypeCAMIR_CustomsStatus, null);
	
	if type = null or type.type &lt;&gt; EDIFileTypeCAMIR_CustomsStatus then
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'Camir file type missing');
	endif;
	
	self.myEDIFileType := type;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b0fe9865-bd99-49e0-9792-4143064716a3">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars
	proxy : CM_EDIPartyCAMIRRules;
begin
	proxy := inheritMethod();
	proxy.isImport := self.isImport;
	return proxy;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0036d2d6-a3ee-4ebb-9eba-dd57f798fe78">
        <updating/>
        <source>setForUpdate(_proxy: CM_EDIPartyCAMIRRules) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars

begin
	inheritMethod(_proxy);
	self.isImport := _proxy.isImport;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIPartyCAMIRRules"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="54b9d4c8-3fe0-4986-8731-896d8353f74f">
        <updating/>
        <source>setProxy(_isImport : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars

begin
	self.isImport := _isImport;
epilog

end;</source>
        <Parameter name="_isImport" type="Boolean"/>
    </JadeMethod>
</Class>
