    <JadeMethod name="setIndexForEDIBayPlan" id="8e4c6615-308f-4c87-befc-aae3bf7aa36e">
        <updating/>
        <source>setIndexForEDIBayPlan( _value: Integer) updating;
/*
------------------------------------------------------------------------
Created:			31 January 2003 by cnwdwq1
Purpose:			This property is set when you do an EDI move to a ship. We use it to:
							1: Determine the correct futureMove type for the create of the move.
							2: Create "null" futureMoves that hang off a slotController (i.e. there is no ti in this slot
									controller for this edi bayplan").
							You can have any number of EDI containers in a ship bayplan.
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	if self.myToPrimaryLocation = null or (not self.myToPrimaryLocation.isKindOf(CM_VoyageController)) then
		//This property MUST be related to a move to ship.
		app.raiseCMException(Err_NotEDIMoveToShip, 'to location for ' &amp; self.myTrackedItem.id, null);
		return;
	endif;
	self.indexForEDIBayPlan := _value;
end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
