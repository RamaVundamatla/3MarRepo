    <JadeMethod name="autoSelectDeck" id="504b9e39-43b1-4168-adab-19278c1d2abc">
        <source>autoSelectDeck( _bay : CM_BayVoyage );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwndl1	Initial creation

*/

vars

	job : CM_VoyageJob;
	iter : Iterator;
	slotRequest : CM_SlotRequest;
	slotDef : CM_SlotDefnVoyage;
	cellDef : CM_CellDefn;
	onDeck : Boolean;
	
begin

	//default behaviour.
	onDeck := true;
	
	
	if _bay &lt;&gt; null then
	
		//what job are we showing.
		job := self.getJob;
		if job &lt;&gt; null then
			// find the first incomplete task for the selected bay and whether it is on or below deck.
			iter := job.allRequests.createIterator;
			while iter.next( slotRequest ) do
				if slotRequest.myBay &lt;&gt; _bay then
					continue;
				endif;
				if slotRequest.isComplete then
					continue;
				endif;
				slotDef := slotRequest.mySlotDefinition;
				if slotDef = null then
					continue;
				endif;
				cellDef := slotDef.myCellDefinition;
				if cellDef = null then
					continue;
				endif;
				// found one.
				onDeck := cellDef.onDeck;
				break;
			endwhile;
		endif;
	
	endif;
	
	if onDeck then
		optUnderDeck.value := false;
		optOnDeck.value := true;
	else
		optUnderDeck.value := true;
		optOnDeck.value := false;
	endif;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_bay" type="CM_BayVoyage"/>
    </JadeMethod>
