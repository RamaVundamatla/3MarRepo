    <JadeMethod name="isReleaseByType" id="7d97fe4e-38e9-4601-a1f4-e10446393569">
        <source>isReleaseByType(): Boolean;
//--------------------------------------------------------------
//Created: 17 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	mainTbl,
	extraTbl	: CM_EntryTable;
	cmb			: GTE_ComboBox;
	code		: String;
	tmpRow		: Integer;
	
begin

	code := self.myMenuAction.code;
	if code &lt;&gt; NavObj_GTE_Out then
		return false;
	endif;
	
	mainTbl := self.myTblMain;	
	tmpRow := mainTbl.getRow(ETRow_ReleaseByType);
	if tmpRow &gt; 0 then
		return mainTbl.getValue(tmpRow).Boolean;
	else
		return false;
	endif;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="8e0e0b27-e0be-4272-bd90-d416c4213f09">
        <updating/>
        <source>setCaption(pCaption : String) updating;
// ---------------------------------------------------------------------------
// Created:     14 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.caption := pCaption;
	// Create wasn't called.
	create self.mySearchTypeCompare transient;
	
end;</source>
        <Parameter name="pCaption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setContainerSizeFromISOType" id="651a542c-dc41-43e5-9cbb-7c437abe68cb">
        <source>setContainerSizeFromISOType();
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_ContainerFrame;
	isoType	: CM_ISOType;
	theLength	: Integer;
	
begin

	if self.allContainerFrames.isEmpty then
		return;
	endif;

	isoType := self.getISOType();
	
	if isoType &lt;&gt; null then
		if isoType.is40ftLong then
			theLength := 40;
		elseif isoType.is45ftLong then
			theLength := 45;
		elseif isoType.is20ftLong then
			theLength := 20;
		else
			theLength := 0;
		endif;
	else
		theLength := 0;
	endif;
	
	foreach contFrm in self.allContainerFrames do
		contFrm.setLength(theLength);
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setHeading" id="ddf1ee65-3b4e-4720-94c0-9546ae1c93fd">
        <updating/>
        <source>setHeading(pHeading : String) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm		: GTE_ContainerFrame;
	menuAction	: CMUI_MenuAction;
	
begin

	menuAction := self.myMenuAction;
	if menuAction &lt;&gt; null then
		menuAction.setHeading(pHeading);
		self.caption := menuAction.heading;
		foreach contFrm in self.allContainerFrames do
			contFrm.setId(menuAction.heading);
		endforeach;
	endif;

end;</source>
        <Parameter name="pHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setIsFromPrenote" id="ad4a2f28-7420-4f89-9c8a-4b95c92f52fe">
        <updating/>
        <source>setIsFromPrenote(_preNote: CM_TrackedItem) updating;
//----------------------------------------------------------------
//	Created:	05 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _preNote &lt;&gt; null then
		self.isPopulatedFromPrenote := true;

		// 06/07/2010 cnwar2 #24865
		self.myMenuAction.myObject 	:= _preNote;
		self.tiEdition 				:= _preNote.edition;
	else
		self.isPopulatedFromPrenote := false;
	endif;

end;</source>
        <Parameter name="_preNote" type="CM_TrackedItem"/>
    </JadeMethod>
