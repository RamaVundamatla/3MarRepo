    <JadeMethod name="txtQuantity_gotFocus" id="edcd5e6b-15cf-447f-8fd0-6ab1da531dd6">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtQuantity_gotFocus(textbox: TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
