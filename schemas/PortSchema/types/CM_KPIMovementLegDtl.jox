    <JadeMethod name="displayString" id="68a255e2-3570-445b-83a1-ba654b5876a7">
        <source>displayString() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2012	cnwdw1	Initial creation
*/
vars

begin
	return "Source: " &amp; self.sourceType &amp; " " &amp; self.source &amp; " To: " &amp; self.targetType &amp; " " &amp; self.target &amp; " By: " &amp; self.machineId &amp; 
			" Start: " &amp; self.startTime.asStringForWebInterface &amp; " Finish: " &amp; self.finishTime.asStringForWebInterface &amp; " Duration: " &amp; self.duration.String;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMachineType" id="c3fb7321-114f-4e02-882f-722366041c34">
        <source>getMachineType(_machine : CM_Machine) : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2012	cnwdw1	Initial creation
*/
vars
	machineType: String;
begin
	if _machine.isCrane then
		return "CRANE";
	endif;
	
	machineType := _machine.getMachineTypeGroup.description;
	if machineType.cnContains("Straddle") then
		return "STRADDLE";
	endif;
	if machineType.cnContains("Rubber Tyred Gantry") then
		return "RTG";
	endif;
	if machineType.cnContains("Rail Mounted Gantry") then
		return "RMG";
	endif;
	if machineType.cnContains("Internal Move Vehicle") then
		return "IMV";
	endif;
	
	return "FORKLIFT";

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFinishTime" id="e15eb8ca-961b-4754-940f-1f97ae2d4e8c">
        <updating/>
        <source>setFinishTime(_finishTime: TimeStamp) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2013	cnwdw1	Initial creation
*/
vars

begin
	if _finishTime &lt;&gt; null then
		self.finishTime := _finishTime;
		self.duration :=  self.startTime.getDifferenceInSeconds(self.finishTime).rounded;
	endif;
epilog

end;</source>
        <Parameter name="_finishTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setFromMoveTxns" id="1c2047db-61c6-4222-8ba8-3767c0d7251c">
        <updating/>
        <source>setFromMoveTxns(_moveStart: CMIF_KEAMove; _moveFinish: CMIF_KEAMove) updating;
vars
	machine: CM_Machine;
begin

	if _moveStart &lt;&gt; null and _moveStart.moveTxn &lt;&gt; null then
		self.sourceType := _moveStart.sourceType;
		self.source := _moveStart.moveTxn.getKEASourceLocation(self.sourceType);
		self.startTime := _moveStart.moveTxn.dateTime;
		self.machineId := _moveStart.moveTxn.machineId;
		if self.machineId &lt;&gt; "" then
			machine := _moveStart.moveTxn.myTerminal.machines[self.machineId];
			self.machineType := self.getMachineType(machine);
		endif;
	endif;
	
	if _moveFinish &lt;&gt; null and _moveFinish.moveTxn &lt;&gt; null then
		self.targetType := _moveFinish.targetType;
		self.target := _moveFinish.moveTxn.getKEATargetLocation(self.targetType);
		self.finishTime := _moveFinish.moveTxn.dateTime;
	endif;
	
	if self.startTime.isValid and self.finishTime.isValid then
		self.duration :=  self.startTime.getDifferenceInSeconds(self.finishTime).rounded;
	else
		self.duration := 0;
	endif;
	
epilog

end;</source>
        <Parameter name="_moveStart" type="CMIF_KEAMove"/>
        <Parameter name="_moveFinish" type="CMIF_KEAMove"/>
    </JadeMethod>
    <JadeMethod name="setFromVehicleVisit" id="c66c55d0-5bb3-44a8-a409-054eb60c5533">
        <updating/>
        <source>setFromVehicleVisit(_mode: String; _visit: CM_VehicleVisitRecord) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2012	cnwdw1	Initial creation
*/
vars
begin
	if _mode = "RECEIPT" then
		self.source := _visit.getVisitId &amp; " " &amp; _visit.vehicle.code;
		self.sourceType := CM_LocationsController.Location_Type_ROAD;
		self.target := _visit.getYardIC &amp; " " &amp; _visit.vehicle.code;
		self.targetType := CM_LocationsController.Location_Type_YARD;
		self.startTime := _visit.timeIn;
		self.finishTime := _visit.getArrivalAtYardIC;
	else
		self.source := _visit.getYardIC &amp; " " &amp; _visit.vehicle.code;
		self.sourceType := CM_LocationsController.Location_Type_YARD;
		self.target := _visit.getVisitId &amp; " " &amp; _visit.vehicle.code;
		self.targetType := CM_LocationsController.Location_Type_ROAD;
		self.startTime := _visit.getArrivalAtGateOutTime;
		self.finishTime := _visit.timeOut;
	endif;
	if self.startTime.isValid and self.finishTime.isValid then
		self.duration := self.startTime.getDifferenceInSeconds(self.finishTime).rounded;
	endif;
	self.machineId := _visit.vehicle.code;
	self.machineType := "TRUCK";
epilog

end;</source>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_visit" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setNextLeg" id="428bd647-30d1-40dc-b275-1b892b05c04c">
        <updating/>
        <source>setNextLeg(_nextLeg: CM_KPIMovementLegDtl) updating;
// 
vars

begin
	self.target := _nextLeg.source;
	self.targetType := _nextLeg.sourceType;
end;
</source>
        <Parameter name="_nextLeg" type="CM_KPIMovementLegDtl"/>
    </JadeMethod>
