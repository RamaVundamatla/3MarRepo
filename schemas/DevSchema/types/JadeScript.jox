    <JadeMethod name="ma131219" id="3281fc06-8ad6-4281-ae5e-5412cbaa0ef1">
        <source>ma131219();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2019	jlgma1	Initial creation

*/

vars
	payment : CM_CashPayment;
	objArr  : ObjectArray;
begin
	
	create objArr transient;
	foreach payment in CM_CashPayment.instances discreteLock do
	
	if payment.isTaxPayment then
		continue;
	endif;
	
	if not payment.isManual then
		continue;
	endif;
	
	if payment.myInvoiceLine &lt;&gt; null then
		continue;
	endif;
	
	objArr.add(payment);
	endforeach;
	
	write objArr.size.String;
epilog
	delete objArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="ma14720" id="4cf0dd4a-94e0-4123-8e03-220185cb875f">
