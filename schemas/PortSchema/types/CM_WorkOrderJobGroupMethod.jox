    <JadeMethod name="validateDelete" id="0f3b9d02-32e9-4a10-b25d-2fcbc6bdb61f">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars

begin
	if self.allWorkOrders.isNotEmpty then
		app.raiseCMException1(Work_order_group_metho_being_u, self.code, null, null);
	endif;
epilog

end;</source>
