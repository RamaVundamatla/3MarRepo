        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="lstCargoIDvalues_click" id="b1484c44-83ed-4066-b97a-16615d9f1499">
        <controlMethod name="CMUI_ListTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstCargoIDvalues_click(table: Table input) updating;
// -----------------------------------------------------------------------------
// Created:		10 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	obj : CM_TrackedItem;
//	firstSelectedTI : CM_TrackedItem;
	terminal: CM_Terminal;
	multiSelectAllowed: Boolean;
begin
	terminal := self.myTerminal;
	if terminal &lt;&gt; null then
		multiSelectAllowed := terminal.getConfig(UpdateReleasedCargo).Integer &lt;&gt; UpdateDefaultSingle;		// 30/1/18 MAP TFS40701
	endif;
	//21 Dec 2017	NDL	TFS 8254 - Apply in all situations, we only have one fieldf for many of the options we are updating dutring the save
	//and prefill these with details from teh first ti, but want to retain the individual ti's attributtes.....
	obj := self.lstCargoIDvalues.allSelectedObjects.last.CM_TrackedItem;
	if not multiSelectAllowed then
		self.lstCargoIDvalues.clearSelected();
	endif;
	self.lstCargoIDvalues.addSelectedObject(obj);

/*	// may only select one TI when in update mode
	
	obj := self.lstCargoIDvalues.allSelectedObjects.last.CM_TrackedItem;
	if self.updateMode = self.Mode_Update  then
		self.lstCargoIDvalues.clearSelected();
		self.lstCargoIDvalues.addSelectedObject(obj);
	else	
		if self.lstCargoIDvalues.allSelectedObjects.size = 2 then
			firstSelectedTI:= self.lstCargoIDvalues.allSelectedObjects.first.CM_TrackedItem;
			if firstSelectedTI.myCargoType.isBulkMulti or firstSelectedTI.myCargoType.isBreakBulkMulti then
				self.lstCargoIDvalues.clearSelected();
				self.lstCargoIDvalues.addSelectedObject(obj);
			endif;
			if obj.myCargoType.isBulkMulti or obj.myCargoType.isBreakBulkMulti then
				self.lstCargoIDvalues.clearSelected();
				self.lstCargoIDvalues.addSelectedObject(obj);
			endif;
		endif;
	endif; */
	
	
	
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstCargoIDvalues_displayRow" id="f635ea37-db27-4fe2-a162-df823f14bbe7">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstCargoIDvalues_displayRow(_table: Table input; _theSheet: Integer; _obj: Object; _theRow: Integer; _bcontinue: Boolean io):String updating;
// -----------------------------------------------------------------------------
// Created:		07 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	id, str : String;
	invalidObj : Boolean;
	sel : Character;
	remaining : Integer;
begin
	on Exception do app.handleDeletedObject(exception, _obj, invalidObj);

	id := _obj.CM_TrackedItem.id;
	
	if invalidObj then
		return null;
	endif;

	if self.lstCargoIDvalues.allSelectedObjects.includes(_obj) then
		sel := TableCheckBox_Selected;
	else
		sel := TableCheckBox_NotSelected;
	endif;

	str:= sel &amp; Tab &amp;  id;
	//epr par 32330 29/8/13
	if _obj.CM_TrackedItem.myCargoType.isBreakBulkMulti then
		if self.myBulkRelease &lt;&gt; null and   _obj.CM_TrackedItem.hasBulkReleaseWithRemaining(self.myBulkRelease,remaining) then
			
		else
			remaining:=_obj.CM_TrackedItem.totalQuantity;
		endif;
		str:= str &amp; " "  &amp; _obj.CM_TrackedItem.getPrimaryLocationId(REAL_MODE) &amp; "(" &amp; remaining.asStringJMT &amp; ")";
	endif;
	
	return str;

epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_theSheet" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
