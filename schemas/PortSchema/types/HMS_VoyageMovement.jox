    <JadeMethod name="validateMe" id="b336ad4a-8c4f-4143-869e-aeb59e1cf0ed">
        <source>validateMe(_passport : CM_Passport input);
//-----------------------------------------
// Created: March 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpDict : HMS_VoyageMovementByDateDict;
	tmpInfo	: String;
	
begin
	inheritMethod(_passport);
	
	if self.getMyBerth = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Berth', ETRow_MyBerth,  null);
		app.raiseCMException(Input_required_field_berth, ETRow_MyBerth,  null); // cnwdb2	PAR 35364
	endif;
	
	if self.myHarbour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour', ETRow_MyHarbour,  null);
		app.raiseCMException(Input_required_field_harbour, ETRow_MyHarbour,  null); // cnwdb2	PAR 35364
	endif;
	
	if self.isCancelled() then	//19 Nov 2018	NDL	TFS 42043
		return;
	endif;
	
	if self.myHMSVoyageData = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage Data', ETRow_MyHMSVoyageData,  null);
		app.raiseCMException(Input_required_field_voyData, ETRow_MyHMSVoyageData,  null); // cnwdb2	PAR 35364
	endif;
	
	if self.myTidalClass = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Tidal Class', ETRow_MyTidalClass,  null);
		app.raiseCMException(Input_required_field_tidalClas, ETRow_MyTidalClass,  null); // cnwdb2	PAR 35364
	endif;
	
	self.validate_OccursOnDT(_passport);
	
	if self.chargeForMove then
		if self.myShippingAgent = null
		and self.myShippingLine = null
		then
			// cnwrd1 par #18113 13.10.08
			//app.raiseCMException1(REQUIRED_FIELD, 'Customer: Shipping Agent or Shipping Line for movement ' &amp; self.moveType , ETRow_MyShippingAgent,  null); 
			app.raiseCMException1(Input_requi_custo_shipp_agent_,self.moveType , ETRow_MyShippingAgent,  null);		
		endif;
	endif;

	self.validate_DateIsValid(_passport);

	if _passport.hasErrors then
		return;
	endif;
	
	if (not self.isLogicalBerth())
	and self.moveType &lt;&gt; HMSMovementTypeDeparture then
		// Only check ship position for physical berths
		self.validate_WharfLockouts(true, tmpInfo);
		self.validate_WharfOverhang(true, tmpInfo);
		self.validate_Clearances(_passport);
 	endif;

	self.validate_BerthDepths(true, tmpInfo);
	self.validate_TidalWindow(true, tmpInfo);
	self.validate_BowSternMarks(_passport);
	self.validate_BerthOccupancy(true, _passport, tmpInfo);
	
	self.validate_ExemptMaster(true, tmpInfo);
		
epilog
	delete tmpDict;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate_BerthDepths" id="19d7cc1c-6b34-4743-8d3e-400097196645">
        <source>validate_BerthDepths(_raiseWarning : Boolean; _errorInfo:String output):Boolean;

vars

begin
	// This method checks the tidal window for a movement
 	return self.check_DepthsAtToFromBerths(_raiseWarning, _errorInfo);
end;</source>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate_BerthOccupancy" id="4c140aaf-0778-4dab-8664-3531b641c115">
        <source>validate_BerthOccupancy(_raiseWarning : Boolean; _passport : CM_Passport input; _errorInfo:String output):Boolean;
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// 10 Sep 2019	cnwrs1	TFS 46030
//-----------------------------------------
constants
	LOOKBACKDAYS = -200;
	
vars
	tmpNextMove,
	nextMove,
   	movement:			HMS_VoyageMovement;
   	voyageForMoves:		HMS_VoyageData;
   	iter:				Iterator;
   	moveCode,
	berthCode:			String;
	startDT:			TimeStamp;
	tmpBerth,
	checkBerth:			HMS_Berth;
	tmpWharf,
	checkWharf:			HMS_Wharf;
	otherBerthDict,
	tmpBerthDict:		HMS_BerthByCodeDict;
	bowMark,
	sternMark,
	tmpBow,
	tmpStern:			Real;
	
begin
	if self.moveType = HMSMovementTypeDeparture then
		return true;
	endif;
	
	checkBerth := self.getMyBerth();
	
	if checkBerth = null then
		return true;
	endif;

	voyageForMoves := self.myHMSVoyageData;
	
	if voyageForMoves = null then
		return true;
	endif;
		
	nextMove := self.getVoyageMovementNext();
	if nextMove = null then
		return true;
	endif;
	
	moveCode := self.getDisplayString();
	checkWharf := checkBerth.myWharf;
	
	create otherBerthDict transient;
	create tmpBerthDict transient;
	checkWharf.getAllBerthsForMovement(self, tmpBerthDict);
	
 	iter := self.myHarbour.allVoyageMovements.createIterator();

	/*We start checking LOOKBACKDAYS before the arrival date to cover vessels that may be 
	laid up at a berth for a long period (eg seasonal or refits).*/ 	
 	startDT := self.occursOnDTNEW.cnEcAddDays(LOOKBACKDAYS);
 	self.myHarbour.allVoyageMovements.startKeyGeq(startDT, iter);
 	
 	self.berthing_StartEndFromOrient(bowMark, sternMark, self.bowMarkTo, self.sternMarkTo);

	while iter.next(movement) do
		if movement.occursOnDTNEW &gt; self.occursOnDTNEW then
			break;
		endif;	
		
		if movement = self then
			continue;
		endif;
		
		if movement.isLogicalBerth() then
			//Will also return true is berth or wharf is null
			continue;
		endif;		
		
		if movement.myHMSVoyageData = voyageForMoves then
			// Meaning, if this is "my own" voyage, then don't worry about it.
			continue;
		endif;
		
		tmpWharf := movement.getMyBerth().myWharf;
		if tmpWharf &lt;&gt; checkWharf then
			continue;
		endif;
		
		tmpNextMove := movement.getVoyageMovementNext();
		if tmpNextMove = null then
			continue;
		endif;
		
		if movement.occursOnDTNEW &lt;= nextMove.occursOnDTNEW
		and tmpNextMove.occursOnDTNEW &gt;= self.occursOnDTNEW
		then
			// This movement is in existance at the same time, check marks overlap
				movement.berthing_StartEndFromOrient(tmpBow, tmpStern, movement.bowMarkTo, movement.sternMarkTo);
 				
				if tmpStern &lt; bowMark then
					// not overlapping
					continue;
				endif;
				
				if tmpBow &gt; sternMark then
					// not overlapping
					continue;
				endif;		
			
			// movement may span multiple berths so get all associated berths
			tmpWharf.getAllBerthsForMovement(movement, otherBerthDict);
			berthCode := null;
			
			foreach tmpBerth in otherBerthDict do
				if (not tmpBerthDict.includes(tmpBerth)) then
					continue;
				endif;
				
				if berthCode = null then
					berthCode := tmpBerth.code;
				else
					berthCode := berthCode &amp; ',' &amp; tmpBerth.code;
				endif;
			endforeach;
			
			if berthCode &lt;&gt; null and 
			   self.myHarbour.isDoClearanceCheck then
				if movement.myHMSVoyageData.berthPriority &lt; self.myHMSVoyageData.berthPriority then	// 10 Sep 2019	cnwrs1	TFS 46030
					if _raiseWarning then
						app.raiseCMWarning4(HMSShipOnBerthLessOverlap, movement.getDisplayString(), moveCode, berthCode, movement.getTimePeriod(), null, null, self);
					else
						_errorInfo	:=	app.getErrorString4(HMSShipOnBerthLessOverlap2, movement.getDisplayString(), moveCode, berthCode, movement.getTimePeriod());
					endif;
					
					return false;
				else
					if _raiseWarning then
						app.raiseCMWarning4(HMSShipOnBerthMoreOverlap, movement.getDisplayString(), moveCode, berthCode, movement.getTimePeriod(), null, null, self);
					else
						_errorInfo	:=	app.getErrorString4(HMSShipOnBerthMoreOverlap2, movement.getDisplayString(), moveCode, berthCode, movement.getTimePeriod());
					endif;
					
					return false;
				endif;
			endif;
		endif;
	endwhile;
	
	return true;		// cnwdad1 30/03/2008: PAR #16282 - not returning true results in false conflicts being reported.
epilog
	delete otherBerthDict;
	delete tmpBerthDict;
	delete iter;
end;</source>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate_BowSternMarks" id="2d191b62-7268-49f6-a5af-2af7c3df34f2">
        <source>validate_BowSternMarks(_passport : CM_Passport input);
//--------------------------------------------------
// Created:	27 April 2004 By: cnwgd1
//04 Oct 2022 	navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
//29 Nov 2022	navdap1	TFS 55614 MTN Issue with Movement Maintenance and Berthage
//28 Nov 2023	navdap1	TFS 61264 POB - QShips - Bow and Stern Mark Do Not Match Selected Berth
//04 Sep 2024   navhn30 Bug 61636: NSW | Tech Debt - POB QShips Port Authority Config
//--------------------------------------------------
vars
	berthForMark	: HMS_Berth;
	tmpMark			: Integer;
	wharfForMarks	: HMS_Wharf;
	bridgeMark		: Decimal[9,2];
	waterOnLeft		: Boolean;
	bowMarkMax		: Boolean;
	sideToUse		: Integer;		// TFS 55614
begin

  	// This method checks to see if the bow &amp; stern marks that have been 
  	// entered match the berth that is selected.
  	
  	if self.isLogicalBerth() then
  		//Marks are not applicable to logical berths
  		return;
  	endif;
  	
  	if self.getMyBerth() = null then
  		return;
  	endif;

  	wharfForMarks := self.getMyBerth().myWharf;
  	
  	// Check that bow and stern marks are within the valid range for this wharf
	if self.bowMarkTo &gt; self.sternMarkTo then
		tmpMark := (0-wharfForMarks.overhangZeroMetreEnd);
		if self.sternMarkTo &lt; tmpMark then
			// Stern Mark outside valid range for wharf
			app.raiseCMException4(HMSBowSternMarksInvalid, 'Stern', self.sternMarkTo.String, tmpMark.String, self.getMyBerth().code, null, null);		
		endif;
		
		tmpMark := ((wharfForMarks.length)+(wharfForMarks.overhangMaxMetreEnd));
		if self.bowMarkTo &gt; tmpMark then
			// Bow Mark outside valid range for wharf
			app.raiseCMException4(HMSBowSternMarksInvalid, 'Bow', self.bowMarkTo.String, tmpMark.String, self.getMyBerth().code, null, null);
		endif;
	else
		tmpMark := (0-wharfForMarks.overhangZeroMetreEnd);
		if self.bowMarkTo &lt; tmpMark then
			// Bow Mark outside valid range for wharf
			app.raiseCMException4(HMSBowSternMarksInvalid, 'Bow', self.bowMarkTo.String, tmpMark.String, self.getMyBerth().code, null, null);		
		endif;
	
		tmpMark := ((wharfForMarks.length)+(wharfForMarks.overhangMaxMetreEnd));
		if self.sternMarkTo &gt; tmpMark then
			// Stern Mark outside valid range for wharf
			app.raiseCMException4(HMSBowSternMarksInvalid, 'Stern', self.sternMarkTo.String, tmpMark.String, self.getMyBerth().code, null, null);
		endif;
	endif;
	// START 04 Oct 2022	navsj20	TFS 54739
	bridgeMark := getBridgeMark().asDecimalJMT();
	waterOnLeft := wharfForMarks.waterOnLeft;
	// TFS 55614 start
	sideToUse := self.sideTo;
	if sideToUse = null then
		sideToUse := OrientPortSideTo;
	endif;
	// TFS 55614 end
	// water on left, ship is port side to - bow mark is min, stern mark is max
	// water on right, ship is starboard side to - bow mark is min, stern mark is max
	if (waterOnLeft and sideToUse = OrientPortSideTo) or (not waterOnLeft and sideToUse = OrientStarboardSideTo) then
		bowMarkMax := false;
	// water on left, ship is starboard side to - bow mark is max, stern mark is min
	// water on right, ship is port side to - bow mark is max, stern mark is min
	elseif (waterOnLeft and sideToUse = OrientStarboardSideTo) or (not waterOnLeft and sideToUse = OrientPortSideTo) then
		bowMarkMax := true;
	endif;
	if (self.bowMarkTo &lt; bridgeMark or bridgeMark &lt; self.sternMarkTo) and bowMarkMax then
		app.raiseCMException3(PortSideBollardPositionInvalid, self.bowMarkTo.String, bridgeMark.String, self.sternMarkTo.String, null, null);
	endif;
	if (self.bowMarkTo &gt; bridgeMark or bridgeMark &gt; self.sternMarkTo) and not bowMarkMax then
		app.raiseCMException3(StarBoardSideBollardPosInvalid, self.bowMarkTo.String, bridgeMark.String, self.sternMarkTo.String, null, null);
	endif;
	//04 Oct 2022	navsj20	TFS 54739
	
  	// Check that the bow and stern marks supplied match the selected berth	
	// TFS 61264 but not for Port Authorities, where the ship has to go where it's told to go, regardless of whether it's too long
	//self.getMyTerminal.getConfig(ProcIFCSUMPortAuthority).Boolean then
	if not self.myHarbour.ignoreBerthLOAErrors then		//04.09.24	navhn30  TFS 61636
		berthForMark := self.berthing_GetBerthFromMarks(wharfForMarks); 

		if self.getMyBerth() &lt;&gt; berthForMark then
			// bow and stern marks supplied do not match the selected berth
			app.raiseCMException3(HMSBerthMarkMismatch, self.bowMarkTo.String, self.sternMarkTo.String, self.getMyBerth().code, null, null);
		endif;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate_Clearances" id="a793014a-13c1-4ca5-82ba-af3e9ad5683d">
        <source>validate_Clearances(_passport : CM_Passport input) protected;

vars
   	minClearance : Integer;
	
begin
// cnwdad1 26/02/2007.
	if not self.myHarbour.isDoClearanceCheck then
		return;
	endif;
	
	minClearance := self.myHarbour.minimumClearance;
	
	if self.foreClearanceTo &lt; ClearanceUnbounded and self.foreClearanceTo &lt; minClearance then
		// Fore clearance is less than the minimum clearance and is not unbounded
		if self.overlapsWharfSection then
			app.raiseCMWarning5(HMSClearanceWharfOverlap, self.getDisplayString(), 'Fore', self.getMyBerth().description, self.foreClearanceTo.String &amp; "(m)", minClearance.String &amp; "(m)",  null, null, self);					
		else
			app.raiseCMWarning5(HMSClearanceOccupied, self.getDisplayString(), 'Fore', self.getMyBerth().description, self.foreClearanceTo.String &amp; "(m)", minClearance.String &amp; "(m)",  null, null, self);
		endif;

	elseif self.aftClearanceTo &lt; ClearanceUnbounded and self.aftClearanceTo &lt; minClearance then
		// Aft clearance is less than the minimum clearance and is not unbounded
		if self.overlapsWharfSection then
			app.raiseCMWarning5(HMSClearanceWharfOverlap, self.getDisplayString(), 'Aft', self.getMyBerth().description, self.aftClearanceTo.String &amp; "(m)", minClearance.String &amp; "(m)",  null, null, self);						
		else
			app.raiseCMWarning5(HMSClearanceOccupied, self.getDisplayString(), 'Aft', self.getMyBerth().description, self.aftClearanceTo.String &amp; "(m)", minClearance.String &amp; "(m)",  null, null,self);					
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate_DateIsValid" id="1d26a8d3-7b51-4da5-bacb-337dc37ca1ee">
        <source>validate_DateIsValid(_passport : CM_Passport input);
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
vars
	checkDT:		TimeStamp;
   	moveToCheck:	HMS_VoyageMovement;
   	msgBoxType:		Integer;
begin
 	// This method checks that the movement date is valid for a cloned movement/voyage
 	if self.moveType = HMSMovementTypeArrival then
 		// Arrival Movement - must occur before all other movements
 		// Get first movement in voyage.allWorkingMovements collection directly after the arrival movement
 		moveToCheck := self.myHMSVoyageData.allVoyageMovements.getAtKeyGtr(self.occursOnDTNEW).HMS_VoyageMovement;
        if moveToCheck = null 
        or moveToCheck.occursOnDTNEW &lt;= self.occursOnDTNEW then
        	// Error - arrival movement must occur before all other movements
			app.raiseCMException2(HMSMovementDateTime, HMSMovementTypeArrival, 'before', ETRow_OccursOnDate, null);
        endif;
 	elseif self.moveType = HMSMovementTypeShift then
 		// Shift Movement - must occur after arrival and before departure movements
 		checkDT := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeArrival).occursOnDTNEW;
 		if self.occursOnDTNEW &lt;= checkDT then
 			// Error - The shift movement cannot occur before the arrival movement
			app.raiseCMException3(HMSMovementShiftDT, 'after', 'Arrival', checkDT.shortCurrentLocaleFormat(), ETRow_OccursOnDate, null);
 		else
	 		checkDT := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeDeparture).occursOnDTNEW;
 			if occursOnDTNEW &gt;= checkDT then
	 			// Error - The shift movement cannot occur after the departure movement
				app.raiseCMException3(HMSMovementShiftDT, 'before', 'Departure', checkDT.shortCurrentLocaleFormat(), ETRow_OccursOnDate, null);
			endif;
 		endif;
	elseif self.moveType = HMSMovementTypeDeparture then
		// Departure Movement - must occur after all other movements
 		// Get first movement in voyage.allWorkingMovements collection directly before the departure movement
 		moveToCheck := self.getVoyageMovementPrevious();
        if moveToCheck = null then
        	// Error - departure movement must occur after all other movements
			app.raiseCMException2(HMSMovementDateTime, HMSMovementTypeDeparture, 'after', ETRow_OccursOnDate, null);        	        
        elseif moveToCheck.occursOnDTNEW &gt;= self.occursOnDTNEW then
        	// Error - departure movement must occur after all other movements
			app.raiseCMException2(HMSMovementDateTime, HMSMovementTypeDeparture, 'after', ETRow_OccursOnDate, null);        	
        endif;
 	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate_ExemptMaster" id="919e3cee-bf88-4ab5-9172-8b79177d7bae">
        <source>validate_ExemptMaster(_raiseException : Boolean; _errorInfo:String output) : Boolean;
//-----------------------------------------------------------------------
//	Created:	02 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
// 23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement 
//-----------------------------------------------------------------------
vars
	tmpVessel	: CM_Vessel;
	vesselData	: HMS_VesselData;
	voyageData	: HMS_VoyageData;
	vdh : HMS_VesselDataHarbour;
	voyage : CM_Voyage;
	
begin

	if self.pilotExempt or self.getUnConvertedMyPilotRef &lt;&gt; null or not self.allMovementPilotDetails.isEmpty then //allPilots.isEmpty then // TFS 44438
		return true;
	endif;
	
	// We don't have an exemption for this movemnt, nor do we have a pilot...
	
	tmpVessel	:=	self.getMyVessel;
	if tmpVessel = null or self.myHarbour = null then
		// can not do the check.
		return true;
	endif;
	
	vesselData	:=	self.getMyHMSVesselData();
	voyageData	:=	self.myHMSVoyageData;
	if voyageData &lt;&gt; null then
		voyage := voyageData.myVoyage;
	endif;
	
	//30 Apr 2012	NDL	Par 29496
	if self.myHarbour.requiresPilotFor( tmpVessel, voyage, self ) then
		if self.myMaster = null then
			// if we don't know the master and we are NOT pilot exempt we must require a pilot.
			if _raiseException then
				app.raiseCMWarning(Pilot_Required, null, null, self);
			else
				_errorInfo := app.getErrorString(Pilot_Required);
			endif;
			return false;
			
		else
			if not self.myMaster.hasCurrentPECforVessel( self.myHarbour, tmpVessel, self.occursOnDTNEW.Date ) then
				// the master doesn't have an exemption.	
				if _raiseException then
					app.raiseCMWarning(Pilot_Required, null, null, self);
				else
					_errorInfo := app.getErrorString(Pilot_Required);
				endif;
				return false;
				
			endif;
		endif;
	endif;

	return true;
	
end;</source>
        <Parameter name="_raiseException" type="Boolean"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate_MvmntPilotDetails" id="d094844b-3a6b-44de-91f9-5a3e5b33f068">
        <source>validate_MvmntPilotDetails(_passport : CM_Passport input);
/*

Purpose:			If pilots have a launch, for Pelindo it has to be 'theirs' only.
					A pilot can only be on one launch per movement.
					See also CMIF_HMS_WorkingMovement::validateMvmntPilotDetails
Parameters:			

Return Value:		

Date		Who		Reason
15 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	pilotsUsed : HMS_PilotByCodeDict;
	pilotLaunchesUsed : HMS_PilotLaunchByCodeDict;
	mvmntPilotDetails : HMS_MovementPilotDetails;
	valid : Boolean;
	voyage : CM_Voyage;
	voyageGlobal : CM_VoyageGlobal;
begin
	valid := true;
	create pilotsUsed transient;
	create pilotLaunchesUsed transient;
	foreach mvmntPilotDetails in self.allMovementPilotDetails do
		if mvmntPilotDetails.myPilot &lt;&gt; null then
			if not pilotsUsed.includes(mvmntPilotDetails.myPilot) then
				pilotsUsed.add(mvmntPilotDetails.myPilot);
			else // pilots can only be used once per movement
				app.raiseCMException(Pilot_used_once_movemen, null, null);
				return;
			endif;
		else // tried to use a blank pilot
			app.raiseCMException(Input_require_pilot_field, null, null);
			return;
		endif;
		if mvmntPilotDetails.myPilotLaunch &lt;&gt; null then // if launch not used in this movement yet, add it to the 'used' list
			if not pilotLaunchesUsed.includes(mvmntPilotDetails.myPilotLaunch) then
				pilotLaunchesUsed.add(mvmntPilotDetails.myPilotLaunch);
			else
				voyageGlobal := self.myVoyageGlobal;
				if voyageGlobal &lt;&gt; null then
					voyage := voyageGlobal.allVoyages.first;
					if voyage &lt;&gt; null then // if trying to reuse launch and it's a Pelindo terminal, 'Can only have one pilot per pilot launch'
						if voyage.myVoyageProcess.isMTNWOProcess then //epr TFS 51963 11/10/21
							app.raiseCMException(Only_have_pilot_pilot_launch, null, null);
							return;
						endif;
					endif;
				endif;
			endif;
		endif;	
	endforeach;
epilog
	delete pilotsUsed;
	delete pilotLaunchesUsed;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate_OccursOnDT" id="bfb2cabf-09b0-40f6-a267-76280b07a6a3">
        <source>validate_OccursOnDT(_passport: CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2010	cnwmh5	Initial creation #23248

*/

vars

	voyage : CM_Voyage;
	arrMovement : HMS_VoyageMovement;
	depMovement : HMS_VoyageMovement;

begin
	
	inheritMethod(_passport);

	// check to see if movement for specified date / time exists
	self.myHMSVoyageData.checkIfMovementAlreadyExists(self);	// 29/07/2010 cnwmh5 #23248
	
	//18 Jan 2019	NDL	TFS 42972
	if self.moveType = HMSMovementTypeShift then
		voyage := self.getMyVoyage();
		if voyage &lt;&gt; null and self.occursOnDTNEW.isValid then
			arrMovement := voyage.getMovementArrival();
			depMovement:= voyage.getMovementDeparture();
			if ( arrMovement &lt;&gt; null and self.occursOnDTNEW &lt; arrMovement.occursOnDTNEW )
			or ( depMovement &lt;&gt; null and self.occursOnDTNEW &gt; depMovement.occursOnDTNEW )
			then
				app.raiseCMException1(Not_betwe_voyag_arriv_depar_da, self.occursOnDTNEW.asStringJMT, null , null);
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate_ResourcesUsed" id="402f2038-1d35-464a-9fc0-827c736aee05">
        <source>validate_ResourcesUsed(_createOnly : Boolean; _passport : CM_Passport input);
//--------------------------------------------------
// Created:	17 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpResourceUsed : HMS_ResourceUsed;
begin
	
	foreach tmpResourceUsed in self.allResourceUsed 
		where tmpResourceUsed.partOfContract = false do
		if _createOnly then
			tmpResourceUsed.validateForCreate(_passport);		
		else
			tmpResourceUsed.validateForUpdate(_passport);
		endif;
	endforeach;
end;</source>
        <Parameter name="_createOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate_TidalWindow" id="c2192d43-1bef-4dbe-87ae-f79f1e38ca94">
        <source>validate_TidalWindow(_raiseWarning : Boolean; _errorInfo:String output):Boolean;
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
vars

begin
	// This method checks the tidal window for a movement
	return self.check_TidalWindow(_raiseWarning, _errorInfo);
end;</source>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate_VesselUnavailability" id="90c5e2fd-4674-4c3a-9d92-0e9773b8f6cd">
        <source>validate_VesselUnavailability(_raiseWarning : Boolean; _errorInfo:String output):Boolean;
// --------------------------------------------------------------------------------
// Created:		03 March 2008 by cnwdad1
//
// Purpose:		Checks whether the Vessel is unavailable for this movement.
//
// Parameters:	_raiseWarning - True if a warning only should be raised, rather then
//					an exception.
//				_errorInfo - Specific information pertinant to any errors/warnings.
//
// Returns:		True if the Vessel is available, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	vesselObj		: CM_Vessel;
	departTS		: TimeStamp;
	arriveTS		: TimeStamp;
	
begin
	vesselObj	:=	self.getMyVessel();
	departTS	:=	self.departureTimeFromFromRegion;
	arriveTS	:=	self.arrivalTimeAtToRegion;
	
	/*
		Date	Who		Reason
	 8 sep 2008	cnwdz2	Par17319 - It is valid to be able to delete a vessel which has voyages, so the code needs to handle this.
	*/
	if vesselObj &lt;&gt; null and vesselObj.isUnavailable(departTS.date(), arriveTS.date()) then
		_errorInfo	:=	"Movement details: " &amp; self.getDescription();
		
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate_WharfLockouts" id="bb211431-711c-48d0-a5dd-5676aa083987">
        <source>validate_WharfLockouts(_raiseWarning : Boolean; _errorInfo:String output):Boolean;

vars

begin
	// This method checks a permanent movement to see if its position 
 	// while at a non-logical berth is invalid
 	if self.isLogicalBerth() then
 		// Logical wharf - ignore checks
 		return true;
 	else
      	return self.check_WharfLockouts(_raiseWarning, _errorInfo);
 	endif;
end;</source>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
