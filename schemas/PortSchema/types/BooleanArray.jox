<CollClass name="BooleanArray">
    <JadeMethod name="allValuesAre" id="6779728f-a213-4f31-82cb-d46cf44b23fc">
        <source>allValuesAre( _value : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 June 2020	jlgndl1	Initial creation	TFS 49647

*/

vars

	arrayValue : Boolean;

begin

	if self.isEmpty then
		return false;
	endif;

	foreach arrayValue in self do
		if arrayValue &lt;&gt; _value then
			return false;
		endif;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
