    <JadeMethod name="doDelete" id="576cc4e8-8aed-49fe-bada-7a8c757f5da1">
        <updating/>
        <source>doDelete(): Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	faultresponse : CM_FaultResponse;
	rtnValue : Boolean;
	theReturn : Integer;
begin

	if self.myCurrentObject = null then
		return false;
	endif;
/* WAS  // PAR 15966
	faultresponse:= self.myCurrentObject.CM_FaultResponse;

	app.myTrxDA.trxDeleteFaultResponse(faultresponse,app.myPassport);

	rtnValue:=app.myPassport.trxCompletedOK;
	if not rtnValue then
		app.showErrorWarningDialog('Fault Response Delete', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
	endif;
	NOW */
	
		while true do
		app.myTrxDA.trxDeleteFaultResponses(self.tblData.allSelectedObjects,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Fault Responses", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="f5caca4e-608b-442d-a128-805e11840021">
        <updating/>
        <source>doPrint() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	pxyJadeReport	: JadeReport;
	tblPrintParams	: CMIF_PrintTableParams;

begin

	create tblPrintParams transient;
	tblPrintParams.closePrinter := true;
	tblPrintParams.jadeReport := pxyJadeReport;
	tblPrintParams.newReport := true;
	tblPrintParams.printFrame := self.frmReport;
	tblPrintParams.printLabel := self.lblReport;
	tblPrintParams.title := self.caption[1:100];

//	self.tblAlerts.doPrintTableOLD(false,true,self.frmReport, self.lblReport,self.caption, true, pxyJadeReport);
	//self.tblAlerts.doPrintTable(tblPrintParams);
//	self.tblData.doPrintTable2(self.caption, self.caption, self.caption);
	self.doPrintOutTable(self.tblData, self.caption,  true, false, true, false); // PAR 19503

epilog
	delete tblPrintParams;	

end;</source>
    </JadeMethod>
    <JadeMethod name="getCollectionForSearch" id="b975cfc0-e516-4b31-95de-c7fb68e2a8ef">
        <source>getCollectionForSearch() : CM_FaultResponsesByReportedTS;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	// first collection check if machine &lt;&gt; null 
	if self.filterMachine &lt;&gt; null then
		return self.filterMachine.allFaultResponses;
	elseif self.filterFaultQuestion &lt;&gt; null then
		return self.filterFaultQuestion.allFaultResponses;
	else
		return self.myTerminal.allFaultResponses;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_FaultResponsesByReportedTS"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfItemsForLoad" id="53158ed6-22f0-4e6e-8ddd-c2b44f879c7c">
        <source>getNumberOfItemsForLoad(): Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	allFaultResponses 	: CM_FaultResponsesByReportedTS;
begin

	allFaultResponses:=getCollectionForSearch;
	if allFaultResponses &lt;&gt; null then
		return allFaultResponses.size;
	else
		return null;
	endif;


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="3ea779f4-8e0c-44e2-9a4f-2a07e42187f8">
        <updating/>
        <source>includeObject(_faultResponse: CM_FaultResponse; _passport: CM_Passport): Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 September 2007	cnwer1	Initial creation - PAR#xxxx
23 september 2008	concms1	par 17346 - always filter by terminal
*/
vars

begin
	if self.myTerminal &lt;&gt; _faultResponse.myTerminal then	// par 17346
		return false;										// par 17346
	endif;													// par 17346
	
	if self.filterMachine &lt;&gt; null and _faultResponse.myMachine &lt;&gt; self.filterMachine then
		return false;
	endif;
	
	if self.filterMachineType &lt;&gt; null and _faultResponse.myMachine.getMachineType &lt;&gt; self.filterMachineType then
		return false;
	endif;
	
	if self.filterFaultsOnly and _faultResponse.myFault = null then
		return false;
	endif;
		
	if self.filterFaultType &lt;&gt; null then
		if _faultResponse.myFault = null then 
			return false;
		else
			if _faultResponse.myFault.myFaultType &lt;&gt; self.filterFaultType then
				return false;
			endif;
		endif;
	endif;
		
		
	if self.filterUser &lt;&gt; null then 
		if _faultResponse.myReportedByUser &lt;&gt; null then 
			if _faultResponse.myReportedByUser &lt;&gt; self.filterUser then
				return false;
			endif;
		endif;
	
	endif;
		
	
	if self.filterFromTS &lt;&gt; null and _faultResponse.reportedTS &lt; self.filterFromTS then
		return false;
	endif;

	return inheritMethod(_faultResponse, _passport);


epilog

end;</source>
        <Parameter name="_faultResponse" type="CM_FaultResponse"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
