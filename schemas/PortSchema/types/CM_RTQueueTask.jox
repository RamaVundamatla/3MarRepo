Return Value:		

Date		Who		Reason
16 December 2021	jlier1	Initial creation 52595

*/

vars
	moveAmount : String;
begin
	if self.taskType = TASK_BREAKBULK or self.isPickUp then
	
		moveAmount:=  self.myEntry.getAmountLeftToMoveDisplay();
	else
		moveAmount:= self.myEntry.getAmountMovedDisplay(true);
