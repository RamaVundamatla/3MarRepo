    <JadeMethod name="getItemsToDelete" id="ad8aa13b-d4b8-40d3-a182-4200b0ee3c6d">
        <source>getItemsToDelete(_delSet : CM_MenuEntitySet input);
// ---------------------------------------------------------------------------
// Created:     03 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	child	: CM_MenuEntity;

begin

	foreach child in self.allChildren do
		child.getItemsToDelete(_delSet);
	endforeach;

end;</source>
