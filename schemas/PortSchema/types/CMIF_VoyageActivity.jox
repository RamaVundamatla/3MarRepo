    <JadeMethod name="setMyJobAndLocations" id="16b598dc-435a-4906-95f1-50bfe0742d3d">
        <updating/>
        <source>setMyJobAndLocations( _ti : CM_TrackedItem; _job : CM_Job ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2017	jlgndl1	Initial creation	TFS 5226

*/

vars

	iter : Iterator;
	wle : CM_WorkListEntry;
	sourceLocationsArray : StringArray;
	targetLocationsArray : StringArray;
	sourceStr : String;
	targetStr : String;

begin

	self.jobId := null;
	self.myJob := null;
	self.sourceLocations := null;
	self.targetLocations := null;

	if _job &lt;&gt; null then
		
		self.jobId := _job.id;
		self.myJob := _job.CM_VoyageJob;
		
		create sourceLocationsArray transient;
		create targetLocationsArray transient;
		
		if _ti &lt;&gt; null then
		
			iter := self.myJob.workListEntries.createIterator;
			while iter.next( wle ) do
				if wle.myTrackedItem &lt;&gt; _ti then
					continue;
				endif;
				sourceStr := wle.locationSource.trimBlanks;
				targetStr := wle.locationTarget.trimBlanks;
				if sourceStr &lt;&gt; null and not sourceLocationsArray.includes( sourceStr ) then
					sourceLocationsArray.add( sourceStr );
					if self.sourceLocations &lt;&gt; null then
						self.sourceLocations := self.sourceLocations &amp; ", ";
					endif;
					self.sourceLocations := self.sourceLocations &amp; sourceStr;
				endif;
				if targetStr &lt;&gt; null and not targetLocationsArray.includes( targetStr ) then
					targetLocationsArray.add( targetStr );
					if self.targetLocations &lt;&gt; null then
						self.targetLocations := self.targetLocations &amp; ", ";
					endif;
					self.targetLocations := self.targetLocations &amp; targetStr;
				endif;
			endwhile;
		
		endif;
		
	endif;


epilog

	delete iter;
	
	delete sourceLocationsArray;
	delete targetLocationsArray;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
</Class>
