    <JadeMethod name="healthCheckIsValid" id="2dafc03e-e85d-4e0c-aea1-cb7e91446059">
        <source>healthCheckIsValid(_agent : CMIF_InvoiceHealthAgent) : Boolean;
/*
Purpose:			
Date		Who		Reason
13 September 2016	cnwab1	Initial creation
*/
vars
	message : String;
	resultType : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
// TFS 40620 	invLineDescs : CM_InvoiceLineDescMapDict;
	invLineDescs : CM_InvoiceLineDescSet; // TFS 40620 
	invLineDesc : CM_InvoiceLineDesc;
	paths : HugeStringArray;
	items : ObjectArray;
	bu : CM_Bank;
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, invLineDesc, invalid);

	
	bu := self.getBank();
	if bu = null then
		return true;
	endif;
	if not _agent.allBusinessUnits.includes(bu) then
		return true;
	endif;
	
//	term := self.getMyTerminal();
//	if term = null then
//		return true;
//	endif;
//	if not _agent.allTerminals.includes(term) then
//		return true;
//	endif;
	
	// ### CARGO  Calculation Type
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_CalcType) then
		resultType := CMIF_InvoiceHealthAgent.ResultType_CalcTypeCargo;
		invLineDescs := self.getAllMappedInvoiceLineTypes();
		
		foreach invLineDesc in invLineDescs do
			if  invLineDesc.myCalculationType &lt;&gt; null then
				if not invLineDesc.myCalculationType.isCargoCalcType then
					create detail transient;
					detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_CalcType,"Line Type: '" &amp; invLineDesc.narration &amp;  "'", CMIF_InvoiceHealthAgent.ItemType_TranMapCargo, self.getMyTerminal(), resultType, self);
				endif;
			endif;
		endforeach;
		if invalid then
					create detail transient;
					detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_InvoiceLineType,"Line Type is Invalid Object", CMIF_InvoiceHealthAgent.ItemType_TranMapAlloc, self.getMyTerminal(), CMIF_InvoiceHealthAgent.ResultType_Invalid, self);
		endif;
		return false;
	endif;
	return true;
epilog
	delete invLineDescs;
end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="934c38eb-3efb-4f70-a489-d1537edf61de">
        <updating/>
        <source>initialise(_bank : CM_Bank) updating;

vars
	tiMap : CM_TIServiceMap;
begin

	self.bank := _bank;

	tiMap := tiServiceMap[CM_TIServiceMap.DEFAULT_TI_MAP];
	if tiMap = null then
		create tiMap;
		tiMap.className := CM_TIServiceMap.DEFAULT_TI_MAP;
		tiMap.transactionMap := self;
	endif;

	tiMap.initialise(_bank);

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
