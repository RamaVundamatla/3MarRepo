    <JadeMethod name="loadPicture" id="ed0236e8-5b3f-423b-bc09-e61530214e1b">
        <source>loadPicture();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2010	cnwndl1	Initial creation

*/

vars

	file : File;
	picture : Binary;
	
begin

	create file transient;
	file.fileName := "c:\temp\YardMap2.jpg";//"c:\temp\YardMap.jpg";//"c:\temp\IMG_1236.jpg";
	file.kind := File.Kind_Binary;
	file.open;
	
	picture := file.readBinary(file.fileLength);
	
	picMap.picture := picture;
	
	file.close;
	

epilog

	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadPointsOnMap" id="b72480ea-e4fb-463b-a6eb-f8eb8cb587bf">
        <source>loadPointsOnMap();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2010	cnwndl1	Initial creation

*/

vars

	index : Integer;
	point : Point;
	x : Integer;
	y : Integer;
	text : String;
	len : Integer;

begin

	picMap.clearGraphics;

	if mapLocations.size &gt; 0 then
		foreach index in 1 to mapLocations.size do
			point := mapLocations[index];
			x := point.x;
			y := point.y;
			if x &lt;&gt; 0 or y &lt;&gt; 0 then
				text := cmbTA.itemText[index];
				picMap.autoRedraw := true;
				picMap.drawWidth := 3;
				picMap.drawPoint(x,y,Red);
				y := y + 4;
				len := picMap.getTextExtent(text);
				picMap.drawFillColor := White;
				picMap.drawFilledRectangle(x,y,x + len,y + 10,White);
				picMap.drawWidth := 1;
				picMap.drawTextAt(text,x,y - 2,Red);
			endif;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
