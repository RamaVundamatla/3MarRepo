    <JadeMethod name="setTaskHistory" id="262db9c2-46f9-4e7c-b945-136fa3bcd11a">
        <updating/>
        <source>setTaskHistory(_camTaskHistory : CM_CamTaskHistory input; _camProtocol : CM_CamProtocol) updating;

// 17/07/2012	cnwcs5	par 29601 - log excluded transactions
//28 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - from CM_CamTask
//15 Jun 2016	cnwrs1	Par 35544 - Change Cams task hisoty to use JadeBytes  

vars

begin
	_camTaskHistory.set(self.runDateTime, self.startDateTime, self.endDateTime, self.logExcludedTransactions, 
							_camProtocol, self.processSeqNumber, self.dailySeqNumber, _camProtocol.constructFileName(self, null), 
							self.status, null);		
	_camTaskHistory.clearRawData();
//	_camTaskHistory.fileData.clear();	//28 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
end;</source>
