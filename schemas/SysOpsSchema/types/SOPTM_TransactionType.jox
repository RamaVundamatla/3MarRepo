end;</source>
    </JadeMethod>
    <JadeMethod name="setupComboTranTypeClass" id="54fd2c80-ed17-40ab-bd6c-694c18487aeb">
        <source>setupComboTranTypeClass(_group : String; _class : String);
/*
Purpose - 	
Who - NAVAB1
Date - 27SEP2023
ADO - CR 60699 TASK 60700 
*/

vars
	combo : CMUI_ComboBox;
	strs : StringArray;
	str : String;
	tranType : CM_TransactionType;
begin
	combo := self.myForm.cmbTranTypeClass;
	combo.clear;
	combo.text := "";
	combo.parent.CM_EntryTable.setValueByControlName(combo.name, "");
	combo.sorted := true;

	if _group = app.getErrorString(Cargo_GC).trimBlanks then
		create strs transient;
		ValidTransactionTypes.getTokensForDelimiter(Tab,strs);
		
		foreach str in strs do
			combo.addItem(str);
		endforeach;
		
	elseif _group = app.getErrorString(WorkOrder).trimBlanks then
		tranType := app.myRoot.allTransactionTypes[TRANS_TYPE_WO_TITODO_COMPLET];
		combo.addItemObject(tranType.classNameToCreate, tranType);
		// ### JIRA 14793 24OCT2024 NAVAB1
		tranType := app.myRoot.allTransactionTypes[TRANS_TYPE_WO_TODO_VOY_COMPLET];
		combo.addItemObject(tranType.classNameToCreate, tranType);
		tranType := app.myRoot.allTransactionTypes[TRANS_TYPE_WO_TODO_WGN_COMPLET];
		combo.addItemObject(tranType.classNameToCreate, tranType);
		tranType := app.myRoot.allTransactionTypes[TRANS_TYPE_WO_TODO_TRN_COMPLET];
		combo.addItemObject(tranType.classNameToCreate, tranType);
		tranType := app.myRoot.allTransactionTypes[TRANS_TYPE_WO_TODO_TRK_COMPLET];
		combo.addItemObject(tranType.classNameToCreate, tranType);
		tranType := app.myRoot.allTransactionTypes[TRANS_TYPE_WO_TODO_NOP_COMPLET];
		combo.addItemObject(tranType.classNameToCreate, tranType);
		tranType := app.myRoot.allTransactionTypes[TRANS_TYPE_WO_TODO_VBS_COMPLET];
		combo.addItemObject(tranType.classNameToCreate, tranType);
	endif;
	
	if combo.listCount = 1 then
		combo.listIndex := 1;
	elseif _class&lt;&gt; null then
		combo.text := _class;
	endif;
epilog
	delete strs;
end;</source>
        <Parameter name="_group" type="String"/>
        <Parameter name="_class" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupComboTranTypeGroup" id="ca049520-68f4-4b0d-959a-838a2882ece8">
        <source>setupComboTranTypeGroup(_group : String);
/*
Purpose - 	
Who - NAVAB1
Date - 27SEP2023
ADO - CR 60699 TASK 60700 
*/

vars
	combo : CMUI_ComboBox;
begin
	combo := self.myForm.cmbTranTypeGroup;
	combo.clear();
	
	combo.addItem(app.getErrorString(Cargo_GC));
	combo.addItem(app.getErrorString(WorkOrder));
	
	 // Select the Default
	if _group = null then
		combo.text := app.getErrorString(Cargo_GC); 
	else
		combo.text := _group;
	endif;
epilog

end;</source>
        <Parameter name="_group" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="8fc041e9-9d49-42cf-b543-f635a40a359c">
        <source>setupThumbnailDetails();
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 19/06/2013	cnwcs5	par 31657 - tidy up while fixing par
vars
	form 	: SOP_TableMaintForm;
	table	: CM_EntryTable;
	str		: String;
	coll	: ClassNDict;
	class	: Class;

begin
  	form 	:= self.myForm;
	table	:= form.tblInput1;
	
	form.useProxyObject := true;
	form.setTblDataEntRows(ETDef_TransactionType_Data);

	form.shtTblInput1.caption := 'Details';
	form.initTblInput(table, ETDef_TransactionType_Input);
	
	str	:= app.getErrorString(Cargo_GC);	

	table.setComboValuesByName(ETRow_TranTypeGroup, str);// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1

	form.shtTblInput1.visible := true;

epilog
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="002196fe-b694-4b51-a928-46b9c6e16171">
        <updating/>
        <source>showThumbnail(_trxType : CM_TransactionType) updating;
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 19/06/2013	cnwcs5	par 31657 - tidy up while fixing par

vars
	form 	: SOP_TableMaintForm;
	table	: CM_EntryTable;

	transactionType : String;
begin
// ### TFS CR 60699 TASK 60700 28 SEP2023 NAVAB1	self.setupTransactionTypes();

	form 	:= self.myForm;
	table 	:= form.tblInput1;

	table.clearValues;

	table.setValueByName(ETRow_Description, _trxType.description);
	table.setValueByName(ETRow_TrxType, _trxType.trxType);
// ### TFS CR 60699 TASK 60700 28SEP2023 NAVAB1	table.setValueByName(ETRow_TrxGroupStr, app.transactionTypeEnumToString(_trxType.trxGroup));
// ### TFS CR 60699 TASK 60700 28SEP2023 NAVAB1 	table.setValueByName(ETRow_ClassNameToCreate, _trxType.classNameToCreate);
// PAR 33570	table.setValueByName(ETRow_CanCompleteToDoTask, _trxType.canCompleteToDoTask);

	// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
	transactionType := app.transactionTypeEnumToString(_trxType.trxGroup);
	table.setValueByName(ETRow_TranTypeGroup, transactionType);
	self.setupComboTranTypeClass(transactionType,  _trxType.classNameToCreate);
	table.setValueByName(ETRow_TranTypeClass, _trxType.classNameToCreate);

end;</source>
        <Parameter name="_trxType" type="CM_TransactionType"/>
    </JadeMethod>
</Class>
