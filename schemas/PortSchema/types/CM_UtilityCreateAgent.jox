    <JadeMethod name="utlCreateVehicleBookingAdv" id="1f45db04-c445-4438-99a2-95de9ac12953">
        <updating/>
        <source>utlCreateVehicleBookingAdv(_proxy : CM_VehicleBookingTimeSlot; _newVehicleBooking : CM_VehicleBookingTimeSlot output; _allNewVehicleBookingProxies : CM_VehicleBookingTSItemSet input; _isCopy : Boolean; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jul 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
24 May 2023	navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current
13 Jul 2023 navma1	Bug 59130: FR 53429 EUP | VBS changes MTN - External Ref Validation
10 Aug 2023	navlw1	ChangeRequest 59132:[59133] EUP | VBS Audits
03 Sep 2023	navdap	TFS 60186 EUP | FR 53824 - Road Manifest VBS Booking
*/

vars
	item : CM_VehicleBookingTimeSlotItem;	// TFS 60186
	deliveries, pickups : StringArray;		// TFS 60186

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	// TFS 60186 start
	create deliveries transient;
	create pickups transient;
	foreach item in _allNewVehicleBookingProxies do
		if item.myTrackedItem &lt;&gt; null then
			if item.direction = DIRECTION_DELIVERY then
				deliveries.add(item.myTrackedItem.id);
			else
				pickups.add(item.myTrackedItem.id);
			endif;
		endif;
	endforeach;
	app.myValCA.valVehicleBooking(_proxy, deliveries, pickups,_isCopy, _passport);
	//app.myValCA.valVehicleBooking(_proxy,null,null,_isCopy, _passport);		//24.5.2023 navhl20 #58041
	// TFS 60186 end
	
	if not self.checkValidationWithPassport(_passport) then					//13.07.2023 navma1 #59130
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create _newVehicleBooking as _proxy.class persistent;
	_newVehicleBooking.setForCreate(_proxy);
	
	if _passport.noErrors then
		_newVehicleBooking.setForUpdateVBSTimeSlotItems(_proxy,_allNewVehicleBookingProxies);
	endif;
	
	if _passport.noErrors then // 10.08.2023 navlw1 tfs #59132:#59133
		self.myCreateAuditAgent.audCreateGeneric(_newVehicleBooking);
	endif;
	
epilog
	delete deliveries;	// TFS 60186
	delete pickups;		// TFS 60186
end;</source>
        <Parameter name="_proxy" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_newVehicleBooking" type="CM_VehicleBookingTimeSlot" usage="output"/>
        <Parameter name="_allNewVehicleBookingProxies" type="CM_VehicleBookingTSItemSet" usage="input"/>
        <Parameter name="_isCopy" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
