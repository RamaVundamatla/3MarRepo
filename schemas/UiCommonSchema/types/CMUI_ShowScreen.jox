    <JadeMethod name="setupForm" id="4cd19e29-8fa0-4a7d-a874-0083d2154698">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.setNavigatorHeading(self.caption); 

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;
	
	self.frmPicture.left := 0;
	
	self.doResize();
end;</source>
    </JadeMethod>
