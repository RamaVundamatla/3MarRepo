    <JadeMethod name="getPicture" id="b78e42b8-2404-4554-8e15-fe98d03b8b47">
        <source>getPicture() : Binary;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	thePicture : Binary;
	theISOType : CM_ISOType;
begin
	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
		return null;
	endif;

	theISOType := self.CM_Container.getISOTypeObject;
	if theISOType &lt;&gt; null then
		thePicture := theISOType.getPicture(self.myTerminal);
	endif;
	
	return thePicture;
end;</source>
