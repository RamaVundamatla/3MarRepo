    <JadeMethod name="searchForOnsiteTI" id="8cbcad5b-a49f-4b1d-8954-611c96cccec1">
        <source>searchForOnsiteTI(tiId : String; matches: Integer output; _cargoType : Integer; _cargoGroupId : String; _cargoSubtypeId : String; _operatorCode : String) : CM_TrackedItem; //18 May 2022 navds20 TFS 53504
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 November 2014	cnwndl1	Initial creation	Par 35210
17 May 2022 		navds20 TFS 53504 EUP - Cargo Uniqueness - PortSchema
02 May 2023			jlizm1	TFS 55453 Cargo uniqueness by subtype
05 Jun 2025 		navma1 MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars

	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	iter : Iterator;
	cargoType : CM_CargoType;
	checkCargoGroup : Boolean;
	checkSubtype : Boolean;
	cargoGroupStr, subTypeStr : String;
begin
	create tiArray transient;
	cargoType := app.myRoot.allCargoTypesById[_cargoType];	//05.06.2025 navma1 #MTN-34114
	
	if cargoType &lt;&gt; null then
		if app.isCargoGroupEnabled then
			checkCargoGroup := cargoType.useCargoGroupForUniqueness;
		endif;
		checkSubtype := cargoType.useCargoSubtypeForUniqueness;
	endif;
	
	iter := self.allTrackedItemsById.createIterator;
	self.allTrackedItemsById.startKeyGeq(tiId, _cargoType,iter);
	while iter.next( ti ) do
		if ti.id &lt;&gt; tiId then
			break;
		endif;
		if ti.cargoType &lt;&gt; _cargoType then
			break;
		endif;
		
		//should not happen but add extra check for location with bad data 
		if ti.hasBeenMerged then
			continue;
		endif;
		
		// start 17/05/2022 navds20 TFS 53504
		if checkCargoGroup then
			 cargoGroupStr := ti.getMyCargoGroupId(); // ### TFS BUG 58101 22MAY2023 NAVAB1
			if cargoGroupStr &lt;&gt; null 				  // ### TFS BUG 58101 22MAY2023 NAVAB1
			and cargoGroupStr &lt;&gt; _cargoGroupId then
				continue;
			endif;
		endif;
		//end 17/05/2022 navds20 TFS 53504
		
		/*										//14.Nov.2023 navsp1 TFS 61127
		//03.Nov.2023 navsp1 TFS 61067
		//Check the operator
		//Now the system can create duplicate cargo based on operator
		if ti.myCargoGroup &lt;&gt; null and (ti.myCargoGroup.operatorCode &lt;&gt; null and _operatorCode &lt;&gt; null and ti.myCargoGroup.operatorCode &lt;&gt; _operatorCode) then
			continue;
		endif;*/
		
		if checkSubtype then
			subTypeStr := ti.getCargoSubTypeCode(); // ### TFS BUG 58101 22MAY2023 NAVAB1
			if subTypeStr &lt;&gt; null 					// ### TFS BUG 58101 22MAY2023 NAVAB1
			and subTypeStr &lt;&gt; _cargoSubtypeId then
				continue;
			endif;
		endif;
		
		tiArray.add( ti );
	endwhile;
	
	
	matches := tiArray.size;
	
	
	if not tiArray.isEmpty then
		return tiArray.first;
	endif;

	return null;
epilog

	delete tiArray;
	delete iter;

end;</source>
        <Parameter name="tiId" type="String"/>
        <Parameter name="matches" type="Integer" usage="output"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_cargoGroupId" type="String"/>
        <Parameter name="_cargoSubtypeId" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
