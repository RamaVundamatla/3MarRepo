    <JadeMethod name="getQueryCaption" id="fdda9af6-db39-4ff3-bd16-e351c19b8b2a">
        <source>getQueryCaption() : String;
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpCaption : String;
begin
	if self.myCurrentWagon &lt;&gt; null then
		if tmpCaption = null then
			tmpCaption := self.myCurrentWagon.id;
		else
			tmpCaption := tmpCaption &amp; ", " &amp; self.myCurrentWagon.id;
		endif;
	endif;
	
	return tmpCaption;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
