    <JadeMethod name="contextMenu" id="86c6d3a7-4e0c-4f99-9d97-70fd9882424d">
        <controlMethod name="Form::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>contextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------------------
//Created: 22 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	x1, y1 : Real;
begin
	if (not app.isAllowedToInspect) then
		return false;
	endif;
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuFormContext, x1.Integer, y1.Integer);
	return false;

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="0c644ad3-7fa3-4e67-90e3-b391521ae1ce">
        <updating/>
        <source>create() updating;
//--------------------------------------------------
// Created:	01 October 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.permissionView	:= PmShipJobOperationsMaint;
	self.permissionMaint := PmShipJobOperationsView; // TFS 2198

	self.splTablesRatio := 80;
	self.helpFileName := HelpFile_Voyage;

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteCurrentVoyJobEntry" id="3b07632c-5506-496b-93cf-3d15b808abbe">
        <source>deleteCurrentVoyJobEntry();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20/11/2018 jlgrh7 	TFS #41374 POL - [Fwd: ##RE-9144## : Lori 837R - Archive with active jobe]
28/06/2019	jlgdap1	TFS 45341 Error 1090 when deleting a job entry without a TI
*/

vars
	wleArray 			: CM_WLEArray;
	wleTable 			: CM_DataTable;
	wle					: CM_WorkListEntry;
	tiId				: String;	
	warningMsg 			: String;
	jobId 				: String;
	reqId				: String;						// TFS 42341
	allocation 			: CM_VoyageAllocation;			// TFS 42341
begin
	app.mousePointer := MousePointer_HourGlass;
  	
	create wleArray transient;
	wleTable:=self.myCurrentTableWLE;
	if wleTable = null then
		return;
	endif;
	self.getAllWLEsInTableSelected(wleArray,wleTable,null );
	
	foreach wle in wleArray discreteLock do
		tiId := null;																				// TFS 42341
		if wle &lt;&gt; null then
			jobId := wle.job.jobId;
			if wle.myTrackedItem &lt;&gt; null then														// TFS 42341
				tiId := wle.myTrackedItem.id;
			else																					// TFS 42341
				if wle.myRequest &lt;&gt; null then														// TFS 42341
					allocation := wle.myRequest.getFirstAllocation();								// TFS 42341
					if allocation &lt;&gt; null then														// TFS 42341
						reqId := allocation.code;													// TFS 42341
					else																			// TFS 42341
						reqId := wle.CM_VoyageWLE.getTIId;											// TFS 42341
					endif;																			// TFS 42341
				endif;																				// TFS 42341
			endif;																					// TFS 42341
		endif;
		if tiId &lt;&gt; null then																		// TFS 42341
			warningMsg := app.getErrorString2(CONF_DELETE, "Cargo " &amp; tiId,  "Job " &amp; jobId);
		elseif reqId &lt;&gt; null then																	// TFS 42341
			warningMsg := app.getErrorString2(CONF_DELETE, "Request " &amp; reqId,  "Job " &amp; jobId);	// TFS 42341
		else																						// TFS 42341
			warningMsg := app.getErrorString1(CONF_DELETE, "Job " &amp; jobId);							// TFS 42341
		endif;																						// TFS 42341
		if app.msgBox ( warningMsg, app.getErrorString(Warning), MsgBox_OK_Cancel) = MsgBox_Return_OK then
			app.myTrxDA.trxDeleteVoyageJobEntry(wle, app.myPassport); 
		else
			continue;
		endif;
	endforeach;
	//self.myCurrentTableWLE.refreshMe();
epilog
	delete wleArray;
	app.mousePointer := MousePointer_Default;  	
end;</source>
    </JadeMethod>
    <JadeMethod name="disconnectReefers" id="7601a589-01b2-48e4-b8f0-780e387a919a">
        <updating/>
        <source>disconnectReefers(_all : Boolean)updating;
//--------------------------------------------------------------
//Created: 16 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	result,
	numRows,
	row : Integer;
	obj : Object;
	paramSet : CMIF_TITxnControllerSet;
	wle : CM_WorkListEntry;
	tiParam : CMIF_TITransactionController;
	param : CMIF_ConnectParams;
begin

	if self.myCurrentTableWLE = null then
		return;
	endif;
	app.mousePointer := MousePointer_HourGlass;	
	create paramSet transient;
	
	if _all then
		// get all the ti's in the table
		numRows := self.myCurrentTableWLE.rows;
		foreach row in 2 to numRows do
			obj := self.myCurrentTableWLE.accessRow(row).itemObject;
			if obj.isKindOf(CM_WorkListEntry) then
				wle := obj.CM_WorkListEntry;
				param := self.getCMIF_ConnectParamsForTI(wle.myTrackedItem);
				if param &lt;&gt; null then
					paramSet.add(param);
				endif;
			endif;
		endforeach;
	else
		// get ti's for the selected row(s) only															
		foreach obj in self.myCurrentTableWLE.allSelectedObjects do
			if obj.isKindOf(CM_WorkListEntry) then
				wle := obj.CM_WorkListEntry;
				param := self.getCMIF_ConnectParamsForTI(wle.myTrackedItem);
				if param &lt;&gt; null then
					paramSet.add(param);
				endif;
			endif;
		endforeach;
	endif;
	
	if paramSet.isEmpty then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateDisconnectReefers(paramSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Disconnect Reefers', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
			
epilog
	app.mousePointer := MousePointer_Default;		
	self.allProxies.purge();
	paramSet.purge();
	delete paramSet;	
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayAllWLEsForObj" id="743a8d46-c9a2-4614-8a15-18b6055dbe6a">
        <updating/>
        <source>displayAllWLEsForObj(_table : CM_DataTable input; _job : CM_VoyageJob)updating;
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
vars
	wleArray	: CM_WLEArray;
begin

	create wleArray transient;
	
	if _job &lt;&gt; null then	
		_job.getAllWLEs(wleArray);
	else
		self.getAllWLEs(wleArray);
	endif;
	
	if not wleArray.isEmpty() then
		self.myWLESorter.init(self.myCurrentVoyage, wleArray.first.job.CM_VoyageJob);		
		wleArray.copy(self.myWLESorter);
		wleArray.clear;
		self.myWLESorter.copy(wleArray);
	endif;
	
	self.displayWLEs(_table, wleArray);
	
epilog
	delete wleArray;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="displayExtraInfoForObj" id="e8d1edf4-838c-4b4e-9583-692f90a5bac4">
        <source>displayExtraInfoForObj(_obj : CM_Object);
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	dataContainer : CM_DataContainer;
	wle 		: CM_WorkListEntry;
	
begin

	if self.myCurrentTableInfo = null then
		return;
	endif;
	
	self.myCurrentTableInfo.rows := 0;
	
	if self.myCurrentTableInfo &lt;&gt; null then
		create dataContainer transient;
		dataContainer.headerColour := self.colorHeadingColumn;
		dataContainer.valueColour := self.colorValueColumn;
				
		if _obj &lt;&gt; null and _obj.isKindOf(CM_Object) then
			_obj.CM_Object.getExtraInfo(dataContainer);
			self.showExtraInformation(dataContainer, self.myCurrentTableInfo, true, false, 4, 1, 1, 1, 1);
			self.doResizeColumnWidths(self.myCurrentTableInfo, true);
		endif;
	endif;
	
	
epilog
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="displayRowForDataTable" id="f627457b-db49-488d-956b-e67258c284b7">
        <source>displayRowForDataTable(_obj : CM_Object; _table : CM_DataTable) : String;
//--------------------------------------------------------------
//Created: 13 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return _obj.getAttributeStringForDefArray(_table.allTblDataEntRows);
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_table" type="CM_DataTable"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayWLEs" id="f13a4a28-85f3-41d0-86a5-e03c89bfad3d">
        <updating/>
        <source>displayWLEs(_table : CM_DataTable input; _wleArray: CM_WLEArray)updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	job			: CM_VoyageJob;
	wle	    	: CM_WorkListEntry;
	str			: String;
	idx,
	rtCol 		: Integer;
	label		: CMUI_Label;
	localTbl	: Table;
begin
	
	rtCol := _table.getColumnByRowName(ETRow_RadioTelemetry);
	_table.sortAscending := false;
	_table.resortTableByColumn(_table.getColumnByRowName(ETRow_SeqNumAsString));
	
	job := _table.userObject.CM_VoyageJob;

	if job = null then
		return;
	endif;	
	
	self.updateJobDisplay(_table);
	

	if _wleArray.isEmpty then
		return;
	endif;
	
	foreach wle in _wleArray do
		if wle.job &lt;&gt; job then	
			continue;
		endif;
		localTbl := self.allTablesByWle.getAtKey(wle);
		// Clear it out.
		if localTbl &lt;&gt; null then
			self.allTablesByWle.removeKeyEntry(wle, localTbl);
		endif;
		idx := self.addWLEForTable(_table, wle);
		if idx &gt; 0 then
			self.tblWLESetRowColour(_table, wle, idx, rtCol);				
		endif;
	endforeach;
	
		
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_wleArray" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="displayWLEsShowRT" id="cdcbab46-21cc-490b-b8d8-6740cf37c66b">
        <source>displayWLEsShowRT(_table : CM_DataTable input; _row, _rtCol : Integer);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		The new Queue and Planned icons do not have a Q or a P in them 
//				so use letters instead and this method sets the colours
//				Should only be called from self.tblWLESetRowColour()
//
//Date			Who		Reason
//19 Aug 2019	jlgzm1	TFS 42872 TFS 42872 Moved to CM_BaseForm, multiple forms using same code
// ---------------------------------------------------------------------------

vars
	theCell : JadeTableCell;

begin
	inheritMethod(_table, _row, _rtCol);
	/*
	if _table = null then
		return;
	endif;
	
	if _row &lt;= _table.fixedRows then // ### 10409
		return;
	endif;
	
	if _rtCol &lt;= _table.fixedColumns then // ### 10409
		return;
	endif;
	
	theCell := _table.accessCell(_row, _rtCol);
	
	if theCell.text.pos("H",1) &gt; 0  then
		//Job entry is held
		if theCell.backColor = Red then
			theCell.foreColor := White; // PAR 9342. Incase the line is overstowed, i.e. the background is RED
		else
			theCell.foreColor := Red;
		endif;
		theCell.fontBold := true;
		
	elseif theCell.text.pos("P",1) &gt; 0 then
		//Job entry is planned
		theCell.foreColor := Green;

	elseif theCell.text.pos("Q",1) &gt; 0 then
		//Job entry is Queued
		if theCell.backColor = Red then
			theCell.foreColor := White; // PAR 9342. Incase the line is overstowed, i.e. the background is RED
		else
			theCell.foreColor := Red;
		endif;
	// tfs42840 jlgzm1 30/05/2019
	elseif theCell.text.pos("DR",1) &gt; 0 then
		//Job entry is a direct release
		theCell.foreColor := Green;
		
	else
		theCell.foreColor := Blue;		
	endif;	
	*/
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_rtCol" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAutoDischarge" id="8a2ed6e2-b557-41ba-8951-83b17c5c0817">
        <source>doAutoDischarge(_isAutoPlan : Boolean) protected;

// Created by cnwdvb1 on 01 May 2006

vars

	obj		: Object;
	voyage	: CM_Voyage;

begin

	obj := self.lstJobs.listObject;
	
	if obj.isKindOf(CM_Voyage) then
		voyage := obj.CM_Voyage;
	elseif obj.isKindOf(CM_VoyageJob) then
		voyage := obj.CM_VoyageJob.myVoyage;
	elseif obj.isKindOf(CM_VoyageJobSheet) then
		voyage := obj.CM_VoyageJobSheet.myVoyage;
	endif;
	
	if voyage &lt;&gt; null then
		self.myAssistant.autoPlanForDischarge(self.myTerminal, voyage);
	endif;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_isAutoPlan" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAutoplanSelectedTwin" id="929bc477-aa8a-486f-a802-40514128bf56">
        <updating/>
        <source>doAutoplanSelectedTwin() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 March 2009	cnwer1	Initial creation

*/

vars

	wlesWithWarnings,
	wleArray : CM_WLEArray;
	result	: Integer;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create wleArray transient;
	create wlesWithWarnings transient;	
	

	self.getAllSelectedWLEs(wleArray);

	while true do
		app.myTrxUA.trxUpdateWLEsAutoplanTwin(wleArray, wlesWithWarnings, PLANNING_MODE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				//do show it here, ask Q below.
				result := 1;				
			else
				result := app.showErrorWarningDialog('Voyage Auto-Planning', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			endif;
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

	if app.myPassport.returnCode = INFO_NO_AUTOPLAN then
		if app.msgBox(app.getErrorString(app.myPassport.returnCode), "Information",
					 MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
	
epilog
	delete wlesWithWarnings;
	delete wleArray;
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
