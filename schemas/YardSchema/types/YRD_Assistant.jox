    <JadeMethod name="addPreNoteFromCargoReceiptForm" id="e4baa832-2f2e-4597-aa1d-6459b2f7c363">
        <updating/>
        <source>addPreNoteFromCargoReceiptForm(_parentForm: CM_BaseForm input; _trackedItem: CM_TrackedItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2009	cnwdap1	Initial creation
*/
vars

begin
	inheritMethod(_parentForm, _trackedItem);		// so references at the superschema level finds this implementation
	if _parentForm.isKindOf(YRD_TrainWagonCargoForm) then
		_parentForm.YRD_TrainWagonCargoForm.addPreNoteItem(_trackedItem);
	else
		_parentForm.YRD_LocationEnquiryFrm.addPreNoteItemToWagon(_trackedItem);
	endif;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm" usage="input"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="allowCargoPositionSwap" id="596327c4-f121-4316-9ad7-95d70677a6be">
        <source>allowCargoPositionSwap( selectedCargo : CM_TIArray; _moveMode : Integer; dataArray : ObjectArray io ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwndl1	Initial creation

*/

vars

	size : Integer;
	ti : CM_TrackedItem;
	ti_1 : CM_TrackedItem;
	ti_2 : CM_TrackedItem;
	ti_3 : CM_TrackedItem;
	
	oldLocCont_1 : CM_WagonController;
	oldLocCont_2 : CM_WagonController;
	oldLocCont_3 : CM_WagonController;
	newContPos_1 : CM_WagonController;
	newContPos_2 : CM_WagonController;
	newContPos_3 : CM_WagonController;
	
	dynaDict : DynaDictionary;
	obj : Object;
	
begin

	if dataArray &lt;&gt; null then
		dataArray.clear();
	endif;

	if _moveMode &lt;&gt; REAL_MODE then
		return false;
	endif;

	if selectedCargo = null then
		return false;
	endif;
	
	size := selectedCargo.size;
	
	//13 Oct 2914	NDL	Par 35040
	foreach ti in selectedCargo do
		if ti.myPrimaryActualLocation.allTrackedItems.last &lt;&gt; ti then
			//I'm not on the top of the stack.
			return false;
		endif;
	endforeach;

	if size = 2 then
		
		if selectedCargo.first.getActualLength = selectedCargo.last.getActualLength then
			// they are the same size, simple swap is all that is required.
			if dataArray &lt;&gt; null then
				ti_1 := selectedCargo.first;
				ti_2 := selectedCargo.last;
				
				oldLocCont_1 := ti_1.getPrimaryLocation(REAL_MODE).CM_WagonController;
				oldLocCont_2 := ti_2.getPrimaryLocation(REAL_MODE).CM_WagonController;
		
				dataArray.add(ti_1);
				dataArray.add(oldLocCont_2);
			
				dataArray.add(ti_2);
				dataArray.add(oldLocCont_1);
			endif;
			return true;
		else
			// we have disimilar lengths, set the local variable ti_1 to be the longest of the two
			if selectedCargo.first.getActualLength &gt; selectedCargo.last.getActualLength then
				ti_1 := selectedCargo.first;
				ti_2 := selectedCargo.last;
			else
				ti_1 := selectedCargo.last;
				ti_2 := selectedCargo.first;
			endif;
			oldLocCont_1 := ti_1.getPrimaryLocation(REAL_MODE).CM_WagonController;
			oldLocCont_2 := ti_2.getPrimaryLocation(REAL_MODE).CM_WagonController;
			
			//is there enough space where ti_2 was to fit ti_1, and if so what is the first location controller to use.
			if oldLocCont_2.canSwapTiWithTis( ti_2, ti_1, null, newContPos_1, newContPos_3 ) then
				if dataArray &lt;&gt; null then
					dataArray.add(ti_1);
					dataArray.add(newContPos_1);
				
					dataArray.add(ti_2);
					dataArray.add(oldLocCont_1);
				endif;
				return true;
			endif;
		endif;
		
		return false;
		
	elseif size = 3 then

		// sort into largest to smallest  ti_1 being the largest.
		create dynaDict transient;
		dynaDict.setMembership(CM_TrackedItem);
		dynaDict.addExternalKey(Real,2,true,false);
		dynaDict.endKeys(true);
		foreach ti in selectedCargo do
			dynaDict.putAtKey(ti.getActualLength,ti);
		endforeach;
		
		foreach obj in dynaDict do
			if ti_1 = null then
				ti_1 := obj.CM_TrackedItem;
				continue;
			endif;
			if ti_2 = null then
				ti_2 := obj.CM_TrackedItem;
				continue;
			endif;
			if ti_3 = null then
				ti_3 := obj.CM_TrackedItem;
				continue;
			endif;
		endforeach;
		
		delete dynaDict;
		
		if ti_1 = null or ti_2 = null or ti_3 = null then
			// belt and braces
			return false;
		endif;
		
		oldLocCont_1 := ti_1.getPrimaryLocation(REAL_MODE).CM_WagonController;
		oldLocCont_2 := ti_2.getPrimaryLocation(REAL_MODE).CM_WagonController;
		oldLocCont_3 := ti_3.getPrimaryLocation(REAL_MODE).CM_WagonController;
		
		if oldLocCont_2.myWagon &lt;&gt; oldLocCont_3.myWagon then
			// can't move a ti_1 where ti_2 &amp; ti_3 were if ti_2 &amp; ti_3 aren't on the same wagon
			return false;
		endif;
		
		//is there enough space where ti_2 &amp; ti_3 were to fit ti_1, and if so what location controller do we use.
		if oldLocCont_2.canSwapTisWithTi(ti_2, ti_3, ti_1, newContPos_1 ) then
			if dataArray &lt;&gt; null then
				dataArray.add(ti_1);
				dataArray.add(newContPos_1);	
			endif;
		else
			return false;
		endif;
		
		//is there enough space where ti_1 was to fit ti_2 &amp; ti_3, and if so what location controllers do we use.
		if oldLocCont_1.canSwapTiWithTis( ti_1, ti_2, ti_3, newContPos_2, newContPos_3 ) then
			if dataArray &lt;&gt; null then
				dataArray.add(ti_2);
				dataArray.add(newContPos_2);
				
				dataArray.add(ti_3);
				dataArray.add(newContPos_3);
			endif;
		else
			return false;
		endif;
		
		return true;
		
	endif;
	
	return false;
	
epilog
	delete dynaDict;	
end;</source>
        <Parameter name="selectedCargo" type="CM_TIArray"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="dataArray" type="ObjectArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxRailArea" id="5a39543f-c600-4718-8baf-938d89c1e951">
        <source>comboBoxRailArea(_cmb : ComboBox input; _railArea : CM_Rail);
//--------------------------------------------------------------
//Created: 07 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	idx				: Integer;
	railJobSheet	: CM_RailJobSheet;
	rail			: CM_TerminalArea;
	termAreaDict	: CM_TAByIdDict;
begin
	railJobSheet := self.myTerminal.myRailJobSheet;
	_cmb.clear;
	termAreaDict := self.myTerminal.getAllTAsOfType(TA_TYPE_RAILWAY_TRACK);
	
	foreach rail in termAreaDict do 
		idx := _cmb.addItem(rail.id);
		_cmb.itemObject[idx] := rail;
	endforeach;	
	
	if _railArea &lt;&gt; null then
		_cmb.text := self.displayEntryRailArea(_railArea);
		_cmb.listObject := _railArea;
	endif;
		
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_railArea" type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="comboBoxRailLine" id="c7220b9a-ca29-461f-8736-6da140665c04">
        <source>comboBoxRailLine(_cmb : ComboBox input; _railArea : CM_Rail; _railLine : CM_RailLine);
//--------------------------------------------------------------
//Created: 07 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	idx		: Integer;
	railLine : CM_RailLine;
begin
	_cmb.clear;
	_cmb.sorted := false;
	if _railArea = null then
		return;
	endif;

	_cmb.addItem('All');
	foreach railLine in _railArea.allRailLines do 
		idx := _cmb.addItem(railLine.getIdString);
		_cmb.itemObject[idx] := railLine;
	endforeach;	

	if _railLine &lt;&gt; null then
		_cmb.text := self.displayEntryRailLine(_railLine);
		_cmb.listObject := _railLine;
	else
		_cmb.listIndex := 1;
	endif;
		

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_railArea" type="CM_Rail"/>
        <Parameter name="_railLine" type="CM_RailLine"/>
    </JadeMethod>
    <JadeMethod name="comboBoxRailPosition" id="3bd22240-574c-45d6-9130-54b2124047e0">
        <source>comboBoxRailPosition(_cmb : ComboBox input; _railLine : CM_RailLine; _pos : Integer);
//--------------------------------------------------------------
//Created: 07 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	idx : Integer;
begin
	_cmb.clear;
	if _railLine = null then
		return;
	endif;
	
	foreach idx in 1 to _railLine.maximumWagons do
		if _pos &gt; 0 and idx &lt; _pos  then
			continue;
		endif;
		_cmb.addItem(idx.String.padLeadingZeros(2));
	endforeach;

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_railLine" type="CM_RailLine"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrainUserEventTypes" id="d04e8e04-b38e-4f54-bed8-48ee2470b23b">
        <source>comboBoxTrainUserEventTypes( _cmb : ComboBox input; _eventType : CM_EventType; _terminal : CM_Terminal );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 October 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	iter : Iterator;
	firstOne : CM_EventType;
	eventType : CM_EventType;
	index : Integer;
	
begin

	_cmb.clear;
	
	iter := app.myRoot.allEventTypesByCategory.createIterator;
	firstOne := app.myRoot.allEventTypesByCategory.getAtKeyGeq(eventType.TRAIN_EVENT,null);
	
	if firstOne &lt;&gt; null then
		iter.startAtObject(firstOne);
		while iter.next( eventType ) do
			if eventType.category &lt;&gt; eventType.TRAIN_EVENT then
				break;
			endif;
			if not eventType.canCreateManually() then
				continue;
			endif;
			if not eventType.canUserAdd( _terminal ) then	//09 Mar 2020	NDL	TFS 48784
				continue;
			endif;
			index := _cmb.addItem(eventType.name);
			_cmb.itemObject[index] := eventType;
			
		endwhile;
	endif;
	
/*	eventType := app.myRoot.allEventTypesByType[EVT_TrainArrive];
	if eventType &lt;&gt; null then
		index := _cmb.addItem(eventType.name);
		_cmb.itemObject[index] := eventType;
		_cmb.itemEnabled[index] := false;
	endif;
	
	eventType := app.myRoot.allEventTypesByType[EVT_TrainDepart];
	if eventType &lt;&gt; null then
		index := _cmb.addItem(eventType.name);
		_cmb.itemObject[index] := eventType;
		_cmb.itemEnabled[index] := false;
	endif;*/
	
	if _eventType &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_eventType);
	else
		_cmb.listIndex := -1;
	endif;

epilog
	
	delete iter;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="displayEntryRailArea" id="91b1eef0-d9ca-408f-b321-e3a9e2fb4507">
        <source>displayEntryRailArea(_railArea : CM_Rail) : String;
//--------------------------------------------------------------
//Created: 07 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _railArea = null then
		return null;
	endif;

	return _railArea.id;

end;</source>
        <Parameter name="_railArea" type="CM_Rail"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryRailLine" id="cb342942-bbeb-4354-8daa-1348b9d09081">
        <source>displayEntryRailLine(_railLine : CM_RailLine) : String;
//--------------------------------------------------------------
//Created: 07 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _railLine = null then
		return null;
	endif;

	return _railLine.getIdString;

end;</source>
        <Parameter name="_railLine" type="CM_RailLine"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doAssignReleasesToWagons" id="e6eb2fba-9986-4038-a548-c76fb964c18b">
        <updating/>
        <source>doAssignReleasesToWagons( _wleArray : CM_WLEArray; _wagonArray : CM_WagonArray; _doRtQueue : Boolean )updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
20 August 2009		cnwndl1	Initial creation CCMS 1094
19 October 2022		jlizm1	TFS 54118 Assigning Releases to Wagons

*/

vars

	agent : CM_RailProcessingAgent;
	
	//02 Dec 2020	NDL	TFS 50164
	wle : CM_WorkListEntry;
	cargoType: CM_CargoType;
	totWt : Decimal[14,4];
	totQty : Integer;
	resDet : CM_ReserveDetail;
	density : Decimal [16,4];
	wagon : CM_Wagon;
	tmpWagonArray : CM_WagonArray;
	tmpWleArray : CM_WLEArray;
	newWle : CM_WorkListEntry;
	byWeight : Boolean;	//21 Dec 2020	NDL	TFS 50516
	byQuantity : Boolean; //21 Dec 2020	NDL	TFS 50516
	
begin

	if false then
		inheritMethod( _wleArray, _wagonArray, _doRtQueue );
	endif;

	create agent transient;
	agent.initialise(self.myTerminal);
	
	if self.myTerminal.getConfig(RailReleaseAssignEnhance).Boolean then
		//If they have chosen just one wle and its for dups allowed cargo then allow teh user to tell us how much to use
		//per wagon that they have selected to apply to, even if its just one wagon.
		if _wleArray.size = 1 then
			wle := _wleArray.first;
			cargoType := wle.getCargoType();
			if wle.myRequest &lt;&gt; null then					// TFS 54118
				resDet := wle.myRequest.myReserveDetail;	// TFS 54118
			endif;
			if cargoType.isAllowDuplicates then
				if cargoType.isBulkByVolume or cargoType.isBulkByWeight then
					if cargoType.isBulkByVolume and resDet &lt;&gt; null then
						density := resDet.getDensity();
					endif;
					totWt := wle.weight;
					byWeight := true;	//21 Dec 2020	NDL	TFS 50516
				else
					totQty := wle.quantity;
					byQuantity := true;	//21 Dec 2020	NDL	TFS 50516
				endif;
				if totQty &gt; 1 or totWt &gt; 0 then
					//Need to ask them how much per wagon to assign, default to full amount divided by the number of wagons selected (rounded down).
					if not self.showAmountForRailAssignBulk(	self.myTerminal,
																wagon,
																_wagonArray,
																resDet,
																cargoType,
																density,
																totWt,
																totQty ) then
						return;
					endif;
					//validate that they haven't exceeded the total amount on the WLE
					
					//if wle.weight &lt;&gt; totWt or wle.quantity &lt;&gt; totQty then
					if ( byWeight and wle.weight &lt;&gt; totWt ) or ( byQuantity and wle.quantity &lt;&gt; totQty ) then	//21 Dec 2020	NDL	TFS 50516
						//OK we need to split the wle and assign the 'user selected amount' per wagon.
						create tmpWagonArray transient;
						create tmpWleArray transient;
						
						foreach wagon in _wagonArray do
							tmpWagonArray.clear();
							tmpWleArray.clear();
							
							tmpWagonArray.add( wagon );
							//if wle.weight &gt; totWt or wle.quantity &gt; totQty then
							if ( byWeight and wle.weight &gt; totWt ) or ( byQuantity and wle.quantity &gt; totQty ) then	//21 Dec 2020	NDL	TFS 50516
							
								app.myTrxUA.trxSplitWLEforRailAssign( wle, totWt, totQty, newWle, app.myPassport );
								
								if newWle = null then
									continue;
								endif;
								tmpWleArray.add(newWle);
							else
								tmpWleArray.add(wle);
							endif;
							
							agent.doAssignReleasesToWagons( tmpWleArray, tmpWagonArray, _doRtQueue, true );
						endforeach;
						
						return;
						
					endif;
				endif;
			endif;
		endif;
	endif;
	
	agent.doAssignReleasesToWagons( _wleArray, _wagonArray, _doRtQueue, true );
	
	return;			

epilog

	delete agent;
	delete tmpWagonArray;
	delete tmpWleArray;
	
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray"/>
        <Parameter name="_wagonArray" type="CM_WagonArray"/>
        <Parameter name="_doRtQueue" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCargoPositionSwap" id="df4aa6ff-9a64-4f68-bcda-470facfb1153">
        <source>doCargoPositionSwap( _control : CMIF_WagonMoveController; selectedCargo : CM_TIArray );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwndl1	Initial creation	CCMS 1094

*/

vars
	dataArray : ObjectArray;
	tiArray : CM_TIArray;
	newLocationsArray : ObjectArray;
	obj : Object;
begin

	create dataArray transient;
	if not self.allowCargoPositionSwap( selectedCargo, REAL_MODE, dataArray ) then
		return;
	endif;
	
	create tiArray transient;
	create newLocationsArray transient;
	foreach obj in dataArray do
		if CM_TrackedItem.hasInstance(obj) then
			tiArray.add(obj.CM_TrackedItem);
		elseif CM_WagonController.hasInstance(obj) then
			newLocationsArray.add(obj.CM_WagonController);
		endif;
	endforeach;
	
	app.myTrxUA.trxSwapWagonCargoPositions( _control, tiArray, newLocationsArray, app.myPassport);

epilog 

	delete tiArray;
	delete newLocationsArray;
	delete dataArray;
	
end;</source>
        <Parameter name="_control" type="CMIF_WagonMoveController"/>
        <Parameter name="selectedCargo" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="doConfirmWagonsOutward" id="ac5d8ed0-f83e-40fc-8e1b-28ff93c91886">
        <source>doConfirmWagonsOutward( _moveController : CMIF_WagonMoveController; _wagonArray : CM_WagonArray input; _menuItem : MenuItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwndl1	Initial creation

*/

vars

	theReturn : Integer;
	
begin
	
	while true do
		app.myTrxUA.trxUpdateWagonsConfirmOut( _moveController, _wagonArray, true, app.myPassport);

		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Outward_wagon_confirm), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
		
epilog
	
end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_wagonArray" type="CM_WagonArray" usage="input"/>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doGetSelectorTIsLoadList" id="c9569173-c817-42b6-a288-748a80e9122b">
        <updating/>
        <source>doGetSelectorTIsLoadList(_objs : ObjectSet; _train : CM_Train; _includeDestPort : Boolean) : CM_EnquiryController updating;
// ---------------------------------------------------------------------------
// Created:		14 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//	Feb 2012	29015 include destination port if called from summary tab but not from the other tabs of the Rail Load List
//					to still include items having no destination port
// ---------------------------------------------------------------------------

vars
	enqController			: CM_EnquiryController;
	queryDef				: CM_QueryDefinition;
	queryParams				: CM_QueryCriteriaLineHolder;
	anObject : Any;
	aTI : CM_TrackedItem;
	imex : IntegerArray;
	disPorts,
	taS :	ObjectSet;
	aPort : CM_Port;
	portStr : StringArray;
	
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 0];//mode = 0 for TrackedItem mode
	app.myQAFilter.createEnqControllerForMode(queryDef.mode, queryDef.type, enqController);
	
	create taS transient;
	create enqController.allObjects as CM_ObjectSet transient;
	create disPorts transient;
	create portStr transient;
	create imex transient;

	foreach anObject in _objs do
		aTI := anObject.CM_TrackedItem;
		if aTI.myTerminalArea &lt;&gt; null 
		and not taS.includes(aTI.myTerminalArea) then
			taS.add(aTI.myTerminalArea);
		endif;	
		if aTI.destinationPort &lt;&gt; null then
			aPort := app.myRoot.allPorts[aTI.destinationPort];
			if aPort &lt;&gt; null then
				if not disPorts.includes(aPort) then
					disPorts.add(aPort);
					portStr.add(aPort.code);
				endif;
			endif;
		endif;
	endforeach;

	imex.add(TI_IMEX_STATUS_EXPORT);
	
	imex.add(TI_IMEX_STATUS_REMAINONBOARD); // this will pick up DLRs

	
	delete queryParams;
	create queryParams transient;
	queryParams.collectionBelongsTo := CM_Terminal.firstInstance;//don't need this?
	
	//create criteria
	self.doSetSelectorCriteria(queryParams,queryDef,'myTerminal', CM_QueryOperator.Operator_Equal,self.myTerminal);
	self.doSetSelectorCriteria(queryParams,queryDef,'site', CM_QueryOperator.Operator_Equal,TI_SITE_ONSITE_str);
	if _train &lt;&gt; null then
		self.doSetSelectorCriteria(queryParams,queryDef,'myTrainAssigned', CM_QueryOperator.Operator_Equal,_train);
	endif;
	self.doSetSelectorCriteria(queryParams,queryDef,'planningState', CM_QueryOperator.Operator_NotEqual,"Planned to Load");

	self.doSetSelectorCriteria(queryParams,queryDef,'myTerminalArea', CM_QueryOperator.Operator_IsOneOf,taS);
	if _includeDestPort then
		self.doSetSelectorCriteria(queryParams,queryDef,'destinationPort', CM_QueryOperator.Operator_IsOneOf,portStr);
	endif;


	//execute query
	enqController.myCriteriaLineHolder := queryParams;
	enqController.doQuery(queryDef);

	return enqController;
epilog
	delete taS;
	delete disPorts;
	delete portStr;
	delete imex;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_objs" type="ObjectSet"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_includeDestPort" type="Boolean"/>
        <ReturnType type="CM_EnquiryController"/>
    </JadeMethod>
    <JadeMethod name="doRemoveCargoFromWagon" id="e0b6a749-a4f9-4a79-b69c-93e27c504e72">
        <updating/>
        <source>doRemoveCargoFromWagon(_ti : CM_TrackedItem; _wagon : CM_Wagon; _menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Aug 2009	cnwndl1	Initial creation
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	proxyWagon 	    : CM_Wagon;
	rake		    : CM_RailLine;
	wagonPos 		: Integer;
	result		    : Integer;
begin

	if _ti = null then
		return;
	endif;
	
	if _wagon = null then
		return;
	endif;
	
	proxyWagon := app.createUpdateProxy(_wagon).CM_Wagon;
	proxyWagon.setProxy(self.myTerminal, 
						_wagon.id,
						_wagon.myWagonClass,
						_wagon.myTrainInwards,
						_wagon.myTrainOutwards,
						_wagon.remarks, 
						0,	//Par 21924
						0,	//Par 21924
						0,
						_wagon.myCarrier,
						_wagon.myStevedoreReceive,  //02.10.2020 cnwma1 TFS #50112
						_wagon.myStevedoreRelease );  //02.10.2020 cnwma1 TFS #50112						  
	create wagonUpdateCtrl transient;
	rake := _wagon.myRailLine;
	if rake &lt;&gt; null then
		wagonPos := rake.allWagons.indexOf(_wagon);
	endif;
	wagonUpdateCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
										rake,	//_rake : CM_RailLine;
										_wagon.myTrainOutwards,	//_train : CM_Train;
										wagonPos,	//_wagonPosition : Integer
										true//_trainMode : Boolean;
										);
										
	wagonUpdateCtrl.populateFromExistingWagonAddTi( _wagon, null, 0 );
	wagonUpdateCtrl.removeTrackedItem(_ti, _wagon);
	
	wagonUpdateCtrl.expectedEditionWagon := _wagon.edition;
	wagonUpdateCtrl.myProxyWagon := proxyWagon;
	
	if app.msgBox(app.getErrorString2(CONFIRM_REMOVE,_ti.id,_wagon.id),app.getErrorString(AreYouSure),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport); //+ cnwmd1, CCMS 1067, Par 19913

		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString1(Remove_from_wagon, _ti.id), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;	

epilog
	delete proxyWagon;
	delete wagonUpdateCtrl;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doReturnWagon" id="c2c5c458-00a9-4d27-acce-f1c8bc7d7679">
        <source>doReturnWagon( _wagon : CM_Wagon; _railLine : CM_RailLine; _pos : Integer ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation

*/

vars

	train : CM_Train;
	wagMoveController : CMIF_WagonMoveController;
	theReturn : Integer;
	
begin

	app.mousePointer := Window.MousePointer_HourGlass;
	
	if _wagon = null then
		app.raiseCMException(Wagon_null, null, null);
		return false;
	endif;
	
	if not _wagon.isDeparted then
		app.raiseCMException(Wagon_not_departed, null, null);
		return false;
	endif;

	train := _wagon.myTrainOutwards;
	
	if train = null then
		app.raiseCMException(Null_train, null, null);
		return false;
	endif;
	
	if _railLine = null or _pos = 0 then
		app.msgBox(app.getErrorString(Must_enter_rail_positio), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if app.msgBox(app.getErrorString2(Pleas_confi_that_want_retur_ra, _wagon.id, _railLine.getDisplayDetails(false)), app.getErrorString(Return_Wagon), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return false;
	endif;

	create wagMoveController transient;
	wagMoveController.myTargetRailLine := _railLine;
	wagMoveController.targetPosition := _pos;
	wagMoveController.allWagons.add( _wagon );
	wagMoveController.doAutoPlanOfCargo := false;
	wagMoveController.returnWagon := true;
	wagMoveController.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837

	//Train
//	clear wagons TIs from Trains allTIsReleased 
// set myTerminal
// reset myTerminalDeparted

	
	//wagon
// set myRailLine
// set myTerminal
// reset myTerminalDeparted
//	clear allTIsReleased - includes the TIs....
//	add 'return' transactions
// reset confirmed outwards

	app.myPassport.setWarningsIgnored(false);	//18 Dec 2009	NDL Par 22035

	while true do

		app.myTrxUA.trxUpdateWagonReturn(wagMoveController,  app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Train_confirmation), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so we will want to pass the acknowledgement
				// back to the update trans...
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
		
	endwhile;

	return false;
	
epilog

	delete wagMoveController;
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_railLine" type="CM_RailLine"/>
        <Parameter name="_pos" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetSelectorCriteria" id="18426d1e-cff6-4b6b-a9d0-f57a8c00488a">
        <source>doSetSelectorCriteria(_queryParams: CM_QueryCriteriaLineHolder input;_queryDef	: CM_QueryDefinition;_property : String; _operator : String; _value : Any);
// ---------------------------------------------------------------------------
// Created:		Novemebr 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	criteria: CM_SelectorCriteriaLine;
	queryProperty,clonedProp			: CM_QueryProperty;
	queryOperator,clonedOp			: CM_QueryOperator;
	queryValue				: Any;
	obj : Object;
begin
	if _value.isKindOf(IntegerArray) then
		create criteria transient;
		queryProperty := _queryDef.allQueryProperties[_property];
		queryOperator := queryProperty.allAllowedOperators[_operator];
		clonedProp := queryProperty.cloneSelf(true);
		clonedOp := queryOperator.cloneSelf(true);
	
		clonedOp.setSearchValue(_value);	
		criteria.set(clonedProp, clonedOp, false);
		criteria.setMyCriteriaLineHolder(_queryParams);
	else
		create criteria transient;
		queryProperty := _queryDef.allQueryProperties[_property];
		queryOperator := queryProperty.allAllowedOperators[_operator];
		queryValue := queryProperty.translateToSearchValue(_value); 
		clonedProp := queryProperty.cloneSelf(true);
		clonedOp := queryOperator.cloneSelf(true);
	
		
		
		clonedOp.setSearchValue(queryValue);	
		criteria.set(clonedProp, clonedOp, false);
		criteria.setMyCriteriaLineHolder(_queryParams);
	endif;
end;</source>
        <Parameter name="_queryParams" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <Parameter name="_queryDef" type="CM_QueryDefinition"/>
        <Parameter name="_property" type="String"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doUnassignReleasesFromWagons" id="a0593b6e-f38d-4522-8370-e8b290cc54ef">
        <source>doUnassignReleasesFromWagons(menuItem: MenuItem input; wleArray: CM_WLEArray; wagonArray: CM_WagonArray);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2009	cnwndl1	Initial creation CCMS 1094

*/

vars

	wagon : CM_Wagon;
	wagonCont : CM_WagonController;
	wle : CM_WorkListEntry;
	wlesToUnassign : CM_WLEArray;
	allRailJobs : CM_JobSet;
	job : CM_Job;
	
begin

	create wlesToUnassign transient;

	if menuItem.name = YRD_RailOperationsForm::mnuUnAssignRelWagon.name then
		// starting from job selections end.
		if wleArray.isEmpty then
			app.msgBox(app.getErrorString(No_Assigned_Rail_Reqs_Selected),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		wleArray.copy(wlesToUnassign);
	
	elseif menuItem.name = YRD_RailOperationsForm::mnuUnAssignRelWagon2.name then
		// starting from wagon selections end.
		if wagonArray.isEmpty then
			app.msgBox(app.getErrorString(No_Wagons_Selected_To_Unassign),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		foreach wagon in wagonArray do
			foreach wagonCont in wagon.allLocationsControllersArray do
				foreach wle in wagonCont.allRailWLELoad do
					if not wlesToUnassign.includes(wle) then
						wlesToUnassign.add(wle);
					endif;
				endforeach;
			endforeach;
		endforeach;
		
		if wlesToUnassign.isEmpty then
			app.msgBox(app.getErrorString(No_Rail_reqs_found),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	
	endif;
	
	//unassign the wle's
	app.myTrxUA.trxUnAssignWleFromWagon(wlesToUnassign,app.myPassport);
	
	// bail if we have any errors
	if app.myPassport.hasErrors then
		return;
	endif; 
	
	//send out notifications for each related job.
	create allRailJobs transient;
	foreach wle in wlesToUnassign do
		job := wle.job;
		if job &lt;&gt; null and not allRailJobs.includes(job) then
			allRailJobs.add(job);
		endif;
	endforeach;
	foreach job in allRailJobs do
		job.causeEvent(self.myTerminal.getTerminalEvent(RailJob_Update_Event), true, job);
	endforeach;

epilog

	delete wlesToUnassign;
	delete allRailJobs;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
        <Parameter name="wleArray" type="CM_WLEArray"/>
        <Parameter name="wagonArray" type="CM_WagonArray"/>
    </JadeMethod>
    <JadeMethod name="showAmountForRailAssignBulk" id="58019d7f-3cc2-4a2e-a865-be863798039f">
        <updating/>
        <source>showAmountForRailAssignBulk(	_terminal : CM_Terminal;
								_wagon : CM_Wagon;
								_wagonArray : CM_WagonArray;
								_resDetail : CM_ReserveDetail;
								_cargoType : CM_CargoType;
								_density : Decimal;
								weight : Decimal io;
								quantity : Integer io
								): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2017	cnwndl1	Initial creation	TFS 3514

*/

vars
	
	form : CMUI_RailAssignBulkAmount;
	modalResult : Integer;
	
begin

	app.mousePointer := Window.MousePointer_HourGlass;
											
//	create form transient;
	form := app.loadForm(CMUI_RailAssignBulkAmount, YRD_Assistant, false, false, false, self.myTerminal, null).CMUI_RailAssignBulkAmount;
	form.myCargoType := _cargoType;
	
	
	if _cargoType.isBulkByVolume or _cargoType.isBulkByWeight then
		form.maxWeight := weight;
		if _cargoType.isBulkByVolume then
			form.maxVolume := weight / _density;
		endif;
	else
		form.maxQuantity := quantity;
	endif;
	
	form.myReserveDetail := _resDetail;
	form.myWagon := _wagon;
	if _wagonArray &lt;&gt; null then
		_wagonArray.copy( form.allWagons );
	endif;
	form.setMyTerminal( _terminal );
	
	if form.showModal &lt;&gt; IDOK then
		return false;
	endif;
	
	if form.byQuantity then
		quantity := form.getQuantity;
	else
		weight := form.getWeightMovedKgs;
	endif;
					
	return true;
	
epilog

	delete form;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_wagonArray" type="CM_WagonArray"/>
        <Parameter name="_resDetail" type="CM_ReserveDetail"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_density" type="Decimal"/>
        <Parameter name="weight" type="Decimal" usage="io"/>
        <Parameter name="quantity" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showColorCodeWagnsOLD" id="c4af12a0-020f-469a-8f9c-b31cecd6b6fd">
        <source>showColorCodeWagnsOLD(_allWagons : Collection;
					_masterMenuAction : CMUI_MenuAction);
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	frm				: YRD_WagonColorCodeForm;
	defaultAlooc	: CM_RailAllocation;
	obj				: Any;
	wagon			: CM_Wagon;
begin
	if _allWagons.size = 0 then
		return;
	endif;
	
	frm := app.loadForm(YRD_WagonColorCodeForm, YRD_Assistant, false, false, false, self.myTerminal, _masterMenuAction).YRD_WagonColorCodeForm;
	
	if frm = null then
		return;
	endif;
	
	foreach obj in _allWagons do
		wagon := obj.CM_Wagon;
		if (not frm.allWagons.includes(wagon)) then
			frm.allWagons.add(wagon);
		endif;
		
		defaultAlooc := wagon.getRailAllocation();
		if frm.myRailAllocation = null and defaultAlooc &lt;&gt; null then
			frm.myRailAllocation := defaultAlooc;
		endif;	
	endforeach;
	
	
	frm.showModal();
	
	

end;


</source>
        <Parameter name="_allWagons" type="Collection"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showColorCodeWagons" id="377aed24-0c28-46d2-a93b-6c5a402fd961">
        <source>showColorCodeWagons(_allWagons : Collection;
					_masterMenuAction : CMUI_MenuAction);
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm				: CMUI_YAMaintRailForm;
	defaultAlooc	: CM_RailAllocation;
	obj				: Any;
	wagon			: CM_Wagon;
	yas : ObjectArray;
begin
	if _allWagons.size = 0 then
		return;
	endif;
	

	theForm := app.loadForm(CMUI_YAMaintRailForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_YAMaintRailForm;
	if theForm = null then
		return;
	endif;
	
	foreach obj in _allWagons do
		wagon := obj.CM_Wagon;
		if (not theForm.allWagons.includes(wagon)) then
			theForm.allWagons.add(wagon);
		endif;
		
		defaultAlooc := wagon.getRailAllocation();
	endforeach;
	if defaultAlooc &lt;&gt; null then
		create yas transient;
		if defaultAlooc &lt;&gt; null then
			yas.add(defaultAlooc);
		endif;
	endif;
	theForm.setYardAllocation(yas);
	theForm.setParentForm(null);
	theForm.showModal();
	
	
epilog

	delete yas;
end;


</source>
        <Parameter name="_allWagons" type="Collection"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showInternalMoveForm" id="d5fad22c-3c57-4a6d-9e43-a9dab1d717b9">
        <updating/>
        <source>showInternalMoveForm(_parentForm : CM_BaseForm; _modal: Boolean; _columns, _controlWidth : Integer; _obj : CM_Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwrd1	Initial creation

*/

vars
	form	: YRD_InternalMoveForm;
begin
	form := app.loadForm(	YRD_InternalMoveForm, 
							self.class, 
							false, false, false, 
							self.myTerminal, null).YRD_InternalMoveForm;
														
	// If user fails security we don't want to show a null form.
	if form &lt;&gt; null then
		//form.setIsFull(_isFull);
		form.setColumnsAndControlWidth(_columns, _controlWidth);	// columns, default control width
		form.initForm(_obj);
		
		if _modal then
			form.showModal();
		else
			form.show();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_modal" type="Boolean"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
