    <JadeMethod name="doFormLoad" id="befc5c81-a6ba-43da-9adc-07d8c5e951fb">
        <updating/>
        <source>doFormLoad() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Changes

Date		Name	TFS#		Description
============================================================================
03 Aug 2012	cnwkpd1	Reference to JADE PAR #58552 - to correctly handle images with transparent
					regions, the transparentColor on the setBackDrop method should be set to -1,
					rather than a specific colour
05 Jun 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
20 Sep 2019 jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/

constants
	BackdropCentered	: Integer = 1;
	UsePicTransparency	: Integer = -1;
	
vars
	colorInt	: Integer;
	pic			: Binary;
	
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	// in the Jade Skin Maintenance form set Form, Inner Image, Is brush = false
	// so that the back colour can be set below
	//	self.ignoreSkin := true;

	self.frmToolbarBtns.top := -1000;	// move out of visible area
		colorInt := app.myRoot.getConfig(AppBackgroundColor).Integer;
		if colorInt &lt;&gt; 0 then
			self.setBackColor(colorInt);
		endif;
	self.toolbarStyle := self.ToolbarStyle_ShowAllowHide;
	
	app.defaultMdi := true;
// due to problems with XP turn off skin till at least JADE 6
	//cnwth2 - we're on jade 6 now so lets give it a go...
	//app.setSkinByName('PortTecBlue', null);
	app.mainForm := self;
	self.setMenus();
	
	self.centreWindow();
	self.handlePreShow();
	self.lblUserName.caption := app.getMyUserCode;
	self.lblUserName.transparent := true;
	self.doResize;
	
	self.caption := app.getProductName();

	if process.isJLGAB1() then
		if app.doNotFIlterCombos then
			self.caption := "N " &amp; self.caption;
		else
			self.caption := "Y " &amp; self.caption;
		endif;
	endif;

	//Give the database path so we can distinguish between other JMTerminals that may be open.
	if app.isDevelopmentSystem then
		if app.myRoot.client &lt;&gt; null then
			self.caption := self.caption &amp; ' - ' &amp; app.dbPath &amp; ". Client : " &amp; app.myRoot.client;
		else
			self.caption := self.caption &amp; ' - ' &amp; app.dbPath &amp; "." ;
		endif;
	endif;
	
	// When do change for DCT to allow settting of Background pic need
	// to change here (refer DQ 12 March 2008)
	pic := app.myRoot.getConfig(SystemBackgroundPic).Binary;
	if pic = null then
		pic := self.picBackDrop.picture;
	endif;
	if pic &lt;&gt; null then
		self.setBackDrop(pic, BackdropCentered, UsePicTransparency);
	endif;
	
	//Register for send message events
	self.beginNotification(system, Event_SendMessage, Response_Continuous, null);

	self.show;
	
	if (not app.isSpecial())
	and (not app.myRoot.isLicensedForProductCode(ProductCode_JMT))
	then
		self.mousePointer := Window.MousePointer_Default;
		app.writeLog('System unlicensed - attempting to license', LogINFO);
		app.msgBox(app.getErrorString(UnlicensedSystem), app.getErrorString(Error), MsgBox_OK_Only);
		
		if (not app.doLicense(app.myRoot,true)) then
			app.writeLog('License of system failed', LogFATAL);
			terminate;
		endif;
	endif;
	
	self.helpKeyword := HelpFile_LibraryBase;		// PAR #34210
	
	
epilog
	self.mousePointer := Window.MousePointer_Default;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFrmToolbarShowHideContextMnu" id="2c9ab6cd-ef9c-44a8-8dd0-9dd3cea916ae">
        <source>doFrmToolbarShowHideContextMnu() protected;
// -------------------------------------------
// Created 18 May 2005 by cnwdvb1
// -------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
20/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	tmpUser		: CM_User;
	tmpTerminal	: CM_Terminal;	
begin

	// this sets all to false
	inheritMethod();
	
	if app.myPassport = null then
		return;
	endif;
	tmpUser := app.myPassport.myUser;
	if tmpUser = null then
		return;
	endif;
	tmpTerminal := app.myPassport.myTerminal;

	self.mnuResetFromJMT.visible	:= true;
	self.mnuResetFromSys.visible	:= true;
	self.mnuSeperator1.visible		:= true;
	self.mnuHide.visible			:= true;

	if tmpUser.canDo(tmpTerminal, PmAdmAdminMenuAccess) then
		self.mnuSeperator2.visible := true;
		self.mnuSaveAsSys.visible := true;
		self.mnuResetAll.visible := true;
	endif;
		
	if tmpUser.canDo(tmpTerminal, PmAdmOrganizeMenus) then
		self.mnuCustomise.visible := true;
	endif;

	if app.isSpecial() then
		self.mnuSaveAsJMT.visible		:= true;	
	else
		self.mnuSaveAsJMT.visible		:= false;	
	endif;
	
//	self.mnuShowCaptions.checked 	:= self.frmToolbar.showCaptions;
//	self.mnuShowCaptions.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
