    <JadeMethod name="btnVoyageDefin_click" id="24c582a1-bf28-4ab0-9fc7-831a36be5f5c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnVoyageDefin_click(btn: Button input) updating;

vars

begin
	if self.myCurrentVoyage &lt;&gt; null then
		self.myAssistant.showVoyageDefForm(self.myCurrentVoyage, self.myMasterMenuAction, false, false);
	else
		self.myAssistant.showVoyageDefForm(null, self.myMasterMenuAction, false, false);
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clearNotableObjects" id="9c5c0c4b-28ca-4434-94f7-4b1a84991188">
        <source>clearNotableObjects() protected;

vars
	obj : Object;
begin

	foreach obj in self.allNotableObjects do
		if CM_Voyage.hasInstance(obj) then
			self.endNotification(obj, VoyageBOLIn_Create_Event);
		else
			endNotification(obj, Object_Update_Event);
		endif;
	endforeach;

	self.allNotableObjects.clear;
end;</source>
        <access>protected</access>
    </JadeMethod>
