    <JadeMethod name="utlCreateITSInterfaceRequest" id="065fa2d8-2029-4c7b-a8d0-3c8b8bf6ab44">
        <source>utlCreateITSInterfaceRequest(_pxyObject : CM_ITSInterfaceRequest; _realObject : CM_ITSInterfaceRequest output; 
							_passport : CM_Passport input);

/*

Purpose:			Record ITS Interface Request.

Parameters:			Proxy for class of request (Request from ITS, internal reset request etc.)

Return Value:		None


Date		Who		Reason
16 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	create _realObject as _pxyObject.class persistent;
	_realObject.setForCreate(_pxyObject, _passport);
	
	if _passport.noErrors() and 
	   _realObject.isToBeActioned() then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_ITS_ActionRequest), false, null);
	endif;

epilog

end;</source>
        <Parameter name="_pxyObject" type="CM_ITSInterfaceRequest"/>
        <Parameter name="_realObject" type="CM_ITSInterfaceRequest" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateITSInterfaceResponse" id="8c67e9a8-fb14-4659-ace1-e736610b52f6">
        <source>utlCreateITSInterfaceResponse(	_pxyObject	: CM_ITSInterfaceResponse input;
								_realObject : CM_ITSInterfaceResponse output;
								_request	: CM_ITSInterfaceRequestMessage input;
								_passport	: CM_Passport input);

/*

Purpose:			Create Interface Response that will be sent to ITS.

Parameters:			_pxyObject	: Proxy for response.
					_request	: The request from ITS that is being responded to, null for an internal request.

Return Value:		None


Date		Who		Reason
24 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	if _request &lt;&gt; null then
		_request.setProcessed(_pxyObject.createdTS);
	endif;

	// Single threading for allocation of unique message number
	exclusiveLock(_pxyObject.myITSInterfaceDefinition);
	
	create _realObject as _pxyObject.class persistent;
	_realObject.setForCreate(_pxyObject);
	
	if _passport.noErrors() and 
	   _realObject.isToBeSent() then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_ITS_SendResponse), false, null);
	endif;

epilog

end;</source>
        <Parameter name="_pxyObject" type="CM_ITSInterfaceResponse" usage="input"/>
        <Parameter name="_realObject" type="CM_ITSInterfaceResponse" usage="output"/>
        <Parameter name="_request" type="CM_ITSInterfaceRequestMessage" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateImportStorageConfig" id="708726db-447c-4633-afe3-8af9dc798723">
        <updating/>
        <source>utlCreateImportStorageConfig(_file : File; _term : CM_Terminal; _passport : CM_Passport input;
										_realConfig : CM_StorageConfig output; _errorStore : CM_ErrorSet input; _numLines : Integer output) : Integer updating;
/*
Purpose:			
Date		Who		Reason
04 July 2017	cnwab1	Initial creation
08 Feb 2018		jlgmd1	TFS #36934 - STWO - Nothing happens when loading STORAGECONFIG in PROD
*/

constants
	ProgressBarRefresh	: Integer = 2000;
vars
	count 			: Integer;
	err				: CM_Error;
	xmlElement		: JadeXMLElement;
	loadOk			: Boolean;
	
	xmlDocumentParser : JadeXMLDocumentParser;
	rootElement : JadeXMLElement;
	xmlDocument : JadeXMLDocument;
	xmlNode : JadeXMLNode;
	iter : Iterator;
	proxyStorageConfig, newStorageConfig : CM_StorageConfig;
	proxyStorageDetail, newStorageDetail : CM_StorageDetail;
	proxyFutureStorageMapping, newFutureStorageMapping : CM_FutureStorageMapping;
begin

	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return 0;
	endif;
	
	
	
	create xmlDocumentParser transient;
	create xmlDocument transient;
	
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement := xmlDocument.rootElement;
	
	
	// HOW MANY 'ROWS' IN THE FILE?
	_numLines := 1;
	iter := rootElement.childNodes.createIterator;
	while iter.next(xmlNode) do
		xmlElement := xmlNode.JadeXMLElement;
			if xmlElement.tagName = "allStorageDetails" then
				_numLines:= _numLines + xmlElement.childNodes.size;
		elseif xmlElement.tagName = "myWorkingDaysCalendar" then
			if not xmlElement.childNodes.isEmpty then
				_numLines:= _numLines + 1;
			endif;
		elseif xmlElement.tagName = "allStorageTriggers" then
				_numLines:= _numLines + xmlElement.childNodes.size;
		elseif xmlElement.tagName = "allYACriteriaTypes" then
				_numLines:= _numLines + xmlElement.childNodes.size;
		endif;
	endwhile;	
	
	// LOAD THE XML INTO THE PROXY
	create proxyStorageConfig as CM_StorageConfig transient;
	loadOk := proxyStorageConfig.setProxyFromXMLLoad(rootElement, _errorStore,_term);
	if not loadOk then		//08 Feb 2018 jlgmd1 TFS #36934
		return 0;			//08 Feb 2018 jlgmd1 TFS #36934
	endif;					//08 Feb 2018 jlgmd1 TFS #36934
	
	// DELETE THE EXISTING PERSISTENT CONFIG
	if _term.myStorageConfig &lt;&gt; null and _term.myStorageConfig.cnEcIsPersistent then
		newStorageConfig := _term.myStorageConfig;
		delete newStorageConfig;
	endif;
	
	// LOAD THE PROXY INTO THE PERSISTANT
	create newStorageConfig persistent;
	newStorageConfig.setForCreateWholeStructure(proxyStorageConfig, app.myPassport);

	if _passport.hasErrors and _errorStore &lt;&gt; null then
		foreach err in _passport.allErrors do 
			err.setErrorText('Storage Config  ' &amp; ' : '  &amp; err.text, false);
			if not _errorStore.includes(err) then
				_errorStore.add(err);
			endif;
		endforeach;
	else
		count := 0;
		if newStorageConfig &lt;&gt; null then
			count := 1;
			count := count + newStorageConfig.allStorageDetails.size;
			if newStorageConfig.myWorkingDaysCalendar &lt;&gt; null then
				count := count + 1;
			endif;
			count := count + newStorageConfig.allStorageTriggers.size;
			count := count + newStorageConfig.allYACriteriaTypes.size;
		endif;
	endif;
	
	return count;

epilog
	_file.close;
	delete xmlDocumentParser;
	delete xmlDocument;
	delete proxyStorageConfig;
	delete iter;	//26 Sep 2017	NDL	TFS 7032
	
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_realConfig" type="CM_StorageConfig" usage="output"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_numLines" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInOut" id="b2f068a0-ebc0-47e1-879f-7d2f5a25a235">
        <updating/>
        <source>utlCreateInOut(pIntFaceCommon : CMIF_InOutCommon input; pIntFaceArray : CMIF_TIObjectArray; _passport : CM_Passport input; _allBookingSlots : CMIF_1StopBookingDataArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2014	cnwmc5	Initial creation

*/

vars
	nullObject			: CM_Object;
	job 				: CM_RoadJob;
	createBulkRelease,
	planTwinAtGate,
	rtnValue,
	invalidJob			: Boolean;
	item				: CMIF_TIObject;
	cmifRelByType		: CMIF_ReleaseByType;
	tmpEvent,
	st					: Integer;
	tmpTerminal			: CM_Terminal;
	matchCode, 
	lastSysCode,
	lastMatch			: String;
	icArea 				: CM_InterchangeArea;	// par 24292
	gate				: CM_Gate;
	vehicle 			: CM_Vehicle;
	location 			: CM_YardController;
	receivalsToTwinAutoplan,
	receivalsToAutoplan : ObjectArray;
	isoTypeObject		: CM_ISOType;
	existingRoadJob		: CM_RoadJob;
	ti 					: CM_TrackedItem; 		//TFS 53107, AjitM, navam1
	needsBooking 		: Integer;	
	visit				: CM_VehicleVisitRecord;
	
begin
	// cnwjk3 16/10/09 PAR 20777 - moved here so that it is after the exception handlers are armed
	//th2 added 23/01/07 (1081 : Deadlock) on CM_Termina.allVehicleVisits ( CM_VehicleVisitsByDTDups)
	exclusiveLock(_passport.myTerminal.allVehicleVisits);
	if _passport.hasErrors then
		return;
	endif;
	
	// DVB added 30/05/2005
	app.initialiseForStartAutoPlan(_passport);
	
	app.setContinueCMExceptions(true);
	app.writeLog('Create In/Out - start - validation', LogINFO);

	//epr 18/2/08 refactored all the validation into this method
	app.myValCA.valCreateInOut(pIntFaceCommon,pIntFaceArray,_passport);

	endLoad;		// to clear any locks that may have been held as part of validation

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	planTwinAtGate:=_passport.myTerminal.getConfig(TwinLiftFromGate).Boolean;
	app.writeLog('Create In/Out - start - update', LogINFO);
	st := app.clock;	
	
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;
	
	tmpTerminal := _passport.myTerminal;
	
	// cnwjk3 PAR 20923 29/10/09
	// Check to see if a job has already been created for this vehicle
	if pIntFaceCommon.myProxyRoadJob &lt;&gt; null and pIntFaceCommon.myProxyRoadJob.myVehicle &lt;&gt; null then
		existingRoadJob := pIntFaceCommon.myProxyRoadJob.myVehicle.allRoadJobs.first().CM_RoadJob;
	endif;
	
	app.setContinueCMExceptions(false);
	
	// Do the actual creates and updates
	pIntFaceCommon.actionForCreate(nullObject, _passport);

	if _passport.hasErrors() then
		return;
	endif;
	
	/*
		Date	Who		Reason
	 9 Sep 2008	cnwdz2	Par16804 - handle invalid object reference.
	*/
	on Exception do app.handleDeletedObject(exception, job, invalidJob);
		
	job 	:= pIntFaceCommon.myRoadJob;
	vehicle := job.myVehicle;
	
	
	if invalidJob then 
		app.raiseCMException(ErrorOnStore_JobIsNull, null, null);	// 9 Sep 2008	cnwdz2	Par16804
		return;
	endif;

	if job.myGate = null and job.roadTransAreaId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString (Gate), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString (Gate), null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	//have to move the vehicle into pregate area before the autoplanning and rt queue selection which is done in  item.actionForCreate (below)
	//create the vehicle visit record here
	app.myUtilityCA.utlCreateVehicleVisitRecord(job, _passport);
	
	if _passport.hasErrors() then
		return;
	endif;

	// cnwjk3 PAR 20923 29/10/09
	// Only move the vehicle if a new road job has been created
	//if existingRoadJob &lt;&gt; job then
	// cnwjk3 PAR 20923 30/10/09
	if existingRoadJob &lt;&gt; job and vehicle.myPrimaryActualLocation &lt;&gt; null then
		// If the vehicle is in a gate lane, figure out where to move it next
		if vehicle.myPrimaryActualLocation.isGateAreaLocation then
			gate := job.myGate;
			// get IC Area entered as override area - think this will alway be the case for old gate form
			icArea := job.getOverride_YardICArea;	// par 24418	
			
			if icArea &lt;&gt; null then
				// they specified a particular IC area
				location := icArea.myInTransitToLocation;
			elseif gate &lt;&gt; null then
				// find the next location for the vehicle based on the sequence of areas at the gate and
				// the receipts/releases that are part of the job - ciould be p-gate or into yard
				location := gate.getNextLocation_IN(vehicle);
			endif;
			
			if location &lt;&gt; null then
				//move to next area
				app.myUtilityUA.utlMoveVehicle(	vehicle, location, _passport);
			endif;
			
			if  _passport.hasErrors then
				return;
			endif;
		endif;
	endif;
	createBulkRelease := (not tmpTerminal.getConfig(DoNotCreateBulkRelease).Boolean);
	create receivalsToTwinAutoplan transient;
	create receivalsToAutoplan transient;
	
	foreach item in pIntFaceArray do
		//epr 19/2/09 CCMS 1032 twin straddles 
		//epr par 19912 16/6/09
		if item.canBeTwinAutoPlanned(job) and planTwinAtGate then
			receivalsToTwinAutoplan.add(item);
		else
			if item.canBeAutoPlanned(job) then
				receivalsToAutoplan.add(item);
			endif;
		endif;
		// Par8380 - get system number for bulk release if needed
		// and match up releases from same sheet
		if createBulkRelease then
			if item.isKindOf(CMIF_ReleaseByType) then
				cmifRelByType := item.CMIF_ReleaseByType;
				
				if cmifRelByType.releaseNo = null then
					matchCode := cmifRelByType.systemBulkReleaseCode;
					
					if matchCode = lastMatch then
						cmifRelByType.systemBulkReleaseCode := lastSysCode;
					endif;
				else
					matchCode := cmifRelByType.releaseNo;
					
					if matchCode = lastMatch then
						cmifRelByType.systemBulkReleaseCode := lastSysCode;
					endif;				
				endif;
			endif;
		endif;
			
		if (not item.actionForCreate(nullObject, _passport)) then		//Also does sub items
			break;
		endif;
		
		if _passport.hasErrors() then
			break;
		endif;
		
		if matchCode &lt;&gt; null and cmifRelByType &lt;&gt; null then
			lastSysCode := cmifRelByType.systemBulkReleaseCode;
			lastMatch := matchCode;
		endif;
	endforeach;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	
	app.myUtilityCA.utlCreateInOutAutoplanReceival(receivalsToTwinAutoplan,receivalsToAutoplan,job,_passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	
	//update the created vehicle visit record with newly created ti's
	app.myUtilityUA.utlUpdateVehicleVisitRecordTIs(job);
	
	if _passport.hasErrors() then
		return;
	endif;

	if pIntFaceCommon &lt;&gt; null then
		job := pIntFaceCommon.myRoadJob;
		delete pIntFaceCommon.myProxyRoadJob;
	endif;

	if job = null or invalidJob then
		// raise an exception
		app.raiseCMException(ErrorOnStore_JobIsNull, null, null);
		return;
	endif;

	if _passport.hasErrors() then
		return;
	endif;

	if job.autoComplete and 
	   tmpTerminal.getConfig(GateInAutoCompleteBkgrnd).Boolean then
	   //cnwer1 19/2/09 refactored - extracted code block into method below
	   app.myUtilityCA.utlCreateInOutBGAutoComplete(job,_passport);
		return;
	endif;	

	//cnwer1 19/2/09 refactored -extracted code block into method below
	rtnValue:=app.myUtilityCA.utlCreateInOutReconBol(pIntFaceCommon, pIntFaceArray, job,_passport);	//pIntFaceArray added. 25450 13/09/2010
	
	if _passport.hasErrors() then
		return;
	endif;

	if (not rtnValue) then 
		if job.autoComplete then
		  // job.checkAllToDoTaskComplete then //jlier1 MTN-34117 18/3/25 - deadlocks - road jobs can't have CM_WOToDoWLE kind of wles so just ineffiecient to check
			app.myUtilityUA.utlUpdateJobDoMove(job, REAL_MODE, _passport);
		else
			//Queue WLEs to correct queue;
			if job.hasCargoToQueue(null, true) then
				job.enqueueJob();
			endif;
			if _passport.hasErrors() then
				return;
			endif;
			job.rebuildStatus();
		endif;
	
	endif;

	//TFS 53107, AjitM, navam1
	if job.myVehicleVisit &lt;&gt; null then
		visit := job.myVehicleVisit;
		visit.setBookingSlots(_allBookingSlots);
		
		if tmpTerminal.roadProcessIs1StopVBS and tmpTerminal.is1STOPVBSConfigured then
			
			foreach ti in visit.allReceivedTrackedItems where ti.requires1StopVehicleBooking do
				needsBooking := needsBooking + 1;
			endforeach;
			
			foreach ti in visit.allReleasedTrackedItems where ti.requires1StopVehicleBooking do
				needsBooking := needsBooking + 1;
			endforeach;
			
			if visit.all1StopExtVehicleBookings.size &lt; needsBooking then
				if not app.myPassport.allErrors.includesErrorCode(Not_enough_vehicle_book_slots) then
					app.raiseCMException2(Not_enough_vehicle_book_slots, visit.all1StopExtVehicleBookings.size.String, needsBooking.String, null, null);
					return;
				endif;
			endif;
			
		endif;
	endif;
	
	if _passport.noErrors() then
		// Issue notifications for received containers
		tmpEvent := tmpTerminal.getTerminalEvent(TIEvent_Terminal_Receival);
		foreach item in pIntFaceArray do
			if item.isKindOf(CMIF_Receival) then
				item.CMIF_Receival.myPersistentTrackedItem.causeEvent(tmpEvent, false, null);
			endif;
		endforeach;
	endif;

	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;
	
epilog
	//epr par 18205 17/10/08
	if job &lt;&gt; null and  not invalidJob then
		job.causeTerminalEvent(job.Event_Mode_Create);
	endif;
	
	app.writeLog(method.name &amp; '  complete (' &amp; (app.clock - st).String &amp; ')', LogINFO);
	
	if receivalsToAutoplan &lt;&gt; null then
		delete receivalsToAutoplan;
	endif;
	if receivalsToTwinAutoplan &lt;&gt; null then
		delete receivalsToTwinAutoplan;
	endif;
end;</source>
        <Parameter name="pIntFaceCommon" type="CMIF_InOutCommon" usage="input"/>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_allBookingSlots" type="CMIF_1StopBookingDataArray"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInOutAutoplanReceival" id="eb164905-a7b3-4409-94d7-362d60d28fb0">
        <source>utlCreateInOutAutoplanReceival(	_receivalsToTwinAutoplan,
								_receivalsToAutoplan   : ObjectArray io;
								_job : CM_RoadJob;
								_passport : CM_Passport input	);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2009	cnwer1	Initial creation
16 June 	2009    cnwer1  PAR 19912 - make sure receivals are always planned and queued first
*/

vars
	obj 		: Object;
	twinCount 	: Integer;
	theTI,
	twinTI 		: CM_TrackedItem;
	tiReceival,  
	twinReceival : CMIF_Receival;
begin

	self.initialiseActivity();
	// if there are less than 2 can't twin lift it
	//epr par receivals have to be planned first so can't copy need to insert at the beginning
	if _receivalsToTwinAutoplan.size = 1 then
		_receivalsToAutoplan.insert(1,_receivalsToTwinAutoplan.first);
		_receivalsToTwinAutoplan.clear;
	endif;
	//have to set this to log auto plan failures
	app.autoPlanAlertOverride(_passport.myTerminal);
	//reversed collection because we want to plan from containers on rear of truck
	foreach obj in _receivalsToTwinAutoplan reversed do
		if _receivalsToTwinAutoplan.size - twinCount &lt; 2 and theTI = null then
			_receivalsToAutoplan.add(obj);
			break;
		endif;
		if theTI = null then
			tiReceival:= obj.CMIF_Receival;
			theTI := tiReceival.myPersistentTrackedItem;
		else
			twinReceival:=obj.CMIF_Receival;
			twinTI:=twinReceival.myPersistentTrackedItem;
			//try to autoplan now we have 
		//	write "autoplanning twin containers " &amp; twinTI.id &amp; " " &amp; theTI.id;
			app.myUtilityUA.utlUpdateAutoplanTwin(twinTI,
												  theTI,
												  _job,
												  _job,
												  null,
												  null,
												  QUEUE_MODE,
												  app.myPassport);
			
			if _passport.hasErrors() then
				return;
			endif;
			if (twinTI.myPrimaryQueuedLocation = null or  theTI.myPrimaryQueuedLocation = null) then			
			//epr par receivals have to be planned first so can't copy need to insert at the beginning
				_receivalsToAutoplan.insert(1,twinReceival);
				_receivalsToAutoplan.insert(1,tiReceival);
			endif;
			theTI:=null;
			twinTI:=null;
		endif;
		twinCount:=	twinCount +1;
	endforeach;
	
	foreach obj in _receivalsToAutoplan do
		//write "single plan container " &amp; obj.CMIF_TIObject.getMyTI.id;
		//epr par 19912 not just receivals now do all
		obj.CMIF_TIObject.actionForAutoPlan(_job,_passport);
		if _passport.hasErrors() then
			return;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_receivalsToTwinAutoplan" type="ObjectArray" usage="io"/>
        <Parameter name="_receivalsToAutoplan" type="ObjectArray" usage="io"/>
        <Parameter name="_job" type="CM_RoadJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInOutBGAutoComplete" id="24cc56c5-ea7a-4cd9-ba4c-99e64d04af82">
        <source>utlCreateInOutBGAutoComplete(_job : CM_RoadJob;_passport : CM_Passport input);
/*

Purpose:			Refactored - extracted below code block from trxCreateInOut method

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2009	cnwer1	Initial creation

*/

vars
	bgpRequest			: BGP_GateInOutRequest;
	tmpEvent			: Integer;
	bol					: CM_BOL;
begin

	self.initialiseActivity();
	
	if _job.jobType = BOLType_Log then
		//tmpEvent := _passport.myTerminal.getTerminalEvent(BOLRecon_Create_Event); //- cnwmd1, Par 25446
		tmpEvent := _passport.myTerminal.getTerminalEvent(BOLRecon_Update_Event);//+ cnwmd1 Par 25446
		
		foreach bol in _job.allBOLs do
			_passport.myTerminal.causeEvent(tmpEvent, false, bol);
		endforeach;
	endif;
			
	create bgpRequest persistent;
	bgpRequest.initGateInOut(_job, _passport.userCode);
	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;
epilog

end;</source>
        <Parameter name="_job" type="CM_RoadJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInOutFlexiGateEntity" id="e4d92ee5-fb1a-4cf6-acc4-3a3f0f41917d">
        <updating/>
        <source>utlCreateInOutFlexiGateEntity(_vvr : CM_VehicleVisitRecord input; _pxyGTE : CMGTE_Entity input; _gte : CMGTE_Entity output; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2008 by cnwab1
//
// Purpose:     For new flexi gate
//
// Parameters:  None
//
// Returns:     Nothing
//
/* Changes

Date		Name	TFS#		Description
============================================================================
23 Jul 2018	jlgrs1	TFS 39696	fix Generator leakage when gateing trailer 
								with underslung generator.
31 Jan 2019	jlgka1	41708		Add a method call to validate ReserveTI fields.
08 Nov 2023 navlc30 Bug 61124:  EUP Testing | 1090 error when selecting staged items in Road Gate
19/6/2025   jlier1  MTN-34221   refactoring validation so is before trx - also removed validation only because that is never set or used and shouldn't do that in trx state
============================================================================*/
vars
	realGate, 
	pxySub, 
	realSub 		: CMGTE_Entity;
	tranNum 		: String;
begin
		
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	if _vvr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Vehicle Visit Record is null');
		return;
	endif;
	if _vvr.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Vehicle Visit Record is transient');
		return;
	endif;


	if _pxyGTE.isKindOf(CMGTE_Release) then										//08.11.2023 navlc30 #61124
		if _pxyGTE.CMGTE_Release.myVehicleVisitRecord = null then
			_pxyGTE.CMGTE_Release.setMyVehicleVisit(_vvr);
		endif;
	endif;
	
		
	// ### UPDATE
	// although creating a new container, may already have the chassis
	realGate := _pxyGTE.pxyGetRealObject(); 
	if realGate = null then
		create realGate as _pxyGTE.class persistent;
	endif;
	realGate.setForCreate(_pxyGTE, _vvr);
	tranNum := _vvr.getNextTranNumForFlexiGate(); 
	realGate.setTranNumber(tranNum);
	realGate.setForUpdateErrorsFromPassport(_vvr, _passport);
		

	// Does not look like here as if we are deleting sub-items
	// probably need to copy real to a deleteCollection, and as update remove from the delete collection,
	// - then purge delete collection at end if it has entries

	foreach pxySub in _pxyGTE.allChildren discreteLock do
		/*// ### DEFAULT FROM PARENT
		pxySub.defaultDetailsFromParentItem(_pxyGTE);
		
		// ### VALIDATE 
		app.setContinueCMExceptions(true);
	
		pxySub.validateForCreate(_passport, pxyTI);
		delete pxyTI;
		*/
			
		// ### UPDATE
		
		realSub := pxySub.pxyGetRealObject(); 
		if realSub = null then
			create realSub as pxySub.class persistent;
			realSub.setForCreateIfSubItem(pxySub, realGate, tranNum);
		else
			realSub.setForUpdate(pxySub, null);
		endif;			
		
		realSub.setForUpdateErrorsFromPassport(_vvr, _passport);
			
		
			
		// This is a real hack!  If need to do this then find a better way! - Richard Smith
		//realSub.setMyVehicleVisit(null); // dettach. need to do this as realSubs errors need to go on VVRec, but do not want sub items on VVRec.
	endforeach;
	
	_gte := realGate;
	_vvr.updateJobQueueOrder(null,null);
	_vvr.causeEvent(_vvr.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, _vvr);
	
epilog
	
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pxyGTE" type="CMGTE_Entity" usage="input"/>
        <Parameter name="_gte" type="CMGTE_Entity" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInOutFlexiJob" id="86ba6be3-f21d-4a20-b82f-d2034ead2858">
        <updating/>
        <source>utlCreateInOutFlexiJob(_vvRec : CM_VehicleVisitRecord input; _passport : CM_Passport input; pxyTIs : CM_ObjectByStringDict) updating;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by cnwab1
//
// Purpose:     For new flexi gate
//
// Parameters:  None
//
// Returns:     Nothing
// Precondition	Vehicle moved to gate-lane when visit record created
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//  14/09/2009	cnwcs5		ccms1061 - removed code to find location based on VTA
//  15/09/2009	cnwcs5		ccms1061 - added code to create a complete a-gate transaction
//	11/11/2009	cnwcs5		par 21327 - fix for par 21316 has caused VVRD records to be created in worng order
//							the yard VVRD is being created B4 the complete a-gate
//  19 May 2010	cnwkpd1		PAR #20728 - remove isValidObject calls for performance
//  27 MAY 2010	CNWCS5		PAR24292 - shift code to move vehicle.  vehicle must be moved after 
//							we know where cargo is queued to
// 10 Jul 2025	navhl20 	Bug MTN-35305: MTN - Optimize Saving Road Jobs to Avoid Redundant Yard Allocation Checks
// ---------------------------------------------------------------------------

vars
	vehicle 	: CM_Vehicle;
	location 	: CM_YardController;
	gteEntity 	: CMGTE_Entity;
	job 		: CM_RoadJob;//autocompletecnwas3
	pxyTI,ti		: CM_TrackedItem;
	invalid 	: Boolean;
	lc 			: CM_TILCController;
	wle 		: CM_WorkListEntry;
	autoComplete : Boolean;
	actualLocn	: CM_LocationsController;
begin
	self.initialiseActivity();
	// 22/02/2010	cnwjre1	added from CCMS 1101 testing
	app.initialiseForStartAutoPlan(_passport);
	
	_vvRec.createRoadJob(_passport);


	vehicle := _vvRec.vehicle;
	
	// cnwjk3 PAR 21316 27/10/09 
	// Move the vehicle before CMGTE_Entity::actionForCreate(), so that the queue associated with the gate is picked up
	// Move the truck to the next gate location or into the yard
/*// par 24292	*///location := _vvRec.myGateIn.getNextLocation_IN(vehicle);
/*// par 24292*/	//app.myUtilityUA.utlMoveVehicle(vehicle, location, _passport);

	if  _passport.hasErrors then
		return;
	endif;

	// ##################
	// ### CREATE REQUEST FOR EACH ITEM AND ADD TO JOB
	// ##################

	if _vvRec.myInCMGTE_Chassis &lt;&gt; null  then
		if pxyTIs &lt;&gt; null then
			pxyTI := pxyTIs[_vvRec.myInCMGTE_Chassis.id].CM_TrackedItem;
		else
			pxyTI := null;
		endif;
		if not _vvRec.myInCMGTE_Chassis.actionForCreate(_vvRec, _passport, pxyTI) then
			return;
		endif;
	endif;

	//epr 21011 7/10/09
	/* this is important if the container is already on the chassis and both are being released then you must
		update the container first.  If you don't the chassis updates the edition of the container and when you
		try to update the container the proxy manager complains that the edition does not match the expected edition		
	*/
	if _vvRec.myOutCMGTE_Chassis &lt;&gt; null then	   
		if pxyTIs &lt;&gt; null then
			pxyTI := pxyTIs[_vvRec.myOutCMGTE_Chassis.id].CM_TrackedItem;
		else
			pxyTI := null;
		endif;
		
		//if pxyTI &lt;&gt; null and pxyTI.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD then
		
		//else
		   if not _vvRec.myOutCMGTE_Chassis.actionForCreate(_vvRec, _passport, pxyTI) then
				return;
			endif;
			
			//update the object edition in the proxy manager when chassis is updated the edition of the tis on it also update
			if _vvRec.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem &lt;&gt; null then
				foreach lc in _vvRec.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem.CM_TILC.allLCs do
					foreach ti in lc.allTrackedItems do 
						if app.myProxyManager.allReals[ti] &lt;&gt; null then
							app.myProxyManager.allReals[ti].originalRealEdition:=ti.edition;
						endif;
					endforeach;
				endforeach;
			endif;
		//endif;
	endif; 

	
	foreach gteEntity in _vvRec.allGateEntities discreteLock do // this should only be the 'parent' not the children or generators etc
	
		if gteEntity = _vvRec.myInCMGTE_Chassis or
		   gteEntity = _vvRec.myOutCMGTE_Chassis then
			continue;		// these are handled above
		endif;
	
		pxyTI := null;
		//can release 2 diferent break bulk with same id it which case get the pxy directly of obj rather than dict keyd by id 
		if gteEntity.isKindOf(CMGTE_Release) then
			//if gteEntity.CMGTE_Release.imexStatus =   TI_IMEX_STATUS_REMAINONBOARD then
				//continue;
			//endif;
			if gteEntity.CMGTE_Release.myTrackedItem &lt;&gt; null then
				pxyTI:=gteEntity.CMGTE_Release.myTrackedItem.pxyGetProxyObject();
			endif;
		endif;
		
		if pxyTIs &lt;&gt; null and pxyTI = null then
		//	pxyTI := pxyTIs[gteEntity.id].CM_TrackedItem;
			pxyTI := pxyTIs[gteEntity.getStringDictKey].CM_TrackedItem;	//30 Nov 2016	TFS 2999
		endif;
			
		if not gteEntity.actionForCreate(_vvRec, _passport, pxyTI) then
			return;
		endif;

	endforeach;
	
	
	job := _vvRec.myRoadJob;
	//epr par 32572 26/9/13 - if there is a release chassis need to validate and give an error if there is cargo on the chassis and that cargo has not been specified to be released
//	job.validateReleaseTrailerCargo; 
	
	_vvRec.validateReleaseTrailerCargo();	//05 Oct 2020	NDL	TFS 49189
	
	if _passport.hasErrors then
		return;
	endif;
	
// par 24292 - we can't move the vehicle till after the queuing has happened
//				- we need to know where is the cargo is queued to so we can set the interchange area	
	
	if _vvRec.myTerminal.roadProcessIsASPA then	//05 Oct 2020	NDL	TFS 49189
	else
		location := _vvRec.myGateIn.getNextLocation_IN(vehicle);
		app.myUtilityUA.utlMoveVehicle(vehicle, location, _passport);
	endif;
	
// par 24292
	
	if _passport.noErrors() then // PAR 17703
	
		on Exception do app.handleDeletedObject(exception, job, invalid);
		
		if _vvRec.myTerminal.roadProcessIsASPA then	//05 Oct 2020	NDL	TFS 49189
			//these guys don't use jobs or wles
		else
			 // ### TFS 51853 27AUG2021 NAVAB1
			if _passport.isOpsViewEnabled(job.myTerminal) then
			
				_vvRec.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_VVR, _vvRec);		 // ### TFS 51853 02DEC2021 NAVAB1
			
				job.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB, job);		
				foreach wle in job.workListEntries discreteLock do 
						if wle.status &lt;&gt; WLE_UNACTIONED then
							continue;
						endif;
						wle.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE, wle);	
						
						ti := wle.myTrackedItem; // ### TFS 52925 21FEB2022 NAVAB1
						if ti &lt;&gt; null then // ### TFS 52925 21FEB2022 NAVAB1
							actualLocn := ti.myPrimaryActualLocation;																				//10.07.2025 navhl20 #35305
							if actualLocn &lt;&gt; null // ### TFS 52925 21FEB2022 NAVAB1
							and actualLocn.isVehicle() then // ### TFS 52925 21FEB2022 NAVAB1
								ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, ti);	 // ### TFS 52925 21FEB2022 NAVAB1
							endif;
						endif;
						
				endforeach;
			endif;

			if job.autoComplete then
			 //  job.checkAllToDoTaskComplete then //jlier1 MTN-34117 18/3/25 - deadlocks - road jobs can't have CM_WOToDoWLE kind of wles so just ineffiecient to check
				app.myUtilityUA.utlUpdateJobDoMove(job, REAL_MODE, _passport);
			else
				//navra1 - 25th Jan 2024 - TFS 62081 - start
				foreach ti in job.allReceiveTrackedItems do
					if job.status &lt;&gt; JOB_COMPLETE then			//navra1 - BUG 62962 - 18th March 2024
						if job.canBeAutoCompleted(ti, null,false) then
							actualLocn := ti.myPrimaryPlannedLocation;																					//10.07.2025 navhl20 #35305
							if actualLocn = null then
								ti.autoPlan(PLANNING_MODE, job, null, null, _passport);
							endif;
							if actualLocn &lt;&gt; null then
								ti.moveToLocation(actualLocn, job, null, null, QUEUE_MODE, false, true, false, false, false, false, null, null, null, app.cnGetServerTime(), _vvRec, _passport);
							endif;
						endif;
					endif;										//navra1 - BUG 62962 - 18th March 2024
				endforeach;
				//navra1 - 25th Jan 2024 - TFS 62081 - end
			
				//Queue WLEs to correct queue;
				if job.hasCargoToQueue(null, true) then 
					job.enqueueJob();
				endif;
				if _passport.hasErrorsIgnored() then // PAR 17703
	//			if _passport.hasErrors() then
					return;
				endif;
				job.rebuildStatus();
			// ### JIRA 34198 03APR 2025 NAVAB1	this call to job.setJobPlannedLocation(() meant the road job called the first ware house code twice. 23230 was to fix unit test. The UTs pass with this commented out.
			// ### JIRA 34198 03APR 2025 NAVAB1			job.setJobPlannedLocation(true); // ### JIRA 23230 07OCT2024 NAVAB1.
			endif;
//		if global.isValidObject(job) then
			// Issue notification as not done in rebuildStatus
			job.causeTerminalEvent(job.Event_Mode_Create);
//		endif;
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pxyTIs" type="CM_ObjectByStringDict"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInOutReconBol" id="8756de47-4c0e-46ad-a497-51c0cc406d01">
        <source>utlCreateInOutReconBol(	_intFaceCommon :CMIF_InOutCommon; 
						_intFaceArray : CMIF_TIObjectArray; 
						_job : CM_RoadJob; _passport : CM_Passport input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2009	cnwer1	Initial creation
02/02/2017 cnwrh7		TFS	3241	PAR38583 C3 - Reconciling Log Dockets and Tickets
*/

vars
	tmpEvent 			: Integer;
	bol							: CM_BOL;
	cmifObj				: CMIF_TIObject;
	rtnValue				: Boolean;  
	isAutoMatch		: Boolean;								//+TFS3241 
begin
	self.initialiseActivity();
	//Attempt scaling data match
	if _job.jobType &lt;&gt; BOLType_Log then
		return false;
	endif;
	
	if _job.isRelease then
		return false;
	endif;
	
	rtnValue:=false;
	//tmpEvent := _passport.myTerminal.getTerminalEvent(BOLRecon_Create_Event); //- cnwmd1, Par 25446
	tmpEvent := _passport.myTerminal.getTerminalEvent(BOLRecon_Update_Event); //+ cnwmd1 Par 25446
	
	//foreach bol in _job.allBOLs discreteLock do
	//25450 13/09/2010 - change to only look at BOL's that are being brought on the current visit 
	foreach cmifObj in _intFaceArray discreteLock do	
	
		if not cmifObj.isKindOf(CMIF_BOL) then //25450 13/09/2010
			continue;
		endif;
		if cmifObj.CMIF_BOL.myPersistentBOL = null then	//25450 13/09/2010
			continue;
		endif;
		
		bol := cmifObj.CMIF_BOL.myPersistentBOL;	//25450 13/09/2010
		
		isAutoMatch := app.myPassport.myTerminal.getConfig(LogDocketAutoMatch).Boolean;					//+TFS3241 Check the "Autho Match"parameter in Log Specific Tab in Terminal Config
		if isAutoMatch then
			if _intFaceCommon.isAttemptMatch then
				rtnValue := bol.attemptMatch(_passport);
			else
				rtnValue := false;
			endif;
		endif;
		
		if (not rtnValue) then
			// we did not find matching scaling details
			if _job.autoComplete then
				if _job.isRelease then
					//Still to do
				else
					 //Its a receipt so create unscaled logs
					app.myUtilityCA.utlCreateUnscaledLogs(bol, _passport);
				endif;
			endif;
			
			if _passport.noErrors then
				_passport.myTerminal.causeEvent(tmpEvent, false, bol);
			endif;
		else // We have a match, now move it to the yard location
			// DVB changed 19/10/04 to only process currently matched bol.
			// This is so we don't created unscaled logs during Job move.
			//	bol.myExtension.CM_BOLExtLogIn.completeRoadInProcess(_passport);
			bol.myExtension.CM_BOLExtLogIn.completeRoadInProcessForBOL(_passport);
		endif;
	endforeach;

	return rtnValue;
epilog

end;</source>
        <Parameter name="_intFaceCommon" type="CMIF_InOutCommon"/>
        <Parameter name="_intFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_job" type="CM_RoadJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
