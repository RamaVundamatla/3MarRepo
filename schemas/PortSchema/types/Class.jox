    <JadeMethod name="allPropertiesInFullTreeUpTo" id="f9cdf296-c67f-4f85-a893-a5d9b1391aae">
        <source>allPropertiesInFullTreeUpTo(cls: Class; props: PropertySet input);

vars
	allprops:      PropertyColl;
begin
	allprops := self.allPropertiesUpTo(cls);
	allprops.copy(props);
	getPropertiesInSubclasses(props);

epilog
