    <JadeMethod name="getSatViewHeading" id="0c505cc1-153a-4521-88aa-e024c545c513">
        <source>getSatViewHeading( taViewPos : CM_TerminalAreaViewPosition ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 August 2011	cnwndl1	Initial creation	Par 28076

*/

vars

	num : Integer;
	str : String;

begin
	
	num := self.myLocationsController.getTrackedItemCount;	//cnwrd1 31736 break bulk counting
	if taViewPos &lt;&gt; null then	
		if taViewPos.displayItemCount or taViewPos.displayFreeCount then
			if taViewPos.displayItemCount then
				str := num.String;
			endif;
			
			if taViewPos.displayFreeCount and self.maxCapacity &gt; 0 then
				if str &lt;&gt; null then
					str := str &amp; ", " &amp; ( self.maxCapacity - num ).Integer.String;
				else
					str := ( self.maxCapacity - num ).Integer.String;
				endif;
			endif;
		
		endif;	

	else	
		if self.maxCapacity &gt; 0 then
			str := num.String &amp; ", " &amp; ( self.maxCapacity - num ).Integer.String;
		else
			str := num.String;
		endif;
		
	endif;
	
	if str &lt;&gt; null then
		str := " ( " &amp; str &amp; " )";
	endif;
	
	str := self.id &amp; str;
	
	return str;
	
epilog

end;</source>
        <Parameter name="taViewPos" type="CM_TerminalAreaViewPosition"/>
        <ReturnType type="String"/>
    </JadeMethod>
