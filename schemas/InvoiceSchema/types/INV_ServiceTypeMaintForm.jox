    <JadeMethod name="initDataTable" id="c62d5078-b5e2-4462-8d75-a1253d0104bd">
        <updating/>
        <source>initDataTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2022	navkc1	Initial creation

*/

vars

begin
	
	self.setTblDataEntRows(ETDef_InvSvcTypeMaint);
	
	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_Code, false);

epilog

