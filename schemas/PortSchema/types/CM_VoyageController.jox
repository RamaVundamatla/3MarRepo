    <JadeMethod name="hasGotTIsLoadedToShip" id="6d2540b8-b8fe-4092-b8d7-e51077207ca8">
        <source>hasGotTIsLoadedToShip() : Boolean;
/*
Purpose:			
Date		Who		Reason
04 December 2013	cnwab1	Initial creation
*/

vars
	ti : CM_TrackedItem;
	found : Boolean;
begin
	foreach ti in self.allTrackedItems discreteLock do

		if not ti.hasBeenLoadedToShip() then
			return true;
		endif;
	endforeach;
	
	
	return false;
epilog

end;</source>
