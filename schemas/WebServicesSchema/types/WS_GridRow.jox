<Class name="WS_GridRow" id="9eb1f740-7ad9-48ab-bfbd-569a6fa8c702">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Internal use only. No external support</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allLCs" id="796ee2bd-72aa-4ced-9db4-8422c31c32c2">
        <memberTypeInverse/>
        <type name="WS_GridLCArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="code" id="6b1dbb2d-b7cd-472b-9b5b-e0f71c198a8a">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="delete" id="e3914386-ebb8-42ea-a7ea-bfdc381e2452">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlger1	Initial creation 7521

*/

vars

begin
	self.allLCs.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="e02192a6-6b6f-4b38-99fd-a08c6197721c">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpGR : CM_GridRow;
	tmpGL : CM_GridController;
	wsGL : WS_GridLC;
begin
	inheritMethod(_object);

	tmpGR := _object.CM_GridRow;
	self.code := tmpGR.label;
	
	foreach tmpGL in tmpGR.allControllersByColumn discreteLock do
		create wsGL transient;
		wsGL.setProxyFromObject(tmpGL);
		self.allLCs.add(wsGL);
	endforeach;
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
