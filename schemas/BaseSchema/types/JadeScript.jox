    <JadeMethod name="cnwdad1_ListCategoryConstants" id="9ea76f9f-5d41-4db5-ac50-02b360f961da">
        <source>cnwdad1_ListCategoryConstants(pCategoryName:String);
// --------------------------------------------------------------------------------
// Created:		16 July 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allConstants	: ConstantNDict;
	constantObj		: Constant;

begin
	global.cnEcGetConstants(pCategoryName, allConstants);

	if allConstants &lt;&gt; null and (allConstants.cnEcIsNotEmpty()) then
		foreach constantObj in allConstants do
			write '"' &amp; pCategoryName &amp; '","' &amp; constantObj.name &amp; '","' &amp; constantObj.getSource() &amp; '"';
		endforeach;
	endif;
end;</source>
        <Parameter name="pCategoryName" type="String"/>
