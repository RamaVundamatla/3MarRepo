    <JadeMethod name="doRemoveCode" id="bf410181-9dbc-44e7-b2bc-b98c7da4d8c0">
        <source>doRemoveCode();
// ---------------------------------------------------------------------------
// Created:     04 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	prodCode			: CM_ProductAttributeCode;
	row					: Integer;
	prodAttr			: CM_ProductAttr;
begin
	row := self.tblCodeData.row;
	prodCode := self.tblCodeData.accessRow(row).itemObject.CM_ProductAttributeCode;
	
	if prodCode = null then
		app.msgBox(app.getErrorString(Select_cargoSub_attr_to_remove), app.getErrorString(Nothing_Selected), 0);
		return;
	endif;
	
	prodAttr := self.myCurrentProdAttr;
	if self.myCurrentProdAttr.myCode = prodCode then
		self.myCurrentProdAttr.setMyCode(null);
	endif;
	
	prodAttr.allCodes.remove(prodCode);
	self.tblCodeData.removeItem(row);
	delete prodCode;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="1641a207-618d-4621-b925-017ed3a6c02d">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     22 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	
	self.tblCodeData.width	:= self.tblEntCode.parent.width / 2;
	self.tblCodeData.height	:= self.tblCodeData.parent.height - 100;
	
	self.tblThumb.repositionAfterResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="15e2c906-256f-42d4-9dd8-9061f7830c9b">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

	pxyProduct			: CM_Product;				
	result : Integer;
begin
	
	pxyProduct	:=	self.myProxyObject.CM_Product;
	
	if not self.setProxyProductData(pxyProduct) then
		return false;
	endif;

	/*
	epr par 34310 can't edit in the table anymore so this is redundant
	if not self.setProxyAttributes(pxyProduct) then
		return false;
	endif;
*/

	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateProduct(pxyProduct, self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateProduct(pxyProduct, app.myPassport);
		else
			return false;
		endif;
	
		if not app.myPassport.trxCompletedOK then
			result:=app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			return false;
		else
			return true;
		endif;
	endwhile;
	
epilog
	if app.myPassport.trxCompletedOK then
		self.isCodesEdited	:=	false;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowContextMenuTblAttributes" id="2ee0e8b3-0733-41a3-8e41-3736300c508d">
        <updating/>
        <source>doShowContextMenuTblAttributes(_menu : MenuItem; _tbl: Table input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer) : Boolean updating;
/* ---------------------------------------------------------------------------
Created:	16 July 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	x1 : Real;
	y1 : Real;

begin
	
	if not (self.mode = self.Mode_Add or self.mode = self.Mode_Update) then
		return false;
	endif;
	
	//self.mnuEditAttrtHdr.userObject := _tbl;
	x1 := _x;
	y1 := _y;
	if (not _mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if _tbl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := _tbl.positionTop();
	    endif;
	endif;

	_conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form

	self.popupMenu(_menu, x1.Integer, y1.Integer);

	return false;
	
end;</source>
        <Parameter name="_menu" type="MenuItem"/>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblAttributeContext" id="8ca98593-0ac7-4446-909e-b3d9ddbeefd5">
        <updating/>
        <source>doTblAttributeContext(conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_Object;
	visibleBeforeSep : Boolean;
	visibleAfterSep : Boolean;
	table 	: CM_DataTable;
	str		: String;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	if self.mode = self.Mode_Update or self.mode = self.Mode_Add then 

		table := self.tblAttributes;
		if table.getCellText(table.row, table.getColumnByRowName(ETRow_ValidationType)) &lt;&gt; CM_ProductAttr.ValidationType_Codes then
			return false;
		endif;
	
		str := table.accessCell(table.row, table.getColumnByRowName(ETRow_DisplayName)).text;
		self.mnuEditCodes.caption := '&amp;Edit codes for ' &amp; str;
		self.mnuEditCodes.visible := true;
		self.popupMenu(self.mnuContext, xLeft.Integer, yTop.Integer);

	endif;
	return false;

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
