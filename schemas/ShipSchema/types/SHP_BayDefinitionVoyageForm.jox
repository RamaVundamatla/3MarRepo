    <JadeMethod name="addToolbarControls" id="d702a9ca-133e-4733-bdac-e3bacd036885">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
	showCaptions	: Boolean;
	
begin
	
	inheritMethod();
	
	toolbar := self.frmToolbar;

	showCaptions := toolbar.showCaptions;

	toolbar.addButton(self.btnEditTV, CMUI_Toolbar.Control_Alignment_Left);				
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);	

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExchangeSum, CMUI_Toolbar.Control_Alignment_Left);	
//	toolbar.addButton(self.btnProfile, CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addButton(self.btnDirDefaults, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btn40BaySlots40, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShipGraphics, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBayCopy, CMUI_Toolbar.Control_Alignment_Left); //epr 20/7/06 par 11952 
		
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);			

	// ### BAY LAYOUT TOOLBAR

	toolbar := self.frmToolBarLayout;
	toolbar.showCaptions := showCaptions;

	toolbar.addFrame(self.frmToolbarLayBay, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenTemplate, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPen30, CMUI_Toolbar.Control_Alignment_Left);// PAR 16415 CCMS 1029
	toolbar.addButton(self.btnPen40, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPen45, CMUI_Toolbar.Control_Alignment_Left); // PAR 18682 CCMS SFW 1055
	toolbar.addButton(self.btnPen53, CMUI_Toolbar.Control_Alignment_Left);// PAR 16415 CCMS 1029
	toolbar.addButton(self.btnPenAftDoors20, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenAftDoors40, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenAftMotor20, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenAftMotor40, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenEmpty, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenPower, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenReefer, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenUnavail, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenWaterCool, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenHeavy, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenVoltage, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenCellShiftL, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenCellShiftR, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenLidCreate, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenLidDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenLidMidSt, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenLidMidEnd, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenClearSel, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;



	// ### BAY DETAILS TOOLBAR

	toolbar := self.frmToolBarBay;
	toolbar.showCaptions := showCaptions;

	if app.isSpecial() then
		toolbar.addButton(self.btnBaySeqBay, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnBaySeqBay40, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addButton(self.btnBayPrintBay, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBayTempBay, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBayRemoveBay, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBayNewBay, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBayEditBay, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBayApplyBay, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBayCancelbay, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	toolbar.zOrder(1);
	
end;</source>
