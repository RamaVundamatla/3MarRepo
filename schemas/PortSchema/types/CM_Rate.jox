    <JadeMethod name="updateCharges" id="fe2e23ce-12fd-4734-9cd1-9a3a108cf2e6">
        <source>updateCharges( debtorNode : CM_DebtorNode );
// CCMS 1264 Apr 2012 non-virtual CM_Charge rate, update it from rate entry add/change/delete here
// 05/07/2018	jlgmd1	TFS 38937 - STWO Performance changes
//22.06.2024 navrv30 	Task 64598: Jade - ReserveLock on Invoice
//23 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
//25 Feb 2025 navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
//10 Dec 2025 navhl20 	Bug MTN-35943: POL - Importing Rates from CSV takes too long
vars
	iter		: Iterator;
	status		: Integer;
	serv		: CM_Service;
	charge		: CM_Charge;
	charges 	: CM_ChargeByInvStatusSeqNumDict;
	invoices 	: CM_InvoiceSet;
	inv 		: CM_Invoice;
	invLine 	: CM_InvoiceLine;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141

	if self.service = null then
		return;
	endif;
	
	create invoices transient; // ### TFS BUG 63725 23APR2024 NAVAB1
	create charges transient;
	
	serv := self.service;
	serv.getChargesForDebtor(debtorNode, charges);
	
	iter := charges.createIterator();
	while iter.next(charge) do																		//10.12.2025 navhl20 #35943
		if canLogExtra then																			//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); 	// TFS 42084
		endif;
		charge.evaluateRate();
		
		inv := charge.getInvoice();
		if invoices.tryAddIfNotNull(inv) then  														// ### TFS BUG 63725 23APR2024 NAVAB1
			reserveLock(inv);              															//22.06.2024 navrv30 Task 64598
		endif;
	endwhile;
	
	/*
	//10.12.2025 navhl20 #35943
	iter := charges.createIterator();
	// open invoices
	charges.startKeyGeq(CM_Invoice.INVOICE_OPEN, 0, iter);
	while iter.next(charge) do
		status := iter.getCurrentKey(1).Integer;
		if status &gt; CM_Invoice.INVOICE_OPEN then
			break;
		endif;
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
		endif;
		charge.evaluateRate();
		
		inv := charge.getInvoice();
		if invoices.tryAddIfNotNull(inv) then  // ### TFS BUG 63725 23APR2024 NAVAB1
			reserveLock(inv);              //22.06.2024 navrv30 Task 64598
		endif;
	endwhile;
	
	// pending invoices
	charges.startKeyGeq(CM_Invoice.INVOICE_PENDING, 0, iter);
	while iter.next(charge) do
		status := iter.getCurrentKey(1).Integer;
		if status &gt; CM_Invoice.INVOICE_PENDING then
			break;
		endif;
		charge.evaluateRate();
		
		inv := charge.getInvoice();
		if invoices.tryAddIfNotNull(inv) then // ### TFS BUG 63725 23APR2024 NAVAB1
			reserveLock(inv);              //22.06.2024 navrv30 Task 64598
		endif;
	endwhile;
	
	// suspense invoices
	charges.startKeyGeq(CM_Invoice.INVOICE_SUSPENSE, 0, iter);
	while iter.next(charge) do
		status := iter.getCurrentKey(1).Integer;
		if status &gt; CM_Invoice.INVOICE_SUSPENSE then
			break;
		endif;
		charge.evaluateRate();
		
		inv := charge.getInvoice();
		if invoices.tryAddIfNotNull(inv) then // ### TFS BUG 63725 23APR2024 NAVAB1
			reserveLock(inv);              //22.06.2024 navrv30 Task 64598
		endif;
	endwhile;

	// pre-prending invoices
	charges.startKeyGeq(CM_Invoice.INVOICE_PREPEND, 0, iter);
	while iter.next(charge) do
		status := iter.getCurrentKey(1).Integer;
		if status &gt; CM_Invoice.INVOICE_PREPEND then
			break;
		endif;
		charge.evaluateRate();
		
		inv := charge.getInvoice();
		if invoices.tryAddIfNotNull(inv) then // ### TFS BUG 63725 23APR2024 NAVAB1
			reserveLock(inv);              //22.06.2024 navrv30 Task 64598
		endif;
	endwhile;
	
	// disputed invoices
	charges.startKeyGeq(CM_Invoice.INVOICE_DISPUTED, 0, iter);
	while iter.next(charge) do
		status := iter.getCurrentKey(1).Integer;
		if status &gt; CM_Invoice.INVOICE_DISPUTED then
			break;
		endif;
		charge.evaluateRate();
		
		inv := charge.getInvoice();
		if invoices.tryAddIfNotNull(inv) then // ### TFS BUG 63725 23APR2024 NAVAB1
			reserveLock(inv);              //22.06.2024 navrv30 Task 64598
		endif;
	endwhile;*/
	
	// ### TFS BUG 63725 23APR2024 NAVAB1
	foreach inv in invoices do
		inv.setAmountDetailsToNull();
		inv.setTaxDetailsToNull();
		foreach invLine in inv.invoiceLines discreteLock do
			invLine.setTotalAmount();
			invLine.setTaxDetails();
		endforeach;
	endforeach;
epilog
	delete invoices;

	delete iter;
	delete charges;
end;</source>
        <Parameter name="debtorNode" type="CM_DebtorNode"/>
    </JadeMethod>
</Class>
