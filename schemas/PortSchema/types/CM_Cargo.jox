    <JadeMethod name="handleMergeAttachments" id="fb4cc575-046a-41d3-abae-a7a920e7eb0f">
        <updating/>
        <source>handleMergeAttachments(_newTI: CM_TrackedItem) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2025	navsp1	Initial creation  MTN-36700  STWO - Damage Photos Not Visible for Multi-Quantity Cargo IDs After Full Discharge

*/

vars
    realAttachment,
    newAttachment,
    attachment,
	pxyAttachment : CM_Attachment;
    realObj		: CM_Object;
	expectedEdition		: Integer;
    allreadyExists : Boolean;
begin
    foreach realAttachment in self.allAttachments do
        allreadyExists := false;
        foreach attachment in _newTI.allAttachments do
            if attachment.isKindOf(CM_Photo) then
                if attachment.CM_Photo.getPhotoContent = realAttachment.CM_Photo.getPhotoContent then
                    allreadyExists := true;
                    break;
                endif;
            endif;
        endforeach;
        if not allreadyExists then            
            create newAttachment as realAttachment.class persistent;       
            newAttachment.setForCreate(realAttachment);
            realAttachment.setMyParent(_newTI);
        endif;
    endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_newTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="handleMergeCustomDocDetail" id="1335719e-928b-4048-a755-ae67bb552810">
        <updating/>
        <source>handleMergeCustomDocDetail(_mergeToCargo: CM_TrackedItem; _moveAmount : Decimal ) updating, protected;
/*
Purpose - 	
Who - NAVAB1
Date - 04SEP2023
ADO - CR 59942 TASK 59943 
*/
// ### TFS 60922 TASK 60980 30OCT2023 NAVAB1 - added moveAmount
vars

	custDocDetail : CM_CustomDocumentDetail;
	custDoc : CM_CustomDocument;
	clearedForTIQty: Integer;
begin

	if _mergeToCargo = null then
		return;
	endif;
	
	// Target TI - as we move amounts into a TI we must adjust
	foreach custDocDetail in _mergeToCargo.allCustomDocDetails do
		// ### TFS CR 60425 TASK 60828 14NOV2023 NAVAB1
		if custDocDetail.isCancelled() then
			continue;
		endif;
		
// ### TFS 60922 TASK 60980 30OCT2023 NAVAB1		custDocDetail.setAmountsFromTI();
		
		// ### TFS 60922 TASK 60980 30OCT2023 NAVAB1
		if custDocDetail.isOutward() then
			custDocDetail.handleMerge4TargetAdjustment(_mergeToCargo, _moveAmount);
		endif;
	endforeach;
	
	// Source TI
	foreach custDocDetail in self.allCustomDocDetails do
		// ### TFS CR 60425 TASK 60828 14NOV2023 NAVAB1
		if custDocDetail.isCancelled() then
			continue;
		endif;

		custDocDetail.handleMerge4SourceAdjustment(_moveAmount); // do not change the ORIGINAL amounts
		
	endforeach;
	
	if self.isZombie() then
		self.allCustomDocuments.clear();
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mergeToCargo" type="CM_TrackedItem"/>
        <Parameter name="_moveAmount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="handleMergeReserveDetail" id="8a596d14-d932-4396-9258-9d97312d6c22">
        <updating/>
        <source>handleMergeReserveDetail(	_mergeToCargo: CM_TrackedItem ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2018	jlgndl1	Initial creation	TFS 37084

*/

vars

	resDet : CM_ReserveDetail;

begin

	if _mergeToCargo = null then
		return;
	endif;
	
	foreach resDet in _mergeToCargo.allReserveDetails where resDet.isAllocationById do
		if self.isKindOf(CM_Bulk) then
			resDet.CM_ReserveTI.setWeightRequested( _mergeToCargo.totalWeight );
		else
			resDet.CM_ReserveTI.setTotalRequested( _mergeToCargo.totalQuantity.max(1) );
		endif;
	endforeach;
	
	
	 // ### TFS 51936 15SEP2021 NAVAB1 - Above sets the amount on the merged into release request. The following adjusts the release request we have come from.
	 //									The _mergeToCargo has already had its amount adjusted so use the move controller to adjust the amount on the 'from'
	foreach resDet in self.allReserveDetails where resDet.isAllocationById do

		if self.isKindOf(CM_Bulk) then
			resDet.CM_ReserveTI.setWeightRequested( self.totalWeight );
		else
			resDet.CM_ReserveTI.setTotalRequested( self.totalQuantity.max(1) );
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mergeToCargo" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="handleSplitReserveDetail" id="8bbd5f1c-bf0c-4e42-ab36-1207b0136bc8">
        <source>handleSplitReserveDetail( 	newTI : CM_TrackedItem input;
							_bulkRelease : CM_BulkRelease input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2018	jlgndl1	Initial creation	TFS 37026

*/

vars
	tmpReserveTI : CM_ReserveTI;
	tmpReserveDet : CM_ReserveDetail;
	bulkRelease : CM_BulkRelease;
begin
	//epr TFS 43404 14/2/19
//	if _bulkRelease = null then
//		return;
//	endif;
	
	//10 Sep 2019 NDL	TFS 46367
	// If a bulk release is passed in it means the move that caused teh split has a request that is related to a bulk release
	// and that is why we might want to change the weight or total requested.  However if there is no Bulk release,
	// th emove is either a receival or a simple yard move, so we should not adjust the requested amounts,
	// BUT we should keep the association with the Bulk releases of the parent cargo that we were split from.

	if _bulkRelease &lt;&gt; null and not self.allBulkReleasesAssigned.includes(_bulkRelease) then
		//10 Sep 2019 NDL	TFS 46367 - If we have a bulk release that is not ours, bail
		return;
		
	elseif _bulkRelease &lt;&gt; null and self.allBulkReleasesAssigned.includes(_bulkRelease) then
		//if we know the bulk release the ti is being moved on then only add and assign to that bulk
		//release because when it gets release out the terminal it will move the ti onto the reserve detail
		//release collection and that ti will be removed from any other reserve ti not belonging to that bulk release
		//resulting in reserve details with no assigned tis and no released tis

		self.adjustSplitReserveDetail(newTI, _bulkRelease);

		
	elseif _bulkRelease = null then
		//10 Sep 2019 NDL	TFS 46367 - keep the association with the Bulk releases of the parent cargo that we were split from.
		foreach bulkRelease in self.allBulkReleasesAssigned do
			self.adjustSplitReserveDetail(newTI, bulkRelease);

		endforeach;
		
	endif;
		


epilog

end;</source>
        <Parameter name="newTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isDifferentForBayPlanMerge" id="a84ee45f-784e-4cb6-bfae-43855a4c2446">
        <source>isDifferentForBayPlanMerge(_toTI : CM_Cargo): Boolean;
//----------------------------------------------------------------
//	Created:	14 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.getMyTotalVolume &lt;&gt; _toTI.getMyTotalVolume then
		return true;
	else
		return inheritMethod(_toTI);
	endif;
	
end;</source>
        <Parameter name="_toTI" type="CM_Cargo"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
