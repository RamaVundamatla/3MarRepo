    <JadeMethod name="addItemObjectToTable" id="e0f3ffad-7eee-498f-ad1a-0010546aa459">
        <source>addItemObjectToTable(_obj : CM_Object io; _table : CM_DataTable input);
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	rowIdx,
	backColour : Integer;
	str : String;
begin
	
	if _obj = null 
	or _table = null then
		return;
	endif;	
	
	on Exception do self.handleExceptionObject(exception, _obj);
	_obj.fetchLatest();
	if _obj = null then
		return;
	endif;	

	str := _obj.getAttributeStringForDefArray(_table.allTblDataEntRows);
	rowIdx := _table.addItemObject(_obj, str);

	if rowIdx mod 2 = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;
	_table.accessedRow.backColor := backColour;
	
	self.addNotableObject(_obj);
	
end;</source>
        <Parameter name="_obj" type="CM_Object" usage="io"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addNotableObject" id="d16b27cc-c88e-4ae9-a4af-348738531549">
        <source>addNotableObject(_obj : CM_Object);
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars
begin
	if _obj = null then
		return;
	endif;
	
	if (not global.isValidObject(_obj)) then
		return;
	endif;
	
	if self.allNotableObjects.includes(_obj) then
		return;
	endif;
	
	self.allNotableObjects.add(_obj);
	if CM_Voyage.hasInstance(_obj) then
		self.beginNotification(_obj, VoyageBOLIn_Create_Event, Response_Continuous, null);
	else
		beginNotification(_obj, Object_Update_Event, Response_Continuous, null);
		beginNotification(_obj, Object_Delete_Event, Response_Continuous, null);
	endif;

	if CM_BOL.hasInstance(_obj) then
		self.beginNotification(_obj, self.myTerminal.getTerminalEvent(BOL_Update_Event), Response_Continuous, 0);
	endif;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="addReleaseToTable" id="3ceb0f08-a247-4a6f-96d1-963b9be3d48c">
        <updating/>
        <source>addReleaseToTable(_release : CM_BulkRelease) updating;
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpStr : String;
	rowIdx : Integer;
	tmpTable : CM_DataTable;
begin

	tmpTable := self.tblReleases;
		
	if _release = null then
		return;
	endif;
	
	tmpTable.findObjectInRow(_release, rowIdx);
	if rowIdx &gt; 0 then
		// already there
		return;
	endif;

	tmpStr := _release.getAttributeStringForDefArray(tmpTable.allTblDataEntRows);
			
	rowIdx := tmpTable.rows+1;
	tmpTable.addItemAt(tmpStr, rowIdx);
	tmpTable.accessRow(rowIdx).itemObject := _release;

	self.addNotableObject(_release);	
	
	if _release.status = BR_COMPLETE then
		//Already released, disable row as cannot change once off site
		tmpTable.accessRow(rowIdx).backColor := Grey;
	endif;	
	
end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="44c7a6f8-7998-41a8-acca-f6e9d2a8e7aa">
        <updating/>
        <source>addToolbarControls() updating, protected;
//-----------------------------------------
// Created: February 2006 By: cnwgd1
//
// 22/1/2013 PJS		PAR #30787 - Voyage rationalisation
//-----------------------------------------
vars
	toolbarObj	: CMUI_Toolbar;
	
begin
	inheritMethod();
	//Left side buttons
	toolbarObj	:=	self.frmToolbar;
	toolbarObj.addButton(self.btnPrintReceipt, CMUI_Toolbar.Control_Alignment_Left);				
	toolbarObj.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnVoyageDefin, CMUI_Toolbar.Control_Alignment_Left);								
	toolbarObj.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	
	// PAR #30787 - no longer allowing access to manifest form from this fomrm.
	// feeling is that this dock release form is no longer used.. if necessary access to the button can be re-instated.
	// Note that Manifest permission has been remooved so manifest form wouldbe required to use the BOL release permissins
	
	//toolbarObj.addButton(self.btnManifest, CMUI_Toolbar.Control_Alignment_Left); // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	
	//Right side buttons.
	toolbarObj.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnNew_click" id="13cf7c47-77d7-458c-930f-9106a604ceeb">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNew_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	obj : CM_Object;
begin
	// lorcan 25/5/06 Changed so that even when clicking new - you get prepopulation of selected item
	obj := self.tblData.accessRow(self.tblData.row).itemObject.CM_Object;
	self.doAddRelease(obj);	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
