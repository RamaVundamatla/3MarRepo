    <JadeMethod name="updateOperator" id="53a93cd9-a8e0-4efa-944d-7f2ca480d4f7">
        <source>updateOperator( _operator : CM_Operator);

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
14 December 2010	cnwrd1	Initial creation
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
05/08/2011			cnwmh5	Change to use the classes version of opts
*/


vars
	pxyOperator : CM_Operator;
	tmpConfig : CMIF_ConfigOperator;
begin

	if _operator = null then		
		return;
	endif;
	
	beginLoad;
	pxyOperator := _operator.pxyCreateUpdateProxy();
	endLoad;
	
	if self.opts.includesKey('ReqOperImpPin') then
		pxyOperator.setRequiresImpOperatorPIN(self.opts.bool('ReqOperImpPin'));
	endif;
	//21 Nov 2017	NDL	TFS 7820
	if self.opts.includesKey('RequiresBookingReference') then
		pxyOperator.setPropertyValue( "requiresBookingReference", self.opts.bool('RequiresBookingReference') );
	endif;
	
	create tmpConfig transient;
	tmpConfig.setFromPersistentData(_operator);
	
	app.myTrxUA.trxUpdateOperator(pxyOperator, tmpConfig, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyOperator;
	delete tmpConfig;
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="updateOperatorFreeStorageDays" id="76a910cb-19a0-4410-befc-2bb4e0bfac10">
        <source>updateOperatorFreeStorageDays(_oper : CM_Operator; _emptyFSD : Integer; _fullFSD : Integer);
// update the free storage days for the unit test terminal and entered operator
vars
	opTerm	: CM_OperatorTerminal;
begin
	
	beginTransaction;
	opTerm := _oper.getOperatorTerminal(self.getTerminal, true);
	opTerm.setPropertyValue("emptyFreeStorageDays", _emptyFSD);
	opTerm.setPropertyValue("fullFreeStorageDays", _fullFSD);
	commitTransaction;
end;
</source>
        <Parameter name="_oper" type="CM_Operator"/>
        <Parameter name="_emptyFSD" type="Integer"/>
        <Parameter name="_fullFSD" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateOperatorGroup" id="b2e5715a-e546-4e4a-bec6-b380e04d451f">
        <source>updateOperatorGroup(_operatorGroup : CM_OperatorGroup; _description : String);

/*

Purpose:		Update Operator Group

Date			Who		Reason
06/03/014		cnwmh5	Initial creation

*/

vars

	pxyOperatorGroup				: CM_OperatorGroup;

	loadState						: Boolean;
	description						: String;
	
begin

	app.cmsBeginLoad(loadState);
	pxyOperatorGroup := _operatorGroup.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	if _description &lt;&gt; null then
		description := _description;
	endif;
	
	pxyOperatorGroup.setProxy(_operatorGroup.code, description, _operatorGroup.allCodeGroups, _operatorGroup.isAvailableForEntry);
	
	if self.opts.includesKey("Operators") then
		self.opts.obj("Operators").CM_OperatorByCodeDict.copy(pxyOperatorGroup.allOperators);
	endif;
	
	app.myTrxUA.trxUpdateOperatorGroup(pxyOperatorGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	
	app.cmsEndLoad(loadState);
	
	delete pxyOperatorGroup;
	
end;</source>
        <Parameter name="_operatorGroup" type="CM_OperatorGroup"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateOrganisation" id="b03d2067-7170-4fb6-ac3c-4e953ceee975">
        <source>updateOrganisation(_organisation : Any io);

/*

