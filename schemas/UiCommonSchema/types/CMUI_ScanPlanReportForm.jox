	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.optColDPort.name );
	self.optColDPort.value := (xmlText = "true").Boolean;
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.optColOp.name );
	self.optColOp.value := (xmlText = "true").Boolean;
