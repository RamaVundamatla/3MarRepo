    <JadeMethod name="setCaption" id="cbf301df-6ae3-4ad8-9787-40915a9866c0">
        <updating/>
        <source>setCaption(_caption: String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2016	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	self.caption := _caption &amp; " - " &amp; self.getVoyageCode &amp; " " &amp; self.getModeString() ;
