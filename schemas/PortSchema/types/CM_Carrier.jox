    <JadeMethod name="pxyCreateUpdateProxy" id="3fcd1911-2038-49ea-b586-aec61642586a">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------------------------
//	Created:	02 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
//29/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue -
vars
	pxyCarrier		: CM_Carrier;
	completedOK		: Boolean;
begin
	
	pxyCarrier := inheritMethod();
	self.allPINNotifyEmailAddresses.copy(pxyCarrier.allPINNotifyEmailAddresses);
	pxyCarrier.setDebtor(self.myDebtor); 			//+ cnwmd1, CCMS 1067
	self.allDataAccessControllersRec.copy(pxyCarrier.allDataAccessControllersRec);	// 12/9/17 MAP TFS2749
	self.allDataAccessControllersRel.copy(pxyCarrier.allDataAccessControllersRel);	// 12/9/17 MAP TFS2749
		
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyCarrier;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyCarrier;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
