<Class name="CM_TCPIPAgent" id="5d8bd7b8-3e94-45fb-bdb5-59aadc1bb4aa">
    <superclass name="CM_TCPIP"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="jmtxml"/>
    <Constant name="LogLevel_Full" id="f8b18a1b-09dc-4b03-85dd-ae99c7808ae6">
        <source>3</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="LogLevel_Log" id="cc4e1fe2-f294-406d-9db1-9230477dcac8">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="LogLevel_Trace" id="f1a36a50-3978-4edb-a359-4e53786d9551">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="ProcessTerminate" id="b97b70ba-91c8-4f4b-be15-833861fb11a6">
        <source>66001</source>
        <type name="Integer"/>
    </Constant>
    <ImplicitInverseRef name="myTCPConnection" id="e6d1445b-0e95-4ad4-8d58-6f499d90a6fd">
        <embedded/>
        <type name="TcpIpConnection"/>
    </ImplicitInverseRef>
    <JadeMethod name="createXmlError" id="e19d277f-c0ed-4e8b-8df2-b1def7e813a3">
        <source>createXmlError(_errNumber : Integer; _errText, _msgType, _msgId, _deviceId, _version : String) : String protected;
// -----------------------------------------------------------------------------
// Created:		14 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

	time 		: String;
	theDate		: Date;
	theTime		: Time;
	response	: String;

begin
	
	time	:= theDate.format('yyyyMMdd') &amp; theTime.format('HHmmss');

	response := self.formatAsXMLPrefix(XML_MSG) &amp;
				self.formatAsXMLPrefix(XML_HDR) &amp;
				self.formatAsXML(XML_MSGTYPE, _msgType ) &amp;
				self.formatAsXML(XML_MSGID, _msgId) &amp; 
				self.formatAsXML(XML_DEVICEID, _deviceId);

	response := response &amp; 
				self.formatAsXML(XML_ERRNO, _errNumber.String);
		
	if _errNumber &lt;&gt; 0 then
		response := response &amp;	self.formatAsXML(XML_ERRTXT, _errText);
	endif;

	response := response &amp;
				self.formatAsXML(XML_TIME, time) &amp; 
				self.formatAsXML(XML_VERSION, _version) &amp;
				self.formatAsXMLSuffix(XML_HDR) &amp;				
				self.formatAsXMLSuffix(XML_MSG);
	return response;
end;</source>
        <access>protected</access>
        <Parameter name="_errNumber" type="Integer"/>
        <Parameter name="_errText" type="String"/>
        <Parameter name="_msgType" type="String"/>
        <Parameter name="_msgId" type="String"/>
        <Parameter name="_deviceId" type="String"/>
        <Parameter name="_version" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doConnectionClose" id="044ebeeb-2262-4cdd-90ef-0b01a41c9fa7">
        <updating/>
        <source>doConnectionClose(_tcp : TcpIpConnection) updating, protected;
// -----------------------------------------------------------------------------
// Created:		07 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

	tcp : TcpIpConnection;
	
begin

	if _tcp &lt;&gt; null and global.isValidObject(_tcp) then
		self.logIt(self.LogLevel_Trace, 'Closing conection ' &amp; _tcp.remoteIpAddress);	
		_tcp.close();
		tcp := _tcp;
		beginTransientTransaction;
		delete tcp;
		commitTransientTransaction;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_tcp" type="TcpIpConnection"/>
    </JadeMethod>
    <JadeMethod name="finish" id="4ed31bd0-c32d-4aef-ab25-fea2395970f5">
        <updating/>
        <source>finish() updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	if self.myTCPConnection &lt;&gt; null then
		self.doConnectionClose(self.myTCPConnection);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="1d9102db-d6df-43ce-b7a6-bf7950884e39">
        <updating/>
        <source>init() updating;
// -----------------------------------------------------------------------------
// Created:		02 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	on Exception do self.xGeneralHandler(exception) global;

	self.initLogFile();
end;</source>
    </JadeMethod>
    <JadeMethod name="initLogFile" id="94fbd54b-1555-4478-aa0a-4c7e5b81a15d">
        <updating/>
        <source>initLogFile() updating, protected;
// -----------------------------------------------------------------------------
// Created:		06 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

	fileName	: String;
	date		: Date;
	
begin

//	app.initLogFile();	//rs may 2005 CCMS10137
	self.logIt(LogLevel_Log, app.name &amp; ' started.');
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="logIt" id="ac84549d-5a78-4a20-9341-10699847312f">
        <source>logIt(_level : Integer; _msg : String) protected; 
// -----------------------------------------------------------------------------
// Created:		06 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
		
	app.writeLog(_msg, _level);

end;</source>
        <access>protected</access>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="ba3d3331-db2c-497e-b7d9-011e44fe9d86">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	if eventType = self.ProcessTerminate and theObject = self then
		terminate;
	endif;
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xGeneralHandler" id="b1ad2fe5-a935-4289-96a2-44172a43dd77">
        <updating/>
        <source>xGeneralHandler(_exObj : Exception) : Integer updating, protected;

// cnwdvb1 13 November 2002 

vars

begin

	abortTransaction;
	abortTransientTransaction;
	self.logIt(0,  class.name&amp; ':: ERROR ' &amp; _exObj.errorCode.String &amp; ' ' &amp; _exObj.extendedErrorText);
	if self.myTCPConnection &lt;&gt; null and global.isValidObject(self.myTCPConnection) then
		self.myTCPConnection.writeBinary(self.createXmlError(_exObj.errorCode, _exObj.extendedErrorText, null, null, null, null).asANSI(0));	// 14/3/16 cnwmp6 PAR 36286 unicode version
		// Sleep gives connection enough time to write string before closing.
		process.sleep(5000);
		self.doConnectionClose(self.myTCPConnection);
	endif;
	return Ex_Abort_Action;
	
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xTcpHandler" id="0c77863c-48e9-4e04-b620-350168d0cc52">
        <updating/>
        <source>xTcpHandler(_exObj : ConnectionException) : Integer updating, protected;
// -----------------------------------------------------------------------------
// Created:		07 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	if _exObj.errorCode = 31001 then
		self.logIt(0, 'no target host name specified');
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31002 then
		self.logIt(0,'target host not found');
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31003 then
		self.logIt(0,'invalid port specification');
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31004 then
		self.logIt(0,'failed to connect');
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31005 then
		self.logIt(0,'failed to bind');
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31006 then
		self.logIt(0,'failed to listen');
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31007 then
		self.logIt(0,'failed to accept');
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31008 or _exObj.errorCode = 31009 or _exObj.errorCode = 31017 then
		self.doConnectionClose(self.myTCPConnection);
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
