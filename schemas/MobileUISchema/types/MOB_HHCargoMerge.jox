    <JadeMethod name="doMerge" id="46005ef9-320d-4978-8351-2fede2537ed4">
        <updating/>
        <source>doMerge() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation

*/

vars

	allTisToMerge : CM_TISet;
	ti : CM_TrackedItem;
	index : Integer;
	theReturn : Integer;

begin

	create allTisToMerge transient;
	foreach index in 2 to self.tblProspects.rows do
		if self.tblProspects.accessCell(index, 1).text = "1" then
			ti := self.tblProspects.accessRow(index).itemObject.CM_TrackedItem;
			if ti &lt;&gt; null then
				allTisToMerge.add(ti);
			endif;
		endif;
	endforeach;
	
	if not allTisToMerge.isEmpty then
	
		while true do 
	
			app.myTrxUA.trxMergeBreakBulk(	self.myTrackedItem.CM_Cargo,	//_targetTi : CM_BreakBulkGeneric;
											allTisToMerge,	//_allItemsToBeMerged : CM_TISet;
											app.myPassport	//_passport : CM_Passport input
											);
		
			
			if app.myPassport.trxCompletedOK then
				break;
				
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Merge_breakbulk), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
			
		endwhile;
		
		self.displayProspects();
	
	endif;
	
	
epilog

	delete allTisToMerge;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="cca1ea58-50ad-4413-86fc-0b7d28a9aaac">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.resizedMargin - stdHeight;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	cWidth := stdWidth;
	cHeight := cHeight * 2;
	if _initialSetup then
		self.lblSelectCargo.setAndIncrementTabIndex( tabIndex );
		self.lblSelectCargo.visible := true;
		self.lblSelectCargo.fontBold := true;
	endif;
	self.lblSelectCargo.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
	
	
	cTop := cTop + self.lblSelectCargo.height + self.resizedMargin;
	cHeight := stdHeight;
	cWidth := stdWidth - self.resizedMargin - stdHeight;
	if _initialSetup then
		self.txtFindInList.setAndIncrementTabIndex( tabIndex );
		self.txtFindInList.visible := true;
		self.txtFindInList.enabled := false;
	endif;
	self.txtFindInList.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
	if _initialSetup then
		self.txtFindInList.text := self.lblFindInList.caption.toUpper;	
	endif;
					
								
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnSelect.setAndIncrementTabIndex( tabIndex );
		self.btnSelect.visible := true;
		self.btnSelect.enabled := false;
		self.btnSelect.fontBold := true;
	endif;
	self.btnSelect.move(	self.txtFindInList.left + self.txtFindInList.width + self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
	
	cTop := cTop + self.txtFindInList.height + self.resizedMargin;
	cWidth := stdWidth;
	cHeight:= (self.clientHeight - cTop - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin);
	if _initialSetup then
		self.tblProspects.setAndIncrementTabIndex( tabIndex );
		self.tblProspects.visible := true;
	endif;
	self.tblProspects.move(	self.resizedMargin, 
							cTop, 
							stdWidth, 
							cHeight);
	
	if _initialSetup then
		self.setupTable();
	endif;
	self.tblProspects.cnAdjustColumnWidths();
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
