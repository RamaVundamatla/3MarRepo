    <JadeMethod name="doTblDataMouseDown" id="b2d4e47f-b5b0-498f-893c-c2107e971acc">
        <updating/>
        <source>doTblDataMouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(table, button, shift, x, y);

	self.origXPos := x;
	self.origYPos := y;

	if table.CM_DataTable.allSelectedObjects.size &gt; 1 then
	
		self.tblInfo.rows := 0;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
