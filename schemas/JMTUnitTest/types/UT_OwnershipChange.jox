    <JadeMethod name="tOwnershipChangeApproval" id="3f3ccc7c-7b33-4e73-bbec-4ea7356dedbf">
        <source>tOwnershipChangeApproval();
/*

Purpose:			This UT tests the full approval of COO.
					First COO has individual TIs assigned to it
					Second COO has cargo group assign to it
					
					All TIs that has "included = true" should have
						- New Operator
						- COO Transaction
						- Stops applied correctly		
					
					Cargo group should have
						- Operator collection with the new operator in it
					
					COO header should have
						- Valid COO approval date time
Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/
constants
	VESSEL				= "UT58254";
	VOYAGE				= "UT58254";
	CARGOTYPEDESC 		= "UT_ABPULP";
	CGID1				= "CG58254-1";
	CGID2				= "CG58254-2";
	STOPTABLE			= 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	cargoGroup,
	cargoGroup2		: CM_CargoGroup;
	tiToExclFromCOO,
	ti				: CM_TrackedItem;
	newOperator,
	operator		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1,
	cooHeader2		: CM_OwnershipChange;
	pxyCooDetails,
	subCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	pxyStopCriteria	: CM_StopCriteria;
	pxyStopTemp		: CM_StopTableTemplate;	
	pxyStopTable,
	realStop		: CM_StopsTable;
	tisToDelete,
	tiSet			: CM_TISet;
	
	tiId,
	opCode,
	newOpCode		: String;	
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now				: TimeStamp;	
	include			: Boolean;
	stopCheckArray,
	stopProcessArray,
	stopsSetArray	: IntegerArray;
	allOpsForStop	: ObjectSet;
	cmifAgent,
	cmifAgent2			: CMIF_COOAgent;
begin
	
	create cmifAgent transient;
	create cmifAgent2 transient;
	create tiSet transient;
	create tisToDelete transient;
	create pxyStopCriteria transient;
	create pxyStopTable transient;
	create pxyStopTemp transient;
	create stopsSetArray transient;
	create stopCheckArray transient;
	create stopProcessArray transient;
	create allOpsForStop transient;
	
	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operator := self.getOperator(opCode);
	
	newOpCode := "KCOP";
	newOperator := self.getOperator(newOpCode);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, newOperator); // ### JIRA UT 22JAN2025 NAVAB1

	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	// Stops
	allOpsForStop.add(newOperator);
	stopsSetArray.add(StopApplyImport);
	self.deleteStopsTable(STOPTABLE);
	pxyStopCriteria.setMyStopTable(pxyStopTable);
	pxyStopCriteria.createStopCriteria(allOpsForStop, YACriteriaType_OperatorItem, pxyStopCriteria);
	pxyStopTemp.setProxy(stopCheckArray, stopsSetArray, stopProcessArray, null, false, false, false, false, false, false, false, false);
	pxyStopTemp.setPropertyValue("myStopTable", pxyStopTable);
	pxyStopTemp.setPropertyValue("myTerminal", self.getMyTerminal());
	pxyStopTable.setProxy(false, STOPTABLE.String, STOPTABLE.String, STOPTABLE.String,0, STOPTABLE, null, false, true, app.myRoot, null, null, null);
	app.myTrxCA.trxCreateStopsTable(pxyStopTable, realStop, app.myPassport);
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	
	/*================================
	COO Header 1
	has 5 COO Details
	Each TI has one
	================================*/
	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO1", null, null, app.getMyUserCode(), now, null, now, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 1 is null");
	
	// Create Cargo in Cargo Group 1
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		tisToDelete.add(ti);
		
		// Exclude this from COO for testing later.
		if i = 5 then
			tiToExclFromCOO := ti;
			include := false;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;
	self.deleteCargoGroup(CGID1);
	cargoGroup 	:= self.addCargoGroup(CGID1, tiSet);
	
	/*================================
	COO Header 2
	has 1 COO details of the Cargo Group
	COO Details has 5 sub details for TI
	================================*/
	
	
	// Create Ownership change 2
	delete pxyCooHeader;
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO2", null, null, app.getMyUserCode(), now, null, now, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader2);
	self.assertTrueMsg(cooHeader2 &lt;&gt; null, "COO 2 is null");
	
	// Create Cargo in Cargo Group 2
	tiSet.clear();
	foreach i in 1 to numTiToCreate do
		tiId := "CG2-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		ti.setMyCargoGroup(cargoGroup2, app.myPassport);
		tiSet.add(ti);
		tisToDelete.add(ti);
	endforeach;
	self.deleteCargoGroup(CGID2);
	cargoGroup2	:= self.addCargoGroup(CGID2, tiSet);
	
	// Create Ownership Details for Cargo Group
	delete pxyCooDetails;
	create pxyCooDetails transient;
	pxyCooDetails.setProxy(weight, volume, quantity, true, cooHeader2, null, cargoGroup2);
	self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
	self.assertTrueMsg(cooDetails &lt;&gt; null, cargoGroup2.id &amp; " does not have COO details created");
	
	// Create Ownership SUB details for TI in Cargo Group
	foreach ti in cargoGroup2.allAssignedTrackedItems do
		
		if ti = tiToExclFromCOO then
			continue;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		pxyCooDetails.setProxy(weight, volume, quantity, true, null, cooDetails, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, subCooDetails);
		self.assertTrueMsg(subCooDetails &lt;&gt; null, ti.id &amp; " does not have COO details created");
	endforeach;
	
	// Move all cargo to Yard
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tisToDelete do
		self.deleteStops(ti);
	endforeach;
	
	// Now Approve COO 1
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 1 - ");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	// Check Cargo Group 1 has correct Operator collection
	self.assertTrueMsg(cargoGroup.allOperators.includes(newOperator), cargoGroup.id &amp; " has incorrect allOperators collection");
	// Check cargo group 1 has COO transaction
	transaction := cargoGroup.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
	self.assertTrueMsg(transaction &lt;&gt; null, cargoGroup.id &amp; " does not have Ownership Changed Transaction created");
	// Check TIs in Cargo Group 1
	foreach ti in cargoGroup.allAssignedTrackedItems do
		// This is the TI that was excluded, it shouldn't have anything changed
		if ti = tiToExclFromCOO then
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = opCode, ti.id &amp; " should not have the new operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction = null, ti.id &amp; " should not have Ownership Changed Transaction created");
			// Should not have stops
			self.assertTrueMsg(not ti.hasStopOfType(realStop), ti.id &amp; " should not have Stop set.");
		// These are included in the COO, should have new operators etc..
		else
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = newOpCode, ti.id &amp; " has incorrect new operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, ti.id &amp; " does not have Ownership Changed Transaction created");
			// Should have stops applied
			self.assertTrueMsg(ti.hasStopOfType(realStop), ti.id &amp; " should have Stop set.");
		endif;
	endforeach;
	
	
	// Now Approve COO 2
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader2, app.myPassport, cmifAgent2);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 2 - ");
	// Check COO approved status
	self.assertTrueMsg(cooHeader2.dateTimeApproved.isValid(), "cooHeader2 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader2.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	// Check Cargo Group 2
	self.assertTrueMsg(cargoGroup2.allOperators.includes(newOperator), cargoGroup2.id &amp; " has incorrect allOperators collection");
	// Check Cargo group 2 has COO transaction
	transaction := cargoGroup2.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
	self.assertTrueMsg(transaction &lt;&gt; null, cargoGroup2.id &amp; " does not have Ownership Changed Transaction created");
	// Check TIs in Cargo Group 2
	foreach ti in cargoGroup2.allAssignedTrackedItems do
		// Check Operator
		self.assertTrueMsg(ti.operatorCode = newOpCode, ti.id &amp; " has incorrect new operator code");
		// Check transaction
		transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
		self.assertTrueMsg(transaction &lt;&gt; null, ti.id &amp; " does not have Ownership Changed Transaction created");
		// Should have stops applied
		self.assertTrueMsg(ti.hasStopOfType(realStop), ti.id &amp; " should have Stop set.");
	endforeach;
	
epilog
	
	foreach ti in tisToDelete do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	self.deleteCargoGroup(CGID1);
	self.deleteCargoGroup(CGID2);
	
	if cooHeader1 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader1);
	endif;
	if cooHeader2 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader2);
	endif;
	
	delete tiSet;
	delete tisToDelete;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete pxyStopCriteria;
	delete pxyStopTemp;
	delete pxyStopTable;
	delete stopsSetArray;
	delete stopCheckArray;
	delete stopProcessArray;
	delete allOpsForStop;
	delete cmifAgent;
	delete cmifAgent2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeDetail" id="b42cb041-3314-41ac-88b0-91262fff802c">
        <source>tOwnershipChangeDetail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 June 2023 navtnr20	TFS CR 58507	Task 58211: Jade - Unit Test Ownership Change

*/

vars
	realOwnershipChangeDetail,
	pxyOwnershipChangeDetail : CM_OwnershipChangeDetail;
	transferedWeight, transferedVolume : Decimal[23,4];
	myownership : CM_OwnershipChange;
	ti	: CM_TrackedItem;
	cargoType : CM_CargoType;
	bs						: CM_BlockStack;
	transferedQuantity : Integer;
begin
	self.createOwnershipDetail(realOwnershipChangeDetail);
	self.createOwnerShip(myownership);
	
	ti := realOwnershipChangeDetail.myTrackedItem;
	self.assertNotNull(ti);
	
	transferedWeight		:= ti.totalWeight - 1;
	transferedVolume		:= ti.totalVolume - 1;
	transferedQuantity:= ti.totalQuantity - 2;
	
	//Update Ownership Change
	beginTransaction;
	pxyOwnershipChangeDetail := realOwnershipChangeDetail.pxyCreateUpdateProxy();
	commitTransaction;
	pxyOwnershipChangeDetail.setProxy(transferedWeight,transferedVolume,transferedQuantity,false,myownership,null,ti);
	self.updateOwnershipChangeDetail(pxyOwnershipChangeDetail);
	self.assertNotEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected Ownership change Detail input field errors");
	realOwnershipChangeDetail := app.myProxyManager.getRealObject(pxyOwnershipChangeDetail).CM_OwnershipChangeDetail;
	self.assertEqual(realOwnershipChangeDetail.transferredQuantity,transferedQuantity);
	self.assertEqual(realOwnershipChangeDetail.transferredWeight,transferedWeight);
	self.assertEqual(realOwnershipChangeDetail.transferredVolume,transferedVolume);
	self.assertEqual(realOwnershipChangeDetail.included,false);
	self.assertEqual(realOwnershipChangeDetail.myOwnershipChange, myownership);
	self.assertEqual(realOwnershipChangeDetail.myTrackedItem,ti);
	self.assertEqual(realOwnershipChangeDetail.myParentOwnershipChangeDetail,null);
	self.deleteOwnershipChangeDetail(realOwnershipChangeDetail);
	delete pxyOwnershipChangeDetail;
epilog
	delete pxyOwnershipChangeDetail;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeFSDebtorCheck" id="0cacc55b-e3c4-443e-946c-798ef708308b">
        <source>tOwnershipChangeFSDebtorCheck();
/*

Purpose:			This UT tests the Future storage transaction are charging the correct debtor after COO approval
					If Transaction is Future Storage
						&gt; If has COO approval
							&gt; If COO Storage operator is not null
								Use the COO Storage operator debtor
							&gt; If Incoterm is not null
								&gt; Get Incoterm debtor type to get debtor

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58261 Task 61101: Jade - Unit Tests

*/

constants
	VESSEL				= "UT58261";
	VOYAGE				= "UT58261";
	CARGOTYPEDESC 		= "UT58261";
	CGID1				= "CG58261-1A";
	CGID2				= "CG58262-2A";
	STOPTABLE			= 58261;
	TAGROUP				= "UT58261";
vars
	root			: CM_Root;
	cargoGroup,
	cargoGroup2		: CM_CargoGroup;
	tiToExclFromCOO,
	ti				: CM_TrackedItem;
	newOperator,
	operator		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1,
	cooHeader2		: CM_OwnershipChange;
	pxyCooDetails,
	subCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	pxyStopCriteria	: CM_StopCriteria;
	pxyStopTemp		: CM_StopTableTemplate;	
	pxyStopTable,
	realStop		: CM_StopsTable;
	tisToDelete,
	allTis,
	tiSet			: CM_TISet;
	terminal		: CM_Terminal;
	storageConfig	: CM_StorageConfig;
	storageDetail	: CM_StorageDetail;
	taStorageGroup	: CM_TerminalAreaStorageGroup;
	terminalAreas	: CM_TerminalAreaArray;
	invLineType		: CM_InvoiceLineDesc;
	fsm				: CM_FutureStorageMapping;
	invLineTypeArray: CM_InvoiceLineDescArray;
	futureAction 	: CM_OfflineFutureActor;
	parent			: CM_Object;
	invoiceLine		: CM_InvoiceLine;
	
	tiId,
	opCode,
	newOpCode		: String;	
	i,
	transferQty,
	quantity,
	count,
	numTiToCreate	: Integer;	
	volume,
	transferWeight,
	transferVol,
	weight			: Decimal[23,4];	
	daysAgo15,
	start,
	lastMonth,
	now				: TimeStamp;	
	include			: Boolean;
	stopCheckArray,
	stopProcessArray,
	storageDtlCriteria,
	stopsSetArray	: IntegerArray;
	allOpsForStop	: ObjectSet;
	storageDtlCritV : ObjectArray;
	cmifAgent,
	cmifAgent2		: CMIF_COOAgent;
begin
	
	create cmifAgent transient;
	create cmifAgent2 transient;
	create tiSet transient;
	create tisToDelete transient;
	create pxyStopCriteria transient;
	create pxyStopTable transient;
	create pxyStopTemp transient;
	create stopsSetArray transient;
	create stopCheckArray transient;
	create stopProcessArray transient;
	create allOpsForStop transient;
	create terminalAreas transient;
	create storageDtlCriteria transient;
	create storageDtlCritV transient;
	create invLineTypeArray transient;
	create allTis transient;
	
	daysAgo15 := now;
	daysAgo15.setDate(daysAgo15.date()-15);
	
	root := app.myRoot;
	
	//self.setTerminalConfig(CooSplitOperator, false);
	
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operator := self.getOperator(opCode);
	
	newOpCode := "KCOP";
	newOperator := self.getOperator(newOpCode);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, newOperator); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58261TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	// Stops
	allOpsForStop.add(newOperator);
	stopsSetArray.add(StopApplyImport);
	self.deleteStopsTable(STOPTABLE);
	pxyStopCriteria.setMyStopTable(pxyStopTable);
	pxyStopCriteria.createStopCriteria(allOpsForStop, YACriteriaType_OperatorItem, pxyStopCriteria);
	pxyStopTemp.setProxy(stopCheckArray, stopsSetArray, stopProcessArray, null, false, false, false, false, false, false, false, false);
	pxyStopTemp.setPropertyValue("myStopTable", pxyStopTable);
	pxyStopTemp.setPropertyValue("myTerminal", self.getMyTerminal());
	pxyStopTable.setProxy(false, STOPTABLE.String, STOPTABLE.String, STOPTABLE.String,0, STOPTABLE, null, false, true, app.myRoot, null, null, null);
	app.myTrxCA.trxCreateStopsTable(pxyStopTable, realStop, app.myPassport);
	
	terminal := self.getMyTerminal();
	
	// Storage Config
	self.deleteStorageConfig(true);
	storageConfig := terminal.myStorageConfig;
	
	// Storage Detail
	storageDtlCriteria.add(YACriteriaType_CargoType);
	storageDtlCritV.add(self.getCargoType(CARGOTYPEDESC));
	
	storageDetail := self.addStorageDetail(storageConfig, "UT" &amp; method.name, storageDtlCriteria, storageDtlCritV, 2, 5, false, false, 0, 0, false, null);
	
	// Terminal Area Storage Group
	self.deleteTerminalAreaStorageGroup(TAGROUP);
	
	terminalAreas.add(terminalArea);
	taStorageGroup := self.addTerminalAreaStorageGroup(TAGROUP, TAGROUP, terminalAreas);
	invLineType := self.getInvoiceLineType("UTSSMinChg");
	invLineTypeArray.add(invLineType);
	
	// Future Storage mapping
	fsm := self.addFutureStorageMapping2(self.myBank, taStorageGroup, storageDetail, invLineType.myCalculationType, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	
	transferQty := 10;
	transferVol := 500;
	transferWeight := 500;
	/*================================
	COO Header 1
	has 5 COO Details
	Each TI has one
	================================*/
	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO11", null, null, app.getMyUserCode(), daysAgo15, null, daysAgo15, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 1 is null");
	
	// Create Cargo in Cargo Group 1
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3) &amp; "A";
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		beginTransaction;
			ti.setPropertyValue("receivedDT", lastMonth);
			foreach transaction in ti.allTransactions do
				lastMonth := transaction.dateTime;
				lastMonth.setDate(lastMonth.date()-30);
				transaction.setPropertyValue("dateTime", lastMonth);
			endforeach;
		commitTransaction;
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		tisToDelete.add(ti);
		
		// Exclude this from COO for testing later.
		if i = 5 then
			tiToExclFromCOO := ti;
			include := false;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(transferWeight, transferVol, transferQty, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;
	self.deleteCargoGroup(CGID1);
	cargoGroup 	:= self.addCargoGroup(CGID1, tiSet);
	cooHeader1.doCreateCMIFAgent(cmifAgent);
	
	/*================================
	COO Header 2
	has 1 COO details of the Cargo Group
	COO Details has 5 sub details for TI
	================================*/
	
	
	// Create Ownership change 2
	delete pxyCooHeader;
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO22", null, null, app.getMyUserCode(), daysAgo15, null, daysAgo15, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader2);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 2 is null");
	
	// Create Cargo in Cargo Group 2
	tiSet.clear();
	foreach i in 1 to numTiToCreate do
		tiId := "CG2-" &amp; i.padLeadingWith("0", 3) &amp; "A";
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		ti.setMyCargoGroup(cargoGroup2, app.myPassport);
		tiSet.add(ti);
		tisToDelete.add(ti);
	endforeach;
	self.deleteCargoGroup(CGID2);
	cargoGroup2	:= self.addCargoGroup(CGID2, tiSet);
	
	// Create Ownership Details for Cargo Group
	delete pxyCooDetails;
	create pxyCooDetails transient;
	pxyCooDetails.setProxy(weight, volume, quantity, true, cooHeader2, null, cargoGroup2);
	self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
	self.assertTrueMsg(cooDetails &lt;&gt; null, cargoGroup2.id &amp; " does not have COO details created");
	
	// Create Ownership SUB details for TI in Cargo Group
	foreach ti in cargoGroup2.allAssignedTrackedItems do
		if ti = tiToExclFromCOO then
			continue;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		pxyCooDetails.setProxy(transferWeight, transferVol, transferQty, true, null, cooDetails, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, subCooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, ti.id &amp; " does not have COO details created");
	endforeach;
	cooHeader2.doCreateCMIFAgent(cmifAgent2);
	// Move all cargo to Yard
	lastMonth := now;
	lastMonth.setDate(lastMonth.date() - 30);
	self.opts.purge();
	self.opts.addAssoc("effectiveTS", lastMonth);
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tisToDelete do
		self.deleteStops(ti);
	endforeach;
	
	// Need to run the BGP here
	self.processOfflineFutureActors(lastMonth, now);
	
	// Now Approve COO 1
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 1 - ");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	// Check Cargo Group 1 has correct Operator collection
	self.assertTrueMsg(cargoGroup.allOperators.includes(newOperator), cargoGroup.id &amp; " has incorrect allOperators collection");
	self.assertTrueMsg(cargoGroup.allOperators.includes(operator), cargoGroup.id &amp; " has incorrect allOperators collection");
	// Check cargo group 1 has COO transaction
	transaction := cargoGroup.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
	self.assertTrueMsg(transaction &lt;&gt; null, cargoGroup.id &amp; " does not have Ownership Changed Transaction created");
	// Check TIs in Cargo Group 1
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		// This is the TI that was excluded, it shouldn't have anything changed
		if ti = tiToExclFromCOO then
			// Should not have a TI splitted 
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = opCode, ti.id &amp; " should not have the new operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction = null, ti.id &amp; " should not have Ownership Changed Transaction created");
			// Quantity shouldn't have changed
			self.assertTrueMsg(ti.totalQuantity = quantity, ti.id &amp; " has incorrect quantity");
		// These are included in the COO, should have new operators etc..
		else
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = newOperator.code, ti.id &amp; " has incorrect operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, ti.id &amp; " does not have Ownership Changed Transaction created");
			// Check Quantity
			self.assertTrueMsg(ti.totalQuantity = quantity, ti.id &amp; " has incorrect quantity");
			// Check Future Storage transaction, if &gt;= COO effective date, it should be deleted/with new operator
			foreach transaction in ti.allTransactions where transaction.type = TRANS_TYPE_FUTURE_STORAGE do
				foreach invoiceLine in transaction.allInvoiceLines where invoiceLine.myTransactionTI.type = TRANS_TYPE_FUTURE_STORAGE do
					self.assertTrueMsg(invoiceLine.debtor = operator.debtor, ti.id &amp;  " deleted FS transaction has invoice line to the wrong debtor");
				endforeach;
			endforeach;
		endif;
	endforeach;
	
	// Now Approve COO 2
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader2, app.myPassport, cmifAgent2);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 2 - ");
	// Check COO approved status
	self.assertTrueMsg(cooHeader2.dateTimeApproved.isValid(), "cooHeader2 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader2.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	// Check Cargo Group 2
	self.assertTrueMsg(cargoGroup2.allOperators.includes(newOperator), cargoGroup2.id &amp; " has incorrect allOperators collection");
	// Check Cargo group 2 has COO transaction
	transaction := cargoGroup2.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
	self.assertTrueMsg(transaction &lt;&gt; null, cargoGroup2.id &amp; " does not have Ownership Changed Transaction created");
	// Check TIs in Cargo Group 2
	foreach cooDetails in cooHeader2.allDetails do
		foreach subCooDetails in cooDetails.allSubDetails do
			ti := subCooDetails.myTrackedItem;
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = newOperator.code, ti.id &amp; " has incorrect operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, ti.id &amp; " does not have Ownership Changed Transaction created");
			// Check Quantity
			self.assertTrueMsg(ti.totalQuantity = quantity, ti.id &amp; " has incorrect quantity");
			// Check Future Storage transaction, if &gt;= COO effective date, it should be deleted/with new operator
			foreach transaction in ti.allTransactions where transaction.type = TRANS_TYPE_FUTURE_STORAGE do
				foreach invoiceLine in transaction.allInvoiceLines where invoiceLine.myTransactionTI.type = TRANS_TYPE_FUTURE_STORAGE do
					self.assertTrueMsg(invoiceLine.debtor = operator.debtor, ti.id &amp;  " deleted FS transaction has invoice line to the wrong debtor");
				endforeach;
			endforeach;
		endforeach;
	endforeach;
	
	// Run the BGP again, it should delete the transaction which date time is &lt; 15 days, then create new transaction with the correct debtor
	self.processOfflineFutureActors(daysAgo15, now);
	
	// Check the debtor 
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		// This is the TI that was excluded, it shouldn't have anything changed
		if ti = tiToExclFromCOO then
			// Should not have a TI splitted 
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = opCode, ti.id &amp; " should not have the new operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction = null, ti.id &amp; " should not have Ownership Changed Transaction created");
			// Quantity shouldn't have changed
			self.assertTrueMsg(ti.totalQuantity = quantity, ti.id &amp; " has incorrect quantity");
		// These are included in the COO, should have new operators etc..
		else
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = newOperator.code, ti.id &amp; " has incorrect operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, ti.id &amp; " does not have Ownership Changed Transaction created");
			// Check Quantity
			self.assertTrueMsg(ti.totalQuantity = quantity, ti.id &amp; " has incorrect quantity");
			// Check Future Storage transaction, invoice line, it should have correct debtor.
			foreach transaction in ti.allTransactions where transaction.type = TRANS_TYPE_FUTURE_STORAGE do
				if transaction.isDeleted() or transaction.dateTime.date() &lt; daysAgo15.date() then
					foreach invoiceLine in transaction.allInvoiceLines where invoiceLine.myTransactionTI.type = TRANS_TYPE_FUTURE_STORAGE do
						self.assertTrueMsg(invoiceLine.debtor = operator.debtor, ti.id &amp;  " deleted FS transaction has invoice line to the wrong debtor");
					endforeach;
				else
					foreach invoiceLine in transaction.allInvoiceLines where invoiceLine.myTransactionTI.type = TRANS_TYPE_FUTURE_STORAGE do
						self.assertTrueMsg(invoiceLine.debtor = newOperator.debtor, ti.id &amp;  " new FS transaction has invoice line to the wrong debtor");
					endforeach;
				endif;
			endforeach;
		endif;
	endforeach;
	
	// Check TIs in Cargo Group 2
	foreach cooDetails in cooHeader2.allDetails do
		foreach subCooDetails in cooDetails.allSubDetails do
			ti := subCooDetails.myTrackedItem;
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = newOperator.code, ti.id &amp; " has incorrect operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, ti.id &amp; " does not have Ownership Changed Transaction created");
			// Check Quantity
			self.assertTrueMsg(ti.totalQuantity = quantity, ti.id &amp; " has incorrect quantity");
			// Check Future Storage transaction, invoice line, it should have correct debtor.
			foreach transaction in ti.allTransactions where transaction.type = TRANS_TYPE_FUTURE_STORAGE do
				if transaction.isDeleted() or transaction.dateTime.date() &lt; daysAgo15.date() then
					foreach invoiceLine in transaction.allInvoiceLines where invoiceLine.myTransactionTI.type = TRANS_TYPE_FUTURE_STORAGE do
						self.assertTrueMsg(invoiceLine.debtor = operator.debtor, ti.id &amp;  " deleted FS transaction has invoice line to the wrong debtor");
					endforeach;
				else
					foreach invoiceLine in transaction.allInvoiceLines where invoiceLine.myTransactionTI.type = TRANS_TYPE_FUTURE_STORAGE do
						self.assertTrueMsg(invoiceLine.debtor = newOperator.debtor, ti.id &amp;  " new FS transaction has invoice line to the wrong debtor");
					endforeach;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
epilog
	
	if cooHeader1 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader1);
	endif;
	if cooHeader2 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader2);
	endif;
	
	self.deleteTerminalAreaStorageGroup(TAGROUP);
	
	delete tiSet;
	delete tisToDelete;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete pxyStopCriteria;
	delete pxyStopTemp;
	delete pxyStopTable;
	delete stopsSetArray;
	delete stopCheckArray;
	delete stopProcessArray;
	delete allOpsForStop;
	delete storageDtlCriteria;
	delete storageDtlCritV;
	delete terminalAreas;
	delete invLineTypeArray;
	delete allTis;
	delete cmifAgent;
	delete cmifAgent2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeFutStorage01" id="593cdc43-c9de-4ccc-b739-4029fa7cc5ca">
        <source>tOwnershipChangeFutStorage01();
/*

Purpose:		Future Storage Testing. This means CM_FutureStorage transaction and CM_FutureSTorageProcess for BGP.

					Need a storage configuration for future storage
					
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. check BGP request there should be 1
					
					Create a COO for whole TI with a date in the past
					
					Approve COO.
					
					 check BGP request there should be 2. One for each CM_StorageExpiryDetail.					 
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 18JUN2024
ADO -  BUG 64680
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TAGroup1 : String = "TAGROUPX";

vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS	, actionTS			: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	termAreas : CM_TerminalAreaArray;
	tasg1 : CM_TerminalAreaStorageGroup;
	fsm : CM_FutureStorageMapping;
	actor : CM_OfflineFutureActor;
	actors : CM_OfflineFutureActorDict;
	freeSToExp : CM_StorageExpiryDetail;
	matched : Boolean;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,10,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	// Setup Storage Detail
	self.deleteTerminalAreaStorageGroup(TAGroup1);
	// terminal areas
	create termAreas transient;
	termAreas.add(terminalArea);
	tasg1 := self.addTerminalAreaStorageGroup(TAGroup1, "inside", termAreas);

	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	fsm := self.addFutureStorageMapping(tasg1, invLineType, storageDetail);
	self.assertNotNullMsg(fsm, " Future Storage Mapping not created");
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null,  cooTS.addDays(10), 10, 10, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "OCF1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
		
		
		self.assertTrueMsg(ti.isFutureStorage(storageDetail) &lt;&gt; null, tiId &amp; " is NOT future storage");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	

	// #########################################
	// ##### Check all have one BGP future actor
	// #########################################
	

	foreach ti in tiSet do
	
		actor := app.myRoot.getFutureActor(ti, CM_FutureStorageProcess);
		assertTrueMsg(actor &lt;&gt; null, "BGP actor not created for " &amp; ti.id);
		
		
	endforeach;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	

	// #########################################
	// ##### Check all have two matching BGP future actors
	// #########################################
	create actors transient;
	foreach ti in tiSet do
		actors.clear();
		app.myRoot.getFutureActors(ti, CM_FutureStorageProcess,actors);
		assertTrueMsg(actors.size  &lt;&gt; null, "No BGP actors for " &amp; ti.id);
		assertTrueMsg(actors.size = 2, "Should be 2 BGP actors for " &amp; ti.id &amp; " There are " &amp; actors.size.String);
		
		foreach  freeSToExp in ti.allStorageExpiryDetails do
			actionTS := freeSToExp.freeStorageExpiry.addDays(1);
			matched := false;
			foreach actor in actors do : actorloop
				if actionTS.date = actor.actionTimeStamp.date then
					matched := true;
					break actorloop;
				endif;
			endforeach;		
			assertTrueMsg(matched, "BGP request date doe snot match any storage expiry for " &amp; ti.id);
		endforeach;
	endforeach;
	
	
	
	ti := tiSet.first;
	self.outputDetailsFuture(ti);
	

	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true); // this deletes the future actors
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete termAreas;
	delete actors;
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeFutStorage02" id="52986dc9-f348-460f-a842-789fd4d37598">
        <source>tOwnershipChangeFutStorage02();
/*

Purpose:		Future Storage Testing. This means CM_FutureStorage transaction and CM_FutureSTorageProcess for BGP.

					Need a storage configuration for future storage
					
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. check BGP request there should be 1
					
					Create a COO for whole TI with a date for today
					
					Approve COO.
					
					 check BGP request there should be 2. One for each CM_StorageExpiryDetail.					 
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 18JUN2024
ADO -  BUG 64680
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TAGroup1 : String = "TAGROUPX";

vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS	, actionTS			: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	termAreas : CM_TerminalAreaArray;
	tasg1 : CM_TerminalAreaStorageGroup;
	fsm : CM_FutureStorageMapping;
	actor : CM_OfflineFutureActor;
	actors : CM_OfflineFutureActorDict;
	freeSToExp : CM_StorageExpiryDetail;
	matched : Boolean;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
 	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,5,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	// Setup Storage Detail
	self.deleteTerminalAreaStorageGroup(TAGroup1);
	// terminal areas
	create termAreas transient;
	termAreas.add(terminalArea);
	tasg1 := self.addTerminalAreaStorageGroup(TAGroup1, "inside", termAreas);

	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	fsm := self.addFutureStorageMapping(tasg1, invLineType, storageDetail);
	self.assertNotNullMsg(fsm, " Future Storage Mapping not created");
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now;

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null,  cooTS, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "OCF2-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
		
		
		self.assertTrueMsg(ti.isFutureStorage(storageDetail) &lt;&gt; null, tiId &amp; " is NOT future storage");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	ti := tiSet.first;
	assertTrueMsg(ti.getFreeStorageExpiry().date = moveTS.date + 4, "Free storage expiry is wrong for " &amp; ti.id &amp; ". Is " &amp; ti.getFreeStorageExpiry().date.String &amp; " Should be " &amp; (moveTS.date + 4).String);

	
	// #########################################
	// ##### Check all have one matching BGP future actor
	// #########################################
	create actors transient;
	foreach ti in tiSet do
		actors.clear();
		app.myRoot.getFutureActors(ti, CM_FutureStorageProcess,actors);
		assertTrueMsg(actors.size  &lt;&gt; null, "No BGP actors for " &amp; ti.id);
		assertTrueMsg(actors.size = 1, "Should be 1 BGP actor for " &amp; ti.id &amp; " There are " &amp; actors.size.String);
		
		foreach  freeSToExp in ti.allStorageExpiryDetails do
			actionTS := freeSToExp.freeStorageExpiry.addDays(1);
			matched := false;
			foreach actor in actors do : actorloop
				if actionTS.date = actor.actionTimeStamp.date then
					matched := true;
					break actorloop;
				endif;
			endforeach;		
			assertTrueMsg(matched, "BGP request date doe snot match any storage expiry for " &amp; ti.id);
		endforeach;
	endforeach;
	delete actors;
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	

	// #########################################
	// ##### Check all have two matching BGP future actors
	// #########################################
	create actors transient;
	foreach ti in tiSet do
		actors.clear();
		app.myRoot.getFutureActors(ti, CM_FutureStorageProcess,actors);
		assertTrueMsg(actors.size  &lt;&gt; null, "No BGP actors for " &amp; ti.id);
		assertTrueMsg(actors.size = 2, "Should be 2 BGP actors for " &amp; ti.id &amp; " There are " &amp; actors.size.String);
		
		foreach  freeSToExp in ti.allStorageExpiryDetails do
			actionTS := freeSToExp.freeStorageExpiry.addDays(1);
			matched := false;
			foreach actor in actors do : actorloop
				if actionTS.date = actor.actionTimeStamp.date then
					matched := true;
					break actorloop;
				endif;
			endforeach;		
			assertTrueMsg(matched, "BGP request date doe snot match any storage expiry for " &amp; ti.id);
		endforeach;
	endforeach;
	
	
	
	ti := tiSet.first;
	self.outputDetailsFuture(ti);
	

	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true); // this deletes the future actors
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete termAreas;
	delete actors;
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeFutStorage03" id="68c28e1e-7a70-402c-8b2a-bcba29f359e0">
        <source>tOwnershipChangeFutStorage03();
/*

Purpose:		Future Storage Testing. This means CM_FutureStorage transaction and CM_FutureSTorageProcess for BGP.

					Need a storage configuration for future storage
					
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. check BGP request there should be 1
					
					Create a COO for whole TI with a date for the future
					
					Approve COO.
					
					 check BGP request there should be 2. One for each CM_StorageExpiryDetail.					 
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 18JUN2024
ADO -  BUG 64680
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TAGroup1 : String = "TAGROUPX";

vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS	, actionTS			: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	termAreas : CM_TerminalAreaArray;
	tasg1 : CM_TerminalAreaStorageGroup;
	fsm : CM_FutureStorageMapping;
	actor : CM_OfflineFutureActor;
	actors : CM_OfflineFutureActorDict;
	freeSToExp : CM_StorageExpiryDetail;
	matched : Boolean;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,5,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	// Setup Storage Detail
	self.deleteTerminalAreaStorageGroup(TAGroup1);
	// terminal areas
	create termAreas transient;
	termAreas.add(terminalArea);
	tasg1 := self.addTerminalAreaStorageGroup(TAGroup1, "inside", termAreas);

	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	fsm := self.addFutureStorageMapping(tasg1, invLineType, storageDetail);
	self.assertNotNullMsg(fsm, " Future Storage Mapping not created");
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null,  cooTS.addDays(10), 10, 10, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	self.assertTrueMsg(cooHeader1.freeDaysAdditional = 10, "freeDaysAdditional should be 10");
	self.assertTrueMsg(cooHeader1.freeDaysOperatorNew = 10, "freeDaysOperatorNew should be 10");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "OCF3-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
		
		
		self.assertTrueMsg(ti.isFutureStorage(storageDetail) &lt;&gt; null, tiId &amp; " is NOT future storage");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	ti := tiSet.first;
	assertTrueMsg(ti.getFreeStorageExpiry().date = moveTS.date + 4, "Free storage expiry is wrong for " &amp; ti.id &amp; ". Is " &amp; ti.getFreeStorageExpiry().date.String &amp; " Should be " &amp; (moveTS.date + 4).String);

	
	// #########################################
	// ##### Check all have one matching BGP future actor
	// #########################################
	create actors transient;
	foreach ti in tiSet do
		actors.clear();
		app.myRoot.getFutureActors(ti, CM_FutureStorageProcess,actors);
		assertTrueMsg(actors.size  &lt;&gt; null, "No BGP actors for " &amp; ti.id);
		assertTrueMsg(actors.size = 1, "Should be 1 BGP actor for " &amp; ti.id &amp; " There are " &amp; actors.size.String);
		
		foreach  freeSToExp in ti.allStorageExpiryDetails do
			actionTS := freeSToExp.freeStorageExpiry.addDays(1);
			matched := false;
			foreach actor in actors do : actorloop
				if actionTS.date = actor.actionTimeStamp.date then
					matched := true;
					break actorloop;
				endif;
			endforeach;		
			assertTrueMsg(matched, "BGP request date doe snot match any storage expiry for " &amp; ti.id);
		endforeach;
	endforeach;
	delete actors;
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	

	// #########################################
	// ##### Check all have two matching BGP future actors
	// #########################################
	create actors transient;
	foreach ti in tiSet do
		actors.clear();
		app.myRoot.getFutureActors(ti, CM_FutureStorageProcess,actors);
		assertTrueMsg(actors.size  &lt;&gt; null, "No BGP actors for " &amp; ti.id);
		assertTrueMsg(actors.size = 2, "Should be 2 BGP actors for " &amp; ti.id &amp; " There are " &amp; actors.size.String);
		
		foreach  freeSToExp in ti.allStorageExpiryDetails do
			actionTS := freeSToExp.freeStorageExpiry.addDays(1);
			matched := false;
			foreach actor in actors do : actorloop
				if actionTS.date = actor.actionTimeStamp.date then
					matched := true;
					break actorloop;
				endif;
			endforeach;		
			assertTrueMsg(matched, "BGP request date doe snot match any storage expiry for " &amp; ti.id);
		endforeach;
	endforeach;
	
	
	ti := tiSet.first;
//	self.outputDetailsFuture(ti);

	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true); // this deletes the future actors
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete termAreas;
	delete actors;
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeFutStorage04" id="1a63f832-a9a5-4ad5-94d4-f2bb573cf5a2">
        <source>tOwnershipChangeFutStorage04();
/*

Purpose:		Future Storage Testing. This means CM_FutureStorage transaction and CM_FutureSTorageProcess for BGP.

					Need a storage configuration for future storage
					
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. check BGP request there should be 1
					
					Create a COO for whole TI with a date for today
					
					Approve COO.
					
					 check BGP request there should be 2. One for each CM_StorageExpiryDetail.					 
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 18JUN2024
ADO -  BUG 64680
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TAGroup1 : String = "TAGROUPX";

vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS	, actionTS			: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	termAreas : CM_TerminalAreaArray;
	tasg1 : CM_TerminalAreaStorageGroup;
	fsm : CM_FutureStorageMapping;
	actor : CM_OfflineFutureActor;
	actors : CM_OfflineFutureActorDict;
	freeSToExp : CM_StorageExpiryDetail;
	matched : Boolean;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,5,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	// Setup Storage Detail
	self.deleteTerminalAreaStorageGroup(TAGroup1);
	// terminal areas
	create termAreas transient;
	termAreas.add(terminalArea);
	tasg1 := self.addTerminalAreaStorageGroup(TAGroup1, "inside", termAreas);

	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	fsm := self.addFutureStorageMapping(tasg1, invLineType, storageDetail);
	self.assertNotNullMsg(fsm, " Future Storage Mapping not created");
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now;

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null,  cooTS.addDays(10), 10, 10, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "OCF4-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
		
		
		self.assertTrueMsg(ti.isFutureStorage(storageDetail) &lt;&gt; null, tiId &amp; " is NOT future storage");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-4);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	ti := tiSet.first;
	assertTrueMsg(ti.getFreeStorageExpiry().date = moveTS.date + 4, "Free storage expiry is wrong for " &amp; ti.id &amp; ". Is " &amp; ti.getFreeStorageExpiry().date.String &amp; " Should be " &amp; (moveTS.date + 4).String);

	
	// #########################################
	// ##### Check all have one matching BGP future actor
	// #########################################
	create actors transient;
	foreach ti in tiSet do
		actors.clear();
		app.myRoot.getFutureActors(ti, CM_FutureStorageProcess,actors);
		assertTrueMsg(actors.size  &lt;&gt; null, "No BGP actors for " &amp; ti.id);
		assertTrueMsg(actors.size = 1, "Should be 1 BGP actor for " &amp; ti.id &amp; " There are " &amp; actors.size.String);
		
		foreach  freeSToExp in ti.allStorageExpiryDetails do
			actionTS := freeSToExp.freeStorageExpiry.addDays(1);
			matched := false;
			foreach actor in actors do : actorloop
				if actionTS.date = actor.actionTimeStamp.date then
					matched := true;
					break actorloop;
				endif;
			endforeach;		
			assertTrueMsg(matched, "BGP request date doe snot match any storage expiry for " &amp; ti.id);
		endforeach;
	endforeach;
	delete actors;
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	
	ti := tiSet.first;
	self.outputDetailsFuture(ti);
	
	// #########################################
	// ##### Check all have two matching BGP future actors
	// #########################################
	create actors transient;
	foreach ti in tiSet do
		actors.clear();
		app.myRoot.getFutureActors(ti, CM_FutureStorageProcess,actors);
		assertTrueMsg(actors.size  &lt;&gt; null, "No BGP actors for " &amp; ti.id);
		assertTrueMsg(actors.size = 2, "Should be 2 BGP actors for " &amp; ti.id &amp; " There are " &amp; actors.size.String);
		
		foreach  freeSToExp in ti.allStorageExpiryDetails do
			actionTS := freeSToExp.freeStorageExpiry.addDays(1);
			matched := false;
			foreach actor in actors do : actorloop
				if actionTS.date = actor.actionTimeStamp.date then
					matched := true;
					break actorloop;
				endif;
			endforeach;		
			assertTrueMsg(matched, "BGP request date doe snot match any storage expiry for " &amp; ti.id);
		endforeach;
	endforeach;
	
	
	
	ti := tiSet.first;
	self.outputDetailsFuture(ti);
	

	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true); // this deletes the future actors
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete termAreas;
	delete actors;
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeFutStorage05" id="2847c1e4-7e73-43ab-9b62-f7c0f175065b">
        <source>tOwnershipChangeFutStorage05();
/*

Purpose:		Future Storage Testing. This means CM_FutureStorage transaction and CM_FutureSTorageProcess for BGP.

					Need a storage configuration for future storage
					
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. check BGP request there should be 1
					
					Create a COO for whole TI with a date for today
					
					Approve COO.
					
					 check BGP request there should be 2. One for each CM_StorageExpiryDetail.					 
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 18JUN2024
ADO -  BUG 64680
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TAGroup1 : String = "TAGROUPX";

vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS	, actionTS			: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	termAreas : CM_TerminalAreaArray;
	tasg1 : CM_TerminalAreaStorageGroup;
	fsm : CM_FutureStorageMapping;
	actor : CM_OfflineFutureActor;
	actors : CM_OfflineFutureActorDict;
	freeSToExp : CM_StorageExpiryDetail;
	matched : Boolean;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,5,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	// Setup Storage Detail
	self.deleteTerminalAreaStorageGroup(TAGroup1);
	// terminal areas
	create termAreas transient;
	termAreas.add(terminalArea);
	tasg1 := self.addTerminalAreaStorageGroup(TAGroup1, "inside", termAreas);

	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	fsm := self.addFutureStorageMapping(tasg1, invLineType, storageDetail);
	self.assertNotNullMsg(fsm, " Future Storage Mapping not created");
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now;

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null,  cooTS.addDays(5), 5, 5, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "OCF4-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
		
		
		self.assertTrueMsg(ti.isFutureStorage(storageDetail) &lt;&gt; null, tiId &amp; " is NOT future storage");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-4);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	ti := tiSet.first;
	assertTrueMsg(ti.getFreeStorageExpiry().date = moveTS.date + 4, "Free storage expiry is wrong for " &amp; ti.id &amp; ". Is " &amp; ti.getFreeStorageExpiry().date.String &amp; " Should be " &amp; (moveTS.date + 4).String);

	
	// #########################################
	// ##### Check all have one matching BGP future actor
	// #########################################
	create actors transient;
	foreach ti in tiSet do
		actors.clear();
		app.myRoot.getFutureActors(ti, CM_FutureStorageProcess,actors);
		assertTrueMsg(actors.size  &lt;&gt; null, "No BGP actors for " &amp; ti.id);
		assertTrueMsg(actors.size = 1, "Should be 1 BGP actor for " &amp; ti.id &amp; " There are " &amp; actors.size.String);
		
		foreach  freeSToExp in ti.allStorageExpiryDetails do
			actionTS := freeSToExp.freeStorageExpiry.addDays(1);
			matched := false;
			foreach actor in actors do : actorloop
				if actionTS.date = actor.actionTimeStamp.date then
					matched := true;
					break actorloop;
				endif;
			endforeach;		
			assertTrueMsg(matched, "BGP request date doe snot match any storage expiry for " &amp; ti.id);
		endforeach;
	endforeach;
	delete actors;
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	
	ti := tiSet.first;
	self.outputDetailsFuture(ti);
	
	// #########################################
	// ##### Check all have two matching BGP future actors
	// #########################################
	create actors transient;
	foreach ti in tiSet do
		actors.clear();
		app.myRoot.getFutureActors(ti, CM_FutureStorageProcess,actors);
		assertTrueMsg(actors.size  &lt;&gt; null, "No BGP actors for " &amp; ti.id);
		assertTrueMsg(actors.size = 2, "Should be 2 BGP actors for " &amp; ti.id &amp; " There are " &amp; actors.size.String);
		
		foreach  freeSToExp in ti.allStorageExpiryDetails do
			actionTS := freeSToExp.freeStorageExpiry.addDays(1);
			matched := false;
			foreach actor in actors do : actorloop
				if actionTS.date = actor.actionTimeStamp.date then
					matched := true;
					break actorloop;
				endif;
			endforeach;		
			assertTrueMsg(matched, "BGP request date doe snot match any storage expiry for " &amp; ti.id);
		endforeach;
	endforeach;
	
	
	
	ti := tiSet.first;
	self.outputDetailsFuture(ti);
	

	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true); // this deletes the future actors
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete termAreas;
	delete actors;
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeFutStorage06" id="384814bd-4878-4a39-8ec7-2896e73e53cc">
        <source>tOwnershipChangeFutStorage06();
/*

Purpose:		Future Storage Testing. This means CM_FutureStorage transaction and CM_FutureSTorageProcess for BGP.

					Need a storage configuration for future storage 5 days free
					
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship today, check free storage. check BGP request there should be 1
					
					Create a COO for whole TI with a date for today with 5 extra free days
					
					Approve COO.
					
					 check BGP request there should be 2. One for each CM_StorageExpiryDetail.					 
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 18JUN2024
ADO -  BUG 64680
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TAGroup1 : String = "TAGROUPX";

vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS	, actionTS, newTS			: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	termAreas : CM_TerminalAreaArray;
	tasg1 : CM_TerminalAreaStorageGroup;
	fsm : CM_FutureStorageMapping;
	actor : CM_OfflineFutureActor;
	actors : CM_OfflineFutureActorDict;
	freeSToExp : CM_StorageExpiryDetail;
	matched : Boolean;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,5,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	// Setup Storage Detail
	self.deleteTerminalAreaStorageGroup(TAGroup1);
	// terminal areas
	create termAreas transient;
	termAreas.add(terminalArea);
	tasg1 := self.addTerminalAreaStorageGroup(TAGroup1, "inside", termAreas);

	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	fsm := self.addFutureStorageMapping(tasg1, invLineType, storageDetail);
	self.assertNotNullMsg(fsm, " Future Storage Mapping not created");
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now;

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS.addDays(5), 5, 5, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	self.assertTrueMsg(cooHeader1.storageExpiryOperatorNew.isValid, "COO 100 storageExpiryOperatorNew is invalid ");
	newTS := cooHeader1.dateTimeCOO.addDays(5);
	self.assertTrueMsg(cooHeader1.storageExpiryOperatorNew = newTS, "COO 100 storageExpiryOperatorNew is wrong sbe " &amp; cooHeader1.storageExpiryOperatorNew.date.String &amp; " is " &amp; newTS.date.String);
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "OCF4-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
		
		
		self.assertTrueMsg(ti.isFutureStorage(storageDetail) &lt;&gt; null, tiId &amp; " is NOT future storage");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS;
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	ti := tiSet.first;
	assertTrueMsg(ti.getFreeStorageExpiry().date = moveTS.date + 4, "Free storage expiry is wrong for " &amp; ti.id &amp; ". Is " &amp; ti.getFreeStorageExpiry().date.String &amp; " Should be " &amp; (moveTS.date + 4).String);

	write method.qualifiedName &amp; " FSE: " &amp; ti.getFreeStorageExpiry().date.String;
	
	// #########################################
	// ##### Check all have one matching BGP future actor
	// #########################################
	create actors transient;
	foreach ti in tiSet do
		actors.clear();
		app.myRoot.getFutureActors(ti, CM_FutureStorageProcess,actors);
		assertTrueMsg(actors.size  &lt;&gt; null, "No BGP actors for " &amp; ti.id);
		assertTrueMsg(actors.size = 1, "Should be 1 BGP actor for " &amp; ti.id &amp; " There are " &amp; actors.size.String);
		
		foreach  freeSToExp in ti.allStorageExpiryDetails do
			actionTS := freeSToExp.freeStorageExpiry.addDays(1);
			matched := false;
			foreach actor in actors do : actorloop
				if actionTS.date = actor.actionTimeStamp.date then
					matched := true;
					break actorloop;
				endif;
			endforeach;		
			assertTrueMsg(matched, "BGP request date doe snot match any storage expiry for " &amp; ti.id);
		endforeach;
	endforeach;
	delete actors;
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	
	ti := tiSet.first;
	self.outputDetailsFuture(ti);
	
	// #########################################
	// ##### Check all have two matching BGP future actors
	// #########################################
	create actors transient;
	foreach ti in tiSet do
		actors.clear();
		app.myRoot.getFutureActors(ti, CM_FutureStorageProcess,actors);
		assertTrueMsg(actors.size  &lt;&gt; null, "No BGP actors for " &amp; ti.id);
		assertTrueMsg(actors.size = 2, "Should be 2 BGP actors for " &amp; ti.id &amp; " There are " &amp; actors.size.String);
		
		foreach  freeSToExp in ti.allStorageExpiryDetails do
			actionTS := freeSToExp.freeStorageExpiry.addDays(1);
			matched := false;
			foreach actor in actors do : actorloop
				if actionTS.date = actor.actionTimeStamp.date then
					matched := true;
					break actorloop;
				endif;
			endforeach;		
			assertTrueMsg(matched, "BGP request date does not match any storage expiry for " &amp; ti.id);
		endforeach;
	endforeach;
	
	
	
	ti := tiSet.first;
	//self.outputDetailsFuture(ti);
	

	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true); // this deletes the future actors
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete termAreas;
	delete actors;
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeINCO01" id="1a302589-e4b8-45d5-911e-75561131675c">
        <source>tOwnershipChangeINCO01();
/*

Purpose:		COO INCO Testing. This will be for any TI transaction type. Charge to the COO INCO TERM DEBTOR.
					INCO can have any type of invoice line, not just storage.

					This test will use the edit transaction. Need invoicing for EDIT transaction to create invoice lines
					
					create TIs. edit so that the current operator is charged.
					
					Create a COO with an INCO Term, this should charge from the COO date to the INCO Term debtor type
					The COO should be for the whole TI with a date prior to the CM_EDIT, 2 operators with different debtors
					
					Approve COO.
					
					The transaction invoice lines should be for the COO INCO Term debtor
					
					This test will have the INCO term of the TIs customs agent.
					
					When the COO is approved, all the transactions on the TI from the COO data onwards are resyncd and set with the INCO term, if it exists.
					
					COO DATE is in the PAST so edit charging should be INCO debtor

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 05AUG2024
ADO - CR 64873 TASK 65509
*/

constants
	InvType_Edit = "UT_COOEDIT";
	CalType_Code_Edit = "UT_CALTYPE_COO";
	CalType_Desc_Edit = "UT_CalType_COO_Desc";
	Srvc_COOEdit = "UT_SRVC_COOEDT";
	InvLineType_Code = "UT_COOEDT";
	Debtor_Type = "SDT1";
	TransType_Edit = "Edited";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	DebtorEdit = "DSTR";
	DebtorCA = "CADT";
	OperatorEdit = "DSTR";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	values		: ObjectArray;
	criteria	: IntegerArray;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew, debtorCA : CM_Debtor;
	trans : CM_TITransactionSet;
	incoTerm : CM_InvoiceINCOTerm;
	debtorType : CM_DebtorType;
	customsAgent : CM_CustomsAgent;
	invLineSet : CM_InvoiceLineDescSet;
	moveTS : TimeStamp;
begin

	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");

	
	
	
	self.deleteDebtor(DebtorCA);
	debtorCA := self.addDebtor(DebtorCA, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(DebtorCA,"Debtor debtorCA Create Failed");
	customsAgent := self.addCustomsAgent("UTCA1", "UTCA1 Desc");
	beginTransaction;
	customsAgent.setDebtor(debtorCA);
	commitTransaction;
	
	// ### INCO
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	self.deleteInvINCOTerm("UTINCO");
	incoTerm := self.createInvoiceINCOTerm("UTINCO","Unit Test INCO Term", self.myBank);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
																				
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
																				
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	

	// #########################################
	// ##### INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOEdit);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Edit);

	invType := self.createInvoiceType(InvType_Edit, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Edit &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Edit, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Edit,
										   CalType_Desc_Edit, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Edit &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOEdit, Srvc_COOEdit, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOEdit &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorCA,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	// ### INCO Mapping
	create invLineSet transient;
	invLineSet.add(invLineType);
	self.createInvoiceINCOTermMapping(debtorType,incoTerm,invLineSet);
	
	
	
	
	self.loadTransMapINCO(TransMap_UT, TransType_Edit, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, incoTerm, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // Includes a Storage Debtor  // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	self.assertTrueMsg(cooHeader1.myIncoterm = incoTerm, "COO 100 incoTerm is wrong");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	
	// #########################################
	// ##### EDIT all cargo on Ship
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in tiSet do
		self.updateTI(ti);
	endforeach;

	foreach ti in tiSet do
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "OLD Edit charge after COO should be for " &amp; debtorOld.name);
	endforeach;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		// Check Operator
		self.assertTrueMsg(ti.operatorCode = OperatorNew, ti.id &amp; " has incorrect new operator code. Is " &amp; ti.operatorCode &amp; " should be " &amp; OperatorNew);
		
		self.assertTrueMsg(ti.incoTermCode = "UTINCO", ti.id &amp; " INCO Term is wrong on TI");
		
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.last;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorCA, "CA Edit charge after COO should be for " &amp; debtorCA.name);
		
	endforeach;
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	self.deleteInvINCOTerm("UTINCO");
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteCustomsAgent("UTCA1");
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete invLineSet;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1
	

	delete criteriaTypes;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeINCO02" id="17984808-f035-41c1-ad20-d1e8f11aaeb5">
        <source>tOwnershipChangeINCO02();
/*

Purpose:		COO INCO Testing. This will be for any TI transaction type. Charge to the COO INCO TERM DEBTOR.
					INCO can have any type of invoice line type, not just storage.

					This test will use the edit transaction. Need invoicing for EDIT transaction to create invoice lines
					
					create TIs. edit so that the current operator is charged.
					
					Create a COO with an INCO Term, this should charge from the COO date to the INCO Term debtor type
					The COO should be for the whole TI with a date after the CM_EDIT, same operator same debtor INCO ignored
					
					Approve COO.
					
					The transaction invoice lines should be for the COO INCO Term debtor
					
					This test will have the INCO term of the TIs customs agent.
					
					When the COO is approved, all the transactions on the TI from the COO data onwards are resyncd and set with the INCO term, if it exists.
					
					However the COO DATE is in the FUTURE so edit charging should stay with OLD debtor

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 05AUG2024
ADO - CR 64873 TASK 65509
*/

constants
	InvType_Edit = "UT_COOEDIT";
	CalType_Code_Edit = "UT_CALTYPE_COO";
	CalType_Desc_Edit = "UT_CalType_COO_Desc";
	Srvc_COOEdit = "UT_SRVC_COOEDT";
	InvLineType_Code = "UT_COOEDT";
	Debtor_Type = "SDT1";
	TransType_Edit = "Edited";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	DebtorEdit = "DSTR";
	DebtorCA = "CADT";
	OperatorEdit = "DSTR";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	values		: ObjectArray;
	criteria	: IntegerArray;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew, debtorCA : CM_Debtor;
	trans : CM_TITransactionSet;
	incoTerm : CM_InvoiceINCOTerm;
	debtorType : CM_DebtorType;
	customsAgent : CM_CustomsAgent;
	invLineSet : CM_InvoiceLineDescSet;
	moveTS : TimeStamp;
begin

	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");

	
	
	
	self.deleteDebtor(DebtorCA);
	debtorCA := self.addDebtor(DebtorCA, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(DebtorCA,"Debtor debtorCA Create Failed");
	customsAgent := self.addCustomsAgent("UTCA1", "UTCA1 Desc");
	beginTransaction;
	customsAgent.setDebtor(debtorCA);
	commitTransaction;
	
	// ### INCO
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	self.deleteInvINCOTerm("UTINCO");
	incoTerm := self.createInvoiceINCOTerm("UTINCO","Unit Test INCO Term", self.myBank);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
																				
	
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
																				
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	

	// #########################################
	// ##### INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOEdit);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Edit);

	invType := self.createInvoiceType(InvType_Edit, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Edit &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Edit, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Edit,
										   CalType_Desc_Edit, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Edit &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOEdit, Srvc_COOEdit, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOEdit &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorCA,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	// ### INCO Mapping
	create invLineSet transient;
	invLineSet.add(invLineType);
	self.createInvoiceINCOTermMapping(debtorType,incoTerm,invLineSet);
	
	
	
	
	self.loadTransMapINCO(TransMap_UT, TransType_Edit, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, incoTerm, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // Includes a Storage Debtor  // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	self.assertTrueMsg(cooHeader1.myIncoterm = incoTerm, "COO 100 incoTerm is wrong");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	
	// #########################################
	// ##### EDIT all cargo on Ship
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in tiSet do
		self.updateTI(ti);
	endforeach;

	foreach ti in tiSet do
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "Edit charge after COO should be for " &amp; debtorOld.name);
	endforeach;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		// Check Operator
		self.assertTrueMsg(ti.operatorCode = OperatorNew, ti.id &amp; " has incorrect new operator code. Is " &amp; ti.operatorCode &amp; " should be " &amp; OperatorNew);
		
		self.assertTrueMsg(ti.incoTermCode = "UTINCO", ti.id &amp; " INCO Term is wrong on TI");
		
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.last;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "Edit charge after COO should be for old debtor - " &amp; debtorOld.name);
		
	endforeach;
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	self.deleteInvINCOTerm("UTINCO");
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteCustomsAgent("UTCA1");
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete invLineSet;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1
	

	delete criteriaTypes;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeINCO03" id="a2926f47-cbe2-4dec-a4cb-41b662e8659f">
        <source>tOwnershipChangeINCO03();
/*

Purpose:		COO INCO Testing. This will be for any TI transaction type. Charge to the COO INCO TERM DEBTOR.
					INCO can have any type of invoice line, not just storage.

					This test will use the edit transaction. Need invoicing for EDIT transaction to create invoice lines
					
					create TIs. edit so that the current operator is charged.
					
					Create a COO with an INCO Term, this should charge from the COO date to the INCO Term debtor type
					create transactions prior to the COO date. When approved all transactions are re synced from the COO date so any after should be for new debtor.
					The COO should be for the whole TI with a date prior to the CM_EDIT, 2 operators with different debtors
					
					Approve COO.
					
					The transaction invoice lines should be for the COO INCO Term debtor

					
					This test will have the INCO term of the TIs customs agent.
					
					When the COO is approved, all the transactions on the TI from the COO data onwards are resyncd and set with the INCO term, if it exists.

					COO DATE is in the PAST so edit charging should be NEW debtor
					Transactiosn before COO date should still be for OLD debtor (unchanged)

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 05AUG2024
ADO - CR 64873 TASK 65509
*/

constants
	InvType_Edit = "UT_COOEDIT";
	CalType_Code_Edit = "UT_CALTYPE_COO";
	CalType_Desc_Edit = "UT_CalType_COO_Desc";
	Srvc_COOEdit = "UT_SRVC_COOEDT";
	InvLineType_Code = "UT_COOEDT";
	Debtor_Type = "SDT1";
	TransType_Edit = "Edited";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	DebtorEdit = "DSTR";
	DebtorCA = "CADT";
	OperatorEdit = "DSTR";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	values		: ObjectArray;
	criteria	: IntegerArray;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew, debtorCA : CM_Debtor;
	trans : CM_TITransactionSet;
	incoTerm : CM_InvoiceINCOTerm;
	debtorType : CM_DebtorType;
	customsAgent : CM_CustomsAgent;
	invLineSet : CM_InvoiceLineDescSet;
	moveTS : TimeStamp;
begin

	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");

	
	
	
	self.deleteDebtor(DebtorCA);
	debtorCA := self.addDebtor(DebtorCA, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(DebtorCA,"Debtor debtorCA Create Failed");
	customsAgent := self.addCustomsAgent("UTCA1", "UTCA1 Desc");
	beginTransaction;
	customsAgent.setDebtor(debtorCA);
	commitTransaction;
	
	// ### INCO
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	self.deleteInvINCOTerm("UTINCO");
	incoTerm := self.createInvoiceINCOTerm("UTINCO","Unit Test INCO Term", self.myBank);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
																				
	
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
																				
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	

	// #########################################
	// ##### INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOEdit);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Edit);

	invType := self.createInvoiceType(InvType_Edit, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Edit &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Edit, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Edit,
										   CalType_Desc_Edit, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Edit &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOEdit, Srvc_COOEdit, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOEdit &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorCA,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	// ### INCO Mapping
	create invLineSet transient;
	invLineSet.add(invLineType);
	self.createInvoiceINCOTermMapping(debtorType,incoTerm,invLineSet);
	
	
	
	
	self.loadTransMapINCO(TransMap_UT, TransType_Edit, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, incoTerm, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // Includes a Storage Debtor  // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	self.assertTrueMsg(cooHeader1.myIncoterm = incoTerm, "COO 100 incoTerm is wrong");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
		
		
		self.createTransaction(ti, TRANS_TYPE_CURTAIN, cooTS.addDays(-20));
	endforeach;

	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	
	// #########################################
	// ##### EDIT all cargo on Ship
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in tiSet do
		self.updateTI(ti);
	endforeach;

	foreach ti in tiSet do
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "Edit charge after COO should be for " &amp; debtorOld.name);
		
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_CURTAIN);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No CURTAIN transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_CURTAIN, "No CURTAIN transaction for " &amp; ti.id);
		
		
	endforeach;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		// Check Operator
		self.assertTrueMsg(ti.operatorCode = OperatorNew, ti.id &amp; " has incorrect new operator code. Is " &amp; ti.operatorCode &amp; " should be " &amp; OperatorNew);
		
		self.assertTrueMsg(ti.incoTermCode = "UTINCO", ti.id &amp; " INCO Term is wrong on TI");
		
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.last;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorCA, "Edit charge after COO should be for NEW debtor =  " &amp; debtorCA.name);
		
		
		
		
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_CURTAIN);
		transaction := trans.last;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No CURTAIN transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_CURTAIN, "No CURTAIN transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No CURTAIN charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "CURTAIN charge after COO should be for OLD debtor = " &amp; debtorOld.name);
		
	endforeach;
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	self.deleteInvINCOTerm("UTINCO");
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteCustomsAgent("UTCA1");
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete invLineSet;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1
	

	delete criteriaTypes;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeINCO04" id="59f8b1e5-b218-4e66-b59c-e4825b7783ef">
        <source>tOwnershipChangeINCO04();
/*

Purpose:		COO INCO Testing. This will be for any TI transaction type. Charge to the COO INCO TERM DEBTOR.
					INCO can have any type of invoice line, not just storage.

					This test will use the edit transaction. Need invoicing for EDIT transaction to create invoice lines
					
					create TIs. edit so that the current operator is charged.
					
					Create a COO with an INCO Term, this should charge from the COO date to the INCO Term debtor type
					The COO should be for the whole TI with a date prior to the CM_EDIT, 2 operators with different debtors
					
					Approve COO.
					
					The transaction invoice lines should be for the COO INCO Term debtor
					
					This test will have the INCO term of the COO OLD Operator.
					
					When the COO is approved, all the transactions on the TI from the COO data onwards are resyncd and set with the INCO term, if it exists.
					
					COO DATE is in the PAST so edit charging should be changed to the INCO debtor which is the OLD COO operator

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 05AUG2024
ADO - CR 64873 TASK 65509
*/

constants
	InvType_Edit = "UT_COOEDIT";
	CalType_Code_Edit = "UT_CALTYPE_COO";
	CalType_Desc_Edit = "UT_CalType_COO_Desc";
	Srvc_COOEdit = "UT_SRVC_COOEDT";
	InvLineType_Code = "UT_COOEDT";
	Debtor_Type = "SDT1";
	TransType_Edit = "Edited";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	DebtorEdit = "DSTR";
	DebtorCA = "CADT";
	OperatorEdit = "DSTR";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	values		: ObjectArray;
	criteria	: IntegerArray;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew, debtorCA : CM_Debtor;
	trans : CM_TITransactionSet;
	incoTerm : CM_InvoiceINCOTerm;
	debtorType : CM_DebtorType;
	customsAgent : CM_CustomsAgent;
	invLineSet : CM_InvoiceLineDescSet;
	moveTS : TimeStamp;
begin

	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");

	
	
	
	self.deleteDebtor(DebtorCA);
	debtorCA := self.addDebtor(DebtorCA, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(DebtorCA,"Debtor debtorCA Create Failed");
	customsAgent := self.addCustomsAgent("UTCA1", "UTCA1 Desc");
	beginTransaction;
	customsAgent.setDebtor(debtorCA);
	commitTransaction;
	
	// ### INCO
	debtorType := app.myRoot.allDebtorTypes["SDT18"];	// COO OLD Operator
	self.deleteInvINCOTerm("UTINCO");
	incoTerm := self.createInvoiceINCOTerm("UTINCO","Unit Test INCO Term", self.myBank);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
																				
	
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
																				
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	

	// #########################################
	// ##### INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOEdit);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Edit);

	invType := self.createInvoiceType(InvType_Edit, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Edit &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Edit, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Edit,
										   CalType_Desc_Edit, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Edit &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOEdit, Srvc_COOEdit, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOEdit &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorCA,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	// ### INCO Mapping
	create invLineSet transient;
	invLineSet.add(invLineType);
	self.createInvoiceINCOTermMapping(debtorType,incoTerm,invLineSet);
	
	
	
	
	self.loadTransMapINCO(TransMap_UT, TransType_Edit, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, incoTerm, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // Includes a Storage Debtor  // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	self.assertTrueMsg(cooHeader1.myIncoterm = incoTerm, "COO 100 incoTerm is wrong");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	
	// #########################################
	// ##### EDIT all cargo on Ship
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in tiSet do
		self.updateTI(ti);
	endforeach;

	foreach ti in tiSet do
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "OLD Edit charge after COO should be for " &amp; debtorOld.name);
	endforeach;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		// Check Operator
		self.assertTrueMsg(ti.operatorCode = OperatorNew, ti.id &amp; " has incorrect new operator code. Is " &amp; ti.operatorCode &amp; " should be " &amp; OperatorNew);
		
		self.assertTrueMsg(ti.incoTermCode = "UTINCO", ti.id &amp; " INCO Term is wrong on TI");
		
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.last;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "OD Edit charge after COO should be for " &amp; debtorOld.name);
		
	endforeach;
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	self.deleteInvINCOTerm("UTINCO");
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteCustomsAgent("UTCA1");
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete invLineSet;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1
	

	delete criteriaTypes;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeINCO05" id="22284c4d-1e33-4842-88d0-49b0719c67a7">
        <source>tOwnershipChangeINCO05();
/*

Purpose:		COO INCO Testing. This will be for any TI transaction type. Charge to the COO INCO TERM DEBTOR.
					INCO can have any type of invoice line, not just storage.

					This test will use the edit transaction. Need invoicing for EDIT transaction to create invoice lines
					
					create TIs. edit so that the current operator is charged.
					
					Create a COO with an INCO Term, this should charge from the COO date to the INCO Term debtor type
					The COO should be for the whole TI with a date prior to the CM_EDIT, 2 operators with different debtors
					
					Approve COO.
					
					The transaction invoice lines should be for the COO INCO Term debtor
					
					This test will have the INCO term of the COO NEW Operator.
					
					When the COO is approved, all the transactions on the TI from the COO data onwards are resyncd and set with the INCO term, if it exists.
					
					COO DATE is in the PAST so edit charging should be changed to the INCO debtor which is the NEW COO operator

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 05AUG2024
ADO - CR 64873 TASK 65509
*/

constants
	InvType_Edit = "UT_COOEDIT";
	CalType_Code_Edit = "UT_CALTYPE_COO";
	CalType_Desc_Edit = "UT_CalType_COO_Desc";
	Srvc_COOEdit = "UT_SRVC_COOEDT";
	InvLineType_Code = "UT_COOEDT";
	Debtor_Type = "SDT1";
	TransType_Edit = "Edited";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	DebtorEdit = "DSTR";
	DebtorCA = "CADT";
	OperatorEdit = "DSTR";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	values		: ObjectArray;
	criteria	: IntegerArray;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew, debtorCA : CM_Debtor;
	trans : CM_TITransactionSet;
	incoTerm : CM_InvoiceINCOTerm;
	debtorType : CM_DebtorType;
	customsAgent : CM_CustomsAgent;
	invLineSet : CM_InvoiceLineDescSet;
	moveTS : TimeStamp;
begin

	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");

	
	
	
	self.deleteDebtor(DebtorCA);
	debtorCA := self.addDebtor(DebtorCA, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(DebtorCA,"Debtor debtorCA Create Failed");
	customsAgent := self.addCustomsAgent("UTCA1", "UTCA1 Desc");
	beginTransaction;
	customsAgent.setDebtor(debtorCA);
	commitTransaction;
	
	// ### INCO
	debtorType := app.myRoot.allDebtorTypes["SDT19"];	// COO NEW Operator
	self.deleteInvINCOTerm("UTINCO");
	incoTerm := self.createInvoiceINCOTerm("UTINCO","Unit Test INCO Term", self.myBank);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
																				
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
																				
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	

	// #########################################
	// ##### INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOEdit);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Edit);

	invType := self.createInvoiceType(InvType_Edit, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Edit &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Edit, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Edit,
										   CalType_Desc_Edit, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Edit &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOEdit, Srvc_COOEdit, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOEdit &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorCA,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	// ### INCO Mapping
	create invLineSet transient;
	invLineSet.add(invLineType);
	self.createInvoiceINCOTermMapping(debtorType,incoTerm,invLineSet);
	
	
	
	
	self.loadTransMapINCO(TransMap_UT, TransType_Edit, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, incoTerm, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // Includes a Storage Debtor  // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	self.assertTrueMsg(cooHeader1.myIncoterm = incoTerm, "COO 100 incoTerm is wrong");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	
	// #########################################
	// ##### EDIT all cargo on Ship
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in tiSet do
		self.updateTI(ti);
	endforeach;

	foreach ti in tiSet do
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "OLD Edit charge after COO should be for " &amp; debtorOld.name);
	endforeach;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		// Check Operator
		self.assertTrueMsg(ti.operatorCode = OperatorNew, ti.id &amp; " has incorrect new operator code. Is " &amp; ti.operatorCode &amp; " should be " &amp; OperatorNew);
		
		self.assertTrueMsg(ti.incoTermCode = "UTINCO", ti.id &amp; " INCO Term is wrong on TI");
		
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.last;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorNew, "DN Edit charge after COO should be for " &amp; debtorNew.name);
		
	endforeach;
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	self.deleteInvINCOTerm("UTINCO");
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteCustomsAgent("UTCA1");
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete invLineSet;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1
	

	delete criteriaTypes;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeINCO06" id="227dc967-2855-43c7-81e1-942a3bd8d407">
        <source>tOwnershipChangeINCO06();
/*

Purpose:		COO INCO Testing. This will be for any TI transaction type. Charge to the COO INCO TERM DEBTOR.
					INCO can have any type of invoice line, not just storage.

					This test will use the edit transaction. Need invoicing for EDIT transaction to create invoice lines
					
					create TIs. edit so that the current operator is charged.
					
					Create a COO with NO INCO Term.
					
					The COO should be for the whole TI with a date prior to the CM_EDIT.
					
					Approve COO.
					
					The transaction invoice lines should be for the original debtor, unchanged becasue there was no INCO set.
					
					This test will have NO INCO term. Shoudl just do normal debtor deriving.
					
					When the COO is approved, all the transactions on the TI from the COO data onwards are resyncd and set with the INCO term, if it exists. In this case there is no INCO term.
					
					COO DATE is in the PAST so edit charging should not change from the old exisitng debtor

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 05AUG2024
ADO - CR 64873 TASK 65509
*/

constants
	InvType_Edit = "UT_COOEDIT";
	CalType_Code_Edit = "UT_CALTYPE_COO";
	CalType_Desc_Edit = "UT_CalType_COO_Desc";
	Srvc_COOEdit = "UT_SRVC_COOEDT";
	InvLineType_Code = "UT_COOEDT";
	Debtor_Type = "SDT1";
	TransType_Edit = "Edited";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	DebtorEdit = "DSTR";
	DebtorCA = "CADT";
	OperatorEdit = "DSTR";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	values		: ObjectArray;
	criteria	: IntegerArray;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew, debtorCA : CM_Debtor;
	trans : CM_TITransactionSet;
	customsAgent : CM_CustomsAgent;
	invLineSet : CM_InvoiceLineDescSet;
	moveTS : TimeStamp;
begin

	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");

	
	
	
	self.deleteDebtor(DebtorCA);
	debtorCA := self.addDebtor(DebtorCA, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(DebtorCA,"Debtor debtorCA Create Failed");
	customsAgent := self.addCustomsAgent("UTCA1", "UTCA1 Desc");
	beginTransaction;
	customsAgent.setDebtor(debtorCA);
	commitTransaction;
	
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
																				
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
																				
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	

	// #########################################
	// ##### INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOEdit);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Edit);

	invType := self.createInvoiceType(InvType_Edit, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Edit &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Edit, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Edit,
										   CalType_Desc_Edit, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Edit &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOEdit, Srvc_COOEdit, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOEdit &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorCA,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMapINCO(TransMap_UT, TransType_Edit, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // Includes a Storage Debtor  // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	self.assertTrueMsg(cooHeader1.myIncoterm = null, "COO 100 incoTerm is wrong");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	
	// #########################################
	// ##### EDIT all cargo on Ship
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in tiSet do
		self.updateTI(ti);
	endforeach;

	foreach ti in tiSet do
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "OLD Edit charge after COO should be for " &amp; debtorOld.name);
	endforeach;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		// Check Operator
		self.assertTrueMsg(ti.operatorCode = OperatorNew, ti.id &amp; " has incorrect new operator code. Is " &amp; ti.operatorCode &amp; " should be " &amp; OperatorNew);
		
		self.assertTrueMsg(ti.incoTermCode = "", ti.id &amp; " INCO Term is wrong on TI");
		
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_EDIT);
		transaction := trans.last;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Edit transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_EDIT, "No Edit transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Edit charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorNew, "DN Edit charge after COO should be for " &amp; debtorNew.name);
		
	endforeach;
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteCustomsAgent("UTCA1");
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete invLineSet;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1
	

	delete criteriaTypes;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeInvContractId" id="f53bb753-03e5-48af-a58c-d2921f9cc64c">
        <updating/>
        <source>tOwnershipChangeInvContractId() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2024	navra1	Initial creation for //navra1 - TFS 64874 - 14th Aug 2024

*/

constants
	InvType_Edit = "UT_COOEDIT";
	CalType_Code_Edit = "UT_CALTYPE_COO";
	CalType_Desc_Edit = "UT_CalType_COO_Desc";
	Srvc_COOEdit = "UT_SRVC_COOEDT";
	InvLineType_Code = "UT_COOEDT";
	Debtor_Type = "SDT1";
	TransType_Edit = "Edited";
	TransMap_UT = "UtTransMap";
	DebtorNew = "DC-N";
	OperatorNew = "OC-N";
	DebtorEdit = "DSTR";
	DebtorCA = "CADT";
	OperatorEdit = "DSTR";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
vars
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	values		: ObjectArray;
	criteria	: IntegerArray;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew, debtorCA : CM_Debtor;
	trans : CM_TITransactionSet;
	incoTerm : CM_InvoiceINCOTerm;
	debtorType : CM_DebtorType;
	customsAgent : CM_CustomsAgent;
	invLineSet : CM_InvoiceLineDescSet;
	moveTS : TimeStamp;
	oldCon, newCon, oldConNewOp : CM_InvoiceContract;
	fromTS, toTS : TimeStamp;	
	trx : CM_TITransaction;
begin

	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-2);
	toTS := fromTS.addDays(6);

	oldCon := self.createContract(operatorOld.debtor, 'OLD-CONTRACTID',false,false, fromTS, toTS, true);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
	
	newCon := self.createContract(operatorNew.debtor, 'NEW-CONTRACTID',true,false, fromTS, toTS, true);
	oldConNewOp := self.createContract(operatorNew.debtor, 'OLD-CONTRACTID',false,false, fromTS, toTS, false);	
	
	self.deleteDebtor(DebtorCA);
	debtorCA := self.addDebtor(DebtorCA, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(DebtorCA,"Debtor debtorCA Create Failed");
	customsAgent := self.addCustomsAgent("UTCA1", "UTCA1 Desc");
	beginTransaction;
	customsAgent.setDebtor(debtorCA);
	commitTransaction;	
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
																				
	
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
																				
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	numTiToCreate := 2;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, incoTerm, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), newCon); // Includes a Storage Debtor  // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	self.assertTrueMsg(cooHeader1.myIncoterm = incoTerm, "COO 100 incoTerm is wrong");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "OLD-CONTRACTID", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);	
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;	
	
	//==check 1==
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		foreach trx in ti.allTransactions do
			if trx.operatorCode = OperatorNew then
				assertEqualMsg(trx.contractId, "NEW-CONTRACTID", "Transactions contractid is not as expected");
			elseif ti.operatorCode = operatorOld.code then
				if trx.contractId &lt;&gt; null then
					assertEqualMsg(trx.contractId, "OLD-CONTRACTID", "Transactions contractid is not as expected");				
				endif;		
			endif;
		endforeach;		
	endforeach;
	
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in tiSet do
		self.updateTI(ti);
	endforeach;	
	
	//===check 2 ====
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		foreach trx in ti.allTransactions do
			if trx.operatorCode = OperatorNew then
				assertEqualMsg(trx.contractId, "NEW-CONTRACTID", "Transactions contractid is not as expected");
			elseif ti.operatorCode = operatorOld.code then
				if trx.contractId &lt;&gt; null then
					assertEqualMsg(trx.contractId, "OLD-CONTRACTID", "Transactions contractid is not as expected");				
				endif;			
			endif;
		endforeach;		
	endforeach;
	
	//approve COO	
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		foreach trx in ti.allTransactions do
			if trx.operatorCode = OperatorNew then
				assertEqualMsg(trx.contractId, "NEW-CONTRACTID", "Transactions contractid is not as expected");
			elseif ti.operatorCode = operatorOld.code then
			if trx.contractId &lt;&gt; null then
					assertEqualMsg(trx.contractId, "OLD-CONTRACTID", "Transactions contractid is not as expected");				
				endif;
			endif;			
		endforeach;		
	endforeach;
	
	//clean up
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	self.deleteInvINCOTerm("UTINCO");
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteCustomsAgent("UTCA1");
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete invLineSet;
	delete trans;
	

	delete criteriaTypes;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeNewIDLocation" id="fb7e98c4-a72e-4ab3-bb88-96e0ea3265c8">
        <source>tOwnershipChangeNewIDLocation();
/*

Purpose:			This UT tests the split approval of COO with New ID and Location entered.

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

constants
	VESSEL				= "UT58254";
	VOYAGE				= "UT58254";
	CARGOTYPEDESC 		= "UT58254";
	CGID1				= "CG58254-1";
	CGID2				= "CG58254-2";
	STOPTABLE			= 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
	NEWLOCATION			= "50699 1";
vars
	cargoGroup,
	cargoGroup2		: CM_CargoGroup;
	splitTI,
	tiToExclFromCOO,
	ti				: CM_TrackedItem;
	newOperator,
	operator		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1,
	cooHeader2		: CM_OwnershipChange;
	pxyCooDetails,
	subCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	pxyStopCriteria	: CM_StopCriteria;
	pxyStopTemp		: CM_StopTableTemplate;	
	pxyStopTable,
	realStop		: CM_StopsTable;
	tisToDelete,
	tiSet			: CM_TISet;
	
	tiId,
	opCode,
	newOpCode		: String;	
	i,
	transferQty,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	transferWeight,
	transferVol,
	weight			: Decimal[23,4];	
	now				: TimeStamp;	
	include			: Boolean;
	stopCheckArray,
	stopProcessArray,
	stopsSetArray	: IntegerArray;
	allOpsForStop	: ObjectSet;
	cmifAgent,
	cmifAgent2		: CMIF_COOAgent;
begin
	create cmifAgent transient;
	create cmifAgent2 transient;
	create tiSet transient;
	create tisToDelete transient;
	create pxyStopCriteria transient;
	create pxyStopTable transient;
	create pxyStopTemp transient;
	create stopsSetArray transient;
	create stopCheckArray transient;
	create stopProcessArray transient;
	create allOpsForStop transient;
	
	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	//self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operator := self.getOperator(opCode);
	
	newOpCode := "KCOP";
	newOperator := self.getOperator(newOpCode);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, newOperator); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	// Stops
	allOpsForStop.add(newOperator);
	stopsSetArray.add(StopApplyImport);
	self.deleteStopsTable(STOPTABLE);
	pxyStopCriteria.setMyStopTable(pxyStopTable);
	pxyStopCriteria.createStopCriteria(allOpsForStop, YACriteriaType_OperatorItem, pxyStopCriteria);
	pxyStopTemp.setProxy(stopCheckArray, stopsSetArray, stopProcessArray, null, false, false, false, false, false, false, false, false);
	pxyStopTemp.setPropertyValue("myStopTable", pxyStopTable);
	pxyStopTemp.setPropertyValue("myTerminal", self.getMyTerminal());
	pxyStopTable.setProxy(false, STOPTABLE.String, STOPTABLE.String, STOPTABLE.String,0, STOPTABLE, null, false, true, app.myRoot, null, null, null);
	app.myTrxCA.trxCreateStopsTable(pxyStopTable, realStop, app.myPassport);
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	
	transferQty := 2;
	transferVol := 100;
	transferWeight := 100;
	/*================================
	COO Header 1
	has 5 COO Details
	Each TI has one
	================================*/
	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO1", null, null, app.getMyUserCode(), now, null, now, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 1 is null");
	
	// Create Cargo in Cargo Group 1
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3) &amp; "A";
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		tisToDelete.add(ti);
		
		// Exclude this from COO for testing later.
		if i = 5 then
			tiToExclFromCOO := ti;
			include := false;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(transferWeight, transferVol, transferQty, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;
	self.deleteCargoGroup(CGID1);
	cargoGroup 	:= self.addCargoGroup(CGID1, tiSet);
	cooHeader1.doCreateCMIFAgent(cmifAgent);
	cmifAgent.newLocation := NEWLOCATION;
	/*================================
	COO Header 2
	has 1 COO details of the Cargo Group
	COO Details has 5 sub details for TI
	================================*/
	
	
	// Create Ownership change 2
	delete pxyCooHeader;
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO2", null, null, app.getMyUserCode(), now, null, now, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader2);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 2 is null");
	
	// Create Cargo in Cargo Group 2
	tiSet.clear();
	foreach i in 1 to numTiToCreate do
		tiId := "CG2-" &amp; i.padLeadingWith("0", 3) &amp; "A";
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		ti.setMyCargoGroup(cargoGroup2, app.myPassport);
		tiSet.add(ti);
		tisToDelete.add(ti);
	endforeach;
	self.deleteCargoGroup(CGID2);
	cargoGroup2	:= self.addCargoGroup(CGID2, tiSet);
	
	// Create Ownership Details for Cargo Group
	delete pxyCooDetails;
	create pxyCooDetails transient;
	pxyCooDetails.setProxy(weight, volume, quantity, true, cooHeader2, null, cargoGroup2);
	self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
	self.assertTrueMsg(cooDetails &lt;&gt; null, cargoGroup2.id &amp; " does not have COO details created");
	
	// Create Ownership SUB details for TI in Cargo Group
	foreach ti in cargoGroup2.allAssignedTrackedItems do
		
		if ti = tiToExclFromCOO then
			continue;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		pxyCooDetails.setProxy(transferWeight, transferVol, transferQty, true, null, cooDetails, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, subCooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, ti.id &amp; " does not have COO details created");
	endforeach;
	cooHeader2.doCreateCMIFAgent(cmifAgent2);
	cmifAgent2.newLocation := NEWLOCATION;
	// Move all cargo to Yard
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tisToDelete do
		self.deleteStops(ti);
	endforeach;
	
	// Now Approve COO 1
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 1 - ");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	// Check Cargo Group 1 has correct Operator collection
	self.assertTrueMsg(cargoGroup.allOperators.includes(newOperator), cargoGroup.id &amp; " has incorrect allOperators collection");
	self.assertTrueMsg(cargoGroup.allOperators.includes(operator), cargoGroup.id &amp; " has incorrect allOperators collection");
	// Check cargo group 1 has COO transaction
	transaction := cargoGroup.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
	self.assertTrueMsg(transaction &lt;&gt; null, cargoGroup.id &amp; " does not have Ownership Changed Transaction created");
	// Check TIs in Cargo Group 1
	//foreach ti in cargoGroup.allAssignedTrackedItems do
	i := 0;
	foreach cooDetails in cooHeader1.allDetails do
		i += 1;
		ti := cooDetails.myTrackedItem;
		//splitTI := self.getTrackedItem("COO1-0" &amp; i.String);
		splitTI := self.getTrackedItem(ti.id &amp; "-01");
		// This is the TI that was excluded, it shouldn't have anything changed
		if ti = tiToExclFromCOO then
			// Should not have a TI splitted 
			self.assertTrueMsg(splitTI = null, ti.id &amp; " should not have a split TI");
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = opCode, ti.id &amp; " should not have the new operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction = null, ti.id &amp; " should not have Ownership Changed Transaction created");
			// Should not have stops
			self.assertTrueMsg(not ti.hasStopOfType(realStop), ti.id &amp; " should not have Stop set.");
			// Quantity shouldn't have changed
			self.assertTrueMsg(ti.totalQuantity = quantity, ti.id &amp; " has incorrect quantity");
		// These are included in the COO, should have new operators etc..
		else
			// We should have new TI splitted
			self.assertTrueMsg(splitTI &lt;&gt; null, ti.id &amp; " doesn't have a split TI");
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = operator.code, ti.id &amp; " has incorrect operator code");
			self.assertTrueMsg(splitTI.operatorCode = newOperator.code, splitTI.id &amp; " has incorrect new operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, ti.id &amp; " does not have Ownership Changed Transaction created");
			transaction := splitTI.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, splitTI.id &amp; " does not have Ownership Changed Transaction created");
			// Should have stops applied
			self.assertTrueMsg(not ti.hasStopOfType(realStop), ti.id &amp; " should not have Stop set.");
			self.assertTrueMsg(splitTI.hasStopOfType(realStop), splitTI.id &amp; " should not have Stop set.");
			// Check Quantity
			self.assertTrueMsg(ti.totalQuantity = quantity - transferQty, ti.id &amp; " has incorrect quantity");
			self.assertTrueMsg(splitTI.totalQuantity = transferQty, splitTI.id &amp; " has incorrect quantity");
			// Check Location
			self.assertTrueMsg(splitTI.locationId = NEWLOCATION, splitTI.id &amp; " has incorrect location ID");
		endif;
	endforeach;
	
	// Now Approve COO 2
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader2, app.myPassport, cmifAgent2);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 2 - ");
	// Check COO approved status
	self.assertTrueMsg(cooHeader2.dateTimeApproved.isValid(), "cooHeader2 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader2.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	// Check Cargo Group 2
	self.assertTrueMsg(cargoGroup2.allOperators.includes(newOperator), cargoGroup2.id &amp; " has incorrect allOperators collection");
	// Check Cargo group 2 has COO transaction
	transaction := cargoGroup2.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
	self.assertTrueMsg(transaction &lt;&gt; null, cargoGroup2.id &amp; " does not have Ownership Changed Transaction created");
	i := 0;
	// Check TIs in Cargo Group 2
	foreach cooDetails in cooHeader2.allDetails do
		foreach subCooDetails in cooDetails.allSubDetails do
			//i += 1;
			ti := subCooDetails.myTrackedItem;
			//splitTI := self.getTrackedItem("COO2-0"&amp; i.String);
			splitTI := self.getTrackedItem(ti.id &amp; "-01");
			// We should have new TI splitted
			self.assertTrueMsg(splitTI &lt;&gt; null, ti.id &amp; " doesn't have a split TI");
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = operator.code, ti.id &amp; " has incorrect operator code");
			self.assertTrueMsg(splitTI.operatorCode = newOperator.code, splitTI.id &amp; " has incorrect new operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, ti.id &amp; " does not have Ownership Changed Transaction created");
			transaction := splitTI.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, splitTI.id &amp; " does not have Ownership Changed Transaction created");
			// Should have stops applied
			self.assertTrueMsg(not ti.hasStopOfType(realStop), ti.id &amp; " should not have Stop set.");
			self.assertTrueMsg(splitTI.hasStopOfType(realStop), splitTI.id &amp; " should not have Stop set.");
			// Check Quantity
			self.assertTrueMsg(ti.totalQuantity = quantity - transferQty, ti.id &amp; " has incorrect quantity");
			self.assertTrueMsg(splitTI.totalQuantity = transferQty, splitTI.id &amp; " has incorrect quantity");
			// Check Location
			self.assertTrueMsg(splitTI.locationId = NEWLOCATION, splitTI.id &amp; " has incorrect location ID");
		endforeach;
	endforeach;
epilog
	
	foreach ti in tisToDelete do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	self.deleteCargoGroup(CGID1);
	self.deleteCargoGroup(CGID2);
	
	if cooHeader1 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader1);
	endif;
	if cooHeader2 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader2);
	endif;
	
	delete tiSet;
	delete tisToDelete;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete pxyStopCriteria;
	delete pxyStopTemp;
	delete pxyStopTable;
	delete stopsSetArray;
	delete stopCheckArray;
	delete stopProcessArray;
	delete allOpsForStop;
	delete cmifAgent;
	delete cmifAgent2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangePostedInvEmail" id="03ae58ae-1b9a-4fd4-9433-d76ff5025ea6">
        <source>tOwnershipChangePostedInvEmail();
/*

Purpose:			This UT tests that Change of Ownership creates a COO financial objects for FS Storage posted invoice lines.		

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58261 Task 61101: Jade - Unit Tests

*/

constants
	VESSEL				= "UT58261";
	VOYAGE				= "UT58261";
	CARGOTYPEDESC 		= "UT58261";
	CGID1				= "CG58261-1A";
	CGID2				= "CG58262-2A";
	STOPTABLE			= 58261;
	TAGROUP				= "UT58261";
vars
	cargoGroup,
	cargoGroup2		: CM_CargoGroup;
	tiToExclFromCOO,
	ti				: CM_TrackedItem;
	newOperator,
	operator		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1,
	cooHeader2		: CM_OwnershipChange;
	pxyCooDetails,
	subCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	pxyStopCriteria	: CM_StopCriteria;
	pxyStopTemp		: CM_StopTableTemplate;	
	pxyStopTable,
	realStop		: CM_StopsTable;
	tisToDelete,
	allTis,
	tiSet			: CM_TISet;
	terminal		: CM_Terminal;
	storageConfig	: CM_StorageConfig;
	storageDetail	: CM_StorageDetail;
	taStorageGroup	: CM_TerminalAreaStorageGroup;
	terminalAreas	: CM_TerminalAreaArray;
	invLineType		: CM_InvoiceLineDesc;
	fsm				: CM_FutureStorageMapping;
	invLineTypeArray: CM_InvoiceLineDescArray;
	invoiceLine		: CM_InvoiceLine;
	cmifAgent,
	cmifAgent2		: CMIF_COOAgent;
	invoice,
	invoice2		: CM_Invoice;
	
	tiId,
	opCode,
	newOpCode		: String;	
	cg1InvCounter,
	cg2InvCounter,
	i,
	transferQty,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	transferWeight,
	transferVol,
	weight			: Decimal[23,4];	
	daysAgo15,
	lastMonth,
	now				: TimeStamp;	
	include			: Boolean;
	stopCheckArray,
	stopProcessArray,
	storageDtlCriteria,
	stopsSetArray	: IntegerArray;
	allOpsForStop	: ObjectSet;
	storageDtlCritV : ObjectArray;
	
begin
	
	create cmifAgent transient;
	create cmifAgent2 transient;
	create tiSet transient;
	create tisToDelete transient;
	create pxyStopCriteria transient;
	create pxyStopTable transient;
	create pxyStopTemp transient;
	create stopsSetArray transient;
	create stopCheckArray transient;
	create stopProcessArray transient;
	create allOpsForStop transient;
	create terminalAreas transient;
	create storageDtlCriteria transient;
	create storageDtlCritV transient;
	create invLineTypeArray transient;
	create allTis transient;
	
	daysAgo15 := now;
	daysAgo15.setDate(daysAgo15.date()-15);
	lastMonth := now;
	lastMonth.setDate(lastMonth.date() - 30);
	
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operator := self.getOperator(opCode);
	
	newOpCode := "KCOP";
	newOperator := self.getOperator(newOpCode);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, newOperator); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58261TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	// Stops
	allOpsForStop.add(newOperator);
	stopsSetArray.add(StopApplyImport);
	self.deleteStopsTable(STOPTABLE);
	pxyStopCriteria.setMyStopTable(pxyStopTable);
	pxyStopCriteria.createStopCriteria(allOpsForStop, YACriteriaType_OperatorItem, pxyStopCriteria);
	pxyStopTemp.setProxy(stopCheckArray, stopsSetArray, stopProcessArray, null, false, false, false, false, false, false, false, false);
	pxyStopTemp.setPropertyValue("myStopTable", pxyStopTable);
	pxyStopTemp.setPropertyValue("myTerminal", self.getMyTerminal());
	pxyStopTable.setProxy(false, STOPTABLE.String, STOPTABLE.String, STOPTABLE.String,0, STOPTABLE, null, false, true, app.myRoot, null, null, null);
	app.myTrxCA.trxCreateStopsTable(pxyStopTable, realStop, app.myPassport);
	
	terminal := self.getMyTerminal();
	
	// Storage Config
	self.deleteStorageConfig(true);
	storageConfig := terminal.myStorageConfig;
	
	// Storage Detail
	storageDtlCriteria.add(YACriteriaType_CargoType);
	storageDtlCritV.add(self.getCargoType(CARGOTYPEDESC));
	
	storageDetail := self.addStorageDetail(storageConfig, "UT" &amp; method.name, storageDtlCriteria, storageDtlCritV, 2, 5, false, false, 0, 0, false, null);
	
	// Terminal Area Storage Group
	self.deleteTerminalAreaStorageGroup(TAGROUP);
	
	terminalAreas.add(terminalArea);
	taStorageGroup := self.addTerminalAreaStorageGroup(TAGROUP, TAGROUP, terminalAreas);
	invLineType := self.getInvoiceLineType("UTSSMinChg");
	invLineTypeArray.add(invLineType);
	
	// Future Storage mapping
	fsm := self.addFutureStorageMapping2(self.myBank, taStorageGroup, storageDetail, invLineType.myCalculationType, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	
	transferQty := 10;
	transferVol := 500;
	transferWeight := 500;
	/*================================
	COO Header 1
	has 5 COO Details
	Each TI has one
	================================*/
	self.deleteOwnershipChangeByRef(operator, "COO11D"); // ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1
	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO11D", null, null, app.getMyUserCode(), lastMonth, null, lastMonth, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 1 is null");
	
	// Create Cargo in Cargo Group 1
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3) &amp; "A";
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		beginTransaction;
			ti.setPropertyValue("receivedDT", lastMonth);
			foreach transaction in ti.allTransactions do
				lastMonth := transaction.dateTime;
				lastMonth.setDate(lastMonth.date()-30);
				transaction.setPropertyValue("dateTime", lastMonth);
			endforeach;
		commitTransaction;
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		tisToDelete.add(ti);
		
		// Exclude this from COO for testing later.
		if i = 5 then
			tiToExclFromCOO := ti;
			include := false;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(transferWeight, transferVol, transferQty, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;
	self.deleteCargoGroup(CGID1);
	cargoGroup 	:= self.addCargoGroup(CGID1, tiSet);
	cooHeader1.doCreateCMIFAgent(cmifAgent);
	
	/*================================
	COO Header 2
	has 1 COO details of the Cargo Group
	COO Details has 5 sub details for TI
	================================*/
	self.deleteOwnershipChangeByRef(operator, "COO22D"); // ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1
	
	
	// Create Ownership change 2
	delete pxyCooHeader;
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO22D", null, null, app.getMyUserCode(), lastMonth, null, lastMonth, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry	//navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader2);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 2 is null");
	
	// Create Cargo in Cargo Group 2
	tiSet.clear();
	foreach i in 1 to numTiToCreate do
		tiId := "CG2-" &amp; i.padLeadingWith("0", 3) &amp; "A";
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		ti.setMyCargoGroup(cargoGroup2, app.myPassport);
		tiSet.add(ti);
		tisToDelete.add(ti);
	endforeach;
	self.deleteCargoGroup(CGID2);
	cargoGroup2	:= self.addCargoGroup(CGID2, tiSet);
	
	// Create Ownership Details for Cargo Group
	delete pxyCooDetails;
	create pxyCooDetails transient;
	pxyCooDetails.setProxy(weight, volume, quantity, true, cooHeader2, null, cargoGroup2);
	self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
	self.assertTrueMsg(cooDetails &lt;&gt; null, cargoGroup2.id &amp; " does not have COO details created");
	
	// Create Ownership SUB details for TI in Cargo Group
	foreach ti in cargoGroup2.allAssignedTrackedItems do
		if ti = tiToExclFromCOO then
			continue;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		pxyCooDetails.setProxy(transferWeight, transferVol, transferQty, true, null, cooDetails, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, subCooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, ti.id &amp; " does not have COO details created");
	endforeach;
	cooHeader2.doCreateCMIFAgent(cmifAgent2);
	
	
	// Move all cargo to Yard
	self.opts.purge();
	self.opts.addAssoc("effectiveTS", lastMonth);
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tisToDelete do
		self.deleteStops(ti);
	endforeach;
	
	// Run BGP here to create the FS transactions
	self.processOfflineFutureActors(lastMonth, now);
	
	// Get the invoice and post it.
	ti := cargoGroup.allAssignedTrackedItems.first();
	transaction := ti.getLastTransOfType(TRANS_TYPE_FUTURE_STORAGE).CM_TITransaction;
	foreach invoiceLine in transaction.allInvoiceLines where invoiceLine.myTransactionTI.type = TRANS_TYPE_FUTURE_STORAGE do
		if not invoiceLine.voided then
			if invoice = null then
				invoice := invoiceLine.invoice;
				break;
			endif;
		endif;
	endforeach;
	
	ti := cargoGroup2.allAssignedTrackedItems.first();
	transaction := ti.getLastTransOfType(TRANS_TYPE_FUTURE_STORAGE).CM_TITransaction;
	foreach invoiceLine in transaction.allInvoiceLines where invoiceLine.myTransactionTI.type = TRANS_TYPE_FUTURE_STORAGE do
		if not invoiceLine.voided then
			if invoice2 = null then
				invoice2 := invoiceLine.invoice;
				break;
			endif;
		endif;
	endforeach;
	
	// Post
	self.postInvoice(invoice, false, false);
	if invoice &lt;&gt; invoice2 then
		self.postInvoice(invoice2, false, false);
	endif;
	
	// Now count how many posted invoice lines we have in each COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		foreach transaction in ti.allTransactions where transaction.type = TRANS_TYPE_FUTURE_STORAGE do
			if transaction.dateTime.date() &lt;= cooHeader1.storageExpiryOperatorNew.date() or transaction.isDeleted() then
				continue;
			endif;
			foreach invoiceLine in transaction.allInvoiceLines do
				if not invoiceLine.voided then
					if invoiceLine.invoice.isPosted() then
						cg1InvCounter += 1;
					endif;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	foreach cooDetails in cooHeader2.allDetails do
		foreach subCooDetails in cooDetails.allSubDetails do
			ti := subCooDetails.myTrackedItem;
			foreach transaction in ti.allTransactions where transaction.type = TRANS_TYPE_FUTURE_STORAGE do
				if transaction.dateTime.date() &lt;= cooHeader2.storageExpiryOperatorNew.date() or transaction.isDeleted() then
				continue;
			endif;
				foreach invoiceLine in transaction.allInvoiceLines do
					if not invoiceLine.voided then
						if invoiceLine.invoice.isPosted() then
							cg2InvCounter += 1;
						endif;
					endif;
				endforeach;
			endforeach;
		endforeach;
	endforeach;
	
	// Now Approve COO 1
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 1 - ");
	// Now check we have same number of financial issues
	self.assertTrueMsg(cooHeader1.allFinancialIssues.size() = cg1InvCounter, "cooHeader1 does not have correct number of financial issues created");
	
	// Now Approve COO 2
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader2, app.myPassport, cmifAgent2);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 2 - ");
	// Now check we have same number of financial issues
	self.assertTrueMsg(cooHeader2.allFinancialIssues.size() = cg2InvCounter, "cooHeader2 does not have correct number of financial issues created");
	
epilog
	
	if cooHeader1 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader1);
	endif;
	if cooHeader2 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader2);
	endif;
	
	self.deleteTerminalAreaStorageGroup(TAGROUP);
	
	delete tiSet;
	delete tisToDelete;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete pxyStopCriteria;
	delete pxyStopTemp;
	delete pxyStopTable;
	delete stopsSetArray;
	delete stopCheckArray;
	delete stopProcessArray;
	delete allOpsForStop;
	delete storageDtlCriteria;
	delete storageDtlCritV;
	delete terminalAreas;
	delete invLineTypeArray;
	delete allTis;
	delete cmifAgent;
	delete cmifAgent2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage01" id="7c2ab44e-0d97-4229-ab01-dfdeb98eb62a">
        <source>tOwnershipChangeRelStorage01();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage
					Need to have storage triggers.
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage.
					Edit TI to get storage trigger to create a CM_Storage whilst still on site. Check has invoice line
					
					Create a COO for whole TI with a date prior to the CM_Storage, 2 operators with different debtors
					
					Approve COO.
					
					The storage transaction should have new operator, its invoice line a new debtor

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 15JAN2024
ADO -  CR 58263 TASK 58264
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
vars
	cargoGroup		: CM_CargoGroup;
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	
	// #########################################
	// ##### EDIT TI's IMEX to trigger a CM_Storage creations
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in tiSet do
		self.updateTI(ti);
	endforeach;

	foreach ti in tiSet do
		self.assertTrueMsg(ti.isExport, ti.id &amp; " should be an EXPORT");
		trans := ti.getTransOfType(TRANS_TYPE_STORAGE);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Storage transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "Before No Storage charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "Storage charge before COO should be for " &amp; debtorOld.name);
		
		
	endforeach;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		// Check Operator
		self.assertTrueMsg(ti.operatorCode = OperatorNew, ti.id &amp; " has incorrect new operator code. Is " &amp; ti.operatorCode &amp; " should be " &amp; OperatorNew);
		
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Storage transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Storage charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorNew, "Storage charge after COO should be for " &amp; debtorNew.name);
		
	endforeach;
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage02" id="f258a092-f19b-4c2e-beae-782e1b058005">
        <source>tOwnershipChangeRelStorage02();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. Retrospective 40 days ago
					
					Create a COO for whole TI  retrospective 20 days ago, 2 operators with different debtors
					
					Approve COO.
					
					release the TI. Check that the storage upto 20 days ago is the old operator and the storage for upto now is the new operator.

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 15JAN2024
ADO -  CR 58263 TASK 58264
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 5);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Calendar_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,5,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Calendar_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  5, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO WHOLE
	// #########################################
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-20);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS.addDays(5), 0, 5, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-40);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free storage is wrong");
	
		
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 2, "TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free 1/2 storage is wrong"); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 1/2 storage operator is wrong"); 
	storageExp := ti1.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS.addDays(10).date, "TI1 Free 2/2 storage is wrong"); // Storage Detail COO has 5 and COO has 5 additional so 10
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI1 Free 2/2 storage operator is wrong"); 
	
	
	
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs on COO
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = OperatorNew, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; OperatorNew);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 4, ti1.id &amp; " should have 4 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First Storage transaction should be NOCHARGE for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage charge should be for " &amp; debtorOld.name);
	
	transaction := tranArray[3].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "Third Storage transaction should be NOCHARGE for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "Third Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	transaction := tranArray[4].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Fourth - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Fourth Storage transaction should be CHARGED for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Fourth Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Fourth Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Fourth Storage charge should be for " &amp; debtorNew.name);
		
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage03" id="2d9869ff-9e7e-4e53-b799-4bb0acef5894">
        <source>tOwnershipChangeRelStorage03();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. Retrospective 40 days ago
					
					Create a COO for part TI  retrospective 20 days ago, 2 operators with different debtors
					
					Approve COO.
					
					Check new cargo (split).
					Check 2nd storage expiry detail on new cargo
					Check no 2nd storage expiry on 'source' cargo
					
					Release the split TI. Check that the storage upto 20 days ago is the old operator and the storage for upto now is the new operator.

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 15JAN2024
ADO -  CR 58263 TASK 58264
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPAPE";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	self.deleteVehicle(TRUCKID);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	self.assertTrueMsg(cargoType &lt;&gt; null, "Cargo Type is NULL!");
	self.assertTrueMsg(cargoType.allowDuplicates = true, "Cargo Type should be splittable");
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 5);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Calendar_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,5,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Calendar_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  5, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO PARTIAL
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 12;
	volume := 50;
	weight := 500;
	cooTS := now.addDays(-20);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS.addDays(5), 0, 5, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details for 1/4 of the item
		pxyCooDetails.setProxy(weight * .25, volume * .25, (quantity * .25).Integer, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
		self.assertTrueMsg(cooDetails.transferredQuantity = (quantity * .25).Integer, tiId &amp; " does not have correct quantity on  COO details, should be " &amp; (quantity * .25).Integer.String &amp; " is " &amp; cooDetails.transferredQuantity.String);
	endforeach;

	cooHeader1.doCreateCMIFAgent(cmifAgent);
	
	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-40);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free storage is wrong");
	
		
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	ti3 := ti1.allSplitChildrenTis.first; // new split of cargo item
	self.assertTrueMsg(ti3 &lt;&gt; null, "New split TI is null");
	self.assertTrueMsg(ti3.totalQuantity = (quantity * .25).Integer, "New split TI quantity is wrong");
	
	
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free 1/2 storage is wrong"); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 1/2 storage operator is wrong"); 
	
	self.assertTrueMsg(ti3.allStorageExpiryDetails.size = 2, "TI3 storage 2 exp detail issue");
	storageExp := ti3.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI3 Free 1/2 storage is wrong"); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI3 Free 1/2 storage operator is wrong"); 
	storageExp := ti3.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS.addDays(10).date, "TI1 Free 2/2 storage is wrong"); // Storage Detail COO has 5 and COO has 5 additional so 10
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI3 Free 2/2 storage operator is wrong"); 
	
	
	
	
	
	// #########################################
	// ##### Release What is Left of 'source' Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("1 - ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check Storage for 'source' TI
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = opCode, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; opCode);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 2, ti1.id &amp; " should have 2 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "Third Storage transaction should be NOCHARGE for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "Third Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Fourth - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Fourth Storage transaction should be CHARGED for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Fourth Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Fourth Storage - No charges for  'source TI' " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Fourth Storage charge should be for " &amp; debtorOld.name);
	
	delete tranArray;
	

		
		
		
		
	
	
	
	// #########################################
	// ##### Release split Cargo to create storage transactions
	// #########################################
	
	vvr := self.createVVRForTI(TRUCKID,ti3,ti3.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti3, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti3.locationId = TRUCKID &amp; " Road", ti3.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti3.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("2 - ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check Storage for split TI
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti3.operatorCode = OperatorNew, ti3.id &amp; " has incorrect new operator code. Is " &amp; ti3.operatorCode &amp; " should be " &amp; OperatorNew);
	
	trans := ti3.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 4, ti3.id &amp; " should have 4 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti3.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First Storage transaction should be NOCHARGE for " &amp; ti3.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First Storage - has been charged, should be No Charge " &amp; ti3.id);
	
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti3.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti3.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti3.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti3.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage charge should be for " &amp; debtorOld.name);
	
	transaction := tranArray[3].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third - No Storage transaction for " &amp; ti3.id);
	self.assertTrueMsg(transaction.noCharge =  true, "Third Storage transaction should be NOCHARGE for " &amp; ti3.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "Third Storage - has been charged, should be No Charge " &amp; ti3.id);
	
	transaction := tranArray[4].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Fourth - No Storage transaction for " &amp; ti3.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Fourth Storage transaction should be CHARGED for " &amp; ti3.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Fourth Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti3.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Fourth Storage - No charges for  'split TI' " &amp; ti3.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Fourth Storage charge should be for " &amp; debtorNew.name);
				
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	tiSet.add(ti3);
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage04" id="1c014884-3663-4b71-ae28-f37afeec6af4">
        <source>tOwnershipChangeRelStorage04();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. Retrospective 40 days ago
					
					Create a COO for part TI  retrospective 20 days ago, 2 operators with different debtors
					
					Approve COO.
					
					Check new cargo (split).
					Check 2nd storage expiry detail on new cargo
					Check no 2nd storage expiry on 'source' cargo
					
					Release part of the source TI. This will create a new TI. check that all storage on teh new tI  is for the 'old' operator and debtor.
					
					Release another part of the source TI. This will create a new TI. check that all storage on teh new tI  is for the 'old' operator and debtor.
					
					Check that the storage transactions on teh source are unchanged, iei no storage transactions.
					
					
					
					Release part of the the COO created split TI. Check that the storage upto 20 days ago is the old operator and the storage for upto now is the new operator.

					Create a 2nd COO for part of the COO split new TI  retrospective 20 days ago, 2 operators with different debtors, so on approval part will have 3 storage expiry details, 1 for each operator/debtor, also the OLD operator is given an additional 5 days
							this should  change the free storage expiry for the 'old' operator.
					
					Approve COO.
					
					Check new cargo (split).
					Check 3rd storage expiry detail on new cargo
					Check no 3rd storage expiry on 'source' cargo
						
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 15JAN2024
ADO -  CR 58263 TASK 58264
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	DebtorNew2 = "OCXY";
	OperatorNew2 = "OCXY";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPAPE";
	COOREF1 = "COO199";
	COOREF2 = "COO299";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4, ti5, ti6	: CM_TrackedItem;
	operatorNew, operatorNew2,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1, cooHeader2, prevCOOHeader		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew, debtorNew2 : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);

		
	self.deleteVehicle(TRUCKID);
	

	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	self.assertTrueMsg(cargoType &lt;&gt; null, "Cargo Type is NULL!");
	self.assertTrueMsg(cargoType.allowDuplicates = true, "Cargo Type should be splittable");
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF1);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF2);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
	
	self.deleteDebtor(DebtorNew2);
	debtorNew2 := self.addDebtor(DebtorNew2, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew2,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew2);
	operatorNew2 := self.addOperator(OperatorNew2, OperatorNew2, false, 0, 0, debtorNew2, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	self.addOperatorToVoyage(voyage, operatorNew2); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 5);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Calendar_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,5,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Calendar_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  5, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO PARTIAL
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 1200;
	volume := 50;
	weight := 500;
	cooTS := now.addDays(-20);
	
	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF1, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, COOREF1 &amp; " is null");
	delete pxyCooHeader;
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details for 1/4 of the item
		pxyCooDetails.setProxy(weight * .25, volume * .25, (quantity * .25).Integer, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
		self.assertTrueMsg(cooDetails.transferredQuantity = (quantity * .25).Integer, tiId &amp; " does not have correct quantity on  COO details, should be " &amp; (quantity * .25).Integer.String &amp; " is " &amp; cooDetails.transferredQuantity.String);
	endforeach;

	cooHeader1.doCreateCMIFAgent(cmifAgent);
	
	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-40);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free storage is wrong");
	
		
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	ti3 := ti1.allSplitChildrenTis.first; // new split of cargo item
	self.assertTrueMsg(ti3 &lt;&gt; null, "New split TI is null");
	self.assertTrueMsg(ti3.totalQuantity = (quantity * .25).Integer, "New split TI quantity is wrong");
	
	
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free 1/2 storage is wrong"); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 1/2 storage operator is wrong"); 
	
	self.assertTrueMsg(ti3.allStorageExpiryDetails.size = 2, "TI3 storage 2 exp detail issue");
	storageExp := ti3.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI3 Free 1/2 storage is wrong"); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI3 Free 1/2 storage operator is wrong"); 
	storageExp := ti3.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS.addDays(5).date, "TI3 Free 2/2 storage is wrong"); // Storage Detail COO has 5 free days 
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI3 Free 2/2 storage operator is wrong"); 
	
	
	
	
	
	// #########################################
	// ##### Release part of 'source' Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,(ti1.totalQuantity * .15).Integer);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should not be TI1, we moved part of  TI1");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("1 - ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check Storage for released part of 'source' TI
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti4.operatorCode = opCode, ti4.id &amp; " has incorrect new operator code. Is " &amp; ti4.operatorCode &amp; " should be " &amp; opCode);
	
	trans := ti4.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 2, ti4.id &amp; " should have 2 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti4.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First Storage transaction should be NOCHARGE for " &amp; ti4.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First Storage - has been charged, should be No Charge " &amp; ti4.id);
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti4.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti4.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti4.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti4.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage charge should be for " &amp; debtorOld.name);
	
	delete tranArray;
	
	// source TIs storage expiry should be unchanged
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 22 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free 2 1/2 storage is wrong"); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 2 1/2 storage operator is wrong"); 

		
		
		
		
	
	
		
	
	// #########################################
	// ##### Release 2nd part of 'source' Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,(ti1.totalQuantity * .15).Integer);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti1, "TI4 should not be TI1, we moved part of the TI1");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("1 - ROAD EXIT ISSUE");
	tiSet.add(ti4);
	
	
	// #########################################
	// ##### Check Storage for released part of 'source' TI
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti4.operatorCode = opCode, ti4.id &amp; " has incorrect new operator code. Is " &amp; ti4.operatorCode &amp; " should be " &amp; opCode);
	
	trans := ti4.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 2, ti4.id &amp; " should have 2 storage transactions");
	
	tranArray.clear();
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First (T2) - No Storage transaction for " &amp; ti4.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First (T2) Storage transaction should be NOCHARGE for " &amp; ti4.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First (T2) Storage - has been charged, should be No Charge " &amp; ti4.id);
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second (T2) - No Storage transaction for " &amp; ti4.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second (T2) Storage transaction should be CHARGED for " &amp; ti4.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second (T2) Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti4.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second (T2) Storage - No charges for " &amp; ti4.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second (T2) Storage charge should be for " &amp; debtorOld.name);
	
	delete tranArray;
	
	
	// source TIs storage expiry should be unchanged
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 22 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free 2 1/2 storage is wrong"); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 2 1/2 storage operator is wrong"); 

		
		
		
		
	
	
	
	// #########################################
	// ##### Release part of the COO split Cargo to create storage transactions
	// #########################################
	
	vvr := self.createVVRForTI(TRUCKID,ti3,(ti3.totalQuantity * .33).Integer);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 &lt;&gt; ti3, "TI4 should not be TI3, we moved part of the TI");
	self.assertTrueMsg(ti4.locationId = TRUCKID &amp; " Road", ti4.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti4.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("2 - ROAD EXIT ISSUE");
	tiSet.add(ti4);
	
	
	
	// #########################################
	// ##### Check Storage for split TI
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti4.operatorCode = OperatorNew, ti4.id &amp; " has incorrect new operator code. Is " &amp; ti4.operatorCode &amp; " should be " &amp; OperatorNew);
	
	trans := ti4.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 4, ti4.id &amp; " should have 4 storage transactions");
	
	tranArray.clear();
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage (T3) transaction for " &amp; ti4.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First Storage (T3) transaction should be NOCHARGE for " &amp; ti4.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First Storage (T3) - has been charged, should be No Charge " &amp; ti4.id);
	
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second (T3) - No Storage transaction for " &amp; ti4.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage (T3) transaction should be for operator " &amp; opCode &amp; " for " &amp; ti4.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage (T3) transaction should be CHARGED for " &amp; ti4.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage (T3) - No charges for " &amp; ti4.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage (T3) charge should be for " &amp; debtorOld.name);
	
	transaction := tranArray[3].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third (T3) - No Storage transaction for " &amp; ti4.id);
	self.assertTrueMsg(transaction.noCharge =  true, "Third Storage (T3) transaction should be NOCHARGE for " &amp; ti4.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "Third Storage (T3) - has been charged, should be No Charge " &amp; ti4.id);
	
	transaction := tranArray[4].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Fourth (T3) - No Storage transaction for " &amp; ti4.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Fourth Storage (T3) transaction should be CHARGED for " &amp; ti4.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Fourth Storage (T3) transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti4.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Fourth Storage (T3) - No charges for " &amp; ti4.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Fourth Storage (T3) charge should be for " &amp; debtorNew.name);
				
				
				
				
	
	// #########################################
	// ###### CREATE COO HEADER 2
	// ###### ADD TI TO COO PARTIAL
	// #########################################
	
	cooTS := now.addDays(-10);
	
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF2, null, null, app.getMyUserCode(), cooTS, null, cooTS.addDays(5), 0, 5, 0, 0, 0, 0, null, null, null, operatorNew2, operatorNew, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry	//navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader2);
	self.assertTrueMsg(cooHeader2 &lt;&gt; null, COOREF2 &amp; " is null");
	delete pxyCooHeader;
	
	delete pxyCooDetails;
	create pxyCooDetails transient;
	
	// Create OwnerShip Change Details for 1/4 of the item
	weight := ti3.totalWeight;
	volume := ti3.totalVolume;
	quantity := ti3.totalQuantity;
	
	pxyCooDetails.setProxy(weight * .25, volume * .25, (quantity * .25).Integer, include, cooHeader2, null, ti3);
	self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
	self.assertTrueMsg(cooDetails &lt;&gt; null, ti3.id &amp; " does not have COO details created");
	self.assertTrueMsg(cooDetails.transferredQuantity = (quantity * .25).Integer, ti3.id &amp; " does not have correct quantity on  COO details, should be " &amp; (quantity * .25).Integer.String &amp; " is " &amp; cooDetails.transferredQuantity.String);

	
	
	// #########################################
	// ##### Now Approve COO 2
	// #########################################
	delete cmifAgent;
	create cmifAgent transient;
	cooHeader2.doCreateCMIFAgent(cmifAgent);			
	
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader2, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader2.dateTimeApproved.isValid(), "cooHeader2 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader2.dateTimeApproved.date() = now.date(), "cooHeader2 has incorrect approval date");
	
	ti5 := ti3.allSplitChildrenTis.last; // new split of cargo item
	self.assertTrueMsg(ti5 &lt;&gt; null, "New split TI is null");
	self.assertTrueMsg(ti5.totalQuantity = (quantity * .25).Integer, "New split TI quantity is wrong");
	
	
	self.assertTrueMsg(ti3.allStorageExpiryDetails.size = 2, "TI3 storage 2 exp detail issue");
	storageExp := ti3.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI3 COO2 Free 1/2 storage is wrong, is " &amp; storageExp.freeStorageExpiry.date.String); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI3 Free 1/2 storage operator is wrong"); 
	
	
	storageExp := ti3.allStorageExpiryDetails.last;
	prevCOOHeader := storageExp.myOwnershipChange; // as part of the approval the free days for the 'old' operator has been given 5 extra free days so the free storage expiry should have changed.
	self.assertTrueMsg(prevCOOHeader &lt;&gt; null, "TI3 prevCOOHeader is not on the storage expiry"); 
	
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI3 Free 1/2 storage operator is wrong"); 
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = prevCOOHeader.dateTimeCOO.addDays(5).date, "TI3 COO2  Free 2/2 storage is wrong, is " &amp; storageExp.freeStorageExpiry.date.String &amp; " Should be just the storage detail 5" ); // Storage detail 5 free days
	self.assertTrueMsg(storageExp.additionalStorageDays = 0, "TI3 additional days is wrong, is " &amp; storageExp.additionalStorageDays.String); 
	self.assertTrueMsg(storageExp.storageChangeReason = null, "TI3 storageChangeReason is wrong, should not be null"); 
	
	self.assertTrueMsg(ti5.allStorageExpiryDetails.size = 3, "TI5 storage 2 exp detail issue");
	storageExp := ti5.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI5 Free 1/2 storage is wrong"); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI5 Free 1/2 storage operator is wrong"); 
	storageExp := ti5.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS.addDays(10).date, "TI5 Free 2/2 storage is wrong"); // Storage Detail COO has 5 and COO has 5 additional
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew2, "TI5 Free 2/2 storage operator is wrong"); 
	self.assertTrueMsg(storageExp.additionalStorageDays = 5, "TI5 additional days is wrong, is " &amp; storageExp.additionalStorageDays.String); 
	self.assertTrueMsg(storageExp.storageChangeReason &lt;&gt; null, "TI5 storageChangeReason is wrong, should not be null"); 
	
	
	// #########################################
	// ##### Release part of the COO split Cargo to create storage transactions
	// #########################################
	
	vvr := self.createVVRForTI(TRUCKID,ti3,(ti3.totalQuantity * .33).Integer);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti6 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti6 &lt;&gt; null, "TI6 is null, should be on road job");
	self.assertTrueMsg(ti6 &lt;&gt; ti3, "TI6 should not be TI3, we moved part of the TI");
	self.assertTrueMsg(ti6.locationId = TRUCKID &amp; " Road", ti6.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti6.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("2 - ROAD EXIT ISSUE");
	tiSet.add(ti6);
	
	
	// #########################################
	// ##### Check Storage Expiry. 'old' operator was given additional 5 days, so the storage transaction for the no charge should take that into account
	// #########################################
		
	trans := ti6.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 4, ti6.id &amp; " should have 4 storage transactions");
	
	tranArray.clear();
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage (T4) transaction for " &amp; ti6.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First Storage (T4) transaction should be NOCHARGE for " &amp; ti6.id);
	self.assertTrueMsg(transaction.dateTime.date =  moveTS.addDays(4).date, "First Storage (T4) transaction has wrong date for " &amp; ti6.id); 
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First Storage (T4) - has been charged, should be No Charge " &amp; ti6.id);
	
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second (T4) - No Storage transaction for " &amp; ti6.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage (T4) transaction should be for operator " &amp; opCode &amp; " for " &amp; ti6.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage (T4) transaction should be CHARGED for " &amp; ti6.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage (T4) - No charges for " &amp; ti6.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage (T4) charge should be for " &amp; debtorOld.name);
	
	transaction := tranArray[3].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third (T4) - No Storage transaction for " &amp; ti6.id);
	self.assertTrueMsg(transaction.noCharge =  true, "Third Storage (T4) transaction should be NOCHARGE for " &amp; ti6.id);
	self.assertTrueMsg(transaction.dateTime.date =  prevCOOHeader.dateTimeCOO.addDays(5).date, "third Storage (T4) transaction has wrong date for " &amp; ti6.id); 
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "Third Storage (T4) - has been charged, should be No Charge " &amp; ti6.id);
	
	transaction := tranArray[4].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Fourth (T4) - No Storage transaction for " &amp; ti6.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Fourth Storage (T4) transaction should be CHARGED for " &amp; ti6.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Fourth Storage (T4) transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti6.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Fourth Storage (T4) - No charges for " &amp; ti6.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Fourth Storage (T4) charge should be for " &amp; debtorNew.name);
	
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	
	self.deleteVehicle(TRUCKID);
	

	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF1);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF2);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers&lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage05" id="032b53a2-d4a8-4121-860f-981cebe72b7a">
        <source>tOwnershipChangeRelStorage05();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage expiry. Retrospective 40 days. Should have 1 storage expiry detail  for OPERATOR1
					
					Create a COO for whole TI  retrospective 20 days ago, 2 operators with different debtors
					
					Approve COO, check free storage expiry. Retrospective 40 days. Should have 2  storage expiry detail ago for OPERATOR1 and OPERATOR2
					
					Create a COO for whole TI  retrospective 10 days ago, 2 operators with different debtors
					
					Approve COO, check free storage expiry. Retrospective 30 days. Should have 3  storage expiry detail ago for OPERATOR1, OPERATOR2 and OPERATOR3
					
					release the TI. Check that the storage is correct for all 3 Operators

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 15JAN2024
ADO -  CR 58263 TASK 58264
*/

// ### TFS BUG 64177 30MAY2024 NAVAB1 - the previous operator must have a chargeable storage transaction on the same date as the new operator's free storage expiry.

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew1 = "OCST";
	OperatorNew1 = "OCST";
	DebtorNew2 = "GDXY";
	OperatorNew2 = "GDXY";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF1 = "COO199";
	COOREF2 = "COO299";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	operatorNew1,
	operatorNew2,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1, cooHeader2		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	idx,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS1, cooTS2, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew1, debtorNew2 : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF1);
	
	self.deleteDebtor(DebtorNew1);
	debtorNew1 := self.addDebtor(DebtorNew1, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew1,"Debtor 1 Create Failed");
	
	self.deleteOperator(OperatorNew1);
	operatorNew1 := self.addOperator(OperatorNew1, OperatorNew1, false, 0, 0, debtorNew1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew1 &lt;&gt; null, "newOperator 1 is NULL!");
	
	self.deleteDebtor(DebtorNew2);
	debtorNew2 := self.addDebtor(DebtorNew2, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew2,"Debtor 2 Create Failed");
	
	self.deleteOperator(OperatorNew2);
	operatorNew2 := self.addOperator(OperatorNew2, OperatorNew2, false, 0, 0, debtorNew2, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew2 &lt;&gt; null, "newOperator 2 is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew1); // ### JIRA UT 22JAN2025 NAVAB1
	self.addOperatorToVoyage(voyage, operatorNew2); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 5);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Calendar_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,5,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Calendar_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  5, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew1,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO WHOLE
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS1 := now.addDays(-30);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF1, null, null, app.getMyUserCode(), cooTS1, null, cooTS1, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew1, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach idx in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; idx.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-40);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free storage is wrong");
	
		
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 2, "COO1 - TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "COO1 - TI1 Free 1/2 storage is wrong"); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "COO1 - TI1 Free 1/2 storage operator is wrong"); 
	storageExp := ti1.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS1.addDays(5).date, "COO1 - TI1 Free 2/2 storage is wrong"); // Storage Detail COO has 5 
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew1, "COO1 - TI1 Free 2/2 storage operator is wrong"); 
	
	
	
	
	
	
	// #########################################
	// Create Ownership change 2
	// #########################################
	cooTS2 := now.addDays(-20);
	delete pxyCooHeader;
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF2, null, null, app.getMyUserCode(), cooTS2, null, cooTS2, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew2, operatorNew1, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader2);
	self.assertTrueMsg(cooHeader2 &lt;&gt; null, "COO 200 is null");
	self.assertTrueMsg(cooHeader2.myOperatorNew = operatorNew2, "COO 2 New Op is wrong");
	self.assertTrueMsg(cooHeader2.myOperatorOld = operatorNew1, "COO 2 OLD Op is wrong");
	
	delete pxyCooDetails;
	create pxyCooDetails transient;
	
	// Create OwnerShip Change Details
	pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader2, null, ti1);
	self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
	self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");	
	
	
	
	
	
		
	// #########################################
	// ##### Now Approve COO 2
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader2, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 2");
	// Check COO approved status
	self.assertTrueMsg(cooHeader2.dateTimeApproved.isValid(), "cooHeader2 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader2.dateTimeApproved.date() = now.date(), "cooHeader2  has incorrect approval date");
	self.assertTrueMsg(ti1.operatorCode = OperatorNew2, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; OperatorNew2);

	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 3, "COO2 - TI1 storage 3 exp detail issue");

	idx := 0;
	foreach storageExp in ti1.allStorageExpiryDetails do
	
		idx += 1;
		
		if idx = 1 then
			self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "COO2 - TI1 Free 1/3 storage is wrong"); // Storage detail 5 free days inclusive so 4
			self.assertTrueMsg(storageExp.operatorCode = opCode, "COO2 - TI1 Free 1/3 storage operator is wrong"); 
		elseif idx = 2 then
			self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS1.addDays(5).date, "COO2 - TI1 Free 2/3 storage is wrong"); // Storage Detail COO has 5
			self.assertTrueMsg(storageExp.operatorCode = OperatorNew1, "COO2 - TI1 Free 2/3 storage operator is wrong"); 
		
		elseif idx = 3 then
			self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS2.addDays(5).date, "COO2 - TI1 Free 3/3 storage is wrong"); // Storage Detail COO has 5  
			self.assertTrueMsg(storageExp.operatorCode = OperatorNew2, "COO2 - TI1 Free 3/3 storage operator is wrong"); 
		
		endif;
	
	endforeach;
	
	

	
	
	
	
	
	
	
	
	
	
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check STORAGE TRANS
	// #########################################
	
	create tranArray transient;
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 6, ti1.id &amp; " should have 6 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First Storage transaction should be NOCHARGE for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "First Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.dateTime.date =  moveTS.addDays(4).date, "First Storage transaction should be for date " &amp; moveTS.addDays(4).date.String &amp; " for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti1.id);
	self.assertTrueMsg(transaction.dateTime.date =  cooTS1.addDays(5).date, "Second Storage transaction should be for date " &amp; cooTS1.addDays(4).date.String &amp; " for " &amp; ti1.id); // ### TFS BUG 64177 30MAY2024 NAVAB1 - 5 because this is the OLD op paying upto the NEW op
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage charge should be for " &amp; debtorOld.name);
	
	transaction := tranArray[3].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "Third Storage transaction should be NOCHARGE for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew1, "Third Storage transaction should be for operator " &amp; OperatorNew1 &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.dateTime.date =  cooTS1.addDays(5).date, "Third Storage transaction should be for date " &amp; cooTS1.addDays(5).date.String &amp; " for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "Third Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	transaction := tranArray[4].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Fourth - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Fourth Storage transaction should be CHARGED for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew1, "Fourth Storage transaction should be for operator " &amp; OperatorNew1 &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.dateTime.date =  cooTS2.addDays(5).date, "Fourth Storage transaction should be for date " &amp; cooTS2.addDays(5).date.String &amp; " for " &amp; ti1.id); // ### TFS BUG 64177 30MAY2024 NAVAB1
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Fourth Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew1, "Fourth Storage charge should be for " &amp; debtorNew1.name);
	
	transaction := tranArray[5].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Fifth - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "Fifth Storage transaction should be NOCHARGE for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew2, "Fifth Storage transaction should be for operator " &amp; OperatorNew1 &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.dateTime.date =  cooTS2.addDays(5).date, "Fifth Storage transaction should be for date " &amp; cooTS2.addDays(5).date.String &amp; " for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "Fifth Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	transaction := tranArray[6].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Sixth - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Sixth Storage transaction should be CHARGED for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew2, "Sixth Storage transaction should be for operator " &amp; OperatorNew1 &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.dateTime.date =  now.date, "Sixth Storage transaction should be for date " &amp; now.date.String &amp; " for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Sixth Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew2, "Sixth Storage charge should be for " &amp; debtorNew2.name);
		

	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF1);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage06" id="f4e48587-aba9-4658-86fc-32b831e25661">
        <source>tOwnershipChangeRelStorage06();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction. Charge storage to the COO STORAGE DEBTOR

					Need a storage configuration for release storage
					Need to have storage triggers.
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage.
					Edit TI to get storage trigger to create a CM_Storage whilst still on site. Check has invoice line
					
					Create a COO with a storage operator, this should charge storage from the COO date to this storage debtor.
					The COO should be for the whole TI with a date prior to the CM_Storage, 2 operators with different debtors
					
					Approve COO.
					
					The storage transaction invoice lines should be for the COO storage operator debtor

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 15JAN2024
ADO -  CR 58263 TASK 58264
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	DebtorStorage = "DSTR";
	OperatorStorage = "DSTR";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
vars
	cargoGroup		: CM_CargoGroup;
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld, operatorSto		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew, debtorSto : CM_Debtor;
	trans : CM_TITransactionSet;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");

	
	
	
	self.deleteDebtor(DebtorStorage);
	debtorSto := self.addDebtor(DebtorStorage, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(DebtorStorage,"Debtor DebtorStorage Create Failed");
	
	self.deleteOperator(OperatorStorage);
	operatorSto := self.addOperator(OperatorStorage, OperatorStorage, false, 0, 0, debtorSto, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "operatorSto is NULL!");
	
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	self.addOperatorToVoyage(voyage, operatorSto); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, operatorSto, null, self.getMyTerminal(), null); // Includes a Storage Debtor  // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	self.assertTrueMsg(cooHeader1.myOperatorStorage &lt;&gt; null, "COO 100 storage Op is null");
	self.assertTrueMsg(cooHeader1.myOperatorStorage = operatorSto, "COO 100 storage Op is wrong");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	
	// #########################################
	// ##### EDIT TI's IMEX to trigger a CM_Storage creations
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in tiSet do
		self.updateTI(ti);
	endforeach;

	foreach ti in tiSet do
		self.assertTrueMsg(ti.isExport, ti.id &amp; " should be an EXPORT");
		trans := ti.getTransOfType(TRANS_TYPE_STORAGE);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Storage transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "Before No Storage charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "Storage charge before COO should be for " &amp; debtorOld.name);
		
		
	endforeach;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		// Check Operator
		self.assertTrueMsg(ti.operatorCode = OperatorNew, ti.id &amp; " has incorrect new operator code. Is " &amp; ti.operatorCode &amp; " should be " &amp; OperatorNew);
		
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Storage transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Storage charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorSto, "Storage charge after COO should be for " &amp; debtorSto.name);
		
	endforeach;
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage07" id="685a4e3b-bedd-4104-9b22-db5e98576e6f">
        <source>tOwnershipChangeRelStorage07();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction. Charge storage to the COO INCO TERM DEBTOR

					Need a storage configuration for release storage
					Need to have storage triggers.
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage.
					Edit TI to get storage trigger to create a CM_Storage whilst still on site. Check has invoice line
					
					Create a COO with an INCO Term and NO storage operator, this should charge storage from the COO date to the INCO Term debtor type
					The COO should be for the whole TI with a date prior to the CM_Storage, 2 operators with different debtors
					
					Approve COO.
					
					The storage transaction invoice lines should be for the COO INCO Term debtor

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 15JAN2024
ADO -  CR 58263 TASK 58264
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	DebtorStorage = "DSTR";
	DebtorCA = "CADT";
	OperatorStorage = "DSTR";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
vars
	cargoGroup		: CM_CargoGroup;
	ti				: CM_TrackedItem;
	operatorNew,
	operatorOld, operatorSto		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TISet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew, debtorSto, debtorCA : CM_Debtor;
	trans : CM_TITransactionSet;
	incoTerm : CM_InvoiceINCOTerm;
	debtorType : CM_DebtorType;
	customsAgent : CM_CustomsAgent;
	invLineSet : CM_InvoiceLineDescSet;
begin

	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");

	
	
	
	self.deleteDebtor(DebtorStorage);
	debtorSto := self.addDebtor(DebtorStorage, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(DebtorStorage,"Debtor DebtorStorage Create Failed");
	
	self.deleteOperator(OperatorStorage);
	operatorSto := self.addOperator(OperatorStorage, OperatorStorage, false, 0, 0, debtorSto, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "operatorSto is NULL!");
	
	self.deleteDebtor(DebtorCA);
	debtorCA := self.addDebtor(DebtorCA, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(DebtorCA,"Debtor debtorCA Create Failed");
	customsAgent := self.addCustomsAgent("UTCA1", "UTCA1 Desc");
	beginTransaction;
	customsAgent.setDebtor(debtorCA);
	commitTransaction;
	
	// ### INCO
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
//	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	self.deleteInvINCOTerm("UTINCO");
	incoTerm := self.createInvoiceINCOTerm("UTINCO","Unit Test INCO Term", self.myBank);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	self.addOperatorToVoyage(voyage, operatorSto); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	// ### INCO Mapping
	create invLineSet transient;
	invLineSet.add(invLineType);
	self.createInvoiceINCOTermMapping(debtorType,incoTerm,invLineSet);
	
	
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-10);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, incoTerm, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // Includes a Storage Debtor  // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	self.assertTrueMsg(cooHeader1.myOperatorStorage = null, "COO 100 storage Op should be null");
	self.assertTrueMsg(cooHeader1.myIncoterm = incoTerm, "COO 100 incoTerm is wrong");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := cooTS.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	
	// #########################################
	// ##### EDIT TI's IMEX to trigger a CM_Storage creations
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	foreach ti in tiSet do
		self.updateTI(ti);
	endforeach;

	foreach ti in tiSet do
		self.assertTrueMsg(ti.isExport, ti.id &amp; " should be an EXPORT");
		trans := ti.getTransOfType(TRANS_TYPE_STORAGE);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Storage transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "Before No Storage charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorOld, "Storage charge before COO should be for " &amp; debtorOld.name);
		
		
	endforeach;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	
	// Check TIs on COO
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		// Check Operator
		self.assertTrueMsg(ti.operatorCode = OperatorNew, ti.id &amp; " has incorrect new operator code. Is " &amp; ti.operatorCode &amp; " should be " &amp; OperatorNew);
		
		trans := ti.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
		transaction := trans.first;
		delete trans;
		
		assertTrueMsg(transaction &lt;&gt; null, "No Storage transaction for " &amp; ti.id);
		assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti.id);
		
		invLine := transaction.allInvoiceLines.first;
		assertTrueMsg(invLine &lt;&gt; null, "After - No Storage charges for " &amp; ti.id);
		assertTrueMsg(invLine.debtor = debtorCA, "Storage charge after COO should be for " &amp; debtorCA.name);
		
	endforeach;
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	self.deleteInvINCOTerm("UTINCO");
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteCustomsAgent("UTCA1");
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete invLineSet;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1
	

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage08" id="666e170a-3bca-4900-aa4c-e9166f95c39e">
        <source>tOwnershipChangeRelStorage08();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage, make free storage 30 days
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship Retrospective 40 days ago, check free storage it shoudl be 10 days ago.
					
					Create a COO for whole TI  retrospective 20 days ago, 2 operators with different debtors, this COO is 10 days before the first operators free storage so the new operators free storage should be the same as the old.
					
					Approve COO.
					
					check new operators storage expiry detail is same as old operator's
					
					release the TI. Check that the storage  is all for the old operator, 1 invoice line for hte old operator

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 15JAN2024
ADO -  CR 58263 TASK 58264
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 0);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Calendar_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,30,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Calendar_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  0, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO WHOLE
	// #########################################
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-20);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-40);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(29).date, "TI1 Free storage is wrong should be plus 30");
	
		
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 2, "TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(29).date, "TI1 Free 1/2 storage is wrong"); // Storage detail 30 free days inclusive so 29
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 1/2 storage operator is wrong"); 
	storageExp := ti1.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(29).date, "TI1 Free 2/2 storage is wrong shoudl be the same as 1/2"); // Storage Detail COO has 0 and COO has 0 additional. Previous operators SED is greater than what would be calculated for new op so is the same
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI1 Free 2/2 storage operator is wrong"); 
	
	
	
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs on COO
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = OperatorNew, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; OperatorNew);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 2, ti1.id &amp; " should have 2 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First Storage transaction should be NOCHARGE for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Second Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Second Storage charge should be for " &amp; debtorNew.name);
		
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1
	

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage09" id="e3df7b2c-771f-4720-9cba-62bc52513a5d">
        <source>tOwnershipChangeRelStorage09();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage that includes a calendar with a date that woudl effect, push out, the free storage expiry on the COO storage expiry detail
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. Retrospective 40 days ago
					
					Create a COO for whole TI  retrospective 20 days ago, 2 operators with different debtors
					
					Approve COO.
					
					release the TI. Check that the storage upto 20 days ago is the old operator and the storage for upto now is the new operator.

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 15JAN2024
ADO -  CR 58263 TASK 58264
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS, calTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
	calworkindays : CM_Calendar;
	
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	self.deleteCalendar("UTWD", "WD");
	
	calworkindays:= self.createCalendar("UTWD", "UT WORKING DAYS",false,false,"WD");
	calTS := now.addDays(-18);
	self.addSingleCalendarDate(calTS.date, "DAY OFF", calworkindays);
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, calworkindays, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 5);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Working_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,5,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Working_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  5, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO WHOLE
	// #########################################
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-20);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS.addDays(5), 0, 5, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-40);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free storage is wrong");
	
		
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 2, "TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free 1/2 storage is wrong"); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 1/2 storage operator is wrong"); 
	storageExp := ti1.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS.addDays(11).date, "TI1 Free 2/2 storage is wrong"); // Storage Detail COO has 5 and COO has 5 additional plus 1 datein the calendar so 11
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI1 Free 2/2 storage operator is wrong"); 
	
	
	
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs on COO
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = OperatorNew, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; OperatorNew);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 4, ti1.id &amp; " should have 4 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First Storage transaction should be NOCHARGE for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage charge should be for " &amp; debtorOld.name);
	
	transaction := tranArray[3].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "Third Storage transaction should be NOCHARGE for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "Third Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	transaction := tranArray[4].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Fourth - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Fourth Storage transaction should be CHARGED for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Fourth Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Fourth Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Fourth Storage charge should be for " &amp; debtorNew.name);
		
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteStorageConfig(false);
	self.deleteCalendar("UTWD", "WD");
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1


	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage11" id="694b10c0-03f1-479f-b1b9-e0a18185bba5">
        <source>tOwnershipChangeRelStorage11();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. Retrospective 40 days ago
					Free storage period for both is 10 days
					
					Create a COO for whole TI  retrospective 5 days ago, 2 operators with different debtors
					
					Approve COO.
					
					Release the TI. There should be no charge for the 2nd operator, only for the first and the first should have a free storage period.
					
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 24MAY2024
ADO -  BUG 64177
*/


constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 10);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Calendar_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,10,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Calendar_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  10, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO WHOLE
	// #########################################
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-5);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-40);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(9).date, "TI1 Free storage is wrong SBE " &amp; storageExp.freeStorageExpiry.date.String);
	
		
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 2, "TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(9).date, "TI1 Free 1/2 storage is wrong"); // Storage detail 10 free days inclusive so 9
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 1/2 storage operator is wrong"); 
	storageExp := ti1.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS.addDays(10).date, "TI1 Free 2/2 storage is wrong"); // Storage Detail COO has 5 and COO has 5 additional so 10
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI1 Free 2/2 storage operator is wrong"); 
	
	
	
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs on COO
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = OperatorNew, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; OperatorNew);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 2, ti1.id &amp; " should have 4 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First Storage transaction should be NOCHARGE for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage charge should be for " &amp; debtorOld.name);
	
		
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage12" id="321112bc-3227-4b31-bbf5-1033bed83c0a">
        <source>tOwnershipChangeRelStorage12();
/*

Purpose:		QTerminals do not have any storage details so no free storage days so the free storage expiry in the date of receival.
					In the transaction map the first range for storage days is 8-14, so anything before 8 days is not charged.
					Storage config has include first and last days.
					
					&gt;&gt;&gt;&gt; Test Charge 0 days

					Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage. with Include First Day set to true, BUT no storage details
					
					Need invoicing for Storage to create invoice lines, in bands no 0-7, just 8-15 and 16-max
					
					Becasue we are including the first day to get 7 days on site we Receive cargo from ship retrospective 6 days ago, check free storage. Free Store Exp should be same as receive date
					
					No COO
					
					Release the TI.  The TI has been on site 6 days so because we are include first day that is 7 days which should get zero invoice lines, because of the ranges
					
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 2JULY2024
ADO -  BUG 64965
*/


constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage1 = "UT_SRVC_COOSTO1";
	Srvc_COOStorage2 = "UT_SRVC_COOSTO2";
	InvLineType_Code1 = "UT_COOSTO08-14";
	InvLineType_Code2 = "UT_COOSTO15-MAX";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
unpackTIs : CM_TIArray;
	container1: CM_TrackedItem;
	attachments: CMIF_InOutAttachmentArray;
	attach: CMIF_InOutAttachment;
	vvr : CM_VehicleVisitRecord;
	ti1, ti4				: CM_TrackedItem;
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, moveTS				: TimeStamp;	
	cmifAgent			: CMIF_COOAgent;
	debtorOld : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage1);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_DAYS_SINCE_RECVL, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage1, Srvc_COOStorage1, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage1 &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	
	self.deleteInvoiceLineType(InvLineType_Code1, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code1, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code1 &amp; " not created");
		
	services.clear();
	service := self.createInvoiceService(Srvc_COOStorage2, Srvc_COOStorage2, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage2 &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,50.00);
	
	self.deleteInvoiceLineType(InvLineType_Code2, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code2, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code2 &amp; " not created");
	
	
	self.loadTransMapRange(TransMap_UT, TransType_Storage);
	
	
	
	
	// #########################################
	// ###### CREATE CONTAINER + CHILD ON VOYAGE
	// #########################################
	
	
	self.deleteContainer("COOU2407020");
	self.opts.purge();
	self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc("CustomsEntryNumber", "100");
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	
	
	
	container1 := self.addContainerOpts("COOU2407020", "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	assertTrueMsg(container1 &lt;&gt; null, "container1 is null");
	
	assertEqualMsg(container1.getImExStatus, TI_IMEX_STATUS_IMPORT, "Container1 has incorrect IMEX Status");
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container1 has incorrect Status");
	// MAke sure all stops are removed
	self.opts.addAssoc("CENum", container1.customsEntryNumber);
	deleteStops(container1);
	assertEqualMsg(container1.getAllActiveStopsSize, 0, "Container1 has stops");
	
	
	self.instantMove(container1,voyage.myShipBlockStack);

	assertTrueMsg(container1.locationId = voyage.code, "container1 shoudl be on teh voyage");
	
	create attachments transient;

	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
	
		create attach transient;
		attach.set(getTerminal, cargoType.id, tiId, "", weight); 
		attach.myProduct := null;
		attach.operatorCode := operatorOld.code;
		attach.imExStatus := container1.getImExStatus;
		
		attachments.add(attach);
		
	endforeach;

	
	self.addContainerChildren(container1.CM_Container, attachments);
	
	container1.allChildren.copy(tiSet);
	tiSet.add(container1);

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-6); // including first day = 7
	self.opts.addAssoc("effectiveTS", moveTS);
	
		
	self.instantMove(container1,terminalArea.getMyLocationsController());

//	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), true);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := container1;
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.date, "TI1 Free storage is wrong SBE " &amp; storageExp.freeStorageExpiry.date.String);
	
	// #########################################
	// ##### UNPACK CARGO FROM CONTAINER
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("retrospectiveDT", moveTS);

	create unpackTIs transient;
	unpackTIs.clear();
	unpackTIs.add(container1.allChildren.first);
	self.unpackContainer(container1, unpackTIs);

	beginTransaction;
	container1.updateContentsStatus();
	commitTransaction;
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container has incorrect Status after unpacking all children but not resetting commodity");
	
	beginTransaction;
	container1.setCommodity( null );
	container1.updateContentsStatus();
	commitTransaction;
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_EMPTY, "Container has incorrect Status when no children and no commodity");
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := unpackTIs[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs for Storage
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = operatorOld.code, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; operatorOld.code);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 2, ti1.id &amp; " should have 2 storage transaction");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	
	assertTrueMsg(invLine = null, "Storage - Has storage charges for " &amp; ti1.id);
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	
	assertTrueMsg(invLine = null, "Second Storage - Has storage charges for " &amp; ti1.id);
	
		
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
epilog
	self.resetDefaultTranMap();
	if attachments&lt;&gt; null then
		attachments.purge();
	endif;
	delete attachments;
	delete services;
	delete tiSet;
	delete unpackTIs;
	delete cmifAgent;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage13" id="0925638b-8470-41bf-9488-e4c5d3315ffa">
        <source>tOwnershipChangeRelStorage13();
/*

Purpose:		QTerminals do not have any storage details so no free storage days so the free storage expiry in the date of receival.
					In the transaction map the first range for storage days is 8-14, so anything before 8 days is not charged.
					Storage config has include first and last days.
					
					&gt;&gt;&gt;&gt; Test Charge 1 day
					

					Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage. with Include First Day set to true, BUT no storage details
					
					Need invoicing for Storage to create invoice lines, in bands no 0-7, just 8-15 and 16-max
					
					Receive cargo from ship retrospective 8 days ago, check free storage. Free Store Exp should be same as receive date
					
					No COO
					
					Release the TI.  The TI has been on site 8 days so should get 1 invoice line for quantity of 1, becasue of the ranges
					
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 2JULY2024
ADO -  BUG 64965
*/


constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage1 = "UT_SRVC_COOSTO1";
	Srvc_COOStorage2 = "UT_SRVC_COOSTO2";
	InvLineType_Code1 = "UT_COOSTO08-14";
	InvLineType_Code2 = "UT_COOSTO15-MAX";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
unpackTIs : CM_TIArray;
	container1: CM_TrackedItem;
	attachments: CMIF_InOutAttachmentArray;
	attach: CMIF_InOutAttachment;
	vvr : CM_VehicleVisitRecord;
	ti1, ti4				: CM_TrackedItem;
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, moveTS				: TimeStamp;	
	cmifAgent			: CMIF_COOAgent;
	debtorOld : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage1);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_DAYS_SINCE_RECVL, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage1, Srvc_COOStorage1, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage1 &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	
	self.deleteInvoiceLineType(InvLineType_Code1, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code1, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code1 &amp; " not created");
		
	services.clear();
	service := self.createInvoiceService(Srvc_COOStorage2, Srvc_COOStorage2, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage2 &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,50.00);
	
	self.deleteInvoiceLineType(InvLineType_Code2, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code2, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code2 &amp; " not created");
	
	
	self.loadTransMapRange(TransMap_UT, TransType_Storage);
	
	
	
	
	// #########################################
	// ###### CREATE CONTAINER + CHILD ON VOYAGE
	// #########################################
	
	
	self.deleteContainer("COOU2407020");
	self.opts.purge();
	self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc("CustomsEntryNumber", "100");
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	
	
	
	container1 := self.addContainerOpts("COOU2407020", "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	assertTrueMsg(container1 &lt;&gt; null, "container1 is null");
	
	assertEqualMsg(container1.getImExStatus, TI_IMEX_STATUS_IMPORT, "Container1 has incorrect IMEX Status");
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container1 has incorrect Status");
	// MAke sure all stops are removed
	self.opts.addAssoc("CENum", container1.customsEntryNumber);
	deleteStops(container1);
	assertEqualMsg(container1.getAllActiveStopsSize, 0, "Container1 has stops");
	
	
	self.instantMove(container1,voyage.myShipBlockStack);

	assertTrueMsg(container1.locationId = voyage.code, "container1 shoudl be on teh voyage");
	
	create attachments transient;

	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
	
		create attach transient;
		attach.set(getTerminal, cargoType.id, tiId, "", weight); 
		attach.myProduct := null;
		attach.operatorCode := operatorOld.code;
		attach.imExStatus := container1.getImExStatus;
		
		attachments.add(attach);
		
	endforeach;

	
	self.addContainerChildren(container1.CM_Container, attachments);
	
	container1.allChildren.copy(tiSet);
	tiSet.add(container1);

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-7); // including first day = 8
	self.opts.addAssoc("effectiveTS", moveTS);
	
		
	self.instantMove(container1,terminalArea.getMyLocationsController());

//	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), true);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := container1;
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.date, "TI1 Free storage is wrong SBE " &amp; storageExp.freeStorageExpiry.date.String);
	
	// #########################################
	// ##### UNPACK CARGO FROM CONTAINER
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("retrospectiveDT", moveTS);

	create unpackTIs transient;
	unpackTIs.clear();
	unpackTIs.add(container1.allChildren.first);
	self.unpackContainer(container1, unpackTIs);

	beginTransaction;
	container1.updateContentsStatus();
	commitTransaction;
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container has incorrect Status after unpacking all children but not resetting commodity");
	
	beginTransaction;
	container1.setCommodity( null );
	container1.updateContentsStatus();
	commitTransaction;
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_EMPTY, "Container has incorrect Status when no children and no commodity");

	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := unpackTIs[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs for Storage
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = operatorOld.code, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; operatorOld.code);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 2, ti1.id &amp; " should have 2 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "Storage - No charges for " &amp; ti1.id);
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Storage charge should be for " &amp; debtorOld.name);
	assertTrueMsg(invLine.quantity = 1, "Storage charge should be quantity of 1, is " &amp; invLine.quantity.String);
		
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
epilog
	self.resetDefaultTranMap();
	if attachments&lt;&gt; null then
		attachments.purge();
	endif;
	delete attachments;
	delete services;
	delete tiSet;
	delete unpackTIs;
	delete cmifAgent;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage14" id="e8fafab2-6c08-4e84-92ef-49db514a6e5b">
        <source>tOwnershipChangeRelStorage14();
/*

Purpose:		QTerminals do not have any storage details so no free storage days so the free storage expiry in the date of receival.
					In the transaction map the first range for storage days is 8-14, so anything before 8 days is not charged.
					Storage config has include first and last days.
					
					&gt;&gt;&gt;&gt; Test Charge 2 days

					Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage. with Include First Day set to true, BUT no storage details
					
					Need invoicing for Storage to create invoice lines, in bands no 0-7, just 8-15 and 16-max
					
					Receive cargo from ship retrospective 9 days ago, check free storage. Free Store Exp should be same as receive date
					
					No COO
					
					Release the TI.  The TI has been on site 8 days so should get 1 invoice line for quantity of 2, becasue of the ranges
					
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 2JULY2024
ADO -  BUG 64965
*/


constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage1 = "UT_SRVC_COOSTO1";
	Srvc_COOStorage2 = "UT_SRVC_COOSTO2";
	InvLineType_Code1 = "UT_COOSTO08-14";
	InvLineType_Code2 = "UT_COOSTO15-MAX";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
unpackTIs : CM_TIArray;
	container1: CM_TrackedItem;
	attachments: CMIF_InOutAttachmentArray;
	attach: CMIF_InOutAttachment;
	vvr : CM_VehicleVisitRecord;
	ti1, ti4				: CM_TrackedItem;
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, moveTS				: TimeStamp;	
	cmifAgent			: CMIF_COOAgent;
	debtorOld : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage1);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_DAYS_SINCE_RECVL, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage1, Srvc_COOStorage1, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage1 &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	
	self.deleteInvoiceLineType(InvLineType_Code1, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code1, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code1 &amp; " not created");
		
	services.clear();
	service := self.createInvoiceService(Srvc_COOStorage2, Srvc_COOStorage2, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage2 &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,50.00);
	
	self.deleteInvoiceLineType(InvLineType_Code2, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code2, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code2 &amp; " not created");
	
	
	self.loadTransMapRange(TransMap_UT, TransType_Storage);
	
	
	
	
	// #########################################
	// ###### CREATE CONTAINER + CHILD ON VOYAGE
	// #########################################
	
	
	self.deleteContainer("COOU2407020");
	self.opts.purge();
	self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc("CustomsEntryNumber", "100");
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	
	
	
	container1 := self.addContainerOpts("COOU2407020", "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	assertTrueMsg(container1 &lt;&gt; null, "container1 is null");
	
	assertEqualMsg(container1.getImExStatus, TI_IMEX_STATUS_IMPORT, "Container1 has incorrect IMEX Status");
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container1 has incorrect Status");
	// MAke sure all stops are removed
	self.opts.addAssoc("CENum", container1.customsEntryNumber);
	deleteStops(container1);
	assertEqualMsg(container1.getAllActiveStopsSize, 0, "Container1 has stops");
	
	
	self.instantMove(container1,voyage.myShipBlockStack);

	assertTrueMsg(container1.locationId = voyage.code, "container1 shoudl be on teh voyage");
	
	create attachments transient;

	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
	
		create attach transient;
		attach.set(getTerminal, cargoType.id, tiId, "", weight); 
		attach.myProduct := null;
		attach.operatorCode := operatorOld.code;
		attach.imExStatus := container1.getImExStatus;
		
		attachments.add(attach);
		
	endforeach;

	
	self.addContainerChildren(container1.CM_Container, attachments);
	
	container1.allChildren.copy(tiSet);
	tiSet.add(container1);

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-8); // including first day = 9
	self.opts.addAssoc("effectiveTS", moveTS);
	
		
	self.instantMove(container1,terminalArea.getMyLocationsController());

//	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), true);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := container1;
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.date, "TI1 Free storage is wrong SBE " &amp; storageExp.freeStorageExpiry.date.String);
	
	// #########################################
	// ##### UNPACK CARGO FROM CONTAINER
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("retrospectiveDT", moveTS);

	create unpackTIs transient;
	unpackTIs.clear();
	unpackTIs.add(container1.allChildren.first);
	self.unpackContainer(container1, unpackTIs);

	beginTransaction;
	container1.updateContentsStatus();
	commitTransaction;
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_FCL, "Container has incorrect Status after unpacking all children but not resetting commodity");
	
	beginTransaction;
	container1.setCommodity( null );
	container1.updateContentsStatus();
	commitTransaction;
	assertEqualMsg(container1.getContentsStatus, TI_CONTENTS_STATUS_EMPTY, "Container has incorrect Status when no children and no commodity");
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := unpackTIs[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs for Storage
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = operatorOld.code, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; operatorOld.code);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 2, ti1.id &amp; " should have 2 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "Storage - No charges for " &amp; ti1.id);
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Storage charge should be for " &amp; debtorOld.name);
	assertTrueMsg(invLine.quantity = 2, "Storage charge should be quantity of 2, is " &amp; invLine.quantity.String);
		
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
epilog
	self.resetDefaultTranMap();
	if attachments&lt;&gt; null then
		attachments.purge();
	endif;
	delete attachments;
	delete services;
	delete tiSet;
	delete unpackTIs;
	delete cmifAgent;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage15" id="9b439cca-ab4f-4457-b9f5-de674f6a2462">
        <source>tOwnershipChangeRelStorage15();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. Retrospective 40 days ago
					
					Create a COO for whole TI  retrospective 20 days ago, 2 operators with different debtors
					
					Approve COO.
					
					release the TI. Check that the storage upto 20 days ago is the old operator and the storage for upto now is the new operator.

Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 15JAN2024
	 // ### JIRA 36201 07OCT2025 NAVAB1

*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 5);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Calendar_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,5,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Calendar_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  5, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO WHOLE
	// #########################################
	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-20);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS.addDays(5), 0, 5, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 100 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-40);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free storage is wrong");
	
		
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 2, "TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free 1/2 storage is wrong"); // Storage detail 5 free days inclusive so 4
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 1/2 storage operator is wrong"); 
	storageExp := ti1.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS.addDays(10).date, "TI1 Free 2/2 storage is wrong"); // Storage Detail COO has 5 and COO has 5 additional so 10
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI1 Free 2/2 storage operator is wrong"); 
	
	
	// #########################################
	// ##### Add a storage whilst on site iei an end of month BGP or a trigger.
	// #########################################	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 0, ti1.id &amp; " should have NO storage transactions");
	delete trans;
	
	// #########################################
	// ##### EDIT TI's IMEX to trigger a CM_Storage creations
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	moveTS := now.addDays(-4);
	self.opts.addAssoc("effectiveTS", moveTS);
	ti1 := tiSet[1];
	self.updateTrackedItem(ti1);
	
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 4, ti1.id &amp; " should have 4 storage transactions");
	delete trans;
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs on COO
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = OperatorNew, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; OperatorNew);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 5, ti1.id &amp; " should have 5 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First Storage transaction should be NOCHARGE for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage charge should be for " &amp; debtorOld.name);
	
	transaction := tranArray[3].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "Third Storage transaction should be NOCHARGE for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "Third Storage - has been charged, should be No Charge " &amp; ti1.id);
	
	transaction := tranArray[4].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Fourth - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Fourth Storage transaction should be CHARGED for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Fourth Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Fourth Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Fourth Storage charge should be for " &amp; debtorNew.name);
		
	transaction := tranArray[5].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Fifth - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Fifth Storage transaction should be CHARGED for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Fifth Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.dateTime.date =  now.date, "Fifth Storage transaction should be for date " &amp; now.date.String &amp; " for " &amp; ti1.id);
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage16" id="f1faca2a-8c1a-4744-ab4f-096ad8924c21">
        <source>tOwnershipChangeRelStorage16();
/*

Purpose:			Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. Retrospective 40 days ago
					
					Trigger a storage transaction 30 days ago
					
					Create a COO for whole TI  retrospective 20 days ago, 2 operators with different debtors
					
					Approve COO.
					
					Release the TI. Check that the storage upto 20 days ago is the old operator and the storage for upto now is the new operator.

Parameters:			

Return Value:		

Date		Who		Reason
/*
//11/11/2025	navkc1 JIRA 36580 TPT | UAT - Storage Transaction created for COO date does not retrieve the correct Operator for Non Itemised Cargo. 


*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 0);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Calendar_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Calendar_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  0, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO WHOLE
	// #########################################
	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-20);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 199 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-40);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	//self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free storage is wrong");
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.date, "TI1 Free storage is wrong");
	
	// #########################################
	// ##### EDIT TI's IMEX to trigger a CM_Storage creations
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	moveTS := now.addDays(-30);
	self.opts.addAssoc("effectiveTS", moveTS);
	ti1 := tiSet[1];
	self.updateTrackedItem(ti1);
	
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 1, ti1.id &amp; " should have 1 storage transaction from the trigger");
	delete trans;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 2, "TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = now.addDays(-40).date(), "TI1 Free 1/2 storage is wrong"); // Expiry date of when we discharge the cargo from ship
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 1/2 storage operator is wrong"); 
	storageExp := ti1.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS.date, "TI1 Free 2/2 storage is wrong");  // Expiry date of when we do COO
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI1 Free 2/2 storage operator is wrong"); 
	
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs on COO
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = OperatorNew, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; OperatorNew);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 3, ti1.id &amp; " should have 3 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	// #########################################
	// ##### Check Storage transactions
	// #########################################
	
	// #########################################
	// ##### BEFORE COO
	// #########################################
	
	// First Storage transaction - Triggered, should go to old operator
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "First Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "First Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "First Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "First Storage charge should be for " &amp; debtorOld.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("10 days", 1) &gt; 0, "First Storage Invalid number of storage days");
	
	// #########################################
	// ##### After COO &gt; Release
	// #########################################
	
	// Second Storage transaction - On Release, this is old operator - From first storage transaction till COO approved
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage charge should be for " &amp; debtorOld.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("10 days", 1) &gt; 0, "Second Storage Invalid number of storage days");
	
	// Second Storage transaction - On Release, this is new operator - From COO approved till release
	transaction := tranArray[3].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Third Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Third Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Third Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Third Storage charge should be for " &amp; debtorNew.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("20 days", 1) &gt; 0, "Third Storage Invalid number of storage days");
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans;

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage17" id="770a1cb5-64e6-4b99-875f-127e62ee8378">
        <source>tOwnershipChangeRelStorage17();
/*

Purpose:			Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. Retrospective 40 days ago
					
					Trigger a storage transaction 30 days ago
					
					Create a COO for whole TI  retrospective 20 days ago, 2 operators with different debtors
					Approve COO.
					
					Trigger a storage transaction 15 days ago
					
					Release the TI. Check that the storage upto 20 days ago is the old operator and the storage for upto now is the new operator.

Parameters:			

Return Value:		

Date		Who		Reason
/*
//11/11/2025	navkc1 JIRA 36580 TPT | UAT - Storage Transaction created for COO date does not retrieve the correct Operator for Non Itemised Cargo. 


*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 0);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Calendar_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Calendar_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  0, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO WHOLE
	// #########################################
	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-20);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 199 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-40);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	//self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free storage is wrong");
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.date, "TI1 Free storage is wrong");
	
	// #########################################
	// ##### EDIT TI's IMEX to trigger a CM_Storage creations
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	moveTS := now.addDays(-30);
	self.opts.addAssoc("effectiveTS", moveTS);
	ti1 := tiSet[1];
	self.updateTrackedItem(ti1);
	
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 1, ti1.id &amp; " should have 1 storage transaction from the trigger");
	delete trans;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 2, "TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = now.addDays(-40).date(), "TI1 Free 1/2 storage is wrong"); // Expiry date of when we discharge the cargo from ship
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 1/2 storage operator is wrong"); 
	storageExp := ti1.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS.date, "TI1 Free 2/2 storage is wrong");  // Expiry date of when we do COO
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI1 Free 2/2 storage operator is wrong"); 
	
	
	// #########################################
	// ##### EDIT TI's IMEX to trigger a CM_Storage creations
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_IMPORT);
	moveTS := now.addDays(-15);
	self.opts.addAssoc("effectiveTS", moveTS);
	ti1 := tiSet[1];
	self.updateTrackedItem(ti1);
	
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 3, ti1.id &amp; " should have 3 storage transaction from the trigger");
	delete trans;
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs on COO
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = OperatorNew, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; OperatorNew);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 4, ti1.id &amp; " should have 4 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	// #########################################
	// ##### Check Storage Transactions
	// #########################################
	
	// #########################################
	// ##### Before COO
	// #########################################
	
	// First Storage transaction - Triggered, for old operator
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "First Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "First Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "First Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "First Storage charge should be for " &amp; debtorOld.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("10 days", 1) &gt; 0, "First Storage Invalid number of storage days");
	
	// #########################################
	// ##### After COO &gt; Trigger
	// #########################################
	
	// Second Storage transaction - Triggered - This is for old operator, from first storage transaction till COO approved
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage charge should be for " &amp; debtorOld.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("10 days", 1) &gt; 0, "Second Storage Invalid number of storage days");
	
	// Third Storage transaction - Triggered - This is for new operator, from COO approve till trigger
	transaction := tranArray[3].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Third Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Third Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Third Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Third Storage charge should be for " &amp; debtorNew.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("5 days", 1) &gt; 0, "Third Storage Invalid number of storage days");
	
	// #########################################
	// ##### Release
	// #########################################
	
	
	// Fourth Storage transaction - Release, This is for new operator, from trigger to release
	transaction := tranArray[4].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Fourth - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Fourth Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Fourth Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Fourth Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Fourth Storage charge should be for " &amp; debtorNew.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("15 days", 1) &gt; 0, "Fourth Storage Invalid number of storage days");

	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans;

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage18" id="f196159f-1083-483d-870a-c6d3ad73a7be">
        <source>tOwnershipChangeRelStorage18();
/*

Purpose:			Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. Retrospective 40 days ago
					
					Create a COO for whole TI  retrospective 20 days ago, 2 operators with different debtors
					Approve COO.
					
					Trigger a storage transaction 15 days ago
					
					Release the TI. Check that the storage upto 20 days ago is the old operator and the storage for upto now is the new operator.

Parameters:			

Return Value:		

Date		Who		Reason
/*
//11/12/2025	navkc1 JIRA 36580 TPT | UAT - Storage Transaction created for COO date does not retrieve the correct Operator for Non Itemised Cargo. 


*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 0);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Calendar_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Calendar_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  0, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO WHOLE
	// #########################################
	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(-20);

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 199 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-40);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	//self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free storage is wrong");
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.date, "TI1 Free storage is wrong");
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 2, "TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = now.addDays(-40).date(), "TI1 Free 1/2 storage is wrong"); // Expiry date of when we discharge the cargo from ship
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 1/2 storage operator is wrong"); 
	storageExp := ti1.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS.date, "TI1 Free 2/2 storage is wrong");  // Expiry date of when we do COO
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI1 Free 2/2 storage operator is wrong"); 
	
	
	// #########################################
	// ##### EDIT TI's IMEX to trigger a CM_Storage creations
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	moveTS := now.addDays(-15);
	self.opts.addAssoc("effectiveTS", moveTS);
	ti1 := tiSet[1];
	self.updateTrackedItem(ti1);
	
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 2, ti1.id &amp; " should have 2 storage transaction from the trigger");
	delete trans;
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs on COO
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = OperatorNew, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; OperatorNew);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 3, ti1.id &amp; " should have 3 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	// #########################################
	// ##### Check Storage Transactions
	// #########################################
	
	// #########################################
	// ##### After COO &gt; Trigger
	// #########################################
	
	// First Storage transaction - Triggered, for old operator
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "First Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "First Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "First Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "First Storage charge should be for " &amp; debtorOld.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("20 days", 1) &gt; 0, "First Storage Invalid number of storage days");
	
	// Second Storage transaction - Triggered - This is for new operator, from COO approve till trigger
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Second Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Second Storage charge should be for " &amp; debtorNew.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("5 days", 1) &gt; 0, "Second Storage Invalid number of storage days");
	
	// #########################################
	// ##### Release
	// #########################################
	
	// Third Storage transaction - Release, This is for new operator, from trigger to release
	transaction := tranArray[3].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Third Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Third Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Third Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Third Storage charge should be for " &amp; debtorNew.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("15 days", 1) &gt; 0, "Third Storage Invalid number of storage days");

	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans;

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeRelStorage19" id="822840fa-92b5-482a-bc07-6cbe9cf6bc2a">
        <source>tOwnershipChangeRelStorage19();
/*

Purpose:			Release Storage Testing. This means CM_Storage transaction.

					Need a storage configuration for release storage
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage. Retrospective 20 days ago
					
					Trigger a storage transaction 1 day ago
					
					Create a COO for whole TI  retrospective today, 2 operators with different debtors
					
					Approve COO. today
					
					Release the TI. Check that the storage upto 20 days ago is the old operator, the storage for upto yesterday is the old operator and the storage for now is the new operator.

Parameters:			

Return Value:		

Date		Who		Reason
/*
//11/11/2025	navkc1 JIRA 36580 TPT | UAT - Storage Transaction created for COO date does not retrieve the correct Operator for Non Itemised Cargo. 


*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	DebtorNew = "OCST";
	OperatorNew = "OCST";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	COOREF = "COO199";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	cargoGroup		: CM_CargoGroup;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	operatorNew,
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1		: CM_OwnershipChange;
	pxyCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	storageExp : CM_StorageExpiryDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, cooTS, moveTS				: TimeStamp;	
	include			: Boolean;
	cmifAgent			: CMIF_COOAgent;
	debtorOld, debtorNew : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create cmifAgent transient;
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
	self.deleteDebtor(DebtorNew);
	debtorNew := self.addDebtor(DebtorNew, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtorNew,"Debtor Create Failed");
	
	self.deleteOperator(OperatorNew);
	operatorNew := self.addOperator(OperatorNew, OperatorNew, false, 0, 0, debtorNew, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertTrueMsg(operatorNew &lt;&gt; null, "newOperator is NULL!");
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, operatorNew);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	self.opts.purge();
	self.opts.addAssoc("cooFreeDays", 0);
	self.opts.addAssoc("cooFreeDaysType", CM_StorageDetail.Calendar_Days);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	self.assertTrueMsg(storageDetail.cooFreeDaysType =  CM_StorageDetail.Calendar_Days, " CM_StorageDetail.Calendar_Days Error");
	self.assertTrueMsg(storageDetail.cooFreeStorageDays =  0, " CM_StorageDetail.cooFreeStorageDays Error");
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	self.setServiceRate(service,debtorNew,now.addDays(-50).date,80.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE COO HEADER
	// ###### CREATE CARGO ON VOYAGE
	// ###### ADD EACH TI TO COO WHOLE
	// #########################################
	
	numTiToCreate := 1;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	cooTS := now.addDays(0); // COO is same day as release

	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy(COOREF, null, null, app.getMyUserCode(), cooTS, null, cooTS, 0, 0, 0, 0, 0, 0, null, null, null, operatorNew, operatorOld, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 199 is null");
	
	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(weight, volume, quantity, include, cooHeader1, null, ti1);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-20);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	//self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.addDays(4).date, "TI1 Free storage is wrong");
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = moveTS.date, "TI1 Free storage is wrong");
	
	// #########################################
	// ##### EDIT TI's IMEX to trigger a CM_Storage creations
	// #########################################
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	moveTS := now.addDays(-1);
	self.opts.addAssoc("effectiveTS", moveTS);
	ti1 := tiSet[1];
	self.updateTrackedItem(ti1);
	
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 1, ti1.id &amp; " should have 1 storage transaction from the trigger");
	transaction := trans.first.CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "First Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "First Storage transaction should be CHARGED for " &amp; ti1.id);
	delete trans;
	
	
	// #########################################
	// ##### Now Approve COO 1
	// #########################################
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertTrueTrxOKShowPassport("Errors approving COO 1");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 2, "TI1 storage 2 exp detail issue");
	storageExp := ti1.allStorageExpiryDetails.first;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = now.addDays(-20).date(), "TI1 Free 1/2 storage is wrong"); // Expiry date of when we discharge the cargo from ship
	self.assertTrueMsg(storageExp.operatorCode = opCode, "TI1 Free 1/2 storage operator is wrong"); 
	storageExp := ti1.allStorageExpiryDetails.last;
	self.assertTrueMsg(storageExp.freeStorageExpiry.date = cooTS.date, "TI1 Free 2/2 storage is wrong");  // Expiry date of when we do COO
	self.assertTrueMsg(storageExp.operatorCode = OperatorNew, "TI1 Free 2/2 storage operator is wrong"); 
	
	
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TIs on COO
	// #########################################
	create tranArray transient;
	// Check Operator
	self.assertTrueMsg(ti1.operatorCode = OperatorNew, ti1.id &amp; " has incorrect new operator code. Is " &amp; ti1.operatorCode &amp; " should be " &amp; OperatorNew);
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 3, ti1.id &amp; " should have 3 storage transactions");
	
	trans.copy(tranArray);
	delete trans;
	
	// #########################################
	// ##### Check Storage transactions
	// #########################################
	
	// #########################################
	// ##### BEFORE COO
	// #########################################
	
	// First Storage transaction - Triggered, should go to old operator
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "First Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "First Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "First Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "First Storage charge should be for " &amp; debtorOld.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("19 days", 1) &gt; 0, "First Storage Invalid number of storage days");
	
	// #########################################
	// ##### After COO &gt; Release
	// #########################################
	
	// Second Storage transaction - On Release, this is old operator - From first storage transaction till COO approved
	transaction := tranArray[2].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Second - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  opCode, "Second Storage transaction should be for operator " &amp; opCode &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Second Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Second Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorOld, "Second Storage charge should be for " &amp; debtorOld.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("1 days", 1) &gt; 0, "Second Storage Invalid number of storage days");
	
	// Second Storage transaction - On Release, this is new operator - From COO approved till release
	transaction := tranArray[3].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "Third - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.operatorCode =  OperatorNew, "Third Storage transaction should be for operator " &amp; OperatorNew &amp; " for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  false, "Third Storage transaction should be CHARGED for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine &lt;&gt; null, "Third Storage - No charges for " &amp; ti1.id);
	assertTrueMsg(invLine.debtor = debtorNew, "Third Storage charge should be for " &amp; debtorNew.name);
	self.assertTrueMsg(transaction.CM_Storage.getDisplayStringForAttribute(ETRow_Details, false).pos("0 days", 1) &gt; 0, "Third Storage Invalid number of storage days");
	
	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
	
	self.deleteOwnershipChangeByRef(operatorOld, COOREF);
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete cmifAgent;
	delete tranArray;
	delete trans;

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeSplitApproval" id="7a6236c7-a55e-44c8-99a5-f283587578b6">
        <source>tOwnershipChangeSplitApproval();
/*

Purpose:			This UT tests the split approval of COO.
					First COO has individual TIs assigned to it
					Second COO has cargo group assign to it
					
					All TIs that has "included = true" should have
						- A new TI split
						- Split TI should have new operator
						- Split TI should have  Stops applied correctly		
						- Original TI and Split TI should have COO Transaction
						- Original TI and Split TI should have the correct quantity
					
					Cargo group should have
						- Operator collection with the new and old operator in it
					
					COO header should have
						- Valid COO approval date time	

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval

*/

constants
	VESSEL				= "UT58254";
	VOYAGE				= "UT58254";
	CARGOTYPEDESC 		= "UT58254";
	CGID1				= "CG58254-1";
	CGID2				= "CG58254-2";
	STOPTABLE			= 900; //08/04/2025	navkc1 Stop ID to be &lt;= 999
vars
	cargoGroup,
	cargoGroup2		: CM_CargoGroup;
	splitTI,
	tiToExclFromCOO,
	ti				: CM_TrackedItem;
	newOperator,
	operator		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1,
	cooHeader2		: CM_OwnershipChange;
	pxyCooDetails,
	subCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	pxyStopCriteria	: CM_StopCriteria;
	pxyStopTemp		: CM_StopTableTemplate;	
	pxyStopTable,
	realStop		: CM_StopsTable;
	tisToDelete,
	tiSet			: CM_TISet;
	
	tiId,
	opCode,
	newOpCode		: String;	
	i,
	transferQty,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	transferWeight,
	transferVol,
	weight			: Decimal[23,4];	
	now				: TimeStamp;	
	include			: Boolean;
	stopCheckArray,
	stopProcessArray,
	stopsSetArray	: IntegerArray;
	allOpsForStop	: ObjectSet;
	cmifAgent,
	cmifAgent2		: CMIF_COOAgent;
begin
	create cmifAgent transient;
	create cmifAgent2 transient;
	create tiSet transient;
	create tisToDelete transient;
	create pxyStopCriteria transient;
	create pxyStopTable transient;
	create pxyStopTemp transient;
	create stopsSetArray transient;
	create stopCheckArray transient;
	create stopProcessArray transient;
	create allOpsForStop transient;
	
	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	//self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operator := self.getOperator(opCode);
	
	newOpCode := "KCOP";
	newOperator := self.getOperator(newOpCode);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, newOperator); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	// Stops
	allOpsForStop.add(newOperator);
	stopsSetArray.add(StopApplyImport);
	self.deleteStopsTable(STOPTABLE);
	pxyStopCriteria.setMyStopTable(pxyStopTable);
	pxyStopCriteria.createStopCriteria(allOpsForStop, YACriteriaType_OperatorItem, pxyStopCriteria);
	pxyStopTemp.setProxy(stopCheckArray, stopsSetArray, stopProcessArray, null, false, false, false, false, false, false, false, false);
	pxyStopTemp.setPropertyValue("myStopTable", pxyStopTable);
	pxyStopTemp.setPropertyValue("myTerminal", self.getMyTerminal());
	pxyStopTable.setProxy(false, STOPTABLE.String, STOPTABLE.String, STOPTABLE.String,0, STOPTABLE, null, false, true, app.myRoot, null, null, null);
	app.myTrxCA.trxCreateStopsTable(pxyStopTable, realStop, app.myPassport);
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	
	transferQty := 2;
	transferVol := 100;
	transferWeight := 100;
	/*================================
	COO Header 1
	has 5 COO Details
	Each TI has one
	================================*/
	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO1", null, null, app.getMyUserCode(), now, null, now, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 1 is null");
	
	// Create Cargo in Cargo Group 1
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3) &amp; "A";
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		tisToDelete.add(ti);
		
		// Exclude this from COO for testing later.
		if i = 5 then
			tiToExclFromCOO := ti;
			include := false;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(transferWeight, transferVol, transferQty, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;
	self.deleteCargoGroup(CGID1);
	cargoGroup 	:= self.addCargoGroup(CGID1, tiSet);
	cooHeader1.doCreateCMIFAgent(cmifAgent);
	/*================================
	COO Header 2
	has 1 COO details of the Cargo Group
	COO Details has 5 sub details for TI
	================================*/
	
	
	// Create Ownership change 2
	delete pxyCooHeader;
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO2", null, null, app.getMyUserCode(), now, null, now, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader2);
	self.assertTrueMsg(cooHeader2 &lt;&gt; null, "COO 2 is null");
	
	// Create Cargo in Cargo Group 2
	tiSet.clear();
	foreach i in 1 to numTiToCreate do
		tiId := "CG2-" &amp; i.padLeadingWith("0", 3) &amp; "A";
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		ti.setMyCargoGroup(cargoGroup2, app.myPassport);
		tiSet.add(ti);
		tisToDelete.add(ti);
	endforeach;
	self.deleteCargoGroup(CGID2);
	cargoGroup2	:= self.addCargoGroup(CGID2, tiSet);
	
	// Create Ownership Details for Cargo Group
	delete pxyCooDetails;
	create pxyCooDetails transient;
	pxyCooDetails.setProxy(weight, volume, quantity, true, cooHeader2, null, cargoGroup2);
	self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
	self.assertTrueMsg(cooDetails &lt;&gt; null, cargoGroup2.id &amp; " does not have COO details created");
	
	// Create Ownership SUB details for TI in Cargo Group
	foreach ti in cargoGroup2.allAssignedTrackedItems do
		
		if ti = tiToExclFromCOO then
			continue;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		pxyCooDetails.setProxy(transferWeight, transferVol, transferQty, true, null, cooDetails, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, subCooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, ti.id &amp; " does not have COO details created");
	endforeach;
	cooHeader2.doCreateCMIFAgent(cmifAgent2);
	// Move all cargo to Yard
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tisToDelete do
		self.deleteStops(ti);
	endforeach;
	
	// Now Approve COO 1
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 1 - ");
	// Check COO approved status
	self.assertTrueMsg(cooHeader1.dateTimeApproved.isValid(), "cooHeader1 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader1.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	// Check Cargo Group 1 has correct Operator collection
	self.assertTrueMsg(cargoGroup.allOperators.includes(newOperator), cargoGroup.id &amp; " has incorrect allOperators collection");
	self.assertTrueMsg(cargoGroup.allOperators.includes(operator), cargoGroup.id &amp; " has incorrect allOperators collection");
	// Check cargo group 1 has COO transaction
	transaction := cargoGroup.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
	self.assertTrueMsg(transaction &lt;&gt; null, cargoGroup.id &amp; " does not have Ownership Changed Transaction created");
	// Check TIs in Cargo Group 1
	//foreach ti in cargoGroup.allAssignedTrackedItems do
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		splitTI := self.getTrackedItem(ti.id &amp; "-01");
		// This is the TI that was excluded, it shouldn't have anything changed
		if ti = tiToExclFromCOO then
			// Should not have a TI splitted 
			self.assertTrueMsg(splitTI = null, ti.id &amp; " should not have a split TI");
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = opCode, ti.id &amp; " should not have the new operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction = null, ti.id &amp; " should not have Ownership Changed Transaction created");
			// Should not have stops
			self.assertTrueMsg(not ti.hasStopOfType(realStop), ti.id &amp; " should not have Stop set.");
			// Quantity shouldn't have changed
			self.assertTrueMsg(ti.totalQuantity = quantity, ti.id &amp; " has incorrect quantity");
		// These are included in the COO, should have new operators etc..
		else
			// We should have new TI splitted
			self.assertTrueMsg(splitTI &lt;&gt; null, ti.id &amp; " doesn't have a split TI");
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = operator.code, ti.id &amp; " has incorrect operator code");
			self.assertTrueMsg(splitTI.operatorCode = newOperator.code, splitTI.id &amp; " has incorrect new operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, ti.id &amp; " does not have Ownership Changed Transaction created");
			transaction := splitTI.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, splitTI.id &amp; " does not have Ownership Changed Transaction created");
			// Should have stops applied
			self.assertTrueMsg(not ti.hasStopOfType(realStop), ti.id &amp; " should not have Stop set.");
			self.assertTrueMsg(splitTI.hasStopOfType(realStop), splitTI.id &amp; " should not have Stop set.");
			// Check Quantity
			self.assertTrueMsg(ti.totalQuantity = quantity - transferQty, ti.id &amp; " has incorrect quantity");
			self.assertTrueMsg(splitTI.totalQuantity = transferQty, splitTI.id &amp; " has incorrect quantity");
		endif;
	endforeach;
	
	// Now Approve COO 2
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader2, app.myPassport, cmifAgent2);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 2 - ");
	// Check COO approved status
	self.assertTrueMsg(cooHeader2.dateTimeApproved.isValid(), "cooHeader2 has incorrect approval datetime");
	self.assertTrueMsg(cooHeader2.dateTimeApproved.date() = now.date(), "cooHeader1 has incorrect approval date");
	// Check Cargo Group 2
	self.assertTrueMsg(cargoGroup2.allOperators.includes(newOperator), cargoGroup2.id &amp; " has incorrect allOperators collection");
	// Check Cargo group 2 has COO transaction
	transaction := cargoGroup2.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
	self.assertTrueMsg(transaction &lt;&gt; null, cargoGroup2.id &amp; " does not have Ownership Changed Transaction created");
	// Check TIs in Cargo Group 2
	foreach cooDetails in cooHeader2.allDetails do
		foreach subCooDetails in cooDetails.allSubDetails do
			ti := subCooDetails.myTrackedItem;
			splitTI := self.getTrackedItem(ti.id &amp; "-01");
			// We should have new TI splitted
			self.assertTrueMsg(splitTI &lt;&gt; null, ti.id &amp; " doesn't have a split TI");
			// Check Operator
			self.assertTrueMsg(ti.operatorCode = operator.code, ti.id &amp; " has incorrect operator code");
			self.assertTrueMsg(splitTI.operatorCode = newOperator.code, splitTI.id &amp; " has incorrect new operator code");
			// Check transaction
			transaction := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, ti.id &amp; " does not have Ownership Changed Transaction created");
			transaction := splitTI.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
			self.assertTrueMsg(transaction &lt;&gt; null, splitTI.id &amp; " does not have Ownership Changed Transaction created");
			// Should have stops applied
			self.assertTrueMsg(not ti.hasStopOfType(realStop), ti.id &amp; " should not have Stop set.");
			self.assertTrueMsg(splitTI.hasStopOfType(realStop), splitTI.id &amp; " should not have Stop set.");
			// Check Quantity
			self.assertTrueMsg(ti.totalQuantity = quantity - transferQty, ti.id &amp; " has incorrect quantity");
			self.assertTrueMsg(splitTI.totalQuantity = transferQty, splitTI.id &amp; " has incorrect quantity");
		endforeach;
	endforeach;
epilog
	
	foreach ti in tisToDelete do
		self.deleteTrackedItem(ti, true);
	endforeach;
	
	self.deleteCargoGroup(CGID1);
	self.deleteCargoGroup(CGID2);
	
	if cooHeader1 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader1);
	endif;
	if cooHeader2 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader2);
	endif;
	
	delete tiSet;
	delete tisToDelete;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete pxyStopCriteria;
	delete pxyStopTemp;
	delete pxyStopTable;
	delete stopsSetArray;
	delete stopCheckArray;
	delete stopProcessArray;
	delete allOpsForStop;
	delete cmifAgent;
	delete cmifAgent2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeStorageDtl" id="425453b1-0d8f-45f8-95bd-4ec266cae1f5">
        <source>tOwnershipChangeStorageDtl();
/*

Purpose:			This UT ensure that the storage expriry details are created correctly after a COO approval.

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58261 Task 61101: Jade - Unit Tests

*/

constants
	VESSEL				= "UT58261";
	VOYAGE				= "UT58261";
	CARGOTYPEDESC 		= "UT58261";
	CGID1				= "CG58261-1A";
	CGID2				= "CG58262-2A";
	STOPTABLE			= 58261;
	TAGROUP				= "UT58261";
vars
	root			: CM_Root;
	cargoGroup,
	cargoGroup2		: CM_CargoGroup;
	tiToExclFromCOO,
	ti				: CM_TrackedItem;
	newOperator,
	operator		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	stoExpDetail	: CM_StorageExpiryDetail;
	cargoType 		: CM_CargoType;
	pxyCooHeader,
	cooHeader1,
	cooHeader2		: CM_OwnershipChange;
	pxyCooDetails,
	subCooDetails,
	cooDetails		: CM_OwnershipChangeDetail;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	pxyStopCriteria	: CM_StopCriteria;
	pxyStopTemp		: CM_StopTableTemplate;	
	pxyStopTable,
	realStop		: CM_StopsTable;
	tisToDelete,
	allTis,
	tiSet			: CM_TISet;
	terminal		: CM_Terminal;
	storageConfig	: CM_StorageConfig;
	prevFSTrans		: CM_FutureStorage;
	storageDetail,
	storageDetail2	: CM_StorageDetail;
	taStorageGroup	: CM_TerminalAreaStorageGroup;
	terminalAreas	: CM_TerminalAreaArray;
	invLineType		: CM_InvoiceLineDesc;
	fsm				: CM_FutureStorageMapping;
	invLineTypeArray: CM_InvoiceLineDescArray;
	
	tiId,
	opCode,
	newOpCode		: String;	
	i,
	transferQty,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	transferWeight,
	transferVol,
	weight			: Decimal[23,4];	
	daysAgo15,
	lastMonth,
	now				: TimeStamp;	
	include			: Boolean;
	stopCheckArray,
	stopProcessArray,
	storageDtlCriteria,
	stopsSetArray	: IntegerArray;
	allOpsForStop	: ObjectSet;
	storageDtlCritV : ObjectArray;
	cmifAgent,
	cmifAgent2		: CMIF_COOAgent;
begin
	
	create cmifAgent transient;
	create cmifAgent2 transient;
	create tiSet transient;
	create tisToDelete transient;
	create pxyStopCriteria transient;
	create pxyStopTable transient;
	create pxyStopTemp transient;
	create stopsSetArray transient;
	create stopCheckArray transient;
	create stopProcessArray transient;
	create allOpsForStop transient;
	create terminalAreas transient;
	create storageDtlCriteria transient;
	create storageDtlCritV transient;
	create invLineTypeArray transient;
	create allTis transient;
	
	daysAgo15 := now;
	daysAgo15.setDate(daysAgo15.date()-15);
	
	root := app.myRoot;
	
	//self.setTerminalConfig(CooSplitOperator, false);
	
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operator := self.getOperator(opCode);
	
	newOpCode := "KCOP";
	newOperator := self.getOperator(newOpCode);
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	self.addOperatorToVoyage(voyage, newOperator); // ### JIRA UT 22JAN2025 NAVAB1
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58261TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	// Stops
	allOpsForStop.add(newOperator);
	stopsSetArray.add(StopApplyImport);
	self.deleteStopsTable(STOPTABLE);
	pxyStopCriteria.setMyStopTable(pxyStopTable);
	pxyStopCriteria.createStopCriteria(allOpsForStop, YACriteriaType_OperatorItem, pxyStopCriteria);
	pxyStopTemp.setProxy(stopCheckArray, stopsSetArray, stopProcessArray, null, false, false, false, false, false, false, false, false);
	pxyStopTemp.setPropertyValue("myStopTable", pxyStopTable);
	pxyStopTemp.setPropertyValue("myTerminal", self.getMyTerminal());
	pxyStopTable.setProxy(false, STOPTABLE.String, STOPTABLE.String, STOPTABLE.String,0, STOPTABLE, null, false, true, app.myRoot, null, null, null);
	app.myTrxCA.trxCreateStopsTable(pxyStopTable, realStop, app.myPassport);
	
	terminal := self.getMyTerminal();
	
	// Storage Config
	self.deleteStorageConfig(true);
	storageConfig := terminal.myStorageConfig;
	
	// Storage Detail
	storageDtlCriteria.add(YACriteriaType_CargoType);
	storageDtlCritV.add(self.getCargoType(CARGOTYPEDESC));
	storageDtlCriteria.add(YACriteriaType_OperatorItem);
	storageDtlCritV.add(operator);
	
	storageDetail := self.addStorageDetail(storageConfig, "UT" &amp; method.name, storageDtlCriteria, storageDtlCritV, 0, 5, false, false, 0, 0, false, null);
	
	// Storage Detail
	storageDtlCriteria.clear();
	storageDtlCritV.clear();
	storageDtlCriteria.add(YACriteriaType_CargoType);
	storageDtlCritV.add(self.getCargoType(CARGOTYPEDESC));
	storageDtlCriteria.add(YACriteriaType_OperatorItem);
	storageDtlCritV.add(newOperator);
	storageDetail2 := self.addStorageDetail(storageConfig, "UT-2" &amp; method.name, storageDtlCriteria, storageDtlCritV, 0, 2, false, false, 0, 0, false, null);
	
	// Terminal Area Storage Group
	self.deleteTerminalAreaStorageGroup(TAGROUP);
	
	terminalAreas.add(terminalArea);
	taStorageGroup := self.addTerminalAreaStorageGroup(TAGROUP, TAGROUP, terminalAreas);
	invLineType := self.getInvoiceLineType("UTSSMinChg");
	invLineTypeArray.add(invLineType);
	
	// Future Storage mapping
	fsm := self.addFutureStorageMapping2(self.myBank, taStorageGroup, storageDetail, invLineType.myCalculationType, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	fsm := self.addFutureStorageMapping2(self.myBank, taStorageGroup, storageDetail2, invLineType.myCalculationType, null, CM_QuantityMap.MapType_Single, TranMapInvLineGroupTypeAll, false, 0, 999999, invLineTypeArray);
	
	numTiToCreate := 5;
	
	quantity := 10;
	volume := 500;
	weight := 500;
	
	transferQty := 10;
	transferVol := 500;
	transferWeight := 500;
	/*================================
	COO Header 1
	has 5 COO Details
	Each TI has one
	================================*/
	// Create Ownership change 1
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO11", null, null, app.getMyUserCode(), daysAgo15, null, daysAgo15, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null); // ### TFS BUG 64680 21JUNE024 NAVAB1 set new free expiry //navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader1);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 1 is null");
	
	// Create Cargo in Cargo Group 1
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3) &amp; "A";
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		beginTransaction;
			ti.setPropertyValue("receivedDT", lastMonth);
			foreach transaction in ti.allTransactions do
				lastMonth := transaction.dateTime;
				lastMonth.setDate(lastMonth.date()-30);
				transaction.setPropertyValue("dateTime", lastMonth);
			endforeach;
		commitTransaction;
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti);
		tisToDelete.add(ti);
		
		// Exclude this from COO for testing later.
		if i = 5 then
			tiToExclFromCOO := ti;
			include := false;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		// Create OwnerShip Change Details
		pxyCooDetails.setProxy(transferWeight, transferVol, transferQty, include, cooHeader1, null, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, tiId &amp; " does not have COO details created");
	endforeach;
	self.deleteCargoGroup(CGID1);
	cargoGroup 	:= self.addCargoGroup(CGID1, tiSet);
	cooHeader1.doCreateCMIFAgent(cmifAgent);
	
	/*================================
	COO Header 2
	has 1 COO details of the Cargo Group
	COO Details has 5 sub details for TI
	================================*/
	
	
	// Create Ownership change 2
	delete pxyCooHeader;
	create pxyCooHeader transient;
	pxyCooHeader.setProxy("COO22", null, null, app.getMyUserCode(), daysAgo15, null, null, 0, 0, 0, 0, 0, 0, null, null, null, newOperator, operator, null, null, null, self.getMyTerminal(), null);	//navra1 - TFS 64874 - 14th Aug 2024
	self.createOwnershipChange(pxyCooHeader, cooHeader2);
	self.assertTrueMsg(cooHeader1 &lt;&gt; null, "COO 2 is null");
	
	// Create Cargo in Cargo Group 2
	tiSet.clear();
	foreach i in 1 to numTiToCreate do
		tiId := "CG2-" &amp; i.padLeadingWith("0", 3) &amp; "A";
		
		ti := self.getTrackedItem(tiId);
		if ti &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti := self.createGCOnVoyage(false, "", tiId, cargoType, operator, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		ti.setMyCargoGroup(cargoGroup2, app.myPassport);
		tiSet.add(ti);
		tisToDelete.add(ti);
	endforeach;
	self.deleteCargoGroup(CGID2);
	cargoGroup2	:= self.addCargoGroup(CGID2, tiSet);
	
	// Create Ownership Details for Cargo Group
	delete pxyCooDetails;
	create pxyCooDetails transient;
	pxyCooDetails.setProxy(weight, volume, quantity, true, cooHeader2, null, cargoGroup2);
	self.createOwnershipChangeDetail(pxyCooDetails, cooDetails);
	self.assertTrueMsg(cooDetails &lt;&gt; null, cargoGroup2.id &amp; " does not have COO details created");
	
	// Create Ownership SUB details for TI in Cargo Group
	foreach ti in cargoGroup2.allAssignedTrackedItems do
		if ti = tiToExclFromCOO then
			continue;
		endif;
		
		delete pxyCooDetails;
		create pxyCooDetails transient;
		
		pxyCooDetails.setProxy(transferWeight, transferVol, transferQty, true, null, cooDetails, ti);
		self.createOwnershipChangeDetail(pxyCooDetails, subCooDetails);
		self.assertTrueMsg(cooDetails &lt;&gt; null, ti.id &amp; " does not have COO details created");
	endforeach;
	cooHeader2.doCreateCMIFAgent(cmifAgent2);
	// Move all cargo to Yard
	lastMonth := now;
	lastMonth.setDate(lastMonth.date() - 30);
	self.opts.purge();
	self.opts.addAssoc("effectiveTS", lastMonth);
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti in tisToDelete do
		self.deleteStops(ti);
	endforeach;
	
	// Need to run the BGP here
	self.processOfflineFutureActors(lastMonth, now);
	
	// Now Approve COO 1
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader1, app.myPassport, cmifAgent);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 1 - ");
	
	// Now Approve COO 2
	app.myTrxUA.trxUpdateOwnershipChangeApprov(cooHeader2, app.myPassport, cmifAgent2);
	// No errors
	self.assertNoTrxErrorsPassport("Errors approving COO 2 - ");

	// Run the BGP again
	self.processOfflineFutureActors(daysAgo15, now);
	
	// Check we have correct storage details for COO 1
	foreach cooDetails in cooHeader1.allDetails do
		ti := cooDetails.myTrackedItem;
		if ti = tiToExclFromCOO then
			continue;
		endif;
		prevFSTrans := null;
		self.assertTrueMsg(ti.allStorageExpiryDetails.size() = 2, ti.id &amp; " has incorrect number of storage expiry details.");
		stoExpDetail := ti.getLastStorageExpDetailWithCOO();
		self.assertTrueMsg(stoExpDetail &lt;&gt; null, ti.id &amp; " should have new storage expiry details with COO");
		self.assertTrueMsg(stoExpDetail.myOwnershipChange = cooHeader1, ti.id &amp; " should have new storage expiry details with COO");
		self.assertTrueMsg(stoExpDetail.freeStorageExpiry.date() = cooHeader1.dateTimeCOO.date, ti.id &amp; " new storage expiry details has incorrect date (cooHeader1)"); // ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1 use freeStorageExpiry
		
		// Check the future storage days is correct
		foreach transaction in ti.allTransactions where transaction.type = TRANS_TYPE_FUTURE_STORAGE and not transaction.isDeleted() and transaction.dateTime &gt;= daysAgo15 do
			if prevFSTrans &lt;&gt; null then
				self.assertTrueMsg(transaction.dateTime.date() - prevFSTrans.dateTime.date() = 2, ti.id &amp; " FS interval days are incorrect");
				prevFSTrans := transaction.CM_FutureStorage;
			endif;
		endforeach;
	endforeach;
	
	// Check we have correct storage details for COO 2
	foreach cooDetails in cooHeader2.allDetails do
		foreach subCooDetails in cooDetails.allSubDetails do
			ti := subCooDetails.myTrackedItem;
			if ti = tiToExclFromCOO then
				continue;
			endif;
			prevFSTrans := null;
			self.assertTrueMsg(ti.allStorageExpiryDetails.size() = 2, ti.id &amp; " has incorrect number of storage expiry details.");
			stoExpDetail := ti.getLastStorageExpDetailWithCOO();
			self.assertTrueMsg(stoExpDetail &lt;&gt; null, ti.id &amp; " should have new storage expiry details with COO");
			self.assertTrueMsg(stoExpDetail.myOwnershipChange = cooHeader2, ti.id &amp; " should have new storage expiry details with COO");
			self.assertTrueMsg(stoExpDetail.freeStorageExpiry.date() = cooHeader2.dateTimeCOO.date, ti.id &amp; " new storage expiry details has incorrect date (cooHeader2)"); // ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1 use freeStorageExpiry
			
			// Check the future storage days is correct
			foreach transaction in ti.allTransactions where transaction.type = TRANS_TYPE_FUTURE_STORAGE and not transaction.isDeleted() and transaction.dateTime &gt;= daysAgo15 do
				if prevFSTrans &lt;&gt; null then
					self.assertTrueMsg(transaction.dateTime.date() - prevFSTrans.dateTime.date() = 2, ti.id &amp; " FS interval days are incorrect");
					prevFSTrans := transaction.CM_FutureStorage;
				endif;
			endforeach;
		endforeach;
	endforeach;

	
epilog
	
	if cooHeader1 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader1);
	endif;
	if cooHeader2 &lt;&gt; null then
		self.deleteOwnershipChange(cooHeader2);
	endif;
	
	self.deleteTerminalAreaStorageGroup(TAGROUP);
	
	delete tiSet;
	delete tisToDelete;
	delete pxyCooHeader;
	delete pxyCooDetails;
	delete pxyStopCriteria;
	delete pxyStopTemp;
	delete pxyStopTable;
	delete stopsSetArray;
	delete stopCheckArray;
	delete stopProcessArray;
	delete allOpsForStop;
	delete storageDtlCriteria;
	delete storageDtlCritV;
	delete terminalAreas;
	delete invLineTypeArray;
	delete allTis;
	delete cmifAgent;
	delete cmifAgent2;
end;</source>
    </JadeMethod>
    <JadeMethod name="uOwnershipChangeRelStorage10" id="a358e891-ed8f-4446-bcf4-e75f4caf28ae">
        <source>uOwnershipChangeRelStorage10();
/*

Purpose:		Release Storage Testing. This means CM_Storage transaction.
					This is not ownership change, it is just testing an ordinary release before the free storage expiry
					
					Need a storage configuration for release storage
					Need invoicing for Storage to create invoice lines
					
					Receive cargo from ship, check free storage period
					
					The free storage period is 10 days, 
					the Cargo is released 2 days after receival, There should be NO storage charges.
	
Parameters:			

Return Value:		

Date		Who		Reason
/*
Purpose - 	
Who - NAVAB1
Date - 13APR2024
ADO - BUG 63683 
*/

constants
	InvType_Storage = "UT_COOSTORAGE";
	CalType_Code_Storage = "UT_CALTYPE_COO";
	CalType_Desc_Storage = "UT_CalType_COO_Desc";
	Srvc_COOStorage = "UT_SRVC_COOSTO";
	InvLineType_Code = "UT_COOSTO";
	Debtor_Type = "SDT1";
	TransType_Storage = "Storage";
	TransMap_UT = "UtTransMap";
	VESSEL				= "UT58263";
	VOYAGE				= "UT58263";
	CARGOTYPEDESC 		= "UT_ABPULP";
	TRUCKID = "COOSTO";
vars
	vvr : CM_VehicleVisitRecord;
	ti1, ti4				: CM_TrackedItem;
	operatorOld		: CM_Operator;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	port 			: CM_Port;
	cargoType 		: CM_CargoType;
	terminalArea	: CM_TerminalArea;
	transaction		: CM_TITransaction;
	tiSet			: CM_TIArray;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	values		: ObjectArray;
	criteria	: IntegerArray;
	storageDetail : CM_StorageDetail;
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	tiId,
	opCode : String;
	i,
	quantity,
	numTiToCreate	: Integer;	
	volume,
	weight			: Decimal[23,4];	
	now, moveTS				: TimeStamp;	
	include			: Boolean;
	debtorOld : CM_Debtor;
	trans : CM_TITransactionSet;
	tranArray:  CM_ObjectArray;
begin
	
	create tiSet transient;

	self.setTerminalConfig(CooSplitOperator, false);
	self.setTerminalConfig(NoImportStops, false);
	
	
	// #########################################
	// ##### SUPPORTING DATA
	// #########################################
	
	self.deleteVehicle(TRUCKID);

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CARGOTYPEDESC );
	if cargoType= null then
		cargoType := self.addCargoType(CARGOTYPEDESC, false);
	endif;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	operatorOld := self.getOperator(opCode);
		
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	port := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	terminalArea := self.addBlockStack("UT58254TA",9999999,null);
	self.assertNotNullMsg(terminalArea, "TA1 is null");
	
	
	// #########################################
	// #### STORAGE CONFIG
	// #########################################

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_EX_TO_IM, false, null);
	triggers.add(pxyStorageTrigger);
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_EX, false, null);
	triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(cargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	
	storageDetail:=self.addStorageDetail(storageConfig, CARGOTYPEDESC &amp; " Storage",criteria,values,10,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null);
	self.assertNotNull(storageDetail);
	
	// #########################################
	// ##### STORAGE INVOICING
	// #########################################
	debtorOld := operatorOld.debtor;
	
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_COOStorage);
	self.deleteTransactionMapByName(TransMap_UT);
	self.deleteInvoiceType(InvType_Storage);

	invType := self.createInvoiceType(InvType_Storage, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Storage &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_Storage, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_Storage,
										   CalType_Desc_Storage, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_Storage &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_COOStorage, Srvc_COOStorage, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_COOStorage &amp; " not created");
	services.add(service);
	
	self.setServiceRate(service,debtorOld,now.addDays(-50).date,40.00);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	
	self.loadTransMap(TransMap_UT, TransType_Storage, invLineType.narration);
	
	
	
	
	// #########################################
	// ###### CREATE CARGO ON VOYAGE
	// #########################################
	
	numTiToCreate := 2;
	
	quantity := 10;
	volume := 500;
	weight := 500;

	// Create Cargo 
	foreach i in 1 to numTiToCreate do
		include := true;
		tiId := "CG1-" &amp; i.padLeadingWith("0", 3);
		
		ti1 := self.getTrackedItem(tiId);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(tiId, true);
		endif;
		
		ti1 := self.createGCOnVoyage(false, "", tiId, cargoType, operatorOld, voyage, port, weight.Integer, volume, quantity);
		
		self.assertTrueMsg(ti1 &lt;&gt; null, tiId &amp; " is null, Cargo not created");
		tiSet.add(ti1);
	endforeach;

	// #########################################
	// ##### Move all cargo to Yard
	// #########################################
	self.opts.purge();
	moveTS := now.addDays(-2);
	self.opts.addAssoc("effectiveTS", moveTS);
	
	
	self.moveAllCargoOnVoyage2(voyage, terminalArea.getMyLocationsController(), false);
	self.opts.purge();
	
	// Delete all stops. Check the stops are applied correctly after COO is done
	foreach ti1 in tiSet do
		self.deleteStops(ti1);
	endforeach;
	
	ti1 := tiSet[1];
	self.assertTrueMsg(ti1.allStorageExpiryDetails.size = 1, "TI1 storage 1 exp detail issue");
	
	// #########################################
	// ##### Release Cargo to create storage transactions
	// #########################################
	
	ti1 := tiSet[1];
	vvr := self.createVVRForTI(TRUCKID,ti1,ti1.totalQuantity);	
	self.assertTrueTrxOKShowPassport("VVR ISSUE");
	
	ti4 := vvr.myRoadJob.workListEntries.first.myTrackedItem;
	self.assertTrueMsg(ti4 &lt;&gt; null, "TI4 is null, should be on road job");
	self.assertTrueMsg(ti4 = ti1, "TI4 should be TI1, we moved the whole TI");
	self.assertTrueMsg(ti1.locationId = TRUCKID &amp; " Road", ti1.id &amp; " Should be on truck " &amp; TRUCKID &amp; " is " &amp; ti1.locationId);
	
	self.roadExit(vvr);
	
	self.assertTrueTrxOKShowPassport("ROAD EXIT ISSUE");
	
	
	
	// #########################################
	// ##### Check TI Released
	// #########################################
	create tranArray transient;
	
	trans := ti1.getAllTransactionsOfType(TRANS_TYPE_STORAGE);
	self.assertTrueMsg(trans.size = 1, ti1.id &amp; " should have 1 storage transaction");
	
	trans.copy(tranArray);
	delete trans;
	
	transaction := tranArray[1].CM_TITransaction;
	self.assertTrueMsg(transaction.type =  TRANS_TYPE_STORAGE, "First - No Storage transaction for " &amp; ti1.id);
	self.assertTrueMsg(transaction.noCharge =  true, "First Storage transaction should be NOCHARGE for " &amp; ti1.id);
	invLine := transaction.allInvoiceLines.first;
	assertTrueMsg(invLine = null, "First Storage - has been charged, should be No Charge " &amp; ti1.id);
	

	// #########################################
	// ##### TIDY UP
	// #########################################
	
	foreach ti1 in tiSet do
		self.deleteTrackedItem(ti1, true);
	endforeach;
	
epilog
	self.resetDefaultTranMap();
	delete services;
	delete tiSet;
	delete tranArray;
	delete trans; // ### TFS BUG 64177 21MAY2024 NAVAB1
	

	delete criteriaTypes;
	if triggers &lt;&gt; null then
		triggers.purge();
	endif;
	delete triggers;
	delete values;
	delete criteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="uOwnershipTest1000" id="2f95dc0a-e3db-478c-99eb-ad819dae9966">
        <updating/>
        <source>uOwnershipTest1000()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2023 navtnr20	TFS CR 58507	Task 58212: Jade - Test script to Create Test COO

*/
constants
	DODELETE = true; //  if TRUE this will purge all ownerships
	AMOUNTTOCREATE = 4;
	OPOLD = "CO1";
	OPNEW = "CO2";
	OPORIG = "CO3";
	OPSTO = "CON7";
	FF1 = "UTF2";
	BLKSTK = "OWN1";
	
vars
	dateTimeCOO,dateTimeApproved,storageExpriryOperatorNew: TimeStamp;
	remarks 					: String;
	myiNCOTerm					: CM_InvoiceINCOTerm;
	myOperatorNew,
	myOperatorOid,
	myOperatorOrig,
	myOperatorStorage			: CM_Operator;
	myFreightForward			: CM_ConsigneeConsignor;
	terminal					: CM_Terminal;
	myOwnerShip,realOwnershipChange		: CM_OwnershipChange;
	transferedWeight, transferedVolume 					: Decimal[23,4];
	debtor1												: CM_Debtor;
	doDelete											: Boolean;
	idx,contractSeq,size									: Integer;
	refrenceNum,cargoID 										: String;
	operatorNew											: String;
	ti	: CM_TrackedItem;
	cargoType : CM_CargoType;
	bs						: CM_BlockStack;
	commodiy : String;
	cargoTypeArray :ObjectArray;
begin
	doDelete := DODELETE;
	
	terminal := self.getTerminal();
	if doDelete then
		self.deleteAllOwnerships();
		self.deleteInvINCOTerm("ABC");
		self.deleteOperator(OPOLD);
		self.deleteOperator(OPNEW);
		self.deleteOperator(OPORIG);
		self.deleteOperator(OPSTO);
		//self.deleteConsigneeConsignor("UTFreightForward");
		self.deleteConsigneeConsignor(FF1);
		myOperatorNew := self.addOperator(OPNEW, OPNEW &amp; " Ownership Change", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
		self.assertNotNullMsg(myOperatorNew,OPNEW &amp; " - Operator Create Failed");
		myOperatorOid := self.addOperator(OPOLD, OPOLD &amp; " Ownership Change", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
		self.assertNotNullMsg(myOperatorOid,OPOLD &amp; " - Operator Create Failed");
		myOperatorOrig := self.addOperator(OPORIG, OPORIG &amp; " Ownership Change", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
		self.assertNotNullMsg(myOperatorOrig, OPORIG &amp; " - Operator Create Failed");
		myFreightForward := self.addConsigneeConsignor(FF1, FF1 &amp; " Freight Forward", true, false, false);
		self.assertNotNullMsg(myFreightForward, FF1 &amp; " - FFr Create Failed");
		myOperatorStorage := self.addOperator(OPSTO, OPSTO &amp; " Ownership Change", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
		self.assertNotNullMsg(myOperatorStorage,OPSTO &amp; " - Operator Create Failed");
		
		bs := self.addBlockStack("BSLOCC", 49, null);
		self.assertNotNull(bs);
		/*cargoType := self.getCargoType("CANNON");
		if cargoType.allCommodities.size &gt; 0 then
				commodiy := cargoType.allCommodities.first.code;
			else
				commodiy := null;
			endif;
		
		self.deleteCargo("UT_MATOCC", cargoType);
		ti := self.createTrackedItem("UT_MATOCC", cargoType.id, "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false, bs.myLocationsController);*/
		
		//self.assertNotNull(ti);
		self.deleteInvINCOTerm("abcd");
		self.contractINCOCreate(myiNCOTerm, "abcd");
	endif;
	
	if self.opts.includesKey("DtRequired") then
		dateTimeApproved := self.opts.str("DtRequired").TimeStamp;
	endif;
	
	dateTimeCOO.setFromYYYYMMDDHHmm("202104181216");
	storageExpriryOperatorNew.setFromYYYYMMDDHHmm("20210312119");
	
	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
	endif;
	
	transferedWeight		:= 91.78;
	transferedVolume		:= 14.8974;
	myFreightForward := self.addConsigneeConsignor("UTFr", "FreightForward", true, false, false);
	
		create cargoTypeArray transient;
	foreach cargoType in app.myRoot.allCargoTypesById do
		cargoTypeArray.add(cargoType);
		size:= size+1;
		
		if size = AMOUNTTOCREATE then
			break;
		endif;
	endforeach;
	
	foreach idx in 1 to AMOUNTTOCREATE do
		contractSeq := idx;
		refrenceNum := myOperatorNew.code.removeInvalidChars() &amp; contractSeq.padLeadingWith("0",3);
		cargoID	:= "CANNON" &amp; contractSeq.padLeadingWith("0",3);
		cargoType:= cargoTypeArray[idx].CM_CargoType;
		if cargoType.allCommodities.size &gt; 0 then
			commodiy := cargoType.allCommodities.first.code;
		else
			commodiy := null;
		endif;
		self.deleteCargo(cargoID, cargoType);
		ti := self.createTrackedItem(cargoID, cargoType.id, commodiy, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false, bs.myLocationsController);
		self.assertNotNull(ti);
		if idx mod 50 = 0 then
			write refrenceNum;
		
		endif;
		// create ownership
		realOwnershipChange := self.createOwnership000d(refrenceNum,app.getMyUserCode(),"Bad",app.getMyUserCode(),self.systemToLocalTime(dateTimeCOO) ,self.systemToLocalTime(dateTimeApproved),self.systemToLocalTime(storageExpriryOperatorNew),121,717,483,125,transferedWeight,transferedVolume,"Good COO",
		myFreightForward,myiNCOTerm,myOperatorNew,myOperatorOid,myOperatorOrig,myOperatorStorage,null,terminal);
		//create OwnershipDetail -1
		createOwnershipDetail000d(3500.535,0,0,true,realOwnershipChange,null,ti);	
		//create ownershipdetail1-2
		createOwnershipDetail000d(3205.535,0,0,false,realOwnershipChange,null,ti);
		//create OwnershipDetail -3
		createOwnershipDetail000d(2805.535,0,0,true,realOwnershipChange,null,ti);
		
		
	endforeach;
epilog
	
	delete cargoTypeArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="uOwnershipTest2000" id="252cc013-023c-4c57-bd9b-d9a5a7dd8375">
        <updating/>
        <source>uOwnershipTest2000()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2023 navtnr20	TFS CR 58507	Task 58212: Jade - Test script to Create Test COO

*/
constants
	DODELETE = false; //  if TRUE this will purge all ownerships
	COOTOCREATE = 3;
	DTLTOCREATE = 5;
	OPOLD = "OWNM";
	OPNEW = "OWNY";
	OPORIG = "OWNR";
	OPSTO = "OWNO";
	FF1 = "OWNF1"; // max LENGTH  IS 5
	BLKSTK = "OWN1";
	INCO = "abcd";
	CONTRACTID = "";
	VESSEL = "COO";
	VOYAGE1 = "COO230629";
vars
	dateTimeCOO,dateTimeApproved,storageExpriryOperatorNew: TimeStamp;
	remarks : String;
	myiNCOTerm : CM_InvoiceINCOTerm;
	myOperatorNew,
	myOperatorOld,
	myOperatorOrig,
	myOperatorStorage : CM_Operator;
	myFreightForward : CM_ConsigneeConsignor;
	terminal : CM_Terminal;
	myOwnerShip,realOwnershipChange		: CM_OwnershipChange;
	cooDetail : CM_OwnershipChangeDetail;
	transferedWeight, transferedVolume, totalWeight, totalVolume : Decimal[23,4];
	transferedQuantity, totalQuantity : Integer;
	debtor1 : CM_Debtor;
	doDelete : Boolean;
	idx, idy,contractSeq : Integer;
	refrenceNum : String;
	ti	: CM_TrackedItem;
	cargoType : CM_CargoType;
	bs : CM_BlockStack;
	cargoId : String;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
begin
	doDelete := DODELETE;
	dateTimeCOO.setFromYYYYMMDDHHmm("202307131215");
	cargoType := self.getCargoType("CANNON");
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	transferedWeight := 0;
	transferedVolume := 0;
	transferedQuantity := 0;
	bs := self.addBlockStack(BLKSTK, 999999, null);
	self.assertNotNull(bs);
	
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];

	
	terminal := self.getTerminal();
	if doDelete then
		self.deleteOwnershipChangeForTerm();
	endif;
		
	myOperatorNew := app.myRoot.allOperators[OPNEW];
	if myOperatorNew = null then
		myOperatorNew := self.addOperator(OPNEW, OPNEW &amp; " Ownership Change", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
		self.assertNotNullMsg(myOperatorNew,OPNEW &amp; " - Operator Create Failed");
	endif;
	myOperatorOld := app.myRoot.allOperators[OPOLD];
	if myOperatorOld = null then
		myOperatorOld := self.addOperator(OPOLD, OPOLD &amp; " Ownership Change", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
		self.assertNotNullMsg(myOperatorOld,OPOLD &amp; " - Operator Create Failed");
	endif;
	myOperatorOrig := app.myRoot.allOperators[OPORIG];
	if myOperatorOrig = null then
		myOperatorOrig := self.addOperator(OPORIG, OPORIG &amp; " Ownership Change", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
		self.assertNotNullMsg(myOperatorOrig, OPORIG &amp; " - Operator Create Failed");
	endif;
	myOperatorStorage := app.myRoot.allOperators[OPSTO];
	if myOperatorStorage = null then
		myOperatorStorage := self.addOperator(OPSTO, OPSTO &amp; " Ownership Change", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
		self.assertNotNullMsg(myOperatorStorage,OPSTO &amp; " - Operator Create Failed");
	endif;
	myFreightForward := app.myRoot.allConsigneeConsignors[FF1];
	if myFreightForward = null then
		myFreightForward := self.addConsigneeConsignor(FF1, FF1 &amp; " Freight Forward", true, false, false);
		self.assertNotNullMsg(myFreightForward, FF1 &amp; " - FFr Create Failed");
	endif;

	storageExpriryOperatorNew := app.actualTimeAppServer();
	
	self.deleteInvINCOTerm(INCO);
	self.contractINCOCreate(myiNCOTerm, INCO);
	
	foreach idx in 1 to COOTOCREATE do
		contractSeq := idx;
		refrenceNum := myOperatorNew.code.removeInvalidChars() &amp; dateTimeCOO.date.year.String &amp; dateTimeCOO.date.month.String &amp; dateTimeCOO.date.day.String &amp; contractSeq.padLeadingWith("0",4);
		
		if idx mod 50 = 0 then
			write refrenceNum;
		
		endif;
		// create ownership
		realOwnershipChange := self.createOwnership000d(refrenceNum,app.getMyUserCode(),"Good",
				app.getMyUserCode(),dateTimeCOO,dateTimeApproved,storageExpriryOperatorNew,1,2,3,transferedQuantity,transferedWeight,transferedVolume,"Generated " &amp; method.qualifiedName,
				myFreightForward,myiNCOTerm,myOperatorNew,myOperatorOld,myOperatorOrig,myOperatorStorage,null,terminal);
		
		
		
		foreach idy in 1 to DTLTOCREATE do
			cargoId := "OWN" &amp; dateTimeCOO.date.year.String &amp; dateTimeCOO.date.month.String &amp; dateTimeCOO.date.day.String &amp; contractSeq. String &amp; "-" &amp; idy.padLeadingWith("0",4);
			
			ti := self.createGCOnVoyage(doDelete, CONTRACTID, cargoId, cargoType, myOperatorOld, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity);
			assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
			cooDetail := self.createOwnershipDetail000d(totalWeight -transferedWeight,totalVolume - transferedVolume,totalQuantity - transferedQuantity,true,realOwnershipChange,null,ti);	
		
		
		endforeach;
		
		
	endforeach;
epilog
	

end;</source>
    </JadeMethod>
