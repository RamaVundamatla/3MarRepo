    <JadeMethod name="selectionCriteria" id="86352155-c581-4e8f-be5a-4a2363e295a8">
        <methodInvocation>mapping</methodInvocation>
        <source>selectionCriteria(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     08 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str				:String;
begin
	inheritMethod(set, _value);

	str := _value;
	
	if str &lt;&gt; null then
		str := str &amp; CrLf &amp; "Start Date:";
	else
		str :=              "Start Date:";
	endif;
	
	str := str &amp; CrLf &amp; "End Date:";
	
	if self.myMachineType &lt;&gt; null then
		str := str &amp; CrLf &amp; "Machine Type:";
	endif;
	
	if self.myMachine &lt;&gt; null then
		str := str &amp; CrLf &amp; "Machine:";
	endif;
	
	if self.myUser &lt;&gt; null then
		str := str &amp; CrLf &amp; "User:";
	endif;
	
	if not self.allDelayTypeGroups.isEmpty then
		str := str &amp; CrLf &amp; "Delay Type Group(s):";
	endif;
	
	if not self.allDelayTypes.isEmpty then
		str := str &amp; CrLf &amp; "Delay Type(s):";
	endif;
epilog
	_value := str;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="selectionCriteriaValues" id="c8021298-35a4-4271-b652-c1dd1db34b6b">
        <methodInvocation>mapping</methodInvocation>
        <source>selectionCriteriaValues(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     08 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str				:String;
	tsFrom, tsTo	:TimeStamp;
	delayType		:CM_DelayType;
	delayTypeGroup	:CM_DelayTypeGroup;
begin
	inheritMethod(set, _value);

	str := _value;
	
	tsFrom.setDate (self.dateFrom);
	tsFrom.setTime (self.timeFrom);
	tsTo.setDate (self.dateTo);
	tsTo.setTime (self.timeTo);
	
	if str &lt;&gt; null then
		str := str &amp; CrLf &amp; tsFrom.asStringJMT;
	else
		str :=              tsFrom.asStringJMT;
	endif;
	
	str := str &amp; CrLf &amp; tsTo.asStringJMT;
	
	if self.myMachineType &lt;&gt; null then
		str := str &amp; CrLf &amp; self.myMachineType.description;
	endif;
	
	if self.myMachine &lt;&gt; null then
		str := str &amp; CrLf &amp; self.myMachine.code;
	endif;
	
	if self.myUser &lt;&gt; null then
		str := str &amp; CrLf &amp; self.myUser.code;
	endif;
	
	foreach delayTypeGroup in self.allDelayTypeGroups do
		str := str &amp; CrLf &amp; delayTypeGroup.description;
	endforeach;
	
	foreach delayType in self.allDelayTypes do
		str := str &amp; CrLf &amp; delayType.description;
	endforeach;
epilog
	_value := str;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
