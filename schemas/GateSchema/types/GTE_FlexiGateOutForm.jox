    <JadeMethod name="doMoveTrackedItem" id="25fe7840-2341-4a03-a50b-bba1591e2858">
        <updating/>
        <source>doMoveTrackedItem(_toLocation : CM_LocationsController ; _wle : CM_WorkListEntry) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2011	cnwndl1	Initial creation	Par 28366

*/

vars
	moveController	: CMIF_MoveController;
	result		: Integer;
begin

	if app.myMoveController = null then
		return;
	endif;

	if _toLocation = null then
		app.raiseCMException1(INVALID_MOVE_REQUEST, 'No Target Location found.', null, null);	
		return;
	endif;

	moveController := app.myMoveController;
	
	if _wle &lt;&gt; null then
		moveController.setMyWorkListEntry(_wle);
		//moveController.setJobForMove(_wle.job);
	endif;

	moveController.setMyToPrimaryLocation(_toLocation);
		
	while true do
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	app.myMoveController := null;
	if moveController &lt;&gt; null then
		delete moveController;
	endif;
	self.tblReceivals.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="b72e47d0-d507-4fa4-94fe-49a22dad8127">
        <updating/>
        <source>doPrint() updating;
// --------------------------------------------------------------------------------
// Created:		01 July 2010 by cnwjo3
//
// Purpose:		par 24747
//
vars
	copies : Integer;
	preview : Boolean;
begin
	//inheritMethod();
//	copies := 1;//self.myTerminal.getConfig(GateReceiptCopies).Integer;
//	preview := true;//self.myTerminal.getConfig(PrintPreview).Boolean;
	
	//14 Nov 2011	NDL	Par 28366
	copies := self.cmbCopies.text.Integer;
	preview := self.chkPrintPreview.value;

	if self.myVisitRecord &lt;&gt; null then
		//self.myVisitRecord.printReceipt(1,true,self.myTerminal,self.myTerminal.getRoadReceiptReport().String,null);
		//self.myVisitRecord.printReceipt(copies, preview, self.myTerminal, self.myTerminal.getRoadReceiptReport().String, null, null);	//14 Nov 2011	NDL	Par 28366
		//12 Dec 2013	NDL	Par 33184
		self.myVisitRecord.printRoadReceipt(	copies,	//_copies : Integer;
												preview,	//_printPreview : Boolean;
												null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryRowColumnChange" id="e7a7fefa-5b89-468d-a98d-514e0e1c7768">
        <updating/>
        <source>doQueryRowColumnChange(table: Table input; newRow: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2011	cnwndl1	Initial creation	Par 28367

*/

vars
	theRow,
	cols,
	idx,
	col : Integer;
begin

	theRow := table.row;

	cols := table.columns;
	col := table.column+1;
	
	if col &gt; cols then
		//end of row
		foreach idx in theRow+1 to table.rows do
			if table.accessRow(idx).enabled then
				return;
			endif;
		endforeach;				
		//self.doDetailAdd();
		return;
	endif;		
	
	while col &lt;= cols do
		if table.accessCell(theRow, col).enabled then
			break;
		endif;
		if col+1 &gt; cols then
			foreach idx in theRow+1 to table.rows do
				if table.accessRow(idx).enabled then
					return;
				endif;
			endforeach;		
			//end of row
			//self.doDetailAdd();
			return;
		endif;
		col := col+1;			
	endwhile;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="878b7d4e-f9ae-465b-a00d-a4d64cf317da">
        <updating/>
        <source>doRefresh() updating, protected;
//13 August 2009	cnwdw1	
//
