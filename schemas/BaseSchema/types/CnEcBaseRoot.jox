	return historyMasterObj;
end;</source>
        <ReturnType type="CnEcReleaseHistoryMaster"/>
    </JadeMethod>
    <JadeMethod name="createReportCategory" id="ab35590d-3f84-4d26-aa85-5b0b113fdd26">
        <updating/>
        <source>createReportCategory(pCategoryName:String):CnEcReportCategory updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Create a Report Category.
//
// Parameters:	pCategoryName - The name of the Report Category.
//
// Returns:		The new Report Category object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	reportCategoryObj	: CnEcReportCategory;

begin
	create reportCategoryObj;
	reportCategoryObj.initializeMe(pCategoryName, self);
	return reportCategoryObj;
end;</source>
        <Parameter name="pCategoryName" type="String"/>
        <ReturnType type="CnEcReportCategory"/>
    </JadeMethod>
    <JadeMethod name="createReportDefinition" id="083e0ded-2586-4362-bd2a-bf1e1c37e9fd">
        <updating/>
        <source>createReportDefinition(	pReportName:String;
						pReportCategory:CnEcReportCategory;
						pReportDescription:String;
						pFormName:String;
						pPrinterName:String;
						pCopies:Integer;
						pIsLocalAllowed:Boolean;
						pPaperSize:Integer;
						pOrientation:Integer;
						pMarginTop:Integer;
						pMarginBottom:Integer;
						pMarginLeft:Integer;
						pMarginRight:Integer;
						pParameterArray:CnEcReportParameterArray):CnEcReportDefinition updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Create a Report Definition.
//
// Parameters:	pReportName - The name of the report.
//				pReportCategory - A reference to the report's category.
//				pReportDescription - A description of the report.
//				pFormName - The name of the report's Form (sub)class.
//				pPrinterName - The name of the report's default printer.
//				pCopies - The default number of copies to print.
//				pIsLocalAllowed - True if the report can be printed on a local printer.
//				pPaperSize - The default paper size.
//				pOrientation - The default orientation.
//				pMarginTop - The top margin.
//				pMarginBottom - The bottom margin.
//				pMarginLeft - The left margin.
//				pMarginRight - The right margin.
//				pParameterArray - A collection of report parameters.
//
// Returns:		The new Report Definition object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	reportDefinitionObj	: CnEcReportDefinition;

begin
	create reportDefinitionObj;

	reportDefinitionObj.initializeMe(	pReportName,
										pReportCategory,
										pReportDescription,
										pFormName,
										pPrinterName,
										pCopies,
										pIsLocalAllowed,
										pPaperSize,
										pOrientation,
										pMarginTop,
										pMarginBottom,
										pMarginLeft,
										pMarginRight,
										pParameterArray,
										self);

	return reportDefinitionObj;
end;</source>
        <Parameter name="pReportName" type="String"/>
        <Parameter name="pReportCategory" type="CnEcReportCategory"/>
        <Parameter name="pReportDescription" type="String"/>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pPrinterName" type="String"/>
        <Parameter name="pCopies" type="Integer"/>
        <Parameter name="pIsLocalAllowed" type="Boolean"/>
        <Parameter name="pPaperSize" type="Integer"/>
        <Parameter name="pOrientation" type="Integer"/>
        <Parameter name="pMarginTop" type="Integer"/>
        <Parameter name="pMarginBottom" type="Integer"/>
        <Parameter name="pMarginLeft" type="Integer"/>
        <Parameter name="pMarginRight" type="Integer"/>
        <Parameter name="pParameterArray" type="CnEcReportParameterArray"/>
        <ReturnType type="CnEcReportDefinition"/>
    </JadeMethod>
    <JadeMethod name="createReportQueueEntry" id="51aa2c7a-6c0e-4903-bd0a-7254f9b2fda7">
        <source>createReportQueueEntry(	pTimeStamp:TimeStamp;
						pPriority:Integer;
						pCopies:Integer;
						pDestination:String;
						pIsPrintToFile:Boolean;
						pPrintStatus:Integer;
						pPrinterName:String;
						pReportDefinition:CnEcReportDefinition):CnEcReportQueueEntry;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Create a Report Queue entry.
//
// Parameters:	pTimeStamp - The timestamp of the queue entry.
//				pPriority - The priority of the print job.
//				pCopies - The number of copies to print.
//				pDestination - The name of the destination file (only applicable ir
//					the pIsPrintToFile flag is set).
//				pIsPrintToFile - If true, the output will be written to a disk file
//					in CSV format.
//				pPrintStatus - The current status of the report.
//				pPrinterName - The name of the destination printer (not required if
//					the pIsPrintToFile flag is set).
//				pReportDefinition - A reference to the report definition object.
//
// Returns:		The new Report Queue entry object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	queueEntryObj	: CnEcReportQueueEntry;

begin
	create queueEntryObj;
	queueEntryObj.initializeMe(	pTimeStamp,
								pPriority,
								pCopies,
								pDestination,
								pIsPrintToFile,
								pPrintStatus,
								pPrinterName,
								self,
								pReportDefinition);
	return queueEntryObj;
end;</source>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <Parameter name="pPriority" type="Integer"/>
        <Parameter name="pCopies" type="Integer"/>
        <Parameter name="pDestination" type="String"/>
        <Parameter name="pIsPrintToFile" type="Boolean"/>
        <Parameter name="pPrintStatus" type="Integer"/>
        <Parameter name="pPrinterName" type="String"/>
        <Parameter name="pReportDefinition" type="CnEcReportDefinition"/>
        <ReturnType type="CnEcReportQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="createTActivity" id="8f39b800-9847-4f95-af20-007eaef6741d">
