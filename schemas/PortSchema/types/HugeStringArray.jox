<CollClass name="HugeStringArray">
    <JadeMethod name="addTruncated" id="4ba98d9e-0cd2-4110-b349-41fc14a65357">
        <lockReceiver/>
        <updating/>
        <source>addTruncated(_value : String) updating;

/*

Purpose:		Add the passed string into the array, truncating it if necessary


Return Value:	None


Date		Who		Reason
21 May 2008	cnwkpd1	PAR #16687 - Correct String too long errors in error messages

*/

vars
  	maxLength 		: Integer;

begin
   	maxLength := getMaxLength;
   	if _value.length &gt; maxLength then
   		self.add(_value[1:maxLength]);
   	else
   		self.add(_value);
   	endif;

	
epilog	

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="asCSV" id="b5b6a929-17c6-4f57-b3d9-6017c414913b">
        <source>asCSV(_withQuotes : Boolean) : String;

vars

	str, output	: String;
	
begin

	foreach str in self do
		str := str.trimBlanks;
		if _withQuotes then
			str := '"' &amp; str &amp; '"';
		endif;
		output := output &amp; ',' &amp; str;
	endforeach;	
	if output.length &gt; 1 then
		return output[2:end];
	endif;
	return '';
end;</source>
        <Parameter name="_withQuotes" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="concatenate" id="276d0c5b-342d-4fc0-b73e-a5a56d38fff4">
        <source>concatenate(_delimiter : String) : String;
/*

Date		Who		Reason
04 September 2015	cnwer1	Initial creation PAR 36867

*/

vars
	element,
	result			: String;
begin
	foreach element in self do
		if result = null then
			result := element;
		else
			result := result &amp; _delimiter &amp; element;
		endif;
	endforeach;
	
	return result;
	

epilog

end;</source>
        <Parameter name="_delimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstElementsDelimited" id="f1ba6117-ca6d-4146-a77c-c1574b204d5e">
        <source>getFirstElementsDelimited(_numElements: Integer; _delimiter: String): String;
// --------------------------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
// --------------------------------------------------------------------------------
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 21/06/2005	cnwdad1		Copied this method from the StringArray class.
// --------------------------------------------------------------------------------
vars
	str,
	retStr			: String;
	elementCount,
	numToReturn		: Integer;
	tmpDelim		: String;
begin
	elementCount := 0;
	if _numElements &lt; 1 then
		numToReturn := self.size;
	else
		numToReturn := _numElements;
	endif;
	tmpDelim := _delimiter;
	
	foreach str in self do
		elementCount := elementCount + 1;
		if elementCount &gt; numToReturn then
			break;
		endif;
		
		retStr := retStr &amp; tmpDelim &amp; str;
		
	endforeach;

	if retStr.length &gt; tmpDelim.length then
		return retStr[tmpDelim.length + 1:end];
	endif;
end;</source>
        <Parameter name="_numElements" type="Integer"/>
        <Parameter name="_delimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMaxLength" id="08102a89-85e2-463d-9b1b-43179b09d196">
        <source>getMaxLength() : Integer;

/*

Purpose:			Get the maximum String length of the members in the receiver


Return Value:		Max length of elements


Date		Who		Reason
21 May 2008	cnwkpd1	PAR #16687 - Correct String too long errors in error messages
27 Apr 2021 navmd1	TFS 51086 - Workaround JADE 2020 variable string arrays by defaulting member size back to pre-2020 values

*/

vars
	size	: Integer;
begin
	size := self.class.CollClass.memberTypeSize;
	if size &lt; 0 then
		size := 2048;
	endif;
	
	return size - 1;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleXMLException" id="e2f0d3b2-42c2-450d-979c-6099dfc46435">
        <source>handleXMLException(_exc : JadeXMLException; _parserError : Boolean io) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgndl1	Initial creation

*/

vars

begin
	app.writeLog(method.qualifiedName &amp; 
							 " " &amp; _exc.class.name &amp; 
							 " " &amp; _exc.errorCode.String &amp; 
							 " " &amp; _exc.text &amp; 
							 " " &amp; _exc.extendedErrorText, LogERROR);	//26 Nov 2019	NDL	TFS 47053
	
	if _exc.resumable then
		_parserError := true;
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="JadeXMLException"/>
        <Parameter name="_parserError" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateFromXMLDocOrStr" id="46ba2f1b-1dd0-430d-b44f-26cbe29468f1">
        <lockReceiver/>
        <updating/>
        <source>populateFromXMLDocOrStr( _xml : JadeXMLDocument; _xmlStr : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	headerElement : JadeXMLElement;
	localString : String;

begin
	self.clear();
	
	if _xml = null and _xmlStr.trimBlanks = null then
		return;
	endif;
	
	if _xml &lt;&gt; null then
		headerElement := _xml.rootElement;
		if headerElement &lt;&gt; null then
			headerElement.addToHugeStringArray( self );
		endif;
		return;
		
	elseif _xmlStr.trimBlanks &lt;&gt; null then
		localString := _xmlStr.replaceString( CrLf, Cr );
		localString := localString.replaceString( Lf, Cr );
		localString := localString.replaceString( Tab, " " );
		localString.getTokensHugeTruncate(Cr, self);
	
	endif;
	
	
epilog
	
end;</source>
        <Parameter name="_xml" type="JadeXMLDocument"/>
        <Parameter name="_xmlStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setExtraActivityHistory" id="72d8cb6d-5f19-4dc8-821e-db892a19c547">
        <source>setExtraActivityHistory(_activityHistory: CM_ActivityHistory input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2015	cnwndl1	Initial creation

*/

vars

begin

	if _activityHistory.isKindOf(CM_ActivityHistoryGeneralSys) then
		_activityHistory.CM_ActivityHistoryGeneralSys.setExtraDetailFromStack( self );
	else
		inheritMethod(_activityHistory);
	endif;

epilog

end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistory" usage="input"/>
    </JadeMethod>
</CollClass>
