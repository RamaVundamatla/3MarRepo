    <JadeMethod name="handleGlobalExceptions" id="10aa98be-9948-4a5a-88c5-73803375583f">
        <updating/>
        <source>handleGlobalExceptions(x : Exception) : Integer updating;

vars
	time : Time;
begin

	app.causeEvent(Statusline_Message, true,  time.String &amp; ' Handling ' &amp; x.text &amp; ' (' &amp; x.errorCode.String &amp; ')');
	globalExceptionCount.bump;
	lastGlobalException := x.errorCode;
	return Ex_Abort_Action;

epilog

	abortTransaction;
	abortTransientTransaction;
end;</source>
        <Parameter name="x" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleTCPException" id="1219fb26-627a-4abb-ac3c-9df2013a4abd">
        <updating/>
        <source>handleTCPException(x : ConnectionException) : Integer updating;

vars
	connection : Connection;
	time       : Time;
begin

	tcpExceptionCount.bump;
	lastTcpException := x.errorCode;
	if x.errorCode = 31017 then
		connection := x.connection;
		beginTransientTransaction;
		app.myListener.v_tcpHandler.v_tcpArray.remove(connection.TcpIpConnection);
		connection.close;
		delete connection;
		commitTransientTransaction;
	endif;
	if myListener &lt;&gt; null then
		app.causeEvent(Statusline_Message, true, time.String &amp; ' Handling ' &amp; x.text &amp; ' (' &amp; x.errorCode.String &amp; ')');
	endif;
	return Ex_Abort_Action;
epilog

	abortTransaction;
	abortTransientTransaction;
end;</source>
        <Parameter name="x" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="3023e57c-86d6-4ea1-bd36-772f030f4331">
        <updating/>
        <source>initialize() updating;

vars

begin
//	on Exception do handleGlobalExceptions(exception) global;
	on ConnectionException do handleTCPException (exception) global;

end;</source>
    </JadeMethod>
</Class>
