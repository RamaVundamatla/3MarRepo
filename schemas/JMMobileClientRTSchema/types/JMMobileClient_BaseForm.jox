    <JadeMethod name="setupForm" id="8e0866d6-27f3-4dde-83f3-4cd346c2f31d">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	registerKeys		: IntegerArray;
begin

	create registerKeys transient;
	self.getRegisterFormKeys(registerKeys);
	self.registerFormKeys(registerKeys);
	
	inheritMethod();

	self.doApplyScreenColors();
	self.aIsSaveRequired	:=	false;
	
epilog
	delete registerKeys;
end;</source>
    </JadeMethod>
