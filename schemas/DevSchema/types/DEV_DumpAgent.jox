    <JadeMethod name="createNewFolder" id="48322d87-2479-4639-96ac-8f89ee667e67">
        <updating/>
        <source>createNewFolder(_newPath : String)updating ;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 18 January 2007
//
//----------------------------------------------------------------------
// 17/03/2015	cnwmh5	Transient Leak
vars
	fileFolder : FileFolder;
	
begin
	create fileFolder transient;
	fileFolder.fileName := _newPath;
	fileFolder.make;
epilog
	delete fileFolder;
end;</source>
        <Parameter name="_newPath" type="String"/>
    </JadeMethod>
    <JadeMethod name="createParentFolder" id="4fba7fe1-5701-4ac2-b765-330724b0ebba">
        <updating/>
        <source>createParentFolder() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 04 April 2007
//
// Create a new folder at the same level as the dump files where the sub folders will be placed.
//----------------------------------------------------------------------

vars
	folder : FileFolder;
	dt : TimeStamp;
	parentFolderPath : String;
begin
	
	parentFolderPath := self.myFileFolder.fileName &amp; '\' &amp; dt.date.String;
	if not self.checkFolderExists(parentFolderPath) then
		create self.myParentFileFolder transient;
		self.myParentFileFolder.fileName := parentFolderPath;
		self.myParentFileFolder.make();
	else
		//Already exists;
		self.myParentFileFolder.fileName := parentFolderPath;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDumpFolder" id="e3f1a906-6db1-4a5b-b738-3bb5d7e0fc48">
        <source>getDumpFolder(): FileFolder;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 18 January 2007
//
//----------------------------------------------------------------------

vars
	fileFolder : FileFolder;
begin
	create fileFolder transient;
	
	fileFolder.fileName := fileFolder.browseForFolder('Select Dump File Folder', null);
	return fileFolder;
epilog

end;</source>
        <ReturnType type="FileFolder"/>
    </JadeMethod>
    <JadeMethod name="getErrorNumberFromFile" id="1a1c998b-978a-4e2a-80f7-ac597f3cd1af">
        <updating/>
        <source>getErrorNumberFromFile(_file : File) : String updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 18 January 2007
//
//----------------------------------------------------------------------

vars
	int,
	int2 : Integer;
	fileLine,
	errorNumber : String;
begin
	int := 1;
	while not _file.endOfFile do
		fileLine := _file.readLine();
		int := 1;
		if fileLine.pos('Exception',int) &gt; 0 then
			//Now look for the number before the "(" in the str.
			int2 := 1;
			errorNumber := fileLine.scanUntil('(', int2);
			errorNumber := errorNumber.reverse.trimLeft;
			
			//ok now just get the number.  This could be 2 to 5 chars in length
			int2 := 1;
			errorNumber := errorNumber.scanWhile('0123456789', int2);
			errorNumber := errorNumber.reverse;

			break;
		endif;
	endwhile;
	
	if errorNumber &lt;&gt; null then
		return errorNumber;
	else
		return 'Unsuccessful';
	endif;
epilog

end;</source>
        <Parameter name="_file" type="File"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFilesAndProcess" id="594cc79a-0984-405f-b0d0-221b0c2ee1f9">
        <updating/>
        <source>getFilesAndProcess() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 04 April 2007
//
// 	Get any dump files from a selected destination and sort them.
//----------------------------------------------------------------------

vars

begin
	create self.myFileFolder transient;
	
	self.myFileFolder.fileName := self.myFileFolder.browseForFolder('Select Dump File Folder', 'C:\aJunk\Test');
	
	self.createParentFolder();
	
	self.allFilesToProcess := self.getFilesFromFolder(self.myFileFolder);
	
	self.processFiles(self.allFilesToProcess, true);
	
	//self.cleanupFiles();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getFilesFromFolder" id="d5064dc3-736b-4404-b57b-9b245bc0cc53">
        <updating/>
        <source>getFilesFromFolder(_fileFolder : FileFolder io) : FileNodeArray updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 18 January 2007
//
//----------------------------------------------------------------------

vars
	fileList : FileNodeArray;
	fileNode : FileNode;
begin
	create fileList transient;
	
	//Also set this so we know which folder we are using as the root folder.
	self.setFilePath(_fileFolder.fileName);
	
	foreach fileNode in _fileFolder.files do
		fileList.add(fileNode);
	endforeach;
	
	return fileList;
	//	return _fileFolder.files;
	
epilog

end;</source>
        <Parameter name="_fileFolder" type="FileFolder" usage="io"/>
        <ReturnType type="FileNodeArray"/>
    </JadeMethod>
