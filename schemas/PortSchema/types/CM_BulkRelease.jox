    <JadeMethod name="getCoparnRules" id="6ec8231e-4edd-4a5e-8ec1-bc22363aa264">
        <source>getCoparnRules(): CM_EDIPartyCoparnRules ;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15 January 2025	navcs2	MTN-19832 SNO - Cannot delete single items with COPARN in a Relese Request Actioned
*/

vars
	ediFile 		: CM_EDIFile;
	ediTi			: CM_EDITrackedItem;
	invalidObject	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ediFile, invalidObject);
	
	foreach ediFile in self.allEDIFiles do
		ediFile.edition;
		if invalidObject then
			invalidObject := false;
			continue;
		endif;
		
		if (ediFile.ediData &lt;&gt; null and ediFile.ediData.isCoparnFile) then
			if ediFile.ediData &lt;&gt; null and not ediFile.ediData.allEDITrackedItems.isEmpty then
				foreach ediTi in ediFile.ediData.allEDITrackedItems do
					if ediTi.isReleaseRequest then 
						return ediTi.CM_EDIReleaseRequestTI.getCoparnRules;
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
	
	return null;
	
epilog
	on Exception do null;
	
end;</source>
        <ReturnType type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="getCreatedByUser" id="c2cb80ac-1200-4f1e-83b1-31cff455bf1d">
        <source>getCreatedByUser():CM_User;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Mar 2024	navma1  Bug 62810: MTN - Notifications causing updates to combo box in cargo work order

*/

vars
	audit : CM_AuditObject;
begin
	audit := self.allAuditObjects.first;
	
	if audit &lt;&gt; null then
		return audit.myUser;
	endif;
epilog

end;</source>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="getCustomAgent" id="5b2a38ef-a3f5-4ff5-8b0e-36a528b42a42">
        <source>getCustomAgent() : CM_CustomsAgent;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgrh7	Initial creation TFS39309

*/

vars

begin
	return app.myRoot.allCustomsAgents[self.customsAgent];
epilog
	
end;</source>
