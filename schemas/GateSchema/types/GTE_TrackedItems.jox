    <JadeMethod name="populateBOL" id="8782f204-f893-4779-b66a-d4475cfa57ef">
        <source>populateBOL();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 January 2019
TFS#		: 41708
Function	: Populate Bill of Lading Combobox when 
			  Release Type are Rail, Road, Ship or Unknown
			  When Release By Type is False.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	voyageCode	: String;
	bolInNumber	: String;
	voyage		: CM_Voyage;
	bolIn		: CM_BOLIn;
begin	
//	if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
	if self.useTotReqAllowedFld then	//28 Aug 2019	NDL	TFS 46118
		voyage 	:= self.myVoyage;
		bolIn	:= self.myBOLIn;
		
		self.myAssistant.comboBoxBOLInsForVoyage(self.cmbBOLAnyId, voyage, bolIn);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeTI" id="248c6b43-7434-44be-8a18-3addc6a82e72">
        <updating/>
        <source>removeTI() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		: Object;

begin

	if tblList.row &gt; 1 and tblList.row &lt;= tblList.rows then
		obj := tblList.accessRow(tblList.row).itemObject;
		if obj &lt;&gt; null then
			self.allTrackedItems.remove(obj.CM_TrackedItem);
		endif;
		tblList.removeItem(tblList.row);
		
		self.tblList_ShowTI(obj.CM_TrackedItem, 0,self.tblListAll );
		self.tblListAll.resort();
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="51308828-ed45-4ecc-84df-f4c639734569">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//--------------------------------------------------
// Created:	21 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	self.grpDetail.backColor := self.backColor;
	self.setColorsForEntryTable(self.tblInput);
	self.setColorsForTable(self.tblList);
	self.setColorsForTable(self.tblListAll);	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setTIs" id="fca56fb8-2fa2-4dfd-bd14-9df4177a4fa9">
        <updating/>
        <source>setTIs(pTIArray : CM_TIArray; pSelectedTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;

begin

	foreach ti in pTIArray do
		//self.allOriginalTrackedItems.add(ti);
		self.allTrackedItems.add(ti);
		
		if ti = pSelectedTI then
			self.mySelectedTI := ti;
		endif;
	endforeach;
end;</source>
        <Parameter name="pTIArray" type="CM_TIArray"/>
        <Parameter name="pSelectedTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="d7059467-bad8-4d36-a0ae-10dbff7bb82f">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2021	navndl1	Initial creation	TFS 51338

*/

vars
	
	startIndex : Integer;
	endIndex : Integer;
	rowIndex : Integer;
	rowObject : CM_TrackedItem;
	rowStr : String;

begin

	startIndex := _theTable.fixedRows + 1;
	endIndex := _theTable.rows;
	
	if endIndex &lt; startIndex then
		return;
	endif;
	
	foreach rowIndex in startIndex to endIndex do
		rowObject := _theTable.accessRow( rowIndex ).itemObject.CM_TrackedItem;
		if rowObject &lt;&gt; null then
			rowStr :=  rowObject.getAttributeStringForDefArray(_theTable.allTblDataEntRows);
			_theTable.setCellText( rowIndex, 1, rowStr );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setUseColumnOrganiser" id="f00b7073-c8ec-46a2-a4a5-1dbee308cb68">
        <updating/>
        <source>setUseColumnOrganiser( _firstTime : Boolean ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2021	navndl1	Initial creation	TFS 51338

*/

vars

	entTableDef 	: EntTableDef;
	rowStr 			: String;

begin

	if self.useColumnOrganiser = self.chkUseColOrg.value and not _firstTime then
		return;
	elseif self.useColumnOrganiser &lt;&gt; self.chkUseColOrg.value then
		self.useColumnOrganiser := self.chkUseColOrg.value;
	endif;
	
	if _firstTime or not self.useColumnOrganiser then
	
		self.tblInput.hideRowByName(ETRow_BillOfLadingCmbAnyId,true);
		self.cmbBOLAnyId.visible := false;	
		tblInput.setValueByName(ETRow_CargoType, cmbTiType.text);
		rowStr := 'Number' &amp; Tab &amp; 'Cargo Type' &amp; Tab &amp; 'ISO Type' &amp; Tab &amp; 'Voyage' &amp; Tab &amp; 'Operator'&amp; Tab &amp; 'Quantity'&amp; Tab &amp; 'Location';
		tblList.columns := 7;
		tblListAll.columns := 7;
				
		if self.myTerminal &lt;&gt; null then
			if  self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean and not self.isReleaseByType then
				self.tblInput.showRowByName(ETRow_BillOfLadingCmbAnyId,true);	
				tblInput.setValueByName(ETRow_CargoType, null);
				
				rowStr := 'Number' &amp; Tab &amp; 'Cargo Type' &amp; Tab &amp; 'ISO Type' &amp; Tab &amp; 'Voyage' &amp; Tab &amp; 'Operator'&amp; Tab &amp; 'Quantity'&amp; Tab &amp; 'Location'&amp; Tab &amp; 'Bill Of Lading';
				tblList.columns := 8;
				tblListAll.columns := 8;
			endif;
		endif;
		
		tblList.addItemAt(rowStr, 1);
		tblList.rows := 1;
		
	endif;
	
	if self.useColumnOrganiser then	
		entTableDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);	
		self.tblListAll.setTblDataEntRowsFromDef(entTableDef);
		self.tblListAll.setMyDataClass(CM_TrackedItem);
		self.tblListAll.fixedColumns := 0;
		self.tblListAll.fixedRows := 1;
		self.tblListAll.selectMode := CM_DataTable.SelectMode_FixedRow;
		self.tblListAll.selectionType := CM_DataTable.SelectionType_Row;
		self.tblListAll.multiSelect := CM_BaseTable.MultiSelect_Simple;	
	
	else	
		self.tblListAll.selectMode := Table.SelectMode_FixedRow;
		self.tblListAll.selectionType := CM_DataTable.SelectMode_FixedRow;
		self.tblListAll.multiSelect := CM_DataTable.MultiSelect_Simple;
		
		tblListAll.addItemAt(rowStr, 1);
		tblListAll.rows := 1;
	
	endif;
	
	self.setColorsForTable(self.tblList);
	self.setColorsForTable(self.tblListAll);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_firstTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5e434477-7d05-4d90-b700-6cca2fb19f89">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     07 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/* Changes

Date		Name	TFS#			Description
============================================================================
16/12/2009	cnwmh5	PAR #21921 		Change to use ISO Type Group rather than check iso group
24/01/2019	jlgka1	41708			Call populateBOL and deault BOL value from previous
									screen value.
15/03/2019	jlgka1	43807			Fixed bug of floating combo box. 
									Add "not isReleaseByType" to the condition.									
============================================================================*/
vars
	entTableDef 	: EntTableDef;
	ti				: CM_TrackedItem;
	tmpRow			: Integer;
//	rowStr 			: String;
	
begin

	self.useTotReqAllowedFld := self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean;	//28 Aug 2019

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.mnuCargoEnq.visible := false;
	self.btnAdd.visible 	:= true;//th2 PAR 14758
	self.btnRemove.visible 	:= false;
	self.tblList.visible 	:= false;
	self.btnSaveBase.visible := false;
	self.sptTIs.hideRightControl(true);
	
	self.isSelectorCapable := true;	//28 Aug 2019	NDL	TFS 46118
	
	inheritMethod();
	
	tblInput.warningMethod := 'entTableWarning';
	
	entTableDef := app.myController.getEntTableDef(ETDef_TrackedItem);
	tblInput.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	self.getXMLSettingsForSetup();	//14 Jun 2021	NDL	TSF 51338 - moved up.
	self.setUseColumnOrganiser( true );	//14 Jun 2021	NDL	TFS 51338
	
/*	migrated into "setUseColumnOrganiser"
	
	// jlgka1 TFS 41708 --&gt;
	if self.myTerminal &lt;&gt; null then
		if  self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean and not self.isReleaseByType then
			self.tblInput.showRowByName(ETRow_BillOfLadingCmbAnyId,true);
		
			//tblInput.setValueByName(ETRow_CargoType, cmbTiType.text);
		
			tblInput.setValueByName(ETRow_CargoType, null);
			
			rowStr := 'Number' &amp; Tab &amp; 'Cargo Type' &amp; Tab &amp; 'ISO Type' &amp; Tab &amp; 'Voyage' &amp; Tab &amp; 'Operator'&amp; Tab &amp; 'Quantity'&amp; Tab &amp; 'Location'&amp; Tab &amp; 'Bill Of Lading';
			tblList.columns := 8;
			tblListAll.columns := 8;
		else	
			self.tblInput.hideRowByName(ETRow_BillOfLadingCmbAnyId,true);
			self.cmbBOLAnyId.visible := false;
			
			tblInput.setValueByName(ETRow_CargoType, cmbTiType.text);
		
			rowStr := 'Number' &amp; Tab &amp; 'Cargo Type' &amp; Tab &amp; 'ISO Type' &amp; Tab &amp; 'Voyage' &amp; Tab &amp; 'Operator'&amp; Tab &amp; 'Quantity'&amp; Tab &amp; 'Location';
			tblList.columns := 7;
			tblListAll.columns := 7;
		endif;
	endif;
	// jlgka1 TFS 41708 &lt;--
	tblList.addItemAt(rowStr, 1);
	tblList.rows := 1;
	self.tblListAll.selectMode := Table.SelectMode_FixedRow;
	//self.tblListAll.accessMode := Table.AccessMode_Row;
	self.tblListAll.selectionType := CM_DataTable.SelectMode_FixedRow;
	self.tblListAll.multiSelect := CM_DataTable.MultiSelect_Simple;
	
	tblListAll.addItemAt(rowStr, 1);
	tblListAll.rows := 1;

	self.setColorsForTable(self.tblList);
	self.setColorsForTable(self.tblListAll);
*/	
	foreach ti in self.allTrackedItems do
		tmpRow := self.tblList_ShowTI(ti, 0,self.tblList);
		if ti = self.mySelectedTI then
			self.tblList.accessRow(tmpRow).selected := true;
			self.selectedRow := tmpRow;
		endif;
	endforeach;
	
	btnAdd.default 		:= true;
	btnRemove.enabled 	:= true;
	
	if self.mySelectedTI &lt;&gt; null then
		self.myAssistant.GTE_Assistant.comboBoxCargoBolType(cmbTiType, self.mySelectedTI.cargoType,true, false, true, true);
		
		// This is the new one for after 7.4.1 release	
		//self.myAssistant.GTE_Assistant.comboBoxCargoBOLTypeGate(cmbTiType, self.mySelectedTI.cargoType,true, true, true);
		//self.resetComboTI(self.mySelectedTI.tiType, self.mySelectedTI);
		self.showSelectedTI();
	else
		if self.myCargoType &lt;&gt; null then
			self.myAssistant.GTE_Assistant.comboBoxCargoBolType(cmbTiType, self.myCargoType.id,true, false, true, true);
			
			// This is the new one for after 7.4.1 release	
//			self.myAssistant.GTE_Assistant.comboBoxCargoBOLTypeGate(cmbTiType, self.myCargoType.id,true, true, true);
		else
			if not self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then //jlgka1 TFS 41708
				self.myAssistant.GTE_Assistant.comboBoxCargoBolType(cmbTiType, app.myPassport.getDefaultCargoBOLTypeId, true, false, true, true);
			endif;															   //jlgka1 TFS 41708
			// This is the new one for after 7.4.1 release	
			//self.myAssistant.GTE_Assistant.comboBoxCargoBOLTypeGate(cmbTiType, app.myPassport.getDefaultCargoBOLTypeId,true, true, true);
		endif;
		self.cmbTiType.lostFocus(cmbTiType);
		self.cmbTiType.click(cmbTiType);
		//self.resetComboTI(TI_CargoType_Container, null);
	endif;
	self.myAssistant.comboBoxOperator(cmbOperator, self.myOperator, null);
	
//	self.myAssistant.comboBoxISOType(cmbISOType, self.myISOType);
	self.cmbISOType.setObject(self.myISOType);
	self.myAssistant.comboBoxISOTypeGroup(cmbISOGroup, self.myISOGroup);						// 16/12/2009 cnwmh5 #21921
	if self.myISOType &lt;&gt; null then
		self.myAssistant.comboBoxISOTypeGroupFilter(self.cmbISOGroup, self.myISOType.myISOTypeGroup);
	endif;
//	self.myAssistant.comboBoxVoyageCode(self.cmbVoyage, self.myVoyage,false);
	self.doComboVoyageBuild();
	self.populateBOL();
	self.myAssistant.comboBoxConsignor(self.cmbFreightFwdr, self.myFiltFreightFwdr, FREIGHT_FORWARDER);
	//self.myAssistant.comboBoxConsignor(self.cmbConsignee, self.myFiltConsignee, CONSIGNEE);
	self.cmbConsignee.setType(CONSIGNEE);
	self.cmbConsignee.setObject(self.myFiltConsignee);
	self.myAssistant.comboBoxDestination(self.cmbDestination, self.myFiltDestination);

	// Get IMEX STATUS Default
//	self.getXMLSettingsForSetup();		- moved up
	if self.myIMEXStatus = null then
		self.myIMEXStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
	endif;
	self.myAssistant.comboBoxIMEXStatus(self.cmbImEx, self.myIMEXStatus.code);
	
	
	self.cmbOperator.addItemAt("All",1);
	self.tblInput.setValueByControlName(self.cmbImEx.name,self.cmbImEx.text);
	self.tblInput.setValueByControlName(self.cmbOperator.name,self.cmbOperator.text);
	self.tblInput.setValueByControlName(self.cmbVoyage.name,self.cmbVoyage.text);
	self.tblInput.setValueByControlName(self.cmbISOType.name,self.cmbISOType.text);
	self.tblInput.setValueByControlName(self.cmbDestination.name,self.cmbDestination.text);
	self.tblInput.setValueByControlName(self.cmbFreightFwdr.name,self.cmbFreightFwdr.text);
	self.tblInput.setValueByControlName(self.cmbConsignee.name,self.cmbConsignee.text);
	
	self.tblInput.setValueByName( ETRow_Mark, self.filterMark );	//28 Aug 2019	NDl	TFS 46118
	
	//jlgka1 TFS 41708 --&gt;
	if self.myTerminal &lt;&gt; null then
		if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean and not self.isReleaseByType then
			self.tblInput.setValueByControlName(self.cmbBOLAnyId.name,self.cmbBOLAnyId.text);	
		else
			self.cmbBOLAnyId.visible := false;
		endif;		
	endif;
	//jlgka1 TFS 41708 &lt;--
	
	self.tblInput.setValueByName(ETRow_MtRelease, self.isEmptyOnly);	
	self.tblInput.setValueByControlName(self.cmbBOLAnyId.name,self.cmbBOLAnyId.text); // jlgka1 TFS 41708
	///self.tblInput.setValueByName(ETRow_DoISOGroupCheck, self.checkISOGroup);			// 16/12/2009 cnwmh5 #21921
	self.tblInput.setValueByControlName(self.cmbISOGroup.name, self.cmbISOGroup.text);		// 16/12/2009 cnwmh5 #21921	

	self.chkUseFilter.value := self.filterForCargo;
	self.doChkFilterClick();
	
	//th2 PAR 14758 - show screen to return to
	self.updateNumSelectedLabel();	
	
	self.setCaption('Search for cargo items...');
end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectedTI" id="d5ee963c-6caa-43da-bdca-2cee0ec9f818">
        <updating/>
        <source>showSelectedTI() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	selectedCargoType,
	theCargoType	: CM_CargoType;
	
begin
	selectedCargoType := self.cmbTiType.listObject.CM_CargoType;
	self.tblInput.clearValues();
	
	theCargoType := self.myCargoType; //app.myRoot.allCargoTypesById[self.mySelectedTI.cargoType];
	if theCargoType = null then
		theCargoType := app.myRoot.allCargoTypesById[self.mySelectedTI.cargoType];
	endif;

	cmbTiType.text := self.myAssistant.GTE_Assistant.displayEntryCargoBolType(theCargoType);
	//th2 - comboTI no longer ever present - was used from the empty release request form - now no longer used
	/*
	if theCargoType &lt;&gt; selectedCargoType then
		cmbTiType.listObject := theCargoType;
		self.resetComboTI(theCargoType.id, self.mySelectedTI);
	endif;
	*/
	self.tblInput.setValueByName(ETRow_CargoType, cmbTiType.text);
	
	
	btnRemove.enabled := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showSelector" id="05a58b60-ef92-4c55-a474-326dc56b1ce3">
        <source>showSelector();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2019	jlgndl1	Initial creation	TFS 46118

*/

vars

	frm	 : CMUI_Selector;
	cargoType : CM_CargoType;

begin

	frm := app.getSelectorForm(self, self.myMasterMenuAction);

	if frm = null then
		return;
	endif; 
	
	frm.myEnquiryCollectionClass := CM_ObjectSet;
	frm.myTerminal := self.myTerminal;
	
	if self.currentCargoType &gt; 0 then
		cargoType := app.myRoot.allCargoTypesById[self.currentCargoType];
	endif;
	if cargoType = null then
		cargoType := app.myRoot.allCargoTypesById[self.myTerminal.defaultCargoType];
	endif;
	if cargoType.id = TI_CargoType_Container then
		frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, cargoType.id];
	elseif cargoType.id = TI_CargoType_Log then
		frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 9];
	elseif cargoType.id = TI_CargoType_Generator then
		frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 4];
	elseif cargoType.id = TI_CargoType_COU then
		frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 2];
	elseif cargoType.id = TI_CargoType_Timber then
		frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 6];
	elseif cargoType.id = TI_CargoType_LCL then
		frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 8];
	elseif cargoType.isBreakBulk() then
		frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 3];		// TI_CargoType_BreakBulk
	elseif cargoType.productType = ProductType_Trailer then
		frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 10];		// TI_CargoType_Chassis
	elseif cargoType.productType = ProductType_Vehicle then
		frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 7];		// TI_CargoType_Car
	else
		frm.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 0];
	endif;

	frm.defaultSiteStr := TI_SITE_ONSITE_str;
	frm.show;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblGotFocus_idCombo" id="4cdb5b92-ccfc-4928-b598-68a9ae8e555b">
