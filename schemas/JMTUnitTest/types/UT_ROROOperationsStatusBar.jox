    <JadeMethod name="xPAR31367StatusBarStepB5" id="1db68ac9-2b59-42a5-b028-0bbbf17d6436">
        <source>xPAR31367StatusBarStepB5();

/*

Purpose:		Put into a job and check that the Status Bar details are correct

Date			Who		Reason
17/05/2013		cnwmh5	Initial creation

*/

vars

	job									: CM_Job;
	wle 								: CM_WorkListEntry;
	roroRequest							: CM_RORORequest;
	locnDefnVoyage 						: CM_ROROLocnDefnVoyage;
	locnGCDefnVoyage					: CM_ROROGCDefnVoyage;
	slotDefn 							: CM_ROROSlotDefn;
	slotLC 								: CM_ROROSlotController;
	ti									: CM_TrackedItem;
	
	wlesToMove							: CM_WLEArray;
	wlesWithWarnings 					: CM_WLEArray;
	
	tisToDischarge						: StringArray;
	dischargeLocn						: StringArray;

	completedDate 						: TimeStamp;
	locn								: String;
	
begin

	app.writeLog("STEP B5", LogINFO);
	app.writeLog("Discharging containers.  Please wait...", LogINFO);
	
	self.loadAllJobsToOps(self.myVoyage, true);
	
	create wlesToMove transient;
	create wlesWithWarnings transient;
	
	create tisToDischarge transient;
	
	create dischargeLocn transient;
	dischargeLocn.add("D4083");
	dischargeLocn.add("D4082");
	dischargeLocn.add("D4087");
	dischargeLocn.add("D4074");
	dischargeLocn.add("D4070");
	dischargeLocn.add("D4075");
	dischargeLocn.add("D4199");
	
	dischargeLocn.add("D4086");
	dischargeLocn.add("D4085");
	dischargeLocn.add("D4076");
	dischargeLocn.add("D4077");
	dischargeLocn.add("D4064");
	dischargeLocn.add("D4040");
	dischargeLocn.add("D4065");
	
	dischargeLocn.add("D4421OR");
	dischargeLocn.add("D4423OR");
	dischargeLocn.add("D4424OR");
	dischargeLocn.add("D4414O");
	dischargeLocn.add("D4412O");
	dischargeLocn.add("D4411O");
	
	dischargeLocn.add("D4426OR");
	dischargeLocn.add("D4428OR");
	dischargeLocn.add("D4420O");
	dischargeLocn.add("D4418O");
	
	foreach locn in dischargeLocn do
	
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			roroRequest := slotLC.myRORORequestDischarge;
			if roroRequest &lt;&gt; null then
				ti := roroRequest.getTrackedItem();
				if ti &lt;&gt; null then
					tisToDischarge.add(ti.id);
				endif;
			endif;
		endforeach;
	
	endforeach;
	
	
	/*
	tisToDischarge.add("UT313670059");
	tisToDischarge.add("UT313670060");
	tisToDischarge.add("UT313670058");
	tisToDischarge.add("UT313670048");
	tisToDischarge.add("UT313670049");
	tisToDischarge.add("UT313670050");
	tisToDischarge.add("UT313670051");
	tisToDischarge.add("UT313670061");
	tisToDischarge.add("UT313670062");
	tisToDischarge.add("UT313670063");
	tisToDischarge.add("UT313670064");
	tisToDischarge.add("UT313670066");
	tisToDischarge.add("UT313670067");
	tisToDischarge.add("UT313670068");
	tisToDischarge.add("UT313670069");
	tisToDischarge.add("UT313670070");
	tisToDischarge.add("UT313670079");
	tisToDischarge.add("UT313670079");
	tisToDischarge.add("UT313670080");
	tisToDischarge.add("UT313670081");
	tisToDischarge.add("UT313670052");
	tisToDischarge.add("UT313670053");
	tisToDischarge.add("UT313670076");
	tisToDischarge.add("UT313670077");
	tisToDischarge.add("UT313670078");
	tisToDischarge.add("UT313670084");
	tisToDischarge.add("UT313670085");
	tisToDischarge.add("UT313670054");
	tisToDischarge.add("UT313670055");
	tisToDischarge.add("UT313670056");
	tisToDischarge.add("UT313670082");
	tisToDischarge.add("UT313670083");
	tisToDischarge.add("UT313670040");
	tisToDischarge.add("UT313670041");
	tisToDischarge.add("UT313670042");
	tisToDischarge.add("UT313670043");
	tisToDischarge.add("UT313670044");
	tisToDischarge.add("UT313670071");
	tisToDischarge.add("UT313670042");
	tisToDischarge.add("UT313670073");
	tisToDischarge.add("UT313670074");
	tisToDischarge.add("UT313670075");
	tisToDischarge.add("UT313670072");
	tisToDischarge.add("UT313670065");
	*/
	
	foreach job in self.myVoyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isHatchLidJob() then
			continue;
		endif;
		
		if job.CM_VoyageJob.status = JOB_COMPLETE then					// 14/05/2013 cnwmh5
			continue;
		endif;
		
		foreach wle in job.workListEntries discreteLock do
			wlesToMove.clear();
			wlesWithWarnings.clear();
			if not tisToDischarge.includes(wle.myTrackedItem.id) then
				continue;
			endif;
			wlesToMove.add(wle);
			app.myPassport.warningsAcknowledged	:= true;	// stop 'No planned location, want to autoplan' warning and do the autoplan instead
			app.myTrxUA.trxUpdateWLEsDoMove(wlesToMove, wlesWithWarnings, REAL_MODE, true, null,app.myPassport);
			self.assertNoTrxErrorsOrWarnings();	// some invoicing wles may not complete, don't really care
			self.assertTrueMsg(wlesWithWarnings.isEmpty(), "Not all jobs completed &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
		endforeach;
		
		beginTransaction;
		job.CM_VoyageJob.updateActualAndEndTs(completedDate);
		commitTransaction;
	
	endforeach;
	
	/*
	app.writeLog("Checking Status Bar (HIDE) details are correct.  Please wait...", LogAlways);
	
	// check that the details of the status bar is correct - Hide Exports
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004 Job: 200");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670005, UT313670006, UT313670007, UT313670008 Job: 200");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670009, UT313670010, UT313670011, UT313670012 Job: 201");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019 Job: 205");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015 Job: 203");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 4 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018, UT313670015");
	self.locationArray.add("D4021");
	self.statusArray.add("D4021 D4021 | Aft: D4016 | 5 x CONT AUSYD  U40G | UT313670040, UT313670041, UT313670042, UT313670043, UT313670044 Job: 207");
	
	self.locationArray.add("D4060");
	self.statusArray.add("D4060 D4060 | Aft: D4055 | 4 x CONT AUBRI  U20G| 3 x CONT AUSYD  U40G | UT313670059, UT313670060, UT313670045, UT313670046, UT313670047, UT313670057, UT313670058 Job: 207");
	self.locationArray.add("D4040");
	self.statusArray.add("D4040 D4040 | Aft: D4035 | 4 x CONT AUSYD  U40G | UT313670048, UT313670049, UT313670050, UT313670051 Job: 207");
	self.locationArray.add("D4036");
	self.statusArray.add("D4036 D4036 |  Fwd: D4041 | 5 x CONT AUBRI  U20G | UT313670061, UT313670062, UT313670063, UT313670064, UT313670065 Job: 207");
	self.locationArray.add("D4041");
	self.statusArray.add("D4041 D4041 | Aft: D4036  | ");
	self.locationArray.add("D4037");
	self.statusArray.add("D4037 D4037 |  Fwd: D4042 | 5 x CONT AUBRI  U20G | UT313670066, UT313670067, UT313670068, UT313670069, UT313670070 Job: 207");
	self.locationArray.add("D4042");
	self.statusArray.add("D4042 D4042 | Aft: D4037 | 5 x CONT AUBRI  U20G | UT313670071, UT313670072, UT313670073, UT313670074, UT313670075 Job: 207");
	self.locationArray.add("D4043");
	self.statusArray.add("D4043 D4043 | Aft: D4038 | 6 x CONT AUBRI  U20G| 2 x CONT AUSYD  U40G | UT313670079, UT313670080, UT313670081, UT313670052, UT313670053, UT313670076, UT313670077, UT313670078 Job: 207");
	self.locationArray.add("D4044");
	self.statusArray.add("D4044 D4044 | Aft: D4039 | 4 x CONT AUBRI  U20G| 3 x CONT AUSYD  U40G | UT313670084, UT313670085, UT313670054, UT313670055, UT313670056, UT313670082, UT313670083 Job: 207");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsHide);

	app.writeLog("Checking Status Bar (SHOW) details are correct.  Please wait...", LogAlways);
	
	// check that the details of the status bar is correct - SHOW EXPORTS
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 1 x CONT ITGOA  U20G| 3 x CONT ITGOA  U40G | UT313670020, UT313670030, UT313670031, UT313670032");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 2 x CONT ITGOA  U20G| 3 x CONT ITGOA  U40G | UT313670021, UT313670030, UT313670031, UT313670032, UT313670020");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 2 x CONT NZLYT  U20G | UT313670009, UT313670010");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010  | ");
	self.locationArray.add("D4006");
