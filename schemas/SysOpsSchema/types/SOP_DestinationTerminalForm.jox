    <JadeMethod name="chxAutoPlan_click" id="96bb414c-2cf1-410c-bc7b-713bb83cd48c">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chxAutoPlan_click(checkbox: CheckBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	conkc1	Initial creation

*/

vars

begin
	doAutoPlanChange(chxAutoPlan.value);
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbDefaultTrans_click" id="579db47a-38f5-4205-b312-f2e658fe451b">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDefaultTrans_click(combobox: ComboBox input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2010	conkc1	Initial creation
*/
vars

begin
	if self.cmbDefaultTrans.listIndex &gt; 0 and self.cmbDefaultTrans.listIndex &lt;= self.cmbDefaultTrans.listCount then
		vDefaultTerminalArea := self.cmbDefaultTrans.listObject.CM_TerminalArea;
	else
		vDefaultTerminalArea := null;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbDestTerminal_click" id="48f97d55-0594-4f71-ad81-e04839fe96b2">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDestTerminal_click(combobox: ComboBox input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2010	conkc1	Initial creation
*/
vars

begin
	if self.cmbDestTerminal.listIndex &gt; 0 and self.cmbDestTerminal.listIndex &lt;= self.cmbDestTerminal.listCount then
		vDestinationTerminal := self.cmbDestTerminal.listObject.CM_Terminal;
		setupTerminalAreas;
		self.btnOk.enabled := true;
	else
		vDestinationTerminal := null;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAutoPlanChange" id="c9117390-74f2-4f44-ab93-6590bf87df4b">
        <updating/>
        <source>doAutoPlanChange(_value : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2010	conkc1	Initial creation

*/
vars

begin
	if _value = true then
		self.cmbDefaultTrans.clear;
		self.cmbDefaultTrans.enabled := false;
	else
		self.cmbDefaultTrans.enabled := true;
		setupTerminalAreas;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadTerminals" id="aa0c5e18-abad-4153-b150-edcfeb73905f">
        <updating/>
        <source>doLoadTerminals() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 February 2010	conkc1	Initial creation

*/
vars

	terminal : CM_Terminal;
	index    : Integer;
	
begin
	if self.vMode  = Mode_Add then
		foreach terminal in app.myRoot.allTerminals do
			if self.allUsedTerminals.includes(terminal) = false then
				index := self.cmbDestTerminal.addItem(terminal.code);
				self.cmbDestTerminal.itemObject[index] := terminal;
			endif;
		endforeach;

	elseif self.vMode = Mode_Edit then
		index := self.cmbDestTerminal.addItem(myEditTerminal.code);
		self.cmbDestTerminal.itemObject[index] := myEditTerminal;
		self.cmbDestTerminal.listIndex := 1;
		self.vDestinationTerminal      := myEditTerminal;
		self.chxAutoPlan.value         := self.myInterTerminalInfo.autoPlanAtDestTerminal;
		self.chxAutoPlan.click(chxAutoPlan); 	
		self.setupTerminalAreas;
		if self.chxAutoPlan.value = false then
			cmbDefaultTrans.listIndex := cmbDefaultTrans.findObject(self.myInterTerminalInfo.myDefaultTargetTermArea);
		endif;
		
	else
		// should not be here for a delete
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="a9d8f966-4f8a-4b0b-ad1b-39b263a33317">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	conkc1	Initial creation

*/

vars

begin
	if cmbDefaultTrans.listIndex &lt; 0 then
		if chxAutoPlan.value = false then
			app.msgBox('Must Select either Auto Plan or Transfer Area', 'Error', 0);
			return;
		endif;
	endif;
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3a9307b2-bb3f-4226-ae35-27eae12cbeb1">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	conkc1	Initial creation

*/

vars

begin
	inheritMethod();

	self.doLoadTerminals;
	if vMode = Mode_Add then
		cmbDestTerminal.enabled := true;
		self.btnOk.enabled      := false;
	elseif vMode = Mode_Edit then
		cmbDestTerminal.enabled := false;
		self.btnOk.enabled      := true;
	else
		write method.qualifiedName &amp; " Mode - '" &amp; vMode.String &amp; "' Error";
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTerminalAreas" id="3618e7cd-23e1-4800-97cb-7280572ed277">
        <updating/>
        <source>setupTerminalAreas() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
03 February 2010	conkc1	Initial creation
25/02/2010 			cnwcs5 	remove VTA references
08/09/2022			jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/

vars
	theFilter    : CMQF_TerminalAreas;
	theQryReport : CM_QryReport;
	terminal     : CM_Terminal;
	terminalArea : CM_TerminalArea;
	index        : Integer;
begin

	if self.cmbDestTerminal.listIndex &gt; 0 and self.cmbDestTerminal.listIndex &lt;= self.cmbDestTerminal.listCount then
		terminal := self.cmbDestTerminal.listObject.CM_Terminal;
		
		self.cmbDefaultTrans.clear;

		theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalArea);
		create theFilter transient;
		theFilter.allTerminals.add(terminal);
		theFilter.terminalAreaTypes.add(TA_TYPE_DEPOT_LCL);
		theFilter.terminalAreaTypes.add(TA_TYPE_BLOCK_STACK);
		theFilter.terminalAreaTypes.add(TA_TYPE_SUBBLOCK_STACK);            
		theFilter.terminalAreaTypes.add(TA_TYPE_WASH_AREA);                                  
		theFilter.terminalAreaTypes.add(TA_TYPE_PTI);                                      
		theFilter.terminalAreaTypes.add(TA_TYPE_REPAIR);                                          
		theFilter.terminalAreaTypes.add(TA_TYPE_RECTRANS);                                     
		theFilter.terminalAreaTypes.add(TA_TYPE_RELTRANS);                                     
		theFilter.terminalAreaTypes.add(TA_TYPE_RAIL_TRANS);                                               
//		theFilter.terminalAreaTypes.add(TA_TYPE_ROAD_TRANS);      	25/02/2010 cnwcs5 remove VTA references                                 
		theFilter.terminalAreaTypes.add(TA_TYPE_DAIRY);
		theFilter.terminalAreaTypes.add(TA_TYPE_MAFI);
        theQryReport.doFilter(theFilter, app.myPassport);

		foreach terminalArea in theFilter.allQryTerminalAreas do
			if terminalArea.type = TA_TYPE_CRANE_TRANS or
               terminalArea.type = TA_TYPE_DELETE then
               continue;
			endif;

			index := self.cmbDefaultTrans.addItem(terminalArea.id);
			self.cmbDefaultTrans.itemObject[index] := terminalArea;
		endforeach;
	
	endif;

epilog
	delete theFilter;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4452b976-317c-4553-8629-ad6649b6d010">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014047, locale);
	chxAutoPlan.translateCaption(Xlat_0014048, locale);
	lblDefaultTarget.translateCaption(Xlat_0014049, locale);
	lblDestTerminal.translateCaption(Xlat_0014050, locale);
	lblOr.translateCaption(Xlat_0014051, locale);
end;</source>
    </JadeMethod>
</GUIClass>
