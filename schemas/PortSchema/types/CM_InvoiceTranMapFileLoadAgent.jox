    <JadeMethod name="checkForVoidInvoiceLine" id="81640e26-98d8-4f2b-b2c8-552a70d95106">
        <updating/>
        <source>checkForVoidInvoiceLine(_currentPath : String; _invoiceLine : String) updating, protected;

vars
	i	: Integer;
begin
	if self.previousPath = "" then
		self.previousPath := _currentPath;
	endif;
	if _currentPath &lt;&gt; self.previousPath then
	
		foreach i in self.previousRow to self.rowCount - 1 do
			self.voidList[i] := self.hasVoid;
		endforeach;
		self.previousPath := _currentPath;
		self.previousRow := self.rowCount;
		self.hasVoid := false;
	endif;

	if _invoiceLine = self.voidInvoiceLineDesc then
		self.hasVoid := true;
	endif;
	self.previousPath := _currentPath;
	// last entry
	if self.rowCount = self.maxEntries then
		foreach i in self.previousRow to self.rowCount do
			self.voidList[i] := self.hasVoid;
		endforeach;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_currentPath" type="String"/>
        <Parameter name="_invoiceLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="createBOLMap" id="2be4cd3a-8551-49b6-8b97-951dbb9a6354">
        <updating/>
        <source>createBOLMap(_bankObj : CM_Bank; _mapName : String; _bolMap : CM_TranMapBOL output) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	bolMap,
	proxyMap	: CM_TranMapBOL;

begin
	// BOL Map
	bolMap := _bankObj.allBOLTranMaps[_mapName];
	if bolMap = null then
		create proxyMap transient;
		proxyMap.setProxy(_bankObj, _mapName, _mapName);
		// this will create a chain of default children 
		app.myTrxCA.trxCreateInvoiceTranMapBOL(proxyMap, bolMap, self.passport);
 		if (not app.myPassport.trxCompletedOK) then
 			self.setAllErrors('Creating BOL map (' &amp; _mapName &amp; '), row ' &amp; rowCount.String);
 			return false;
 		endif;
		createCount := createCount + 1;
	endif;
	
	_bolMap := bolMap;
	return true;
epilog
	delete proxyMap;
end;</source>
        <access>protected</access>
        <Parameter name="_bankObj" type="CM_Bank"/>
        <Parameter name="_mapName" type="String"/>
        <Parameter name="_bolMap" type="CM_TranMapBOL" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createBOLTypeMap" id="dba15b38-4a19-41c0-919e-4386e52e8c32">
        <updating/>
        <source>createBOLTypeMap(_bolTrxName : String; _bolMapObj : CM_TranMapBOL; _bolBrokerObj : CM_BOLServiceBroker output) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	found		: Boolean;
	isDefault	: Boolean;
	isMove		: Boolean;
	className	: String;
	bolTypeObj : CM_TransactionType;
	serviceBrokerObj : CM_ServiceBroker;
	bolBrokerObj	 : CM_BOLServiceBroker;
	proxyBolBroker	: CM_BOLServiceBroker;
	trxType : Integer;
begin
	self.getBOLDetails(_bolTrxName, isDefault, bolTypeObj);

	if isDefault then
		foreach bolBrokerObj in _bolMapObj.allBOLServiceBrokers do
			if bolBrokerObj.transactionType = 0 then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			bolBrokerObj := null;
		endif;
	else
		bolBrokerObj := _bolMapObj.allBOLServiceBrokers[bolTypeObj.trxType];
	endif;
	_bolBrokerObj := bolBrokerObj;

	if bolBrokerObj = null then
		create proxyBolBroker transient;
		
		trxType := 0;
		if bolTypeObj &lt;&gt; null then
			trxType:= bolTypeObj.trxType;
		endif;
		proxyBolBroker.setProxyRSB( trxType, _bolMapObj);
		
		app.myTrxCA.trxCreateInvoiceTMTransaction(proxyBolBroker, serviceBrokerObj, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating BOL type map (' &amp; _bolTrxName &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		_bolBrokerObj := serviceBrokerObj.CM_BOLServiceBroker;
		createCount := createCount + 1;
	endif;
	
	return true;
epilog
	delete proxyBolBroker;
end;
</source>
        <access>protected</access>
        <Parameter name="_bolTrxName" type="String"/>
        <Parameter name="_bolMapObj" type="CM_TranMapBOL"/>
        <Parameter name="_bolBrokerObj" type="CM_BOLServiceBroker" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCargoMap" id="d03ff384-4044-47a9-9f75-5890aa8a6e80">
        <updating/>
        <source>createCargoMap(_bankObj : CM_Bank; _mapName : String; _cargoMap : CM_TranMap output) : Boolean updating, protected;

vars
	cargoMap,
	proxyMap	: CM_TranMap;

begin
	// Cargo Map
	cargoMap := _bankObj.myCurrentTranMapCargo[_mapName];
	if cargoMap = null then
		create proxyMap transient;
		proxyMap.setProxy(_bankObj, _mapName, _mapName);
		// this will create a chain of default children 
		app.myTrxCA.trxCreateInvoiceTranMap(proxyMap, cargoMap, passport);
 		if (not app.myPassport.trxCompletedOK) then
 			self.setAllErrors('Creating cargo map (' &amp; _mapName &amp; '), row ' &amp; rowCount.String);
 			return false;
 		endif;
		createCount := createCount + 1;
	endif;
	
	_cargoMap := cargoMap;
	return true;
epilog
	delete proxyMap;
end;</source>
        <access>protected</access>
        <Parameter name="_bankObj" type="CM_Bank"/>
        <Parameter name="_mapName" type="String"/>
        <Parameter name="_cargoMap" type="CM_TranMap" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCargoTypeMap" id="0cf67848-3d3f-419a-8f18-71074f2feb9a">
        <updating/>
        <source>createCargoTypeMap(_cargoType : String; _cargoMap : CM_TranMap; _cargoTypeObj : CM_CargoType output; _serviceMap : CM_TIServiceMap output) : Boolean updating, protected;

vars
	proxyServiceMap,
	serviceMap		: CM_TIServiceMap;
	cargoTypeObj		: CM_CargoType;
	isDefault		: Boolean;
	found			: Boolean;
	label			: String;
begin
	// Cargo type
	self.getCargoTypeDetails(_cargoType, isDefault, cargoTypeObj);
	
	found := false;
	// find matching service map for this cargo type
	foreach serviceMap in _cargoMap.allTIServices do
		if serviceMap.myCargoType = cargoTypeObj then
			found := true;
			break;
		endif;
	endforeach;
	if not found then
		serviceMap := null;
		// create new
		create proxyServiceMap transient;
		label := "";
		if cargoTypeObj &lt;&gt; null then
			label := cargoTypeObj.classNameToCreate;
		endif;
		proxyServiceMap.setProxy(label, _cargoMap, cargoTypeObj);
		// this will create a chain of default children 
		app.myTrxCA.trxCreateInvoiceTMCargoType(proxyServiceMap, serviceMap,  passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating cargo type map (' &amp; _cargoType &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		createCount := createCount + 1;
	endif;
		
	_cargoTypeObj := cargoTypeObj;
	_serviceMap := serviceMap;
	return true;
epilog
	delete proxyServiceMap;
end;
</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="String"/>
        <Parameter name="_cargoMap" type="CM_TranMap"/>
        <Parameter name="_cargoTypeObj" type="CM_CargoType" usage="output"/>
        <Parameter name="_serviceMap" type="CM_TIServiceMap" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCommodityMap" id="1e18c9c0-7fe9-44fc-b6c7-253d57d4171d">
        <updating/>
        <source>createCommodityMap(_commodity : String;  _contentsMapObj : CM_ContentsMap; _commodityMapObj : CM_CommodityMap output) : Boolean updating, protected;

vars
	found		: Boolean;
	isDefault	: Boolean;
	commodityObj		: CM_Commodity;
	proxyCommodityMap,
	commodityMapObj 	: CM_CommodityMap;
begin
	self.getCommodityDetails(_commodity, isDefault, commodityObj);

	if isDefault then
		foreach commodityMapObj in _contentsMapObj.commoditiesMap do
			if commodityMapObj.commodityCode = null then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			commodityMapObj := null;
		endif;
	else
		commodityMapObj := _contentsMapObj.commoditiesMap[commodityObj.code];
	endif;

	if commodityMapObj = null then
		create proxyCommodityMap transient;
		proxyCommodityMap.setProxy(commodityObj, _contentsMapObj);
		app.myTrxCA.trxCreateInvoiceTMCommodity(proxyCommodityMap, commodityMapObj, passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating commodity map (' &amp; _commodity &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		createCount := createCount + 1;
	endif;

	_commodityMapObj := commodityMapObj;
	return true;
epilog
	delete proxyCommodityMap;
end;
</source>
        <access>protected</access>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_contentsMapObj" type="CM_ContentsMap"/>
        <Parameter name="_commodityMapObj" type="CM_CommodityMap" usage="output"/>
        <ReturnType type="Boolean"/>
