    <JadeMethod name="setForCreateFromTemplate" id="111dc42a-c044-4403-92a3-81f873df1ff0">
        <updating/>
        <source>setForCreateFromTemplate(_yardAllocation : CM_InvoiceCargoAllocation; _terminal : CM_Terminal) updating;
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/
begin
	
	// Set terminal reference.
//	self.myTerminal	:=	_terminal;
	self.myTerminal := null;	//23 Jul 2021	NDL	TFS 49952	 - should not be used

	// Standard set for update.	Builds blocks and primitives.
	self.setForUpdate(_yardAllocation);
	
	create self.myQuantityMap;
	self.myQuantityMap.initialise(self.myServiceBroker, self.myTransactionMap.myBank, true);
	
	
end;</source>
        <Parameter name="_yardAllocation" type="CM_InvoiceCargoAllocation"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d0ff2d71-bb18-4417-a81e-80917c62bb7c">
        <updating/>
        <source>setForUpdate(_proxyObj: CM_InvoiceCargoAllocation ) updating;
/*
Purpose:			
Date		Who		Reason
17 March 2015	cnwab1	Initial creation
19 Jun 2017	cnwma1 TFS #4498 JMT - Cargo Allocation Fix Up Export Script
*/

vars
	sb : CM_CargoAllocServiceBroker;
begin

   
	if self.myServiceBroker= null then
		create self.myServiceBroker as CM_CargoAllocServiceBroker;
		sb := self.myServiceBroker.CM_CargoAllocServiceBroker;
	endif;

	inheritMethod(_proxyObj);
	
	//self.myTransactionMap := pxy.myTransactionMap; //19/06/2017 cnwma1 TFS #4498

	if self.myServiceBroker= null then
		self.myServiceBroker := sb;
	endif;
	
	self.myTransactionMap.addSeviceBroker(self.myServiceBroker.CM_CargoAllocServiceBroker);

	self.myServiceBroker.CM_CargoAllocServiceBroker.initialiseYA();
	
	self.setPriority();
epilog

end;</source>
        <Parameter name="_proxyObj" type="CM_InvoiceCargoAllocation"/>
    </JadeMethod>
    <JadeMethod name="setPriority" id="d8013f59-5026-48bd-8831-b71b89ccc48b">
        <updating/>
        <source>setPriority() updating;

/*

Purpose:			Set the priority of the receiver based on the owning Transaction Map configuration

Date		Who		Reason
24 Mar 2015	cnwab1	Initial creation
30 May 2017	cnwkpd1	TFS #4542 - Invoicing performance changes
20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error

*/

vars
	criType 		: CM_YACriteriaType;
	critPriority,
	allocPriority, 
	cnt 			: Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
	opCritByType	: CM_YACritetriaTypeByTypeDict;
	crit			: CM_YACriteria;
	
begin
	// TFS #4542 - Need to remove any criteria types from the receiver that are no longer
	// valid in the owing transaction map configuration
	create opCritByType transient;
	self.myTransactionMap.myInvoiceAllocationConfig.allOpCriteria.copy(opCritByType);
	
	foreach crit in self.allCriteria do
		if opCritByType[crit.myYACriteriaType.type] = null then
			delete crit;
		endif;
	endforeach;	

	// Now go through the configured criteria, for this transaction map, in the configured order
	// If the criteria type is used by the allocation add to its priority value
	cnt := -1;
	foreach criType in self.myTransactionMap.myInvoiceAllocationConfig.allOpCriteria discreteLock, reversed do

		cnt := cnt + 1;

		crit := self.allCriteriaByType[criType.type];
		if crit &lt;&gt; null then
			critPriority := (2 ^ cnt);
			crit.setPriorityValue(critPriority);
			allocPriority := allocPriority + critPriority;
		endif;
	
	endforeach;

	if self.priorityValue &lt;&gt; allocPriority then
		self.priorityValue := allocPriority;
	endif;
	
epilog
	delete opCritByType;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateME" id="289c7c00-efef-4aef-8ab8-6bb27c68d534">
        <source>validateME(_allTransientCriteriaObj	: CMIF_Array;
			_update : Boolean //12/05/2023 navmv20 Bug 57561
			);
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
May 12 2023  navmv20	Bug 57561: STWO - Code :79963. A Yard Allocation with this code () already exists- Issue 1 of 2
*/

vars
		c : CMIF_Object;
		found : Boolean;
		invCargoAllocation	: CM_InvoiceCargoAllocation; //12/05/2023 navmv20 Bug 57561
begin

	if self.myTransactionMap = null then
		app.raiseCMException(Invoic_cargo_alloca_requir_tra,null,null);
	endif;
	



	if _allTransientCriteriaObj.isEmpty() then
	
		app.raiseCMException(No_Criteria_values_selected,null,null);
	endif;
	
	foreach c in _allTransientCriteriaObj discreteLock do
		if c.CMIF_YACriteriaPriority.isChanged then
			if c.CMIF_YACriteriaPriority.myCriteriaPriority.myYACriteriaType.type = YACriteriaType_TransactionType then
				found := true;
			endif;
		endif;
		if c.CMIF_YACriteriaPriority.isNew then
			if c.CMIF_YACriteriaPriority.myProxy.myYACriteriaType.type = YACriteriaType_TransactionType then
				found := true;
			endif;
		endif;
	endforeach;
		
	if not found then
		app.raiseCMException(Pleas_selec_some_trans_type_cr,null,null);
	
	endif;
	
	//12/05/2023 navmv20 Bug 57561 - start
		foreach invCargoAllocation in self.myTransactionMap.allInvoiceCargoAllocations as CM_InvoiceCargoAllocation do
			if invCargoAllocation.description = self.description then
				if ((_update and invCargoAllocation &lt;&gt; self.pxyGetRealObject()) 
						or (not _update and invCargoAllocation &lt;&gt; self)) then  // NAVAB1 03AUG2023 Fixing UTs. UT loading file, so create was failing 
					app.raiseCMException1(Err_YA_AlreadyExists, self.code, null, null);
					break;
				endif;
			endif;
		endforeach;
	//12/05/2023 navmv20 Bug 57561 - end
end;
</source>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
</Class>
