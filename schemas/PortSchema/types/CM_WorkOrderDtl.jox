    <JadeMethod name="canEdit" id="c4962bc2-aba7-4d09-b75a-f8ad16aa4202">
        <source>canEdit():Boolean;
/*

Purpose:			

Parameters:			
History 
28.6.2018 cnwma1 TFS #39462
18/9/18   epr    TFS 40869 
Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	allowEdit	  : Boolean;
	voyage		  : CM_Voyage;
	voyStatus 	  : CM_VoyageStatus;
	user		  : CM_User;
	term          : CM_Terminal;
begin
	user	  := app.getMyUser();	
	term      := self.getMyTerminal(); 
	allowEdit := self.getStatus &lt; WO_STATUS_APPROVED ;
	
	if self.isKindOf(CM_WodMarineServicesDepart) or self.isKindOf(CM_WodMarineServicesInitial) then
		allowEdit := false;
	elseif self.isKindOf(CM_WodCargoRequest) and self.CM_WodCargoRequest.myVoyageCargoRequest &lt;&gt; null then
		if allowEdit and voyage &lt;&gt; null then
			voyStatus := voyage.getVoyageStatusObject;
			if not voyStatus.id =Voyage_Status_CargoReqPending and not voyStatus.id = Voyage_Status_ICargoReqPending then
				allowEdit := false;
			endif;
		endif;
	elseif self.isKindOf(CM_WodCargoRequest) and self.CM_WodCargoRequest.myVoyageCargoRequest = null then  
		allowEdit := self.getStatus = WO_STATUS_PENDING;
	endif;
	
	
	if allowEdit then
		if self.isWorkOrderVoyageDtl then
			allowEdit := user.canDo(term, PmWebWorkOrdersVoyMaint);
		else
			allowEdit := user.canDo(term, PmWebWorkOrderMaint);
		endif;		
	endif;
	
	return allowEdit;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canPrintWOReportOnWeb" id="7403573c-3405-439b-9c41-e509374c7193">
        <source>canPrintWOReportOnWeb():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2018	jlgndl1	Initial creation	TFS 40213

*/

vars

begin

	if self.getStatus &lt;&gt; WO_STATUS_APPROVED then
		return false;
	endif;

	if not self.getMyParent.canPrintWorkOrderReport then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="causeTerminalEvent" id="be83ba9a-b088-4413-a438-2cc48a796bd4">
        <source>causeTerminalEvent(_mode : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2025	jlier1	Initial creation  MTN-34591

*/

vars
	evt : CM_SingleObjectUserInfoNoteEvt;
	terminal : CM_Terminal;
begin
	if self.isTransient then
		return;
	endif;
	
	if app.isInProformaMode then
		return;
	endif;
	
	terminal:= self.getMyTerminal;
	
	if terminal = null then
		return;
	endif;
	
	if _mode =Event_WODtl_Update then
		evt := app.myEventManager.allSingleObjInfoNotes[self, Event_WODtl_Create, self];
		if evt = null then
			app.myEventManager.createSingleObjInfoNoteEvt(self, terminal.getTerminalEvent(Event_WODtl_Update),  self);
		endif;
	elseif _mode = Event_WODtl_Create then
		app.myEventManager.createSingleObjInfoNoteEvt(self, terminal.getTerminalEvent(Event_WODtl_Create),  self);
	elseif _mode = 	Event_WODtl_Delete then
		self.causeEvent( terminal.getTerminalEvent(Event_WODtl_Delete),false,self);
	endif;
	
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
