    <JadeMethod name="setDamageParent" id="b2c958cf-9d4f-4ce3-9cb9-6a58b4671ef9">
        <source>setDamageParent(_tiMaster: CM_TIMasterContainer);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		21 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	di : CM_DamageInstance;
begin
	foreach di in self.allDamageInstancesByPos do
		di.setMySubject(_tiMaster);
	endforeach;
epilog
end;</source>
