    <JadeMethod name="toolbarShowCaptions" id="8654141f-1578-4db7-beb4-02677f30165f">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//20 Jan 2017	cnwrs1	TFS 3137 - resize the find/trplace form when show captions is on
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.optDocket.top := self.optDocket.top + heightDiff;
	self.optLot.top := self.optLot.top + heightDiff;
	self.optNoNumber.top := self.optNoNumber.top + heightDiff;
	self.optLogId.top := self.optLogId.top + heightDiff;
	self.chkInterTerminal.top:= self.chkInterTerminal.top + heightDiff;
	self.tblSelection.top := self.tblSelection.top + heightDiff;
	self.tblSelectData.top := self.tblSelectData.top + heightDiff;
	self.tblSelectData.height := self.tblSelectData.height - heightDiff;
	self.doResize();
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="869f0604-02a3-49f5-9ab3-020d8f1c9060">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006323, locale);
	btnFindT.translateCaption(Xlat_0002421, locale);
	btnNextT.translateCaption(Xlat_0002422, locale);
	btnSelectAllT.translateCaption(Xlat_0002423, locale);
	btnSelectNoneT.translateCaption(Xlat_0002424, locale);
	chkInterTerminal.translateCaption(Xlat_0002420, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0006324, locale);
	mnuHideDetail.translateCaption(Xlat_0006325, locale);
	mnuLogDetail.translateCaption(Xlat_0006326, locale);
	mnuOffloadContext.translateCaption(Xlat_0006327, locale);
	mnuShowOrganiser.translateCaption(Xlat_0006328, locale);
	optDocket.translateCaption(Xlat_0002425, locale);
	optLogId.translateCaption(Xlat_0006329, locale);
	optLot.translateCaption(Xlat_0002426, locale);
	optNoNumber.translateCaption(Xlat_0002427, locale);
end;</source>
    </JadeMethod>
