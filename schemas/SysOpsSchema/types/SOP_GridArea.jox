    <JadeMethod name="deleteGridColumn" id="b45194e6-f482-4a4e-a827-bc7be0ef4256">
        <updating/>
        <source>deleteGridColumn(_gridColumn : CMUI_GridColumn) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	gridColumn	: CMUI_GridColumn;
	realColumn : CM_GridColumn;
	int			: Integer;
	gridArea : CM_GridArea;
begin
	int := 0;
	gridArea := self.getProxyGridArea();
	
	foreach gridColumn in self.allGridColumns do
		if gridArea &lt;&gt; null then
			realColumn := gridArea.allGridColumns[gridColumn.column];
		else
			realColumn := null;
		endif;
		if gridColumn = _gridColumn then
			delete realColumn;
			delete gridColumn;
		else
			int := int + 1;
			if gridColumn.column &lt;&gt; int then
				if realColumn &lt;&gt; null then
					realColumn.setForProxy(int, realColumn.label,realColumn.myGridArea);
				endif;
				gridColumn.SOP_GridColumn.setColumn(int);
			endif;
		endif;
			
	endforeach;
end;</source>
        <Parameter name="_gridColumn" type="CMUI_GridColumn"/>
    </JadeMethod>
    <JadeMethod name="deleteGridRow" id="74b1ddbf-18cb-453e-ac6c-dff1bcb30e18">
        <updating/>
        <source>deleteGridRow(_gridRow : CMUI_GridRow) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	gridRow : CMUI_GridRow;
	int		: Integer;
begin
	int := 0;
	foreach gridRow in self.allGridRows do
		
		if gridRow = _gridRow then
			if gridRow.SOP_GridRow.myPxyGridRow &lt;&gt; null then // adm 230609 Par 20086
				delete gridRow.SOP_GridRow.myPxyGridRow;
			endif;
			delete gridRow;
		else
			int := int + 1;
			if gridRow.row &lt;&gt; int then
				gridRow.SOP_GridRow.setRow(int);
			endif;
		endif;
			
	endforeach;
end;</source>
        <Parameter name="_gridRow" type="CMUI_GridRow"/>
    </JadeMethod>
