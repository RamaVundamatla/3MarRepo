    <JadeMethod name="dumpAllCategoriesDetails" id="f9a5f36a-e160-4f2b-8b3b-16eebc9a3c4b">
        <source>dumpAllCategoriesDetails();

/*

Purpose:		Write out what's in allCategories	

Date			Who		Reason
11/03/2013		cnwmh5	Initial creation

*/

vars

	category					: UM_Category;
	obj							: Object;

begin

	foreach category in self.allCategories do
	
		foreach obj in category.allCategoryClassMethods do
		
			if obj.isKindOf(Class) then
				write obj.Class.name;
			else
				write obj.Method.getSchemaType().name &amp; Tab &amp; obj.Method.name;
			endif;
		
		endforeach;
	
	
	endforeach;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="emailReports" id="d9f1e9e9-a8e6-448a-8a2c-8f330bfd2764">
        <source>emailReports(_message : String; _subject : String; _flag : Integer; _testRunner : JMTTestController; _byTeam, _isHtml: Boolean);
/*

Purpose:	Email correct details to the specified recipient(s)		

Parameters:

			_flag : 0 = Not Admin
			_flag : 1 = Summary
			_flag : 2 = User Summary
			_flag : 3 = User Ignore Summary

Return Value:		

Date		Who		Reason
11 October 2012	cnwmc5	Initial creation
08/05/2025	navhn30 MTN: 34403: MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 4 - Phase1
09 Sep 2025 navah1 	MTN-34969: MTN - Investigate formatting Unit Test Emails in HTML - Phase2
*/
/*
vars
	root 				: UM_Root;
	userEmail			: UM_UserEmailAddress;
	
begin
	root := UM_Root.firstInstance();
	
	if root = null then
		return;
	endif;
	
	if _message = null then
		return;
	endif;
	
	foreach userEmail in root.allUserEmailAddresses do
	
		if userEmail.isDisabled then
			continue;
		elseif _flag = 0 then
			///if userEmail.user.toUpper() &lt;&gt; _subject.toUpper() then
			if not _subject.toUpper().cnContains(userEmail.user.toUpper()) then				// 08/03/2016 cnwmh5
				continue;
			endif;
		elseif _flag = 1 and not userEmail.getsSummary then
			continue;
		elseif _flag = 2 and not userEmail.getsUserSummary then
			continue;
		elseif _flag = 3 and not  userEmail.getsUserIgnore then
			continue;
		endif;
		
		_testRunner.emailResults(userEmail.user, _message, _subject, null);
		
		if _flag = 0 then					// 10/11/2015 cnwmh5
			break;
		endif;
		
	endforeach;
	
epilog

end;
*/

/*
18/02/2020	JLGMH%	Change to run either the Navis or JLI reports.  JLI will run how we normally run
*/


vars


begin

	//emailReports_Navis(_message, _subject, _flag, _testRunner,_byTeam);  //09.09.2025 navah1 #34969
	emailReports_Navis(_message, _subject, _flag, _testRunner,_byTeam, _isHtml); //09.09.2025 navah1 #34969

epilog

end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_flag" type="Integer"/>
        <Parameter name="_testRunner" type="JMTTestController"/>
        <Parameter name="_byTeam" type="Boolean"/>
        <Parameter name="_isHtml" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="emailReports_Admin" id="5ba79b9e-8a99-4fdb-b85b-bd6d2dac6986">
        <source>emailReports_Admin(_message : String; _subject : String; _flag : Integer) : String;

/*

Purpose:	Workout what email addrsss we need to send the reports to		

arameters:

			_flag : 0 = Not Admin
			_flag : 1 = Summary
			_flag : 2 = User Summary
			_flag : 3 = User Ignore Summary
			_flag : 4 = XLAT Form Constants Missing
			_flag : 5 = Failure Summary
			_flag : 6 = Framework


Date		Who		Reason
18/02/2020	jlgmh5	Initial creation

*/
constants

	DevEmailGroup			: String = "Navis - Dev Email Group";
	QAEmailGroup			: String = "Navis - QA Email Group";
	
vars
	
	emailGroup				: CM_EmailGroup;
	emailAddress			: CM_EmailAddress2;
	obj						: Object;
	emailGroupDev			: CM_EmailGroup;
	emailGroupQA			: CM_EmailGroup;
	
	emailGroupArray			: ObjectArray;


	emailTo					: String;

begin

	// get the dev email group
	emailGroupDev := app.myRoot.allEmailEntities[Email_Group, DevEmailGroup].CM_EmailGroup;
	emailGroupQA := app.myRoot.allEmailEntities[Email_Group, QAEmailGroup].CM_EmailGroup;

	create emailGroupArray transient;

	// Failure Summary Report
	if _subject.cnContains("Failure Summary") then
		if app.isRunningInDMAST() then
			emailGroupArray.add(emailGroupDev);
		elseif app.isRunningInWMAST() then
			emailGroupArray.add(emailGroupQA);
		endif;
	elseif _flag = JMTTestController.EmailType_Summary then							// full summary, _flag 1
		emailGroupArray.add(emailGroupQA);
	endif;
	
	// XLAT Form Constants Missing
	if app.isRunningInWMAST() and _subject.cnContains("XLAT Form Constants Missing") then
		emailGroupArray.add(emailGroupQA);
		emailGroupArray.add(emailGroupDev);	
	endif;
	
	// Source Comparison Checks
	if app.isRunningInWMAST() and _subject.cnContains("Source Comparison Check Failed") then
		emailGroupArray.add(emailGroupDev);
	endif;
	
	// All Flag 2 and 3 reports
	if _flag = JMTTestController.EmailType_UserSummary or _flag = JMTTestController.EmailType_UserIgnoreSummary then
		emailGroupArray.add(emailGroupQA);
	endif;
	
	// Get the email addresses to email to from the group
	foreach obj in emailGroupArray do
		emailGroup := obj.CM_EmailGroup;
		foreach emailAddress in emailGroup.allEmailAddresses do
			if not emailTo.cnContains(emailAddress.emailAddress) then
				if emailTo.length &gt; 0 then
					emailTo := emailTo &amp; ";";
				endif;
				emailTo := emailTo &amp; emailAddress.emailAddress;
			endif;
		endforeach;
	endforeach;
	
	return emailTo;

epilog

	delete emailGroupArray;

end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_flag" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="emailReports_ByTeam" id="2bd3eef0-ab41-40d0-9512-64d3a99db884">
        <source>emailReports_ByTeam(subject: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2025	navhn30	 MTN: 34403: MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 4 - Phase1

*/

vars	
	root 				: UM_Root;
	userEmail			: UM_UserEmailAddress;
	user				: CM_User;
	emailEntity			: CM_EmailEntity;
	emailTo				: String;
	emailGroupArray		: ObjectArray;
	email				: String;

begin

	
	root := UM_Root.firstInstance();
	
	if subject.isOneOf(UT_UnitTest.Team_None.toUpper,UT_UnitTest.Team_Andrew.toUpper,UT_UnitTest.Team_Phil.toUpper,UT_UnitTest.Team_Mason.toUpper,UT_UnitTest.Team_Mohamed.toUpper,UT_UnitTest.Team_Ram.toUpper) then
		foreach userEmail in root.allUserEmailAddresses do
	
			if userEmail.isDisabled then
				continue;
			endif;
			foreach email in userEmail.allReports do
				if email.toUpper = subject then
					user := app.myRoot.allUsers[userEmail.user];
					if user&lt;&gt; null then
					emailEntity :=  user.myEmailEntity;
						if emailEntity &lt;&gt; null and emailEntity.isKindOf(CM_EmailAddress2) then
							if emailTo.length &gt; 0 then
								emailTo := emailTo &amp; ";";
							endif;
							emailTo := emailTo &amp; emailEntity.CM_EmailAddress2.getEmailAddress();
						endif;
					endif;
				endif;
			endforeach;
			
		endforeach;
	endif;
	
	return emailTo;

epilog

end;</source>
        <Parameter name="subject" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="emailReports_JLI" id="88766645-6a8e-4acc-97b4-fb7522eb61b3">
        <source>emailReports_JLI(_message : String; _subject : String; _flag : Integer; _testRunner : JMTTestController);
/*

Purpose:	Email correct details to the specified recipient(s)		

Parameters:

			_flag : 0 = Not Admin
			_flag : 1 = Summary
			_flag : 2 = User Summary
			_flag : 3 = User Ignore Summary
			_flag : 4 = XLAT Form Constants Missing

Return Value:		

Date		Who		Reason
11 October 2012	cnwmc5	Initial creation

*/

vars
	root 				: UM_Root;
	userEmail			: UM_UserEmailAddress;
	
begin
	root := UM_Root.firstInstance();
	
	if root = null then
		return;
	endif;
	
	if _message = null then
		return;
	endif;
	
	foreach userEmail in root.allUserEmailAddresses do
	
		if userEmail.isDisabled then
			continue;
		elseif _flag = 0 or _flag = 4 then
			///if userEmail.user.toUpper() &lt;&gt; _subject.toUpper() then
			if not _subject.toUpper().cnContains(userEmail.user.toUpper()) then				// 08/03/2016 cnwmh5
				continue;
			endif;
		elseif _flag = 1 and not userEmail.getsSummary then
			continue;
		elseif _flag = 2 and not userEmail.getsUserSummary then
			continue;
		elseif _flag = 3 and not  userEmail.getsUserIgnore then
			continue;
		endif;
		
		_testRunner.emailResults(userEmail.user, _message, _subject, null,false);
		
		if _flag = 0 then					// 10/11/2015 cnwmh5
			break;
		endif;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_flag" type="Integer"/>
        <Parameter name="_testRunner" type="JMTTestController"/>
    </JadeMethod>
    <JadeMethod name="emailReports_Navis" id="72896b38-a4f2-4237-9dbf-d888aff06308">
        <source>emailReports_Navis(_message : String; _subject : String; _flag : Integer; _testRunner : JMTTestController; _byTeam,_isHtml: Boolean);
/*

Purpose:	Email correct details to the specified recipient(s)		

Parameters:

			_flag : 0 = User specific emails
			_flag : 1 = Summary
			_flag : 2 = User Summary
			_flag : 3 = User Ignore Summary
			_flag : 4 = XLAT Form Constants Missing
			_flag : 5 = Failure Summary
			_flag : 6 = Framework

Return Value:		

Date		Who		Reason
11 October 2012	cnwmc5	Initial creation
18/02/2020	JLMH5	Rewrite for Navis
08/05/2025		navhn30 MTN: 34403: MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 4 - Phase1
09 Sep 2025 navah1 MTN-34969: MTN - Investigate formatting Unit Test Emails in HTML - Phase2
*/

vars

	tokens						: StringArray;

	emailTo						: String;
	emailResults				: Boolean;

begin

	if _message = null then
		return;
	endif;
	
	emailResults := false;
	
	if _flag.isOneOf(JMTTestController.EmailType_Summary, JMTTestController.EmailType_UserSummary, JMTTestController.EmailType_UserIgnoreSummary, JMTTestController.EmailType_Framework, JMTTestController.EmailType_FailureSummary) then
		if not _byTeam  then		//08.05.25	navhn30	MTN-34403
			emailTo := emailReports_Admin(_message, _subject, _flag);
		else
			emailTo := emailReports_ByTeam(_subject);
		endif;
		if process.isRunningScript and _byTeam = null and (process.isMPD or process.isPW or process.isCallum) then
			write "Previous EmailTo: " &amp; emailTo;
			emailTo := "mason.drew@kaleris.com;phillip.wells@kaleris.com;callum.slaven@kaleris.com";
			write "Overwriting with: " &amp; emailTo;
		endif;
		emailResults := true;
	endif;
	
	if emailResults then
	
		create tokens transient;
		emailTo.getTokensForDelimiter(";", tokens);
	
		foreach emailTo in tokens do
			//_testRunner.emailResults(emailTo, _message, _subject, null); 
			_testRunner.emailResults(emailTo, _message, _subject, null,_isHtml); //09.09.2025 navah1 #34969
		endforeach;
	endif;

epilog

	delete tokens;

end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_flag" type="Integer"/>
        <Parameter name="_testRunner" type="JMTTestController"/>
        <Parameter name="_byTeam" type="Boolean"/>
        <Parameter name="_isHtml" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="extractChangedDetails" id="a2baa701-9481-40c5-b17a-3afed6ddc5bc">
        <source>extractChangedDetails();

/*

Purpose:			

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars

	changesInSource				: UM_ChangesInSource;
	
begin

	app.initialize();
	
	
	create changesInSource transient;
	
	// get the changes from the current system
	changesInSource.extractChangesCurrent();
	
	// get the changes from the other system
	changesInSource.extractChangesOtherSystem();
	
	// what's in current system and not in other
	changesInSource.findMissingDetails();
	
	// go get the mssing details from the other system
	changesInSource.updateOtherOutputFile();
	
	// do compare again and see where the difference are
	changesInSource.updateDoFullCompare(true);
	changesInSource.reloadXMLDocuments();
	changesInSource.compareChangesSchemas();

epilog

	delete changesInSource;
	
	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="extractChangedDetailsAdd" id="a503e3df-4470-4070-bf15-16d1586d8e18">
        <source>extractChangedDetailsAdd();

/*

Purpose:		Extract out additional details	

Date			Who		Reason
09/09/2016		cnwmh5	Initial creation

*/

vars

	changesInSource				: UM_ChangesInSource;
	
begin

	app.initialize();
	
	
	create changesInSource transient;
	
	// extract out additional details
	changesInSource.extractAdditionalDetails();
	

epilog

	delete changesInSource;
	
	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="extractEmailMUserAltUserAdmin" id="1d736dd3-e160-4b10-bcb3-964aa0fbf929">
        <source>extractEmailMUserAltUserAdmin();

/*

Purpose:		Get the User / Alt User / Admin combination and write to a file. 
				This is used by JadeScript::setupDataForEmailManagement when
				setting up a new system

Date			Who		Reason
17/04/2014		cnwmh5	Initial creation

*/

vars

	file					: File;
	emailManagement			: UM_UserEmailAddress;
	root					: UM_Root;

begin

	app.initialize();

	root := UM_Root.firstInstance;
	if root = null then
		app.writeLog("Unable to find UM_Root instance.  Exiting...", LogINFO);
		return;
	endif;

	create file transient;
	file.usePresentationFileSystem := true;
	file.fileName := app.getTempDir() &amp; "\dmastUserAltUserAdmin.txt";
	if file.isAvailable() then
		file.purge();
	endif;
	
	foreach emailManagement in root.allUserEmailAddresses do
		file.writeLine(emailManagement.user &amp; "," &amp; emailManagement.altUser &amp; "," &amp; emailManagement.isAdmin.Integer.String);	
	endforeach;
	file.close();
	
epilog

	delete file;
	
	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="extractForSpreadsheets" id="b6fb0bde-159e-4de4-ae63-cdbab3f66337">
        <source>extractForSpreadsheets();

/*

Purpose:		Get the data out for use in the spreadsheets to check what is overlapping and what isn't

Date			Who		Reason
08/11/2013		cnwmh5	Initial creation

*/
constants

	ExtractPrimary					: String = 'extractPrimary=';
	DELIM							: Character = ",";
	
vars

	inputFile						: File;
	overlapFile						: File;
	root							: UM_Root;
	constant						: Constant;
	schema							: Schema;
	klass							: Class;
	testRun							: UM_UnitTestRun;
	
	args							: StringArray;
	
	iter							: Iterator;

	envName 						: String;
	commandFlag						: String;
	extractPrimary					: Boolean;
	startTS							: TimeStamp;
	finishTS						: TimeStamp;
	runStartTS						: TimeStamp;
	schedule						: String;
	elapsed							: String;
	result							: Integer;
	serverName						: String;
	tempTS							: TimeStamp;

begin

	app.initialize();

	root := UM_Root.firstInstance;
	if root = null then
		app.writeLog("Unable to find UM_Root instance.  Exiting...", LogINFO);
		return;
	endif;

	// create the file	
	create inputFile transient;
	inputFile.usePresentationFileSystem := true;
	inputFile.fileName := app.getTempDir() &amp; "\Unit_Test_Run_Details.csv";
	inputFile.mode := File.Mode_Append;
	//inputFile.kind := File.Kind_ANSI;
	inputFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	
	app.writeLog(method.qualifiedName() &amp; Tab &amp; 'inputFile: ' &amp; inputFile.fileName, LogINFO);
	
	create args transient;	
	
	// get the command line details
	commandFlag := process.getCommandLine();
	commandFlag := commandFlag[commandFlag.pos(ExtractPrimary, 1) + ExtractPrimary.length : end];
	extractPrimary := commandFlag.Boolean;
	
	app.writeLog(method.qualifiedName() &amp; Tab &amp; 'commandFlag: ' &amp; commandFlag.String &amp; Tab &amp;
		'extractPrimary: ' &amp; extractPrimary.String, LogINFO);
	
	// extractPrimary stuff
	//if extractPrimary then
		// file available then purge, write header and close		
		if inputFile.isAvailable() then
			inputFile.purge();
		endif;
		inputFile.writeLine('System' &amp; DELIM &amp; 'Server' &amp; DELIM &amp; 'Start Date' &amp; DELIM &amp; "Start Time" &amp; DELIM &amp; 
			"Finish Date" &amp; DELIM &amp; "Finish Time" &amp; DELIM &amp; "Runnable" &amp; DELIM &amp; "Tests Run" &amp; DELIM &amp; "Failed" &amp; DELIM &amp; 
			"Elapsed" &amp; DELIM &amp; "Schedule" &amp; DELIM &amp; "LogResult");
		inputFile.close();
		
		// class to smast (8.6.1U)
		app.writeLog("Opening development envirnoment (umast 8.6.1 UNICODE)...", LogINFO);
		args.clear();
		args.add('appServer=jade1.cnwumast.cnw.co.nz');
		args.add('appServerPort=51980');
		args.add('app=JMTExtractRunsForSpreadsheets');
		args.add('schema=JMTUnitTest');
		args.add('ini="C:\DevelopmentEnvs\cnwumast\cnwumast.ini"');
		args.add('endJade');
		args.add(ExtractPrimary &amp; (not extractPrimary).String);
		
		node.createExternalProcess("C:\DevelopmentEnvs\cnwumast\c_bin", '"C:\DevelopmentEnvs\cnwumast\c_bin\jade.exe"', args, null, true, true, result);
		
		// class to wmast (8.5.1)
		app.writeLog("Opening development envirnoment (wmast 8.5.1)...", LogINFO);
		args.clear();
		args.add('appServer=jade1.cnwwmast.cnw.co.nz');
		args.add('appServerPort=50821');
		args.add('app=JMTExtractRunsForSpreadsheets');
		args.add('schema=JMTUnitTest');
		args.add('ini="C:\DevelopmentEnvs\cnwwmast\cnwwmast.ini"');
		args.add('endJade');
		args.add(ExtractPrimary &amp; (not extractPrimary).String);
		
		node.createExternalProcess("C:\DevelopmentEnvs\cnwwmast\c_bin", '"C:\DevelopmentEnvs\cnwwmast\c_bin\jade.exe"', args, null, true, true, result);
		
		// class to smast (8.4.2)
		app.writeLog("Opening development envirnoment (smast 8.4.2)...", LogINFO);
		args.clear();
		args.add('appServer=jade1.cnwsmast.cnw.co.nz');
		args.add('appServerPort=51066');
		args.add('app=JMTExtractRunsForSpreadsheets');
		args.add('schema=JMTUnitTest');
		args.add('ini="C:\DevelopmentEnvs\cnwsmast\cnwsmast.ini"');
		args.add('endJade');
		args.add(ExtractPrimary &amp; (not extractPrimary).String);
		
		node.createExternalProcess("C:\DevelopmentEnvs\cnwsmast\c_bin", '"C:\DevelopmentEnvs\cnwsmast\c_bin\jade.exe"', args, null, true, true, result);
		
		/*
		// class to xmast (8.3.2)
		app.writeLog("Opening development envirnoment (xmast 8.3.2)...", LogAlways);
		args.clear();
		args.add('appServer=jade1.cnwxmast.cnw.co.nz');
		args.add('appServerPort=50730');
		args.add('app=JMTExtractRunsForSpreadsheets');
		args.add('schema=JMTUnitTest');
		args.add('ini="C:\DevelopmentEnvs\cnwxmast\cnwxmast.ini"');
		args.add('endJade');
		args.add(ExtractPrimary &amp; (not extractPrimary).String);
		
		node.createExternalProcess("C:\DevelopmentEnvs\cnwxmast\c_bin", '"C:\DevelopmentEnvs\cnwxmast\c_bin\jade.exe"', args, null, true, true, result);
		
		// class to nmast (8.3.1)
		app.writeLog("Opening development envirnoment (nmast 8.3.1)...", LogAlways);
		args.clear();
		args.add('appServer=jade1.cnwnmast.cnw.co.nz');
		args.add('appServerPort=51306');
		args.add('app=JMTExtractRunsForSpreadsheets');
		args.add('schema=JMTUnitTest');
		args.add('ini="C:\DevelopmentEnvs\cnwnmast\cnwnmast.ini"');
		args.add('endJade');
		args.add(ExtractPrimary &amp; (not extractPrimary).String);
		
		node.createExternalProcess("C:\DevelopmentEnvs\cnwnmast\c_bin", '"C:\DevelopmentEnvs\cnwnmast\c_bin\jade.exe"', args, null, true, true, result);

		/*
		// class to gmast (8.2.2)
		app.writeLog("Opening development envirnoment (gmast 8.2.2)...", LogAlways);
		args.clear();
		args.add('appServer=jade1.cnwgmast.cnw.co.nz');
		args.add('appServerPort=53251');
		args.add('app=JMTExtractRunsForSpreadsheets');
		args.add('schema=JMTUnitTest');
		args.add('ini="C:\DevelopmentEnvs\cnwgmast\cnwgmast.ini"');
		args.add('endJade');
		args.add(ExtractPrimary &amp; (not extractPrimary).String);
		
		node.createExternalProcess("C:\DevelopmentEnvs\cnwgmast\c_bin", '"C:\DevelopmentEnvs\cnwgmast\c_bin\jade.exe"', args, null, true, true, result);
		
		// class to lmast (8.2.1)
		app.writeLog("Opening development envirnoment (lmast 8.2.1)...", LogAlways);
		args.clear();
		args.add('appServer=jade1.cnwlmast.cnw.co.nz');
		args.add('appServerPort=50879');
		args.add('app=JMTExtractRunsForSpreadsheets');
		args.add('schema=JMTUnitTest');
		args.add('ini="C:\DevelopmentEnvs\cnwlmast\c_bin\cnwlmast.ini"');
		args.add('endJade');
		args.add(ExtractPrimary &amp; (not extractPrimary).String);
		
		node.createExternalProcess("C:\DevelopmentEnvs\cnwlmast\c_bin", '"C:\DevelopmentEnvs\cnwlmast\c_bin\jade.exe"', args, null, true, true, result);
		
		// class to tmast (8.1.2)
		app.writeLog("Opening development envirnoment (tmast 8.1.2)...", LogAlways);
		args.clear();
		args.add('appServer=jade1.cnwtmast.cnw.co.nz');
		args.add('appServerPort=50721');
		args.add('app=JMTExtractRunsForSpreadsheets');
		args.add('schema=JMTUnitTest');
		args.add('ini="C:\DevelopmentEnvs\cnwtmast\cnwtmast.ini"');
		args.add('endJade');
		args.add(ExtractPrimary &amp; (not extractPrimary).String);
		
		node.createExternalProcess("C:\DevelopmentEnvs\cnwtmast\c_bin", '"C:\DevelopmentEnvs\cnwtmast\c_bin\jade.exe"', args, null, true, true, result);
		
		// class to wmast (8.1.1)
		app.writeLog("Opening development envirnoment (wmast 8.1.1)...", LogAlways);
		args.clear();
		args.add('appServer=jade1.cnwwmast.cnw.co.nz');
		args.add('appServerPort=50821');
		args.add('app=JMTExtractRunsForSpreadsheets');
		args.add('schema=JMTUnitTest');
		args.add('ini="C:\DevelopmentEnvs\cnwwmast\cnwwmast.ini"');
		args.add('endJade');
		args.add(ExtractPrimary &amp; (not extractPrimary).String);
		
		node.createExternalProcess("C:\DevelopmentEnvs\cnwwmast\c_bin", '"C:\DevelopmentEnvs\cnwwmast\c_bin\jade.exe"', args, null, true, true, result);
		*/
		
	//endif;
	
	// get the system name
	envName := CM_Version.VERSION;
	if app.isUnicode then
		envName := envName &amp; "U";
	endif;
	
	app.writeLog("Start extracting run details in " &amp; envName &amp; ".  Please wait.....", LogINFO);
	
		// get startTS details
	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		return;
	endif;
	
	klass := schema.getClass("CM_Version");
	if klass = null then
		return;
	endif;
	constant := klass.findConstant('VERSION').Constant;
	startTS := constant.cnGetModifiedTimeStamp();
	
	inputFile.open();
	
	// read through the data
	iter := root.allUnitTestRuns.createIterator;
	root.allUnitTestRuns.startKeyGeq(startTS, iter);
	while iter.next(testRun) do

		runStartTS := testRun.creationTime;
		
		finishTS := runStartTS;
		finishTS := finishTS.addMinutes(testRun.elapsedTime.Integer);
		
		schedule := testRun.scheduleName;
		if schedule.trimBlanks() = null then
			schedule := "^^";
		endif;
				
		elapsed := testRun.elapsedTime.String;
		if elapsed.trimBlanks() = null then
			elapsed := "^^";
		endif;				
				
		// 11/12/2015 cnwmh5 -  work out server name for overlap details
		serverName := "CNWCHCS101";
		if envName = "8.6.1U" then
			tempTS.setDate("26/11/2015".Date);
			tempTS.setTime("14:56:00".Time);
			if testRun.startTS &gt; tempTS then
				serverName := app.computerNameAppServer;
			endif;
		elseif envName = "8.5.1" then
			tempTS.setDate("30/11/2015".Date);
			tempTS.setTime("21:09:00".Time);
			if testRun.startTS &gt; tempTS then
				serverName := app.computerNameAppServer;
			endif;
		//elseif envName = "8.3.2" then
		//	tempTS.setDate("30/11/2015".Date);
		//	tempTS.setTime("22:15:00".Time);
		//	if testRun.startTS &gt; tempTS then
		//		serverName := app.computerNameAppServer;
		//	endif;
		//elseif envName = "8.3.1" then		
		//	tempTS.setDate("30/11/2015".Date);
		//	tempTS.setTime("11:06:00".Time);
		//	if testRun.startTS &gt; tempTS then
		//		serverName := app.computerNameAppServer;
		//	endif;
		endif;
				
		inputFile.writeLine(envName &amp; DELIM &amp; serverName &amp; DELIM &amp; testRun.startTS.date.String &amp; DELIM &amp; testRun.startTS.time.String &amp; DELIM &amp; 
			finishTS.date.String &amp; DELIM &amp; finishTS.time.String &amp; DELIM &amp; testRun.totalRunnable.String &amp; DELIM &amp; testRun.numRun.String &amp; DELIM &amp;
			elapsed &amp; DELIM &amp; schedule &amp; DELIM &amp; testRun.logResult.String &amp; DELIM &amp; testRun.numFailed.String);
		
	endwhile;
	inputFile.close();
	
	app.writeLog("Finished extracting run details in " &amp; envName &amp; ".  Please wait.....", LogINFO);
	
	//if extractPrimary then
		// create the overlapping file
		create overlapFile transient;
		overlapFile.fileName := app.getTempDir() &amp; "\Unit_Test_Run_Details_Overlap.csv";
		if overlapFile.isAvailable() then
			overlapFile.purge;	
		endif;
		overlapFile.writeLine('System' &amp; DELIM &amp; 'Server' &amp; DELIM &amp;	'Start Date' &amp; DELIM &amp; "Start Time" &amp; DELIM &amp; 
			"Finish Date" &amp; DELIM &amp; "Finish Time" &amp; DELIM &amp; "Runnable" &amp; DELIM &amp; "Tests Run" &amp; DELIM &amp; "Failed" &amp; DELIM &amp; 
			"Elapsed (mins)" &amp; DELIM &amp; "Elapsed (hours)" &amp; DELIM &amp; "Schedule" &amp; DELIM &amp; 
			"LogResult" &amp; DELIM &amp; "Overlapped" &amp; DELIM &amp; "Non Overlap Time" &amp; DELIM &amp; "Overlap Amount");	
		
		///self.createOverlapFile(overlapFile, inputFile.fileName);
		if self.class.getMethod("createOverlapFile") &lt;&gt; null then
			self.sendMsgWithParams("createOverlapFile", overlapFile, inputFile.fileName);
		endif;
		
		// open overlap file in excel
		global.cnEcOpenMSExcel(overlapFile.fileName);
	//endif;
	
epilog

	inputFile.close();
	delete inputFile;

	if overlapFile &lt;&gt; null then					// 29/06/2015 cnwmh5
		overlapFile.close();
	endif;
	delete overlapFile;
	
	delete args;
	delete iter;
	
	terminate;
	
end;</source>
    </JadeMethod>
