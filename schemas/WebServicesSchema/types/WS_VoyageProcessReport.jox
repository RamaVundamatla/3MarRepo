    <JadeMethod name="setReportOutputFromAgent" id="ac41ed0d-eb2e-4b1b-b8f4-9653dddb5a0f">
        <updating/>
        <source>setReportOutputFromAgent(agent : WebService_ReportAgent input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2018	jlgndl1	Initial creation	TFS 40889

*/

vars

	cashReceipt : CM_CashReceipt;
	invoice : CM_Invoice;
	ws_Invoice : WS_Invoice;

begin

	self.reportOutputFileURL := agent.reportOutputFileURL;
	self.reportOutput := agent.reportOutputFileURL;
	
	//08 Feb 2019	NDL	TFS 43240
	
	if agent.myContextObject &lt;&gt; null then
		if agent.myContextObject.isKindOf( CM_VoyageProcessReport ) then
			self.reportName := agent.myContextObject.CM_VoyageProcessReport.displayName;	//19 Feb 2019
			return;
		endif;
	endif;
	
	if agent.myCashReceipt &lt;&gt; null then
	/* TFS 41026	
		invoice := agent.myCashReceipt.myCashInvoice;
		if invoice &lt;&gt; null then
			create ws_Invoice transient;
			ws_Invoice.setProxyFromObject( invoice );
			self.invoice := ws_Invoice;
		endif;

		*/
		create ws_Invoice transient;
		ws_Invoice.setFromCashReceipt( agent.myCashReceipt );
		self.invoice := ws_Invoice;
			
	elseif agent.myInvoice &lt;&gt; null then
		create ws_Invoice transient;
		ws_Invoice.setProxyFromObject( agent.myInvoice );
		self.invoice := ws_Invoice;
	endif;

epilog

end;</source>
        <Parameter name="agent" type="WebService_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
