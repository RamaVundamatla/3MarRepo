<Class name="CM_KPITrainVisitDtl" id="a58c1a20-5c8c-4c92-a108-24bbb7835abc">
    <superclass name="CM_KPIVisitDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="kpiPeriod"/>
    <PrimAttribute name="railArea" id="e0aa2d19-4955-4765-b407-52911ef653ec">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="train" id="1b838c55-eb3a-4034-acf4-9df9663004eb">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="displayString" id="d6405004-c645-4916-aafb-8fe186541c91">
        <source>displayString(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2012	cnwdw1	Initial creation
*/
vars

begin
	return inheritMethod() &amp; " RailArea: " &amp; railArea &amp; " Train: " &amp; train ;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromTrain" id="52e50b39-081f-42cd-958a-6ed32f925974">
        <updating/>
        <source>setFromTrain(_train: CM_Train) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2012	cnwdw1	Initial creation
*/
vars
	ta: CM_Rail;
begin
	self.startTime := _train.arrivalDT;
	self.finishTime := _train.departureDT;
	self.train := _train.code;
	ta := _train.myRailArea;
	if ta &lt;&gt; null then
		self.railArea := ta.id;
	endif;
epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
</Class>
