    <JadeMethod name="setForUpdate" id="13911238-86e8-45d6-a580-007329409ff9">
        <updating/>
        <source>setForUpdate(_proxyDriver :CM_DriverDetails) updating;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 18/10/2019	jlgdap1		TFS 46854 SNO Driver Identity Checking for Cargo Release
vars

begin
	self.name			:= _proxyDriver.name;
	self.code		:= _proxyDriver.code;
	self.secondaryCode			:= _proxyDriver.secondaryCode;
	self.status			:= _proxyDriver.status;
	if app.getMyUser.canDo(_proxyDriver.myTerminal, PmAdmDriverExternalIDMaint) then	// TFS 46854
		self.externalID := _proxyDriver.externalID;										// TFS 46854
	endif;																				// TFS 46854
	self.allCarriers.clear;
	_proxyDriver.allCarriers.copy(self.allCarriers);
	self.allVehicleMachines.clear;
	_proxyDriver.allVehicleMachines.copy(self.allVehicleMachines);
	self.myTerminal		:= _proxyDriver.myTerminal;
end;
</source>
        <Parameter name="_proxyDriver" type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="01eee314-50e2-4e6b-9aae-2e17f0859c4e">
        <updating/>
        <source>setProxy(	_name,
			_code,
			_secondaryCode		: String;
			_status				: Integer;
			_externalId			: String;					// TFS 46854
			_terminal			: CM_Terminal;
			_allCarriers		: CM_CarrierByCodeDict;
			_allVehicleMachines	: CM_VehicleSet) updating;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 18/10/2019	jlgdap1		TFS 46854 SNO Driver Identity Checking for Cargo Release
vars

begin
	self.name			:= _name;
	self.code			:= _code;
	self.secondaryCode	:= _secondaryCode;
	self.status			:= _status;
	if app.getMyUser.canDo(_terminal, PmAdmDriverExternalIDMaint) then	// TFS 46854
		self.externalID	:= _externalId;									// TFS 46854
	endif;																// TFS 46854
	self.allCarriers.clear;
	_allCarriers.copy(self.allCarriers);
	self.allVehicleMachines.clear;
	_allVehicleMachines.copy(self.allVehicleMachines);
	self.myTerminal		:= _terminal;
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_secondaryCode" type="String"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_externalId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_allCarriers" type="CM_CarrierByCodeDict"/>
        <Parameter name="_allVehicleMachines" type="CM_VehicleSet"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="982518f8-b5a6-4b06-8e9d-f16134e871d7">
        <source>statusString() :String;

vars

begin
	if status = Status_Allowed then
		return Status_Allowed_String;
	elseif status = Status_Suspended then
		return Status_Suspended_String;
	elseif status = Status_Banned then
		return Status_Banned_String;
	else
		return "INVALID";
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="a148064a-9e72-445a-9284-bcbc6feb9c5f">
        <source>validateForCreate();
// 16/12/2014  cnwdb2	PAR 35364
// Changed On	By			Reason
// ----------	--------	----------------------------------------------
// 05/11/2019	jlgdap1		TFS 46854 SHO Driver Identity Checking for Cargo Release
// 17/12/2019	JLGNS1		Bug 48076: SNO - Re: External ID issue
// 05/06/2024	jlizm1		TFS 63908 Allow duplicate driver names
vars
	existingDriver 	: CM_DriverDetails;
	realDriver 		: CM_DriverDetails;	// Bug 48076
	terminal		: CM_Terminal;
	
begin
	if self.name = null then
		app.raiseCMException(Input_required_field_name, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.code = null then
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	endif;
	
	terminal := self.myTerminal;
	
	if terminal = null then
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	realDriver := self.pxyGetRealObject;
	
	if not terminal.getConfig(AllowDupDriverNames).Boolean then
		existingDriver := terminal.allDriversbyName[self.name];
		if existingDriver &lt;&gt; null and existingDriver &lt;&gt; realDriver then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.name, null, null);
		endif;
	endif;
	
	existingDriver := terminal.allDriversByCode[self.code];
	if existingDriver &lt;&gt; null and existingDriver &lt;&gt; realDriver then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	
	// cnwjk3 PAR 21510 16/02/10
	if self.secondaryCode &lt;&gt; null then
		existingDriver := terminal.allDriversBySecondaryCode[self.secondaryCode];
		if existingDriver &lt;&gt; null and existingDriver &lt;&gt; realDriver then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.secondaryCode, null, null);
		endif;
	endif;
	
	// TFS 46854 start
	if self.externalID &lt;&gt; null then
		existingDriver := terminal.allDriversByExternalID[self.externalID];
		if existingDriver &lt;&gt; null and existingDriver &lt;&gt; realDriver then												// Bug 48076
			app.raiseCMException1(External_ID_Already_In_Use, existingDriver.code, null, null);
		endif;
	endif;
	// TFS 46854 end

end;</source>
    </JadeMethod>
