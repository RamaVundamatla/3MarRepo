//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//15/07/2019 	JLGNS1	Bug 45588: PNL - To Do Task Description no Planning / Queueing when To Do Task Terminals setup

vars

begin

//	_theTI.setToDoTaskComplete(app.myRoot.allToDoTaskDescriptions[_toDoCode].description, _passport);
	_theTI.setToDoTaskComplete(_toDoCode, _passport);
	_passport.doPostUpdateAutoPlansFor( _theTI );	//Bug 45588

end;</source>
