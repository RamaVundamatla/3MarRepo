    <JadeMethod name="checkGrouping" id="cf3131b8-2c10-4595-8448-15d1178e2549">
        <source>checkGrouping(_oa : ObjectArray) : Boolean protected;

/*

Purpose:	Cannot mix high and low. Cannot have 2 or more defaults		

Parameters:			

Return Value:		


Date		Who		Reason
21 November 2012	cnwjre1	Initial creation
TFS CR 56446 TASK 56447 15FEB2023 NAVAB1 - re wrote to produce a clearer message and to be able to check the new 5 'highest' groupings
*/

vars
	allCount,
	highCount,
	lowCount,
	defaultLCount, default1Count,default2Count,default3Count,default4Count,default5Count	: Integer;
	total, idx	: Integer;
	lowRow,
	highRow	: Integer;
	type	: Integer;
	inError	: Boolean;
	obj		: Object;
	groupByKey	: CMIF_GroupingByKey;
	mapType		: CM_TranMapInvoiceLineGroupType;
	msg, levels : String;
	defaulLevels : IntegerArray;
begin
	lowRow := 9999;
	highRow := 0;
	create defaulLevels transient;
	foreach obj in _oa do
		groupByKey := obj.CMIF_GroupingByKey;
		mapType := groupByKey.myGroupingType;
		type := mapType.type;
		if type = TranMapInvLineGroupTypeAll then
			allCount := allCount + 1;
		elseif type = TranMapInvLineGroupTypeLow or
		   type = TranMapInvLineGroupTypeLowDef then
			lowCount := lowCount + 1;
		elseif type = TranMapInvLineGroupTypeHigh 
		or type = TranMapInvLineGroupTypeHigh2 
		or type = TranMapInvLineGroupTypeHigh3 
		or type = TranMapInvLineGroupTypeHigh4 
		or type = TranMapInvLineGroupTypeHigh5 
		or type = TranMapInvLineGroupTypeHighDef 
		or type = TranMapInvLineGroupTypeHigh2Df 
		or type = TranMapInvLineGroupTypeHigh3Df 
		or type = TranMapInvLineGroupTypeHigh4Df 
		or type = TranMapInvLineGroupTypeHigh5Df then
			highCount := highCount + 1;
		endif;
		if type = TranMapInvLineGroupTypeLowDef then
			defaultLCount := defaultLCount + 1;
			if defaultLCount &gt; 1 then
				if defaulLevels.indexOf(0) = 0 then
					defaulLevels.add(0);
				endif;
			endif;
		elseif type = TranMapInvLineGroupTypeHighDef then
			default1Count := default1Count + 1;
			if default1Count &gt; 1 then
				if defaulLevels.indexOf(1) = 0 then
					defaulLevels.add(1);
				endif;
			endif;
		elseif type = TranMapInvLineGroupTypeHigh2Df then
			default2Count := default2Count + 1;
			if default2Count &gt; 1 then
				if defaulLevels.indexOf(2) = 0 then
					defaulLevels.add(2);
				endif;
			endif;
		elseif type = TranMapInvLineGroupTypeHigh3Df then
			default3Count := default3Count + 1;
			if default3Count &gt; 1 then
				if defaulLevels.indexOf(3) = 0 then
					defaulLevels.add(3);
				endif;
			endif;
		elseif type = TranMapInvLineGroupTypeHigh4Df then
			default4Count := default4Count + 1;
			if default4Count &gt; 1 then
				if defaulLevels.indexOf(4) = 0 then
					defaulLevels.add(4);
				endif;
			endif;
		elseif type = TranMapInvLineGroupTypeHigh5Df then
			default5Count := default5Count + 1;
			if default5Count &gt; 1 then
				if defaulLevels.indexOf(5) = 0 then
					defaulLevels.add(5);
				endif;
			endif;
		endif;
		if groupByKey.index &gt; highRow then
			highRow := groupByKey.index;
		endif;
		if groupByKey.index &lt; lowRow then
			lowRow := groupByKey.index;
		endif;
	endforeach;
	
	total := _oa.size;
	// just look for mixed types
	if lowCount &lt;&gt; 0 and highCount &lt;&gt; 0 then
		inError := true;
		msg := "Cannot mix low and high groupings";
	// look for too many default entries
	elseif defaulLevels.size &gt; 0 then
		inError := true;
		msg := "Cannot have two or more defaults of same level." &amp; CrLf;
		
		if defaulLevels.size = 1 then
			if defaulLevels[1] = 0 then
				levels := "There are two or more 'lowest' defaults.";
			else
				levels := "Level " &amp; defaulLevels[1].String &amp; " has two or more 'highest' defaults.";
			endif;
		else
			levels := "Levels ";
			foreach idx in 1 to defaulLevels.size do
				if levels = "Levels " then
					levels := levels &amp; defaulLevels[idx].String;
				elseif idx = defaulLevels.size then
					levels := levels &amp; " and " &amp; defaulLevels[idx].String;
				
				else
					levels := levels &amp; ", " &amp; defaulLevels[idx].String;
				endif;
			endforeach;
			levels := levels &amp; " have two or more 'highest' defaults.";
		endif;
		

	endif;
	
	if inError then
		 // ### TFS CR 56446 TASK 56447 13FEB2023 NAVAB1 app.msgBox("Grouping in rows " &amp; lowRow.String &amp; " to " &amp; highRow.String &amp; " must be consistent - optionally All with either Lowest or Highest, and no more than one Default value.", "Invoice Mapping Problem", MsgBox_OK_Only);
		app.msgBox(msg &amp; levels, "Line Grouping Problem", MsgBox_OK_Only);
		return false;
	endif;
	
	return true;
epilog
	delete defaulLevels;
end;</source>
        <access>protected</access>
        <Parameter name="_oa" type="ObjectArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoType_click" id="54a713d2-3405-48f2-9131-b37d7597f13f">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_click(combobox: ComboBox input) updating;
/*
Purpose:	

Date		Who		Reason
07 August 2024	navab1	CR 65331 TASK 65332
*/

vars
	cargotype : CM_CargoType;
	cmbtext : String;
	idx : Integer;
	theTable: Table;
	
	combo, combost, combocomm: CMUI_ComboBox;

begin
	theTable := self.tblLines;
	cmbtext := combobox.text;
	cargotype := combobox.listObject.CM_CargoType;
	idx := combobox.listIndex;
	
	self.doComboCargoTypeBuild(combobox.listObject.CM_CargoType,null, false, combo, combost, combocomm); // ### TFS CR 65331 TASK 65332 07AUG2024 NAVAB1, // ### TFS BUG 66001 19SEP2024 NAVAB1 - clone the combos for each line
	
	theTable.accessCell(self.currentLineRow, 1).itemObject := cargotype;
	theTable.accessCell(self.currentLineRow, 1).text := cmbtext;
	combobox.listIndex := idx;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoType_gotFocus" id="44dcf49b-28b3-43ac-bfeb-3fdb86d6ddc7">
        <controlMethod name="ComboBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_gotFocus(combobox: ComboBox input) updating;
/*
Purpose:	

Date		Who		Reason
07 August 2024	navab1	CR 65331 TASK 65332
*/

vars
	theTable: Table;
begin
	theTable := self.tblLines;
	self.currentLineRow := theTable.row;
	combobox.listObject := theTable.accessCell(self.currentLineRow, 1).itemObject;
	if combobox.listObject = null then
		combobox.listIndex := 1;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoType_lostFocus" id="7b62fd32-5056-479c-b894-b7e832549878">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_lostFocus(combobox: ComboBox input) updating;
/*
Purpose:	

Date		Who		Reason
07 August 2024	navab1	CR 65331 TASK 65332
*/

vars
	theTable: Table;
begin
	theTable := self.tblLines;
	if self.currentLineRow &lt;= theTable.rows then
		theTable.accessCell(self.currentLineRow, 1).text := combobox.text;
		theTable.accessCell(self.currentLineRow, 1).itemObject := combobox.listObject;
	endif;

	if combobox.itemObject = null then
		combobox.listIndex := 1;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
