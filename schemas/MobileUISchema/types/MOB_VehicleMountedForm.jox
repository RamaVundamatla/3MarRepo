    <JadeMethod name="getDescriptionForAction" id="c7e48d96-4f17-45ee-8e37-f2a12caf7c5f">
        <source>getDescriptionForAction(_action: Integer): String protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 June 2010	cnwer1	Initial creation

*/

vars

begin
	if _action = self.ACTION_HELP  then
		return "Shortcut Keys";
	elseif  _action = self.ACTION_FLIP_HORIZONTAL then
		return "Flip Horizontal";
	elseif _action = self.ACTION_FLIP_VERTICAL then
		return "Flip Vertical";
	elseif  _action = self.ACTION_FLIP_LANDSCAPE_PORTRAIT then
		return "Flip between Landscape and Portrait";
	elseif _action = self.ACTION_REFRESH then
		return "Refresh task list";
	elseif _action = self.ACTION_ACCEPT then
		return self.btnAccept.caption &amp; " task";
	elseif _action = self.ACTION_REJECT then
		return "Reject task";
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_action" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDirectorTIs" id="ef234a57-049c-4609-b103-e847b1c7f969">
        <source>getDirectorTIs(_tiSet : ObjectSet input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2010	cnwjk3	Initial creation

*/

vars
	obj			: Object;
	tableRow 	: JadeTableRow;
	row			: Integer;
begin
	if _tiSet = null then
		return;
	endif;
	
	_tiSet.clear();
	
	row := self.tblDirector.fixedRows + 1;
	while row &lt;= self.tblDirector.rows do
		tableRow := self.tblDirector.accessRow(row);
		obj := tableRow.itemObject;
		if obj.isKindOf(CM_TrackedItem) then 
			_tiSet.add(obj);
		endif;
		
		row := row + 1;
	endwhile;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFirstDirectorLocation" id="9777de77-3b4d-4fd0-8f84-46c70200c8e3">
        <source>getFirstDirectorLocation() : CM_LocationsController protected;

/*

Purpose:			
	Get the Location controller for either:
		- the selected TI in the director task table
		- or the first TI in the director task table, if none selected;
Parameters:			

Return Value:		


Date		Who		Reason
18 May 2010	cnwjk3	Initial creation

*/

vars
	row 		: Integer;
	tableRow 	: JadeTableRow;
begin
	if self.tblDirector.rows = self.tblDirector.fixedRows then
		return null;
	endif;
	
	if self.tblDirector.row &gt; self.tblDirector.fixedRows then
		// We have a selected row
		tableRow := self.tblDirector.accessRow(self.tblDirector.row);
	else
		// No rows selected, so get the first row
		tableRow := self.tblDirector.accessRow(self.tblDirector.fixedRows + 1);		
	endif;
	
	//epr par 35664 2/3/15
	if tableRow.itemObject = null then
		return null;
	endif;
	
	return tableRow.itemObject.CM_TrackedItem.myPrimaryActualLocation;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getFirstDirectorTI" id="42c9e976-61d2-4551-8ad1-c2c73cfdd482">
