    <JadeMethod name="validateMe" id="df466078-d2cc-4a97-b39c-b5a98ce9f7b9">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

begin

	if self.shortCode.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Short Code', null, null);
		app.raiseCMException(Input_required_field_shortCode, null, null); // cnwdb2	PAR 35364
	endif;
	if self.helpDescription.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Help Description', null, null);
		app.raiseCMException(Input_required_field_helpDesc, null, null); // cnwdb2	PAR 35364
	endif;
	if self.permissionInteger &lt; 1 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Permisssion Value', null, null);
		app.raiseCMException(Input_required_field_permValue, null, null); // cnwdb2	PAR 35364
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
