    <JadeMethod name="getMenuIUserItemOlderThanDate" id="6c025d5f-87f4-43bf-ba59-8084a217778c">
        <source>getMenuIUserItemOlderThanDate(_allMenuReportsToPurge: DynaDictionary input; _class : Class) protected;
// -------------------------------------------
// Created Aug 2008 by cnwrs1 par17772
// -------------------------------------------
vars
	//menuItem: CM_MenuUserItem;
	menuItem: CM_MenuUserReport;
	theDate: TimeStamp;
	objArray: ObjectArray;
	obj: Object;
begin
	_allMenuReportsToPurge.clear();
	theDate := self.date.TimeStamp.cnEcAddDays(1);

	create objArray transient;
	_class.allInstances(objArray,0,true);
	foreach obj in objArray do
		//menuItem := obj.CM_MenuUserItem;
		menuItem := obj.CM_MenuUserReport;
		
		// PAR 22361 - do not delete reports that are templates
		if menuItem.isReportTemplate then
			continue;
		endif;
		
		if menuItem.createdTime &lt;= theDate then
			_allMenuReportsToPurge.add(menuItem);
		endif;
	endforeach;
epilog
	delete objArray;
end;

</source>
        <access>protected</access>
        <Parameter name="_allMenuReportsToPurge" type="DynaDictionary" usage="input"/>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="getUnknownTrucksOlderThanDate" id="a845d8a8-7d44-4ebc-b657-1371e6081cf7">
        <source>getUnknownTrucksOlderThanDate(_allUnknownTrucksToPurge : DynaDictionary input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2021	navpw1	Initial creation TFS: 51994

*/

vars

	iter			: Iterator;
	startAtVehicle,
	unknownTruck	: CM_Vehicle;
	theDate			: TimeStamp;

begin

	_allUnknownTrucksToPurge.clear();
	theDate := self.date.TimeStamp.cnEcAddDays(1);
	startAtVehicle := null;
	startAtVehicle := self.myTerminal.vehicles.getAtKeyGeq( Unknown_Truck_Prefix, null );
	if startAtVehicle = null or not startAtVehicle.isUnknownVehicle then
		return;
	endif;
	
	iter := self.myTerminal.vehicles.createIterator();
	iter.startAtObject(startAtVehicle);
	while iter.next(unknownTruck) do
		if unknownTruck.createdTime &lt;= theDate and unknownTruck.isUnknownVehicle and unknownTruck.visitRecords.size &gt;= 1 
			and unknownTruck.allRoadJobs.isEmpty 
		then
			_allUnknownTrucksToPurge.add(unknownTruck);
		endif;
	endwhile;

epilog
	
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_allUnknownTrucksToPurge" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getddExtHistoryOldThanDate" id="2bf865be-1d82-4851-8751-d0c3f99b3629">
