    <JadeMethod name="doBtnToolBarDELETE" id="fed1dfa4-0a8c-4c27-b10e-c90e808c0a29">
        <updating/>
        <source>doBtnToolBarDELETE() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------
vars
	theJobId, 
	theCraneID 			: String;
	rightNow 			: TimeStamp;
	isCreate, 
	ls 					: Boolean;
	anArray,
	anArrayForUpdate 	: ObjectArray;
	aSlotController 	: CM_SlotController;
	idx,
	result,
	theReturn 			: Integer;
	aVoyage 			: CM_Voyage;
	theRealVJob 		: CM_VoyageJob;
	theVoyageJS 		: CM_VoyageJobSheet;
	aCrane 				: CM_Machine;
	anObject 			: Object;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	if self.workingMode &lt;&gt; WorkMode_Job then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid working mode (' &amp; self.workingMode.String &amp; ')');
		return;
	endif;
	
	theJobId := self.cmbJob.text.trimBlanks;
	isCreate := false;
	if theJobId = null then
		// the job id may not be in the combo cos it has not been allocated to the crane so go to the point to get the job id
		theRealVJob := self.getTheSelectedJob();
		if theRealVJob &lt;&gt; null then
			theJobId := theRealVJob.jobNum;
		else
			app.msgBox("A Job must be entered/selected","Job Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	theReturn := app.msgBox("Are you sure that you  want to delete job " &amp; theJobId &amp; "?", "Confirm Job Delete", MsgBox_Yes_No);
	if theReturn = MsgBox_Return_No then
		return;
	endif;
	
	if self.cmbCrane.listObject &lt;&gt; null then
		theCraneID := self.cmbCrane.listObject.CM_Crane.id.trimBlanks;
	endif;
	theVoyageJS := self.myCurrentVoyage.allJobSheets[theCraneID];
	if theRealVJob = null then
		theRealVJob :=  self.cmbJob.listObject.CM_VoyageJob; //theVoyageJS.allJobsByJobNum[theJobId];
	endif;

	while true do
		app.myTrxDA.trxDeleteVoyageJob(theRealVJob, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog('Voyage Job', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

		endif;
		return;
	endwhile;

	self.doCmbJobBuild();
	
epilog
	if anArray &lt;&gt; null then
		delete anArray;
	endif;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarDISCHDRAW" id="7af2fa7c-f5d2-4567-9d87-7e6dcf125468">
        <updating/>
        <source>doBtnToolBarDISCHDRAW() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	trxCompletedOK : Boolean;
begin

	if (not self.toolbarClickPreProcessing(VIEW_SEQUENCE)) then
		return;
	endif;

	// DLR, SOB and basic Discharge and Load colour coding allow for the ALT key to be used. 
	// This checks that the same amount of slots have been slected either side of the 'ALT'
	if self.myBayDrawingController.validateCompareSelectedPoints("Discharge","slots") = false then
		return;
	endif;

	if self.displayMode = ShpDisplayMode_ColCodeDisch then
		self.updateSlotRequestAttribute(CM_SlotRequest.Attribute_ColourCode);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid displayMode for method (' &amp; self.displayMode.String &amp; ')');
		return;
	endif;

end;</source>
    </JadeMethod>
