    <JadeMethod name="qryStorage" id="04055968-cef0-4157-9829-577381e33f46">
        <updating/>
        <source>qryStorage(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     04 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	numSelected		: Integer;
	jrwTrans		: CM_JRWBreakBulk;
	breakBulkFilter	: CMQF_WarehouseStorage;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	jrwTrans := self.createJRWTransient(CM_JRWBreakBulk).CM_JRWBreakBulk;
	jrwTrans.allStorageLines.clear();
	if _filter.isKindOf(CMQF_WarehouseStorage) then
		breakBulkFilter := _filter.CMQF_WarehouseStorage;
		breakBulkFilter.filterObjects(jrwTrans.allStorageLines, _passport);
//		breakBulkFilter.allTerminals.copy(jrwTrans.allTerminals);
		jrwTrans.setAllTerminals(breakBulkFilter.allTerminals);
		jrwTrans.myOperator := breakBulkFilter.myOperator;
		jrwTrans.qryStartDate := breakBulkFilter.startDate;
		jrwTrans.qryEndDate := breakBulkFilter.endDate;
		jrwTrans.outwardsTIs := breakBulkFilter.outwardsTIs;
	endif;
	
	numSelected := jrwTrans.allStorageLines.size;

epilog	
	return numSelected;
end;</source>
