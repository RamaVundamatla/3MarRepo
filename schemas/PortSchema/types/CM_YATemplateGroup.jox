    <JadeMethod name="addAllocationsToGroup" id="ff1dcb68-3820-4e05-b7da-9e4a68152ffe">
        <source>addAllocationsToGroup(_realAllocationsSet : CM_YardAllocationSet input);

// Created by cnwdvb1 on 07 August 2006

vars

	templateAllocation,
	realAllocation	: CM_YardAllocation;
	template		: CM_YardAllocationTemplate;
	set				: ObjectSet;
	obj				: Object;

begin

	create set transient;
	// Erase any allocations that already exist with the same code. Have already warned in validation.
	foreach templateAllocation in self.allYardAllocations where not set.includes(templateAllocation) do
		foreach realAllocation in _realAllocationsSet do
			if templateAllocation.code = realAllocation.code then
				set.add(templateAllocation);
			endif;
		endforeach;
	endforeach;
	
	foreach obj in set do
		obj.CM_Object.erase(NORMAL_ERASE);
	endforeach;
	

	// Create new templates.
	foreach realAllocation in _realAllocationsSet do
		create template persistent;
		template.setForCreateTemplate(realAllocation, self);
	endforeach;
	
epilog
	delete set;
end;</source>
        <Parameter name="_realAllocationsSet" type="CM_YardAllocationSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildCurrentAllocations" id="612c6ec7-6ab5-4ecd-9161-70ccf45a08f4">
        <source>buildCurrentAllocations(_yaSet : CM_YardAllocationSet input; _terminal : CM_Terminal);

// Created by cnwdvb1 on 08 August 2006

vars

	ya,			
	yaTemplate	: CM_YardAllocation;
	set			: ObjectSet;
	obj			: Object;

begin

	create set transient;
	// All allocations to be copied.
	foreach yaTemplate in _yaSet do
	
		// Just double check.
		if not self.allYardAllocations.includes(yaTemplate) then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Group does not include allocation', null, null);
			return;
		endif;
		
		// Delete all those that exist in the terminal with the same code. Have already warned during validation.
		foreach ya in _terminal.allYardAllocations discreteLock where not set.includes(ya) do
			if ya.code = yaTemplate.code then
				set.add(ya);
			endif;
		endforeach;
		
		foreach obj in set do
			obj.CM_Object.erase(NORMAL_ERASE);
		endforeach;
		
		set.clear();
		
		// Build new allocation.
		yaTemplate.CM_YardAllocationTemplate.buildCurrentAllocation(_terminal);
	endforeach;
epilog
	delete set;
end;</source>
        <Parameter name="_yaSet" type="CM_YardAllocationSet" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6e085f79-2d6b-4b4d-a2d1-b3a3b8e8fac9">
        <updating/>
        <source>setForCreate(_code : String) updating;

// Created by cnwdvb1 on 07 August 2006
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable

vars

	root	: CM_Root;
	group	: SelfType;	
	theCode	: String; 

begin

	root := app.myRoot;
	
	theCode := _code[1:50];
	
	group := root.allYATemplateGroups[theCode];
	if group &lt;&gt; null and group &lt;&gt; self then
		//app.raiseCMException2(DuplicateItem, 'Group ' &amp; theCode, 'System', null, null); //14.06.2022 navds20 53760
		// Group %1 already exists for System : Group_already_exists_system
		app.raiseCMException1(Group_already_exists_system, theCode, null, null); //14.06.2022 navds20 53760
		return;
	endif;
	
	self.code	:= theCode;
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateAllocationCopy" id="de546147-5d22-4f48-98de-d96b545f8f6f">
        <source>validateAllocationCopy(_isToTerminal : Boolean; _yardAllocation : CM_YardAllocation input; _passport : CM_Passport);

// Created by cnwdvb1 on 08 August 2006
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
vars

	ya		: CM_YardAllocation;
	term	: CM_Terminal;

begin

	term := _passport.myTerminal;
	
	// Validate ids against terminal.
	if _isToTerminal then
		foreach ya in term.allYardAllocations discreteLock do
			if ya.code = _yardAllocation.code then
				//app.raiseCMWarning2(DuplicateItem, ya.code, 'Terminal ' &amp; term.code &amp; '. Press Save To Overwrite', null, null, ya); //14.06.2022 navds20 53760
				// %1 Terminal already exists for %2 . Press Save To Overwrite  : Termi_alrea_exist_press_save_o
				app.raiseCMWarning2(Termi_alrea_exist_press_save_o, ya.code, term.code , null, null, ya); //14.06.2022 navds20 53760
				return;
			endif;
		endforeach;
	else
		// Validate ids against group.
		foreach ya in self.allYardAllocations do
			if ya.code = _yardAllocation.code then
				//app.raiseCMWarning2(DuplicateItem, ya.code, 'Template Group ' &amp; self.code &amp; '. Press Save To Overwrite', null, null, ya); //14.06.2022 navds20 53760
				// %1 Template Group already exists for %2 . Press Save To Overwrite : Templ_group_alrea_exist_press_
				app.raiseCMWarning2(Templ_group_alrea_exist_press_, ya.code, self.code , null, null, ya); //14.06.2022 navds20 53760
				return;
			endif;
		
		/*	if ya.myTerminal = null then
				app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Terminal Reference null', null, null);
				return;
			endif;*/
		endforeach;
	endif;

end;</source>
        <Parameter name="_isToTerminal" type="Boolean"/>
        <Parameter name="_yardAllocation" type="CM_YardAllocation" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
