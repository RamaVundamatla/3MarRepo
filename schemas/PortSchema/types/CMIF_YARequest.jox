    <JadeMethod name="isRailReleaseReq_Match" id="c9d3fdab-d50b-4624-8e3c-493c30631358">
        <source>isRailReleaseReq_Match(_yaData: CM_YADataObjects): Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	br 			: CM_BulkRelease;
	terminal	: CM_Terminal;
begin

	// Return regardless.
	if self.bulkReleaseCode = null then
		return true;
	endif;
	terminal := app.getMyTerminalDO_NOT_USE;
	if terminal = null then
		return true;
	endif;
	
	br := terminal.allBulkReleasesByCodeDate.getAtKeyGeq(self.bulkReleaseCode, null);
	
	if br = null or br.code &lt;&gt; self.bulkReleaseCode then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(br);


end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
