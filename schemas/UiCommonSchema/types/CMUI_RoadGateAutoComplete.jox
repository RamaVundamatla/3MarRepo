    <JadeMethod name="populateDataTable" id="5d47421c-3440-4625-92ea-c9bd7d844be9">
        <updating/>
        <source>populateDataTable() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move
12 Jun 2024	jlier1  TFS 64018  

*/
vars
	str		: String;
	savedRow,
	row		: Integer;
	roadGateCriteria : CM_RoadGateAutoComplete;
begin

	if self.tblData.rows &gt; 1 then
		savedRow := self.tblData.row;
	endif;
	self.tblData.rows:= self.tblData.fixedRows;

	foreach roadGateCriteria in self.myTerminal.allRoadGateAutoCompleteCrit where roadGateCriteria.isRelease = self.optRelease.value do
		self.doQueryAddItem(roadGateCriteria);
	endforeach;
	
	// restore the current row
	if savedRow &gt; 0 and savedRow &lt;= self.tblData.rows then
		self.tblData.row := savedRow;
	else
		if self.tblData.rows &gt; 1 then
			self.tblData.row := 2;	// first data row
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
