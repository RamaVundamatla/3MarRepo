<Class name="CMQF_Export" id="fef9cb23-f3ac-4a2c-8308-a3d2f0eb08fb">
    <superclass name="CMQF_TrackedItem"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="f25bf072-108b-4dbc-818a-812dceaaca33">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ta			: CM_TerminalArea;
	ti			: CM_TrackedItem;
	lc			: CM_LocationsController;
	terminal	: CM_Terminal;
	breakOut	: Boolean;
begin

	ta := self.getMyTerminalArea;

	if ta &lt;&gt; null then
		foreach lc in ta.allLocationsControllers discreteLock do :locLoop
			foreach ti in lc.allTrackedItems discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if self.includesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
						//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
						self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
					endif;
				endif;
				
//				if breakOut then
//					break locLoop;
//				endif;
			endforeach;
		endforeach;
		return;
	endif;
	
	foreach terminal in self.allTerminals do : terminalLoop
		//need to scan onsite, onship, notified as default when no ta specified
		
		//search onsite ti's
		//TI_STATE_NORMAL
		foreach ti in terminal.allOnsiteTIsByIdCargoType discreteLock do		
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
					self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
				endif;
				
//				if breakOut then
//					break terminalLoop;
//				endif;
			endif;
		endforeach;
		
		//search notified ti's
		//TI_STATE_NOTIFIED
		foreach ti in terminal.allNotifiedTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
					self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
				endif;
			endif;
//			if breakOut then
//				break terminalLoop;
//			endif;
		endforeach;
		
		//search onship ti's for selected voyage
		//TI_STATE_ONSHIP
		if self.getMyVoyage &lt;&gt; null then
			foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if self.includesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
						//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
						self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
					endif;
				endif;
				
//				if breakOut then
//					break terminalLoop;
//				endif;
			endforeach;
		endif;
	endforeach;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="d9fc520c-cd00-4705-afee-07abeeab7dae">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars

begin

	if (not CM_Log.hasInstance(_ti)) and
	_ti.myParent = null and
	//(_ti.isExport or _ti.isARework or _ti.isTranshipOutbound) and		//- cnwmd1 Par 25572
	(_ti.isExport or _ti.isARework or (_ti.isTranshipItem and (self.getMyVoyage = null or _ti.myExportVoyage = self.getMyVoyage))) and //+ cnwmd1 Par 25572
   	inheritMethod(_ti, _passport, _breakOut) then 
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
