    <JadeMethod name="doViewCopy" id="19bc758b-c9ff-4e2d-98dc-5fe7bc87beac">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CM_TerminalAreaViews::copyView"/>
        </interfaceImplements>
        <source>doViewCopy(_taViewToCopy : CM_TerminalAreaView; _newName : String; _user : CM_User);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwer1	Initial creation

*/

vars
	realTAView : CM_TerminalAreaView;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxCopyTerminalAreaView(_taViewToCopy,realTAView,_newName,_user,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.IF_CM_TerminalAreaViews.editView(realTAView);
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog

end;</source>
        <Parameter name="_taViewToCopy" type="CM_TerminalAreaView"/>
        <Parameter name="_newName" type="String"/>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
