    <JadeMethod name="doComboTASelect" id="57c0110c-e8a8-4b0c-b927-e03a23bf03ed">
        <updating/>
        <source>doComboTASelect() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2011	cnwer1	Initial creation

*/

vars
	ta : CM_TerminalArea;
	onlyLC : CM_LocationsController;
begin
	ta := self.cmbTA.listObject.CM_TerminalArea;
	if ta &lt;&gt; null then
		self.myAssistant.comboBoxLocationControllers(self.cmbLoc, ta.getLCsCollectionForDisplay(), false);	
		//epr par 26495 27/1/2011
		if ta.isKindOf(CM_BlockStack) then	
			onlyLC:=ta.CM_BlockStack.myLocationsController;
		elseif ta.isKindOf(CM_GridArea) and ta.CM_GridArea.allGridControllersByName.size = 1 then
			onlyLC:=ta.CM_GridArea.allGridControllersByName.first;
		endif;
		
		if onlyLC &lt;&gt; null and self.cmbLoc.findObject(onlyLC) &lt;&gt; -1 then
			self.cmbLoc.listObject := onlyLC;
		endif;	
		// 23099 director tasks from gridded areas
		if self.cmbLoc.enabled then
			self.cmbLoc.lostFocus(cmbLoc);
		else
			self.txtLoc.text := ta.id;
			self.txtLoc.userObject := ta.allLocationsControllers.first;
		endif;
		
		self.checkMoveMethodChanged(ta);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="2207371f-76a1-4409-8c76-799fed6eea33">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 February 2009	cnwer1	Initial creation
22 Jan 2020 jlgka1	TFS 47394: Web Apps - To be able to switch error message for twin lift and tandem lift as we use only one error code for both. 
*/

vars
	twinLoc	: String;
	ta 		: CM_TerminalArea;
	locationController,
	twinController : CM_LocationsController;
	foundHeight : Integer;
	errorMsg		: String;
	firstLC,
	secondLC 		: CM_LocationsController;
	direction : Integer;
begin
	/*
		validate the twin free text is a valid location 
		and that it is a capable to twin with the other loc	
	*/
	
	
	
	locationController:=self.txtLoc.userObject.CM_LocationsController;
	if locationController = null then
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, 'Location'), 'Location', MsgBox_OK_Only + MsgBox_Information_Icon);
		app.msgBox(app.getErrorString(Input_required_field_location), 'Location', MsgBox_OK_Only + MsgBox_Information_Icon); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.txtTwinLoc.visible then
		twinLoc:=self.txtTwinLoc.text;
		if twinLoc = null then
		//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, 'Twin location'), 'Twin location', MsgBox_OK_Only + MsgBox_Information_Icon);
			app.msgBox(app.getErrorString(Input_required_field_twinLocn), 'Twin location', MsgBox_OK_Only + MsgBox_Information_Icon); // cnwdb2	PAR 35364
			return;
		endif;
		
		self.myTerminal.findLocationFromString( twinLoc, false, twinController, foundHeight);
		
		if twinController = null then
			app.msgBox(app.getErrorString1(Err_InvalidLocation, twinLoc), 'Twin Location', MsgBox_OK_Only + MsgBox_Information_Icon);
			return;
		endif;
		
		if twinController.myTerminalArea &lt;&gt; locationController.myTerminalArea then
		
		
		endif;
		
		if locationController.isKindOf(CM_GridController) then
		
		endif;
		
		if self.isTandemLift and  twinController &lt;&gt; locationController then
		//tandem lifting and selected two different pads to set down.
			app.msgBox(app.getErrorString(Tandem_lifting_setdown),"Tandem lift", MsgBox_OK_Only + MsgBox_Information_Icon);
			return;
		elseif not self.isTandemLift and not locationController.canTwinLiftWithLocation(twinController,self.myTrackedItem,self.myTwinTI,QUEUE_MODE,direction,errorMsg) then
				app.msgBox(app.getErrorString4(Twin_lift_locations, "Twin", locationController.getFullId, twinController.getFullId, errorMsg), "Twin lift", MsgBox_OK_Only + MsgBox_Information_Icon); //jlgka1 TFS 47394
			return;
			
		else
			self.txtTwinLoc.userObject:=twinController;
		
		endif;
	endif;

	if self.frmMoveMethod.visible and (self.cmbMoveMethod.listCount &gt; 0 and self.cmbMoveMethod.listIndex &lt; 0) then
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, 'Move Method Rule'), 'Move Method Rule', MsgBox_OK_Only + MsgBox_Information_Icon);
		app.msgBox(app.getErrorString(Input_required_field_mvMethRle), 'Move Method Rule', MsgBox_OK_Only + MsgBox_Information_Icon); // cnwdb2	PAR 35364
		return;
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
