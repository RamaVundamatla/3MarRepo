    <JadeMethod name="doResync" id="a36fa7a7-6c1f-4e6a-ad7c-2ee8350d12eb">
        <source>doResync();
/*
Purpose:			

Date		Who		Reason
02JUN2021	NAVAB1	TFS 51219
*/


vars
	shipTrans	: CM_TITransaction;
	tiTrans		: CM_TITransaction;
	ti		: CM_TrackedItem;
	controller : CMIF_TiTransactionResync;
	completedDate	: TimeStamp;
	theReturn : Integer;
	table : Table;
	anObject : Object;
	invoice	: CM_Invoice;
	event : CMEVT_LocationActivity;
	bank : CM_Bank;
begin
	app.mousePointer := MousePointer_HourGlass; 
  	

	create controller transient;

	table := self.tblLocActivity;
	if table.row &gt; table.fixedRows then
		anObject := table.accessRow(table.row).itemObject;
		if anObject.isKindOf(CMEVT_LocationActivity) then
			event := anObject.CMEVT_LocationActivity;
			controller.allTransactions.add(event);
		endif;
	endif;	
	
	
	if controller.allTransactions.size &gt; 0 then
		while true do
			app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
			if app.myPassport.trxCompletedOK then
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Inventory Event Resync", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
		endwhile;
	endif;
epilog
	delete controller;

	app.mousePointer := MousePointer_Default;  
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="6b340dee-d9e7-4859-be50-fed926a0b21b">
        <updating/>
        <source>doSearch() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	self.setFilterValues();
	
	if self.filterDateFrom = null
	and self.filterDateTo = null
	and self.filterTerminalArea = null
	and self.filterVoyage = null
	and self.filterVehicleVisitRecord = null
	and self.filterTrain = null
	then
		app.msgBox(app.getErrorString(Please_enter_date_or_type), app.getErrorString(Search), 0);
		return;
	endif;

	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	self.modalDialogShow(null, app.getErrorString(Cancel), null, null, app.getErrorString(SearchingForData), null);
	
	self.numItemsShown		:= 0;
	self.numItemsSearched	:= 0;
	self.allLocActivityByDate.clear();
	self.allLocationActivitySet.clear();
	self.searchCancelled := false;
	
	self.filterMoveDirections  := self.valueMoveDirections;  // ### TFS 51515 13JUL2021 NAVAB1
		
	self.doLocationActivitySearch();
	
	if not self.doMaxTableSizeCheck(self.numItemsShown, null) then
		return;
	endif;
	self.populateLocActivityTable();

	
	self.showNumRowsShown();
	

	
epilog

	self.frmModalDialog.visible := false;
	app.mousePointer := MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="4e0cfa45-3ca2-4f03-8970-2834eea99530">
        <updating/>
        <source>doSystemNotification(_eventType: Integer; _object:Object; _eventTag: Integer) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	invalidObject : Boolean;
	locActivity : CMEVT_LocationActivity;
	edition : Integer;
	rowIndex : Integer;
	columnIndex : Integer;
	rowString : String;

begin

	on Exception do app.handleDeletedObject (exception, _object, invalidObject);
	
	if _object &lt;&gt; null and _object.isKindOf( CMEVT_LocationActivity ) and _eventType = Object_Update_Event then
		edition := _object.edition;
		if invalidObject then
			return;
		endif;
		locActivity := _object.CMEVT_LocationActivity;
	else
		return;
	endif;
	
	if locActivity &lt;&gt; null then 
		if self.allLocationActivitySet.includes( locActivity ) then
			self.tblLocActivity.findObjectInRow( locActivity, rowIndex );
			if rowIndex &gt; 1 then
			
				rowString := locActivity.getAttributeStringForDefArray( self.tblLocActivity.allTblDataEntRows );
				self.tblLocActivity.setCellText( rowIndex, 1, rowString );
				
				/* // ### TFS 51515 13JUL2021 NAVAB1
				self.tblLocActivity.accessRow(rowIndex).backColor := locActivity.getDisplayColour( self.colorRow1 );
			
				if locActivity.getHasBeenEdited then
					columnIndex := self.tblLocActivity.getColumnByRowName(ETRow_HasBeenEdited);
					if columnIndex &gt; 0 then
						self.tblLocActivity.accessCell( rowIndex, columnIndex ).foreColor := Red;
					endif;
				endif;
				if locActivity.isLocationBalance and locActivity.needsRecalculation then
					columnIndex := self.tblLocActivity.getColumnByRowName(ETRow_NeedsRecalculation);
					if columnIndex &gt; 0 then
						self.tblLocActivity.accessCell( rowIndex, columnIndex ).foreColor := Red;
					endif;
				endif;	
				*/
				
				self.tblLocActivity.accessRow(rowIndex).backColor := locActivity.getDisplayColour( null );
		
				if locActivity.isLocationBalance
				and locActivity.needsRecalculation then  // ### TFS 51515 13JUL2021 NAVAB1
					self.tblLocActivity.accessRow(rowIndex).foreColor := Red;// ### TFS 51515 13JUL2021 NAVAB1
				endif;

			endif;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="enableButtons" id="322b0dae-3e91-49ef-ad96-0524ca764e59">
        <source>enableButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	obj : Object;
	locActivity : CMEVT_LocationActivity;
	edition : Integer;
	invalid : Boolean;
	rowIndex : Integer;
begin

	//print
	self.btnPrint.enabled := self.tblLocActivity.rows &gt; self.tblLocActivity.fixedRows; 
	
	//extract
	self.btnCSV.enabled := self.tblLocActivity.rows &gt; self.tblLocActivity.fixedRows;
	

	//refresh
	self.btnRefresh.enabled := not self.allLocActivityByDate.isEmpty;
	
	//edit
	self.btnEdit.enabled := false;
	
	on Exception do app.handleDeletedObject( exception, obj, invalid );

	rowIndex := self.tblLocActivity.row;
	if rowIndex &lt;= self.tblLocActivity.rows then
		if self.tblLocActivity.accessRow( rowIndex ).selected then
			obj := self.tblLocActivity.accessRow( rowIndex ).itemObject;
			if obj &lt;&gt; null then
				edition := obj.edition;
				if not invalid then
					locActivity := obj.CMEVT_LocationActivity;
					if locActivity.isAbleToBeEdited then
						self.btnEdit.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
					endif;
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
