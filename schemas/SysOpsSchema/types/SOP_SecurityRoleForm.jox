    <JadeMethod name="sysNotify" id="45f26df2-e250-4ea2-bacf-9a66564f7f68">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

vars
	idx	: Integer;
begin

	inheritMethod(eventType, theObject, eventTag);
	
	if theObject &lt;&gt; null and theObject.isKindOf(CM_SecurityRole) then
		if eventType = Object_Update_Event then
			idx := self.cmbParentRole.findObject(theObject);
			if idx &gt; 0 then
				self.cmbParentRole.itemText[idx] := self.lstDataDisplayRow(theObject.CM_SecurityRole);
			endif;
		endif;
	endif;

end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblMaintRoles_mouseDown" id="01c9b81d-b6d0-4134-85dc-2ab2211b7981">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMaintRoles_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2018	jlgndl1	Initial creation	TFS 36947

*/

vars

	column : Integer;
	row : Integer;
	selected : String;
	selectedRole : CM_SecurityRole;
	rowIndex : Integer;
	secRole : CM_SecurityRole;

begin

	column := self.tblMaintRoles.column;
	
	if self.mode = Mode_View then
		if column = self.SelectColumn then
			//Don't let them change the value unless they are in maintenance mode
			row := self.tblMaintRoles.row;
			selected := self.tblMaintRoles.accessCell( row, column ).text;
			if selected = 1.String then
				selected := 0.String;
			else
				selected := 1.String;
			endif;
			self.tblMaintRoles.accessCell( row, column ).text := selected;
		endif;
		
	else
		if column = self.SelectColumn then
			//Reset all my children to match this one
			row := self.tblMaintRoles.row;
			selected := self.tblMaintRoles.accessCell( row, column ).text;
			selectedRole := self.tblMaintRoles.accessRow( row ).itemObject.CM_SecurityRole;
			if not selectedRole.allChildRoles.isEmpty then
				foreach rowIndex in 1 to self.tblMaintRoles.rows do
					secRole := self.tblMaintRoles.accessRow( rowIndex ).itemObject.CM_SecurityRole;
					if secRole &lt;&gt; selectedRole and secRole.isChildOf( selectedRole ) then
						self.tblMaintRoles.accessCell( rowIndex, column ).text := selected;
					endif;
				endforeach;
			endif;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblMaintRoles_mouseUp" id="544a23cf-4716-434a-8f04-2749d63bf13f">
        <controlMethod name="CM_DataTable::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMaintRoles_mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2018	jlgndl1	Initial creation	TFS 36947

*/

vars

	row : Integer;
	column : Integer;
	obj : Object;
	str : String;
	isPlusMinusRow : Boolean;
	plusMinusText : String;
	isPlus : Boolean;
	rowIndex : Integer;
	rowObject : CM_SecurityRole;

begin

	row := self.tblMaintRoles.row;
	column := self.tblMaintRoles.column;

	if row &lt;= self.tblMaintRoles.fixedRows or row &gt; self.tblMaintRoles.rows then
		return;
	endif;
	
	if self.mode = Mode_View then
		if column = self.SelectColumn then
			return;
		endif;
	endif;
	
	obj := self.tblMaintRoles.accessRow(row).itemObject;
	if obj = null then
		return;
	endif;
	
	isPlusMinusRow := column = self.ExpandColumn;
	
	if not isPlusMinusRow then
		return;
	endif;
	
	plusMinusText := self.tblMaintRoles.getCellText(row,column).trimBlanks;
	
	if plusMinusText = null then
		return;
	endif;
	
	isPlus := plusMinusText = "+";
	
	if isPlus then
		self.tblMaintRoles.setCellText(row,column,"-");
		foreach rowIndex in row + 1 to self.tblMaintRoles.rows do
			rowObject :=  self.tblMaintRoles.accessRow(rowIndex).itemObject.CM_SecurityRole;
			if rowObject.myParentRole = obj.CM_SecurityRole then
				self.tblMaintRoles.accessRow(rowIndex).visible := true;
			endif;
		endforeach;
	else
		self.tblMaintRoles.setCellText(row,self.ExpandColumn,"+");
		foreach rowIndex in row + 1 to self.tblMaintRoles.rows do
			rowObject :=  self.tblMaintRoles.accessRow(rowIndex).itemObject.CM_SecurityRole;
			if rowObject.isChildOf( obj.CM_SecurityRole ) then
				self.tblMaintRoles.accessRow(rowIndex).visible := false;
				if not rowObject.allChildRoles.isEmpty then
					self.tblMaintRoles.setCellText(rowIndex,self.ExpandColumn,"+");
				endif;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblPermUsers_contextMenu" id="4ecdec16-56ad-4c89-849a-037fe363658b">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPermUsers_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

vars
	xLeft 	: Real;
	yTop	: Real;

begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.popupMenu(self.mnuUsers, xLeft.Integer, yTop.Integer);

	return false;
	
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblPermUsers_dblClick" id="a57bd5ba-c482-4b50-9d81-23c5d8d78688">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPermUsers_dblClick(table: Table input) updating;

vars
	theRow	: Integer;

begin

	theRow := table.row;
	
	if theRow &lt;= 0 then
		return;
	endif;
	
	if theRow = 1 then
		if self.mode = self.Mode_View then
			self.tblPermUsers.resortTableByColumn(table.column);
		endif;
	else
		self.doUserEdit( table );
	endif;

end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblPermissions_click" id="e70ccf6f-6e3c-44a8-b4a9-294c02171019">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPermissions_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	permObj : CM_PermissionObject;
 
begin

	if table = null or table.column &lt;&gt; 1 or table.row &lt; 2 or table.row &gt; table.rows then
		return;
	endif;
	permObj := table.itemObject.CM_PermissionObject;
	if permObj &lt;&gt; null then
		permObj.permValue := (table.text = "1");
		//  setFormChanged(true, bNew, bUpdate, bDelete, bCancel, cmbKey);
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblPermissions_dblClick" id="5423dda2-e8d0-445b-839e-24235584bd8c">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPermissions_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2018	jlger1	Initial creation

*/

vars

begin
	if table.row &gt; 1 and table.column = 4 then
		
			app.copyStringToClipboard(table.accessCell(table.row,table.column).text);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7b02d266-5d2f-4a9a-b8fd-29abc5b3625a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 November 2022 09:36:25.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007062, locale);
	btnAllowAll.translateBubbleHelp(Xlat_0007063, locale);
	btnAllowAll.translateCaption(Xlat_0007064, locale);
	btnDisallowAll.translateBubbleHelp(Xlat_0007065, locale);
	btnDisallowAll.translateCaption(Xlat_0007066, locale);
	btnResetFilter.translateBubbleHelp(Xlat_0022218, locale);
	btnResetFilter.translateCaption(Xlat_0022219, locale);
	btnRootReset.translateBubbleHelp(Xlat_0003917, locale);
	btnRootReset.translateCaption(Xlat_0003918, locale);
	btnSelectAll.translateCaption(Xlat_0003919, locale);
	btnShowFilter.translateCaption(Xlat_0022220, locale);
	btnUnselectAll.translateCaption(Xlat_0003940, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0007067, locale);
	mnuUsers.translateCaption(Xlat_0007068, locale);
