    <JadeMethod name="btnPackedTemp_click" id="a104a7ca-f02d-4525-b1e9-09c3ae894197">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPackedTemp_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation

*/

vars

begin

	return; //deliberately knobbled in STW environment.
	//STW only use director tasks.  Once cargo is associated with a dir task and it is actioned it becomes a std 
	// move / pack, and has no knowledge that it was a director task.
	// If the move / pack is 'undone' then the wle is turned into a real nove waiting to happen.
	// When presenting jobs in these forms, real wle/cargo items are presented first, if there are sufficient real
	// ones to meet the requests, no other prospects are shown. 
	// This can lead to no presenting all available matching cargo options.
	// Undo processes for STW will need to be done by the main office, so that th elists remain fully available.
	self.doUnPack( btn.userObject );

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkFullyLoaded" id="93286b97-5841-4f61-a2c5-3ef22ba86369">
        <updating/>
        <source>checkFullyLoaded():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2018	jlgndl1	Initial creation	TFS 38083

*/

vars


	vehicle : CM_Vehicle;
	roadJob : CM_RoadJob;
	wle : CM_WorkListEntry;
	incompleteWleSet : CM_WLESet;
	msg : String;
	bulkRel : CM_BulkRelease;
	childResDet : CM_ReserveDetail;
	complete : Boolean;

begin

	//12 Nov 2018	NDL	TFS 38083
	bulkRel := self.myMobileGenericAgent.myBulkRelease;
	if bulkRel &lt;&gt; null and bulkRel.isPackingType then
		// Packing request
		//warning if bulk rel has single container on single parent and not all items packed.
		complete := true;
		foreach childResDet in bulkRel.allReservePackingChildren do
			if not childResDet.isFullyPacked() then
				complete := false;
				break;
			endif;
		endforeach;
		if complete then
			if not self.myPackContainer.hasTransactionOfType(TRANS_TYPE_PackComplete) then
				if self.msgBox(app.getErrorString(Items_packe_would_like_pack_co), app.getErrorString(Pack_Complete), MsgBox_Yes_No, false) = MsgBox_Return_Yes then
					self.handleBtnOne;
					return false;
				endif;
			endif;
		endif;
	endif;

	if self.myMobileGenericAgent.myTruck &lt;&gt; null then
		vehicle := self.myMobileGenericAgent.myTruck;

		roadJob := vehicle.allRoadJobs.first.CM_RoadJob;
		create incompleteWleSet transient;
		foreach wle in roadJob.workListEntries do
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
			if wle.isReceipt then
				continue;
			endif;
			if wle.myTrackedItem &lt;&gt; null then
				continue;
			endif;
			incompleteWleSet.add( wle );
		endforeach;
		
		if incompleteWleSet.isEmpty then
			msg := app.getErrorString(Jobs_this_truck_compl_want_com);
			if self.msgBox( msg,  app.getErrorString(Complete) &amp; "?", MsgBox_Yes_No, false ) = MsgBox_Return_Yes then
				self.handleBtnOne;
				return false;
			endif;
		endif;
	
	endif;

	return true;

epilog

	delete incompleteWleSet;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clickInYardItem" id="9b6a2397-99c8-471e-bd2b-e5e457525552">
        <updating/>
        <source>clickInYardItem( obj : Object ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	ti : CM_TrackedItem;
	bulkRelease : CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	reason : String;
	
//	hasActions : Boolean;
//	resDetailSet : CM_ReserveDetailSet;
//	bookingItemSet : CM_BookingRefItemSet;
//	opt1Str : String;
//	opt2Str : String;
//	opt3Str : String;
//	opt4Str : String;
//	returnValue : Integer;
//	doActions : Boolean;
//	doPack : Boolean;
//	doChecks : Boolean;

begin

	app.myMobileAgent.setMyProxy(null);
	bulkRelease := self.myMobileGenericAgent.myBulkRelease;	//01 Sep 2014	Par 34717 / CCMS 2384
	reserveDetail := self.myMobileGenericAgent.myReserveSelection;	//11 Dec 2015	NDL	Par 37288

	if obj = null then
		// searching for one
		self.myMobileGenericAgent.setMyNextTiToAction(null);
		self.myMobileGenericAgent.setMyDeliveryRequest(null);
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);
		app.myMobileCargoFindAgent.setHidePackItems(true);
		app.myMobileCargoFindAgent.setHideOnTransportTIs(true);			// TFS 38111 13/04/2018 jlgmd1
		if self.txtCargoId.text &lt;&gt; null 								// 36111
		and self.txtCargoId.text &lt;&gt; lblCargoId.caption.toUpper then     //cnwmc5 - 8 Dec 2015 - PAR 37230
			app.myMobileCargoFindAgent.setID(self.txtCargoId.text);
			app.myMobileCargoFindAgent.setDoSearchImmediate(true);
		else
			//16 Jul 2014	NDL	Par 34571
			if self.myPackContainer.myVoyage.isNullVoyage then
				app.myMobileCargoFindAgent.setMyVoyage(null);
			else
				app.myMobileCargoFindAgent.setMyVoyage( self.myPackContainer.myVoyage );
			endif;
		endif;
		//app.myMobileCargoFindAgent.setMyBookingRef( self.myPackContainer.bookingReference );
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	elseif CM_TrackedItem.hasInstance( obj ) then
		ti := obj.CM_TrackedItem;
		
		//22 Jul 2016	NDL	TFS 2403
		if self.txtCargoId.text &lt;&gt; lblCargoId.caption.toUpper
		and self.txtCargoId.text.trimBlanks &lt;&gt; null
		and ti.id[1:self.txtCargoId.text.length] &lt;&gt; self.txtCargoId.text
		then
			//we were probably doing a find, didn't find a matching id in the list
			//and have automatically pressed the first button, which would happen
			//if the scanner was contfigured to tab/return automatically.
			reason := app.getErrorString(Item_selec_does_not_match_text);
			if app.msgBox( reason, app.getErrorString(Warning), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
				self.txtCargoId.setFocus();
				return;
			endif;
			reason := null;
		endif; 
		
		//01 Sep 2014	Par 34717 / CCMS 2384
		if bulkRelease &lt;&gt; null then
		//	if self.myHandHeldCheckerAgent.getReserveDetailCargoMatches( ti, 1, reason ) = null then
			if reserveDetail = null then	//11 Dec 2015	NDL	Par 37288
				if ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti then	//23 Jan 2019	NDL	TFS 42927
					//just test the minimum amount because we get to choose how much later during packing
					if self.myMobileGenericAgent.getReserveDetailCargoMatches( ti, 1, 1, reason ) = null then
						self.msgBox( reason, app.getErrorString(Error), MsgBox_OK_Only, true );
						return;
					endif;
				else
					if self.myMobileGenericAgent.getReserveDetailCargoMatches( ti, ti.totalQuantity.max(1), ti.totalWeight, reason ) = null then	//10 Nov 2015	NDL	Par 37092
						self.msgBox( reason, app.getErrorString(Error), MsgBox_OK_Only, true );
						return;
					endif;
				endif;
			endif;
		endif;
		
		if not self.validatePreCargoChecks( ti ) then
			return;
		endif;
		
		//05 Jan 2016	NDL	TFS 3157
	//	create resDetailSet transient;
	//	create bookingItemSet transient;
	//	if ti.hasDocumentActions( resDetailSet, bookingItemSet ) then
	//		hasActions := true;
	//	endif;
		
		
	//	if not hasActions then	//05 Jan 2016	NDL	TFS 3157
		
			self.myMobileGenericAgent.setMyNextTiToAction(ti);
		
			//if self.myTerminal.allCargoChecks[CARGO_CHECK_CONTEXT_PACK].allCargoCheckItems.size = 0 then
			if self.myTerminal.hasNoCargoCheckItemsFor(CARGO_CHECK_CONTEXT_PACK) then	//31 May 2012	NDL Par 29038
				self.goBackToFirst( MOB_HHPackContainerFormSTW );
				return;
			else
				self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.PackCargo);
				self.gotoForm(MOB_HHGateCheckCargo, false);
				return;
			endif;
		
	/*	else
		
			//05 Jan 2016	NDL	TFS 3157
			doActions := false;
			doPack := false;
			doChecks := false;
		
			opt1Str := app.getErrorString( Pack );
			opt2Str := app.getErrorString( Perform_document_actions );
			opt3Str := app.getErrorString( Perform_cargo_checks );
			opt4Str := app.getErrorString(None_above_cancel);
			if self.myTerminal.hasNoCargoCheckItemsFor(CARGO_CHECK_CONTEXT_PACK) then 
				returnValue := self.optBox(opt1Str, opt2Str, opt3Str, opt4Str, 3, app.getErrorString(Select_option) );
				if returnValue = 1 then
					doPack := true;
				elseif returnValue = 2 then
					doActions := true;
				elseif returnValue = 3 then
					doChecks := true;
				else
					//bail
					return;
				endif;
			else
				returnValue := self.optBox(opt1Str, opt2Str, opt4Str, null, 2, app.getErrorString(Select_option) );
				if returnValue = 1 then
					doPack := true;
				elseif returnValue = 2 then
					doActions := true;
				else
					//bail
					return;
				endif;
			endif;
		
			if doActions then
				self.myMobileGenericAgent.setAllReserveDetails( resDetailSet );
				self.myMobileGenericAgent.setAllBookingRefItems( bookingItemSet );
				self.myMobileGenericAgent.setStringField1( self.fldCargo.topSheet.name );
				self.myMobileGenericAgent.setMyNextTiToAction( ti );
				self.gotoForm( MOB_HHDocumentActions, false );
				
			elseif doPack then
				self.myMobileGenericAgent.setMyNextTiToAction(ti);
				self.goBackToFirst( MOB_HHPackContainerForm );
				return;
				
			elseif doChecks then
				self.myMobileGenericAgent.setMyNextTiToAction(ti);
				self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.PackCargo);
				self.gotoForm(MOB_HHGateCheckCargo, false);
				return;
				
			endif;
			
		endif; */
		
	
	endif;

epilog

//	delete resDetailSet;
//	delete bookingItemSet;

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doFindCargoButton" id="daa8d380-f245-4ee1-937a-94514a9f78e3">
        <updating/>
        <source>doFindCargoButton() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	str : String;
//	booking : CM_BookingRef;
//	bookingItem : CM_BookingRefItem;
	ti : CM_TrackedItem;
	theTI : CM_TrackedItem;
	buttonNumber : Integer;
	menuButton : MOB_Button;
	value : Real;
//	bulkRelease : CM_BulkRelease;
//	yardLocation : CM_LocationsController;
	obj : Object;

begin

	str := self.txtCargoId.text.trimBlanks.toUpper;
	if str = null then
		return;
	endif;
	
	if str = self.lblCargoId.caption.trimBlanks.toUpper then
		return;
	endif;
	
	
	//22 Dec 2015	NDL	Par 37349
	if self.toPackSize &gt; 0 then
		foreach buttonNumber in 1 to  self.toPackSize do
			menuButton := self.btnInYardTemp.getControl(buttonNumber);
			if menuButton = null then
				continue;
			endif;
			obj := menuButton.userObject;
			if obj = null or not obj.isKindOf(CM_TrackedItem) then
				value := value + menuButton.height;
				continue;
			endif;
			ti :=  obj.CM_TrackedItem;
			if ti.id = str then
				theTI := ti;
				break;
			endif;
		endforeach;
	endif;
	
	if theTI &lt;&gt; null then
		self.scrToPack.value := value.Integer;
		menuButton := self.btnInYardTemp.getControl(buttonNumber);
		self.setMenuScrollStart( self.scrToPack, self.btnInYardTemp, self.frmToPack, toPackSize );
		menuButton.setFocus();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPack" id="5ef31864-dd16-4b68-a2f4-2f8248cf9872">
        <updating/>
        <source>doPack( _ti : CM_TrackedItem input ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars
	
	hideMoveConfirmation:Boolean;
	
begin
	if _ti = null then
		return;
	endif;
	
	//epr par 34472 3/7/14
	hideMoveConfirmation := app.myPassport.myTerminal.getConfig(HhMoveConfirmation).Boolean;	//15 Dec 2015	NDL	Par 37288
	 self.myMobileGenericAgent.doPackCargo(self.myPackContainer,_ti,hideMoveConfirmation);
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPackAll" id="f8636507-8df3-414d-a82e-1930ce49e849">
        <updating/>
        <source>doPackAll() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2014	cnwndl1	Initial creation	Par 35146

*/

vars

	buttonNumber : Integer;
	menuButton : MOB_Button;
	ti : CM_TrackedItem;
	complete : Boolean;
	bulkRel : CM_BulkRelease;

begin

	if self.toPackSize &lt; 1 then
		return;
	endif;
	
	foreach buttonNumber in 1 to self.toPackSize reversed do
		menuButton:= null;
		ti := null;
		menuButton := self.btnInYardTemp.getControl( buttonNumber ).MOB_Button;
		if menuButton = null then
			continue;
		endif;
		if menuButton.userObject = null or not menuButton.userObject.isKindOf(CM_TrackedItem) then
			continue;
		endif;
		ti := menuButton.userObject.CM_TrackedItem;
		if ti = null or ti.myParent = self.myPackContainer then
			continue;
		endif;
		
		if not self.myMobileGenericAgent.doPackCargo( self.myPackContainer, ti, true ) then
			return;
		endif;
		
		if app.myPassport.hasErrors then
			return;
		endif;
	
	endforeach;
	
	bulkRel := self.myMobileGenericAgent.myBulkRelease;
	if bulkRel &lt;&gt; null and bulkRel.isPackingType and bulkRel.allReserveDetails.size = 1 then
		self.handleBtnOne();
	endif;
	
	complete := true;

epilog

	if not complete then
		self.setupForm();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="e9c4f433-35c4-41ae-a19b-edaea00057ba">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation

*/

vars

	folderHeight : Real;
	stdHeight : Real;
	top : Real;
	thirdWidth : Real;
	stdWidth : Real;
	
	buttonWidth : Real;
	menuButton : MOB_Button;
	index : Integer;
	buttonHeight : Integer;
	buttonTop : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;
	stdWidth := self.clientWidth - 4;

//	folderHeight := self.height - self.getCMDHeight() - (stdHeight *2)+  self.getSessionAgent().deviceHeightOffset;
	folderHeight := self.clientHeight - self.getCMDHeight() - (stdHeight *2); //26 Jun 2017	NDL	TFS 4647
	
	//28 Feb 2017	NDL	TFS 3157
	if self.docActsToDisplay.isEmpty then
		self.btnDocActions.visible := false;
	else
		self.btnDocActions.visible := true;
		self.btnDocActions.height := self.btnOne.height;
		folderHeight := folderHeight - self.btnDocActions.height - self.resizedMargin;
	endif;
	
	self.fldCargo.move(	(stdWidth + self.resizedMargin) /2,	//self.resizedMargin,
						self.resizedMargin,
						(stdWidth - self.resizedMargin) /2,	//stdWidth + 2,
						folderHeight
						);
						
	self.lstRelItems.move(	self.resizedMargin,
							self.fldCargo.top,
							self.fldCargo.width,
							self.fldCargo.height - (self.resizedMargin * 2) );
						
	self.frmPacked.move(	0,
							0,
							self.shtPacked.width - self.resizedMargin,
							self.shtPacked.height// - self.resizedMargin
							);
								
	self.txtCargoId.move(	0,
							1,
							self.shtToPack.width - self.resizedMargin,
							stdHeight
							);
	self.txtCargoId.text := lblCargoId.caption.toUpper;
							
	top := self.txtCargoId.height + self.resizedMargin;
	self.frmToPack.move(	0,
							top,
							self.shtToPack.width - self.resizedMargin,
							self.shtToPack.height - top - self.resizedMargin
							);
							
	top := self.fldCargo.top + self.fldCargo.height; // + self.resizedMargin;
	
	if self.btnDocActions.visible then
		self.btnDocActions.move(	self.resizedMargin,
									top,
									self.btnOne.width,
									self.btnOne.height
									);
		top := top + self.btnDocActions.height + self.resizedMargin;
		
	endif;
	
	if _initialSetup then
		self.lblWeight.visible := true;
	endif;
	self.lblWeight.move(	self.resizedMargin,
							top,
							stdWidth,	//thirdWidth * 2,
							stdHeight );
							
	if _initialSetup then
		self.lblCount.visible := true;
	endif;
	top := self.lblWeight.top + self.lblWeight.height;
	self.lblCount.move(	self.resizedMargin,	//self.lblWeight.left + self.lblWeight.width,
						top,
						stdWidth,	//thirdWidth,
						stdHeight );
						
	
	if self.toPackSize &gt; 0 then
	
		buttonHeight := self.getScrollingButtonHeight();
		self.btnInYardTemp.height := buttonHeight;
		buttonWidth := self.getButtonWidthSetScrollBar( self.toPackSize, self.frmToPack, self.btnInYardTemp.height, self.scrToPack );
	
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.toPackSize do
			menuButton := self.btnInYardTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnInYardTemp.fontSize;	//07 Apr 2015	NDL	Par 35990
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
	endif;
	
	if self.packedSize &gt; 0 then
	
		buttonHeight := self.getScrollingButtonHeight();
		self.btnPackedTemp.height := buttonHeight;
		buttonWidth := self.getButtonWidthSetScrollBar( self.packedSize, self.frmPacked, self.btnPackedTemp.height, self.scrPacked );
	
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.packedSize do
			menuButton := self.btnPackedTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnPackedTemp.fontSize;	//07 Apr 2015	NDL	Par 35990
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
		
	endif;
						
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnPack" id="f47f04fb-779b-42ef-8a3d-07612a9b2f36">
        <updating/>
        <source>doUnPack( obj : Object ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2011	cnwndl1	Initial creation

*/

vars
	success : Boolean;
	ti : CM_TrackedItem;
begin

	if CM_TrackedItem.hasInstance( obj ) then
		ti := obj.CM_TrackedItem;
	endif;
	
	if ti = null then
		return;
	endif;
	
	//epr par 34472 3/7/14
	success := self.myMobileGenericAgent.doUnpackCargoAgain(ti);
														
	if success then
		self.goBackToFirst( MOB_HHPackContainerFormSTW );
		return;
	endif;
													
epilog

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="getUltimateParentIfNotPackedIn" id="e3a3023f-f3ae-44dd-89dd-9fd43ab98bd4">
        <source>getUltimateParentIfNotPackedIn( _ti : CM_TrackedItem; _packedIn : CM_TrackedItem ):CM_TrackedItem protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2014	cnwndl1	Initial creation	Par 34020

*/

vars

	potentialChildTi : CM_TrackedItem;
	parentTi : CM_TrackedItem;

begin

	if _ti = null then
		return null;
	endif;
	
	potentialChildTi := _ti;
	while potentialChildTi.myParent &lt;&gt; null do
		parentTi := potentialChildTi.myParent;
		if parentTi = _packedIn then
			// its already packed in this container
			parentTi := null;
			break;
		elseif parentTi.isContainer then
			// its already packed in another container
			parentTi := null;
			break;
		endif;
		potentialChildTi := parentTi;
	endwhile;
	
	return parentTi;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_packedIn" type="CM_TrackedItem"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
