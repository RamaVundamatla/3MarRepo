    <JadeMethod name="addLogsFromScaleData" id="a642cd1b-1005-4d9c-b701-6a4344bad1d7">
        <source>addLogsFromScaleData(_bolNumber : String; _logScalingData: StringArray; _operatorCode: String);
// 16 September 2010	cnwvu1

/*
_logScalingData string array has one row for one log: 
"logId	minSED	maxSED"

For example: "Log1	10	20"
*/

vars
	logScaleHdrPxy,
	hdr 			: CM_LogScalingHdr;
	logDetailPxy	: CM_LogScalingDtl;
	now				: TimeStamp;
	str				: String;
	strTokens		: StringArray;
	
begin

	create logScaleHdrPxy transient;

	logScaleHdrPxy.setProxy(_bolNumber, _operatorCode, null, now, self.getTerminal());
	
	foreach str in _logScalingData do
		create logDetailPxy transient;
		strTokens := str.getTokens;
		logDetailPxy.setProxy(	strTokens[1],	//logID,
								"OK", //log.conditionCode, 
								strTokens[2].Decimal,	//minSED,
								strTokens[3].Decimal,	//maxSED, 
								logScaleHdrPxy, 
								app.getMyUserCode /*log.scalerCode*/);
		delete strTokens;	// 13 Jan 2010	NDL	Leaking transients.
	endforeach;
	
	app.myTrxCA.trxCreateLogScalingData(logScaleHdrPxy, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete logScaleHdrPxy;
	delete strTokens;     // 13/09/2012 cnwmc5

end;</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_logScalingData" type="StringArray"/>
        <Parameter name="_operatorCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="addProductLog" id="3c821dc4-5c90-4c51-ad0e-303fc94d53ca">
        <source>addProductLog(	_operator: CM_Operator;
				_species: CM_LogSpecies;
				_grade: CM_LogGrade;
				_type: CM_LogType;
				_treat: CM_LogTreatment;
				_length: CM_LogLength);
//10 September 2010	by cnwvu1

vars
	pxyLogProduct	: CM_ProductLog;
	realLogProduct	: CM_Product;
	prodCode		: String;
	
begin

	create pxyLogProduct transient;
	
	prodCode := app.buildLogProductCode(_species.code, _grade.code, _type.code, _treat.code, _length.code);
	
	pxyLogProduct.setProxyLogProduct(prodCode, _operator, _species, _grade, _type, _treat, _length);

	realLogProduct := _operator.allProducts[TI_CargoType_Log, prodCode].CM_ProductLog;
	
	if realLogProduct = null then
		app.myTrxCA.trxCreateProduct(pxyLogProduct, realLogProduct, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();							
	endif;
	
epilog
	delete pxyLogProduct;

end;</source>
