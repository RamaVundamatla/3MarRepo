    <JadeMethod name="pxyCreateUpdateProxy" id="52254963-8eea-41b4-8e9e-5b2af746e099">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation 39166

*/

vars
	pxySelf : CM_WodVoyageCargoRequest;
	completedOK : Boolean;
	pxyCargoDetail,
	cargoDetail : CM_WodCargoRequest;
	
	pxyMarineService : CM_WodMarineServiceDetail;
	marineService : CM_WodMarineServiceDetail;
begin
	pxySelf:= inheritMethod();

	foreach cargoDetail in self.allCargoDetails discreteLock do
		pxyCargoDetail:=cargoDetail.pxyCreateUpdateProxy;
		pxySelf.allCargoDetails.add(pxyCargoDetail);
	endforeach;
	
	pxySelf.myBerth := self.myBerth;	//01 Aug 2018	NDL	TFS 39930
	
	//17 Aug 2018	NDL	TFS 40127
	foreach marineService in self.allMarineServiceDetails discreteLock do
		pxyMarineService:= marineService.pxyCreateUpdateProxy;
		if pxyMarineService &lt;&gt; null then	
			pxySelf.allMarineServiceDetails.add(pxyMarineService);
		endif;
	endforeach;
	
	completedOK := true;
	return pxySelf;

epilog

	if not completedOK then
		delete pxySelf;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresLengthOfTime" id="5ae545a4-a68b-4980-b4fd-c76ce85daad5">
        <source>requiresLengthOfTime(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2018	jlger1	Initial creation

*/

vars

begin
	if self.myBerth &lt;&gt; null and 
		 not self.myBerth.requiresLengthOfTime  then
		 return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6fe31dfe-fea3-44d5-b82d-cb8d7ea6eb7c">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodVoyageCargoRequest) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation 39166

*/

vars
	realCargoDetail,
	pxyCargoDetail : CM_WodCargoRequest;
	pxyDetail : CM_WorkOrderDtl;
	
	//17 Aug 2018	NDL	TFS 40127
	realMarineDetail : CM_WodMarineServiceDetail;
	pxyMarineDetail : CM_WodMarineServiceDetail;
	wodMarineServiceDtl : CM_WodMarineServiceDetail;	
	purgeSet : CM_WodMarineServiceDetailSet;
	status : CM_VoyageStatus;
	voyage : CM_Voyage;
	
begin
	inheritMethod(_pxyWoDDtl);
     
	foreach pxyCargoDetail in _pxyWoDDtl.allCargoDetails discreteLock do
		 realCargoDetail:=pxyCargoDetail.pxyGetRealObject .CM_WodCargoRequest;
		 pxyDetail:=pxyCargoDetail;
		 if realCargoDetail = null then
			 create realCargoDetail persistent;	
			
			 realCargoDetail.setForCreate(pxyDetail, null);
			 self.allCargoDetails.add(realCargoDetail);
		else
			realCargoDetail.setForUpdate(pxyCargoDetail);			
		endif;
	endforeach;
	
	self.myBerth := _pxyWoDDtl.myBerth;	//01 Aug 2018	NDL	TFS 39930
	
	//17 Aug 2018	NDL	TFS 40127 - removed 26 Nov 2018	NDL	TFS 41980 - and put back again 04 Dec 2018
	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if _pxyWoDDtl.allMarineServiceDetails.findWodMarineServiceDet2( wodMarineServiceDtl ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif; 
     
	foreach pxyMarineDetail in _pxyWoDDtl.allMarineServiceDetails discreteLock do
		 realMarineDetail:=pxyMarineDetail.pxyGetRealObject .CM_WodMarineServiceDetail;
		 pxyDetail:=pxyMarineDetail;
		 if realMarineDetail = null then
			 create realMarineDetail persistent;	
			
			 realMarineDetail.setForCreate(pxyDetail.CM_WodMarineServiceDetail, null);
			 self.allMarineServiceDetails.add(realMarineDetail);
		else
			realMarineDetail.setForUpdate(pxyMarineDetail);			
		endif;
	endforeach;
	 
epilog
	delete purgeSet;
end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodVoyageCargoRequest"/>
    </JadeMethod>
    <JadeMethod name="setMarineDetsFromResourceUsed" id="fe649a66-f3d7-41eb-983b-eb67c9eff94c">
        <updating/>
        <source>setMarineDetsFromResourceUsed( _resourceUsedSet : HMS_ResourceUsedSet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2018	jlgndl1	Initial creation	TFS 40127

*/

vars

	wodMarineServiceDtl : CM_WodMarineServiceDetail;
	pxyWodMarineServiceDtl : CM_WodMarineServiceDetail;
	realWodMarineServiceDtl : CM_WodMarineServiceDetail;
	resourceUsed : HMS_ResourceUsed;
	purgeSet : CM_WodMarineServiceDetailSet;
	checkFor : CM_WodMarineServiceDetail;

begin

	// removed 26 Nov 2018	NDL	TFS 41980 - no facility to remove anymore
/*	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if _resourceUsedSet.findResourceUsedFor( wodMarineServiceDtl.myHMSResource ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif; */
	
	//04 Dec 2018	NDL	TFS 41980 - New rule, they can remove them on the web.....
	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if wodMarineServiceDtl.isTransient then
			pxyWodMarineServiceDtl := wodMarineServiceDtl;
			realWodMarineServiceDtl := wodMarineServiceDtl.pxyGetRealObject();
		else
			pxyWodMarineServiceDtl := wodMarineServiceDtl.pxyGetProxyObject();
			realWodMarineServiceDtl := wodMarineServiceDtl;
		endif;
		if _resourceUsedSet.findResourceUsedForDtl( realWodMarineServiceDtl ) = null
		and  _resourceUsedSet.findResourceUsedForDtl( pxyWodMarineServiceDtl ) = null
		then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif;
	//end of 03 Dec change
	
	if _resourceUsedSet = null or _resourceUsedSet.isEmpty then
		return;
	endif;
	
	foreach resourceUsed in _resourceUsedSet do
		//wodMarineServiceDtl := self.allMarineServiceDetails.findWodMarineServiceDet( resourceUsed.myResource );
		//27 Nov 2018	NDL	TFS 41980
		//04 Dec 2018	NDL	TFS 41980
		if resourceUsed.myWorkOrderVoyageDtl &lt;&gt; null
		and resourceUsed.myWorkOrderVoyageDtl.isKindOf( CM_WodMarineServiceDetail ) then
			if self.isTransient then
				checkFor := resourceUsed.myWorkOrderVoyageDtl.CM_WodMarineServiceDetail.pxyGetProxyObject;
			else
				checkFor := resourceUsed.myWorkOrderVoyageDtl.CM_WodMarineServiceDetail;
			endif;
		endif;
	
		
		if checkFor &lt;&gt; null
		and self.allMarineServiceDetails.includes( checkFor ) then
			wodMarineServiceDtl := resourceUsed.myWorkOrderVoyageDtl.CM_WodMarineServiceDetail;
		else	//30 Nov 2018	NDL	TFS 4980
			wodMarineServiceDtl := null;
		endif;
		
		if wodMarineServiceDtl = null then
			if self.isTransient then
				create wodMarineServiceDtl transient;
			else
				create wodMarineServiceDtl persistent;
			endif;
			self.allMarineServiceDetails.add( wodMarineServiceDtl );
		endif;
		wodMarineServiceDtl.setProxyFromResourceUsed( resourceUsed );		
	endforeach;

epilog

	delete purgeSet;

end;</source>
        <Parameter name="_resourceUsedSet" type="HMS_ResourceUsedSet"/>
    </JadeMethod>
