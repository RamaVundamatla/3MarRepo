    <JadeMethod name="doBtnSaveClick" id="ec88db71-e085-408e-81eb-be0185ef40e0">
        <updating/>
        <source>doBtnSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	if self.mode = self.Mode_TIs then
		self.doSaveTIs();
	else
		self.doSaveFMs();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="45f2eef1-74a3-4c19-a701-9e1694f8484e">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	toolbarHeight	: Integer;
begin
	self.width := 260;
	self.height := 220;
	
	toolbarHeight := self.frmToolbar.clientHeight;

	self.frmToolbar.width := self.clientWidth;
	self.lblRequests.move(5, self.frmToolbar.top + toolbarHeight + 5,self.clientWidth - 10, 15 );

	self.magCargo.move(0, self.lblRequests.top + self.lblRequests.height + 5, self.clientWidth - 10, 161 - toolbarHeight);
	self.magCargo.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveFMs" id="cfbdc621-86a8-4391-8588-01e3b294c133">
        <updating/>
        <source>doSaveFMs() updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aLeftReq, aRightReq : CM_FutureMove;
	theRightFutureMove : CM_FutureMoveArray;
	idx,result : Integer;
begin
	create theRightFutureMove transient;
	self.magCargo.getItemsOnRightSide(theRightFutureMove);

//	app.myTrxUA.trxUpdateSlotControllerShuffFM(myLocationsController,theRightFutureMove,app.myPassport);			
//	if not app.myPassport.trxCompletedOK then
//		app.showErrorWarningDialog('Shuffle Future Move', app.myPassport, ErrWarnMode_Update);
//		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
//		return;
//	else
//		self.clearErrorWarnings();
//	endif;
	while true do
		app.myTrxUA.trxUpdateSlotControllerShuffFM(myLocationsController,theRightFutureMove,app.myPassport);			

		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Shuffle Future Move', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and  result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;

				continue;
			endif;
		endif;
		break;
	endwhile;

	global.beep;
	self.unloadForm();
epilog
	delete theRightFutureMove;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveTIs" id="bcb39ae5-2135-4fd4-9f91-f7a37bd2cac5">
        <updating/>
        <source>doSaveTIs() updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aLeftReq, aRightReq : CM_TrackedItem;
	theTIs : CM_TIArray;
	idx,result : Integer;
begin
	create theTIs transient;
	self.magCargo.getItemsOnRightSide(theTIs);
	while true do
		app.myTrxUA.trxUpdateSlotControllerShuffle(theTIs, app.myPassport);			

		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Shuffle TrackedItem XX', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and  result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;

				continue;
			endif;
		endif;
		break;
	endwhile;


		
	global.beep;
	self.unloadForm();
epilog
	delete theTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="initGroupBox" id="c0a9b2c1-6403-4a88-8904-32f82b676561">
        <source>initGroupBox();
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	self.magCargo.caption := null;
	self.magCargo.distanceFromBottom 	:= 5;
	self.magCargo.distanceFromRight 		:= 5;
	self.magCargo.lockBottom 				:= false;
	self.magCargo.lockRight				:= false;
	self.magCargo.stretchHeight 			:= true;
	self.magCargo.stretchWidth 			:= true;
	self.magCargo.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.magCargo.borderStyle := Frame.BorderStyle_None;
	
	self.magCargo.availableHeading := app.getErrorString(TrackedItems);	//cnwmc5 

	self.magCargo.selectedHeading := app.getErrorString(TrackedItems);	//cnwmc5 

	self.magCargo.displayAddRemoveBtns(false, false);	//cnwmc5
	self.magCargo.displayOrderBtns(true, true);	//cnwmc5
	self.magCargo.myBaseForm	:= self;
	self.magCargo.mySelectedListBox.sorted := false;
//	self.magCargo.cnEcResizeContents();
	self.magCargo.readOnly := false;
	self.magCargo.myAvailableListBox.listObject := null;
	self.magCargo.setAsAlignOnly();
end;</source>
    </JadeMethod>
