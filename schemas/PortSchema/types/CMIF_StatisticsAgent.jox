        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="splitIntoRows" id="d50aadb5-71bb-4cf5-bcd7-848818a7e65d">
        <source>splitIntoRows(_locations: CM_LCArray; _rows: ObjectArray io);
/*
Purpose:			_locations is a rectangular sequence of locations. Split in up into a number of rows.
					Caller will need to purge the returned _rows ObjectArray

Date		Who		Reason
23 Feb 2009	cnwdw1	
08 Sep 2009	cnwkpd1	PAR #20586 - Improve performance of BGP Location Statistics
*/
vars
	lc				: CM_LocationsController;
	location		: CM_GridController;
	lcRow			: CM_LCArray;
	i, row			: Integer;
	
begin
	foreach lc in _locations do				// PAR #20586
		if lc.isGridLocation then
			location := lc.CM_GridController;
			if row &lt;&gt; location.row then
				create lcRow transient;
				_rows.add(lcRow);
				row := location.row;
			endif;
			if lcRow = null then
				create lcRow transient;
			endif;
			lcRow.add(location);
		endif;
	endforeach;
end;</source>
        <Parameter name="_locations" type="CM_LCArray"/>
        <Parameter name="_rows" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="totalSpaceIn" id="96a695e6-0bd0-438b-b7de-7f68f33bfa2a">
        <source>totalSpaceIn(_containerSize: Integer; _locations: CM_LCArray): Integer;
//20 February 2009	cnwdw1	
//
vars
	total, i: Integer;
	offset: Integer;
	rows: ObjectArray;
	obj: Object;
	row: CM_LCArray;
	nextLocation, location: CM_GridController;
begin
	create rows transient;
	self.splitIntoRows(_locations, rows);
	
	foreach obj in rows do
		row := obj.CM_LCArray;
		offset := 0;
		nextLocation := row[1].CM_GridController;
		foreach i in 1 to row.size do
			location := row[i].CM_GridController;
			if location &lt;&gt; nextLocation then
				continue;
			endif;
			total := total + location.totalSpaceFor(_containerSize, offset);
			location.nextLocationForSize(_containerSize, nextLocation, offset);
		endforeach;
	endforeach;
	
	return total;
epilog
	if rows &lt;&gt; null then
		rows.purge;
		delete rows;
	endif;
end;</source>
        <Parameter name="_containerSize" type="Integer"/>
        <Parameter name="_locations" type="CM_LCArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
