    <JadeMethod name="getLoadOrderForTI" id="7e02104d-5722-4fc6-a14f-3b6f29a2807b">
        <source>getLoadOrderForTI(_ti: CM_TrackedItem): Integer;
//--------------------------------------------------
// Created:	10 December 2003 By: cnwgd1
//--------------------------------------------------
vars
	num,
	idx : Integer;
begin
	if _ti = null then
		return null;
	endif;
	idx := self.allTrackedItems.indexOf(_ti);
	num := self.allTrackedItems.size+1;
	if idx = 0 then
		return null;
	endif;
	return num - idx;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
