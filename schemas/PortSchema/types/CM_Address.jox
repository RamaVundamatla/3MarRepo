    <JadeMethod name="isDifferentFromCMIF" id="f67904a1-4c2a-4714-b0f9-9e237bb378bb">
        <source>isDifferentFromCMIF(_anotherAddress : CMIF_Address) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2023	navra1	Initial creation for 57447 - Check if any of the fields that could have been passed on from a REST request(WS_RestAddressObject) are different to what we have

*/

vars

begin
	if self.addr1 &lt;&gt; _anotherAddress.addr1 or
		self.addr2 &lt;&gt; _anotherAddress.addr2 or
		self.addr3 &lt;&gt; _anotherAddress.addr3 or
		self.postCode &lt;&gt; _anotherAddress.postCode or
		self.region &lt;&gt; _anotherAddress.region or
		self.countryISOCode &lt;&gt; _anotherAddress.isoCountryCode or
		self.isDefault &lt;&gt; _anotherAddress.isDefault or
		self.isAlternative &lt;&gt; _anotherAddress.isAlternative or
		self.city &lt;&gt; _anotherAddress.city or
		self.code &lt;&gt; _anotherAddress.code or
		self.description &lt;&gt; _anotherAddress.description or
		self.email &lt;&gt; _anotherAddress.email then
		
		return true;
		
	endif;
	
	return false;		

epilog

end;</source>
        <Parameter name="_anotherAddress" type="CMIF_Address"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f222b0c3-23e3-4c5f-9f3a-4e33dac9575b">
        <updating/>
        <source>setForCreate(_pxyAddress : CM_Address)  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars

begin


	self.setForUpdate(_pxyAddress);
epilog

end;</source>
        <Parameter name="_pxyAddress" type="CM_Address"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="19f31e18-4491-498a-bb72-f6056c3914c7">
        <updating/>
        <source>setForUpdate(_pxyAddress : CM_Address)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
02 Sept 2022	navkc1	ChangeRequest 54564(54372.020): Alternate address for Debtor
28 Apr 2023		navra1	TFS 57086 EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
*/

vars
	realAddress,
	defaultAddress,
	alternateAddress	: CM_Address;
	emails : StringArray;
	emailStr : String;
begin	
	_pxyAddress.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	if self.isTransient then
		realAddress := self.pxyGetRealObject;
	else
		realAddress := self;
	endif;
	
	if realAddress.myDebtor &lt;&gt; null then
		defaultAddress := realAddress.myDebtor.getDefaultDebtorAddress;
		alternateAddress := realAddress.myDebtor.getDebtorAlternativeAddress();	//02/09/22	navkc1	#54564(54372.020)
	endif;
	
	self.isDefault	 	:= _pxyAddress.isDefault;
	self.isAlternative	:= _pxyAddress.isAlternative;	//02/09/22	navkc1	#54564(54372.020)
	self.code 		 	:= _pxyAddress.code;
	self.description 	:= _pxyAddress.description;
	self.addr1		 	:= _pxyAddress.addr1;
	self.addr2		 	:= _pxyAddress.addr2;
	self.addr3		 	:= _pxyAddress.addr3;
	self.region		 	:= _pxyAddress.region;
	self.postCode    	:= _pxyAddress.postCode;
	self.countryCode 	:= _pxyAddress.countryCode;
	
	 // ### JIRA 35465 28JUL2025 NAVAB1
	emailStr := _pxyAddress.email;
	emailStr := emailStr.replaceString(",", " ");
	emails := emailStr.getTokens();
	if emails.size &gt; 1 then
		emailStr := emails.concatenate(";");
	endif;
	self.email			:= emailStr;
	
//	self.email			:= _pxyAddress.email;			//navra1 - TFS 57086 - 28th Apr 2023 				
	self.myDebtor    	:= _pxyAddress.myDebtor;
	//jlier1 TFS 53679 27/6/22
	self.deliveryInstructions:=_pxyAddress.deliveryInstructions;
	self.city		:= _pxyAddress.city;
	
	if 	_pxyAddress.myDebtor &lt;&gt; null then
		if 	_pxyAddress.myDebtor.allAddressesByCode.size = 1 then
			if not _pxyAddress.isDefault then
				self.isDefault := true;		
			endif;
		endif;
	endif;
	
	if _pxyAddress.isDefault then
		if defaultAddress &lt;&gt; null then
				if defaultAddress.code &lt;&gt; _pxyAddress.code then
					defaultAddress.isDefault := false;
				endif;
		endif;
	endif;
	
	// 02/09/22	navkc1	#54564(54372.020) --&gt;
	if _pxyAddress.isAlternative then
		if alternateAddress &lt;&gt; null then
			if alternateAddress.code &lt;&gt; _pxyAddress.code then
				alternateAddress.isAlternative := false;
			endif;
		endif;
	endif;
	// 02/09/22	navkc1	#54564(54372.020) &lt;--
epilog
	delete emails;
end;</source>
        <Parameter name="_pxyAddress" type="CM_Address"/>
    </JadeMethod>
    <JadeMethod name="setIsDefault" id="9fd49cba-19b0-439b-83e2-3d0688ed77d1">
        <updating/>
        <source>setIsDefault(default : Boolean) updating;
