    <JadeMethod name="getNextBuyLineSequenceNumber" id="f4786846-fdd8-4406-85e8-3e9e422d51aa">
        <updating/>
        <source>getNextBuyLineSequenceNumber(): Integer updating;

begin
	if self.buyLineSequenceNumber &lt; 1000 then
		self.buyLineSequenceNumber := 1000;
	elseif self.buyLineSequenceNumber &gt; 999999 then
		self.buyLineSequenceNumber := 1000;
	endif;
	
	self.buyLineSequenceNumber	:=	self.buyLineSequenceNumber + 1;
	
	return self.buyLineSequenceNumber;	 	 	 	 	 	 	 	 
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="3c72b740-e038-4122-a43a-b481417995eb">
        <updating/>
        <source>initializeMe(	pBuyLineAdminEmailAddress : String;
				pBuyLineETLpassword : String;
				pBuyLineOPSId : Integer;
				pBuyLinePath : String;
				pBuyLineRpassword : String;
				pBuyLineServer : String;
				pTimeOut : Integer;
				pBuyLineVpassword : String;
				pMyBaseRoot : CnEcBaseRoot) updating;

begin
	self.buyLineAdminEmailAddress	:=	pBuyLineAdminEmailAddress;
	self.buyLineETLpassword			:=	pBuyLineETLpassword;
	self.buyLineOPSId				:=	pBuyLineOPSId;
	self.buyLinePath				:=	pBuyLinePath;
	self.buyLineRpassword			:=	pBuyLineRpassword;
	self.buyLineServer				:=	pBuyLineServer;
	self.timeOut					:=	pTimeOut;
	self.buyLineVpassword			:=	pBuyLineVpassword;
	self.myBaseRoot					:=	pMyBaseRoot;
end;</source>
        <Parameter name="pBuyLineAdminEmailAddress" type="String"/>
        <Parameter name="pBuyLineETLpassword" type="String"/>
        <Parameter name="pBuyLineOPSId" type="Integer"/>
        <Parameter name="pBuyLinePath" type="String"/>
        <Parameter name="pBuyLineRpassword" type="String"/>
        <Parameter name="pBuyLineServer" type="String"/>
        <Parameter name="pTimeOut" type="Integer"/>
        <Parameter name="pBuyLineVpassword" type="String"/>
        <Parameter name="pMyBaseRoot" type="CnEcBaseRoot"/>
    </JadeMethod>
    <JadeMethod name="removeExpiredAuthorisations" id="2f55b993-5167-4adc-867f-761aba1ea55d">
        <source>removeExpiredAuthorisations();

vars
	msg		: CnEcBNZBuyLineMsg;
	auth	: CnEcBNZBuyLineAuthorisation;
	today	: Date;
	theTA	: CnEcBuyLineAgent; 
	
begin
	create theTA transient;

	foreach msg in self.allBuyLineMessages where msg.isKindOf(CnEcBNZBuyLineAuthorisation) do
		auth := msg.CnEcBNZBuyLineAuthorisation;
		if auth.myCompletion = null then
			if auth.sentToBuyLine.Date + 7 &lt; today then
				theTA.trxBNZBuyLineMsgDelete(msg);
			endif;
		endif;
	endforeach;
epilog
	delete theTA;	
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMe" id="bbcaf286-e477-4f83-a727-2501ff4e3134">
        <updating/>
        <source>updateMe(	pBuyLineAdminEmailAddress : String;
			pBuyLineETLpassword : String;
			pBuyLineOPSId : Integer;
			pBuyLinePath : String;
			pBuyLineRpassword : String;
			pBuyLineServer : String;
			pTimeOut : Integer;
			pBuyLineVpassword : String) updating;

begin
	if self.buyLineAdminEmailAddress &lt;&gt; pBuyLineAdminEmailAddress then
		self.buyLineAdminEmailAddress	:= pBuyLineAdminEmailAddress;
	endif;
	
	if self.buyLineETLpassword &lt;&gt; pBuyLineETLpassword then
		self.buyLineETLpassword	:= pBuyLineETLpassword;
	endif;
	
	if self.buyLineOPSId &lt;&gt; pBuyLineOPSId then
		self.buyLineOPSId	:= pBuyLineOPSId;
	endif;
	
	if self.buyLinePath &lt;&gt; pBuyLinePath then
		self.buyLinePath	:= pBuyLinePath;
	endif;
	
	if self.buyLineRpassword &lt;&gt; pBuyLineRpassword then
		self.buyLineRpassword	:= pBuyLineRpassword;
	endif;
	
	if self.buyLineServer &lt;&gt; pBuyLineServer then
		self.buyLineServer	:= pBuyLineServer;
	endif;
	
	if self.timeOut &lt;&gt; pTimeOut then
		self.timeOut	:= pTimeOut;
	endif;
	
	if self.buyLineVpassword &lt;&gt; pBuyLineVpassword then
		self.buyLineVpassword	:= pBuyLineVpassword;
	endif;
end;</source>
        <Parameter name="pBuyLineAdminEmailAddress" type="String"/>
        <Parameter name="pBuyLineETLpassword" type="String"/>
        <Parameter name="pBuyLineOPSId" type="Integer"/>
        <Parameter name="pBuyLinePath" type="String"/>
        <Parameter name="pBuyLineRpassword" type="String"/>
        <Parameter name="pBuyLineServer" type="String"/>
        <Parameter name="pTimeOut" type="Integer"/>
        <Parameter name="pBuyLineVpassword" type="String"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="6e87dd2f-59fd-47eb-a421-1d7a37206bfb">
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars
	void		: CnEcBNZBuyLineVoid;
	trxAccepted	: Boolean;
	
begin
	if eventType = CnEcBNZBuyLineMsg.SEND_VOID_TO_BUYLINE then 
		void := userInfo.CnEcBNZBuyLineVoid;
		
		if void &lt;&gt; null then
			process.sleep(1000);
			void.sendMessage(trxAccepted);
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
