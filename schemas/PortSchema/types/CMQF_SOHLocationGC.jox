<Class name="CMQF_SOHLocationGC" id="e4aaf578-d70f-441a-a91b-fd329e521ef1">
    <superclass name="CMQF_SOHLocation"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="04de92e9-e47c-4ade-a35f-f8a295d4df07">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	breakOut	: Boolean;

begin
	if (not app.getMyUser.canDo(null, Mod_GeneralCargo)) then
		return;
	endif;
	
	if self.getMyLocationsController &lt;&gt; null then
		self.handleLocationsController(self.getMyLocationsController, _collection, _passport, breakOut);
	elseif self.getMyTerminalArea &lt;&gt; null then
		self.handleTerminalArea(self.getMyTerminalArea, _collection, _passport, breakOut);
	elseif self.myOperator &lt;&gt; null then
		self.handleOperator(self.myOperator, _collection, _passport, breakOut);
	elseif self.getMyProduct &lt;&gt; null then
		self.handleProduct(self.getMyProduct, _collection, _passport, breakOut);
	elseif CM_CargoType.hasInstance(self.getMyCargoType) then 
		self.handleCargoType(self.getMyCargoType.CM_CargoType, _collection, _passport, breakOut);
	else
		self.handleAllCargoTypes(_collection, _passport, breakOut);
	endif;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="handleAllCargoTypes" id="67ffa82d-7d4d-464a-b3fe-960050cdb100">
        <updating/>
        <source>handleAllCargoTypes(_collection: Collection input; 
				_passport: CM_Passport;
				_breakOut : Boolean output) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 November 2004	cnwth2
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
//14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
vars
	cargoTypeDict			: CM_CargoTypesByIdDict;
	iter					: Iterator;
	cargoTypeKey			: Integer;
	cargoType				: CM_CargoType;
begin
	cargoTypeDict := app.myRoot.allCargoTypesById;
	iter := cargoTypeDict.createIterator;

	cargoTypeDict.startKeyGeq(TI_CargoBOLType_Max, iter);
	
	while iter.next(cargoType) do
		iter.getCurrentKeys(cargoTypeKey); //MTN-35226
		//if cargoTypeKey &gt;= TI_CargoBOLType_JMTMax then										// TFS 49252
		if (cargoTypeKey &gt;= TI_CargoBOLType_JMTMax and not app.myRoot.isClientCentrePort) then	// TFS 49252
			break;
		endif;
		
		self.handleCargoType(cargoType, _collection, _passport, _breakOut);
	endwhile;
epilog
	delete iter;	

end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleCargoType" id="cd7d9e99-7466-4ce7-b5a9-2425ca57cfa2">
        <updating/>
        <source>handleCargoType(_cargoType : CM_CargoType;
				_collection: Collection input; 
				_passport: CM_Passport;
				_breakOut : Boolean output) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	product					: CM_Product;
begin

	if _cargoType = null then
		return;
	endif;
	
	foreach product in _cargoType.allProducts discreteLock do
		self.handleProduct(product, _collection, _passport, _breakOut);
		if _breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleLocationsController" id="ed456919-3219-4d96-a9a4-ddd78075e04b">
        <updating/>
        <source>handleLocationsController(_lc : CM_LocationsController;
							_collection: Collection input; 
							_passport: CM_Passport;
							_breakOut : Boolean output) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	sohLocation			: CM_SOHLocation;
begin
	foreach sohLocation in _lc.allProductLocations discreteLock do
		self.handleSOHLocation(sohLocation, _collection, _passport, _breakOut);
		if _breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleOperator" id="251158da-4316-47a3-88fd-93a041d5909d">
        <updating/>
        <source>handleOperator(_op : CM_Operator;
				_collection: Collection input; 
				_passport: CM_Passport;
				_breakOut : Boolean output) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	product				: CM_Product;
begin
	if _op = null then
		return;
	endif;
	foreach product in _op.allProducts discreteLock do
		self.handleProduct(product, _collection, _passport, _breakOut);
		if _breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_op" type="CM_Operator"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleProduct" id="412831b4-4850-4697-a87a-9739ee3281d4">
        <updating/>
        <source>handleProduct(_product : CM_Product;
				_collection: Collection input; 
				_passport: CM_Passport;
				_breakOut : Boolean output) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	sohLocation			: CM_SOHLocation;
begin
	foreach sohLocation in _product.allSOHLocations discreteLock do
		self.handleSOHLocation(sohLocation, _collection, _passport, _breakOut);
		if _breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleSOHLocation" id="632cca54-c43d-41bf-85ec-cdd1836f8c9b">
        <updating/>
        <source>handleSOHLocation(_sohLoc : CM_SOHLocation;
				_collection: Collection input; 
				_passport: CM_Passport;
				_breakOut : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     All filtering comes through to here at the bottom level
//				Create a transient shoReporter and adds it to the collection
//			 
// ----------   ----------  --------------------------------------------------
vars
	sohReporter			: CMIF_SOHReporter;
	breakOut			: Boolean;
begin
	
	if not self.checkStatusIncludesObject(_sohLoc, _passport, breakOut) then
//	if (not self.includesObject(_sohLoc, _passport, breakOut)) then
		return;
	endif;
	
	create sohReporter transient;
	sohReporter.setFromSOHLocation(_sohLoc);
	_collection.add(sohReporter);

end;</source>
        <access>protected</access>
        <Parameter name="_sohLoc" type="CM_SOHLocation"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleTerminalArea" id="26e294e8-9427-4069-a21b-1f49702e65cc">
        <updating/>
        <source>handleTerminalArea(_ta : CM_TerminalArea;
				_collection: Collection input; 
				_passport: CM_Passport;
				_breakOut : Boolean output) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	lc			: CM_LocationsController;
begin
	foreach lc in _ta.allLocationsControllers discreteLock do
		self.handleLocationsController(lc, _collection, _passport, _breakOut);
		if _breakOut then
			break;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="d145f89b-3634-483f-bbdd-d2d845adeb02">
        <updating/>
        <source>includesObject(_sohLoc: CM_SOHLocation; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	querySelf			: CMQF_SOHLocationGC;
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if (querySelf.getMyCargoType &lt;&gt; null and querySelf.getMyCargoType &lt;&gt; _sohLoc.myProduct.myCargoType) or
	   (querySelf.getMyTerminalArea &lt;&gt; null and querySelf.getMyTerminalArea &lt;&gt; _sohLoc.myTerminalArea) or
	   (querySelf.getMyLocationsController &lt;&gt; null and querySelf.getMyLocationsController &lt;&gt; _sohLoc.myLocationsController) or
	   (querySelf.myOperator &lt;&gt; null and querySelf.myOperator &lt;&gt; _sohLoc.myOperator) or
	   (querySelf.getMyProduct &lt;&gt; null and querySelf.getMyProduct &lt;&gt; _sohLoc.myProduct) or
	   (_sohLoc.allTrackedItems.isEmpty) then 
		return false;
	endif;
	
	querySelf.numFound := querySelf.numFound + 1;
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_sohLoc" type="CM_SOHLocation"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
