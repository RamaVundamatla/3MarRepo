<Class name="WS_SealType" id="86023e6c-08bd-446d-a9ea-8ac3c7479685">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents User defined seal types.</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allCargoTypes" id="ab83086e-f425-41f9-af6d-f6a99dfc2628">
        <memberTypeInverse/>
        <type name="WS_CargoTypeArray"/>
        <text>Cargo Types which associate with the seal Type. ex ID1= 1,Description = CONT</text>
    </ImplicitInverseRef>
    <PrimAttribute name="allowMultipleSealNums" id="ddd10923-4ede-4d00-ab35-bc0fe410e409">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>More than one seal number may be required to be recorded for this seal type. ex.True/False</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="33263737-6194-4ccc-84b8-5eb6e1420eff">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Description of the seal type ex.MAF/Customs Seal</text>
    </PrimAttribute>
    <PrimAttribute name="sealType" id="c9e54ff6-0a58-4cdf-bc6d-64d248459d83">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <text>Code of the Seal Type ex.CUST</text>
    </PrimAttribute>
    <PrimAttribute name="showSealOnCheck" id="206cb502-af02-4ce9-9874-67a35fef633f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Display the seal numbers to users who are performing seal checks. ex.True/False</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="455f3aad-100c-4e3e-a089-4fe8647b3bfa">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation	Par 28303

*/

vars

begin

	if not self.allCargoTypes.isEmpty then
		self.allCargoTypes.purge();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="276d15a8-91fe-4537-8717-44601db64232">
        <updating/>
        <source>setProxyFromObject(_object: CM_SealType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation	Par 28303

*/

vars

	cargoType : CM_CargoType;
	wsCargoType : WS_CargoType;

begin

	inheritMethod(_object);
	
	self.sealType := _object.sealType;
	self.description := _object.description;
	self.showSealOnCheck := _object.showSealOnCheck.String;
	self.allowMultipleSealNums := _object.allowMultipleSealNums.String;
	
	foreach cargoType in _object.allCargoTypes discreteLock do
		create wsCargoType transient;
		wsCargoType.setProxyFromObject( cargoType );
		wsCargoType.description := cargoType.abbreviation;
		self.allCargoTypes.add( wsCargoType );
	endforeach;

epilog

end;</source>
        <Parameter name="_object" type="CM_SealType"/>
    </JadeMethod>
</Class>
