			delete tran;
		endif;
	endforeach;
	_storageConfig.setPropertyValue("includeFirstDay", _useFirst);
	_storageConfig.setPropertyValue("includeLastDay", _useLast);
	commitTransaction;

	tranDate.setDate(day,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(1, 1, 00, 00);
	tranTS.setTime(tranTime);
	tran := self.createDatedTransaction(_ti, tranTS, TRANS_TYPE_STORAGE);
	msg := "FIRST Storage: In 1 out " &amp; day.String &amp; " Use First day=" &amp; _useFirst.String &amp; " Use Last Day=" &amp; _useLast.String;
	if tran = null then
		msg := msg &amp; " NO storage transaction";
	elseif tran.allInvoiceLines.isEmpty then
		msg := msg &amp; " NO invoice lines";
	else
		foreach invLine in tran.allInvoiceLines do
			msg := msg &amp; " Quantity=" &amp; invLine.quantity.String;
		endforeach;
	endif;
	write msg;

	day := _day2;
	tranDate.setDate(day,3,2016);
	tranTS.setDate(tranDate);
	tranTime.setTime(1, 1, 00, 00);
	tranTS.setTime(tranTime);
	tran := self.createDatedTransaction(_ti, tranTS, TRANS_TYPE_STORAGE);
	msg := "SECOND Storage: In 1 out " &amp; day.String &amp; " Use First day=" &amp; _useFirst.String &amp; " Use Last Day=" &amp; _useLast.String;
	if tran = null then
		msg := msg &amp; " NO storage transaction";
	elseif tran.allInvoiceLines.isEmpty then
		msg := msg &amp; " NO invoice lines";
	else
		foreach invLine in tran.allInvoiceLines do
			msg := msg &amp; " Quantity=" &amp; invLine.quantity.String;
		endforeach;
	endif;
	write msg;
epilog

end;</source>
