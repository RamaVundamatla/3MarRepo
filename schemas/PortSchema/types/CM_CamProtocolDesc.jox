    <JadeMethod name="getCamMessage" id="c52006ef-0243-4b36-842b-f6e777c45fe6">
        <source>getCamMessage(_camFile: CM_CamFile input; _voyageCode, _vesselName : String; _messageType: Integer; _singleMessage : Boolean): CM_CamMessage;
//
// processTransaction calls this or setCamMessage to get a CM_CamMessage
//
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
vars
	camVoyage 	: CM_CamVoyage;
	camMessage 	: CM_CamMessage;
begin
	if not _singleMessage then 										//ccms1747 cnwrs1 aug 2008 
		camVoyage := _camFile.camVoyages[_voyageCode, _vesselName]; //par18987 cnwrs1 Mar 2009
	endif;
	
	if camVoyage = null then
		create camVoyage transient;
		
		camVoyage.voyage 		:= _voyageCode;
		camVoyage.vesselName 	:= _vesselName; //par18987 cnwrs1 Mar 2009
		camVoyage.camFile 		:= _camFile;
		
		app.writeLog("Creating camVoyage for voyage = " &amp; _voyageCode &amp; ".", LogERROR);
	else
		app.writeLog("Found camVoyage " &amp; camVoyage.voyage &amp; " for voyage = " &amp; _voyageCode &amp; ".", LogWARN);
	endif;
	
	camMessage := camVoyage.camMessages[_messageType];
	
	if camMessage = null then
		create camMessage transient;
		
		camMessage.activity		:= _messageType;
		camMessage.camVoyage 	:= camVoyage;
		camVoyage.camMessagesByTiId.add(camMessage);
		_camFile.camMessageByActivityVoyage.add(camMessage);
		
		app.writeLog("Creating " &amp; self.getMessageTypeString(_messageType) &amp; " message for voyage " &amp; camVoyage.voyage &amp; ".", LogWARN);
	else
		app.writeLog("Found " &amp; self.getMessageTypeString(_messageType) &amp; " message for voyage " &amp; camVoyage.voyage &amp; ".", LogWARN);
	endif;

	return camMessage;
end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_messageType" type="Integer"/>
        <Parameter name="_singleMessage" type="Boolean"/>
        <ReturnType type="CM_CamMessage"/>
    </JadeMethod>
    <JadeMethod name="getCamMessageVoyage" id="8a8e4b1f-a39f-4608-afb5-3932dc4e8fe7">
        <source>getCamMessageVoyage(_camFile: CM_CamFile input; _opVoyageCode, _voyVoyageCode, _vesselName : String; _messageType: Integer; _singleMessage : Boolean): CM_CamMessage;
//
//25 May 2017	cnwrs1	TFS 4470
//
vars
	camVoyage : CM_CamVoyage;
	camMessage : CM_CamMessage;
begin
	if not _singleMessage then 
		camVoyage := _camFile.camVoyages[_opVoyageCode, _vesselName];
	endif;
	
	if camVoyage = null then
		create camVoyage transient;
		camVoyage.voyage := _opVoyageCode;
		camVoyage.vesselName := _vesselName;
		camVoyage.camFile := _camFile;
		camVoyage.voyageCodeVoyOp := _voyVoyageCode;
		
		app.writeLog("Creating camVoyage for voyage = " &amp; _voyVoyageCode &amp; ".", LogERROR);
	else
		app.writeLog("Found camVoyage " &amp; camVoyage.voyage &amp; " for voyage = " &amp; _voyVoyageCode &amp; ".", LogWARN);
	endif;
	
	camMessage := camVoyage.camMessages[_messageType];
	
	if camMessage = null then
		create camMessage transient;
		camMessage.activity	:= _messageType;
		camMessage.camVoyage := camVoyage;
		camVoyage.camMessagesByTiId.add(camMessage);
		_camFile.camMessageByActivityVoyage.add(camMessage);
		
		app.writeLog("Creating " &amp; self.getMessageTypeString(_messageType) &amp; " message for voyage " &amp; camVoyage.voyage &amp; ".", LogWARN);
	else
		app.writeLog("Found " &amp; self.getMessageTypeString(_messageType) &amp; " message for voyage " &amp; camVoyage.voyage &amp; ".", LogWARN);
	endif;

	return camMessage;
end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_opVoyageCode" type="String"/>
        <Parameter name="_voyVoyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_messageType" type="Integer"/>
        <Parameter name="_singleMessage" type="Boolean"/>
        <ReturnType type="CM_CamMessage"/>
    </JadeMethod>
