<Class name="CMIF_TMCResourceContractGroup" id="830b7abd-e9fb-423d-a3d1-c2f18939df44">
    <superclass name="CMIF_TMCGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="myDebtor" id="18ea0a32-6428-4363-a38b-3b75abc20a47">
        <embedded/>
        <type name="CM_DebtorNode"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myDebtorMap" id="25fa276f-2dff-45c2-955d-469bbb946f7b">
        <embedded/>
        <type name="CM_DebtorMap"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myQuantityRangeMap" id="ffd6a80b-8f7d-40e6-b771-288c91b8db93">
        <embedded/>
        <type name="CM_QuantityRangeMap"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myServiceBroker" id="a312ebed-5e66-48d7-b947-a812f4336bad">
        <embedded/>
        <type name="CM_ResourceServiceBroker"/>
    </ImplicitInverseRef>
    <JadeMethod name="getItemLevel" id="e77c7bb8-7596-4ed8-8876-2f2cc107a8bf">
        <source>getItemLevel(): Integer;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return CMIF_TranMapController.TM_Level_06_Contract;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="a178c238-c1a4-4daf-8924-294e6fc95fab">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin
	myTMCController.isContractIn := false;
	myTMCController.isContractOut := false;
	
	myTMCController.myCurrentMapQuantityRange := self.myQuantityRangeMap;
	
	if self.myDebtorMap &lt;&gt; null then
		myTMCController.myCurrentMapTMVoyage := self.myDebtorMap.myServiceBroker.CM_ResourceServiceBroker.myTransMap;
		myTMCController.myCurrentMapDebtor := self.myDebtorMap;
		myTMCController.myCurrentMapServiceBroker := self.myDebtorMap.myServiceBroker;
		myTMCController.myCurrentMapQuantity := myTMCController.myCurrentMapDebtor.myChildQuantityMap;
	else
		myTMCController.myCurrentMapTMVoyage := self.myServiceBroker.CM_ResourceServiceBroker.myTransMap;
		myTMCController.myCurrentMapServiceBroker := self.myServiceBroker;
		myTMCController.myCurrentMapQuantity := myTMCController.myCurrentMapServiceBroker.myChildQuantityMap;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="c5a974b6-eb6a-4df0-9200-79946eb790d3">
        <source>setEnableObjects(form: INV_TransactionMap io);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(form);

	form.menuTMVnew.visible := true;  // MAIN VTMIS NEW MENU
	form.menuSItemNew.visible := false;  // MAIN CARGO NEW MENU	
	form.mnuTMExport.visible := false;
	form.menuMappingSetActive.visible := false;
	form.modePropertyNew := INV_TransactionMap.ModeProperty_Invoice;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Invoice;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_Debtor;
	form.mnuSItemUpdate.visible := true;

	form.menuSItemProperties.visible := true;
	form.btnProperties.enabled := true;

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="9788728f-73a5-4bc6-800e-779e86362aec">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	form.myTMCContractIN := null;
	form.myTMCContractOUT := null;
	
	form.myCurrentMapQuantityRange := self.myQuantityRangeMap;
	
	if self.myDebtorMap &lt;&gt; null then
		form.myCurrentMapTMVoyage := self.myDebtorMap.myServiceBroker.CM_ResourceServiceBroker.myTransMap;
		form.myCurrentMapDebtor := self.myDebtorMap;
		form.myCurrentMapServiceBroker := self.myDebtorMap.myServiceBroker;
		form.myCurrentMapQuantity := form.myCurrentMapDebtor.myChildQuantityMap;
	else
		form.myCurrentMapTMVoyage := self.myServiceBroker.CM_ResourceServiceBroker.myTransMap;
		form.myCurrentMapServiceBroker := self.myServiceBroker;
		form.myCurrentMapQuantity := form.myCurrentMapServiceBroker.myChildQuantityMap;
	endif;

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
