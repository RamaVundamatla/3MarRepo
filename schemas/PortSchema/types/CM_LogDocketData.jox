    <JadeMethod name="archiveSelf" id="7b0d1a0e-eb02-4d7e-8087-0d3caecf529b">
        <updating/>
        <source>archiveSelf(_bol : CM_BOL) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2003		cnwth2	
//
// Purpose:     
// 02 Nov 2016	cnwma1		TFS #2892:PAR38364 C3 - CreateLogDocket Webservice	 
// ----------   ----------  --------------------------------------------------

vars
	bol : CM_BOL;
begin
	if _bol = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'CM_BOL was null trying to archive weighbridge object');
		return;
	endif;

	bol := _bol;   				//04/11/2016 cnwma1 TFS #2892
	if self.myBol &lt;&gt; _bol then  //04/11/2016 cnwma1 TFS #2892
		bol.setLogDocketData(null);
	endif;
	//self.myBol := _bol;			//04/11/2016 cnwma1 TFS #2892
	self.myBol := bol;             //04/11/2016 cnwma1 TFS #2892
	self.myTerminal := null;      //04/11/2016 cnwma1 TFS #2892

end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
