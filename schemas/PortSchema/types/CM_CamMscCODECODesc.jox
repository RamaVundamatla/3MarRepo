    <JadeMethod name="availableTransactions" id="6bbdc681-323e-4ea2-9e36-f5d0c9a908b2">
        <source>availableTransactions(_classColl: ClassColl input);
//
//cnwrs1 CCMS 1826 29 July 2010
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed parameter usage from io to input
vars

begin
	inheritMethod(_classColl);
	_classColl.add(CM_Damage);	//cnwrs1 CCMS 1826 29 July 2010
	_classColl.add(CM_Repair);
	_classColl.add(CM_Wash);	//cnwrs1 15 Aug 2011 par 27945
	_classColl.add(CM_PreTrip);
	_classColl.add(CM_DairyBoard);	//cnwrs1 par 28644 10 nov 2011
	_classColl.add(CM_NeedsWash);	//par 28043 cnwrs1 19 Aug 2011
	_classColl.add(CM_NeedsPreTrip);
	_classColl.add(CM_NeedsDairyBoard);	//cnwrs1 par 28644 10 nov 2011
end;
</source>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
    </JadeMethod>
