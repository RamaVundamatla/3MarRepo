        <Parameter name="pLdapHost" type="String"/>
        <Parameter name="pMyEmailBaseRoot" type="CnEcEmailRoot"/>
        <Parameter name="pCnEcEmailBaseDataNew" type="CnEcEmailBaseData" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
