    <JadeMethod name="setupContextMenuItems" id="5dded00a-8a97-486f-8cdf-f5d220ab569b">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
/* -----------------------------------------------------------------------------------------------------------
// Created:     21 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------

// Changed On   Changed By  				Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 		Remove unused auto plan flags
// 11/08/2011	cnwdap1		PAR #27972 		Bulk release types no longer translatable, replaced by string constants
// 31/08/2018   jlgka1		TFS# 39694 		To Allow Rail Pre Notes the option to Receive Cargo.
 -----------------------------------------------------------------------------------------------------------*/
vars
	tmpMenu	: MenuItem;

	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	
	inheritMethod(conwin);
	
	//if self.viewTransportMode = app.getErrorString(BR_TYPE_DESCR_ROAD) and // cnwrd1 par 18519 6.3.09	// PAR #27972
	if (self.viewTransportMode = BR_TYPE_ROAD_STR or self.viewTransportMode = BR_TYPE_RAIL_STR)  and // cnwrd1 par 18519 6.3.09							// PAR #27972
	   conwin = tblData and 
	   tblData.row &gt; tblData.fixedRows and
	   app.myCurrentUserCan(self.myTerminal, PmPreNoteReceiveCargo) then	//+cnwml2 PAR24989
		self.mnuContextReceive.visible := true;
		
		// TFS 2198 CNWAB1
		if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			self.mnuContextReceive.visible := false;
		endif;

		
	else
		self.mnuContextReceive.visible := false;
	endif;
	
	self.mnuTestAP.visible := true;

	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_TrackedItem) then
		self.mnuTestAP.userObject := self.myCurrentObject;
		//self.mnuTestAP.caption :='Test Auto Plan ' &amp; self.myCurrentObject.CM_TrackedItem.id &amp; " ...";
		//self.mnuTestAP.translateCaption(Test_autoplan, locale);
		self.mnuTestAP.caption :=  app.getErrorString(Test_autoplan)  &amp; ' ' &amp; self.myCurrentObject.CM_TrackedItem.id &amp; '...';
	endif;
	
	//26 Aug 2009	NDL	CCMS 1609 Par 20521
	self.mnuBookRefDiscrep.visible := true;
	self.mnuBookRefDiscrep.caption := app.getErrorString(Show_booking_referen_discrep) &amp; "...";
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuBookRefDiscrep, false);
	
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuTestAP, false);
	
	// Putting first menu second so it works?
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuContextReceive, false);

	// TFS 2198 CNWAB1
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		//cnwmc5
		self.mnuSetReceiveType.visible := true;
		tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSetReceiveType, false);

	endif;
	

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b1930f4a-612b-40e7-b512-22477a5f46cc">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
23 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
08 December 2014    cnwma1  PAR #35327 Problem when selecting 45G1 for the ISO type
*/
	
vars
	imex	: CM_IMEXStatus;
	idx		: Integer;
	
begin
	// cnwrl1 236/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	// The user can access the summarise functionality only if they have at least view security role.
	self.bAllowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	self.cmbISOType.sorted := true;		//08/12/2014 cnwma1 PAR #35327   	
	self.cmbOperator.sorted := true;	//08/12/2014 cnwma1 PAR #35327
	self.cmbVoyage.sorted := true;		//08/12/2014 cnwma1 PAR #35327	
	inheritMethod();
	
	//+cnwml2 PAR23668
	if self.myTerminal.getConfig(NoPINs).Boolean then
		self.tblSearch.hideRowByName(ETRow_FilterPIN, false);
	else
		self.tblSearch.showRowByName(ETRow_FilterPIN, false);
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
