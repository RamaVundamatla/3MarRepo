<Class name="CM_Terminal">
    <JadeMethod name="exportAttrIgnorePDXML" id="f3695272-96d1-430f-b317-6a9ad7f4cd14">
        <source>exportAttrIgnorePDXML(_attrName:String) :Boolean;

vars

begin
	if _attrName = CM_Terminal::portLogo.name or
	   _attrName = CM_Terminal::jmtLogo.name then
		return true;
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
