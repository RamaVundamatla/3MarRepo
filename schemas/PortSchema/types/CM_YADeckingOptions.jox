    <JadeMethod name="pxyCreateUpdateProxy" id="b593746d-2f9b-484c-869d-9cf04f6993c4">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		26 April 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	deckingRule,
	pxyDeckingRule	: CM_YADeckingRule;
	pxyOptions		: CM_YADeckingOptions;
	completedOK		: Boolean;
begin
	pxyOptions := inheritMethod();
	
	self.allYALocationCellsIn.copy(pxyOptions.allYALocationCellsIn);
	self.allYALocationCellsOut.copy(pxyOptions.allYALocationCellsOut);
	
	//want proxy decking rules as well
	//IN
	foreach deckingRule in self.allDeckingRulesIn do
		pxyDeckingRule := deckingRule.pxyCreateUpdateProxy();
		pxyOptions.allDeckingRulesIn.add(pxyDeckingRule);
	endforeach;
	//OUT
	foreach deckingRule in self.allDeckingRulesOut do
		pxyDeckingRule := deckingRule.pxyCreateUpdateProxy();
		pxyOptions.allDeckingRulesOut.add(pxyDeckingRule);
	endforeach;	
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyOptions;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyOptions;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="reverseLocnCellsIn" id="badde9b1-5ce9-4fc5-a00e-cd5338c31bfe">
        <source>reverseLocnCellsIn(_theRow: CM_GridRow);
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	pointArray	: PointArray;
	locnCell	: CM_YALocationCell;
	point		: Point;
	maxX		: Integer;
	lcArray		: CM_YALocationCellArray;
begin

	create pointArray transient;
	foreach locnCell in self.allYALocationCellsIn do
		point := locnCell.getRowCoordinate();
		if point.x &gt; maxX then
			maxX := point.x;
		endif;
		pointArray.add(point);
	endforeach;
	
	create lcArray transient;
	//transform point array and create new order
	foreach point in pointArray do
		point.setX((maxX+1)-point.x);
		locnCell := _theRow.getLocnCellAtCoord(point);
		if locnCell &lt;&gt; null then
			lcArray.add(locnCell);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, "can't find locnCell at Coordinate " &amp; point.display);
		endif;
		
	endforeach;
	
	//apply
	self.allYALocationCellsIn.clear;
	lcArray.copy(self.allYALocationCellsIn);

epilog
	delete 	pointArray;
	delete 	lcArray;
end;</source>
        <Parameter name="_theRow" type="CM_GridRow"/>
    </JadeMethod>
    <JadeMethod name="reverseLocnCellsOut" id="b82d1c78-ae4a-4cec-8632-3bb7e2e8d355">
