	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	
	prenote := self.getTrackedItem(Prenote1);
