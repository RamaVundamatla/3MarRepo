    <JadeMethod name="doMnuStops" id="ffa1d2b9-e389-4f76-9955-7f6c3b279e28">
        <updating/>
        <source>doMnuStops( menuItem : MenuItem input ) updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// Changed On   Changed By  Reason
// 28/01/2010	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
// 16/06/2010	CNWCS5		PAR 24342 - new form for stops maintenance
// ---------------------------------------------------------------------------
	
vars
	lTI			: CM_TrackedItem;
	
begin
	// just maintains the last ti selected
	lTI := menuItem.userObject.CM_TrackedItem;
	
	self.myAssistant.showStopsForm_TI (lTI, null, app.getMyUser.canUpdateStops( self.myTerminal) );	//cnwrd1 par 29440 27.4.2012
	
	return;
	
/*	app.mousePointer	:= Busy;						// cnwrl1 27/01/2010 PAR 21889
	
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuStops then
		return;
	endif;
	
	// cnwrl1 27/01/2010 PAR 21889 - start of coding
	// NOTE: This reproduces the release 7.7.3 behaviour - ie it only handles the last TrackedItem clicked on.
	create tiSet transient;
	stopsTable	:= app.myRoot.allStopsTable[ menuItem.index ];
	while true do : update_TrackedItems
		self.myAssistant.contextMenuTIsStop( stopsTable, lTI, tiSet );
		
		if app.myPassport.noErrors then
			self.clearErrorWarnings();
			return;
		endif;
		result	:= app.showErrorWarningDialog(	app.getString( EWD_Cannot_Continue, app.getString( HeadingSaved ) ),
												app.myPassport,
												ErrWarnMode_Add + ErrWarnMode_CanAckWarnings );
		if app.myPassport.noErrors and result = IDOK then
			app.myPassport.warningsAcknowledged	:= true;
			continue update_TrackedItems;
		endif;
		self.setAllErrorWarnings( app.myPassport );	// copies errors to this form and shows in err/warnings window
		return;
	endwhile update_TrackedItems;*/
	// cnwrl1 27/01/2010 PAR 21889 - end of coding
	
	/* cnwrl1 28/01/2010 PAR 21889 - what it was
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuStops then
		return;
	endif;
	
	create lStops transient;
	create tiSet transient;			// cnwrl1 12/05/2009 PAR 19574 - CCMS 1791
	
	lStops.add(menuItem.index);
//	if lTI.getStopByID(menuItem.index) = null then	// cnwrl1 14/12/2009 PAR 21889 - what it was
	if not lTI.isStopSet( menuItem.index ) then
		// cnwrl1 12/05/2009 PAR 19574 - CCMS 1791 - start of coding
		tiSet.add( lTI );
		app.myTrxCA.trxCreateStopsForTIs( tiSet, lStops, app.myPassport );
//		app.myTrxCA.trxCreateStops(lTI, lStops, aOK, app.myPassport);	what it was
		// cnwrl1 12/05/2009 PAR 19574 - CCMS 1791 - end of coding
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog('Grid Area Form', app.myPassport, ErrWarnMode_Add);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	else
//		stopTable := lTI.getStopByIDAsAtDate(menuItem.index).myStopsTable;	// cnwrl1 11/01/2010 PAR 21889 - what it was
		stopTable := lTI.getStopByIDAsAtDate( menuItem.index, null ).myStopsTable;
		// cnwrl1 11/05/2009 PAR 19574 - CCMS 1791 - what it was
		if stopTable.requiresInfo then
			self.processStopInfo(lTI, stopTable, lStops);
		else
			app.myTrxDA.trxDeleteStops(lTI, lStops, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog(app.getErrorString(Cargo_Enquiry), app.myPassport, ErrWarnMode_Update);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	endif;
	
	menuItem.checked := not menuItem.checked;
	
epilog
	delete lStops;
	delete tiSet;
	mousePointer := MousePointer_Default;
end;
	cnwrl1 28/01/2010 PAR 21889 - end of what it was */
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskAdd" id="a945a1d9-dd0c-49f5-9d0c-b33d2194c9e5">
        <updating/>
        <source>doMnuTaskAdd(menuItem : MenuItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------

vars
	lTI	: CM_TrackedItem;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815

begin
	if menuItem = mnuTaskAdd then
		return;
	endif;
	
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null then
		return;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskAdd(lTI, menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskComplete" id="8c0edc64-2ed0-49ac-a8db-15b11f4489c4">
        <updating/>
        <source>doMnuTaskComplete(menuItem : MenuItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------

vars

	lTI	: CM_TrackedItem;
	realTiSet : CM_TISet;
	pxyTiSet : CM_TISet;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	toDoTaskDesc : CM_ToDoTaskDesc;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815

begin

	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuTaskComplete then
		return;
	endif;
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[menuItem.index];
	
	create realTiSet transient;
	realTiSet.add(lTI);

	//+cnwml2 MSL CCMS 1017
	create pxyTiSet transient;
	
	//31 Dec 2009 NDL CCMS MES 1006	- Common code migrated up to assistant
	if not self.myAssistant.doTaskProxySetForComplete( menuItem.index, pxyTiSet, lTI, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('GridArea Form', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
		
epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;
	
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuUnconfirmOutClick" id="5321c644-c475-490d-a0e5-2877e10b2743">
        <updating/>
        <source>doMnuUnconfirmOutClick(_menuItem : MenuItem) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagon		: CM_Wagon;
	theReturn			: Integer;
begin
	wagon := _menuItem.userObject.CM_Wagon;
	if wagon = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWagonConfirmOut(null, wagon, false, app.myPassport);

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog('Outward Wagon Confirmation', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

end;





</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
