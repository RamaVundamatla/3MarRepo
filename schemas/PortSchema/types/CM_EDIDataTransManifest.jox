    <JadeMethod name="getVoyageCode" id="8fa0af32-e310-4a55-99d0-c8f9f1f6799a">
        <source>getVoyageCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2024	navhn30	Initial creation

*/

vars

begin
	if self.myCargoOnSite &lt;&gt; null then
		return self.myCargoOnSite.getVoyageCode();
	elseif self.myGateDocument &lt;&gt; null then
		return self.myGateDocument.getVoyageCode();
	elseif self.myShipManifest &lt;&gt; null then
		return self.myShipManifest.getVoyageCode();
	elseif self.myTrainConsist &lt;&gt; null then
		return self.myTrainConsist.getVoyageCode();
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageETA" id="b32fc072-0c02-4824-a254-cc23765a038d">
        <source>getVoyageETA(): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2025	navsaa30	Initial creation
24/1/25 navsaa30 EUP | FR 54871 - EDI Message Administration Advanced Filters not working
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.estimatedArrivalDT.date;
		endif;
	endif;
	return null;
epilog

end;
</source>
        <ReturnType type="Date"/>
