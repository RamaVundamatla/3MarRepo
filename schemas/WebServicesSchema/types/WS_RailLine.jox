    <JadeMethod name="delete" id="75c469e4-9267-4f7b-bcf1-d7a7cc246f20">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2017	cnwsc8	Initial creation

*/

vars

begin
	if self.allIncompleteWLEs &lt;&gt; null and not self.allIncompleteWLEs.isEmpty() then
		self.allIncompleteWLEs.purge();
	endif;
	if self.allWagons &lt;&gt; null and not self.allWagons.isEmpty() then
		self.allWagons.purge();
	endif;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setNotifiedConfirmedCounts" id="aa8dff76-dac7-4866-b668-61dbcb053560">
        <updating/>
        <source>setNotifiedConfirmedCounts(railLine : CM_RailLine; train : CM_Train; inward : Boolean) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	iter 		: Iterator;
	wagon 		: CM_Wagon;
	wagonTis 	: CM_TIArray;
	confirmed, 
	forTrain	: Boolean;
begin
	if train = null or railLine = null then
		return;
	endif;
	
	iter:=railLine.allWagons.createIterator();
	
	create wagonTis transient;
	
	while iter.next(wagon) do
		if wagon = null then
			continue;
		endif;
		if inward then
			if wagon.myTrainInwards = train then
				forTrain:=true;
			endif;
			
		else
			if wagon.myTrainOutwards = train then
				forTrain:=true;
			endif;
		endif;
		
		confirmed:=false;
		self.wagonNotified:=self.wagonNotified +1;
		if inward then
			
			confirmed:=  wagon.confirmed;
		else
			confirmed:= wagon.confirmedOutwards;
		endif;
		if confirmed then
			self.wagonConfirmed:=self.wagonConfirmed+1;
		endif;
		wagonTis.clear();
		wagon.getAllTrackedItems(inward, wagonTis, false);
		self.cargoNotified:=self.cargoNotified + wagonTis.size;
		if confirmed then
			self.cargoConfirmed:=self.cargoConfirmed + wagonTis.size;
		endif;		
	
	endwhile;
	
	if not forTrain then
		self.wagonNotified:=0;
		self.wagonConfirmed:=0;
		self.cargoConfirmed:=0;
		self.cargoNotified:=0;
	endif;
	
	
epilog
	delete wagonTis;
	delete iter;
end;</source>
        <Parameter name="railLine" type="CM_RailLine"/>
        <Parameter name="train" type="CM_Train"/>
        <Parameter name="inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="c4cf23b5-681b-4cb5-93a1-5bedc2d6a97f">
        <updating/>
        <source>setProxyFromObject(_railLine: CM_RailLine) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2017	cnwsc8	Initial creation
30 Jun 2022			jlika1 TFS 53971 - MTN - Rail Confirm App to React
*/

vars
	wsWagon 	: WS_Wagon;
	wsWle		: WS_RailWLE;
	wagon 		: CM_Wagon;
	wle			: CM_WorkListEntry;
begin
	inheritMethod(_railLine);
	
	self.maximumWagons := _railLine.maximumWagons;
	self.id := _railLine.id;
	self.description:=_railLine.getFullId();
	
	/*
	foreach wagon in _railLine.allWagons do
		if wagon = null then
			continue;
		endif;
		create wsWagon transient;
		wsWagon.setProxyFromObject(wagon);
		self.allWagons.add(wsWagon);
	endforeach;

	foreach wle in _railLine.allIncompleteWLEs discreteLock do
		if wle.isKindOf(CM_YardWLE) then
			create wsWle transient;
			wsWle.setProxyFromObject(wle.CM_YardWLE);
			self.allIncompleteWLEs.add(wsWle);
		endif;
	endforeach;	
	*/
	
epilog

end;</source>
        <Parameter name="_railLine" type="CM_RailLine"/>
    </JadeMethod>
</Class>
