        <methodInvocation>mapping</methodInvocation>
        <source>vTranslationCount(set: Boolean; _value: Integer io) mapping;

vars

begin
	if set then
		// read only
	else
		_value := allXlatTranslationsByCatNumber.size;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
