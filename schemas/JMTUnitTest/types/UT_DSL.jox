    <JadeMethod name="updateRORORehandle" id="865cb49d-9f73-4640-8694-1349139b59fa">
        <source>updateRORORehandle(_roroLCs : CM_LCArray; _moveType : Integer; _isLoad : Boolean);
/*
Purpose:		28968	
Date		Who		Reason
30 April 2012	NAVAB1	Initial creation
*/

