    <JadeMethod name="setHazards" id="6f257cb7-deff-4443-b29c-9306fea49101">
        <updating/>
        <source>setHazards(_tmpHazards: CM_HazardByCodeDict) updating;
/*
	Created on 11 January 2008
	
	by Debby Hutchison
	
	Purpose: Copied from CM_BookingRef for CCMS 1618
*/
/* Changes

Date		Name	TFS#		Description
============================================================================
27/05/2019	jlgka1	TFS 43346	LNX - Multiple Hazardous Details with same Hazardous Class.
============================================================================*/
vars
	haz		: CM_Hazard;
	tiHaz	: CM_TIHazard;
begin
	
	self.raiseExceptionIfTransient(method);
	
	self.allTIHazards.purge;

	if _tmpHazards.isEmpty then
		return;
	endif;
	
	foreach haz in _tmpHazards do
		if app.myPassport.myTerminal.getConfig(UseBookingSummView).Boolean then
			if self.myBookingReference.allTIHazards[haz.code] = null then
				continue;
			endif;
		endif;
		
		create tiHaz persistent;
		tiHaz.setForCreate(haz, null, app.myPassport);
		self.allTIHazards.add(tiHaz);
	endforeach;
	

end;</source>
        <Parameter name="_tmpHazards" type="CM_HazardByCodeDict"/>
    </JadeMethod>
