    <JadeMethod name="getDefTextIntToStr" id="b4b96be2-3e42-4eed-935e-e9c03f9751f9">
        <source>getDefTextIntToStr(_context : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			 Reason
12 October 2022	navhl20	 ChangeRequest 53424: MTN - MOB - Input Remarks - Jade
27 February 2023 navdp20 ChangeRequest 56847:[56848] EUP | Outturn Remarks on BOL - Predefined Text
*/

vars

begin
	if _context = DefText_WPPrenote then
		return DefText_WPDescPrenote;
	elseif _context = DefText_WPReleaseRequest then
		return DefText_WPDescReleaseRequest;
	elseif _context = DefText_WPBookings then
		return DefText_WPDescBookings;
	elseif _context = DefText_WPVehBooking then
	return DefText_WPDescVehicleBooking;
	elseif _context = DefText_WPCargoNotifReq  then
		return DefText_WPDescCargoNotifReq;
	elseif _context = DefText_WPCargoUpdateReq then
		return   DefText_WPDescCargoUpdateReq;
	elseif _context = DefText_WPVoyageRequest  then
		return DefText_WPDescVoyageRequest;
	elseif _context = DefText_WPInvRejection   then
		return DefText_WPDescInvRejection;
	elseif _context = DefText_MOBAssignTask    then
		return  DefText_MOBDescAssignTask;  
	elseif _context = DefText_MOBCompleteTask  then
		return  DefText_MOBDescCompleteTask;     
	elseif _context = DefText_MOBCargoMaint	   then
		return DefText_MOBDescCargoMaint;
	elseif _context = DefText_MOBDelaysVoyage  then
		return DefText_MOBDescDelayVoyage;
	elseif _context = DefText_MOBDelayMachine  then
		return DefText_MOBDescDelayMachine;
	elseif _context = DefText_MTNBolOutturn  then 		//27.02.2023 navdp20 #56847[56848]
		return  DefText_MTNDescBolOutturn; 				//27.02.2023 navdp20 #56847[56848]
	endif;
epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefTextStrToInt" id="070b1115-8d4b-4959-bf82-8718ac9a541c">
        <source>getDefTextStrToInt(_str : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		 Reason
12 October 2022	navhl20	 ChangeRequest 53424: MTN - MOB - Input Remarks - Jade
27 February 2023 navdp20 ChangeRequest 56847:[56848] EUP | Outturn Remarks on BOL - Predefined Text
*/

vars

begin
	if DefText_WPDescPrenote = _str then
		return DefText_WPPrenote;
	elseif DefText_WPDescReleaseRequest = _str then
		return DefText_WPReleaseRequest;
	elseif DefText_WPDescBookings =  _str then
		return DefText_WPBookings;             
	elseif DefText_WPDescVehicleBooking = _str then
		return DefText_WPVehBooking;   
	elseif DefText_WPDescCargoNotifReq = _str then
		return DefText_WPCargoNotifReq;        
	elseif DefText_WPDescCargoUpdateReq = _str then
		return DefText_WPCargoUpdateReq;        
	elseif DefText_WPDescVoyageRequest = _str then
		return DefText_WPVoyageRequest; 
	elseif DefText_WPDescInvRejection = _str then
		return DefText_WPInvRejection;    
	elseif DefText_MOBDescAssignTask  = _str then
		return DefText_MOBAssignTask;      
	elseif DefText_MOBDescCompleteTask = _str then
		return DefText_MOBCompleteTask;        
	elseif DefText_MOBDescCargoMaint = _str then
		return DefText_MOBCargoMaint;      
	elseif DefText_MOBDescDelayVoyage = _str then
		return DefText_MOBDelaysVoyage;        
	elseif DefText_MOBDescDelayMachine = _str then
		return DefText_MOBDelayMachine; 
    elseif DefText_MTNDescBolOutturn = _str then 	//27.02.2023 navdp20 #56847[56848]
		return DefText_MTNBolOutturn; 				//27.02.2023 navdp20 #56847[56848]		
	endif;
epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
