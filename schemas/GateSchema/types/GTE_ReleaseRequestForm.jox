    <JadeMethod name="cmbType_click" id="f459c1ce-d9f8-40dd-a3ae-8c8d6f17f921">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbType_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 22/02/2010	cnwcs5	Removed call to of app.getMyTerminalConfigDO_NOT_USE
// 16/02/2012	cnwcs5	CCMS POL 2151 / par 29137
// 17/01/2019	jlgzm1	TFS41961 getting 14025 when too many release requests
// ---------------------------------------------------------------------------
vars
	index : Integer;
	entDef : EntTableDef;
	carrier : CM_Carrier;		//cnwas3 par 24344
	table		: CM_EntryTable;
	reachedMaxSize : Boolean;
begin
	on Exception do app.handleUE14025(exception, reachedMaxSize);
	
	table 		:= self.tblSearch;
	
	self.setIgnoreFilterType (false);	// par 29137
	
	self.typeMode := self.cmbType.text;
	
	if (not self.myTerminal.getConfig(GateRelNoSearchText).Boolean) then			// 25/02/2010 cnwcs5
		//fill release number search box
		self.myAssistant.comboBoxBulkRelByTypeStatus(cmbBulkRelease, self.cmbType.text, self.cmbView.text, null);
		//if oversize, switch combobox to textbox
		if reachedMaxSize then
			table.hideRowByName(ETRow_ReleaseNoCmb, false);
			table.showRowByName(ETRow_FiltReleaseNo, false);
			self.relNoSearchByText := true;
			self.cmbBulkRelease.clear();
		else
			table.hideRowByName(ETRow_FiltReleaseNo, false);
			table.showRowByName(ETRow_ReleaseNoCmb, false);
			self.relNoSearchByText := false;
		endif;
	endif;
	
	self.setNavigatorHeading(self.typeMode);
	
	// CCMS 1412
	self.setEnableObjects();

	index := self.getIndexForXmlStrTblDataArray();

	if index = BR_TYPE_ROAD then
		self.xmlStrTblData := self.xmlRoad;
	elseif index = BR_TYPE_RAIL then
		self.xmlStrTblData := self.xmlRail;
	elseif index = BR_TYPE_SHIP then
		self.xmlStrTblData := self.xmlShip;
	elseif index = BR_TYPE_PACKING then
		self.xmlStrTblData := self.xmlPack;
	elseif index = BR_TYPE_UNKNOWN then
		self.xmlStrTblData := self.xmlUnknown;
	elseif index = BR_TYPE_BOL then
		self.xmlStrTblData := self.xmlAll;
	endif;

	entDef := app.myController.getEntTableDef(ETDef_MTReleaseDataTable);

	if self.xmlStrTblData &lt;&gt; null then
		self.tblData.setTblDataEntRowsFromXML(entDef, self.xmlStrTblData);	
	else	
		self.tblData.setTblDataEntRowsFromDef(entDef);
	endif;
	
	if self.cmbFiltCarrier.listObject &lt;&gt; null then												//cnwas3 par 24344 begin
		carrier := self.cmbFiltCarrier.listObject.CM_Carrier;
	endif;
	
	self.myAssistant.comboBoxCarrierTransportMode(self.cmbFiltCarrier, carrier, self.cmbType.text);//cnwas3 par 24344 end
	
	self.setFilterValues();
	//TH2 PAR 11857 -  collection too large to show in table	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbView_click" id="07249693-a5b9-4c00-ae7d-c547bf73fe21">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbView_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     19 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/02/2012	cnwcs5		Use terminal references from form
// 16/02/2012	cnwcs5		CCMS POL 2151 / par 29137
// 17/01/2019	jlgzm1		TFS41961 getting 14025 when too many release requests
// ---------------------------------------------------------------------------
vars
	table		: CM_EntryTable;
	reachedMaxSize : Boolean;
begin
	on Exception do app.handleUE14025(exception, reachedMaxSize);
	
	table 		:= self.tblSearch;
	
	self.setIgnoreFilterStatus (false);	// par 29137
	
	self.setFilterValues();

	self.viewStatusMode := cmbView.text;
	if (not self.myTerminal.getConfig(GateRelNoSearchText).Boolean) then
		//fill release number search box
		self.myAssistant.comboBoxBulkRelByTypeStatus(cmbBulkRelease, self.cmbType.text, self.cmbView.text, null);
		//if oversize, switch combobox to textbox
		if reachedMaxSize then
			table.hideRowByName(ETRow_ReleaseNoCmb, false);
			table.showRowByName(ETRow_FiltReleaseNo, false);
			self.relNoSearchByText := true;
			self.cmbBulkRelease.clear();
		else
			table.hideRowByName(ETRow_FiltReleaseNo, false);
			table.showRowByName(ETRow_ReleaseNoCmb, false);
			self.relNoSearchByText := false;
		endif;
	endif;
	
	self.setNavigatorHeading(self.viewStatusMode);

	if self.canMaintainPending or self.canMaintainAll then
		// Need to check status to determine options
		if (self.viewStatusMode = BR_PENDING_STRING and (not self.canMaintainPending)) or
		   (self.viewStatusMode = BR_ACTIVE_STRING and (not self.canMaintainAll)) or
		   (self.viewStatusMode = BR_ARCHIVE_STRING and (not self.canMaintainAll)) or		   
		   (self.viewStatusMode = BR_COMPLETE_STRING and (not self.canMaintainAll)) then
			self.allowAdd 	 := false;
			self.allowUpdate := false;
		else
			self.allowAdd 	 := true;
			self.allowUpdate := true;
		endif;
	endif;
	
	// CCMS 1412
	self.setEnableObjects();
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="8442a2d2-698b-42e7-9396-59a9aba153f6">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
