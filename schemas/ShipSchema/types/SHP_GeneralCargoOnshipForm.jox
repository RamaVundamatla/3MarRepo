	*/
	//epr par 34857 17/11/14
//	self.myAssistant.comboBoxVoyageCurrent(self.cmbVoyages, app.getMyCurrentVoyage(),true,false,false,true,false,false,false,false,false);
	
	//25 Feb 2021	NDL	TFS 50836
