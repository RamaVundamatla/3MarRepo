    <JadeMethod name="alignDateField" id="2df03d96-84cf-4651-9a13-364f9ace7814">
        <source>alignDateField();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2011	cnwrd1	Initial creation

*/

vars
	isVisible : Boolean;
begin

	isVisible := self.cmbShifts.visible;
	
	if not isVisible then
		self.dtRequired.top := self.cmbShifts.top;
	endif;
	
	 self.cmbShifts.left := self.txtRequiredTime.getEmbeddedControl.left;
	 self.dtRequired.left := self.txtRequiredTime.getEmbeddedControl.left;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="btnAdvancedSrc_doAlignCtrls" id="d7703a1b-fb67-4f7f-98f1-1b6e7b71d473">
        <controlMethod name="CMUI_FieldGeneric::doAlignCtrls"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdvancedSrc_doAlignCtrls(_fieldGeneric: CMUI_FieldGeneric input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2011	cnwrd1	Initial creation

*/

vars

begin
	self.btnAdvanced.move(self.btnAdvancedSrc.width - self.btnAdvanced.width, 0, self.btnAdvanced.width, self.btnAdvanced.height);
	self.txtYardSource.move(self.btnAdvancedSrc.width - self.btnAdvanced.width - self.txtYardSource.width -5, 0, self.txtYardSource.width, self.txtYardSource.height);
	
epilog

end;</source>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAdvancedSrc_doTabOrder" id="b9845a93-4fb6-4332-8a08-31a913e41ce1">
        <controlMethod name="CMUI_FieldGeneric::doTabOrder"/>
        <methodInvocation>event</methodInvocation>
        <source>btnAdvancedSrc_doTabOrder(_startTab: Integer):Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2011	cnwrd1	Initial creation

*/

vars
	tabOrder	: Integer;
begin

	tabOrder				:= _startTab;
	tabOrder 				:= tabOrder + 1;
	self.btnAdvanced.tabIndex 	:= tabOrder;
	return tabOrder;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startTab" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
