vars

begin
	self.myOtherTrackedItem:=pTI;

epilog

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="7c1c68a9-53c5-4834-a16f-bf612190b1e1">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(_set: Boolean; _value: String io) mapping;

// Created by cnwdvb1 on 15 November 2006

vars

begin
	
	if self.mode = PLANNING_MODE then

		if self.unplan then
			_value := "Unplanned";
		else
			_value := "Planned";
		endif;
	elseif self.mode = QUEUE_MODE then
		if self.unplan then
			_value := "Unqueue";
		else
			_value := "Queued";
		endif;
	else
		inheritMethod(_set, _value);
		
	endif;

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
