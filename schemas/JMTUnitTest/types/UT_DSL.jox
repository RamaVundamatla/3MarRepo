    <JadeMethod name="updateVessel" id="3bb18143-7680-4ba5-9852-c0c7b42c4526">
        <updating/>
        <source>updateVessel(_vessel : CM_Vessel) : CM_Vessel updating;

/*

Purpose:		Update Vessel details

Date			Who		Reason
23/01/2014		cnwmh5	Initial creation

*/

vars

	vesselProxy					: CM_Vessel;
	conflictManager				: CMIF_HMS_ConflictsManager;
	pxyVoyageAllocationConfig 	: CM_VoyageAllocationConfig;
	
	groupLabelCriteriaColl  	: CM_YACriteriaTypeArray;
	
	vesselCode					: String;

begin

	if _vessel = null then
		return _vessel;
	endif;

	beginLoad;
	vesselProxy := _vessel.pxyCreateUpdateProxy();
	endLoad;
	
	if self.opts.includesKey("VesselCode") then
		vesselProxy.setPropertyValue("code", self.opts.str("VesselCode"));
	endif;
	
	// 24/07/2015 cnwmh5
	if self.opts.includesKey("VoyageAllocationsCriteria") then
		create pxyVoyageAllocationConfig transient;
		create groupLabelCriteriaColl transient;
		pxyVoyageAllocationConfig.setProxyVoyage(self.opts.obj("VoyageAllocationsCriteria").CM_YACriteriaTypeArray,
			groupLabelCriteriaColl, Red, CM_YATypeCommodityGroup.firstInstance, null, null);
		vesselProxy.setVoyageAllocationConfig(pxyVoyageAllocationConfig);
	endif;
	
	// 24/07/2015 cnwmh5
	if vesselProxy.myOperator = null then
		vesselProxy.setPropertyValue("myOperator", app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString()]);
	endif;

	app.myTrxUA.trxUpdateVessel(vesselProxy, false, true, conflictManager, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	delete vesselProxy;
	delete pxyVoyageAllocationConfig;
	delete groupLabelCriteriaColl;

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="updateVesselROROConfig" id="bfa76a1e-7197-42aa-8fa9-957215b67edd">
        <source>updateVesselROROConfig(_vessel : CM_Vessel io; _allStateData : CM_StateDataDict; _fieldNameArray, _valueArray : StringArray);

/*

Purpose:		Save the Vessels RORO Config

Date			Who		Reason
08/08/2014		cnwmh5	Initial creation

*/

vars
	
	stateData 					: CM_StateData;
	proxyStateData 				: CM_StateData;
	class						: Class;
	parent						: Object;
	
	allProxyStateData 			: CM_StateDataDict;
	
	index						: Integer;
	value						: String;
	
begin

	create allProxyStateData transient;
	
	foreach index in 1 to _fieldNameArray.size do
	
		stateData := _allStateData[_fieldNameArray[index]];

		if stateData &lt;&gt; null then
			beginLoad;
			proxyStateData := stateData.pxyCreateUpdateProxy();
			endLoad;
			if _valueArray &lt;&gt; null then
				value := _valueArray[index];
			endif;
		else
			if _valueArray = null then
				value := null;
			else	
				value := _valueArray[index];
			endif;
			
			if _fieldNameArray[index] = "RoRoLaneNumberLength" or _fieldNameArray[index] = "RoRoAutoGenerateStartEnd" or 
					_fieldNameArray[index] = "RoRoLocationNumberLength" then
				class := global.getDataClass(value.Integer);
			elseif _fieldNameArray[index] = "RoRoLaneWidth" or _fieldNameArray[index] = "RoRoLaneLength" or 
					_fieldNameArray[index] = "RoRoLaneGap" or _fieldNameArray[index] = "RoRoLocationWidth" or 
					_fieldNameArray[index] = "RoRoLocationLength" or _fieldNameArray[index] = "RoRoLocationGap" then		
				class := global.getDataClass(value.asDecimalJMT());
			else
				class := global.getDataClass(value.asStringJMT());
			endif;
			create proxyStateData as class transient;	
			
		endif;
		
		if _vessel &lt;&gt; null then
			parent := _vessel;
		else
			parent := app.myRoot;
		endif;
		
		proxyStateData.set(_fieldNameArray[index], value, parent);
		
		allProxyStateData.add(proxyStateData);
	
	endforeach;
	
	app.myTrxUA.trxUpdateConfigAllStateData(allProxyStateData, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete proxyStateData;
	allProxyStateData.purge();
	delete allProxyStateData;

end;
</source>
        <Parameter name="_vessel" type="CM_Vessel" usage="io"/>
        <Parameter name="_allStateData" type="CM_StateDataDict"/>
        <Parameter name="_fieldNameArray" type="StringArray"/>
        <Parameter name="_valueArray" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="updateVesselTankContentType" id="66f2d477-ed65-4b14-a0ca-de6c68dfb4cb">
        <source>updateVesselTankContentType(_code : String);
/*
Date		    Who			Reason
19 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	pxyVesselTankContentType,vesselTankContentType 	: CM_VesselTankContentsType;
	initialCode,initialDescription,initialRemarks 	: String;
	initialAvailability 							: Boolean;
begin
	vesselTankContentType := self.getVesselTankContentType(_code);
	
	if vesselTankContentType &lt;&gt; null then
		
		initialCode := vesselTankContentType.code;
		initialDescription := vesselTankContentType.description;
		initialRemarks := vesselTankContentType.remarks;
		initialAvailability := vesselTankContentType.isAvailableForEntry;
		
		pxyVesselTankContentType := app.createUpdateProxy(vesselTankContentType).CM_VesselTankContentsType;
				
		pxyVesselTankContentType.setProxyForTankContentsType(initialCode &amp; '1',initialDescription &amp; '1',initialRemarks &amp; '1',not initialAvailability,app.myRoot);
		
		app.myTrxUA.trxUpdateVesselTankContentType(pxyVesselTankContentType, app.myPassport);
		
		self.assertNoTrxErrorsOrWarnings();
		
		self.assertEqual(initialCode &amp; '1',pxyVesselTankContentType.code);
		self.assertEqual(initialDescription &amp; '1',pxyVesselTankContentType.description);
		self.assertEqual(initialRemarks &amp; '1',pxyVesselTankContentType.remarks);
		self.assertEqual(not initialAvailability,pxyVesselTankContentType.isAvailableForEntry);		
						
	endif;
epilog
	if pxyVesselTankContentType &lt;&gt; null then
		delete pxyVesselTankContentType;
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageHMS" id="534e78ad-2a9a-4a4e-92b3-1fd274e8357b">
        <source>updateVoyageHMS(_voyage : CM_Voyage; _netRegTonnes : Integer; _grossRegTonnes : Integer; _lengthOverall : Decimal; _beam : Decimal; _deadWeight : Integer; _draftMid : Decimal);
// update HMS data for voyage invoicing - 
//
/****Changes

Date		Name	TFS#			Description
============================================================================
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/

vars
	proxyVoyage : CM_Voyage;
	pxyHMSVoyage : HMS_VoyageData;
	conflictManager : CMIF_HMS_ConflictsManager;
begin
	if _voyage = null then
		return;
	endif;
	beginLoad;
	proxyVoyage := _voyage.pxyCreateUpdateProxy();
	endLoad;

	pxyHMSVoyage := proxyVoyage.myHMSVoyageData;
	if pxyHMSVoyage = null then
		create pxyHMSVoyage transient;
		proxyVoyage.setHMSVoyageData(pxyHMSVoyage);
	endif;

	proxyVoyage.setProxyVoyage(	_voyage.bitmap,
							_voyage.callSign,
							_voyage.code,
							_voyage.inwardCode,
							_voyage.remarks,
							_voyage.vesselCode,
							_voyage.vesselName,
							_voyage.lloydsNumber,
							_voyage.archived,
/* PAR 33644							_voyage.isNonPlannedVoyage,
							_voyage.isNonWorkedVoyage, */
							_voyage.isTransferable,
							_voyage.starboardBerthed,
							_voyage.craneClearance,
							_voyage.displayOption,
							_voyage.colour,
							_voyage.status,
							_voyage.vesselType,
							_voyage.archivedDT,
							_voyage.arrivedDT,
							_voyage.departedDT,
							_voyage.loadStartDT,
							_voyage.loadEndDT,
							_voyage.nonPlannedEffectiveDT,
							_voyage.cutOffDT,
							null,
							null,
							_voyage.myOperator,
							_voyage.myTrade,
							_voyage.myShippingLine,
							_voyage.myTerminal,
							_voyage.myVoyageGlobalArrival,
							null,
							null,
							null,
							null,
							null,
							_voyage.voyageNumber,
							_voyage.overrideDefaults,
							_voyage.allOperators,
							null,
							_voyage.useVoyageAllocations,
							_voyage.externalRef,
							null,
							null,
							null,
							null,
							_draftMid,
							null,
							null,
							null,null,
							null,null,
							null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
							null,		// TFS 4050
							_voyage.paymentType,
							_voyage.isBarge, 			//jlgka1 TFS 37102
							_voyage.voyageGroupCode,     //03/06/2020 cnwma1 Tfs #49400
							false	// 31.Aug.2023 navsp1 TFS 57809
							);					
	
	pxyHMSVoyage.setPropertyValue("dim_GrossRegTonnes", _grossRegTonnes);
	pxyHMSVoyage.setPropertyValue("dim_NetRegTonnes", _netRegTonnes);
	pxyHMSVoyage.setPropertyValue("dim_LengthOverall", _lengthOverall);
	pxyHMSVoyage.setPropertyValue("dim_Beam", _beam);
	pxyHMSVoyage.setPropertyValue("dim_DeadWeight", _deadWeight);

	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateVoyage(true,false,proxyVoyage,conflictManager,null,false,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	endLoad;
	delete proxyVoyage;
	delete conflictManager;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_netRegTonnes" type="Integer"/>
        <Parameter name="_grossRegTonnes" type="Integer"/>
        <Parameter name="_lengthOverall" type="Decimal"/>
        <Parameter name="_beam" type="Decimal"/>
        <Parameter name="_deadWeight" type="Integer"/>
        <Parameter name="_draftMid" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageJob" id="2efc3c8b-ffb0-4643-bf54-5a5230b7b90e">
        <source>updateVoyageJob(_voyageJob : CM_VoyageJob io);

/*

Purpose:		Update Voyage Job

Date			Who		Reason
17/02/2014		cnwmh5	Initial creation

*/

vars

	pxyJob						: CM_VoyageJob;
	theJobParams 				: CMIF_VoyageJobParams;
	
	remarks						: String;

begin

	if _voyageJob = null then
		return;
	endif;
	
	beginLoad;
	pxyJob := _voyageJob.pxyCreateUpdateProxy();
	
	
	create theJobParams transient;
	theJobParams.useNewMethod := true;
	theJobParams.myVoyage := pxyJob.myVoyage;
	theJobParams.myProxyJob := pxyJob;
	theJobParams.craneID := _voyageJob.craneId;
	theJobParams.myWorkPoint := _voyageJob.getMyWorkPointObject().CM_WorkPoint;
	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
		if remarks = null then
			theJobParams.myProxyJob.setRemarks(class.name &amp; '::' &amp; method.name);
		else	
			theJobParams.myProxyJob.setRemarks(remarks);
		endif;
	endif;

	app.myTrxUA.trxUpdateVoyageJob(theJobParams, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete pxyJob;
	delete theJobParams;

end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageStatus" id="e1cdcb91-1e70-4950-b2a1-1abcb2ac03c2">
        <source>updateVoyageStatus(_status : Integer; _voyage : CM_Voyage);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navsp1	Initial creation TFS#53956

*/

vars
	voyage : CM_Voyage;
begin
	voyage	:= _voyage;
	if _status &lt;&gt; null and _voyage &lt;&gt; null then
		app.myTrxUA.trxUpdateVoyageVoyageStatus(voyage, _status,false,app.myPassport);
	endif;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="updateWPOpHrs" id="138f2848-abff-4c03-ab5d-763249ae739b">
        <source>updateWPOpHrs(_wpOpHrs : CM_WorkPointOperatingHours);

/*

Purpose:		Update Work Point Operating Hours

Date			Who		Reason
18/02/2014		cnwmh5	Initial creation

*/

vars

	pxyWpOpHrs					: CM_WorkPointOperatingHours;
	
	remarks						: String;
	user : CM_User;
begin

	remarks := _wpOpHrs.remarks;
	if self.opts.includesKey("Remarks") then
		remarks := remarks &amp; self.opts.str("Remarks");
	endif;

	///create pxyWpOpHrs transient;
	beginLoad;
	pxyWpOpHrs := _wpOpHrs.pxyCreateUpdateProxy();
	endLoad;
	pxyWpOpHrs.setProxy(_wpOpHrs.exchangeStart, 
		_wpOpHrs.exchangeEnd, 
		_wpOpHrs.labourStart, 
		_wpOpHrs.labourEnd, 
		remarks,
		_wpOpHrs.myCrane,
		_wpOpHrs.myWorkPoint,
		_wpOpHrs.myVoyage,
		_wpOpHrs.myUser);
	
	app.myTrxUA.trxUpdateWpOperatingHrs(pxyWpOpHrs, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	delete pxyWpOpHrs;

end;</source>
        <Parameter name="_wpOpHrs" type="CM_WorkPointOperatingHours"/>
    </JadeMethod>
    <JadeMethod name="updateWagonMaster" id="0271beca-b0f3-4eaf-9920-87793a2ebb1c">
        <source>updateWagonMaster(_wagonMaster : CM_WagonMaster);

/*

Purpose:		Update Wagon Master

Date			Who		Reason
25/05/2015		cnwmh5	Initial creation

*/

vars

	pxyWagonMaster			: CM_WagonMaster;

begin

	if _wagonMaster = null then
		return;
	endif;
	
	beginLoad;
	pxyWagonMaster := _wagonMaster.pxyCreateUpdateProxy();
	endLoad;
	
	if self.opts.includesKey("PropogatesChanges") then
		pxyWagonMaster.setPropertyValue("propogateChanges", self.opts.int("PropogatesChanges"));
	endif;
	
	app.myTrxUA.trxUpdateWagonMaster(pxyWagonMaster, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete pxyWagonMaster;
end;</source>
        <Parameter name="_wagonMaster" type="CM_WagonMaster"/>
    </JadeMethod>
    <JadeMethod name="updateYABlock" id="11701cf0-e563-4c15-a860-2cc00e88ab1b">
        <source>updateYABlock(_yaBlock: CM_YABlock io);
//20 November 2008	cnwdw1	
//
vars
	proxyYABlock: CM_YABlock;
begin
	proxyYABlock := app.createUpdateProxy(_yaBlock).CM_YABlock;
	if self.opts.includesKey("MinHeight") then
		proxyYABlock.setMinMaxHeight(self.opts.int("MinHeight"), self.opts.int("MaxHeight"));
	endif;
	if self.opts.includesKey("Open") then
		proxyYABlock.openBlock();
	endif;
	if self.opts.includesKey("Close") then
		proxyYABlock.closeBlock();
	endif;
	app.myTrxUA.trxUpdateYABlock(proxyYABlock, _yaBlock, app.myPassport);
	checkTrxResult();
epilog
	delete proxyYABlock;
end;</source>
        <Parameter name="_yaBlock" type="CM_YABlock" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateYABlocks" id="af0d6e2f-fff2-4f18-9038-792bbd42fcfc">
        <source>updateYABlocks(_ya: CM_YardAllocation; _locations: ObjectArray);
//08 February 2009	cnwdw1	
//
vars
	yaAgent: CM_YAAgent;
begin
	create yaAgent transient;
	yaAgent.updateYALocations(_ya, _locations,null);
	self.assertNoTrxErrorsOrWarnings;

epilog
	delete yaAgent;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_locations" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="updateYAPriority" id="7cbae1e6-6891-4c43-86f3-a0b6eedd9eb9">
        <source>updateYAPriority(_ya: CM_YardAllocation input; _priority: Integer);
//20 November 2008	cnwdw1	
//
vars
	proxyYA: CM_YardAllocation;
	proxyCriterias: CMIF_Array;
begin
	proxyYA := app.createUpdateProxy(_ya).CM_YardAllocation;

	proxyYA.setPriorityAdjustment(_priority);
	create proxyCriterias transient;
	app.myTrxUA.trxUpdateYardAllocation(proxyYA, proxyCriterias, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	assertTrue(_ya.allCriteria.size &gt; 0);
epilog
	delete proxyYA;
	delete proxyCriterias;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation" usage="input"/>
        <Parameter name="_priority" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateYARailConfig" id="b5893d59-51ac-48cc-aa13-df277f60900f">
        <source>updateYARailConfig(_yaRailConfig : CM_YARailConfig);

/*

Purpose:		Update yaRailConfig

Date			Who		Reason
15/04/2014		cnwmh5	Initial creation

*/

vars

	opCriteria				: CM_YACriteriaTypeArray;
	pxyRailConfig			: CM_YARailConfig;
	
	loadState				: Boolean;
	
begin

	if _yaRailConfig = null then
		return;
	endif;
	
	create opCriteria transient;
	if self.opts.includesKey("OpCriteria") then
		self.opts.obj("OpCriteria").CM_YACriteriaTypeArray.copy(opCriteria);
	else	
		_yaRailConfig.allOpCriteria.copy(opCriteria);
	endif;
	
	app.cmsBeginLoad(loadState);
	pxyRailConfig := _yaRailConfig.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	pxyRailConfig.setProxyRail(opCriteria, _yaRailConfig.allGroupLabelCriteria, _yaRailConfig.colour, 
		_yaRailConfig.myYACriteriaTypeForColour, _yaRailConfig.myDefaultColourType);
	
	app.myTrxUA.trxUpdateYAIMEXConfig(pxyRailConfig, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	app.cmsEndLoad(loadState);

	delete opCriteria;
	delete pxyRailConfig;

end;</source>
        <Parameter name="_yaRailConfig" type="CM_YARailConfig"/>
    </JadeMethod>
    <JadeMethod name="userConfigCargoLoad" id="d67111d9-334d-49cb-8690-104583cbe3d1">
        <source>userConfigCargoLoad(_text : String; _userDefinedName : String);
// Aug 2011		cnwjre1

vars
	loadFile : File;
	fileName : String;
	la 		 : CM_ExtractLoadAgent;
begin

	fileName := "CC_LOAD " &amp; _userDefinedName &amp; ".csv";
	fileName.replaceChar(' ', '_');
	create loadFile transient;
	loadFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	loadFile.openOutput(fileName);
	loadFile.writeString(_text);
	loadFile.close;
	
	loadFile.mode := File.Mode_Input;

	create la;
	la.loadUserCargoConfig(loadFile);

epilog
	delete loadFile;
	delete la;
end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_userDefinedName" type="String"/>
    </JadeMethod>
