    <JadeMethod name="finalizeBackgroundCopy" id="245661aa-631f-4448-8b41-8e6ebe5c02e3">
        <updating/>
        <source>finalizeBackgroundCopy() updating;
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad2
//
// Purpose:		Finalizes the Background Copy application.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.myServiceObject;
	self.finalize();
end;</source>
    </JadeMethod>
