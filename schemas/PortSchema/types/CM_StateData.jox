// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myStateObject := pStateObject;

end;</source>
        <Parameter name="pStateObject" type="CM_StateObject"/>
    </JadeMethod>
