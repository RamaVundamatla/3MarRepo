    <JadeMethod name="isFeatureForSubClass" id="d1b90692-73f4-48ce-a9d9-240a9bd1d8db">
        <source>isFeatureForSubClass(_featureName: String) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

vars
	subClasses : ClassColl;
	cls : Class;
	
begin
	create subClasses transient;
	self.getRealSubClasses(subClasses, false);
	
	foreach cls in subClasses where
			self.getFeatureForClass(cls, _featureName) &lt;&gt; null do
		return true;
	endforeach;
	
	return false;
	
epilog
	delete subClasses;
end;</source>
        <Parameter name="_featureName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateFeature" id="733fd7ac-e37f-47d0-8315-767472285e8b">
        <source>pxyCreateFeature(_fieldName: String; _field : CM_DataExtractField) : CM_DataExtractField;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	#cnwdz2	 

*/

vars
	newField : CM_DataExtractField;

begin
/*
	create field transient;
	field.setProxy(_fieldName, _field);
	field.setDataExtractClass(self);
	
	return field;
	*/
	newField := _field.createTransientFieldWithName(_fieldName);
	newField.setDataExtractClass(self);
	return newField;
end;</source>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_field" type="CM_DataExtractField"/>
        <ReturnType type="CM_DataExtractField"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="be49d229-68da-4ff3-8ded-80baa4698d05">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	#cnwdz2	 

*/

vars
	pxyClass      : CM_DataExtractClass;
	realFeature, 
	pxyFeature    : CM_DataExtractField;
	completedOK	  : Boolean;
	
begin
	pxyClass := inheritMethod;
	
	foreach realFeature in self.allDataExtractFields do
		pxyFeature := realFeature.pxyCreateUpdateProxy;
		pxyFeature.setDataExtractClass(pxyClass);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyClass;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyClass;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
