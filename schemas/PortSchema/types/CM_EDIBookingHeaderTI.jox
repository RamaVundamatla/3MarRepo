    <JadeMethod name="getDisplayStringForAttribute" id="28ac2aba-5a9c-4457-b68c-af80072652ac">
        <source>getDisplayStringForAttribute( _attrName : String; _short : Boolean ) : String;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
vars
	
begin
	if _attrName = ETRow_BookingRemarks then
		return self.bookingRemarks;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;
</source>
        <Parameter name="_attrName" type="String"/>
