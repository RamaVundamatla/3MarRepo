    <JadeMethod name="includeObject" id="864a0751-03c6-4d17-ba07-a04506a9a12a">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation

*/

vars

begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return _obj.CM_VesselTankContentsType.isAvailableForEntry;
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
