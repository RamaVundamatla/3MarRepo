    <JadeMethod name="performExport" id="413bc048-d7c5-482c-98aa-00c9d3cb3311">
        <source>performExport() protected;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	inputFileName		: String;
	noidFileName		: String;
	errorFileName		: String;
	logFileName			: String;
	outputFileName		: String;
	hubbleId			: String;
	formatName			: String;
	oidTableRootObj		: CnEcOidTable;
	formatDataArrayObj	: ObjectArray;
	hubbleObj 			: CnEcHubble;
	display				: String;
	className			: String;
	instanceObj			: Object;
	formatObj			: CnEcXmlFormat;
	formatClassObj		: CnEcXmlFormatClass;
	classObj			: Class;
	superClassObj		: Class;
	isSkip				: Boolean;
	
begin
	app.mousePointer := Busy;
	
	if (not self.checkExportScreenData()) then
    	return;
 	else
 		lblInstruct.caption := "";   	
	endif;
	
	inputFileName 	:= "";
	noidFileName	:= txtInputNoid.text;  
	errorFileName 	:= txtHubbleId.text;
	
	if txtError.text.trimBlanks &lt;&gt; null then
		errorFileName 	:= txtError.text.trimBlanks();
	endif;
	
	logFileName 	:= txtLog.text;
	outputFileName 	:= txtInput.text;
	hubbleId 		:= "";
	formatName 		:= cmbInputFormat.text;
	
	display := "Started at " &amp; app.actualTimeServer().Time.String &amp; ".  ";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	lblInstruct.caption := display;
	self.doWindowEvents(0);
	
	create formatDataArrayObj transient;

	formatObj := app.myBaseRoot.getXmlFormat(app.myCnEcXmlSchema.name, formatName);
	
	if app.isValidObject(formatObj) then
		foreach formatClassObj in formatObj.allFormatClasses do
			if formatClassObj.isShowTagData then
				className := formatClassObj.className;
				
				if className = "Class" then
					continue;
				endif;
				
				classObj := app.myCnEcXmlSchema.getClass(className);
				
				if classObj &lt;&gt; null then
					superClassObj := classObj.getSuperclass();
					
					if superClassObj &lt;&gt; null then
						if superClassObj.name = CnEcExtractLoad.name
						or superClassObj.name = CnEcXML.name
						or superClassObj.name = Global.name
						or superClassObj.name = Ocx.name
						then
							continue;
						else
							isSkip := false;
							
							while superClassObj.getSuperclass &lt;&gt; null do
								superClassObj := superClassObj.getSuperclass;
								
								if superClassObj.name = CnEcExtractLoad.name
								or superClassObj.name = CnEcXML.name
								or superClassObj.name = Global.name
								or superClassObj.name = Ocx.name
								then
									isSkip := true;
								endif;
							endwhile;
							
							if isSkip then
								continue;
							endif;	
						endif;
					endif;

					foreach instanceObj in classObj.instances do
						formatDataArrayObj.add(instanceObj);
					endforeach;
								
				endif;
			endif;
		endforeach;
	endif;

	display := display &amp; CrLf &amp; formatDataArrayObj.size().String &amp; " objects being extracted.";
	lblInstruct.caption := display &amp; " - " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.doWindowEvents(0);

	create oidTableRootObj transient;
	
	create hubbleObj transient;
	
	hubbleObj.initializeMe(	errorFileName,
							inputFileName,
							noidFileName,
							logFileName,
							outputFileName,
							formatName,
							oidTableRootObj,
							formatDataArrayObj);
	
	lblInstruct.caption := display &amp; CrLf &amp; "Hubble exporting...." &amp; " - " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.doWindowEvents(0);
	
    if formatDataArrayObj.size() &lt; 1000 then
    	hubbleObj.export(0,false);
 	else
 		hubbleObj.export((formatDataArrayObj.size() div 10),false);
 	endif;   	   	
    
    lblInstruct.caption := display &amp; CrLf &amp; "Hubble exporting complete, deleting transients...." &amp; " - " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.doWindowEvents(0);        
epilog
	delete formatDataArrayObj;
	delete oidTableRootObj;
	delete hubbleObj;
	display := display &amp; CrLf &amp; "Hubble Completed - " &amp; app.actualTimeServer().String; // 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.mousePointer := Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="performImport" id="42b255e6-84c8-4934-8fbe-331e11982500">
        <source>performImport() protected;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	inputFileName	: String;
	noidFileName	: String;
	errorFileName	: String;
	logFileName		: String;
	outputFileName	: String;
	hubbleId		: String;
	formatName		: String;
	fileKind 		: Integer;
	oidTableObj		: CnEcOidTable;
	hubbleObj 		: CnEcHubble;
	displayMessage	: String;

begin
	app.mousePointer := Busy;
	
	if (not self.checkImportScreenData()) then
    	return;
 	else
 		lblInstruct.caption := "";   	
	endif;
	
	inputFileName 	:= txtInput.text;
	noidFileName	:= txtInputNoid.text;  
	errorFileName 	:= txtHubbleId.text;
	
	if txtError.text.trimBlanks &lt;&gt; null then
		errorFileName 	:= txtError.text.trimBlanks();
	endif;
	
	logFileName 	:= txtLog.text;
	hubbleId 		:= txtHubbleId.text;
	formatName 		:= cmbInputFormat.text;
	fileKind		:= cmbInputKind.itemData[cmbInputKind.listIndex];

	create hubbleObj transient;

	hubbleObj.initializeMe(	errorFileName,
							inputFileName,
							noidFileName,
							logFileName,
							outputFileName,
							formatName,
							oidTableObj,
							null);	
	
	hubbleObj.setMyOidTable(hubbleId);
	
	if txtObjectsPer.text.trimBlanks &lt;&gt; "" and txtObjectsPer.text.Integer &gt; 1 then
		hubbleObj.setObjectsPerTrx(txtObjectsPer.text.Integer);
	endif;

    displayMessage := "Started at " &amp; app.actualTimeServer().Time.String &amp; ".  ";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
    
    if noidFileName &lt;&gt; "" then
    	lblInstruct.caption := displayMessage &amp; CrLf &amp; "currently 'Loading NOID's ";
    	self.doWindowEvents(0);
    	hubbleObj.loader(CNEC_DATA_LOAD_NOID, fileKind);
    	displayMessage := displayMessage &amp; "Processing of 'Noid's completed at " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
    	lblInstruct.caption := displayMessage &amp; ".  " &amp; CrLf &amp; "Currently 'Loading Primary attribute's.";
    else
    	lblInstruct.caption := displayMessage  &amp; CrLf &amp; "Currently 'Loading Primary attribute's.";	  	
    endif;
    
    self.doWindowEvents(0);
   	hubbleObj.loader(CNEC_DATA_LOAD_ATTRIBUTE, fileKind);
   	
   	if noidFileName &lt;&gt; "" then
   		displayMessage := displayMessage &amp; ", 'Primary attribute's at " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
   	else
   		displayMessage := displayMessage &amp; "Processing of 'Primary attribute's completed at " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
   	endif;
   	
   	lblInstruct.caption := displayMessage &amp; "." &amp; CrLf &amp; "Currently 'Loading Singleton's.";
    self.doWindowEvents(0);  
  	hubbleObj.loader(CNEC_DATA_LOAD_SINGLETON, fileKind);
  	displayMessage := displayMessage &amp; ", 'Singleton's at " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
  	
  	lblInstruct.caption := displayMessage &amp; "." &amp; CrLf &amp; "Currently 'Loading Collection's.";
    self.doWindowEvents(0);
	hubbleObj.loader(CNEC_DATA_LOAD_COLLECTION, fileKind);
	displayMessage := displayMessage &amp; ", 'Collection's at " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	lblInstruct.caption := displayMessage &amp; "." &amp; CrLf &amp; "Currently 'running Epilogue's.";
    self.doWindowEvents(0);
	hubbleObj.epilogue();
	displayMessage := displayMessage &amp; " and 'Epilogue's at " &amp; app.actualTimeServer().Time.String &amp; ".";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	lblInstruct.caption := displayMessage;
	hubbleObj.deleteMyOidTable(hubbleId);
epilog
	app.mousePointer := Idle;
	delete hubbleObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateInputKind" id="c7e50b68-1b82-4322-b1e8-7c82947865f3">
        <source>populateInputKind() protected;

begin
	cmbInputKind.clear();
	cmbInputKind.itemData[cmbInputKind.addItem("ANSI text file (default)")] := 2; //2 Kind_ANSI	
	cmbInputKind.itemData[cmbInputKind.addItem("Unicode text file")] := 3; //3 Kind_Unicode
	cmbInputKind.listIndex := 1;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectFile" id="37d3b163-3ad4-49a2-b2db-5bb30964917b">
        <updating/>
        <source>selectFile(pTextBox : TextBox io) updating, protected;

vars
 	fileOpenObj	: CMDFileOpen;
 	textboxObj	: TextBox;
 	
begin
	textboxObj	:=	pTextBox;
	create fileOpenObj transient;
	
	if fileOpenObj.open() = 0 then
		textboxObj.text := fileOpenObj.fileName;
	else
		textboxObj.text := "";
	endif;
epilog
	delete fileOpenObj;	
end;</source>
        <access>protected</access>
        <Parameter name="pTextBox" type="TextBox" usage="io"/>
    </JadeMethod>
    <JadeMethod name="txtError_dblClick" id="0534c82f-46af-4946-a475-a8a54a29ac8b">
        <controlMethod name="TextBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtError_dblClick(textbox: TextBox input) updating;

vars
	textboxObj : TextBox;
	
begin
	app.mousePointer	:=	Busy;
	textboxObj := textbox;
	self.selectFile(textboxObj);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
