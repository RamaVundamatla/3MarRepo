    <JadeMethod name="doTxtDescrLostFocus" id="c69c2830-54dd-4fed-9977-4e7cfc0e9e5a">
        <updating/>
        <source>doTxtDescrLostFocus() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	populate code text with a suggested and unique code from the description entered

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	suggestedCode,
	descr		: String;
	consign		: CM_ConsigneeConsignor;
	
begin
	self.lblInfoSuggest.visible := false;
	if self.txtCode.text.trimBlanks &lt;&gt; null then
		return;
	endif;
	
	descr := self.txtDescr.text.trimBlanks;
	if descr = null then
		return;
	endif;

	//search for existing description
	consign := app.myRoot.allConsigneeConsignorsForDescr[descr];

	if consign &lt;&gt; null then
		self.txtDescr.text := consign.description.trimBlanks;
		self.txtCode.text := consign.code.toUpper.trimBlanks;
		self.lblInfoSuggest.caption := '(description already exists)';
		self.lblInfoSuggest.visible := true;
		return;
	endif;
	
	//suggest an unused code
	suggestedCode := descr.getSuggestedCode();
	if suggestedCode = null then
		self.txtCode.text := null;
		return;
	endif;
	
	suggestedCode := suggestedCode.makeUniqueCodeForDict(app.myRoot.allConsigneeConsignors);
	if suggestedCode &lt;&gt; null then
		self.txtCode.text := suggestedCode;
		self.lblInfoSuggest.caption := '(automatically suggested)';
		self.lblInfoSuggest.visible := true;
	endif;
	
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="687d7198-b969-45d5-8cd3-61ac4f7a8a73">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	mainForm		: Form;
begin
	inheritMethod();
	
	mainForm := app.mainForm;
	if mainForm &lt;&gt; null then
		self.left := (mainForm.width /2) - (self.width /2);
		self.top := 300;
	endif;
		
	

end;


</source>
    </JadeMethod>
    <JadeMethod name="saveConsign" id="5498414e-df83-455f-af6f-54fb50c831a4">
        <updating/>
        <source>saveConsign() : Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute
03 Aug 2017	cnwma1		TFS #5209:PEN - Release Request Stop
*/
vars
	newConsign,
	pxyConsign		: CM_ConsigneeConsignor;
	result			: Integer;
begin
	self.myNewConsign := null;
	
	newConsign := app.myRoot.allConsigneeConsignorsForDescr[self.txtDescr.text.trimBlanks()];
	if newConsign &lt;&gt; null then//just use this
		self.myNewConsign := newConsign;
		return true;
	endif;
	
	create pxyConsign transient;
	pxyConsign.setProxy(self.txtCode.text.trimBlanks.toUpper,
						self.txtDescr.text.trimBlanks,
						false,//not available
						false,//secure export partner
						null,//derogation number
						null,//email addresses
						null,//color
						null,//order No
						null,//group
						null,//debtor
						false,
						true,//is consignee
						true,//is consignor
						false,//is freight forwarder
						null,
						null,	//cnwmc5 - 19/12/2012 - HAT 2198 - license
						null,	//cnwmc5 - 19/12/2012 - HAT 2198 - expiryDate
						false,	// PAR #35895
					    false,
						false); // 3.8.2017 cnwma1 TFS #5209
						
	while true do
		app.myTrxCA.trxCreateConsigneeConsignor(pxyConsign, newConsign, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.myNewConsign := newConsign;
			break;
		else
			result := app.showErrorWarningDialog('Consignee/Consignor creation', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;
	
	return true;
	
end;


</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
