<Class name="CM_Country">
    <JadeMethod name="exportMyCollectionsXML" id="fbff740e-d359-403a-ad59-9b544cc153c6">
        <source>exportMyCollectionsXML(_file: File; _objArray: ObjectArray io);

vars
	port: CM_Port;
begin
	//tis already loaded - just store their ID
	_file.writeLine('&lt;allPorts&gt;');
	foreach port in self.ports do
		_file.writeLine('&lt;code&gt;'&amp;port.code&amp;'&lt;/code&gt;');
	endforeach;
	_file.writeLine('&lt;/allPorts&gt;');
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="importMyCollectionsXML" id="2d966d78-3a09-453b-9879-095191aad9df">
        <updating/>
        <source>importMyCollectionsXML(_collectionsBlock: String) updating;

vars
	port: CM_Port;
	portsBlock, portCode: String;
	blockLength, pos: Integer;
	
begin
	portsBlock := _collectionsBlock.cnEcGetTagValueOfName(self.class.name &amp; 'allPorts');
	blockLength := portsBlock.length;
	pos := 1;
	
	while pos &lt; blockLength do
		portCode := portsBlock.cnEcGetNextTagValueOfName('code', pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if portCode = null then
			app.writeLog("Port Code missing.",0); 
			continue;
		endif;
		
		//port := app.myRoot.allPorts[portCode];
		port := app.myRoot.allPorts[portCode];
	
		if port &lt;&gt; null then
			self.ports.add(port);
		else
			app.writeLog("Port Code "&amp;portCode&amp;" not found.",0); 
		endif;
	endwhile;
end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
</Class>
