/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Aug 2021 navma1 ChangeRequest 51485: PRP - Multi-Roll Pickup Enhancement
*/
vars

begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); 

	app.setContinueCMExceptions(false);
	
	if _machine = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Machine is null.', null, null);
	endif;

	if _passport.hasErrors() then
		return;
	endif;
	

	beginTransaction;
	
	_passport.useTIDictDeferUpdate 		  := true;
	_passport.useTITransactionDeferUpdate := true;
	
	app.myUtilityUA.utlMachinePickupMultiTask(_machine,_allMoveItems ,_passport );
	
	_passport.doDeferredUpdates();

	
epilog
