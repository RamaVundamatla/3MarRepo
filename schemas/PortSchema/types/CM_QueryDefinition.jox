Type 2 = Booking Ref CM_QueryDefinition.BookRef_Query_Type
Type 4 = Transaction Query CM_QueryDefinition.Transaction_Query_Type
Type 99 = Snap Shot Summary CM_QueryDefinition.Snapshot_Query_Type
</text>
