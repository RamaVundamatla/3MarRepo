    <JadeMethod name="checkVBSSlot" id="f62f7360-f0bf-49de-9901-9817fb2e587a">
        <updating/>
        <source>checkVBSSlot(_vbt : CM_VehicleBookingTerminal; _pinCode : String; _vbsts : CM_VehicleBookingTimeSlot output) : Boolean protected, updating;
/*

Purpose:			Checks the VBS Slot has not been assigned to any other visit if the process is standard.
					Otherwise tries to get the timeslot by the pin and populates the form

Parameters:			_vbt		CM_VehicleBookingTerminal	The vehicle booking termianl to use to check against.
					_pinCode	String						The pincode to use if the process is slot type validation 
															can either be vehicle booking slot id or external reference
					_vbsts		CM_VehicleBookingTimeSlot	The vehicle booking timeslot to check

Return Value:		Boolean	Representing whther or not the timeslot is valid

Date		Who		Reason
11 May 2023	navpw1	Initial creation TFS: 54049 (55841)

*/

vars
	vbsProcess	: CM_VBSProcess;
	realVVR		: CM_VehicleVisitRecord;
	msg			: String;
	
begin
	vbsProcess := self.myVBSProcess;
	
	if _vbt &lt;&gt; null then
		_vbsts := _vbt.allVBTimeslotsById.getAtKey( _pinCode.trimBlanks.toUpper );
		
		if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation and _vbsts = null then
			_vbsts := _vbt.allVBTimeslotsByExtRef.getAtKey( _pinCode.trimBlanks.toUpper );
		endif;
		
		realVVR := self.myBulkGateAgent.myRealVVR;
		
		if vbsProcess &lt;&gt; null and vbsProcess.isVbsStandard 
			and realVVR &lt;&gt; null 
			and realVVR.myVehicleBookingTimeslot &lt;&gt; null
			and realVVR.myVehicleBookingTimeslot &lt;&gt; _vbsts 
		then
			msg := app.getErrorString1( Vehic_booki_times_alrea_been_a,  realVVR.myVehicleBookingTimeslot.id );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			return false;
		endif;
		
		if _vbsts &lt;&gt; null then
			self.populateFromVehicleBookingTS( _vbsts );
			self.myBulkGateAgent.myVehicleBookingTimeslot := _vbsts;       
		endif;
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_vbt" type="CM_VehicleBookingTerminal"/>
        <Parameter name="_pinCode" type="String"/>
        <Parameter name="_vbsts" type="CM_VehicleBookingTimeSlot" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkVehicleVisit" id="1b869520-949c-4022-953d-b45a3a0f139b">
        <updating/>
        <source>checkVehicleVisit(_vehicle : CM_Vehicle) : Boolean updating;
//
// Created:     09 December 2016 by cnwns1
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 
//
vars
	vvr : CM_VehicleVisitRecord;
	vvrIncomplete : Boolean;
	
begin
	vvr := _vehicle.getCurrentVisit();
	
	if vvr = null or vvr.status = CM_VehicleVisitRecord.Status_Complete or vvr.status = CM_VehicleVisitRecord.Status_Cancelled  then
		return false;
	endif;
	
	if not vvr.isBulkGateVVR then
		
		if self.txtRegno.visible then
			self.txtRegno.text := null.String;
		else
			self.cmbRegNo.listIndex := -1;
		endif;
	
		self.cmbCarrier.listIndex := -1;
		app.raiseCMException1(Vehicle_Visit__Not_Bulk_only,self.caption,"wrongGate", null);
		
		return false;
	endif;
		
	if self.getMyTerminal.getConfig(SiteHasSecurityGate).Boolean then
		vvrIncomplete :=  vvr.isIncompleteForSecurityGate;
	else
		vvrIncomplete :=  vvr.isIncomplete;
	endif;
	
	if   vvrIncomplete then
		self.txtVisitNumber.text := vvr.visitNumber;
		self.doQuery(vvr);
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearForm" id="1e6fd573-1c69-4a66-9ce7-015bd4d525cb">
        <updating/>
        <source>clearForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//08/06/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
// ---------------------------------------------------------------------------

vars
	gate : CM_Gate;
begin
	self.myBulkGateAgent.clearSavedWarnings();			
	self.enableFieldsAfterQuery(true);
	
	
	self.lblVisitType.caption := null;
	self.lblCargoId.caption := null;
	
	self.txtDriverCode.text := null;
	self.txtDriverCode.enabled := true;
	self.lblDriverCode.enabled := true;
	self.txtState.text := null;
	
	self.cmbCarrier.listIndex := -1;
	self.cmbSubCarrier.listIndex := -1;			//08/06/2022 navhl20 TFS 53430
	self.cmbDriver.clear;
		
	// When the form is cleared, set the gate combo to the gate recorded in user prefs.
	// If that fails, then set it to the default configured gate
	
	if not self.myBulkGateAgent.gateAndLaneSet or self.gateAndLaneSetFromVVR then
		self.myBulkGateAgent.getGateFromSetup();
		self.cmbGateLanes.clear();
		self.setDefaultGate();	
		self.gateAndLaneSetFromVVR := false;
	endif;	
	
	
	self.cmbInterchange.listIndex := -1;	
	self.cmbCargoTypes.listIndex := -1;		
	
	self.txtDriverName.text := null;
	self.txtDriverName.enabled := true; 
	self.lblDriverName.enabled := true;
	self.txtState.text := null;
	self.btnPrint.visible := false;

	self.txtVisitNumber.text := null;
	self.txtRegno.text := null;
	self.cmbRegNo.listIndex := -1;
	self.myBulkGateAgent.clearReferences();

	self.detailsChangedVehicle := false; 
	self.btnSave.enabled := app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);
	self.btnGetWeight.enabled := app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);
	self.txtDriverCode.setFocus();		
	self.txtRegno.setFocus();			
		
	self.setTxtPinToNullOrVbsId();
	
	self.txtWeightIN.text := null;																		
	self.txtWeightIN.setValues("" &amp; Space &amp; app.getDefaultMeasurementForType(Type_Weight).shortName);
	self.myAssistant.comboBoxRFIDTag( self.cmbRFID, self.myTerminal, null );	
	
	
	
	self.setDirectionLabel(0);
		
	self.resetFirstChange();
	
	//self.txtWeightIN.enabled := true;
	//19 Apr 2017	NDL	TFS 4126
	if  self.myWeightInterfaceController &lt;&gt; null and self.myWeightInterfaceController.hasValidConnection then
		self.txtWeightIN.setFieldsEnabled( self.allowManualWeight );	
	else
		//self.txtWeightIN.setFieldsEnabled( app.getMyUser.canDo(self.myTerminal,PmGteBulkInMaint) );
		self.txtWeightIN.setFieldsEnabled( self.allowManualWeight ); // After confirmation from Salman
	endif;
	
	//05 Dec 2017	NDL	TFS 7993
	self.txtWeightIN.row := 1;
	self.txtWeightIN.column := 1;
	self.allVehicleBookingTimeslots.clear();	// ### TFS 58164 29May2023 NAVPW1
epilog

end;</source>
    </JadeMethod>
