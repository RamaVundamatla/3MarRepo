    <JadeMethod name="initializeTwistLockReader" id="25341a40-01af-4ac8-9dc0-fcafcea18d79">
        <updating/>
        <source>initializeTwistLockReader() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtgAgent : VehicleMountedRTGAgent;
begin
	//self.beginNotification(process, EVENT_TWISTLOCK_TERMINATE, Response_Continuous, null);
	
	create myTwistLockReaderGUIAgent transient;
	rtgAgent:=self.myVehicleMountedRTGGuiAgent.myVehicleMountedRTGAgent;
	myTwistLockReaderGUIAgent.myTwistLockReaderAgent.setMyMachine(rtgAgent.myMachine);
