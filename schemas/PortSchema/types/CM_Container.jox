    <JadeMethod name="validateCubicMetres" id="26e1d0df-61ba-4e0e-9aad-ee4f7ad031a8">
        <source>validateCubicMetres(pControl : CMIF_TIUpdateController ) protected;
// ---------------------------------------------------------------------------
// Created:     05 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 Jul 2011	NDL		Par 27485 - Should be checking volume NOT totalVolume.
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pControl);

	if pControl.mode = TI_UPDMODE_RECEIPT or
	   pControl.mode = TI_UPDMODE_BOOKINGREF then
	//	if pCubicMetres &lt;&gt; NULL_VOLUME then
	//		if pCubicMetres &gt; 200 then
		if self.getMyTotalVolume &lt;&gt; NULL_VOLUME then
			if self.getMyTotalVolume &gt; 200 then
				app.raiseCMWarning2(WARN_LARGE_NUMBER, self.getMyTotalVolume.String, 'volume', 'volume', pControl.myUserObject, self);
			endif;
		endif;
	endif;

end;</source>
        <access>protected</access>
