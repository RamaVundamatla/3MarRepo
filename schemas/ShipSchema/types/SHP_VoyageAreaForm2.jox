    <JadeMethod name="doBuildMnuContainer" id="6755da54-19a7-4c76-9b64-c5bc6061c85e">
        <updating/>
        <source>doBuildMnuContainer(_theTI: CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Dec 2008	cnwkpd1		PAR #18664 - clean up transient leaks for performance
// 12 May 2010	cnwdap1		CCMS 1116 Tranship changes
// ---------------------------------------------------------------------------

vars
	tiArray: CM_TIArray;
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex,lMoveMode : Integer;
	lCaption 	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex,theAction 	: Integer;
	theLocn : CM_LocationsController;
	obj : Object;
begin
	self.mnuCargoSetGrade.visible := false;
	self.mnuRemarks.visible := false;
	self.mnuCargoCreateItem.visible := false; //ccms 1093 cnwrs1 Mar 2008
	
	if self.displayMode &lt;&gt; ShpDisplayMode_Actual
	and self.displayMode &lt;&gt; ShpDisplayMode_Proposed then
		return;
	endif;
	theLocn := _theTI.getPrimaryLocation(REAL_MODE);
	if theLocn = null then
		return;
	endif;
	lIndex := theLocn.getIndexOfTI(REAL_MODE,_theTI);
	if lIndex &lt; 1 then 
		return;
	endif;

	self.mnuCargo.visible := true;
	self.mnuCargoUnplan.visible := false; // TFS 2198 CNWAB1
	self.mnuCargoMoveIt.visible := false; // TFS 2198 CNWAB1
	
	// ##### ENQUIRE menu
	// PAR 21746
	if self.myCurrentDrawingController &lt;&gt; null and self.myCurrentDrawingController.allSelectedObjects.size &gt; 1 then
		mnuChild := self.mnuCargoEnquiry.getMenuItem(lIndex);
		if mnuChild = null then
			mnuChild := self.mnuCargoEnquiry.loadMenu(lIndex);
		
		endif;
		mnuChild.userObject := self.myCurrentDrawingController;
		mnuChild.caption := "Bulk Enquiry...";
		mnuChild.visible := true;
			
	else
		mnuChild := self.mnuCargoEnquiry.getMenuItem(lIndex);
		if mnuChild = null then
			mnuChild := self.mnuCargoEnquiry.loadMenu(lIndex);
		
		endif;
		mnuChild.userObject := _theTI;
		mnuChild.caption := "Enquiry " &amp; _theTI.id; //$SHP_Enquiry
		mnuChild.visible := true;
	endif;
	
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	self.mnuReturnToYard.visible := app.myCurrentUserCan(self.myTerminal, PmShipReturnCargo);
	
	create tiArray transient;
	self.mnuEditTransExp.visible := false;
	self.mnuEditTransExp.caption := null;
	
	self.mnuNonTrans.visible := false;
	self.mnuNonTrans.caption := null;
	if self.myBayDrawingController &lt;&gt; null then
		self.myBayDrawingController.getAllSelectedTIs(tiArray);	
		foreach obj in tiArray do
			//if obj.isKindOf(CM_TrackedItem) and obj.CM_TrackedItem.isTranshipItem and obj.CM_TrackedItem.myTranshipExport &lt;&gt; null then	// PAR #23645 CCMS 1116
			if obj.isKindOf(CM_TrackedItem) and obj.CM_TrackedItem.isTranshipItem then														// PAR #23645 CCMS 1116
				self.mnuNonTrans.visible := true;
				self.mnuNonTrans.caption := 'Make Selected Item(s) non Tranship';
				break;
			endif;
		endforeach;
	endif;
	
	self.mnuGridAreaContext.enabled := true;
	self.mnuGridSeperator01.visible := true;

	if self.displayMode = ShpDisplayMode_Actual then
		self.mnuTranship.visible := app.myCurrentUserCan(self.myTerminal, PmAdmCargoEnquiryView);
	endif;

	self.mnuCargo.visible := true;

	// ##### EDIT menu
	mnuChild := self.mnuCargoEdit.getMenuItem(lIndex);
	if mnuChild = null then
		mnuChild := self.mnuCargoEdit.loadMenu(lIndex);
	
	endif;
	mnuChild.userObject := _theTI;
	mnuChild.caption := "Edit " &amp; _theTI.id; //$SHP_Edit
	mnuChild.visible := true;


	// ###### ERASE menu
	mnuChild := self.mnuCargoErase.getMenuItem(lIndex);
	if mnuChild = null then
		mnuChild := self.mnuCargoErase.loadMenu(lIndex);
	
	endif;
	mnuChild.userObject := _theTI;
	mnuChild.caption := "Erase " &amp; _theTI.id; //$SHP_Erase
	mnuChild.visible := true;

	self.mnuCargoUnplan.userObject := _theTI;
	self.mnuCargoUnplan.visible := false;
	self.mnuCargoMoveIt.visible := false;
	self.mnuCargoLCL.visible := false;
	if _theTI.isKindOf(CM_Container) and
	   not _theTI.CM_Container.isEmpty() then //ccms 1093 cnwrs1 Mar 2008
		self.mnuCargoCreateItem.visible := true;
		self.mnuCargoCreateItem.userObject := _theTI;
	endif;
	
epilog
	delete tiArray;		// PAR #18664
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuZoom" id="91917b53-1f40-40eb-aa7e-c009cee27f8f">
