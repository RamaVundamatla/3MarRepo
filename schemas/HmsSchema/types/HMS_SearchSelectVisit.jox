    <JadeMethod name="setCriteriaForCurrentVoyage" id="dc9a1472-abf6-4ee2-a971-acd1571025e3">
        <updating/>
        <source>setCriteriaForCurrentVoyage() updating;
//Changed by cnwgd1 26 November 2004 as per VTMIS Report dated 18/10/04 - they only want the Vessel Feild populated
vars
/*	selectedShipType:		HMS_VesselType;
	selectedShipLinesCo:	CM_ShippingLine;
	selectedPilot:			HMS_Pilot;
	selectedAgent:			CM_ShippingAgent;
	selectedBerth : 		HMS_Berth;*/	
	posn:					Integer;
begin
	// Sets selection criteria for current voyage
	if self.currentVoyage = null then
		return;
	endif;

	// Get criteria for this movement
	//selectedShip:=currentMovement.myWorkingVoyage.ofVessel;
/*	selectedShipType  := self.currentVoyage.myHMSVoyageData.myVesselType;
	selectedShipLinesCo := self.currentVoyage.ofHmsShippingLine;
	selectedPilot := self.currentVoyage.myPilot;
	selectedAgent := self.currentVoyage.myShippingAgent;
	selectedBerth := currentMovement.myBerth;		//NFS 1011
*/
	// Look for criteria in combo lists

	// Look for ship name
	posn := self.cbxShipName.findObject(self.currentVoyage.getMyVessel());
	if posn &gt; 0 then
		self.cbxShipName.listIndex := posn;
		//self.cbxShipName.text := self.cbxShipName.itemText[self.cbxShipName.listIndex];
	endif;

	// Look for ship type
/*	posn := self.cbxShipType.findObject(selectedShipType);
	if posn &gt; 0 then
		self.cbxShipType.listIndex := posn;
		self.cbxShipType.text := self.cbxShipType.itemText[self.cbxShipType.listIndex];
	endif;

	// Look for shipping line
	posn := self.cbxShipLineCo.findObject(selectedShipLinesCo);
	if posn &gt; 0 then
		self.cbxShipLineCo.listIndex := posn;
		self.cbxShipLineCo.text := self.cbxShipLineCo.itemText[self.cbxShipLineCo.listIndex];
	endif;

	// Look for pilot
	posn := self.cbxPilot.findObject(selectedPilot);
	if posn &gt; 0 then
		self.cbxPilot.listIndex := posn;
		self.cbxPilot.text := self.cbxPilot.itemText[self.cbxPilot.listIndex];
	endif;

	// Look for agent
	posn := self.cbxAgent.findObject(selectedAgent);
	if posn &gt; 0 then
		self.cbxAgent.listIndex := posn;
		self.cbxAgent.text := self.cbxAgent.itemText[self.cbxAgent.listIndex];
	endif;

	//NFS 1011: Look for berth
	posn := self.cbxBerth.findObject(selectedBerth);
	if posn &gt; 0 then
		self.cbxBerth.listIndex := posn;
		self.cbxBerth.text := self.cbxBerth.itemText[self.cbxBerth.listIndex];
	endif;
	*/
end;</source>
