    <JadeMethod name="updateQueuedNoteInfo" id="2e177563-f518-4665-925b-807535c52148">
        <source>updateQueuedNoteInfo(_eventObject : Object; _event : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwer1	Initial creation

*/

vars

	dtoVehicleMountedInfo : DTO_VehicleMountedInfo;
begin
	if _eventObject = null then
		return;
	endif;
	//check if one exist for rt Queue Entry
	foreach dtoVehicleMountedInfo in self.allQueuedNoteInfo do
		if dtoVehicleMountedInfo.eventObject = _eventObject then
			dtoVehicleMountedInfo.event:=_event + Event_Factor;
			return;
		endif;
	endforeach;
	
	create dtoVehicleMountedInfo transient;
	dtoVehicleMountedInfo.eventObject:=_eventObject;
	dtoVehicleMountedInfo.event:=_event + Event_Factor;
	self.allQueuedNoteInfo.add(dtoVehicleMountedInfo);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_eventObject" type="Object"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
