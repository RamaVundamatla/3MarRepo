    <JadeMethod name="setupForm" id="1620e5c7-d972-483b-8c5b-0db10267b309">
        <updating/>
        <source>setupForm() updating, protected;

// --------------------------------------------------------------------------------
// Created:		23 February 2009 by cnwjo3
//
// Purpose:		Start setting up form
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------

vars

begin
	inheritMethod();
	
	//somewhere someone is setting pointer to hour glass
	//quick hack
	self.lastMousePointer := self.mousePointer;
	app.mousePointer := Window.MousePointer_Arrow;
	self.setupTable();
	
	self.caption := "KIOSK - Container Picker";	//10 Sep 2021	NDL	TFS 51934
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="e4be7345-e54a-46af-96d6-4baaf2a9895a">
        <updating/>
        <source>setupTable() updating;
// --------------------------------------------------------------------------------
// Created:		23 February 2009 by cnwjo3
//
// Purpose:		Setup up table.  Add Objects to table and remove any ZERO quantity items
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// --------------------------------------------------------------------------------
vars
	isoType : String;
	description : String;
	quantity : Integer;
	
	rd : CM_ReserveDetail;
	rs : CM_Object;
	reserveSelection : CM_ReserveSelection;

	rbi : CMIF_ReleaseById;
	rbiIndex : Object;
	
	rbt : CMIF_ReleaseByType;
	rbtIndex : Object;
	
	
	ar : CM_Object;
	dr : CM_DeliveryRequest;
	tir : CM_TIRequest;
	
	objectsToRemove : CM_ObjectSet;
	removeObj	: Object;
	
	iso : CM_ISOType;
	isoCode : String;
	isoCodeTbl : String;
	idx : Integer;
	firstTi : CM_TrackedItem;
begin
	self.tblContainerType.clear();
	self.tblContainerType.rows := 0;
	self.tblContainerType.columns := 3;
	self.tblContainerType.selectMode := Table.SelectMode_CurrentRow;
	self.tblContainerType.allowResize := 3;
	self.tblContainerType.scrollBars := 2;

	if self.myBulkRelease.allReserveDetails.first().isKindOf(CM_ReserveTI) then
		idx := self.tblContainerType.addItem("ISO Type" &amp; Tab &amp; "Container Code" &amp; Tab &amp; "Qty");
		self.tblContainerType.sortColumn[1] := 2;
		self.tblContainerType.sortType[1] := Table.SortType_Alpha;
		self.tblContainerType.sortAsc[1] := true;
	else
		self.tblContainerType.sortColumn[1] := 1;
		self.tblContainerType.sortType[1] := Table.SortType_Numeric;
		self.tblContainerType.sortAsc[1] := true;
		idx := self.tblContainerType.addItem("ISO Type" &amp; Tab &amp; "Description" &amp; Tab &amp; "Qty");
	endif;	

	self.tblContainerType.accessColumn(1).width := 150;
	self.tblContainerType.accessColumn(2).width := 400;
	self.tblContainerType.accessColumn(3).width := 180;
	self.tblContainerType.accessColumn(1).alignment := Table.Alignment_Center_Middle;
	self.tblContainerType.accessColumn(2).alignment := Table.Alignment_Center_Middle;
	self.tblContainerType.accessColumn(3).alignment := Table.Alignment_Left_Middle;
	self.tblContainerType.fixedRows := 1;

	//allTransients could be filled with dirty object refs
	self.myPinEntryForm.allTransients.removeInvalidObjects();	
	
	if self.myBulkRelease.allReserveDetails.first().isKindOf(CM_ReserveTI) then
		foreach rd in self.myBulkRelease.allReserveDetails do
			quantity := 0;
			firstTi := rd.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
			//if rd.allTrackedItems.size &gt; 0 then
			if firstTi &lt;&gt; null then //23/06/2023	navkc1	CR 58406 Task 58408
				//isoType := rd.allTrackedItems.first().CM_Container.isoType.String;
				//description := rd.allTrackedItems.first().CM_Container.id;
				isoType := firstTi.CM_Container.isoType.String; //23/06/2023	navkc1	CR 58406 Task 58408
				description := firstTi.CM_Container.id; //23/06/2023	navkc1	CR 58406 Task 58408
				quantity := 1;
			else
				//if there are no tracked items on reserve detail then
				//all items have been processed
			endif;
			
			//see if ReleaseById item has already been selected in current session
			foreach rbiIndex in self.myPinEntryForm.allTransients do
				if rbiIndex.isKindOf(CMIF_ReleaseById) then
					rbi := rbiIndex.CMIF_ReleaseById;
					if rbi.id.toUpper() = description.toUpper() then
						quantity := 0;
					endif;
				endif;
			endforeach;
			
			//check that ReleaseById item has already been actioned in previous session
			//and hasn't been processed
			foreach ar in self.myBulkRelease.allRequestsBeingActioned do
				if ar.isKindOf(CM_TIRequest) then
					tir := ar.CM_TIRequest;
					if tir.trackedItem.id.toUpper() = description.toUpper() then
						quantity := 0;
					endif;
				endif;
			endforeach;
			
			if quantity &gt; 0 then
				self.tblContainerType.cnEcAddItem(isoType &amp; Tab &amp; description &amp; Tab &amp; quantity.String,rd);
			endif;
		endforeach;
		
	elseif self.myBulkRelease.allReserveDetails.first().isKindOf(CM_ReserveSelection) then
		foreach rs in self.myBulkRelease.allReserveDetails do
			iso := rs.CM_ReserveSelection.myISOType;
			isoType :=  iso.code;
			description := iso.description;
			quantity := rs.CM_ReserveSelection.totalRequested;
			
			self.tblContainerType.cnEcAddItem(isoType &amp; Tab &amp; description &amp; Tab &amp; quantity.String,rs);
		endforeach;

		//decrement quantity depending on releaseByType being selected in current and
		//previous session.
		//needs to be done outside loop since Release Requests form allow for two
		//reserve details to have the iso type
		
		//see if ReleaseByType item has already been selected in current session
		foreach rbtIndex in self.myPinEntryForm.allTransients do
			if rbtIndex.isKindOf(CMIF_ReleaseByType) then
				rbt := rbtIndex.CMIF_ReleaseByType;
				isoCode := rbt.isoType;
				foreach idx in 2 to self.tblContainerType.rows do
					isoCodeTbl := self.tblContainerType.accessCell(idx,1).text;
					quantity := self.tblContainerType.accessCell(idx,3).text.Integer;
					
					if isoCode = isoCodeTbl and quantity &gt; 0 then
						quantity := quantity - 1;
						self.tblContainerType.accessCell(idx,3).text := quantity.String;
						break;
					endif;
				endforeach;
			endif;
		endforeach;

		//check that ReleaseByType item has already been actioned in previous session
		//and hasn't been processed
		foreach ar in self.myBulkRelease.allRequestsBeingActioned do
			if ar.isKindOf(CM_DeliveryRequest) then
				dr := ar.CM_DeliveryRequest;
				isoCode := dr.isoType;
				foreach idx in 2 to self.tblContainerType.rows do
					isoCodeTbl := self.tblContainerType.accessCell(idx,1).text;
					quantity := self.tblContainerType.accessCell(idx,3).text.Integer;
					
					if isoCode = isoCodeTbl and quantity &gt; 0 then
						quantity := quantity - 1;
						self.tblContainerType.accessCell(idx,3).text := quantity.String;
						break;
					endif;
				endforeach;
			endif;
		endforeach;		
		
		//check that ReleaseByType item has be actioned and road exit processed
		foreach rd in self.myBulkRelease.allReserveDetails do
			if rd.allTrackedItemsReleased.size &gt; 0 then
				isoCode := rd.CM_ReserveSelection.myISOType.code;
				foreach idx in 2 to self.tblContainerType.rows do
					isoCodeTbl := self.tblContainerType.accessCell(idx,1).text;
					quantity := self.tblContainerType.accessCell(idx,3).text.Integer;
					
					if isoCode = isoCodeTbl and quantity &gt; 0 then
						quantity := quantity - 1;
						self.tblContainerType.accessCell(idx,3).text := quantity.String;
						break;
					endif;
				endforeach;
			endif;
		endforeach;
		
		//clean up ZERO quantity reserve details
		
		//find objects to remove.  Can't remove objects while cycling through table
		create objectsToRemove transient;
		foreach idx in 2 to self.tblContainerType.rows do
			quantity := self.tblContainerType.accessCell(idx,3).text.Integer;
			if quantity &lt; 1 then
				objectsToRemove.add(self.tblContainerType.accessRow(idx).itemObject);
			endif;
		endforeach;
		
		//actually remove the objects from table
		foreach removeObj in objectsToRemove do
			self.tblContainerType.cnEcRemoveObjectRow(removeObj);
		endforeach;
	endif;
	
	//this selects the first row since 'accessRow(x).selected := true' doesn't
	//appear to be working anymore
	if self.tblContainerType.rows &gt;= 2 then
		self.tblContainerType.row := 2;
		self.tblContainerType.column := 1;
		self.doClick( self.tblContainerType );	//10 Sep 2021	NDL	TFS 51943 - need to do the actual selection
	endif;
epilog
	delete objectsToRemove;
end;</source>
    </JadeMethod>
    <JadeMethod name="tblContainerType_click" id="050acd52-1065-4d93-889c-a2033c9c433f">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblContainerType_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		1 Janurary 2009 by cnwjo3
//
// Purpose:		
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
begin
	self.doClick(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
