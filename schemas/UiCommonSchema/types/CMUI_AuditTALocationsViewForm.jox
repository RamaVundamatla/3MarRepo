epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrint" id="cdd73067-8835-4ad3-b51a-232b27cf59eb">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2011 by cnwcs5 CCMS CPL 2017/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.doPrintOutTable(self.tblData, self.caption, true, true, true, false);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="fe65b903-0d8c-4280-809b-bd7858aab28f">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	table				: CM_DataTable;
	dateStart, dateEnd	: Date;
	ts,		
	localStartTS, 	
	localEndTS			: TimeStamp;
	selectedTA, ta		: CM_TerminalArea;
	resultsColl			: CM_ObjectSet;
	iter, iter2			: Iterator;
	audit				: CM_AuditObject;
	obj					: Object;
	str					: String;
	row					: Integer;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	// start by clearing the table
	table		:= self.tblData;
	
	table.clearAllData;

	// get parameters for query
	
	localStartTS.cnEcSetDateAndTime(self.txtQDateStart.getDate,TimeStartOfDay);	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localEndTS.cnEcSetDateAndTime(self.txtQDateEnd.getDate,TimeEndOfDay);		// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	dateStart := self.localToSystemTime(localStartTS).date();	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	dateEnd := self.localToSystemTime(localEndTS).date();		// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//	dateStart 	:= self.txtQDateStart.getDate; 
//	dateEnd		:= self.txtQDateEnd.getDate;
	selectedTA	:= self.cmbTerminalArea.listObject.CM_TerminalArea;
		
	self.dateFrom		:= dateStart;
	self.dateTo			:= dateEnd;
	self.myTerminalArea	:= selectedTA;
	
	ts.setDate (dateStart);
	ts.setTime (null);
	
	self.progressStart (0, app.getErrorString (Cancel), null, null, app.getErrorString(SearchingForData));
	
	// we collect the candidate objects first and then display them in the table
	create resultsColl transient;
	
	iter := self.myTerminal.allTerminalAreas.createIterator;
	
	if selectedTA &lt;&gt; null then
		self.myTerminal.allTerminalAreas.startKeyGeq (selectedTA.id, iter);
	endif;
	
	while iter.next (ta) do
		if selectedTA &lt;&gt; null and ta &lt;&gt; selectedTA then
			break;
		endif;
		
		iter2 := ta.allAuditObjectsForClass.createIterator;	//21 Jan 2021	NDL	TFS 50152
		ta.allAuditObjectsForClass.startKeyGeq (ts, iter2);	//21 Jan 2021	NDL	TFS 50152
		
		while iter2.next (audit) do
			if dateEnd &lt;&gt; null and audit.timestamp.date &gt; dateEnd then
				break;
			endif;
			
			if not audit.isKindOf (CM_AuditTALocations) then
				continue;
			endif;
			
			resultsColl.add (audit);
		endwhile;
		
		delete iter2;
	endwhile;
	
	if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
		// someone has clicked the cancel button during the query
		return;
	endif;
	
	// now we are ready to load our table
	self.progressStart (resultsColl.size, app.getErrorString (Cancel), null, null, app.getErrorString(LoadingDataIntoView));

	foreach obj in resultsColl do
		self.progressUpdate;
		
		if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
			// someone clicked the cancel button
			break;
		endif;
		
		str := obj.CM_AuditTALocations.getAttributeStringForDefArray(table.allTblDataEntRows);	
		row := table.addItemObject (obj, str);
		
		//table.optimiseHeightForRow (row);
	endforeach;
	// sort table before coloring
	if table.sortColumn[1] &lt;&gt; null then
		table.resort;
	endif;
	// set the row colours
	table.colourRows(self.colorRow1,self.colorRow2);
	
	inheritMethod();
	
epilog
	self.progressFinish;
	self.mousePointer := Window.MousePointer_Default;
		
	delete iter;	
	delete iter2;
	delete resultsColl;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="131fba4e-ef83-40dc-be99-7f29f8b8b663">
        <source>doResetSearch();
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	date	:Date;
begin
	inheritMethod();

	date := self.systemToLocalTime(app.actualTimeServer).Date;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.cmbTerminalArea.listIndex := -1;
	
	self.txtQDateStart.setDate (date - 7);
	self.txtQDateEnd.setDate (date);

	self.cmbTerminalArea.setFocus;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="41b91d92-0136-43e0-baea-c3da0460f37c">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
//
// Changed On   Changed By  Reason
