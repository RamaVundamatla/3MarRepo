    <JadeMethod name="setTIFields" id="e5e9536d-dbe1-437d-9d8a-58029532b8ee">
        <updating/>
        <source>setTIFields() updating;
// ---------------------------------------------------------------------------
// Created:		17 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	self.myOperator := self.myTI.myOperator;
	self.dischargePort := self.myTI.dischargePort.trimBlanks;
	self.myVoyage := self.myTI.myVoyage;
end;</source>
