// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if combobox.listObject &lt;&gt; null then
		// 35872 
		self.myCurrentBank := combobox.listObject.CM_Bank;
		// 37580 Feb 2016 refresh the invoice type combos for the new BU
		self.doCmbInvoiceTypeBuild(self.cmbInvTypeInv, false);
		self.doCmbInvoiceTypeBuild(self.cmbInvoiceType, true);
		self.populateCmbStatusBank(); // TFS 39618 PATCH 1
	endif;
end;</source>
