    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllYAIdentifiers" id="97fcd9ce-a2e4-4642-a0d3-b4c20884b21b">
        <source>getAllYAIdentifiers(_yaIdentifiers: StringArray input) : Boolean;

/*

Purpose:		This method returns a list of all the identifiers for this criteria type that may be used for data entry.

Parameters:			

Return Value:		


Date			Who		Reason
27 August 2008	consw1	Initial creation

*/

vars

begin
	_yaIdentifiers.clear;
	_yaIdentifiers.add(TI_TRANSMODE_RAIL_STR.toUpper());
	_yaIdentifiers.add(TI_TRANSMODE_ROAD_STR.toUpper());
	_yaIdentifiers.add(TI_TRANSMODE_SHIP_STR.toUpper());
	
	return true;

epilog

end;</source>
        <Parameter name="_yaIdentifiers" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="4d6db4e3-a3c0-4e14-b0d6-0c8d82eec9fb">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/11/2010	cnwdap1	Initial creation PAR #26184
*/
vars
	modes : IntegerArray;

begin
	create modes transient;
	modes.add(_ti.receiptTransportMode);
	_criteriaValue := modes;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="578d7fb7-ed33-4cf8-97e9-a66d249038b7">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
// --------------------------------------------------------------------------------
// Created:		18 March 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 10/09/2008	Simon Ward	SFW1030 - Allow for patterns included in YA re-work.
// --------------------------------------------------------------------------------
vars

	i				: Integer;
	displayString	: String;
	
begin
	if pDataObj.isKindOf(CM_YADataPattern) then
		return pDataObj.CM_YADataPattern.getDataDisplay(self);
	endif;

	foreach i in pDataObj.CM_YADataInteger.allValues do
		if displayString = null then
			displayString	:=	app.transModeToString(i);
		else
			displayString	:=	displayString &amp; ", " &amp; app.transModeToString(i);
		endif;
	endforeach;
	
	return displayString;
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIntegerDisplay" id="daf7129a-1fdf-4a7b-901b-d0a2882d8cb6">
        <source>getIntegerDisplay(_value: Integer) : String;
begin
	return app.transModeToString(_value);
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
