    <JadeMethod name="zSpecialScript" id="c467f5b4-0158-4cc7-953e-d6a15d830ea8">
        <source>zSpecialScript();
/*
Purpose:			
Date		Who		Reason
// ### JIRA 33543 27JAN2025 NAVAB1 
*/
constants
	DELIM = '","';

vars
	tmpClient		: DEV_LicenseClient;
	tmpDtl			: DEV_LicenseDtl;
	licSet	: DEV_LicenseDtlSet;
	licStr : String;
	idx : Integer;
begin
	app.mousePointer := MousePointer_HourGlass;
	create licSet transient;

	foreach tmpClient in self.allClients do : clientloop
		if not tmpClient.isRealClient then
			continue;
		endif;

		licStr := "";
		tmpClient.allLicenseDtls.copy(licSet);
	
		licStr := self.zzSpecialScriptCall(licSet);

		licSet.clear();
	write licStr;
		idx +=1;
		if idx &gt; 5 then
			break;
		endif;
	endforeach;
	
	write Tab &amp; "endif;";
epilog
	delete licSet;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
