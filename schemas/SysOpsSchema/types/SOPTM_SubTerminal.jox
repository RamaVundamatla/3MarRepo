    <JadeMethod name="initShtMultiSelect" id="15fd6794-0895-4dd2-8826-b0eee00130a5">
        <source>initShtMultiSelect();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 October 2010	cnwndl1	Initial creation	Par 23991

*/

vars

	theForm	: SOP_TableMaintForm;

begin

	inheritMethod();
	
	theForm := self.myForm;
	
	theForm.mulSelect1.setVisibleButtons(false,false,true);
	self.setupMultiSelect1(app.getErrorString(Allowed_cargo_edit_grades), app.myRoot.allAvailabilityGrades, SOP_TableMaintForm::displayEntryAvailGrade.name);
	theForm.mulSelect1.myBaseForm	:= theForm;
	theForm.mulSelect1.mySelectedListBox.sorted := false;
	
	theForm.mulSelect2.setVisibleButtons(false,false,true);
	self.setupMultiSelect2(app.getErrorString(Allowed_cargo_edit_tasks), app.myRoot.allToDoTaskDescriptions, SOP_TableMaintForm::displayEntryToDoTaskDesc.name);
	theForm.mulSelect2.myBaseForm	:= theForm;
	theForm.mulSelect2.mySelectedListBox.sorted := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="a00f515e-600a-4d39-ba7b-02b631c630c0">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm : SOP_TableMaintForm;
//	allowAreaDefinition : Boolean;
begin
  
  theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;	//13 Oct 2010	NDL Par 23991
	theForm.mulSelect2.userInputEnabled := true;	//13 Oct 2010	NDL Par 23991
	
	theForm.tblInput1.hideRowByName(ETRow_DefineAreas,false);	//26 Nov 2014	NDL	Par 35295
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_TypeDesc);	//04 Dec 2014	NDL	Par 35341
		theForm.tblInput1.enableRowByName(ETRow_Bank);	//03 Dec 2014	NDL	Par 35337
		theForm.myAssistant.comboBoxSubTerminalType(theForm.cmbSubTermType);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.mulSelect1.setSelected(null);	//13 Oct 2010	NDL Par 23991
		theForm.mulSelect2.setSelected(null);	//13 Oct 2010	NDL Par 23991
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_SubTerminal);
				
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_Bank);		//03 Dec 2014	NDL	Par 35337
		theForm.mulSelect1.setSelected(theForm.myProxyObject.CM_SubTerminal.allAllowedEditAvailGrades);	//13 Oct 2010	NDL Par 23991
		theForm.mulSelect2.setSelected(theForm.myProxyObject.CM_SubTerminal.allAllowedEditToDoTasks);	//13 Oct 2010	NDL Par 23991
	
	endif; 
	
	self.enableMulSelect1Contents();	//13 Oct 2010	NDL Par 23991
	self.enableMulSelect2Contents();	//13 Oct 2010	NDL Par 23991
	
	if not theForm.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then	//11 May 2015	NDL	Par 36181
		theForm.tblInput1.hideRowByName(ETRow_Bank,false);	//26 Jan 2015	NDL	Par 35485
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="53ef5b85-915c-48a5-85b9-10cb3dd0756b">
        <updating/>
        <source>setCtrlsForView() updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	theForm : SOP_TableMaintForm;
	allowAreaDefinition : Boolean;

begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.mulSelect1.setSelected(null);	//13 Oct 2010	NDL Par 23991
	theForm.mulSelect2.setSelected(null);	//13 Oct 2010	NDL Par 23991
  
	//26 Nov 2014	NDL	Par 35295
	allowAreaDefinition := theForm.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean;
	if allowAreaDefinition and app.getMyUser.canDo( theForm.myTerminal, PmAdmSubTerminalMaint ) then
		theForm.tblInput1.showRowByName(ETRow_DefineAreas,false);
		theForm.tblInput1.cnEcResizeContents();
		theForm.tblInput1.userInputEnabled := true;
		theForm.tblInput1.disableRowByName(ETRow_Code);
		theForm.tblInput1.disableRowByName(ETRow_Description);
		theForm.tblInput1.disableRowByName(ETRow_TypeDesc);
		theForm.tblInput1.disableRowByName(ETRow_Bank);
		theForm.tblInput1.enableRowByName(ETRow_DefineAreas);
	endif;
	
	if not allowAreaDefinition then	//11 May 2015	NDL	Par 36181
		theForm.tblInput1.hideRowByName(ETRow_Bank,false);	//26 Jan 2015	NDL	Par 35485
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="b3f4faa6-7957-4bb3-baae-02484ea708da">
        <source>setupThumbnailDetails();
/*
----------   ----------  --------------------------------------------------
Created:	07 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm : SOP_TableMaintForm;

begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_SubTerminalTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_SubTerminalMaint);
	theForm.shtTblInput1.visible := true;
	theForm.myAssistant.comboBoxSubTerminalType(theForm.cmbSubTermType);
	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
	
	if not theForm.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then	//11 May 2015	NDL	Par 36181
		theForm.tblInput1.hideRowByName(ETRow_Bank,false);	//26 Jan 2015	NDL	Par 35485
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="a85b5d79-3124-4749-9a21-300eeb437a6d">
        <updating/>
        <source>showThumbnail(_subTermianl: CM_SubTerminal) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm : SOP_TableMaintForm;
	batNum : String;
	bank : CM_Bank;
begin
  
 	theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setTableFromObject(_subTermianl, null);
	theForm.tblInput1.setValueByName(ETRow_DefineAreas, 'Dbl-Click to update');	//26 Nov 2014	NDL	Par 35295
	bank := _subTermianl.getMyBank;
	theForm.myAssistant.comboBoxBank(theForm.cmbBank,bank);	//03 Dec 2014	NDL	Par 35337
	if bank &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_Bank, bank.code);
	endif;
	
	if not theForm.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then	//11 May 2015	NDL	Par 36181
		theForm.tblInput1.hideRowByName(ETRow_Bank,false);	//26 Jan 2015	NDL	Par 35485
	endif;
	  
	
	//13 Oct 2010	NDL Par 23991
	theForm.mulSelect1.setSorted(true);
	theForm.mulSelect1.setSelected(_subTermianl.allAllowedEditAvailGrades);
	self.disableMulSelect1Contents();
	
	theForm.mulSelect2.setSorted(true);
	theForm.mulSelect2.setSelected(_subTermianl.allAllowedEditToDoTasks);
	self.disableMulSelect2Contents();
	
end;</source>
        <Parameter name="_subTermianl" type="CM_SubTerminal"/>
    </JadeMethod>
</Class>
