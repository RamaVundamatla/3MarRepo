    <JadeMethod name="am006_SPAF_cmbArea_click" id="7f26d669-ac23-4afe-a0e8-976dd3f07757">
        <updating/>
        <source>am006_SPAF_cmbArea_click():Integer updating;
/*

Date		Who		Reason
30 Nov 2012	cnwkpd1	Update for 8.2.1 - change to Navigator display
	
*/

vars
	cmbArea:ComboBox;
begin
	mySHP_ProfileAreaForm_2:=app.getForm('SHP_ProfileAreaForm').Form;
	cmbArea:=mySHP_ProfileAreaForm_2.getPropertyValue('cmbArea').ComboBox;
	cmbArea.gotFocus(cmbArea);
	myCMUI_Navigator_1.lstTest.listIndex:=app.atcgGetListHierarchicalIndex(myCMUI_Navigator_1.lstTest, 'Port Otago|Voyage Functions|Operations|Voyage Side Profile|Voyage Side Profile POE|', 135);
	myCMUI_Navigator_1.lstTest.itemSelected[myCMUI_Navigator_1.lstTest.listIndex]:=true;
	myCMUI_Navigator_1.lstTest.mouseUp(myCMUI_Navigator_1.lstTest, 1, 0, 148, 337);
	app.doWindowEvents(shortPause);
	cmbArea:=mySHP_ProfileAreaForm_2.getPropertyValue('cmbArea').ComboBox;
	cmbArea.listIndex:=app.atcgGetComboStringIndex(cmbArea, 1, 'JBL500N EMMA MAERSK', 22);
	cmbArea.closeup(cmbArea);
	cmbArea:=mySHP_ProfileAreaForm_2.getPropertyValue('cmbArea').ComboBox;
	app.doWindowEvents(shortPause);
	cmbArea.listIndex:=app.atcgGetComboStringIndex(cmbArea, 1, 'JBL500N EMMA MAERSK', 22);
	cmbArea.click(cmbArea);  // 12:59:29
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
