    <JadeMethod name="doBtnNewClick" id="6c4ae5c3-9f9a-44d8-9327-a94dd2c782ce">
        <updating/>
        <source>doBtnNewClick() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

vars
	form : INV_InvoiceLineNew; //10/03/2023  navmv20 TFS 56128 Task 56129
begin

	if not self.getStatusGood() then
		app.msgBox("Cannot add new lines to VOID or POSTED invoices.","New Invoice Line Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//10/03/2023  navmv20 TFS 56128 Task 56129 - START
	form := app.loadForm(INV_InvoiceLineNew, 
					INV_Assistant, 
					false, 
					false,
					false, 
					self.myTerminal,
					null).INV_InvoiceLineNew;	
	
	if form = null then
		return;
	endif;
	form.createMyAssistant(INV_Assistant);
	form.setMyCurrentBank(self.myCurrentBank);
	form.setMyCurrentInvoice(self.myCurrentInvoice);
	form.myParentForm := self;
	form.showModal();
	//self.showInvoicePropFrame(ETView_InvListInvLinePropNew);
	//10/03/2023  navmv20 TFS 56128 Task 56129 - END
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRateCancelClick" id="ac83b457-1b9c-4452-b3fa-f8de0d2a325c">
