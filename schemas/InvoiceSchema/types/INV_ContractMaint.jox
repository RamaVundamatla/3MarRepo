    <JadeMethod name="btnAccumulate_click" id="8af71de0-e50d-4e21-ac89-376eda79d0d4">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAccumulate_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	form		: INV_ContractAccumulationsMaint;
	contract	: CM_InvoiceContractDtlsVolBased;
begin
	contract := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContractDtlsVolBased;
	
	if contract = null then
		return;
	endif;
	
	form := app.loadForm(INV_ContractAccumulationsMaint, INV_Assistant, false, false, false, self.myTerminal, null).INV_ContractAccumulationsMaint;
	
	if form = null then
		return;
	endif;
	
	form.setMyTerminal(self.myTerminal);
	form.myBusinessUnit := self.myCurrentBank;
	form.myInvoiceContractDtlsVolBased := contract;
// ### TFS BUG 61268 28NOV2023 NAVAB1	form.showModal();
	form.show(); // ### TFS BUG 61268 28NOV2023 NAVAB1
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAdd_click" id="7386a66e-6cd1-46db-a30b-9fcb011efd29">
        <controlMethod name="CMUI_Button::click"/>
