    <JadeMethod name="doCallBackAbortCheck" id="394d0eda-acb7-4a0b-9537-d7cd8fb0ff1a">
        <source>doCallBackAbortCheck() : Boolean;
// 24/04/2013	cnwcs5	par 30652 - remove resynch/resynchObject method calls
// 03 Jan 2013	cnwrs1	32983 crash after user deleted.
// 24 Nov 2017	jlgkpd1	TFS 6960 - reduce logging to only when abort is true

vars
	controller	: BGP_Controller;
	returnValue	: Boolean;
	
begin
	if self.myProcessingController &lt;&gt; null then
		controller := self.myProcessingController;
		
		returnValue := controller.abortProcessing;
		
		if returnValue then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' controller abortProcessing true', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		endif;
		
		return returnValue;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
