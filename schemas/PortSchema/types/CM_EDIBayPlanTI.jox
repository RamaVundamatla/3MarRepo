    <JadeMethod name="setForCreateNew" id="27126724-37e0-4fe3-acd7-f7c3ff824455">
        <updating/>
        <source>setForCreateNew(_ediData: CM_EDIData) updating;
//----------------------------------------------------------------
//	Created:	05 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	term		: CM_Terminal;
	strArray	: StringArray;
	cmpny		: Any;
	voyCode		: String;
	voyage		: CM_Voyage;
begin
	inheritMethod(_ediData);
	//create strArray persistent;
	//self.dischargePorts := strArray;
		
	term := _ediData.getMyTerminal();
	
	voyCode := _ediData.CM_EDIDataBayPlan.voyageCode;
	
	if term = null then
		return;
	endif;
	
	voyage := term.lookupVoyage (voyCode, null, false);
	
	if voyage = null then
		//cmpny := term.getConfig(DefCompany);
		cmpny := term.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
	else
		cmpny := voyage.myDischargeCompany;
	endif;
	
	if cmpny &lt;&gt; null then
		self.companyCode := cmpny.CM_Bank.code;
	endif;

end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a6ac56e4-8747-4aa6-8c2e-32b3fb41ad9d">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
/* Changes

Date		Name	TFS#		Description
============================================================================
10 Sep 2014	cnwrs1	CCMS 2381
19 May 2016	cnwdap1	TFS #1881 	BAPLIE/EDI VGM Updates
22 Feb 2016	cnwrs1	TFS 3401 	fixup EDI Operations update of EDI TIs
22 May 2019	jlgka1	TFS 42732	PNL - CUSCAR - Bay Plan Style, Added consigneeCode.
============================================================================*/
vars

begin
	inheritMethod(_proxyEDITI);
	self.bol 					:= _proxyEDITI.bol;
	self.commodity 				:= _proxyEDITI.commodity;
	self.commodityDescription 	:= _proxyEDITI.commodityDescription;
	self.companyCode 			:= _proxyEDITI.companyCode;
	self.couId 					:= _proxyEDITI.couId;
	self.destinationPort 		:= _proxyEDITI.destinationPort;
	self.ediTranshipPort 		:= _proxyEDITI.ediTranshipPort;
	self.dischargePort 			:= _proxyEDITI.dischargePort;
	self.dischargePorts.clear;
	_proxyEDITI.dischargePorts.copy(self.dischargePorts);
	self.imCodes.clear;
	_proxyEDITI.imCodes.copy(self.imCodes);
	self.height 				:= _proxyEDITI.height;
	self.weight 				:= _proxyEDITI.weight;
	self.width 					:= _proxyEDITI.width;
	self.length 				:= _proxyEDITI.length;
	self.loadPort 				:= _proxyEDITI.loadPort;
	self.locationId 			:= _proxyEDITI.locationId;
	self.isoType 				:= _proxyEDITI.isoType;
	self.operatorCode 			:= _proxyEDITI.operatorCode;
	self.remarks 				:= _proxyEDITI.remarks;
	self.sealNum 				:= _proxyEDITI.sealNum;
	self.temperature 			:= _proxyEDITI.temperature;
	self.rawEDIData 			:= _proxyEDITI.rawEDIData;
	self.overHeight				:= _proxyEDITI.overHeight; // adm 220909 Par 20434 add oversize attributes
	self.overLengthBack 		:= _proxyEDITI.overLengthBack;
	self.overLengthFront 		:= _proxyEDITI.overLengthFront;
	self.overWidthLeft			:= _proxyEDITI.overWidthLeft;
	self.overWidthRight 		:= _proxyEDITI.overWidthRight;
	self.setHumidity( _proxyEDITI.getHumidity );
	self.setCarbonDioxide( _proxyEDITI.getCarbonDioxide );
	self.setOxygen( _proxyEDITI.getOxygen );
	self.vent 					:= _proxyEDITI.vent;
	
	self.isCertifiedWeight 		:= _proxyEDITI.isCertifiedWeight;					// TFS #1881
	self.weightCertifiedName 	:= _proxyEDITI.weightCertifiedName;				// TFS #1881
	self.weightCertifiedReference := _proxyEDITI.weightCertifiedReference;		// TFS #1881
	
	self.transhipToPort 		:= _proxyEDITI.transhipToPort;
	self.consigneeCode			:= _proxyEDITI.consigneeCode; //jlgka1 TFS 42732
	self.volume					:= _proxyEDITI.volume; 		  //jlgka1 TFS 42732
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setHumidity" id="fd8c4b08-3171-4607-ae9f-e34b661e0eb0">
        <updating/>
        <source>setHumidity(_humidity : Decimal) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2020	jlgndl1	Initial creation	TFS 47958
