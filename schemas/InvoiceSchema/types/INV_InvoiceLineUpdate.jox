    <JadeMethod name="doBaseFormSave" id="e719ec35-90a9-4af0-af85-b47334f3d83b">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2026	jlier1	Initial creation 36572

*/

vars
	manController   : CMIF_InvoiceLineManual;
	theTable 		: CM_EntryTable;
	pxyInvLine 	    : CM_InvoiceLine;
	theReturn 	    : Integer;
	ls 			    : Boolean;
	tmpQty 			: Real;
	extRef1,
	extRef2,
	extRef3,
	extRef4,
	cargoId         : String;
	startTS			: TimeStamp;					// TFS 51154
	currentInvoice : CM_Invoice;
begin
 	theTable := self.tblInvLineProps;
	cargoId  := theTable.getValueByName(ETRow_CargoId).String;
	currentInvoice:=self.myCurrentInvoiceLine.invoice;
	
	if self.currentView = ETView_InvListInvLinePropVoid then
		if self.myCurrentInvoiceLine.status = CM_InvoiceLine.STATUS_NORMAL then
			if self.doSaveChangeStatus(CM_InvoiceLine.STATUS_VOIDED) then
				self.unloadForm;
				return;
			else
				return;
			endif;
		else
			if  self.doSaveChangeStatus(CM_InvoiceLine.STATUS_NORMAL) then
				self.unloadForm;
				return;
			else
				return;
			endif;
		endif;
		self.frmToolbar.enabled := true;
	else
		
		pxyInvLine := app.createUpdateProxy(self.myCurrentInvoiceLine).CM_InvoiceLine;
				
		extRef1 := theTable.getValueByName(ETRow_ExternalReference1).String;  //08/12/2025	navkc1 JIRA 36262
		extRef2 := theTable.getValueByName(ETRow_ExternalReference2).String;  //08/12/2025	navkc1 JIRA 36262
		extRef3 := theTable.getValueByName(ETRow_ExternalReference3).String;  //08/12/2025	navkc1 JIRA 36262
		extRef4 := theTable.getValueByName(ETRow_ExternalReference4).String;  //08/12/2025	navkc1 JIRA 36262
		pxyInvLine.setExternalReferences(extRef1, extRef2, extRef3, extRef4); //08/12/2025	navkc1 JIRA 36262
		
		pxyInvLine.setRemarks(theTable.getValueByName(ETRow_Remarks300).String);		// 24035 // ### JIRA 32731 03DEC2024 NAVAB1
		self.setMyCurrentTI();
		pxyInvLine.setTrackedItemOnly(self.myCurrentTI);
		

		if not pxyInvLine.invoice.isPostedOrReversal then	 //08.11.2017 cnwma1 TFS #7362
			if app.myRoot.isClientGhana() then //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34822
				tmpQty := theTable.getValueByName(ETRow_QuantityTen).String.asRealJMT();
			else
				tmpQty := theTable.getValueByName(ETRow_Quantity).String.asRealJMT();
			endif;
			pxyInvLine.setPropertyValue("quantity",tmpQty);
			
			//startTS.setDate(theTable.getValueByName(ETRow_StartDate).String.asDateJMT);				// TFS 51154 // 6.08.2021 navma1 #51617
			startTS.setDate(theTable.getValueAsDate(ETRow_StartDate));												 // 6.08.2021 navma1 #51617
			startTS.setTime(pxyInvLine.chargeTime.time);												// TFS 51154   
			pxyInvLine.setPropertyValue(CM_InvoiceLine::chargeTime.name, startTS);						// TFS 51154
		endif;
		
		if cargoId &lt;&gt; null and  self.myCurrentTI = null then                 //27.02.2020 cnwma1 #48666
			if app.msgBox(app.getErrorString1(Cargo_item_not_found,cargoId) &amp; Cr &amp; 
						  app.getErrorString(DoYouWantToContinue), 
						  app.getErrorString(Warning), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
				return;
			endif;
		endif;
		
		while true do
			app.myTrxUA.trxUpdateInvoiceLineRemarks(pxyInvLine, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Update_invoice_line), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
		endwhile;
	endif;
	
	self.unloadForm;
	
epilog
	delete manController;
	delete pxyInvLine;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveChangeStatus" id="a0eec62e-799d-41d7-a073-019593688577">
        <updating/>
        <source>doSaveChangeStatus(_status : Integer) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2026	jlier1	Initial creation 36572

*/
vars
	theStatus : CMIF_InvoiceStatus;
	pxyInvoiceLine	: CM_InvoiceLine;
	theReturn	: Integer;
begin

	if self.myCurrentInvoiceLine = null then
		app.msgBox(app.getErrorString(Invoice_line_selected),app.getErrorString(Update_invoice_line),MsgBox_OK_Only);
		return false;
	endif;
	
	create theStatus transient;
	
	if not self.myCurrentInvoiceLine.invoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759
	
		pxyInvoiceLine := app.createUpdateProxy(self.myCurrentInvoiceLine).CM_InvoiceLine;
		theStatus.allInvoiceLines.add(pxyInvoiceLine);
	endif;
	
	if self.myTerminal.allInvoiceStatusReasons.size &gt; 0 and self.tblInvLineProps.isRowVisible(ETRow_VoidReason) and self.myCurrentInvoiceLine &lt;&gt; null then // Bug 38115
		//epr par 36958
		theStatus.voidReason:= self.tblInvLineProps.getValueByName(ETRow_VoidReason).asStringJMT;
		theStatus.voidReasonCode:=self.tblInvLineProps.getValueByName(ETRow_VoidReasonCode).asStringJMT;
		
		if theStatus.voidReason = null then
			app.msgBox(app.getErrorString( Input_required_field_reason),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
		if theStatus.voidReasonCode = null then
			app.msgBox(app.getErrorString( Input_required_field_reasonCde),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endif;
	
	
	theStatus.newStatus := _status;
	if theStatus.allInvoiceLines.isEmpty then
		if self.myCurrentInvoiceLine.invoice.isPostedOrReversal then
			app.msgBox(app.getErrorString1(Not_updat_invoi_lines_when_inv,self.myCurrentInvoiceLine.invoice.getStatusDescriptionForSelf()) ,app.getErrorString(Update_invoice_line),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	
			return false;
		endif;
	endif;
	

	if app.msgBox(app.getErrorString(WARN_CHANGE_CHARGE)&amp; " " &amp; app.getErrorString(DoYouWantToContinue),app.getErrorString(Update_invoice_line),
		MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No  then
		// TFS 2085 close the Void Reason frame, if showing

		return false;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateInvoiceStatus(theStatus,app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	
	return true;
epilog
	if theStatus &lt;&gt; null then
		theStatus.allInvoiceLines.purge;
		theStatus.allCashPayments.purge;
	endif;
	delete theStatus;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMyTrackedItem" id="6ad20996-6d7a-48fb-97fb-fa259427d49f">
        <source>getMyTrackedItem(_id: String;
					_cargoType: CM_CargoType;
					_operator: CM_Operator;	
					_location: CM_LocationsController	
					): CM_TrackedItem protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2026	jlier1	Initial creation 36572

*/

vars
	ti, tmpTi		: CM_TrackedItem;
	tiSet 			: CM_TISet;
	cargotTypeId 	: Integer;
	iter : Iterator;
	cargoTypeId : Integer;
begin
	// searches onhship, onsite, offsite collections
		
	if _id = null then
		return null;
	endif;
	 
	if _cargoType &lt;&gt; null then 			// TFS 46054
		cargoTypeId := _cargoType.id;	// TFS 46054
	endif;
	
	create tiSet transient;
	
	self.myTerminal.lookupAllOnsiteTrackedItems(cargoTypeId, _id, tiSet, false, null);
	
	if tiSet.isEmpty then
		self.myTerminal.lookupAllOnShipTrackedItems(_id, cargoTypeId, false, false, false, tiSet, null);
	endif;
	
	if tiSet &lt;&gt; null then
		foreach ti in tiSet do
			if ti.id &lt;&gt; _id then
				break;
			endif;
			if _cargoType &lt;&gt; null and ti.myCargoType &lt;&gt; _cargoType then
				break;
			endif;
			if _operator &lt;&gt; null and ti.myOperator &lt;&gt; _operator then
				continue;
			endif;
			if _location &lt;&gt; null and ti.myPrimaryActualLocation &lt;&gt; _location then
				continue;
			endif;
			
			return ti;
			
		endforeach;
	endif;
	
	// when tiSet is null - to check offsite
	if _location = null then
		iter := self.myTerminal.allOffsiteTIsByIdCargoType.createIterator;
	    self.myTerminal.allOffsiteTIsByIdCargoType.startKeyGeq(_id,cargoTypeId,null, iter);  //14.02.2020 cnwma1 #48578
		while iter.next( ti ) do
			if ti.id &lt;&gt; _id then
				break;
			endif;
			if _cargoType &lt;&gt; null and ti.myCargoType &lt;&gt; _cargoType then
				break;
			endif;
			if _operator &lt;&gt; null and ti.myOperator &lt;&gt; _operator then
				continue;
			endif;	
			return ti;
		endwhile;
	endif;
		
	// if nothing found search notified
	if ti = null then
		if _location = null then
			iter := self.myTerminal.allNotifiedTIsByIdCargoType.createIterator;
			while iter.next( tmpTi ) do
				if tmpTi.id &lt;&gt; _id then
					break;
				endif;
				if _cargoType &lt;&gt; null and tmpTi.myCargoType &lt;&gt; _cargoType then
					break;
				endif;
				if _operator &lt;&gt; null and tmpTi.myOperator &lt;&gt; _operator then
					continue;
				endif;	
				return tmpTi;
			endwhile;
		endif;
	endif;
	
	return null;

epilog
	delete tiSet;
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="saveSelectedTrackedItems" id="00e840c0-f5af-499e-9806-ec67a2b0e1e5">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::saveSelectedTrackedItems"/>
        </interfaceImplements>
        <updating/>
        <source>saveSelectedTrackedItems(_allTIs : CM_TIArray) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2026	jlier1	Initial creation 36572

*/

vars
	ti : CM_TrackedItem;
	currentTA : CM_TerminalArea;
begin

	if _allTIs = null then
		return true;
	endif;
	
	ti := _allTIs.first;
	
	if ti &lt;&gt; null then
		// Update "New Invoice Line" table with selected TI id and cargo type
		self.myCurrentTI := ti;
		self.myCurrentCargoType := ti.myCargoType;
		self.tblInvLineProps.setValueByName( ETRow_CargoId, ti.id );
		self.cmbCargoTypeInvP.listObject := ti.myCargoType;
		self.tblInvLineProps.setValueByName( ETRow_CargoType, ti.myCargoType.description );
		
	
		self.myCurrentTIOperator := ti.myOperator;	
		self.cmbCargoOper.listIndex := self.cmbCargoOper.findObject( self.myCurrentTIOperator );
		self.cmbCargoOper.lostFocus( self.cmbCargoOper );
		self.myCurrentTILocation := ti.myPrimaryActualLocation;
		
		//18 Dec 2019	NDL	TFS 47954
		if self.myCurrentTILocation = null then
			currentTA := null;
		elseif self.myCurrentTILocation.isMachineController then
			currentTA := self.myCurrentTILocation.CM_MachineController.getMyLastKnownTerminalArea;
		else
			currentTA := self.myCurrentTILocation.getMyTerminalArea;
		endif;
		
		if currentTA = null then
			self.cmbCargoTA.listIndex := -1;
		else
			self.cmbCargoTA.listIndex := self.cmbCargoTA.findObject( currentTA );
		endif;
		
		self.cmbCargoTA.lostFocus( self.cmbCargoTA );
		if self.cmbCargoTA.listIndex &gt;= 1 then
			self.cmbCargoLoc.listIndex := self.cmbCargoLoc.findObject( self.myCurrentTILocation );
			self.cmbCargoLoc.lostFocus( self.cmbCargoLoc );
		endif;
		
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_allTIs" type="CM_TIArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentTI" id="d7c48ab0-05a3-4e46-ad9f-34b6b33af403">
        <updating/>
        <source>setMyCurrentTI() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2026	jlier1	Initial creation 36572

*/
vars
	cargoTypeId,
	tiId		  : String;
	ti			  : CM_TrackedItem;
	cargoType	  : CM_CargoType;
	cargoOperator : CM_Operator;
	cargoLocation : CM_LocationsController;
	
begin

	
	tiId		  := self.tblInvLineProps.getValueByName(ETRow_CargoId).String;
	cargoTypeId	  := self.tblInvLineProps.getValueByName(ETRow_CargoType).String;
	cargoType	  := self.cmbCargoTypeInvP.listObject.CM_CargoType;	
	cargoOperator := self.cmbCargoOper.listObject.CM_Operator;				
	cargoLocation := self.cmbCargoLoc.listObject.CM_LocationsController;	
	
	if tiId = null then
		self.myCurrentTI		 := null;
		return;
	endif;

	if self.myCurrentTI &lt;&gt; null 
	and self.myCurrentCargoType &lt;&gt; null
	and self.myCurrentTI.id = tiId 
	and self.myCurrentCargoType.description = cargoTypeId	  
	and self.myCurrentTIOperator = cargoOperator			 
	then
		if self.myCurrentTI.isOnSite then                   
			if self.myCurrentTILocation = cargoLocation then
				return;	// nothing changed, just return
			endif;
		else
			return;
		endif;
	endif;
	
	self.myCurrentTI		 := null;
	self.myCurrentCargoType	 := null;
	self.myCurrentTIOperator := null;
	self.myCurrentTILocation := null;
	
	ti := self.getMyTrackedItem( tiId, cargoType, cargoOperator, cargoLocation );
	if ti &lt;&gt; null then
		self.myCurrentTI		 := ti;
		self.myCurrentCargoType	 := cargoType;
		self.myCurrentTIOperator := cargoOperator;
		self.myCurrentTILocation := cargoLocation;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a8913360-e50c-494e-81e2-003dcb541359">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2026	jlier1	Initial creation 36572

*/

vars
	entTableDef : EntTableDef;
	entTableView : EntTableView;
	iter : Iterator;
	operTerm : CM_OperatorTerminal;
	oper : CM_Operator;

begin
	inheritMethod();
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	entTableDef:= app.myController.getEntTableDef(ETDef_InvListInvLineProperties); 
	if self.currentView = null then
		self.currentView:=ETView_InvListInvLinePropUpd;
	endif;
	
	entTableView:=entTableDef.allEntTableViews[self.currentView];
	
	self.tblInvLineProps.setEntTableFromView(entTableDef,entTableView,null,null);
	
	self.myAssistant.comboBoxCargoTypes(self.cmbCargoTypeInvP, app.myPassport.getDefaultCargoType());
	

	iter := self.myTerminal.allOperatorTerminals.createIterator;
	self.cmbCargoOper.clear();
	while iter.next( operTerm ) do
		oper := operTerm.myOperator;
		self.cmbCargoOper.itemObject[ self.cmbCargoOper.addItem( oper.code ) ] := oper;
	endwhile;
	self.cmbCargoTA.listCollection( self.myTerminal.allTerminalAreasByTypeId, false, 0);
	
	self.displayInvoiceLine;
epilog

	delete iter;

end;</source>
    </JadeMethod>
