        <source>utlCreateXTABMapping(_proxy	: CM_XTABMapping;
					_realObject	: CM_XTABMapping output;
					_passport	: CM_Passport input );
// ---------------------------------------------------------------------------
// Created:     25 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.initialiseActivity();
	
