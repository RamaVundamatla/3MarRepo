    <JadeMethod name="create" id="d3ed97e7-7897-4094-8b49-ea66cba5381f">
        <updating/>
        <source>create() updating;

/*

Purpose:		

Date			Who		Reason
02/09/2013		cnwmh5	Initial creation

*/

vars

	root					: UM_Root;

begin

	root := UM_Root.firstInstance;
	if root = null then
		create root;
	endif;
	self.myRoot := root;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="failingForXConsecutiveRuns" id="7c9b19c3-a19e-4594-9afe-ccc44fa5a2d2">
        <source>failingForXConsecutiveRuns(_startFirstTS : TimeStamp io) : Integer;

/*

Purpose:		Get the number of consecutive runs the test has been failing for
				Take into account if it only runs Sat/Sun or Mon/Tue/Wed/Thu/Fri/Sun		


Date		Who		Reason
16/11/2017	jlgmh5	Initial creation

*/

vars

	unitTestResult				: UM_UnitTestResult;

	iter						: Iterator;
	scheduleNoDays				: Integer;
	noConsecutiveRunsCount		: Integer;

begin

	// verification admin method so don't care
	if self.isVerificationAdminTest() then
		return 0;
	endif;

	// read through all the records starting at the specified date and stop when the first pass is found
	iter := self.allUnitTestResults.createIterator;
	self.allUnitTestResults.startKeyGeq(_startFirstTS, iter);
	while iter.next(unitTestResult) do
		
		// update the number of consecutive days failing for
		if unitTestResult.result = 1 then
			noConsecutiveRunsCount := noConsecutiveRunsCount + 1;
			_startFirstTS := unitTestResult.myTestRun.startTS;
			continue;
		endif;
		
		// have a pass so need to get the details
		if unitTestResult.result = 0 then
			return noConsecutiveRunsCount;
		endif;
		
	endwhile;
	
	return noConsecutiveRunsCount;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_startFirstTS" type="TimeStamp" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAvgForResults" id="28612315-365b-4eb1-8e04-8282796ed496">
        <source>getAvgForResults(_detailsDict : DynaDictionary io; _maxYear, _minYear, _maxWeek, _minWeek : Integer io); 		

/*

Purpose:		Get the average run time for the result

Date			Who		Reason
17/09/2015		cnwmh5	Initial creation

*/

vars

	result						: UM_UnitTestResult;
	utRun						: UM_UnitTestRun;
	root						: UM_Root;
	classMethod					: UM_UnitTestClassMethod;
	file						: File;
		
	detailsDict					: DynaDictionary;
	
	iter						: Iterator;
	iter2						: Iterator;
	
	className					: String;
	methodName					: String;
	runTS						: TimeStamp;
	weekOfYear					: Integer;
	currentWeek					: Integer;
	elapsedTime					: Real;
	currentClassName			: String;
	currentMethodName			: String;
	shortWeek					: Boolean;
	dayCount					: Integer;
	currentYear					: Integer;
	avgTime						: Real;

begin
	
	iter := self.allUnitTestResults.createIterator;
	while iter.next(result) do
	
		// get Week No
		//weekOfYear := result.getMyTestRunRunDate.getWeekNumber();
		weekOfYear := result.methodRunStartTS.date.getISOWeekNumber();
		
		if currentWeek &lt;&gt; weekOfYear then
		
			if currentWeek &gt; 0 then
				if dayCount &lt; 6 then
					shortWeek := true;
				endif;
				avgTime := (elapsedTime / 7).Real;
				_detailsDict.putAtKey(self.className, self.methodName, currentYear, currentWeek, avgTime, shortWeek, self);
				if currentYear &gt; _maxYear then
					_maxYear := currentYear;
				endif;
				if currentYear &lt; _minYear then
					_minYear := currentYear;
					_minWeek := 60;
				endif;
				if currentYear = _maxYear and currentWeek &gt; _maxWeek then
					_maxWeek := currentWeek;
				endif;
				if currentYear = _minYear and currentWeek &lt; _minWeek then
					_minWeek := currentWeek;
				endif;
			endif;
			
			currentClassName := className;
			currentMethodName := methodName;
			elapsedTime := 0;
			currentWeek := weekOfYear;
			shortWeek := false;
			dayCount := 0;
			currentYear := result.methodRunStartTS.date.year;
		endif;
		
		elapsedTime := elapsedTime + result.elapsedTime.Real;
		dayCount := dayCount + 1;
		
	endwhile;
	
	avgTime := (elapsedTime / 7).Real;
	_detailsDict.putAtKey(self.className, self.methodName, currentYear, currentWeek, avgTime, shortWeek, self);
	if currentYear &gt; _maxYear then
		_maxYear := currentYear;
	endif;
	if currentYear &lt; _minYear then
		_minYear := currentYear;
		_minWeek := 60;
	endif;
	if currentYear = _maxYear and currentWeek &gt; _maxWeek then
		_maxWeek := currentWeek;
	endif;
	if currentYear = _minYear and currentWeek &lt; _minWeek then
		_minWeek := currentWeek;
	endif;
	
epilog

	delete detailsDict;
	delete iter;
	delete iter2;
	delete file;
	
end;</source>
        <Parameter name="_detailsDict" type="DynaDictionary" usage="io"/>
        <Parameter name="_maxYear" type="Integer" usage="io"/>
        <Parameter name="_minYear" type="Integer" usage="io"/>
        <Parameter name="_maxWeek" type="Integer" usage="io"/>
        <Parameter name="_minWeek" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getElapsedTimesForDateRange" id="7c6946ae-97ba-4a8f-8c3c-6369789b2956">
        <source>getElapsedTimesForDateRange(_startDate, _endDate : Date; _totalElapsed : Real io; _elapsedArray : StringArray io);

/*

Purpose:		Return a StringArray of elapsed times for a date range.  Take into account any missing ones

Date			Who		Reason
03/09/2013		cnwmh5	Initial creation

*/

vars

	testResult						: UM_UnitTestResult;

	iter							: Iterator;
	
	startTS							: TimeStamp;
	tempDate						: Date;
	runDate							: Date;
	failedStr						: String;
	
begin

	startTS.setDate(_endDate);
	startTS.setTime("19:59:59".Time);
	tempDate := startTS.date;
	
	iter := self.allUnitTestResults.createIterator;
	self.allUnitTestResults.startKeyGeq(startTS, iter);
	while iter.next(testResult) do
	
		runDate := testResult.getMyTestRunRunDate();
		
		failedStr := null;
		if testResult.result = 1 then
			failedStr := ":FAIL";
		endif;
		
		// current run date is same a current temp date, so add record
		if runDate = tempDate then
			_elapsedArray.add(testResult.elapsedTime &amp; failedStr);
			_totalElapsed := _totalElapsed + testResult.elapsedTime.Real;
		endif;
		
		// add a record for any missing days 
		while tempDate &gt; runDate do
			_elapsedArray.add(null);
			tempDate := tempDate.addDays(-1);
			if tempDate &lt; _startDate then 
				break;
			elseif tempDate = runDate then
				_elapsedArray.add(testResult.elapsedTime &amp; failedStr);
				_totalElapsed := _totalElapsed + testResult.elapsedTime.Real;
			endif;
		endwhile;
		
		// if before startDate then time to leave
		tempDate := tempDate.addDays(-1);
		if tempDate &lt; _startDate then
			break;
		endif;	
	
	endwhile;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_totalElapsed" type="Real" usage="io"/>
        <Parameter name="_elapsedArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getFailingFor" id="eebd3a30-9ea3-4c0f-b308-b8271fad3c05">
        <source>getFailingFor(_startCheckingFromDate1stFail : Date io) : Integer;

/*

Purpose:		Get the number of consecutive days a test has been failing

Date			Who		Reason
03/09/2013		cnwmh5	Initial creation

*/

vars

	testResults				: UM_UnitTestResult;

	iter					: Iterator;
	
	failingFor				: Integer;
	ts						: TimeStamp;
	tempTS					: TimeStamp;
	failingForDate			: Date;

begin

	ts.setDate(_startCheckingFromDate1stFail);
	ts.setTime("19:59:59".Time);
	
	failingForDate.setDate(31, 12, 2999);
		
	iter := self.allUnitTestResults.createIterator;
	self.allUnitTestResults.startKeyGeq(ts, iter);
	
	while iter.next(testResults) do
		// Some test results might be on the boundry of being cleaned up
		// And their Run might have already been removed
		// In that case, just skip them
		if testResults.myTestRun = null then
			continue;
		endif;
		
		tempTS := testResults.myTestRun.startTS;
		if tempTS.date &lt; testResults.myTestRun.endTS.date then
			tempTS := testResults.myTestRun.endTS;
			tempTS.setTime("19:59:59".Time);
		endif;
	
		if tempTS.date &gt; ts.date then
			break;
		endif;
		
		if testResults.result = 1 then
			failingFor := failingFor + 1;
			if testResults.getMyTestRunRunDate() &lt;&gt; null and testResults.getMyTestRunRunDate() &lt;= failingForDate then
				failingForDate := testResults.getMyTestRunRunDate();  //tempTS.date;
				failingForDate := failingForDate.addDays(-1);
			endif;
			continue;
		endif;
	
		if testResults.result = 0 then 
			break;
		endif;	
	
	endwhile;
	
	_startCheckingFromDate1stFail := failingForDate;
	return failingFor;

epilog

	delete iter;

end;</source>
        <Parameter name="_startCheckingFromDate1stFail" type="Date" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getIgnoreLastRunRunsAgo" id="ba0b3ce6-183f-4088-920c-f9657d8a9d07">
        <source>getIgnoreLastRunRunsAgo(_startCheckingFromDate : Date) : Integer;

/*

Purpose:		Get the number of consecutive days a test has been ignored for

Date			Who		Reason
22/10/2013		cnwmh5	Initial creation

*/

vars

	testResults				: UM_UnitTestResult;

	iter					: Iterator;
	
	ignoredFor				: Integer;
	ts						: TimeStamp;
	tempTS					: TimeStamp;

begin

	ts.setDate(_startCheckingFromDate);
	ts.setTime("19:59:59".Time);
	
	iter := self.allUnitTestResults.createIterator;
	self.allUnitTestResults.startKeyGeq(ts, iter);
	while iter.next(testResults) do
	
		if testResults.result = 2 then
			ignoredFor := ignoredFor + 1;
			continue;
		endif;
	
		if ignoredFor &gt; 0 and testResults.result &lt;= 1 then
			break;
		endif;	
	
	endwhile;

	return ignoredFor;

epilog

	delete iter;

end;</source>
        <Parameter name="_startCheckingFromDate" type="Date"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLastPassedElapsedTime" id="d6b6e593-d06d-4274-8629-76a338fbdfc6">
        <source>getLastPassedElapsedTime() : String;

/*

Purpose:		Get the methods last passed elapsed time

Date			Who		Reason
28/04/2014		cnwmh5	Initial creation

*/

vars

	utResult					: UM_UnitTestResult;

	elapsed						: String;
	
begin

	foreach utResult in self.allUnitTestResults do
		if utResult.hasPassed() then
			elapsed := utResult.elapsedTime;
			break;
		endif;
	endforeach;

	return elapsed;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
