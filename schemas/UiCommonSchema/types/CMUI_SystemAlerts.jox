    <JadeMethod name="setupForm" id="35618ecd-3b8d-4688-bb0f-b2892e4ca5ab">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();

	self.displayLimit := 500;
	self.width := 700;
	self.height := 500;
	self.currentButton := self.BTN_ALL;
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;

	btnDelete.enabled := (app.myPassport.myUser.canDo(app.myPassport.myTerminal, self.permissionMaint) );
	self.myTerminal := app.myPassport.myTerminal;
	self.initTable();
	self.initTblQuery();
	// cnwjk3 PAR 18356 - Date - 03/11/2008 - make the heading column widths a bit bigger
	self.tblQuery.headingColumnWidth := self.tblQuery.headingColumnWidth + 4;
	
end;</source>
