    <JadeMethod name="validateMoveTo" id="4ab83837-a79b-4ed6-abb5-1a582593f799">
        <source>validateMoveTo(control: CMIF_MoveController input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	first : Boolean;
	lc : CM_LocationsController;
	lcArray : CM_LCArray;

begin
	if control.isForcedMove then
		return;
	endif;
	inheritMethod(control);
	
	create lcArray transient;
	first := true;
	foreach lc in self.allLocations do
		if first then
			control.setMyToPrimaryLocation(lc);
			first := false;
		else
			lcArray.add(lc);
		endif;
	endforeach;
	
	control.setMyToSecondaryLocations(lcArray);
	
epilog
	delete lcArray;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
