    <JadeMethod name="getDisplayStringForAttribute" id="67a367e5-e13d-4731-9736-227574eaf758">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/12/2022	navdap1		Initial creation TFS 55159 MTN Export CMAS to JSON API Endpoint
//
vars

begin
	if _attrName = ETRow_Type then
		if self.myCamProtocol &lt;&gt; null then
			return self.myCamProtocol.description;
		endif;
		return null;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseWithCamProtocol" id="72acb4e1-65d4-4110-b9b9-93dfc9e43f5e">
        <updating/>
        <source>initialiseWithCamProtocol(_protocol : CM_CamProtocol) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/01/2023	navdap1		Initial creation TFS 55159 MTN Export CAMS to JSON API Endpoint
//
vars

begin
	self.myCamProtocol := _protocol;
	if _protocol &lt;&gt; null then
		self.description := _protocol.description;
		self.myTerminal := _protocol.terminal;
	endif;
	self.myRoot := app.myRoot;
	self.createdUser := app.getMyUserCode;
	self.created := app.actualTimeServer;
	self.interfaceName := CM_EWSActivityCams@interface;
epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="interface" id="8f3a2d03-e680-4cdd-8085-fd2d70aee668">
        <options>4</options>
        <source>interface() : String typeMethod;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/12/2022	navdap1		Initial creation TFS 55159 MTN Export CMAS to JSON API Endpoint
//
vars

begin
	return "CAMS Web Service";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCams" id="cb8713a1-fe3f-40e5-8a26-2cd50a557379">
        <source>isCams(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
