    <JadeMethod name="doUserNotifyDeckItems" id="86ae9a22-cb32-4c0c-ad19-6bb76f6401fb">
        <updating/>
        <source>doUserNotifyDeckItems(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	deckItem : CM_DeckItem;
	str : String;
begin
	deckItem:=userInfo.CM_DeckItem;
	if eventType = EVENT_DECK_ITEM_DELETE then
		self.tblDeckItems.removeItemObject(deckItem);
	elseif eventType = EVENT_DECK_ITEM_CREATE then
		self.addDeckItemTableItem(deckItem);
	elseif eventType = EVENT_DECK_ITEM_UPDATE then
		self.tblDeckItems.updateItemObject(deckItem, null, null, app.myPassport);	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doUserNotifyDecks" id="16253aa8-1b39-4185-9eaf-16baf5fa597a">
        <updating/>
        <source>doUserNotifyDecks(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation

*/

vars
	lastDeck,
	deck, 
	parentDeck : CM_Deck;
	roroStructure : CM_Object;
	idx  : Integer;
begin

	deck:=userInfo.CM_Deck;
	if eventType = EVENT_VESSEL_DECK_DELETE then
		idx:=self.cmbDeck.findObject(deck);
		if idx &gt; 0 then
			self.cmbDeck.removeItem(idx);
		endif;
		if self.myCurrentDeck = deck then
			self.doChangeDeck(null);
		endif;
	endif;

	if eventType = EVENT_VESSEL_DECK_CREATE then
		idx:=self.cmbDeck.findObject(deck);
		if idx &lt; 0 then
			if deck.isKindOf(CM_DeckVesselSub) or deck.isKindOf(CM_DeckVoyageSub) then
				if deck.isKindOf(CM_DeckVesselSub) then
					parentDeck:=deck.CM_DeckVesselSub.myParentDeck;
				else
					parentDeck:=deck.CM_DeckVoyageSub.myParentDeck;
				endif;
				
				idx:=self.cmbDeck.findObject(parentDeck);
				idx:=idx + parentDeck.getSubDeckCollection.indexOf(deck);
					
				self.cmbDeck.addItemAt(deck.code,idx);
				self.cmbDeck.itemObject[self.cmbDeck.newIndex] := deck;
				self.cmbDeck.itemLevel[idx]:=2;
				self.cmbDeck.itemExpanded[idx]:=true;
			else
				if deck.ordinal = 1 then
					idx:=1;
				else
					roroStructure:=deck.getROROStructure;
					if roroStructure.isKindOf(CM_ROROVesselStructure) then
						lastDeck:=roroStructure.CM_ROROVesselStructure.allDecks[deck.ordinal-1];
					elseif  roroStructure.isKindOf(CM_ROROVoyageStructure) then
						lastDeck:=roroStructure.CM_ROROVoyageStructure.allDecks[deck.ordinal-1];
					endif;
					idx:=self.cmbDeck.findObject(lastDeck);
					idx:=idx + lastDeck.getSubDeckCollection.size + 1;
				endif;
			
				if idx &lt;= 0 then
					return;
				endif;
			
				self.cmbDeck.addItemAt(deck.code,idx);
				self.cmbDeck.itemObject[self.cmbDeck.newIndex] := deck;
			endif;
		endif;
		
		if self.cmbDeck.findObject(self.myCurrentDeck) &gt; 0 then
			self.cmbDeck.listObject:=self.myCurrentDeck;
		endif;
			
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doUserNotifyLayers" id="416ff55d-7539-4ae1-ac40-3bbd4f57506f">
        <updating/>
        <source>doUserNotifyLayers(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected, updating;
/*
Purpose:	the layers are maintained on a seperate form		
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/


vars
	layerFrame : CMUI_PointDrawingFrame;
	idx : Integer;
	pxyLayer : CM_DeckLayerLayout;
begin


	if eventType = EVENT_RORO_LAYER_SELECT then
		// PAR 27515 changing layer, clear out what is currently drawn
		self.myCurrentProxyItemLayout := null;
		self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.doBtnClearClick(true);
		self.doDrawCurrentLayer();
		
		self.myCurrentProxyLayerLayout := theObject.CM_DeckLayerLayout;
		self.doDrawCurrentLayer();
		self.setCaption(null);
	elseif eventType = EVENT_RORO_LAYER_CREATE then // PAR 27515
		pxyLayer := userInfo.CM_DeckLayerLayout;
		self.doCloneBackFrame(pxyLayer);
		layerFrame := self.getFrameForLayer(pxyLayer);
		self.repositionAllBackFrames();
		self.doDrawLayer(layerFrame);
		
	// PAR 27643 added EVENT_RORO_LAYER_DELETE event
	elseif eventType = EVENT_RORO_LAYER_DELETE then
		pxyLayer := userInfo.CM_DeckLayerLayout;
		if layerFrame &lt;&gt; null then
			layerFrame := self.getFrameForLayer(pxyLayer);
			self.allBackgroundFrames.remove(layerFrame);
			delete layerFrame;
		endif;
		self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.doBtnClearClick(true); // PAR 27643 part 2

	elseif eventType = EVENT_RORO_LAYER_UPDATE then
		layerFrame := self.getFrameForLayer(theObject.CM_DeckLayerLayout);

		if layerFrame = null then // PAR 28732
			pxyLayer := userInfo.CM_DeckLayerLayout;
			self.doCloneBackFrame(pxyLayer);
			layerFrame := self.getFrameForLayer(pxyLayer);
			self.repositionAllBackFrames();
			self.doDrawLayer(layerFrame);
			return;
		endif;
		
		idx := self.allBackgroundFrames.indexOf(layerFrame);
		self.allBackgroundFrames[idx] := null;
		delete layerFrame;
		self.doCloneBackFrame(theObject.CM_DeckLayerLayout);
		layerFrame := self.getFrameForLayer(theObject.CM_DeckLayerLayout);
		self.allBackgroundFrames.remove(layerFrame);
		self.allBackgroundFrames[idx] := layerFrame;
		self.myCurrentProxyItemLayout := null;
		self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.doBtnClearClick(true);
		self.repositionAllBackFrames();
//		self.doDrawLayer(layerFrame); // PAR 27595
		self.doReorderLayerFrames();
		self.drawDeckLayouts(self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.mode, false); // PAR 27821 pass in mode, this was turning off the context menu while in edit mode
	elseif eventType = EVENT_RORO_LAYER_VISIBLE then
		layerFrame := self.getFrameForLayer(theObject.CM_DeckLayerLayout);
		layerFrame.visible := theObject.CM_DeckLayerLayout.isVisible; // HIDE/SHOW
	elseif eventType = EVENT_RORO_ITEM_SELECT then
		self.myCurrentProxyItemLayout := theObject.CM_DeckItemLayout;
		self.doDrawCurrentPoly4CurrentLayer();
	elseif eventType = EVENT_RORO_ITEM_VISIBLE  then // HIDE/SHOW
		layerFrame := self.getFrameForLayer( theObject.CM_DeckItemLayout.myDeckLayer);
		self.doDrawLayer(layerFrame);
	elseif eventType = EVENT_RORO_ITEM_UPDATE then
		// PAR 27512
		self.btnRotate.value := false;
		self.mnuGrphRotate.checked := false;
		self.doDrawCurrentPoly4CurrentLayer();
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="drawDeckLayouts" id="e3fa9f50-2a70-44f5-831c-a55b475934e8">
        <updating/>
        <source>drawDeckLayouts(_mode : Integer; _resetCurrentLayer : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpLayer : CM_DeckLayerLayout;
begin
// PAR 27821	self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_DisplayOnly;
	self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.mode := _mode;
	self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.doBtnClearClick(true);
	self.doDrawCentreRedLine();
	self.doCloneBackFrames();
	self.setModeOnBackFrames(CMUI_PointDrawingFrame.Mode_DisplayOnly);
	// 28845 Dec 2011 keep labels if 'Show Labels' button is down
	if self.btnShowText.value then
		self.setShowTextOnFrames();
	endif;
	self.doDrawLayers();

	self.frmScrollable.zOrder(1);
	self.frmScrollable.myHLabels.zOrder(1);
	self.frmScrollable.myVLabels.zOrder(1);
	
	if _resetCurrentLayer then // PAR 28058
		self.myCurrentProxyLayerLayout :=  null;
		if self.myCurrentProxyDeck &lt;&gt; null then
			// PAR 27509
			foreach tmpLayer in self.myCurrentProxyDeck.myDeckLayout.allDeckLayerLayouts  discreteLock  where tmpLayer.isVisible and tmpLayer.isDefinable()  do
				self.myCurrentProxyLayerLayout := tmpLayer;
				break;
			endforeach;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_resetCurrentLayer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableControls" id="ad244f26-8119-4348-a67c-300f4e52a4a3">
        <source>enableControls() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	cntrl : Control;	
	indx : Integer;
begin
	self.btnCancelBase.enabled:=mode &lt;&gt; self.Mode_View;
	self.btnSaveBase.enabled:=mode &lt;&gt; self.Mode_View;

	self.cmbVessel.enabled:=mode = self.Mode_View;
	self.cmbDeck.enabled:=mode =  self.Mode_View;
	self.btnEditDeck.enabled:=mode = self.Mode_View;
	self.btnNewDeck.enabled:=mode = self.Mode_View;
	self.btnNewSubDeck.enabled:=mode = self.Mode_View;
	self.btnCopyDeck.enabled:=mode = self.Mode_View;
	self.btnPrintRoRo.enabled:= mode = self.Mode_View;
	self.btnDeleteDeck.enabled:=mode = self.Mode_View;
	
	foreach indx in 1 to self.controlCount do
		cntrl := self.controls(indx);
		if cntrl.isKindOf(CMUI_TextBox) and cntrl.parent = self.picDeckDetails then
			cntrl.CMUI_TextBox.enabled := mode &lt;&gt; self.Mode_View;	
		endif;
	endforeach;
	
	// ### DRAWING BUTTONS
	self.btnDrawAlignBot.enabled := false; // PR Testing 792 mode &lt;&gt; self.Mode_View;
	self.btnDrawAlignLeft.enabled := false; // PR Testing 792 mode &lt;&gt; self.Mode_View;
	self.btnDrawAlignRght.enabled := false; // PR Testing 792 mode &lt;&gt; self.Mode_View;
	self.btnDrawAlignTop.enabled := false; // PR Testing 792 mode &lt;&gt; self.Mode_View;
	self.btnDrawTBCross.enabled := mode &lt;&gt; self.Mode_View;
//	self.btnShowText.enabled := mode &lt;&gt; self.Mode_View;
	
	self.btnLayers.enabled := mode &lt;&gt; self.Mode_View;
	self.btnRotate.enabled := mode &lt;&gt; self.Mode_View;
	self.btnMultiSelect.enabled := mode &lt;&gt; self.Mode_View;
	self.btnDrawSameH.enabled := mode &lt;&gt; self.Mode_View;
	self.btnDrawSameHW.enabled := mode &lt;&gt; self.Mode_View;
	self.btnDrawSameW.enabled := mode &lt;&gt; self.Mode_View;
	//self.btnDrawRemarks.enabled := mode &lt;&gt; self.Mode_View;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableControlsMultiSelect" id="86756472-2575-4198-87ef-e44709a9c6f6">
        <source>enableControlsMultiSelect() protected;
/*
Purpose:			
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/

vars
	cntrl : Control;	
	frameMode, indx : Integer;
	enabled : Boolean;
begin

	frameMode := self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.mode;
	enabled := (frameMode &lt;&gt; CMUI_PointDrawingFrame.Mode_MultiSelect);
	
	self.mnuGrphAuto.enabled := enabled;
	self.mnuGrphNewItem.enabled := enabled;
	self.mnuGrphPointAfter.enabled := enabled;
	self.mnuGrphPointBefore.enabled := enabled;
	self.mnuGrphPointRemove.enabled := enabled;
	self.mnuGrphRotate.enabled := enabled;
	self.btnRotate.enabled := not self.btnMultiSelect.value.Boolean; // PAR 27595

	self.mnuGrphNewItem.enabled := enabled;
	
	self.mnuGrphAlign.enabled := not enabled;
	self.btnDrawAlignBot.enabled := not enabled;
	self.btnDrawAlignLeft.enabled := not enabled;
	self.btnDrawAlignRght.enabled := not enabled;
	self.btnDrawAlignTop.enabled := not enabled;
	
	if self.myLayerFrame &lt;&gt; null then
		self.myLayerFrame.enableControlsMultiSelect(frameMode);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
