    <JadeMethod name="setMyTerminal" id="b8b4582a-f9c6-462e-8597-dfe965478321">
        <updating/>
        <source>setMyTerminal(_terminal: CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpForm	: Form;
begin
	inheritMethod(_terminal);
	
	// Main form maybe null e.g BGP processes.
	tmpForm := app.mainForm;
	if tmpForm = null then
		return;
	endif;
	
	if not tmpForm.isKindOf(CMUI_SuperAppForm2) then
		return;
	endif;

	tmpForm.CMUI_SuperAppForm2.setMyCurrentTerminal(_terminal);
	
end;</source>
