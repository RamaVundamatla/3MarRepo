    <DbClassMap file="webservice"/>
    <PrimAttribute name="conversion_rate" id="0be854a9-bd9f-423b-90c6-33cde0d411bc">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="default" id="f76c5897-ecb1-4f61-9d88-c15d1b4faab4">
