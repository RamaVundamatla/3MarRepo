    <JadeMethod name="createNewAcitivityBalances" id="43ee9e86-5313-4c0e-a68b-1c6297759a98">
        <source>createNewAcitivityBalances( _noSumSet : CMEVT_LocationActivityByDate input; _current : Boolean; _reCalcBalanceSet : CMEVT_LocationActivityByDate input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	la : CMEVT_LocationActivity;
	balanceTS : TimeStamp;
	lc : CM_LocationsController;
	existingBalance : CMEVT_LocationActivity;

begin

	if _current then
		balanceTS := self.latestCurrentTS;
	endif;

	//These guys are Location Activities that have never been summed.
	foreach la in _noSumSet do
		//These are the 'Move' and 'Discrepancy' type Location Activity Objects ( NOT 'Balance' objects ) that were found to not have been summed
		//into a 'Balance' in the time frame we were looking at.
		if la.myLocationBalance &lt;&gt; null then
			// Because their status can change as the result of what we have already processed.
			continue;
		else
			if not _current then
				balanceTS := la.getDateTimeClient;
				balanceTS.setTime( nomalEndTime );
			endif;
			lc := la.mySourceLocation;
			if lc &lt;&gt; null and lc.isActivityTrackingLocation then
				existingBalance := lc.getLocationActivity( la.cargoType, la.operatorCode, EVT_LocationBalance, balanceTS );
				if existingBalance &lt;&gt; null then
					if not existingBalance.needsRecalculation then
						app.myTrxUA.trxLocationActivityNeedsRecalc( existingBalance, _reCalcBalanceSet, app.myPassport );
					endif;
				else
					lc.createLocationBalance( la.getCargoType, la.getOperator, balanceTS, _reCalcBalanceSet );
				endif;
			endif;
			lc := la.myTargetLocation;
			if lc &lt;&gt; null and lc.isActivityTrackingLocation then
				existingBalance := lc.getLocationActivity( la.cargoType, la.operatorCode, EVT_LocationBalance, balanceTS );
				if existingBalance &lt;&gt; null then
					if not existingBalance.needsRecalculation then
						app.myTrxUA.trxLocationActivityNeedsRecalc( existingBalance, _reCalcBalanceSet, app.myPassport );
					endif;
				else
					lc.createLocationBalance( la.getCargoType, la.getOperator, balanceTS, _reCalcBalanceSet );
				endif;
			endif;
		endif;
		
	endforeach;

epilog

end;</source>
        <Parameter name="_noSumSet" type="CMEVT_LocationActivityByDate" usage="input"/>
        <Parameter name="_current" type="Boolean"/>
        <Parameter name="_reCalcBalanceSet" type="CMEVT_LocationActivityByDate" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createNoActivityBalances" id="dbb1a8b6-821f-4123-b7ab-a287712e169d">
        <source>createNoActivityBalances( _untilDate : TimeStamp; _startTS : TimeStamp; _reCalcBalanceSet : CMEVT_LocationActivityByDate input );
/*

Purpose:
			
	This method should only be called after we have built the balances that record the real activity.
	
	
	First get a collection of the LC / Cargo Type / Operators that have ANY Location Activity at all.
	Because believe it or not the requirement here is to create Location Activity balance objects for periods of no change.
	
	This is seperated off into its own set of methods so that if sanity eventually prevails, this is an easy stuff up to remove.

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	iterTa : Iterator;
	ta : CM_TerminalAreaMaster;
	taLcSet : CM_LCSet;
	lcIter : Iterator;
	lc : CM_LocationsController;

begin

	iterTa := self.myTerminal.allTerminalAreaMastersById.createIterator;
	while iterTa.next( ta ) do
		if taLcSet &lt;&gt; null and taLcSet.isTransient() then
			delete taLcSet;
		endif;
		taLcSet := ta.getLCSet().CM_LCSet;
		if taLcSet = null or taLcSet.isEmpty then
			continue;
		endif;
		lcIter := taLcSet.createIterator;
		while lcIter.next( lc ) do
			if lc.allLocationActivity.isEmpty then
				continue;
			endif;
			// this guy has some data, generate missing balances during this period
			lc.createNoChangeBalancesFor( _untilDate, _startTS, _reCalcBalanceSet );
		endwhile;
		delete lcIter;
	endwhile; 

epilog

	if taLcSet &lt;&gt; null and taLcSet.isTransient() then
		delete taLcSet;
	endif;
	delete lcIter;
	delete iterTa;

end;</source>
        <Parameter name="_untilDate" type="TimeStamp"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_reCalcBalanceSet" type="CMEVT_LocationActivityByDate" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDailyBalances" id="52026ceb-f6f7-409b-a9d5-99f8e6bc271c">
        <source>doDailyBalances() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

//	newActivityLcSet : CM_LCSet;
	laIter : Iterator;
	lc : CM_LocationsController;
	noSumSet : CMEVT_LocationActivityByDate;
	laBalance : CMEVT_LocationActivity;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	eventTrx : CM_EventTransaction;
	la : CMEVT_LocationActivity;
	types : IntegerArray;
	type : Integer;
	startObject : CM_EventTransaction;

begin

	create noSumSet transient;

	//The current types that make up the data that can be summed into a Location Activity Balance object.
	create types transient;
	types.add( EVT_LocationMove );
	types.add( EVT_LocationDiscrepDecrease );
	types.add( EVT_LocationDiscrepIncrease );
	
	//find all 'new' activity in the 'Current' period that will need summing into Balance objects. ( the 24 hrs immediately prior to Midnight )
	foreach type in types do
		delete laIter;
		laIter := self.myTerminal.allEventsByTypeDateTime.createIterator;
		startObject := self.myTerminal.allEventsByTypeDateTime.getAtKeyGtr( type, self.latestRecalcTSServer );
		if startObject = null or not startObject.type = type then
			continue;
		endif;
		laIter.startAtObject( startObject );
		while laIter.next( eventTrx ) do
			if eventTrx.type &lt;&gt; type then
				break;
			endif;
			la := eventTrx.CMEVT_LocationActivity;
			cargoType := la.getCargoType();
			if cargoType = null or not cargoType.saveLocationActivity then
				//no longer turned on, or crap data
				continue;
			endif;
			operator := la.getOperator;
			if operator = null then
				//crap data?
				continue;
			endif;
			
			if self.latestCurrentTS &lt; la.getDateTimeClient then
				//These ones are too new to be summed, they are todays location activity.
				break;	
			endif;
			
			laBalance := la.myLocationBalance;
			if laBalance &lt;&gt; null then
				//already been been summed
				continue;
			endif;
			
			//never been summed, and in the right time period, good to go.
			noSumSet.addNoDuplicates( la, false );
					
		endwhile;
		
	endforeach;
	
	

	//Create new Balance objects for the ones that actually had activity
	self.createNewAcitivityBalances( noSumSet, true, null );
	
	
	//Now generate new balance objects for the combinations on LCs that haven't changed.	
	self.createNoActivityBalances( self.latestCurrentTS, null, null );
		
epilog

	delete types;
	delete noSumSet;
	delete laIter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doProcess" id="956d2bc4-5564-4c88-be8b-73cb309ee0d7">
        <updating/>
        <source>doProcess() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2021	navndl1	Initial creation	TFS 50906 

*/

vars

begin
	
	if self.myTerminal = null then
		app.raiseCMException( No_Terminal_specified, null, null );
		return;
	endif;
	
	self.doRecalculations();
	
	if self.recalculateOnly then
		return;
	endif;
	
	self.doDailyBalances();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRecalculations" id="463b2632-4240-4e61-9278-71b8de37f696">
        <source>doRecalculations() protected;
/*

Purpose:			

Parameters:			This guy does all of the non current processing. If they don't change the historical data it will have nothing to do,
					however, if they change amounts and locations we have to rebuild the daily total for those cargotype/operator/location daily balances.

Return Value:		

Date		Who		Reason
15 April 2021	navndl1	Initial creation	TFS	50906

*/

vars

	recalcLaBalanceSet : CMEVT_LocationActivityByDate;
	noBalanceSet : CMEVT_LocationActivityByDate;
	types : IntegerArray;
	iter : Iterator;
	startObject : CM_EventTransaction;
	eventTrx : CM_EventTransaction;
	la : CMEVT_LocationActivity;
	type : Integer;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	laBalance : CMEVT_LocationActivity;
	deactivated : CM_CargoTypeSet;
	ctaString : String;
	msg : String;
	formInitiated : Boolean;	//16 Sep 2021	NDL TFS 51975

begin

	create recalcLaBalanceSet transient;
	create noBalanceSet transient;
	create deactivated transient;
	
	if self.myTerminalArea &lt;&gt; null then
		//we have been initiated from the form
		formInitiated := true;	//16 Sep 2021	NDL TFS 51975
		iter := self.myTerminalArea.allLocationActivity.createIterator;
		
		startObject := self.myTerminalArea.allLocationActivity.getAtKeyGeq( self.earliestRecalcTSServer );
		if startObject = null then
			//there is nothing here to do
			return;
		endif;
		iter.startAtObject( startObject );
		while iter.next( la ) do
			cargoType := la.getCargoType();
			if cargoType = null then
				continue;
			endif;
			if not cargoType.saveLocationActivity then
				deactivated.addNoDuplicates( cargoType, false );
				//no longer turned on
				continue;
			endif;
			operator := la.getOperator;
			if operator = null then
				//crap data?
				continue;
			endif;
			
			if self.latestRecalcTS &lt; la.getDateTimeClient then
				//Location Activities in this time period are supposed to be handled by the daily run, not the recalculation run.
				break;
				
			else
				if  self.myCargoType &lt;&gt; null and self.myCargoType &lt;&gt; cargoType then
					continue;
				endif;
				if  self.myOperator &lt;&gt; null and self.myOperator &lt;&gt; operator then
					continue;
				endif;
				if  self.myLocation &lt;&gt; null then
					if self.myLocation &lt;&gt; la.mySourceLocation and self.myLocation &lt;&gt; la.myTargetLocation then
						continue;
					endif;
				endif;
				
				if la.isLocationBalance then
					if la.needsRecalculation then
						recalcLaBalanceSet.addNoDuplicates( la, false );
					endif;
				else
					laBalance := la.myLocationBalance;
					if laBalance = null then
						//not currently been summed, and wont be picked up the daily calc (too old)
						noBalanceSet.addNoDuplicates( la, false );
					elseif laBalance &lt;&gt; null and la.needsRecalculation then

						if not laBalance.needsRecalculation then
							app.myTrxUA.trxLocationActivityNeedsRecalc( laBalance, recalcLaBalanceSet, app.myPassport );
						endif;	
					endif;
				endif;
			
			endif;
			
		endwhile;
		
	else
		//we have been initiated by the BGP.
		create types transient;
		types.add( EVT_LocationMove );
		types.add( EVT_LocationDiscrepDecrease );
		types.add( EVT_LocationDiscrepIncrease );
		types.add( EVT_LocationBalance );
	
		foreach type in types do
			delete iter;
			iter := self.myTerminal.allEventsByTypeDateTime.createIterator;
			startObject := self.myTerminal.allEventsByTypeDateTime.getAtKeyGeq( type, self.earliestRecalcTSServer );
			if startObject = null or not startObject.type = type then
				continue;
			endif;
			iter.startAtObject( startObject );
			while iter.next( eventTrx ) do
				if eventTrx.type &lt;&gt; type then
					break;
				endif;
				la := eventTrx.CMEVT_LocationActivity;
				cargoType := la.getCargoType();
				if cargoType = null or not cargoType.saveLocationActivity then
					//no longer turned on
					continue;
				endif;
				operator := la.getOperator;
				if operator = null then
					//crap data?
					continue;
				endif;
				
				if self.latestRecalcTS &lt; la.getDateTimeClient then
					//Location Activities in this time period are supposed to be handled by the daily run, not the recalculation run.
					break;
					
				else
					if type = EVT_LocationBalance then
						if la.needsRecalculation then
							recalcLaBalanceSet.addNoDuplicates( la, false );
						endif;
					else
						laBalance := la.myLocationBalance;
						if laBalance = null then
							//not currently been summed, and wont be picked up the daily calc (too old)
							noBalanceSet.addNoDuplicates( la, false );
						elseif laBalance &lt;&gt; null and la.needsRecalculation then

							if not laBalance.needsRecalculation then
								app.myTrxUA.trxLocationActivityNeedsRecalc( laBalance, recalcLaBalanceSet, app.myPassport );
							endif;	
						endif;
					endif;
				
				endif;
				
			endwhile;
			
		endforeach;
	
	endif;
	
	//These guys are Location Activities that have never been summed despite pre-dating the normal yesterday midnight
	//start point, they wont be picked up by the normal daily run, so should be done here.
	self.createNewAcitivityBalances( noBalanceSet, false, recalcLaBalanceSet );
	
	
	//Now generate new balance objects for the combinations on LCs that haven't changed.
	if formInitiated then	//16 Sep 2021	NDL TFS 51975
		self.createNoActivityBalances( self.latestRecalcTS, self.earliestRecalcTSServer, recalcLaBalanceSet );
	else
		self.createNoActivityBalances( self.latestRecalcTS.cnEcAddDays( -1 ), self.earliestRecalcTSServer, recalcLaBalanceSet );
	endif;
	
	
	//These guys are Location Activity Balances that have been marked as needing to be recalculated, because they or
	//one of their associated location activities has been updated.
	foreach la in recalcLaBalanceSet do
		//These are all Balance records that need to be recalculated.
		if la.needsRecalculation then	// Because an update to a previous one may have sorted this one too.
			app.myTrxUA.trxLocationActBalanceRecalc( la, app.myPassport );
		endif;
	endforeach;	
	
	if deactivated &lt;&gt; null and not deactivated.isEmpty then
		foreach cargoType in deactivated do
			if ctaString = null then
				ctaString := cargoType.abbreviation;
			else
				ctaString := ctaString &amp; ", " &amp; cargoType.abbreviation;
			endif;
		endforeach;
		msg := app.getErrorString1( Cargo_types_not_curre_marke_lo, ctaString );
		if self.myTerminalArea &lt;&gt; null then
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		else
			app.createAlert( msg, true );
		endif;
	endif;

epilog

	delete iter;
	delete types;
	delete recalcLaBalanceSet;
	delete noBalanceSet;
	delete deactivated;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="05d39946-1e95-412c-bb4b-9a5e79451d61">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

