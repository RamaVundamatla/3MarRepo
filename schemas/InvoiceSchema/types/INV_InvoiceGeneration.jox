    <JadeMethod name="doCmbInvoiceTypeBuild" id="593626ba-9aa9-4d97-b8df-482d389e12e1">
        <source>doCmbInvoiceTypeBuild() protected;
/* ---------------------------------------------------------------------------
Created:	16 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	invType			: CM_InvoiceDesc;
	invTypes		: CM_InvoiceTypeByNumber;
	theInvoiceDescs	: CM_InvoiceTypeByNumber;
	bank 			: CM_Bank;
	invTypeSet		: CM_InvoiceDescSet;
	
begin

	cmbInvoiceType.clear;
	cmbInvoiceType.sorted := true;
	
	create invTypeSet transient;
	
	foreach bank in self.myTerminal.companies where (not bank.isSuspended) and (bank.isBusinessUnit) do
		
		invTypes := bank.invoiceTypes;
		
		foreach invType in invTypes 
		where invType.isTriggerOnRelease() //Par18670. Dec 2008
		and not invType.isNotAvailableForEntry
		do
			if not invTypeSet.includes(invType) then
				invTypeSet.add( invType );
			endif;
		endforeach;
	
	endforeach;
	
	cmbInvoiceType.listCollection( invTypeSet, false, 0 );
	
epilog
	delete invTypeSet;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbSetStatusToBuild" id="07239a27-d1e6-4118-a935-dc3d502fc0fa">
        <source>doCmbSetStatusToBuild( _status : Integer ) protected;
/* ---------------------------------------------------------------------------
Created:	16 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

	invProcess : CM_InvoiceProcess;	//13 Jan 2021	NDL	TFS 50600

begin

	invProcess := self.myTerminal.getDefaultCompanyBank().getMyInvoiceProcess();

	self.cmbSetStatusTo.clear;
	cmbSetStatusTo.sorted := false;

	self.cmbSetStatusTo.addItem(app.getInvoiceStatusString( invProcess, CM_Invoice.INVOICE_OPEN)); //getErrorString(Open_GC)); // TFS 39618
	self.cmbSetStatusTo.itemData[self.cmbSetStatusTo.newIndex] := CM_Invoice.INVOICE_OPEN;

	self.cmbSetStatusTo.listIndex := self.cmbSetStatusTo.newIndex;
	
	self.cmbSetStatusTo.addItem(app.getInvoiceStatusString( invProcess, CM_Invoice.INVOICE_PENDING)); //getErrorString(Pending)); // TFS 39618
	self.cmbSetStatusTo.itemData[self.cmbSetStatusTo.newIndex] := CM_Invoice.INVOICE_PENDING;

	if _status &lt;&gt; null then
		if _status = CM_Invoice.INVOICE_OPEN then
			self.cmbSetStatusTo.text := app.getInvoiceStatusString( invProcess, CM_Invoice.INVOICE_OPEN); //getErrorString(Open_GC); // TFS 39618
		elseif _status = CM_Invoice.INVOICE_PENDING then
			self.cmbSetStatusTo.text := app.getInvoiceStatusString( invProcess, CM_Invoice.INVOICE_PENDING); //getErrorString(Pending); // TFS 39618
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doGenerate" id="c76380a0-fff8-4869-b9b8-aff88cd0e851">
        <updating/>
        <source>doGenerate() updating, protected;
/* ---------------------------------------------------------------------------
Created:	17 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
------------------------------------------------------------------------------*/
vars
	invoiceType		: CM_InvoiceDesc;
	dateFrom, dateTo: Date;
	tsFrom,
	tsTo: TimeStamp;
	status			: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	self.mousePointer := Window.MousePointer_HourGlass;

	if self.cmbInvoiceType.listIndex = NULLINDEX then
		// cnwrl1 11/11/2009 PAR 19277 - start of coding
		app.msgBox(	app.getString( NothingSelected, app.getString( Invoice_type ) ),
					app.getString( Information ),
					MsgBox_OK_Only );
		// cnwrl1 11/11/2009 PAR 19277 - end of coding
		return;
	endif;
	
	invoiceType	:= self.cmbInvoiceType.itemObject[self.cmbInvoiceType.listIndex].CM_InvoiceDesc;
	// 33304 next two lines were .Date which is not locale-sensitive
	tsFrom.cnEcSetDateAndTime(txtDateFrom.text.asDateJMT(),TimeStartOfDay);// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tsTo.cnEcSetDateAndTime(txtDateTo.text.asDateJMT(),TimeEndOfDay);		// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	dateFrom	:= self.localToSystemTime(tsFrom).date();
	dateTo		:= self.localToSystemTime(tsTo).date();
	
	status		:= self.cmbSetStatusTo.itemData[self.cmbSetStatusTo.listIndex];
	
	self.myInvoiceGenerationAgent.set( invoiceType, dateFrom, dateTo, status );
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxInvoiceGeneration( self.myInvoiceGenerationAgent, app.myPassport );
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Invoice Generation', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	// print report of all updated invoices. ccms 1772 Ivoice Generation Tool Enhancement. Nov 2008
	if self.myInvoiceGenerationAgent.evtInvoiceGeneration &lt;&gt; null then
		self.showFrm(false);	// go to Print Dialog mode
	else
		app.raiseUnexpectedProgramError( class.name, method.name, '' );
		return;
	endif;

epilog
	self.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="56a3f610-8d79-4a3d-ae18-d65956a28879">
        <updating/>
        <source>setupForm() updating;
/* ---------------------------------------------------------------------------
Created:	16 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	inheritMethod();
	self.setNavigatorHeading(self.caption); // CCMS 1772
	
	self.height	:= 225; // CCMS 1772
	self.width	:= 356; // CCMS 1772
	
	self.handleMenusForModalDisplay();
	
	create self.myInvoiceGenerationAgent transient;

	self.doCmbSetStatusToBuild( null );
	self.doCmbInvoiceTypeBuild();
	self.cmbInvoiceType.setFocus();

	self.showFrm(true); // CCMS 1772
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnGenerate.enabled := false;
		
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showFrm" id="24998416-8c18-44ee-ab8f-d4c87236bcdd">
        <source>showFrm( _invoiceGenerationMode : Boolean ) protected;
/* ---------------------------------------------------------------------------
Created:	11 November 2008	by cnwvu1

Purpose:	 // CCMS 1772
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	invoicesUpdated	: CM_InvoiceSet;
	invoicesNumber	: Integer;
	
begin

	self.frm_invoiceGen.left	:= 0;
	self.frm_invoiceGen.top		:= 0;
	self.frm_printDialog.left	:= 0;
	self.frm_printDialog.top	:= 0;

	if _invoiceGenerationMode then
		self.frm_invoiceGen.enabled := true;
		self.frm_printDialog.visible := false;
	
	else
		self.frm_invoiceGen.enabled := false;
		self.frm_printDialog.centreWindow();
		self.frm_printDialog.visible := true;
		
		// displaying number of updated invoices by Invoice Generation
		if self.myInvoiceGenerationAgent.evtInvoiceGeneration = null then
			invoicesNumber := 0;
			
		else
			invoicesUpdated := self.myInvoiceGenerationAgent.evtInvoiceGeneration.getInvoicesUpdated();
			if invoicesUpdated = null then
				invoicesNumber := 0;
			else
				invoicesNumber := invoicesUpdated.size;
			endif;
		endif;
		self.lblInvoicesUpdat.caption := "Invoices Updated" &amp; ": " &amp; invoicesNumber.asStringJMT();
		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_invoiceGenerationMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4b3f1f97-6e04-413d-83e5-6981ace0392b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009586, locale);
	btnCancel.translateCaption(Xlat_0009587, locale);
	btnGenerate.translateCaption(Xlat_0009588, locale);
	btnOkDetails.translateCaption(Xlat_0009589, locale);
	btnPrintDetails.translateCaption(Xlat_0009590, locale);
	lblDateFrom.translateCaption(Xlat_0009591, locale);
	lblDateTo.translateCaption(Xlat_0009592, locale);
	lblInvoiceType.translateCaption(Xlat_0009593, locale);
	lblInvoicesUpdat.translateCaption(Xlat_0009594, locale);
	lblSetStatusTo.translateCaption(Xlat_0009595, locale);
end;</source>
    </JadeMethod>
</GUIClass>
