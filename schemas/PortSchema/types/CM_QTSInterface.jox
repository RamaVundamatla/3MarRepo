    <JadeMethod name="filePrepare" id="bf23cb79-2024-4775-aff5-f9c23f2dd20f">
        <source>filePrepare(_finObject : CM_FinancialObject ;
			_file 	   : File io ;
			_folder    : FileFolder io;
			_ref 	   : String):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars

	path 		: String;
	message,
	destName,
	fileName	: String;
begin

	if app.isJMTUnitTest then	
		path := self.exportPath.normaliseDirectory().substituteDirectory();
	else
		path := self.exportPath.normaliseDirectory().substituteDirectory();
		path := path &amp; _finObject.getMyTerminal.code &amp;"\";
	endif;
	

	_folder.fileName := path;

	if not app.isJMTUnitTest then	
		_folder.usePresentationFileSystem := false;
		_file.usePresentationFileSystem   := false;
	endif;
	
	if not _folder.isAvailable() then
		if not process.isInTransactionState then

			message := app.getErrorString2(Expor_path_does_not_exist_cann,path,self.getObjectSequence(_finObject));
			app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return null;
		else		
			app.raiseCMException3(Error_statu_chang_invoi_not_al, self.getObjectSequence(_finObject), path,self.getObjectSequence(_finObject),null, null);		
			return null;
		endif;
	endif;
	
	fileName := path &amp; self.getFileNameFormat(_finObject) &amp; _ref &amp;".csv";

	
	_file.fileName 	   := fileName;
	_file.mode 	       := File.Mode_Output;
	_file.allowReplace := true;
	
	destName :=  _finObject.getMyTerminal.code &amp;"\" &amp;  self.getFileNameFormat(_finObject) &amp; _ref &amp;".csv";
	return destName;
epilog

end;</source>
        <Parameter name="_finObject" type="CM_FinancialObject"/>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_folder" type="FileFolder" usage="io"/>
        <Parameter name="_ref" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="fileReset" id="47d8b754-0704-440a-89ab-e5f3fb0a05b6">
        <source>fileReset(_file   	: File io ; 
		  _isToFile : Boolean;
		  _folder   : FileFolder io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars

begin
	if _folder &lt;&gt; null then
		delete _folder;
	endif;
	
	if _file &lt;&gt; null then
		if _file.isOpen() then
			_file.close();
		endif;
	
		if _file.isAvailable() then
			if not _isToFile then
				_file.purge;
			endif;
			delete _file;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <Parameter name="_isToFile" type="Boolean"/>
        <Parameter name="_folder" type="FileFolder" usage="io"/>
    </JadeMethod>
