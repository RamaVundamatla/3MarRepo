    <JadeMethod name="setProxy" id="4ecb3842-6c90-421e-82d3-294e681d65b8">
        <updating/>
        <source>setProxy(_dumpClass : CM_DataDumpClass;  _realFeatures : CM_DataDumpFeatureArray; _sqlTableName : String; 
			_deleteAction : Integer;     _deleteActionColumnName:String; _deleteActionColumnPos : Integer;
			_lastOperation : Character;  _lastOperationColumnName : String; _lastOperationColumnPos : Integer;
			_exportedTimestampColumnName : String; _exportedTimestampColumnPos : Integer;
			_oidColumnPos : Integer;    _extractedUpToDateTime : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	if _dumpClass = null then
		app.raiseUnexpectedProgramError(class.name, method.name,
				"Dump Class is null");
		return;
	endif;
	
	self.myDataDumpClass := _dumpClass;
	if _realFeatures &lt;&gt; null then
		self.allDataDumpFeatures.updateSameAsArray(_realFeatures);
	endif;
	self.sqlTableName := _sqlTableName;
	self.deleteAction := _deleteAction;
	self.deleteActionColumnName      := _deleteActionColumnName;
	self.deleteActionColumnPos       := _deleteActionColumnPos;
	self.lastOperationColumnName     := _lastOperationColumnName;
	self.lastOperationColumnPos      := _lastOperationColumnPos;
	self.exportedTimestampColumnName := _exportedTimestampColumnName;
	self.exportedTimestampColumnPos  := _exportedTimestampColumnPos;
	self.oidColumnPos                := _oidColumnPos;
	self.extractedUpToDateTime       := _extractedUpToDateTime;
end;</source>
        <Parameter name="_dumpClass" type="CM_DataDumpClass"/>
        <Parameter name="_realFeatures" type="CM_DataDumpFeatureArray"/>
        <Parameter name="_sqlTableName" type="String"/>
        <Parameter name="_deleteAction" type="Integer"/>
        <Parameter name="_deleteActionColumnName" type="String"/>
        <Parameter name="_deleteActionColumnPos" type="Integer"/>
        <Parameter name="_lastOperation" type="Character"/>
        <Parameter name="_lastOperationColumnName" type="String"/>
        <Parameter name="_lastOperationColumnPos" type="Integer"/>
        <Parameter name="_exportedTimestampColumnName" type="String"/>
        <Parameter name="_exportedTimestampColumnPos" type="Integer"/>
        <Parameter name="_oidColumnPos" type="Integer"/>
        <Parameter name="_extractedUpToDateTime" type="TimeStamp"/>
    </JadeMethod>
