    <JadeMethod name="doBaseFormSave" id="90e54fbf-e32d-4747-967d-554a3ac9cbff">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2024	navrv30	JIRA 33578 EUP | Incoming API Logging

*/
vars
	fileObj		: File;
	
begin
	create fileObj transient;
	
	if not fileObj.cnEcSetSaveName(null, false, true, null) then
		return;
	endif;
	
	fileObj.openOutput(fileObj.fileName);
	fileObj.writeString(self.jtxtMessages.text);
epilog
	delete fileObj;	// This will also close the file.
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doExportRequest" id="8c182012-7c23-422d-be33-93c90f29efc2">
        <source>doExportRequest(_isRequest : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 September 2018	jlger1	Initial creation
25 November 2019	jlgzm1	TFS 47653 Changing how EDI Webservice Monitor displays XML
22 August 2023		navmd1	TFS 59024 Handle JSON messages

*/

vars
	fileXML			: CMDFileSave;
	fileName		: String;
	theXMLFile		: File;
	isJson			: Boolean;
	activityHistory	: CM_ActivityHistoryExtInterface;
	ediFile			: CM_EDIFile;
	data, delim		: String;
	
begin	
	if self.myObject.isKindOf(CM_ActivityHistoryExtInterface) then
		activityHistory := self.myObject.CM_ActivityHistoryExtInterface;
	elseif self.myObject.isKindOf(CM_CamTaskHistory) then
		isJson := true;
	elseif self.myObject.isKindOf(CM_EDIFile) then
		ediFile := self.myObject.CM_EDIFile;
		if ediFile.myEDIFileType.isJSON then
			isJson := true;
		endif;
	endif;

	create fileXML;
	if isJson then
		fileXML.filter := "JSON Message  (*.json)|*.json";
	else
		fileXML.filter := "SOAP Request  (*.xml)|*.xml";
	endif;
	
	if self.myXMLString &lt;&gt; null then	// TFS 47653
		fileXML.fileName := "*.xml";	// TFS 47653
	else
		if activityHistory &lt;&gt; null then
			fileXML.fileName := activityHistory.requestName.trimBlanks &amp; "_" &amp; activityHistory.dateTime.fileNameFormat &amp; ".xml";
		elseif ediFile &lt;&gt; null then
			if self.isXMLRequest then
				fileXML.fileName := ediFile.fileName &amp; "_request.json";
			elseif self.isXMLResponse then
				fileXML.fileName := ediFile.fileName &amp; "_response.json";
			elseif self.isEDIPostTransform then
				fileXML.fileName := ediFile.fileName &amp; "_transformed.json";
			else
				fileXML.fileName := ediFile.fileName &amp; ".json";
			endif;
		elseif isJson then
			fileXML.fileName := "*.json";
		else
			fileXML.fileName := "*.xml";
		endif;
	endif;

	if fileXML.open &lt;&gt; 0 then
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	fileName:=fileXML.fileName;
	
	//get fileName
	create theXMLFile;
	theXMLFile.fileName := fileName;
	theXMLFile.mode:=File.Mode_Output;
	if self.myXMLString &lt;&gt; null then				// TFS 47653
		theXMLFile.writeString(self.myXMLString);	// TFS 47653
	else
		if activityHistory &lt;&gt; null then
			if _isRequest then
				theXMLFile.writeString(activityHistory.request);
			else
				theXMLFile.writeString(activityHistory.response);
			endif;
		else
			if self.myObject.isKindOf(CM_CamTaskHistory) then
				theXMLFile.writeString(self.myObject.CM_CamTaskHistory.getRawDataString());
			elseif ediFile &lt;&gt; null then				
				// Basically ignore the _request flag and use what the form knows about
				if self.isXMLRequest then
					theXMLFile.writeString(ediFile.getWebReqString());
				elseif self.isXMLResponse then
					data := ediFile.getWebResString();
					// Strip the headers in the response, by finding the first blank line and grabbing everything after it
					delim := CrLf&amp;CrLf;
					data := data[data.pos(delim, 1)+delim.length:end];
					theXMLFile.writeString(data);
				else
					if self.isEDIPostTransform then
						theXMLFile.writeString(ediFile.getOriginalFileDataString());
					else
						theXMLFile.writeString(ediFile.getRawDataString());
					endif;
				endif;
			endif;
		endif;
	endif;
epilog
	delete theXMLFile;
	delete fileXML;
end;</source>
        <Parameter name="_isRequest" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFind" id="0cd38fd7-9414-4295-9fa7-81a6d3336999">
        <source>doFind();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2018	jlger1	Initial creation

*/

vars
	searchFor : String;
	found : Integer;
	handle : Integer;
begin
	searchFor	:=	self.cnEcGetUserInput("Find Text", "Enter the text to search for:", null);
	
	if searchFor = null then
		return;
	endif;
	handle:=self.jtxtMessages.doLinemarker(JadeTextEdit.LMACT_MOVESINGLETOPOSITION,0,1);
	found:=self.jtxtMessages.findMarkAll(searchFor,0,1,false,false,false,0,1,true);
	self.jtxtMessages.doLinemarker(JadeTextEdit.LMACT_GONEXTBYNUMBER, 0,1);
	self.jtxtMessages.doLinemarker(JadeTextEdit.LMACT_GOHANDLE, handle, 0);
	self.doFindNext();
epilog

end;</source>
    </JadeMethod>
