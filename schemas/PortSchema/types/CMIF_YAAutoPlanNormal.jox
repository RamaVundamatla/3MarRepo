    <JadeMethod name="isOnboardContentsStatus_Match" id="f48e2414-353c-42ce-bf3a-009c896f5149">
        <source>isOnboardContentsStatus_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2025	navhn30	Initial creation

*/

vars
	tiSet				: CM_TISet;
	ti 					: CM_TrackedItem;
	contentsStatus		: CM_ContentsStatus;
	contentsStatusSet	: CM_ContentsStatusByCodeDict;
	contents			: Integer;
begin
	if _yaData.isEmpty() then
		return true;
	endif;
	
	if self.myTrackedItem = null or not self.myTrackedItem.isTILC() then
		return false;
	endif;
	
	create tiSet transient;
	self.myTrackedItem.CM_TILC.getAllOnboardTIs(tiSet);
	
	create contentsStatusSet transient;
	
	foreach ti in tiSet discreteLock do
		contents := ti.getContentsStatus();
		contentsStatus := app.myRoot.allContentsStatuses[contents];
		if contentsStatus &lt;&gt; null then
			contentsStatusSet.add(contentsStatus);
		endif;
		
	endforeach;
	
	
	foreach contentsStatus in contentsStatusSet do
		if _yaData.matches(contentsStatus) then
			return true;
		endif;
	endforeach;
	
	return false;
	

epilog
	delete tiSet;
	delete contentsStatusSet ;

end;</source>
