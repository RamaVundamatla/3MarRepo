    <JadeMethod name="validateNew" id="ded7ef22-a30a-4d14-8ae4-7d5af109e453">
        <source>validateNew(): Boolean;

/*
Date			Who		Reason
05 August 2016	cnwar2	Initial creation

*/
vars
	parsys, tfs, customer, description, owner, opened, topic, release, errorStr : String;
	returnValue : Boolean;

begin
	parsys 		:= self.txtContact.text;
	tfs			:= self.txtTFS.text;
	customer	:= self.cmbCustomer.text;
	description	:= self.txtDescription.text;
	topic		:= self.cmbTopic.text;
	release		:= self.txtRelease.text;
	owner		:= self.cmbOwned.text;
	opened		:= self.txtOpened.text;
	
	returnValue := true;
	
	if not (parsys.isInteger and parsys.Integer &gt; 30000 and parsys.Integer &lt; 100000) then
		errorStr	:= errorStr &amp; "bad PAR number (" &amp; parsys &amp; "), ";
		returnValue := false;
	endif;
	
	if tfs &lt;&gt; "" and not (tfs.isInteger and tfs.Integer &gt; 1000 and tfs.Integer &lt; 10000) then
		errorStr	:= errorStr &amp; "bad TFS number (" &amp; tfs &amp; "), ";
		returnValue := false;
	endif;
	
	if customer.length &lt; 2 or customer.length &gt; 4 then
		errorStr	:= errorStr &amp; "bad customer (" &amp; customer &amp; "), ";
		returnValue := false;
	else
		if self.getTimezoneForCust(customer) = null then
			errorStr	:= errorStr &amp; "unknown customer (" &amp; customer &amp; "), ";
			returnValue := false;
		endif;
	endif;
	
	if owner.trimBlanks.length = 0 then
		errorStr	:= errorStr &amp; "owner required, ";
		returnValue := false;
	endif;
	
	if description.trimBlanks.length = 0 then
		errorStr	:= errorStr &amp; "description required, ";
		returnValue := false;
	endif;
	
	if topic.trimBlanks.length = 0 then
		errorStr	:= errorStr &amp; "topic required, ";
		returnValue := false;
	endif;
	
	if release.trimBlanks.length = 0 then
		errorStr	:= errorStr &amp; "release required, ";
		returnValue := false;
	endif;
	
	if not opened.TimeStamp.isValid then
		errorStr	:= errorStr &amp; "invalid timestamp (" &amp; opened &amp; "), ";
		returnValue := false;
	endif;
	
	if not returnValue then
		app.msgBox(errorStr, 'Error', 48);
	endif;
	
	return returnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
