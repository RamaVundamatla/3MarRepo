    <JadeMethod name="isStorageDetailMatch" id="6ddfa8f8-686c-48a8-9d69-bea424baca59">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*
Purpose:		 // TFS 4271	
Date		Who		Reason
30 June 2017	cnwab1	Initial creation
*/

vars
	val : String;
begin
	if _tiTrx &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		if  _tiTrx.myTrackedItem &lt;&gt; null and  _tiTrx.myTrackedItem.isKindOf(CM_Container)then
			self.getCriteriaValueForTi( _tiTrx.myTrackedItem, val); // over length length not kept on the generic transaction
		else
			val := _tiTrx.totalLength.String; 
		endif;
	else
		self.getCriteriaValueForTi( _ti, val);
	endif;
	
	if _criteria.myYAData.CM_YADataString.doesValueMatch(val) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
