    <JadeMethod name="renameDirectory" id="e305c5a3-7c76-4d38-83bd-67f05cda8e0f">
        <updating/>
        <source>renameDirectory(pOldDirectoryName:String; pNewDirectoryName:String; pNodeOptions:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		Renames the requested directory to the specified new name.
//
// Parameters:	pOldDirectoryName - The original name of the directory.
//				pNewDirectoryName - The new name of the directory.
//				pNodeOptions - Specifies the source and target JADE nodes.
//
// Returns:		True if the operation succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceNode	: Integer;
	targetNode	: Integer;
	
begin
	on FileException do self.xHandler(exception);
	
	self.doFileErrorSet(0, null);
	
	if self.interpretNodeOptions(pNodeOptions, sourceNode, targetNode) then
		if self.copyDirectory(pOldDirectoryName, pNewDirectoryName, pNodeOptions) then
			return self.deleteDirectory(pOldDirectoryName, sourceNode);
		else
			return false;
		endif;
	else
		return false;
	endif;
epilog
	on Exception do null;
	
	self.doFileErrorCheck();
end;</source>
        <Parameter name="pOldDirectoryName" type="String"/>
        <Parameter name="pNewDirectoryName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="renameDiskFile" id="69534811-dd66-448d-ae8a-153d30a888de">
        <updating/>
        <source>renameDiskFile(pOldFileName:String; pNewFileName:String; pIsPresentationFileSystem:Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 July 2002 by cnwdad1
//
// Purpose:		Renames the requested file to the specified new name.
//
// Parameters:	pOldFileName - The original name of the file.
//				pNewFileName - The new name of the file.
//				pIsPresentationFileSystem - For thin client nodes, this flag indicates
//					whether to use the thin client's own file system rather than the
//					Application Server node's file system.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDiskFile	: File;
	returnValue	: Boolean;
	
begin
	returnValue	:=	false;
	create theDiskFile transient;
	
	theDiskFile.usePresentationFileSystem	:=	pIsPresentationFileSystem;
	theDiskFile.fileName					:=	pOldFileName;
	theDiskFile.rename(pNewFileName);
	
	if theDiskFile.errorCode() &lt;&gt; 0 then
		self.doFileErrorSet(theDiskFile.errorCode(), pOldFileName);
	endif;
	
	returnValue	:=	true;
epilog
	delete theDiskFile;
	
	return returnValue;
end;</source>
        <access>protected</access>
        <Parameter name="pOldFileName" type="String"/>
        <Parameter name="pNewFileName" type="String"/>
        <Parameter name="pIsPresentationFileSystem" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="renameDiskFileAppServer" id="93bff473-a0f3-4d99-b0a3-f2b6aa9f8781">
