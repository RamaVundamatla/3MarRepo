    <JadeMethod name="tblWorkEntries_mouseDown" id="b48becf6-1336-467e-8ed1-6bd441cce8d2">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWorkEntries_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;


	self.tblWLEChange(table.row);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
