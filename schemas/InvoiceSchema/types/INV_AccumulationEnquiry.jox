    <JadeMethod name="includeContractAcc" id="da73c921-b483-496d-9b64-eaa592ec5c08">
        <source>includeContractAcc(_contract : CM_InvoiceContractAccumulate; _checkDetails : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2023 navtnr20	TFS CR 55647 Task 55697: UI - Volume Based Enquiry of Accumulations

*/

vars
	invalid, detailOK, hasCurrent : Boolean;
	contract : CM_InvoiceContract;
begin
	on Exception do app.handleDeletedObject(exception, _contract, invalid);
	
	contract :=  _contract.myContractByVolume.myInvoiceContract;
	if contract &lt;&gt; null then
		if self.filterQueryContract &lt;&gt; "" then
			if contract.contractId.toUpper().pos(self.filterQueryContract,1) &lt; 1 then
				return false;
			endif;
		endif;
		
		if filterQueryDebtor &lt;&gt; null then
			if contract.myDebtor &lt;&gt; filterQueryDebtor then
				return false;
			endif;
		endif;
	endif;
	
	if self.filterQueryContractFromStart.isValid() then
		if _contract.createdDateTime &lt; self.filterQueryContractFromStart then
			return false;
		endif;
	endif;
	
	if self.filterQueryContractFromEnd.isValid() then
		if _contract.createdDateTime &gt; self.filterQueryContractFromEnd then
			return false;
		endif;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_contract" type="CM_InvoiceContractAccumulate"/>
        <Parameter name="_checkDetails" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTblData" id="e63dc3a9-7912-43d5-8920-2b46ef98ea92">
        <source>initTblData(_theEntDef :String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2023 navtnr20	TFS CR 55647 Task 55697: UI - Volume Based Enquiry of Accumulations

*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblData;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CM_InvoiceContractAccumulate);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		self.setColorsForTable(self.tblData);	
	else
		theTable.rows := 1;	
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
