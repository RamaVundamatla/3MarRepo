    <JadeMethod name="utlCreateToDosForWO" id="8b1d8a8e-44cc-40c4-8486-9e15812d436c">
        <source>utlCreateToDosForWO( 	_wodToDo  : CM_WodToDo input;
						_passport : CM_Passport input
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jul 2018	jlgndl1	Initial creation	TFS 39638
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
19 Apr 2023 		navhl20	Defect 57571: MTN - WO - Error when creating a ToDo Cargo work order on the web portal
*/

vars

	numToAction : Integer;
	count 		: Integer;
	tiSet 		: CM_TISet;
	ti 			: CM_TrackedItem;
	msg 		: String;
	information : StringArray512;
	toDoTask   	: CM_ToDoTaskDesc;
	workOrder	: CM_WorkOrder;
begin

	numToAction := _wodToDo.totalUnactioned;
	workOrder	:= _wodToDo.getMyParent();				//27.03.2023 navma1 #56614:[56615]
	
	create information transient;
	//foreach ti in _wodToDo.allAvailableTIs do			//08.02.2023 navma1 #56457 Task#56458
	foreach ti in _wodToDo.allActionedTIs do			//19.4.2023 navhl20	#57571
		
		//_wodToDo.setTIActioned(ti, true);				//19.4.2023 navhl20	#57571
		
		foreach toDoTask in _wodToDo.allToDoTasksDescs do														//15.3.2023 navhl20	#56614[56615]
		//Changed _wodToDo.myToDoTaskDesc to toDoTask															//15.3.2023 navhl20	#56614[56615]
			if ti.allToDoTasksToDo.includesToDoDesc( toDoTask.code ) then
				//ti has already got this to do task against (unactioned)
				msg := app.getErrorString2( Actionwork_order_task, workOrder.id, toDoTask.description );		//27.03.2023 navma1 #56614:[56615]
				information.clear();
				information.add( app.getErrorString2( Item_already_unactio_task, ti.id, toDoTask.description ) );
				ti.createInfomationTransaction( msg, information, null, _passport );
				
			elseif not toDoTask.allCargoTypes.includes( ti.myCargoType ) then
				//Not a valid to do task type for this cargo type
				msg := app.getErrorString2( Actionwork_order_task, workOrder.id,  toDoTask.description );		//27.03.2023 navma1 #56614:[56615]
				information.clear();
				information.add( app.getErrorString2( Invali_task_this_cargo_type, toDoTask.description, ti.id ) );
				ti.createInfomationTransaction( msg, information, null, _passport );
				
			else
				app.myUtilityUA.utlUpdateTIWOToDoTaskAdd( ti, toDoTask.code, _wodToDo, _passport);	//22 Aug 2018	NDL	TFS 40216
			endif;
		endforeach;																					//15.3.2023 navhl20	#56614:[56615]
	
		if _passport.hasErrors then
			break;
		endif;
		
	endforeach;	 
epilog

	delete information;

end;</source>
        <Parameter name="_wodToDo" type="CM_WodToDo" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTowerFault" id="c5b9acb7-d00d-4898-a919-03f9e109fbe7">
        <source>utlCreateTowerFault(pProxyTowerFault:CM_TowerFault; pNewTowerFault:CM_TowerFault output;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
