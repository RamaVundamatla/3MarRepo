    <JadeMethod name="setForCreate" id="17477335-b2c5-4486-be2f-ea0f060fd8e5">
        <updating/>
        <source>setForCreate(_text : String; _type : Integer; _scaleFactor : Integer; _obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:      24 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.text := _text;
	self.type := _type;
	self.scaleFactor := _scaleFactor;
	self.myObject := _obj;
end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_scaleFactor" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
