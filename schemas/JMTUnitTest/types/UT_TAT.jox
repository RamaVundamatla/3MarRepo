    <JadeMethod name="tTAT_RecBookedFull" id="4df8eb1c-4c7c-40de-89dc-37ee81d27acc">
        <updating/>
        <source>tTAT_RecBookedFull()updating;
// cnwns1
// cnwmc5
//31 August 2009	cnwdw1	
// Receive Booked and Prenoted Full thru Gate Into Yard
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	TAT_BK = "TAT_BKFULL";
	
	TI = "TAT00000001";
	
vars
	booking: CM_BookingRef;
	ti: CM_TrackedItem;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// Assume cargo types for Cannon, Cannon Balls, Barrels of Stuff and Rowing Boat
	
	// Create a Booking with different cargo
	
	// Book a Full Container
	deleteBooking(TAT_BK);
	booking := self.addBookingForContainer(TAT_BK, self.operator, self.voyage1, "NZAKL", "2200", "GENL");
		assertNotNull(booking);
		assertTrue(booking.voyageCode &lt;&gt; null);
		assertFalse(booking.allBookingRefItems.first.allTIs.includes(ti));  // The prenote assigns the TI to the booking
	
	// Prenote
	deleteContainer(TI);
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  TI);
		assertTrue(ti.isPreNote);
		// Check TI is assigned to Booking
		assertTrue(booking.allTIs.includes(ti));
		assertTrue(booking.allBookingRefItems.first.allTIs.includes(ti));
	
	deleteVehicle(TRUCK);
	opts.addAssociation("bookingItem", booking.allBookingRefItems.first);
	vvr := gateInContainer(TRUCK, TI, "2200", self.operator.code, "GENL", self.dualGate);
		ti := self.getTrackedItem(TI);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(self.pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		assertTrue(booking.allTIs.includes(ti));
		assertTrue(booking.allBookingRefItems.first.allTIs.includes(ti));


	self.moveVehicleToLane(vvr.vehicle, self.pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		assertNotNull(vvr.vehicle.myPrimaryActualLocation);

	self.workVehicle(vvr);
		assertNotNull(ti.getPrimaryLocation(REAL_MODE));
		assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
		assertNotNull(vvr.vehicle.myPrimaryActualLocation);

	self.moveVehicleToLane(vvr.vehicle, self.pout, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pout, 1));
		
	self.roadExit(vvr);
		assertNull(vvr.myRoadJob);
		assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
		
	// Check TI is still assigned to Booking
	assertTrueMsg(booking.allTIs.includes(ti), "ti is no longer attached to booking");
	assertTrue(booking.allBookingRefItems.first.allTIs.includes(ti));
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTAT_RecBookedFullWithMTRel" id="1d206ef3-5fd7-46da-90d8-7b5ddd7f873f">
        <updating/>
        <source>tTAT_RecBookedFullWithMTRel()updating;
// cnwns1
// cnwmc5
//31 August 2009	cnwdw1	
// // Receive Booked and Prenoted Full with release gate out and full gated into Yard
// 10 Sep 2019	cnwrs1	TFS 46030
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
//
constants
	TAT_BK = "TAT_BK";

	MT_TI = "TAT00000001";
	
vars
	booking: CM_BookingRef;
	mt, ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// Book a Full Container with empty release
	deleteContainer(MT_TI);
	deleteBooking(TAT_BK);
	mt := self.addContainer(MT_TI, self.operator, "2200", "GENL", TI_IMEX_STATUS_STORAGE);
	self.move(mt, bs);
	
	self.opts.addAssociation("releaseTIs", mt);
	booking := self.addBookingForContainer(TAT_BK, self.operator, self.voyage1, "NZAKL", "2200", "GENL");
		assertNotNull(booking);
		assertEqual(booking.allReleaseRequests.size, 1);
		//assertTrue(booking.allReleaseRequests.first.allReserveDetails.first.allTrackedItems.includes(mt));
		assertTrue(booking.allReleaseRequests.first.allReserveDetails.first.includeTrackedItem(mt, false)); //23/06/2023	navkc1	CR 58406 Task 58408
		
	// Release the MT	
	deleteVehicle(TRUCK);

	opts.addAssociation("release", booking.allReleaseRequests.first);
 	vvr := gateOutContainer(TRUCK, "", DRIVER, mt.CM_Container, true, self.dualGate, null);
		assertEqual(vvr.myRoadJob.workListEntries.size, 1);
		assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, mt);
		assertEqual(self.pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		//assertTrueMsg(booking.allReleaseRequests.first.allReserveDetails.first.allTrackedItems.includes(mt), "mt is not assigned as released");
		assertTrueMsg(booking.allReleaseRequests.first.allReserveDetails.first.includeTrackedItem(mt, false), "mt is not assigned as released"); //23/06/2023	navkc1	CR 58406 Task 58408
		
	self.moveVehicleToYard(vvr.vehicle);
		assertNotNull(vvr.vehicle.myPrimaryActualLocation);
		
	self.workVehicle(vvr);
		assertNotNull(mt.getPrimaryLocation(REAL_MODE));
		assertTrue(mt.getPrimaryLocation(REAL_MODE).isKindOf(CM_VehicleController));
		assertNotNull(vvr.vehicle.myPrimaryActualLocation);
		
	self.moveVehicleToLane(vvr.vehicle, self.pout, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pout, 1));
		
	self.roadExit(vvr);
		assertNull(vvr.myRoadJob);
		assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
		
	// Rec The Full Container
	opts.purge;
	opts.addAssociation("bookingItem", booking.allBookingRefItems.first);
	opts.addAssociation("Voyage", self.voyage1.code);
	vvr := gateInContainer(TRUCK, MT_TI, "2200", self.operator.code, "GENL", self.dualGate);
		assertEqual(vvr.allReceivedTrackedItems.size, 1);
		ti := vvr.allReceivedTrackedItems.first;
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(self.pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		assertTrue(booking.allTIs.includes(ti));
		assertTrue(booking.allBookingRefItems.first.allTIs.includes(ti));

	self.moveVehicleToLane(vvr.vehicle, self.pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		assertNotNull(vvr.vehicle.myPrimaryActualLocation);
		
	self.workVehicle(vvr);
		assertNotNull(ti.getPrimaryLocation(REAL_MODE));
		assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
		assertNotNull(vvr.vehicle.myPrimaryActualLocation);
		
	self.moveVehicleToLane(vvr.vehicle, self.pout, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pout, 1));
		
	self.roadExit(vvr);
		assertNull(vvr.myRoadJob);
		assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="unitTestBeforeClass" id="3c3e55b0-3bb7-4746-9658-18b3e2b4a4d6">
        <updating/>
        <source>unitTestBeforeClass() updating, protected;
//18 December 2008	cnwdw1	
// 10 Sep 2019	cnwrs1	TFS 46030
//
vars
	voyageName1, voyageName2, boat: String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	inheritMethod;
	
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	self.addYACatchAll(self.getProfileSetting(UT_Profile.P_YA).asString, bs);

	operator := getOperator(self.getProfileStr(UT_Profile.P_OPERATOR));
	voyageName1 := self.getProfileStr(UT_Profile.P_INITIAL)&amp;"VBOOK1";
	voyageName2 := self.getProfileStr(UT_Profile.P_INITIAL)&amp;"VBOOK2";
	boat := self.getProfileStr(UT_Profile.P_INITIAL)&amp;"BOOT";
	deleteVoyage(voyageName1);
	deleteVoyage(voyageName2);
	deleteVessel(boat);
	self.vessel := addVesselCellular(boat, self.getOperator(self.getProfileStr(UT_Profile.P_OPERATOR)));
	assertNotNull(self.vessel);
	self.voyage1 := addVoyageWithContainerStructur(voyageName1, boat, self.getProfileStr(UT_Profile.P_OPERATOR), self.getProfileStr(UT_Profile.P_SHIPPING_LINE));
	assertNotNull(self.voyage1);
	self.voyage2 := addVoyageWithContainerStructur(voyageName2, boat, self.getProfileStr(UT_Profile.P_OPERATOR), self.getProfileStr(UT_Profile.P_SHIPPING_LINE));
	assertNotNull(self.voyage2);
	
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	pout := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
        <access>protected</access>
    </JadeMethod>
</Class>
