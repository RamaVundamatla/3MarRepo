    <JadeMethod name="doLstDataMouseDown" id="ef443425-68fe-4704-b877-92a270f3b25e">
        <updating/>
        <source>doLstDataMouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     26 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if button = Window.MouseButton_Left then
		self.doLstDataClick(listbox);
	endif;

	self.dragMode := DragMode_None;	
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;

end;</source>
