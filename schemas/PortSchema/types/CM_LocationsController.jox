    <JadeMethod name="isAvailForMultiMove" id="bfc954f2-fac0-4f2c-b76f-cb467bc7007a">
        <source>isAvailForMultiMove():Boolean;

/*

Purpose:			

Parameters:		determine if this location is available for
					a move during a multi cargo move ?	

Return Value:		


Date		Who		Reason
18 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

begin

	// applies to all positions that represent a single stack height.
	// Multi height positions need a re-implementation.
	// See CM_GridController version and CM_YALocationCell::isAvailForMultiMove

	if not self.allTrackedItems.isEmpty then
		return false;
	endif;
	if not self.allQueuedFutureMoves.isEmpty then
		return false;
	endif;
	if not self.allPlannedFutureMoves.isEmpty then
		return false;
	endif;
	if not self.allTrackedItemOSBackEnds.isEmpty then
		return false;
	endif;
	if not self.allTrackedItemOSBackEndsPd.isEmpty then
		return false;
	endif;
	if not self.allTrackedItemOSBackEndsQd.isEmpty then
		return false;
	endif;

	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBackEnd" id="ff0e7276-700c-4a78-bdf3-5fb88b51de6a">
