    <JadeMethod name="canDoLastSuccessDT" id="f599850b-08c5-4e79-bfeb-9dde0f450f49">
        <source>canDoLastSuccessDT(_endpointDesc : String) : Boolean;
/*
Purpose:	

Date		Who		Reason
01.Dec.2025 navsp1  MTN-36362 
*/

vars
	epTypeType : Integer;
	expDate : Date;
	epType : CM_EWSEndpointType;
begin
	
	// Always show the endpoints for invoice API
	if self.myEntTableView.name = ETView_EndPointInvoiceAPI then
		return true;
	endif;

	epTypeType:= -1;
	epType := self.myEWSAgent.allEWSEndpointTypesByName[_endpointDesc];
	if epType&lt;&gt; null then
		epTypeType := epType.type;
	endif;
	
	return app.myRoot.canDoEWSType(epTypeType, expDate);
epilog

end;</source>
        <Parameter name="_endpointDesc" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="d3f76701-61ca-4b98-b573-83de68b3699c">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2025	navsp1	Initial creation

*/

vars

begin
	self.permissionView	:= PmAdmExtwebSrvView;
	self.permissionMaint := PmAdmExtwebSrvMaint;
	
	// ### JIRA 33544 17DEC2024 NAVAB1
	create self.myEWSAgent transient;
	self.myEWSAgent.init();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="82a8e36f-e71c-4d98-b658-0843b2a41a00">
        <updating/>
        <source>doOK() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02.Dec.2025  navsp1      MTN-36362 NSW | OnePort API Last Run Date - Add a Last Successful Date/Time to Web Service Definition
vars
	pxyWebserviceDef        : CM_ExternalWebServiceDef;
	tbl                     : CM_DataTable;
	row                     : Integer;
	termCode, defname       : String;
	pxyObj                  : CM_EWSTerminalLastSuccessDT;
	rowValue                : String;
	objArray                : ObjectArray;
    terminal                : CM_Terminal;
begin
	pxyWebserviceDef := self.myExternalWebServiceDef.CM_ExternalWebServiceDef;

	if pxyWebserviceDef = null then
		return;
    else
        pxyWebserviceDef.allTerminalLastSuccessDT.purge;
	endif;
	
	create objArray transient;
	tbl := self.tblTermLastSuccessDT;
	foreach row in tbl.fixedRows + 1 to tbl.rows do
		if tbl.accessCell(row, 1).text &lt;&gt; null then
			// get terminal code
			termCode := tbl.accessCell(row, 1).text;
			defname := null;
			
			// get the last successful datetime
			rowValue := tbl.accessCell(row, 2).text;
            
            terminal := app.myRoot.allTerminals[termCode];
            if terminal &lt;&gt; null then
                if rowValue &lt;&gt; null then
                     create pxyObj transient;
                     pxyObj.setProxy(rowValue.TimeStamp, pxyWebserviceDef, terminal); 
                endif;
            else
                app.raiseCMException1(Err_InvalidTerminal, termCode, null, null);
            endif;
		endif;
	endforeach;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9c597af2-3861-4cd0-a7ad-bd4dcdd52433">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2025	navsp1	Initial creation MTN-36362
05 Dec 2025	navah1	MTN-36363: NSW | OnePort API Last Run Date - Automatically add a new terminal to the list
*/
vars
	idx                     : Integer;
    terminalLastSuccessDT   : CM_EWSTerminalLastSuccessDT;              //05.12.2025 navah1 #MTN-36363
	terminal                : CM_Terminal; 								//05.12.2025 navah1 #MTN-36363 

begin
    
    inheritMethod();
    self.lblLastDateTime.caption :=  self.myExternalWebServiceDef.name;
    
	self.tblTermLastSuccessDT.accessCell(1,1).text := app.getErrorString(Terminal_code) &amp; Tab &amp; app.getErrorString(Last_success_datetime);
    self.tblTermLastSuccessDT.tabKey := J_key_Tab;
    
	foreach terminal in app.myRoot.allTerminals do	//05.12.2025 navah1 #MTN-36363
		idx := self.tblTermLastSuccessDT.addItem(null);
		terminalLastSuccessDT := self.myExternalWebServiceDef.allTerminalLastSuccessDT[terminal.code];
		self.tblTermLastSuccessDT.accessCell(idx, 1).text := terminal.code;
		if terminalLastSuccessDT &lt;&gt; null then
			self.tblTermLastSuccessDT.accessCell(idx, 2).text := terminalLastSuccessDT.lastSuccessDt.asStringJMT(); 
		endif;
	endforeach;

    if self.mode = self.myParentForm.SOP_TableMaintForm.Mode_View then  //MTN-36362
		self.tblTermLastSuccessDT.enabled := false;                    //MTN-36362
		self.btnOk.visible := false;                                    //MTN-36362
	endif;                                                              //MTN-36362
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblTermLastSuccessDT_dblClick" id="c1f8ebdc-3e21-4bb6-a682-5f0b8acc6931">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTermLastSuccessDT_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2025	navsp1	Initial creation MTN-36362

*/

vars
    txt : String;
begin
    if app.myCurrentUserCan(self.getMyTerminal, PmAdmAllowTermLevelLastSuccTS) then		//new permission added	
        table.CM_BaseTable.showCalenderTimeForm(table.row, 2);
	else
		app.msgBox("You do not have necessary permissions to edit the last successful TS", "Error", MsgBox_OK_Only);
	endif;    
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblTermLastSuccessDT_lostFocus" id="50ca9e4d-90d5-4efc-8049-1663661e89e4">
        <controlMethod name="CM_DataTable::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTermLastSuccessDT_lostFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2025	navsp1	Initial creation    MTN-36362  NSW | OnePort API Last Run Date - Add a Last Successful Date/Time to Web Service Definition

*/

vars
	row : Integer;
	mainTbl : CM_DataTable;
	apiTable : CMUI_ApiEndpointTable;
begin
	mainTbl := self.tblTermLastSuccessDT;
	
	foreach row in mainTbl.fixedRows + 1 to mainTbl.rows do
		if mainTbl.accessCell(row, 2).cellControl = table then
			apiTable := table.CMUI_ApiEndpointTable;
			mainTbl.accessedCell.text := apiTable.accessCell(1,1).text &amp; Space &amp; apiTable.accessCell(1,3).text;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblTermLastSuccessDTsAddLine" id="06e5c404-3b3f-4b77-995a-3b5ebf867105">
        <source>tblTermLastSuccessDTsAddLine( _lastSuccessDT : CM_EWSTerminalLastSuccessDT) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
//01.Dec.2025   navsp1      MTN-36362   NSW | OnePort API Last Run Date - Add a Last Successful Date/Time to Web Service Definition
vars
	idx, tblRow : Integer;
	tbl : CMUI_ApiEndpointTable;
	row : EntTableRow;
	str : String;
	notLicenesed : String;
begin

	idx := self.tblTermLastSuccessDT.addItem(null);	
	str := "" &amp; Tab &amp; str;
	self.tblTermLastSuccessDT.accessCell(idx,1).text := str;
	self.tblTermLastSuccessDT.accessedCell.inputType := Table.InputType_TextBox;

	return idx;
epilog

end;</source>
        <Parameter name="_lastSuccessDT" type="CM_EWSTerminalLastSuccessDT"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="402b595a-4d5d-4f91-8371-568ae4c8a3a8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 January 2026 10:40:58.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0027167, locale);
	lblLastDateTime.translateCaption(Xlat_0027168, locale);
end;</source>
    </JadeMethod>
