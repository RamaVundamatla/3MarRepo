    <JadeMethod name="reverseDeckingForRow" id="b6a462d8-1b41-4f39-ac53-af0287a6ab6d">
        <updating/>
        <source>reverseDeckingForRow(_gridRow: CM_GridRow) updating;
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridRows	: CM_GridRowDict;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	if _gridRow = null then
		return;
	endif;
	
	create gridRows transient;
	gridRows.add(_gridRow);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxReverseDeckingOrderGridRows(gridRows, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Set Decking Options', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

epilog
	delete gridRows;
	
end;</source>
        <Parameter name="_gridRow" type="CM_GridRow"/>
    </JadeMethod>
    <JadeMethod name="reverseDeckingForRows" id="769ad818-5ef9-4bfe-8237-7929283cdc60">
        <updating/>
        <source>reverseDeckingForRows() updating;
//----------------------------------------------------------------
//	Created:	19 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ta	: CM_TerminalArea;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin


	app.mousePointer := Busy;

	ta := self.myCurrentDrawingController.myTerminalArea.CM_GridArea;
	
	if ta = null 
	or (not CM_StraddleStack.hasInstance(ta)) then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxReverseDeckingOrderGridRows(ta.CM_GridArea.allGridRows, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Set Decking Options', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

epilog	
	app.mousePointer := Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="reverseDeckingForYA" id="ffcef621-28c6-4742-bc42-890876746fa9">
        <updating/>
        <source>reverseDeckingForYA(_yardAllocation: CM_YardAllocation) updating;
//----------------------------------------------------------------
//	Created:	19 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridRows	: CM_GridRowDict;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	if _yardAllocation = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxReverseDeckingOrderBlocks(_yardAllocation.allYABlocksIn, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Set Decking Options', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

epilog
	delete gridRows;
	
end;</source>
        <Parameter name="_yardAllocation" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="savePreferences" id="a3e41329-433f-43c9-bf23-1382493b0873">
        <updating/>
        <source>savePreferences() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.tblPreferences.setObjectFromTable(self.myConfig, YRD_GridAreaEnquiryForm::setObjFromTblPreferSpecial.name, false);
	
	app.myTrxUA.trxUpdateUserConfig(app.getMyUser, self.myConfig, app.myPassport);
	
	if app.myPassport.trxCompletedOK then
		self.hidePreferences();
		return true;
	endif;
	
	self.tblPreferences.row := 1;
	self.tblPreferences.setFocus();
	return false;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="scrollPositionFrame" id="8c9af4b1-8d7b-460a-a99c-4c697dda6685">
        <source>scrollPositionFrame() protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     Scrolls the position frame in the overview to the
//				currently displayed position
// ---------------------------------------------------------------------------
vars
	hScroll,
	vScroll	: Integer;
	dfW,dfH,dfCW,dfCH,tmpABLEW, tmpINGW,tmpINGH,
	tmpABLEH, tmpW,tmpH,hPer,wPer,maxVScroll,maxHScroll	: Real;
	viewFrame : Frame;
	scrlH,rowH : Integer;
begin

	if (not self.dkbPosition.visible) then
//		return;
	endif;

	self.myCurrentDrawingController.getCurrentScrollingFrmValues(hScroll, vScroll, tmpINGW, tmpINGH);
	self.myCurrentDrawingController.getCurrentScrollableFrmValues(hScroll, vScroll, tmpABLEW, tmpABLEH);
	self.myCurrentDrawingController.getDrawingFrameDetails(dfW,dfH,dfCW,dfCH);

	self.myCurrentDrawingController.getCurrentScrollableFrmWH(dfCW,dfCH);
	dfCH := dfCH - 40; // take off label thickness
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. hScroll: " &amp; hScroll.String &amp; " vScroll: " &amp; vScroll.String &amp; " tmpINGW: " &amp; tmpINGW.String &amp; " tmpINGH: " &amp; tmpINGH.String &amp; " tmpABLEW: " &amp; tmpABLEW.String &amp; " tmpABLEH: " &amp; tmpABLEH.String &amp; " DF W: " &amp; dfW.String &amp; " DF H: " &amp; dfH.String);	
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. hScroll: " &amp; hScroll.String &amp; " vScroll: " &amp; vScroll.String &amp;  " DF W: " &amp; dfW.String &amp; " DF H: " &amp; dfH.String &amp;  " DF CW: " &amp; dfCW.String &amp; " DF CH: " &amp; dfCH.String);	

	if tmpABLEW &gt; tmpABLEW then
		tmpABLEW := tmpINGW;
	endif;
	if tmpABLEH &gt; tmpABLEH then
		tmpABLEH := tmpINGH;
	endif;
	viewFrame := self.frmPositionView;
	
	wPer := (tmpABLEW / tmpINGW);
	tmpW :=  wPer * self.frmPosition.width;

	hPer := (tmpABLEH / tmpINGH);
	tmpH := hPer * self.frmPosition.height;
	
//	hPer := (vScroll/tmpINGH );
//	vScroll := (hPer * self.frmPosition.height).Integer;
	maxVScroll := tmpINGH - dfCH;
	maxHScroll := tmpINGW - dfCW;

//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 2. vScroll: " &amp; vScroll.String &amp;  " DF CH: " &amp; dfCH.String &amp; " maxVScroll: " &amp; maxVScroll.String &amp; " tmpINGH: " &amp; tmpINGH.String);	
	hPer := (vScroll/maxVScroll );
	vScroll := (vScroll + (dfCH * hPer)).Integer;
//	hPer := (tmpABLEH / tmpINGH);
//	vScroll := (vScroll  * hPer).Integer;
	hPer := (vScroll/tmpINGH );
	vScroll := (hPer * self.frmPosition.height).Integer;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 2. vScroll: " &amp; vScroll.String &amp;  " DF CH: " &amp; dfCH.String &amp; " maxVScroll: " &amp; maxVScroll.String);	
	
	
	wPer := (hScroll/tmpINGW);
	hScroll := (wPer * self.frmPosition.width).Integer;


	viewFrame.move((hScroll),
					  (vScroll ),
					  tmpW,
					  tmpH);
	viewFrame.clearGraphics;
	viewFrame.drawRectangle(0, 0, viewFrame.clientWidth, viewFrame.clientHeight, Red);
	viewFrame.refreshNow();
end;</source>
        <access>protected</access>
    </JadeMethod>
