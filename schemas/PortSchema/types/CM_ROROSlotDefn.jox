    <JadeMethod name="setProxy" id="50abe35e-7fe1-4167-a235-839b37bea358">
        <updating/>
        <source>setProxy(_code: String; _desc: String; _remarks: String; _ord: Integer; _avail: Boolean; _other: Boolean; _parent: CM_ROROLocnDefn) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.code := _code;
	self.description := _desc;
	self.remarks := _remarks;
	
	self.ordinal := _ord;
	self.isAvailable := _avail;
	self.hasOther := _other;
	
	
	self.myROROLocnDen := _parent;
	self.myDeck := self.myROROLocnDen.myDeck;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_ord" type="Integer"/>
        <Parameter name="_avail" type="Boolean"/>
        <Parameter name="_other" type="Boolean"/>
        <Parameter name="_parent" type="CM_ROROLocnDefn"/>
    </JadeMethod>
