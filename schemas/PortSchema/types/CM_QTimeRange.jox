    <JadeMethod name="doMatch" id="fbfdd73c-2cc5-4fa5-a232-c3b98da689b7">
        <source>doMatch(_value: Any): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

begin
	if not _value.Time.isValid then
          return false;
	endif;//par 21575
	return (_value.Time &gt;= fromTime and _value.Time &lt;= toTime);
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaLineDefinitionForRT" id="2b477110-c8ae-49da-bda7-ab5a7a377e71">
        <source>getCriteriaLineDefinitionForRT(_prop: CM_QueryProperty; _searchValueA: String output; _searchValueB: String output; _searchValueBoolean: Boolean output; _isStringProperty: Boolean output; _isStringBetweenProperty: Boolean output; _isBooleanProperty: Boolean output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

begin
	_searchValueA			:= self.fromTime.asStringJMT();
	_searchValueB			:= self.toTime.asStringJMT();
	_searchValueBoolean		:= null;
	_isStringProperty		:= false;
	_isStringBetweenProperty:= true;
	_isBooleanProperty		:= false;
	
epilog

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
        <Parameter name="_isStringProperty" type="Boolean" usage="output"/>
        <Parameter name="_isStringBetweenProperty" type="Boolean" usage="output"/>
        <Parameter name="_isBooleanProperty" type="Boolean" usage="output"/>
    </JadeMethod>
