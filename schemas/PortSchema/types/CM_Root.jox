// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.allStateObjects.size &lt; pGroup then
		return null;
	endif;
	
	return self.allStateObjects[pGroup];

end;</source>
        <Parameter name="pGroup" type="Integer"/>
        <ReturnType type="CM_StateObject"/>
    </JadeMethod>
    <JadeMethod name="getStevedoresAvailableForEntry" id="e919bed5-c58e-4ad5-91e2-49afbef6c363">
        <source>getStevedoresAvailableForEntry(_dict : CM_StevedoreByCodeDict input);
//--------------------------------------------------
// Created:	22 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	stevedore : CM_Stevedore;
begin
	if _dict =  null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null dictionary passed to method');
		return;
	endif;
	
	foreach stevedore in self.allStevedores do
		if stevedore.notAvailableForEntry then
			continue;
		endif;
		_dict.add(stevedore);
	endforeach;
	
end;</source>
        <Parameter name="_dict" type="CM_StevedoreByCodeDict" usage="input"/>
    </JadeMethod>
