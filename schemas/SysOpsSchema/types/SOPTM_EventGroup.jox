    <JadeMethod name="doSave" id="ef912b61-e779-4fd1-a15d-33e22f241a5a">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnValue		: Boolean;
	proxyEventGroup	: CM_EventTypeGroup;
	lDescription,
	lName			: String;
	theForm				: SOP_TableMaintForm;
	selectedEventGroup	: ObjectArray;
begin
    theForm := self.myForm; 
	lDescription	:=	theForm.tblInput1.getValueByName(ETRow_Description).String;
	lName			:=	theForm.tblInput1.getValueByName(ETRow_Name).String;
		
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_EventTypeGroup transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyEventGroup := theForm.myProxyObject.CM_EventTypeGroup;

	create selectedEventGroup transient;
	theForm.mulSelect1.getSelected(selectedEventGroup);
	
	proxyEventGroup.setProxy(lName, lDescription, selectedEventGroup, app.myRoot);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateEventTypeGroup(proxyEventGroup, theForm.myCurrentObject, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
		
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateEventTypeGroup(proxyEventGroup, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return rtnValue;
epilog
	delete selectedEventGroup;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
