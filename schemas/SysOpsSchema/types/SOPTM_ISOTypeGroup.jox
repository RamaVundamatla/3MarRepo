    <JadeMethod name="doQueryISOAttributes" id="081e3d68-d50d-4d40-a816-cad22cd961f0">
        <source>doQueryISOAttributes(_20, _30, _40, _45, _53,  _4, _43, _8, _86, _96 : Boolean; 
								_gen, _flat, _crib, _tank, _open, _reefer, _porthole, _integ, _fan, _powered : Boolean);
/*
Purpose:			
Date		Who		Reason
13 June 2012	cnwab1	Initial creation
*/

vars
	isoCollection, qryCollection : ObjectSet;
	obj : Object;
	isoType : CM_ISOType;
begin

	create isoCollection transient;
	create qryCollection transient;
	
	self.myForm.mulSelect1.getSelected(isoCollection);
	
	foreach isoType in app.myRoot.allISOTypes  discreteLock do
		
		if ((not _20 and not _30 and not _40 and not _45 and not _96)
		or
		(_20 and isoType.is20ftLong = _20)
			or (_30 and isoType.is30ftLong = _30)
			or (_40 and  isoType.is40ftLong = _40)
			or (_45 and  isoType.is45ftLong = _45)
			or (_53 and  isoType.is53ftLong = _53) ) then
		if ((not _4 and not _43 and not _8 and not _86 and not _96)
		or
			(_4 and isoType.is4ftHigh = _4)
			or (_43 and isoType.is4ft3High = _43)
			or (_8 and isoType.is8ftHigh = _8)
			or (_86 and  isoType.is8ft6High = _86)
			or  (_96 and isoType.is9ft6High = _96) 
			)
			then
				 if ((not _gen and not _flat and not _crib and not _tank and not _open and not _reefer and not _porthole and not _integ and not _fan and not _powered)
				 
				 or (_gen and _gen = isoType.isGeneral)
				 or (_flat and _flat = isoType.isFlat)
				 or (_crib and _crib = isoType.isCrib)
				 or (_tank and _tank = isoType.isTank)
				 or (_open and _open = isoType.isOpenTop)
				 or (_reefer and _reefer = isoType.isReefer)
				 or (_porthole and _porthole = isoType.isPorthole)
				 or (_integ and _integ = isoType.isIntegral)
				 or (_fan and _fan = isoType.isFantainer)
				 or (_powered and _powered = isoType.isPowered) ) then
				
						qryCollection.add(isoType);
					endif;
				endif;
			endif;
		
	endforeach;
	
	
	self.myForm.mulSelect1.setAvailable(qryCollection, true);
	self.myForm.mulSelect1.setSelected(isoCollection);
epilog
	delete isoCollection;
	delete qryCollection;
end;</source>
        <Parameter name="_20" type="Boolean"/>
        <Parameter name="_30" type="Boolean"/>
        <Parameter name="_40" type="Boolean"/>
        <Parameter name="_45" type="Boolean"/>
        <Parameter name="_53" type="Boolean"/>
        <Parameter name="_4" type="Boolean"/>
        <Parameter name="_43" type="Boolean"/>
        <Parameter name="_8" type="Boolean"/>
        <Parameter name="_86" type="Boolean"/>
        <Parameter name="_96" type="Boolean"/>
        <Parameter name="_gen" type="Boolean"/>
        <Parameter name="_flat" type="Boolean"/>
        <Parameter name="_crib" type="Boolean"/>
        <Parameter name="_tank" type="Boolean"/>
        <Parameter name="_open" type="Boolean"/>
        <Parameter name="_reefer" type="Boolean"/>
        <Parameter name="_porthole" type="Boolean"/>
        <Parameter name="_integ" type="Boolean"/>
        <Parameter name="_fan" type="Boolean"/>
        <Parameter name="_powered" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="8b1f2562-d838-43a8-ae6c-8f74f568deeb">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
05 September 2024	jlizm1	TFS 65952 NSW Dynamics Integration - ISO Type Group and Cargo Type external references

*/
vars
	errObj		 	 	: CM_Error;
	idx				 	: Integer;
	tmpListBox		 	: ListBox;
	ignoreWarnings,
	rtnValue		 	: Boolean;
	proxyISOTypeGroup	: CM_ISOTypeGroup;
	code,
	groupDescription 	: String;
	theForm			 	: SOP_TableMaintForm;
	repGrpOrder,
	colour			 	: Integer;
	theISOTypes		 	: CM_ISOTypeByCodeDict;
	theSubstituteISOGroups : CM_ISOTypeGroupByCodeDict; //cnwrd1 par 30414 25.9.2012
	maxTotalWeight,
	maxTareWeight		: Integer;
	extRef1				: String;
	extRef2				: String;
	
begin
  	theForm 			:= self.myForm; 
	code 				:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	groupDescription 	:= theForm.tblInput1.getValueByName(ETRow_Description).String;
	repGrpOrder 		:= theForm.tblInput1.getValueByName(ETRow_ReportGroupOrder).Integer;
	colour 				:= theForm.tblInput1.getValueByName(ETRow_Colour).Integer;
	extRef1				:= theForm.tblInput1.getValueByName(ETRow_ExternalReference1).String;
	extRef2				:= theForm.tblInput1.getValueByName(ETRow_ExternalReference2).String;
	
	//18 Mar 2014	NDL	Par 33268
	maxTotalWeight := self.getConvertedDisplayValue( ETRow_MaxTotalWeight, weightType ).Integer;
	maxTareWeight := self.getConvertedDisplayValue( ETRow_MaxTareWeight, weightType ).Integer;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ISOTypeGroup transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	create theISOTypes transient;
	theForm.mulSelect1.getSelected(theISOTypes);
	
	create theSubstituteISOGroups transient; //cnwrd1 par 30414 25.9.2012
	theForm.mulSelect2.getSelected(theSubstituteISOGroups);
	
	proxyISOTypeGroup := theForm.myProxyObject.CM_ISOTypeGroup;
	proxyISOTypeGroup.setProxy(code, groupDescription, colour, repGrpOrder, extRef1, extRef2, maxTareWeight, maxTotalWeight, theISOTypes,theSubstituteISOGroups);//cnwrd1 par 30414 25.9.2012

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateISOTypeGroup(proxyISOTypeGroup, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateISOTypeGroup(proxyISOTypeGroup,app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
	
epilog
	 delete	theISOTypes;
	 delete theSubstituteISOGroups;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
