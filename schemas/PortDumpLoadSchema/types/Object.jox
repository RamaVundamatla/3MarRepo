    <JadeMethod name="importPLXMLListProps" id="486056c4-46c4-4089-bcfa-9911c7129ce9">
        <source>importPLXMLListProps(_propArray:ObjectArray io);

vars
	propColl:PropertyNDict;
	prop: Property;
begin
	create propColl transient;
	self.class.getPropertiesAllSuperclass(propColl);
	foreach prop in propColl do
		_propArray.add(prop);
	endforeach;
end;</source>
        <Parameter name="_propArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLMyAttributes" id="85d01701-8075-439f-a1b8-27828d3dac44">
        <updating/>
        <source>importPLXMLMyAttributes(_attributesBlock : String) updating;

vars
	subScript,
	attributeName: String;
	attributeValue: Any;
	prop: Property;
	propColl: PropertyNDict;
	tempStrArray: StringArray;
	tempIntArray: IntegerArray;
	tempCMIntArray: CM_IntegerArray;
	tempTimeArray: TimeArray;
	tempDecimalArray: DecimalArray;
	tempBooleanArray: BooleanArray;
	tempBinaryArray: BinaryArray;
	strLength, pos: Integer;
	decimal: Decimal[5,2];
	propName: String;

begin
	create propColl transient;
	self.class.getPropertiesAllSuperclass(propColl);
	
	foreach prop in propColl do
//write class.name&amp;'::'&amp;method.name&amp;" class="&amp;self.class.name&amp;" AttrPropertyName="&amp;prop.getName();
		if (not prop.isKindOf(Attribute)) or
//		   (not self.shouldAuditProperty(self.class, prop)) or
		   (prop.virtual) then
			continue;
		endif;
		propName := prop.name;
		attributeName := self.importPLXMLAttrName(propName);
		attributeValue := _attributesBlock.cnEcGetTagValueOfName(attributeName);

//write class.name&amp;'::'&amp;method.name&amp;' '&amp;attributeName&amp;' to '&amp;attributeValue.String&amp;' '&amp;prop.type.String;
		if (not self.importPLXMLValidateProperty(attributeName, attributeValue)) then
			continue;
		endif;
	
		if prop.type = StringArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempStrArray := self.getPropertyValue(propName).StringArray;
			while pos &lt;= strLength do
				tempStrArray.add(attributeValue.String.getNextToken(pos));
			endwhile;
		elseif prop.type = CM_IntegerArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempCMIntArray := self.getPropertyValue(propName).CM_IntegerArray;
			while pos &lt;= strLength do
				tempCMIntArray.add(attributeValue.String.getNextToken(pos).Integer);
			endwhile;
		elseif prop.type = IntegerArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempIntArray := self.getPropertyValue(propName).IntegerArray;
			while pos &lt;= strLength do
				tempIntArray.add(attributeValue.String.getNextToken(pos).Integer);
			endwhile;
		elseif prop.type = TimeArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempTimeArray := self.getPropertyValue(propName).TimeArray;
			while pos &lt;= strLength do
				tempTimeArray.add(attributeValue.String.getNextToken(pos).Time);
			endwhile;
		elseif prop.type = DecimalArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempDecimalArray := self.getPropertyValue(propName).DecimalArray;
			while pos &lt;= strLength do
				tempDecimalArray.add(attributeValue.String.getNextToken(pos).Decimal);
			endwhile;
		elseif prop.type = BooleanArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempBooleanArray := self.getPropertyValue(propName).BooleanArray;
			while pos &lt;= strLength do
				tempBooleanArray.add(attributeValue.String.getNextToken(pos).Boolean);
			endwhile;
		elseif prop.type = BinaryArray then
			pos := 1;
			strLength := attributeValue.String.length;
			tempBinaryArray := self.getPropertyValue(propName).BinaryArray;
			while pos &lt;= strLength do
				tempBinaryArray.add(attributeValue.String.getNextToken(pos).Binary);
			endwhile;
		elseif prop.type = Boolean then
			self.importPLXMLPropUpdate(propName, attributeValue.Boolean);
		elseif prop.type = Character then
			self.importPLXMLPropUpdate(propName, attributeValue.Character);
		elseif prop.type = Date then
			self.importPLXMLPropUpdate(propName, attributeValue.Date);
		elseif prop.type = Decimal then
			self.importPLXMLPropUpdate(propName, attributeValue.Decimal);
		elseif prop.type = Integer then
			self.importPLXMLPropUpdate(propName, attributeValue.Integer);
		elseif prop.type = Point then
			self.importPLXMLPropUpdate(propName, attributeValue.Point);
		elseif prop.type = Real then
			self.importPLXMLPropUpdate(propName, attributeValue.Real);
		elseif prop.type = Time then
			self.importPLXMLPropUpdate(propName, attributeValue.Time);
		elseif prop.type = TimeStamp then
			self.importPLXMLPropUpdate(propName, attributeValue.TimeStamp);
		elseif prop.type = Binary then
			self.importPLXMLPropUpdate(propName, attributeValue.Binary);
		else
			self.importPLXMLPropUpdate(propName, attributeValue);
		endif;		
	endforeach;

end;</source>
        <Parameter name="_attributesBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLMyCollections" id="4601bce7-93d3-4880-990d-97cf1463e4ac">
        <updating/>
        <source>importPLXMLMyCollections(_collectionsBlock : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	property: Property;
	propColl: PropertyNDict;
	object: Object;
	name, theCode: String;
begin
	//re-implement as neccessary
	//what is done here obviously depends on what your exportMyReferences outputs
	create propColl transient;
	self.class.getPropertiesAllSuperclass(propColl);
	foreach property in propColl do
//write class.name&amp;'::'&amp;method.name&amp;" PropertyName="&amp;property.getName();
		if (not property.isKindOf(Reference)) then
			continue;
		endif;
		name := property.getName();
//write class.name&amp;'::'&amp;method.name&amp;" name="&amp;name&amp;' '&amp;property.String&amp;' '&amp;object.String;
//		theCode := _collectionsBlock.cnEcGetTagValueOfName(name);
		self.importPLXMLCollections(name, _collectionsBlock);
//		if object &lt;&gt; null then
//			self.importPLXMLColUpdate(name, object);
//		endif;
	endforeach;
end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLMyReferences" id="472e3c9d-dc05-48e6-b78e-1b0f9de59d8c">
        <updating/>
        <source>importPLXMLMyReferences(_referencesBlock : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	property: Property;
	propColl: ObjectArray;
	object, propObj: Object;
	name, theCode: String;
begin
	//re-implement as neccessary
	//what is done here obviously depends on what your exportMyReferences outputs

	create propColl transient;
	self.importPLXMLListProps(propColl);
	foreach propObj in propColl do
		property := propObj.Property;
//write class.name&amp;'::'&amp;method.name&amp;" PropertyName="&amp;property.getName();
		if (not property.isKindOf(Reference)) then
			continue;
		endif;
		name := property.getName();
		if name &lt;&gt; "myTerminal" and
		   name &lt;&gt; "terminal" then
			continue;
		endif;
//write class.name&amp;'::'&amp;method.name&amp;" name="&amp;name&amp;' '&amp;property.String&amp;' '&amp;object.String;
		theCode := _referencesBlock.cnEcGetTagValueOfName(name);
		object := self.importPLXMLReference(name, theCode, _referencesBlock);
		if object &lt;&gt; null then
			self.importPLXMLPropUpdate(name, object);
		endif;
	endforeach;
	foreach propObj in propColl do
		property := propObj.Property;
//write class.name&amp;'::'&amp;method.name&amp;" PropertyName="&amp;property.getName();
		if (not property.isKindOf(Reference)) then
			continue;
		endif;
		name := property.getName();
		if name = "myTerminal" or
		   name = "terminal" then
			continue;
		endif;
//write class.name&amp;'::'&amp;method.name&amp;" name="&amp;name&amp;' '&amp;property.String&amp;' '&amp;object.String;
		theCode := _referencesBlock.cnEcGetTagValueOfName(name);
		object := self.importPLXMLReference(name, theCode, _referencesBlock);
		if object &lt;&gt; null then
			self.importPLXMLPropUpdate(name, object);
		endif;
	endforeach;
epilog
	delete propColl;
end;</source>
        <Parameter name="_referencesBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLNewCollectionWorker" id="ae8ba5c3-9787-405b-ad93-ccec7e09d547">
        <source>importPLXMLNewCollectionWorker(_collectionsBlock: String; _colName: String; _colArray: ObjectArray io) protected;
//
// called by importPLXMLCollections
// this is called for each collection to return an array of proxyobject
// this is used when you need to create all the objects in the collection
vars
	aClass: Class;
	objBlock, objectBlock, theCode, theKey: String;
	newObject: Object;
	blockLength, pos: Integer;
begin
//write class.name&amp;'::'&amp;method.name&amp; " START.";
	objBlock := _collectionsBlock.cnEcGetTagValueOfName(_colName);
//write(class.name&amp;'::'&amp;method.name&amp;' '&amp;_colName);
	if objBlock = null then
//write class.name&amp;'::'&amp;method.name&amp; " return.";
		return;
	endif;
	pos := 1;
	blockLength := objBlock.length;
	while pos &lt; blockLength do
		theCode := objBlock.cnEcGetNextTagValueOfName('class', pos);
		if pos &lt; 1 then
			break;
		endif;
//write class.name&amp;'::'&amp;method.name&amp;' class='&amp;theCode;
		if theCode = null then
			continue;
		endif;
		aClass := currentSchema.getClass(theCode);
		if aClass &lt;&gt; null then
//write class.name&amp;'::'&amp;method.name&amp;' objBlock='&amp;objBlock;
			objectBlock := objBlock.cnEcGetNextTagValueOfName(theCode, pos);
//write class.name&amp;'::'&amp;method.name&amp;' objectBlock='&amp;objectBlock;
			create newObject as aClass transient;
			newObject.importPLXML(theCode, objectBlock);
//write class.name&amp;'::'&amp;method.name&amp;' objectKey='&amp;newObject.theKey;
			_colArray.add(newObject);
		endif;
		if pos &lt; 1 then
			break;
		endif;
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="_collectionsBlock" type="String"/>
        <Parameter name="_colName" type="String"/>
        <Parameter name="_colArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLOldDictWorkerInt" id="b1805ca1-7b61-4afc-a4af-b0d2b1a8f720">
        <source>importPLXMLOldDictWorkerInt(_collectionsBlock: String; _colName: String; _dict: Dictionary; _colArray: ObjectArray io) protected;
//
// called by importPLXMLCollections
// this is called for each collection to return an array of proxyobject
// this is used when you need to find all the objects in an exiting collection
vars
	aClass: Class;
	objBlock, theCode : String;
	theKey : Integer;
	newObject: Object;
	blockLength, pos: Integer;
begin
//write class.name&amp;'::'&amp;method.name&amp; " START.";
	objBlock := _collectionsBlock.cnEcGetTagValueOfName(_colName);
//write(class.name&amp;'::'&amp;method.name&amp;' '&amp;_colName);
	if objBlock = null then
//write class.name&amp;'::'&amp;method.name&amp; " return.";
		return;
	endif;
	pos := 1;
	blockLength := objBlock.length;
	while pos &lt; blockLength do
		theCode := objBlock.cnEcGetNextTagValueOfName('class', pos);
		if pos &lt; 1 then
			break;
		endif;
//write class.name&amp;'::'&amp;method.name&amp;' class='&amp;theCode;
		if theCode = null then
			continue;
		endif;
		aClass := currentSchema.getClass(theCode);
		theKey := objBlock.cnEcGetNextTagValueOfName('theKey', pos).Integer;
		if aClass &lt;&gt; null then
//write class.name&amp;'::'&amp;method.name&amp;' objBlock='&amp;objBlock;
//write class.name&amp;'::'&amp;method.name&amp;' objectBlock='&amp;objectBlock;
			newObject := _dict[theKey];
			if newObject &lt;&gt; null then
//write class.name&amp;'::'&amp;method.name&amp;' objectKey='&amp;newObject.theKey;
				_colArray.add(newObject);
			endif;
		endif;
		if pos &lt; 1 then
			break;
		endif;
	endwhile;
end;
</source>
        <access>protected</access>
        <Parameter name="_collectionsBlock" type="String"/>
        <Parameter name="_colName" type="String"/>
        <Parameter name="_dict" type="Dictionary"/>
        <Parameter name="_colArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
