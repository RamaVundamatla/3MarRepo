        <methodInvocation>mapping</methodInvocation>
        <source>voided(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	30 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// added for reports mainly
// to set update self.status := CM_InvoiceLine.STATUS_VOIDED	
//
vars

begin
	if set then
		return;
	endif;
	
	_value := (self.status = CM_InvoiceLine.STATUS_VOIDED);	

end;</source>
