    <JadeMethod name="getExtraInfo" id="c1615493-71a2-4021-86c6-acf2049654b8">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgab1	Initial creation

*/

vars
	block : CM_DataContainerBlock;
	wodres : CM_WodCargoRequest;
	wodres2 : CM_WodMarineServiceDetail;
begin
	inheritMethod(_dataContainer);
	
	//01 Aug 2018	NDL	TFS 39930
	if self.myBerth &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Berth), DC_Label, 1, null);
		block.addNewItem(self.myBerth.description , DC_Data, 1, null);
		
// TFS 41538		block := _dataContainer.addNewBlock;
//	TFS 41538	block.addNewItem(app.getErrorString(Occurs_datetime), DC_Label, 1, null);
//	TFS 41538	block.addNewItem( self.systemToLocalTime(self.getOccursDT()).asStringJMT() , DC_Data, 1, null);
		
	endif; 
	
	foreach wodres in self.allCargoDetails do
	
		wodres.getExtraInfo(_dataContainer);
	endforeach;
	
	//17 Aug 2018	NDL	TFS 40127
	foreach wodres2 in self.allMarineServiceDetails do
		wodres2.getExtraInfo(_dataContainer);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
