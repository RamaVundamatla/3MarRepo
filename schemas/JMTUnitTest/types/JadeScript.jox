    <JadeMethod name="mdhTestCreateOrChange" id="d0877bdc-f333-40e7-8273-4293a5ebbb38">
        <source>mdhTestCreateOrChange();

/*

Purpose:		Tests Created / Changed in the last ? days		

Date			Who		Reason
08/09/2015		cnwmh5	Initial creation

*/

vars

	klass						: Class;
	meth						: Method;
	file						: File;
	
	classes						: ClassColl;
	methodsDict					: MethodNDict;
	tokens						: StringArray512;
	
	found						: Boolean;
	linePos						: Integer;
	line						: String;
	token						: String;
	cnwPos						: Integer;
	userName					: String;
	indexOf						: Integer;
	noDays						: Integer;
	dateToCheck					: Date;
	modifiedTS					: TimeStamp;
	daysStr						: String;

begin

	daysStr := "0";
	while true do
		read daysStr;
		if daysStr = null then
			return;
		endif;
		if daysStr.isInteger() then
			noDays := daysStr.Integer;
			break;
		endif;
	endwhile;

	
	dateToCheck := dateToCheck.addDays(-noDays);

	create file transient;
	file.fileName := "c:\temp\UnitTestCreatedChangedLastNoDays.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("Class,Method,Owner,By,Process,Date,Time");

	// get UT_DSL class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	// create classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create tokens transient;
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict  do
			
			modifiedTS := meth.cnGetModifiedTimeStamp();
			if modifiedTS.date &lt; dateToCheck then
				continue;
			endif;
			
			if modifiedTS.date = meth.creationTime.date then
				file.writeLine(meth.schemaType.name &amp; "," &amp; meth.name &amp; "," &amp; meth.getMethodCreator() &amp; "," &amp;
					meth.cnGetModifierName() &amp; "," &amp; 'Created,' &amp; modifiedTS.date.String &amp; "," &amp; 
					modifiedTS.time.String);
			else
				file.writeLine(meth.schemaType.name &amp; "," &amp; meth.name &amp; "," &amp; meth.getMethodCreator() &amp; "," &amp;
					meth.cnGetModifierName() &amp; "," &amp; 'Changed,' &amp; modifiedTS.date.String &amp; "," &amp; 
					modifiedTS.time.String);
			endif;
			
		endforeach;
		
	endforeach;
	file.close();

epilog

	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTestCreateOverlapFile" id="bd9ab145-589b-4f56-a9d3-abed7f7daa70">
        <source>mdhTestCreateOverlapFile();

/*

