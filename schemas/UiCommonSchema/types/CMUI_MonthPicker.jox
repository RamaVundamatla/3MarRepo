    <JadeMethod name="getSelectedDate" id="4426a44f-6906-4fef-9081-23138a0845a7">
        <source>getSelectedDate() : Date;
/*
Return the selected date  - with the month and year that have been selected,and the day as the first one of the month
Date		    Who			Reason
01 November 2010	cnwas3	  

*/

