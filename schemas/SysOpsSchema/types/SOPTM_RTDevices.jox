    <JadeMethod name="isObjectRelevant" id="a5b604c3-1eeb-4d0b-adad-2fa34e7fad26">
        <source>isObjectRelevant(_obj: Object): Boolean;
//-----------------------------------------------------------------------
//	Created:	30 March 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
vars

begin

	if inheritMethod(_obj) then
		if _obj.CM_RadioTelemetryDevice.getMyTerminal = self.myForm.myTerminal then
			return true;
		endif;	
	endif;

	return false;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rtDeviceClass" id="3a26f5aa-908b-46cc-9a3a-2fb4dcbd20fa">
        <source>rtDeviceClass(_type : String) : Class;


begin

	if _type = RTDevice_HandHeld then
		return CM_RTDeviceHandHeld;
	elseif _type = RTDevice_Scanner then
		return CM_RTDeviceScanner;
	elseif _type = RTDevice_Vehicle then
		return CM_RTDeviceVehicleMount;
	endif;
	return null;

end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="410adfde-6c31-49cd-b02e-ed2f50948876">
        <updating/>
        <source>setControlsForAddEdit() updating;
vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	theForm.tblInput1.enableRowByName(ETRow_Model);
	theForm.tblInput1.enableRowByName(ETRow_Machine);
	theForm.tblInput1.enableRowByName(ETRow_Type2);
	theForm.tblInput1.disableRowByName(ETRow_MessageId);
	theForm.tblInput1.enableRowByName(ETRow_Id2);
							
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.showHideRowsByViewName('viewRTEverything', CM_EntryTable.ShowHideRows, false);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
		
	else
		// Can't change type without deleting object first.
		theForm.tblInput1.disableRowByName(ETRow_Type2);
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_RadioTelemetryDevice);
	endif;
    theForm.tblInput1.cnEcResizeContents;
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		theForm.btnSerialConn.enabled:= false;
	endif;

	
end;</source>
    </JadeMethod>
