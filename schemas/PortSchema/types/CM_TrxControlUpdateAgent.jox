    </JadeMethod>
    <JadeMethod name="trxReverseDeckingOrderBlocks" id="c341a4b5-df6f-4906-9873-27279570b367">
        <updating/>
        <source>trxReverseDeckingOrderBlocks(_blocks: CM_YABlockArray; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	19 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	yaBlock	: CM_YABlock;
//	ta		: CM_TerminalArea;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	if _blocks = null 
	or _blocks.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, 'list of blocks is null');
		return;
	endif;
	

beginTransaction;


	foreach yaBlock in _blocks do
	
		app.myUtilityUA.utlReverseDeckingOrderYABlock(yaBlock.CM_YABlockGridArea, _passport);
	
		if _passport.hasErrors then
			return;
		endif;
	
	endforeach;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_blocks" type="CM_YABlockArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxReverseDeckingOrderGridRows" id="6296bc94-1352-4afe-a708-c2ffe1d211e0">
        <updating/>
        <source>trxReverseDeckingOrderGridRows(_gridRows: CM_GridRowDict; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//
//	Purpose:	Reversing the decking order on a STRADDLE row
//
//----------------------------------------------------------------
vars
	gridRow	: CM_GridRow;
	ta		: CM_TerminalArea;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	if _gridRows = null 
	or _gridRows.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, 'gridRows is null or empty');
		return;
	endif;
	
	if not CM_StraddleStack.hasInstance(_gridRows.first.myGridArea) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'invalid area type for this function');
		return;
	endif;

beginTransaction;


	foreach gridRow in _gridRows do
	
		app.myUtilityUA.utlReverseDeckingOrderGridRow(gridRow, _passport);
	
		if _passport.hasErrors then
			return;
		endif;
	
	endforeach;
	ta := gridRow.getGridArea();
	
	if ta &lt;&gt; null then
		ta.causeEvent(ta.myTerminal.getTerminalEvent(EVENT_DECKING_CHANGE), false, ta);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_gridRows" type="CM_GridRowDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRoadJobCompleteReceipt" id="3937f235-ae70-495b-948c-5a378be63dd4">
        <updating/>
        <source>trxRoadJobCompleteReceipt(_passport : CM_Passport input; _alertCreated : Boolean io) updating;
//-----------------------------------------
//Created: December 2002 By: cnwgd1
//-----------------------------------------
/*

Date		Who		Reason
22 Jan 2018	jlgkpd1	TFS 36660 - Penn locking issues
31/05/2022	jlier1	TFS 53650 - refactored schedule packages now called from vvr.departureProcess	
*/

vars
	cancelSave 	: Boolean;
	jobArray	: CM_JobArray;
	roadJob		: CM_RoadJob;
	job			: CM_Job;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_passport.myTerminal, 'Terminal');
	
	if (not _passport.noErrors()) then
		return;
	endif;
	
	self.raiseExceptionIfNull(_passport.myTerminal.myRoadJobSheet, 'Terminal Road Job Sheet');
	
	if (not _passport.noErrors()) then
		return;
	endif;															

	// TFS 36660 - Reduce locking
	jobArray := _passport.myTerminal.myRoadJobSheet.allJobsByOrder.cloneSelf(true);
	
	foreach job in jobArray do
		if (not job.isKindOf(CM_RoadJob)) then
			continue;
		endif;
		roadJob := job.CM_RoadJob;
		if roadJob.isRelease then
			continue;
		endif;
		exclusiveLock(roadJob);	
		//th2 23/01/07 deadlock on CM_Terminal::allVehicleVisitRecords
		exclusiveLock(_passport.myTerminal.allVehicleVisits);
	
		roadJob.validateForMove(REAL_MODE);
		if _passport.noErrors then
			beginTransaction;
			roadJob.doMove(REAL_MODE, _passport);
			if roadJob.status = JOB_COMPLETE then	
				roadJob.departureProcess(_passport);				
			endif;
		endif;

		if _passport.noErrors() then
			app.cmsCommitTransaction(_passport);
		else
			app.convertErrorsWarningsToAlert('Road Job ' &amp; roadJob.jobNumber &amp; ' could not be completed.', _passport.allErrorWarnings);
		
			_alertCreated := true;
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
	delete jobArray;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_alertCreated" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trxRollBooking" id="cfd89871-22c3-447b-aa50-29a3dd932edb">
        <updating/>
        <source>trxRollBooking(		_oldBookingsSet : CM_BookingRefSet io; 
					_newBookingStr : String; 
					_voyage : CM_Voyage; 
					_dischargePortCode :String;
					_transhipPort : CM_Port; 
					_remarks : String;
					_passport : CM_Passport input	) updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 26/10/2011	cnwdap1		PAR #28524 CCMS POL 2096 Change to roll method - don't close old bookings
//							if booking reference is the same, just update booking with new voyage and discharge port
// 14/02/2012	cnwdap1		PAR #29029 Correct multi-booking roll, and fix audits
// 18 Nov 2019  jlger1 		TFS 47457 - Refactor so roll set tis in trx 
vars
	pxyBooking,
	oldBooking,
	newBooking				: CM_BookingRef;
	allNewBookingRefProxies : CM_ObjectArrayActual; //creat pxy for create later for audit cnwrd1 12.2.09 par #17936
	tis						: CM_TISet;
	invalidBooking			: Boolean;
	oldBookingRef, oldVoyage, 				// PAR #29029
	oldDischarge			: String;		// PAR #29029
	
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	on Exception do app.handleDeletedObject(exception, oldBooking, invalidBooking); 
	
	app.myPassport.useTITransactionDeferUpdate := true;
	
	if _oldBookingsSet.size = 1 then
		//------------------------------------------------------------------------------------
		// 								SIMPLE ROLL MODE
		//------------------------------------------------------------------------------------
		oldBooking := _oldBookingsSet.first;
		oldBookingRef := oldBooking.bookingReference;	// PAR #29029
		if oldBooking.myVoyage &lt;&gt; null then				// PAR #29029
			oldVoyage := oldBooking.myVoyage.code;		// PAR #29029
		else											// PAR #29029
			oldVoyage := null;							// PAR #29029
		endif;											// PAR #29029
		oldDischarge := oldBooking.dischargePort;		// PAR #29029
		
		// 18 Nov 2010  jlger1 TFS 47457 - Refactor so roll set tis in trx 
		create tis transient;
		oldBooking.getTIsForRollSplit(tis);		//cnwmc5 - 25 July 2013 - PAR 32084
			// TFS 40417 if self.chkTranships.value  then																			//+TFS38548
		if oldBooking.getMyTerminal.getConfig(AutoBookingCargoUpdates).Boolean then // TFS 40417
			if oldBooking.getMyTerminal.getConfig(AutoBookingCargoUpdateTS).Boolean then // TFS 40417
				oldBooking.getTranshipTIsForRoll(tis, oldBooking.myVoyage);
			endif;
		endif;
		
		
		beginTransaction;
		
		// PAR #28524 if the booking reference hasn't changed, don't create a new booking, just update the old
		if oldBooking.bookingReference = _newBookingStr then
		
			oldBooking.setForUpdateRoll(_voyage, _dischargePortCode);
			newBooking := oldBooking;
			
		else
		
			// PAR #28524 if the booking reference is different, create a new booking
			//newBooking	:= app.myUtilityUA.utlCloneBookingRef(_oldBooking, _newBookingStr, _voyage, _dischargePortCode, _passport);
			pxyBooking	:= app.myUtilityUA.utlCloneBookingRef( oldBooking, _newBookingStr, _voyage, _dischargePortCode,_transhipPort, _passport); //creat pxy for create later for audit cnwrd1 12.2.09 par #17936
			 
			create allNewBookingRefProxies transient; //creat pxy for create later for audit cnwrd1 12.2.09 par #17936
			
			app.myUtilityCA.utlCreateBookingRef(pxyBooking, app.myPassport, null, newBooking, allNewBookingRefProxies); //creat pxy for create later for audit cnwrd1 12.2.09 par #17936
		endif;
		
		if _passport.noErrors then
			app.myUtilityUA.utlSplitRollBooking(tis, oldBooking, newBooking, false, _remarks, _passport) ;
		endif;
		//audit
		if _passport.noErrors then
			oldBooking.createAuditObjectInformation( app.getErrorString3(AUD_RolledBookingOld, newBooking.bookingReference, _voyage.code, _dischargePortCode));
			newBooking.createAuditObjectInformation( app.getErrorString3(AUD_RolledBookingNew, oldBookingRef, oldVoyage, oldDischarge));	// PAR #29029		//cnwmc5 - 11 Nov 2013 - PAR 32671
		endif;
	
		if _passport.noErrors() then	
			_passport.doDeferredUpdates();
		endif;	
	
	else
		//------------------------------------------------------------------------------------
		// 								BULK ROLL MODE
		//------------------------------------------------------------------------------------
		beginTransaction;
		
		foreach oldBooking in _oldBookingsSet do

			if _passport.hasErrors then
				break;
			endif;
		
			// need to create tis for each booking ref
			if invalidBooking then
				invalidBooking := false;
				continue;
			endif;
			
			if tis &lt;&gt; null then
				delete tis;
			endif;
			create tis transient;
			
			//cnwmc5 - 25 July 2013 - PAR 32084
			oldBooking.getTIsForRollSplit(tis);

			oldBookingRef := oldBooking.bookingReference;	// PAR #29029
			if oldBooking.myVoyage &lt;&gt; null then				// PAR #29029
				oldVoyage := oldBooking.myVoyage.code;		// PAR #29029
			else											// PAR #29029
				oldVoyage := null;							// PAR #29029
			endif;											// PAR #29029
			oldDischarge := oldBooking.dischargePort;		// PAR #29029
			
			// PAR #28524 Just update existing bookings, don't create new ones
			oldBooking.setForUpdateRoll(_voyage, _dischargePortCode);	// PAR #29029
			newBooking := oldBooking;
			
			if self.checkValidationWithPassport(_passport) then													//+cnwml2 PAR20884  handle warnings coming into the system via discrepancies
				app.myUtilityUA.utlSplitRollBooking(tis, oldBooking, newBooking, false, _remarks, _passport);
				if _passport.noErrors then
					oldBooking.createAuditObjectInformation( app.getErrorString3(AUD_RolledBookingOld, newBooking.bookingReference, _voyage.code, _dischargePortCode));
					newBooking.createAuditObjectInformation( app.getErrorString3(AUD_RolledBookingNew, oldBookingRef, oldVoyage, oldDischarge));	// PAR #29029		//cnwmc5 - 8 Nov 2013 - PAR 32671
				endif;
			
				if _passport.noErrors() then	
					_passport.doDeferredUpdates();
				endif;	
			endif;

			delete allNewBookingRefProxies;
			delete tis;
		
		endforeach;
	
	endif;
	
	//+cnwml2 PAR21072
	if _passport.noErrors and newBooking &lt;&gt; null then						// cnwjk3 PAR 23444 26/03/2010
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(newBooking);
	endif;
epilog
	delete pxyBooking;
	delete tis;
	delete allNewBookingRefProxies;

	
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_oldBookingsSet" type="CM_BookingRefSet" usage="io"/>
        <Parameter name="_newBookingStr" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dischargePortCode" type="String"/>
        <Parameter name="_transhipPort" type="CM_Port"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxRoroVehicleConfirm" id="fda0416b-c0ff-421c-b1a0-2614f45fb4d8">
        <updating/>
        <source>trxRoroVehicleConfirm(	ti : CM_TrackedItem input; 
						targetLocation : CM_YardController input;
						altId : String;
						numberingDirection : String;
						isAutoPlan : Boolean;
						isIgnoreQueued : Boolean;
						dateReceived : TimeStamp;
						confirmedDate : TimeStamp;
						remarks : String;
						confirmedRemarks : String) updating;
/*
Purpose: Discharge vehicle to the lane			

Parameters:			

Return Value:		

Date		Who			Reason
01/08/2017	jlgam15		TFS#5546 RoRo Vehicle Confirm
16/10/2017	jlgdap1		TFS 7306 AAT Don't set app.isInProformaMode - this is for cash only,
						and resulted in incorrect invoice splitting at AAT
15/02/2022	navlw1		TFS# 52826
*/

vars
	control 					: CMIF_MoveController;
	stowageConfirmController 	: CMIF_StowageConfirmController;
	newTITransaction 			: CM_TITransaction;
	locString 					: String;
	tiUpdateCntrlr 				: CMIF_TIUpdateController;
	roroLane 					: CM_RoRoController;
	allTIs 						: CM_TIArray;
	isRightToLeft 				: Boolean;
	terminal 					: CM_Terminal;
	location 					: CM_LocationsController;
	task						: CM_RTQueueTask;
begin

	self.initialiseActivityWithPassport(app.myPassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, app.myPassport);
	on LockException do agtPassportLockExHandler(exception, app.myPassport);
	
	//31 Dec 2018	NDL	TFS 42356 - Do defered updating
	app.setContinueCMExceptions(false);
	app.myPassport.useTITransactionDeferUpdate := true;
	app.myPassport.useTIDictDeferUpdate := true;
	
	
	self.raiseExceptionIfNull(ti,"cargo");
	if targetLocation = null and not isAutoPlan then // 15 Feb 2022 navlw1 tfs# 52826
		app.raiseCMException(Err_InvalidLocation,null,null);
	endif;
	
	if targetLocation.isKindOf(CM_RoRoController) and not isAutoPlan then // 15 Feb 2022 navlw1 tfs# 52826
		roroLane:=targetLocation.CM_RoRoController;
	endif;
	
	// 14 Feb 2022 navlw1 tfs# 52826
	if targetLocation = null and isAutoPlan then
		// get the terminal in which we wish to auto plan the cargo item
		terminal := app.myPassport.myTerminal;
		//get the auto planned location
		location := app.autoPlanTiYA(terminal,null,ti);
		if location = null then
			app.raiseCMException1(Failed_auto_plan,ti.id,null,null);
		endif;
		
		// First check that it is not already queued
		task := ti.getQueueTask;									
		if task &lt;&gt; null and isIgnoreQueued then			
			app.raiseCMException1(Tracked_item_already_queued, ti.id, null, null);
		endif;
	else
		location := targetLocation;
	endif;
	
	beginTransaction;
	create control transient;
	control.setMyTrackedItem(ti);
	control.setMyToPrimaryLocation(location);
	control.setMoveMode(REAL_MODE);	
	control.isSystemMove := true;
	
	// 15/02/2022 navlw1 tfs# 52826
	if isAutoPlan and remarks &lt;&gt; null then
		ti.setRemarksAdditionals(remarks, null);
	endif;
	
	// 23 Mar 2022 navlw1 tfs# 52826
	if dateReceived &lt;&gt; null then
		control.setEffectiveTimeStampOverride(dateReceived);
	endif;
	
	//epr TFS 7931 1/12/17
	
	if roroLane &lt;&gt; null then
		if numberingDirection &lt;&gt; null then
			isRightToLeft :=numberingDirection = roroLane.myRoRoLaneArea.getRightToLeftString(roroLane.myRoRoLaneArea.leftLabel, roroLane.myRoRoLaneArea.rightLabel);
		else
			isRightToLeft := roroLane.freedLength &gt; 0;
		endif;
		
		if isRightToLeft then
			roroLane.setFreedLength(0);
		endif;
	endif;
	app.myUtilityUA.utlUpdateMoveTrackedItem(control,app.myPassport);
	if app.myPassport.hasErrors then
		return;
	endif;
	//if if direction is right to left insert in first location and shuffle
	if isRightToLeft then
		if location.allTrackedItems.size &gt; 1 then
			create allTIs transient;
			location.allTrackedItems.copy(allTIs);
			allTIs.remove(ti);
			allTIs.insert(1,ti);
			app.myUtilityUA.utlUpdateRoRoLaneTiOrder( roroLane, allTIs, app.myPassport );	//23 Jan 2020	NDL	TFS 48270
		endif;
		roroLane.setFreedLength(roroLane.spareLengthActual);

	endif;
		
	//create transaction type
	//app.setIsInProformaMode(true);					// TFS 7306
	create stowageConfirmController transient;		
	stowageConfirmController.type := TRANS_TYPE_STOWAGE_CONFIRM;
	
	// 21 Feb 2022 navlw1 tfs# 52826
	if confirmedDate &lt;&gt; null then
		stowageConfirmController.dateTime := confirmedDate;
	else
		stowageConfirmController.dateTime := app.actualTimeServer();
	endif;
	
	stowageConfirmController.userId := app.myPassport.userCode;
	stowageConfirmController.noCharge := false;
	stowageConfirmController.myTrackedItem := ti;
	locString := location.getFullIdTI(ti) &amp; " " &amp; location.allTrackedItems.indexOf(ti).String;
	stowageConfirmController.confirmedLocation := locString;
	stowageConfirmController.myTerminal := app.myPassport.myTerminal;
	
	// 21 Feb 2022 navlw1 tfs# 52826
	if confirmedRemarks &lt;&gt; null then	
		stowageConfirmController.remarks := confirmedRemarks;
	endif;
	
	app.myUtilityCA.utlCreateStowageConfirmTrans(stowageConfirmController,newTITransaction,app.myPassport);
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	if altId &lt;&gt; null then
		//epr par 34113 21/5/14
		tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
		ti.setAlternativeIdTrans(altId,tiUpdateCntrlr,app.myPassport);
	endif;
		
	//31 Dec 2018	NDL	TFS 42356 - Do defered updating
	if app.myPassport.noErrors then
		app.myPassport.doDeferredUpdates();
	endif;
		
epilog
	delete allTIs;
	delete control;
	delete stowageConfirmController;
	delete tiUpdateCntrlr;
	self.finaliseActivityWithPassport(app.myPassport);
end;</source>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="targetLocation" type="CM_YardController" usage="input"/>
        <Parameter name="altId" type="String"/>
        <Parameter name="numberingDirection" type="String"/>
        <Parameter name="isAutoPlan" type="Boolean"/>
        <Parameter name="isIgnoreQueued" type="Boolean"/>
        <Parameter name="dateReceived" type="TimeStamp"/>
        <Parameter name="confirmedDate" type="TimeStamp"/>
        <Parameter name="remarks" type="String"/>
        <Parameter name="confirmedRemarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="trxRunImportTasksOnShip" id="cad1c5ec-0e95-49f8-916c-69811913d6d0">
        <updating/>
        <source>trxRunImportTasksOnShip(_voyage: CM_Voyage input; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	if not _passport.myUser.canDo(_passport.myTerminal, PmShipRunImportTasks) then
		app.raiseCMException1(NoPermission, 'perform this task', null, null);
		return;
	endif;	

	if _voyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'voyage', null, null);
		app.raiseCMException(Input_required_field_voyage, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	app.setContinueCMExceptions(true);
	
//	_passport.useTITransactionDeferUpdate := true;
	
	_voyage.runImportTasksOnShip(_passport);

//	_passport.doDeferredUpdates();
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
