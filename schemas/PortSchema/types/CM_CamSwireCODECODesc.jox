    <JadeMethod name="makeMessageTDT20Segment" id="694189a2-4614-436c-89de-e2f1cdd720a8">
        <updating/>
        <source>makeMessageTDT20Segment(_protocol :CM_CamProtocol; _camVoyage :CM_CamVoyage; _activity :Integer ):String updating, protected;
/*
Purpose:		Output TDT+20 segment for voyage			

Date		Who		Reason
17 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
*/
//30 may 2014	cnwrs1	Par 34265 in vCode is null dont put out vessel details 
vars
	vCode, operator,
	msg			:String;
	voyage		:CM_Voyage;
	foundMatch	:Boolean;
begin
	vCode 	:= _camVoyage.getSanitisedVoyageCode().trimBlanks;
	voyage	:= _camVoyage.voyageOid;
	
	if voyage &lt;&gt; null then
		// Swires required the TDT+20 record to contain the Voyage Operator
		// details when available, default to SSL when not available.
		if voyage.myOperator = null then
			operator	:= 'SSL';
		else
			operator	:= app.myRoot.getXlationForeignOperatorCode (voyage.myOperator, voyage.myOperator.code, foundMatch );
		endif;
		
		if vCode &lt;&gt; null and	//30 May 2014	cnwrs1	Par 34265
		   voyage.vesselName &lt;&gt; null then
			if _protocol.camGroup.useCallSign then
				msg := self.makeTDT20Segment (_protocol, vCode, '1', null, operator, null, null, null, null, voyage.callSign.trimRight, '103', null, voyage.vesselName.trimRight.toUpper);
			else
				msg := self.makeTDT20Segment (_protocol, vCode, '1', null, operator, null, null, null, null, voyage.lloydsNumber, '146', null, voyage.vesselName.trimRight.toUpper);
			endif;
		else
			msg := self.makeTDT20Segment (_protocol, vCode, '1', null, 'SSL', null, null, null, null, null, '146', null, null);
		endif;
	else
		//no voyage TDT+20++1+++++:146::'
		msg := self.makeTDT20Segment (_protocol, null, '1', null, 'SSL', null, null, null, null, null, '146', null, null);	
	endif;

	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_activity" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="24f329db-f408-41d3-a41c-d2f27aaaf383">
        <source>makeMessages(
	_trackedItem	: CM_TrackedItem;
	_transaction	: CM_TITransaction;
	_camProtocol	: CM_CamProtocol;
	_camMessage		: CM_CamMessage input;
	_xlVoyageId		: String;
	_terminal		: CM_Terminal; _secondTrx : CM_TITransaction );
// SWIRE
/*
Purpose:	This copy of CM_CamCODECODesc makeMessages (as at 13/04/2010) is being changed to create
			the required CAMS output required for Swire Shipping (used to be Tasman Orient Line).
			
			The summaration of the main differences are:
			Each container must be done as separate transaction.
			
			The following Location (LOC) segments are to be reported within Group 5 (only) of the
			Gate Out message only for empty or full activity:
			LOC+9 -&gt; Loading Port
			LOC+165 -&gt; Activity Place
			LOC+11 -&gt; Discharge Port
			
			RFF+AAE segment is only needed to be reported for Gate In activity,
			which is the customExportEntryNumber (CEDO).
			
			RFF+BN segment is not needed to be reported in the Gate Out Message –
			it is only to be reported for the Gate In Message.
			
			The TMP segment (temperature) is also needs to be reported in the Gate In Message.
			This segment relates specifically to a reefer container – which means that this
			segment will not always be reported, and formatted as TMP+2+-nnn:CEL'
			
			The mandatory segment GID+1 needs to be shown in both gate out and gate in message.
			
			On the SGP require the number of packages stowed in the container.
			
			Make sure the TDT+20 record contains the Voyage Operator (PAR 24128)
			
Date			Who		Reason
13 April 2010	cnwrl1	Initial creation as part of PAR 23617 - Create a CODECO CAMS message for Swire Shipping
10/02/2011		cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camMessage parameter usage from io to input
18/05/2011		cnwcs5	ccms sct 2058/par27460 - user defined special characters
05 Jan 2012		cnwrs1	Par 28933 - do not produce SEL message for MT containers
07 Mar 2013		cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
30/05/2016		cnwdap1	TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 15/07/2016   cnwma1  TFS #2376 POL - CODECO NAD lines in wrong segment and doubling up on information
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
21 Jun 2022		jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
*/
	
vars
	fCode			: String;
	code			: String;
	tempStr			: String;
	imExStatus		: String;
	contentsStatus	: String;
	ti				: CM_TrackedItem;	
	foundMatch		: Boolean;
	isoCode,fIsoCode : String;
	includeVGM : Boolean;
begin
	ti := _transaction.myTrackedItem;
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, _camMessage.activity, _transaction.type);
	
	// GID+1 - One of the Swire Shipping changes - now mandatory.
	self.makeGIDSegment (_camProtocol, _camMessage.group3, 1);	// par 27460 09/05/2011 cnwcs5 
	
	// cnwrl1 19/10/2010 PAR 25867 - start of replacement coding
	if contentsStatus = "5" then
		// set up the potential group of GID, TMP, SGP and DGS records.
		// NOTE: Swires always require the GID - see approx line 58
		if ti.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE or ti.allTIHazards.isNotEmpty then
			// TMP Segment
			self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL");	// par 27460 17/05/2011 cnwcs5 				
			
			// Swire Shipping - require the number of packages stowed in the container.
			// Split Goods Placement
			self.makeSGPSegment (_camProtocol, _camMessage.group3, ti.id.trimRight, ti.numChildren);		// par 27460 09/05/2011 cnwcs5 	
			
			// ie Dangerous Goods
			if not _camProtocol.dgsDetailsInGroup14  then							//JIRA-20814
				self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 	
			endif;																	//JIRA-20814
		endif;
	endif;
	// EQd segment
	if contentsStatus = "5" then
		imExStatus := self.imExStatusToString(ti);	// full
	else
		imExStatus := "";								// empty
	endif;
	//self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, ti.CM_Container.isoType, '102', '5', null, imExStatus, contentsStatus); // par 27460 17/05/2011 cnwcs5 	//23/08/2017 cnwma1 TFS #5834
	isoCode := ti.CM_Container.isoType;
	fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight,fIsoCode, '102', '5', null, imExStatus, contentsStatus); 	//23/08/2017 cnwma1 TFS #5834
	_camMessage.eqdCount := _camMessage.eqdCount + 1;
	
	// only include the booking reference number when the container comes in
	if _camMessage.activity = CODECO_GATEIN then
		// RFF+BN - only for receipts
		self.makeMessageRFF_BN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);	// par 27460 cnwcs5
		
		// One of the Swire Shipping changes
		if ti.customsEntryNumber &lt;&gt; null then
			// An AAE is the "Goods Declaration Number"
			self.makeRFFSegment (_camProtocol, _camMessage.group5, "AAE",  ti.customExportEntryNumber);	// par 27460 17/05/2011 cnwcs5 			
		endif;
		// end of this Swire Shipping changes
	endif;
	
	// RFF+CN - special18 field
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs

	// if creating extra messages for pack/unpack add 1 minute to the second message
	self.makeDTMSegment(_camProtocol, _camMessage.group5, '7', self.transDateTime(_transaction, _camMessage.activity, _camProtocol), '203');	// TFS 53754

	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;
	
	if _camMessage.activity = CODECO_GATEIN then
		// LOC segments
		self.makeMessageLOC_GATEIN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5
		
	elseif _camMessage.activity = CODECO_GATEOUT then
		// LOC segments
		self.makeMessageLOC_GATEOUT (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5		
	endif;
	
	// One of the Swire Shipping changes
	// This Location information is required in the segment 5 group rather than in the segment 1.
	code	:= _terminal.getConfig(PortDestCode).String;
	fCode	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal).trimRight;
	if _camMessage.activity = CODECO_GATEOUT then
		self.makeLOCSegment (_camProtocol, _camMessage.group5, '11', fCode, '139', '6', null, null, null);	// par 27460 09/05/2011 cnwcs5 
	else
		self.makeLOCSegment (_camProtocol, _camMessage.group5, '9', fCode, '139', '6', null, null, null);	// par 27460 09/05/2011 cnwcs5 
	endif;
	// end of this Swire Shipping changes
	
	code := _terminal.getConfig(PortDestCode).String;
	fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, code, XLATION_TYPE_PORT_BYOP, _terminal);
	self.makeLOCSegment (_camProtocol, _camMessage.group5, '165', fCode, '160', '20', null, null, null);	// par 27460 09/05/2011 cnwcs5 
	
	// MEA+ segment
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group5,ti,null); //epr par 37551 TFS 1429 16/2/16
		
	// DIM+ segements
	self.makeMessageDimensionsData (_camProtocol, _camMessage.group5, ti);		// par 27460 17/05/2011 cnwcs5
	
	// SEL - the SEL for the seal number
	self.makeMessageSealsData( ti, _camMessage, _camMessage.group5, _camProtocol, contentsStatus);	//15 Sep 2010	NDL	Par 25608

	// FTX+AAI
	self.makeMessageFTX_DeliveryReason (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs5	
	if includeVGM then
		self.makeMessageFTX_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;

	// EQA - the only attached equipment is a reefer generator
	self.makeEQASegment (_camProtocol, _camMessage.group5, 'RG', ti);	// par 27460 09/05/2011 cnwcs5
	
	// TDT+1
	self.makeMessageTDT1Segment (_camProtocol, _camMessage.group5, _camMessage.activity, _transaction, ti);	// par 27460 cnwcs5
	
	// NAD+CF
	if _camProtocol.useContainerOperator_In_NAD_CF then
		// translate the Party Identifier
		tempStr	:= app.myRoot.getXlationForeignOperatorCode( null, ti.CM_Container.operatorCode.trimBlanks, foundMatch );
		// rest is made up of 1131 = "Code list identification code" and 3055 = "Code list responsible agency code"
		// 172 = Carriers, 20 = "BIC (Bureau International des Containeurs)"
		self.makeNADSegment (_camProtocol, _camMessage.group5, "CF", tempStr.trimRight, '172', '20');	// cnwcs5 par 27460 11/05/2010
	endif;
	
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then				// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group5, ti);									// 15/07/2016 cnwma1  TFS #2376
	endif;																								// TFS #2061
	
	// ie Dangerous Goods													//JIRA-20814
	if _camProtocol.dgsDetailsInGroup14  then								//JIRA-20814
		self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group5);	//JIRA-20814
	endif;																	//JIRA-20814
epilog
	
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeSGPSegment" id="453f22ad-7d61-47fa-9994-0dd4d41d029d">
        <source>makeSGPSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _id :String; _packages :Integer):String protected;
/*
Purpose:	Make a SGP segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "SGP";
vars
	msg, count			:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	count := _packages.asStringJMT;
	
	msg := MESSAGE &amp; plus &amp; _id;
	
	if count &lt;&gt; null then
		// SWIRES use colon here - i think it is a mistake but they are using it now
		msg := msg &amp; colon &amp; count;
	endif;
	
	msg := msg &amp; singleQuote;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_packages" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeTMPSegment" id="85a837ae-0889-4b2f-aea1-366ba18036e2">
        <source>makeTMPSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _qualifier :Integer; _temp :Real; _tempQual:String):String protected;
/*
Purpose:	Make a TMP segment
Returns:	null if there is not a valid temperature

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "TMP";
vars
	msg, temp					:String;
	plus, colon, singleQuote	:Character;
begin
	if _temp = NULL_TEMPERATURE then
		return null;
	endif;
	
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;

	// Swire Shipping - require the format as TMP+2+-nnn:CEL'
	if _temp &lt; 0 then
		temp := "-" &amp; _temp.Integer.positive.stringWithLeadingZeros(3);
	else
		temp := _temp.Integer.positive.stringWithLeadingZeros(3);
	endif;
	
	msg := MESSAGE &amp; plus &amp; 
			_qualifier.String &amp; plus &amp;
			temp &amp; colon &amp; _tempQual;
			
	msg := msg &amp; singleQuote;

	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_qualifier" type="Integer"/>
        <Parameter name="_temp" type="Real"/>
        <Parameter name="_tempQual" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_LOC" id="6eba2da5-9ff9-4580-8a68-f05ca392d7e0">
        <updating/>
        <source>outputHeader_LOC(_protocol :CM_CamProtocol; _camMessage :CM_CamMessage input; _camTaskHistory :CM_CamTaskHistory input; _terminal :CM_Terminal; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	
begin
	// do nothing - LOC not include in Swire header
	return null;
epilog

end;</source>
