    <JadeMethod name="setDeckingMenuIn" id="9b5de47a-c689-480d-9cf7-ade60d0694ee">
        <source>setDeckingMenuIn(_deckingInMenu: MenuItem input; _currentType: Integer; _isFork: Boolean; _deckingLevel: Integer) protected;
//----------------------------------------------------------------
//	Created:	06 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	i			: Integer;
	subMenu,
	mnuChild	: MenuItem;
	isInMenu,
	isOutMenu		: Boolean;
begin
	
	foreach i in DeckingMenu_In_Opt0 to DeckingMenu_In_Opt9 do
		mnuChild := _deckingInMenu.getMenuItem(i);
		if mnuChild = null then
			mnuChild := _deckingInMenu.loadSubMenu(i);
		endif;
		mnuChild.checked := false;
		mnuChild.userObject := _deckingInMenu.userObject;
		mnuChild.caption := app.getDeckingInCaption(i);
		if not _isFork then
			if i &gt;= DeckingMenu_In_Opt5
			and i &lt; DeckingMenu_In_Opt9 then
				mnuChild.visible := false;
				continue;
			endif;
		endif;
		if _deckingLevel = DeckingLevel_TA
		and i &lt; DeckingMenu_In_Opt1 then
			mnuChild.enabled := false;
		else
			mnuChild.enabled := true;
		endif;
		mnuChild.visible := true;
		if app.getDeckingOptionFromMenuIndex(i-DeckingMenuOffset_In) = _currentType then
			mnuChild.checked := true;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_deckingInMenu" type="MenuItem" usage="input"/>
        <Parameter name="_currentType" type="Integer"/>
        <Parameter name="_isFork" type="Boolean"/>
        <Parameter name="_deckingLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDeckingMenuItem" id="92580cc4-633c-4aea-afa3-5713e9c0ca61">
        <source>setDeckingMenuItem(_key: Integer; _menuItem: MenuItem input; _isInMenum, _isOutMenu: Boolean output) protected;
//----------------------------------------------------------------
//	Created:	06 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str, capt	: String;
	constant 	:	GlobalConstant;
	translation : XLAT_Translation;
begin
	
	if _key = DeckingMenu_In then
		_isInMenum := true;
	elseif _key = DeckingMenu_Out then
		_isOutMenu := true;
	endif;
	
	_menuItem.visible := true;
	_menuItem.enabled := true;
	
	// par#13514 Mohammad 29/3/2007
	str := 'DeckingMenuName_' &amp; _key.String;
	constant := currentSchema.getConstant(str);
	if constant &lt;&gt; null then
		translation := app.zGetTranslatedText(XLAT_Exceptions, constant.valueAsInteger);
		if translation &lt;&gt; null then
			capt := translation.text;
		else
			capt := 'Unknown Menu ' &amp; _key.String;
		endif;
	endif;
	
	_menuItem.caption := capt;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="Integer"/>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
        <Parameter name="_isInMenum" type="Boolean" usage="output"/>
        <Parameter name="_isOutMenu" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setDeckingMenuOut" id="d5937caf-1804-47e2-beb4-89c7b15e2daf">
        <source>setDeckingMenuOut(_deckingMenuOut: MenuItem input; _currentType: Integer; _isFork: Boolean; _deckingLevel: Integer) protected;
//----------------------------------------------------------------
//	Created:	06 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	i			: Integer;
	subMenu,
	mnuChild	: MenuItem;
	isInMenu,
	isOutMenu		: Boolean;
begin
	
	foreach i in DeckingMenu_Out_Opt0 to DeckingMenu_Out_Opt10 do
		mnuChild := _deckingMenuOut.getMenuItem(i);
		if mnuChild = null then
			mnuChild := _deckingMenuOut.loadSubMenu(i);
		endif;
		mnuChild.checked := false;
		mnuChild.userObject := _deckingMenuOut.userObject;
		mnuChild.caption := app.getDeckingOutCaption(i);
		if not _isFork then
			if i &gt;= DeckingMenu_Out_Opt5
			and i &lt; DeckingMenu_Out_Opt9 then
				mnuChild.visible := false;
				continue;
			endif;
		endif;
		if _deckingLevel = DeckingLevel_TA
		and i &lt; DeckingMenu_Out_Opt1 then
			mnuChild.enabled := false;
		else
			mnuChild.enabled := true;
		endif;
		mnuChild.visible := true;
		if app.getDeckingOptionFromMenuIndex(i-DeckingMenuOffset_Out) = _currentType then
			mnuChild.checked := true;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_deckingMenuOut" type="MenuItem" usage="input"/>
        <Parameter name="_currentType" type="Integer"/>
        <Parameter name="_isFork" type="Boolean"/>
        <Parameter name="_deckingLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDefaultKeyCodes" id="dea9fe9c-33b4-4a85-b291-f79b048479af">
        <source>setDefaultKeyCodes() protected;

vars

begin

	// Clear just in case called incorrectly.
	self.allRegisteredKeyCodes.clear;
	// Add defaults.
	self.allRegisteredKeyCodes.add(J_key_A);
	self.allRegisteredKeyCodes.add(J_key_C);
	self.allRegisteredKeyCodes.add(J_key_R);
	self.allRegisteredKeyCodes.add(J_key_P); // Print
	self.allRegisteredKeyCodes.add(J_key_D);	//Delete	//+cnwml2 PAR23495
	self.allRegisteredKeyCodes.add(J_key_E);	//Edit 		//+cnwml2 PAR23495
	self.allRegisteredKeyCodes.add(J_key_Tab);
	self.allRegisteredKeyCodes.add(J_key_Stop);
	self.allRegisteredKeyCodes.add(J_key_Return);
	self.allRegisteredKeyCodes.add(CMUI_Key_F1); //Context sensitive help
	self.allRegisteredKeyCodes.add(CMUI_Key_F3); //Query  and Selector
	self.allRegisteredKeyCodes.add(CMUI_Key_F5); // Refresh
	self.allRegisteredKeyCodes.add(CMUI_Key_F10); // Generic Find Form - 22 Jan 2014	NDL	Par 33350
	self.allRegisteredKeyCodes.add(CMUI_Key_F11); // Inspect
	self.allRegisteredKeyCodes.add(CMUI_Key_F12); // GUI info
	self.doRegisterFormKeys();

end;</source>
        <access>protected</access>
    </JadeMethod>
