    <JadeMethod name="addButtonsToForm" id="3783a6b6-ed33-4dc3-b803-349d3e4284b8">
        <source>addButtonsToForm();
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/

vars

begin
	self.allControlsByName.addNoDuplicates(self.btnFillColour1,false);
	self.allControlsByName.addNoDuplicates(self.btnFillColour2,false);
	self.allControlsByName.addNoDuplicates(self.btnFillColour3,false);
	self.allControlsByName.addNoDuplicates(self.btnFillColour4,false);
	self.allControlsByName.addNoDuplicates(self.btnFillColour5,false);
	self.allControlsByName.addNoDuplicates(self.btnFillColour6,false);
	self.allControlsByName.addNoDuplicates(self.btnFillColour7,false);
	self.allControlsByName.addNoDuplicates(self.btnFillColour8,false);
	self.allControlsByName.addNoDuplicates(self.btnFillColour9,false);
	self.allControlsByName.addNoDuplicates(self.btnFillColour10,false);
	self.allControlsByName.addNoDuplicates(self.btnFillColour11,false);
	self.allControlsByName.addNoDuplicates(self.btnFillColour12,false);

	
	self.allControlsByName.addNoDuplicates(self.btnLineColour1,false);
	self.allControlsByName.addNoDuplicates(self.btnLineColour2,false);
	self.allControlsByName.addNoDuplicates(self.btnLineColour3,false);
	self.allControlsByName.addNoDuplicates(self.btnLineColour4,false);
	self.allControlsByName.addNoDuplicates(self.btnLineColour5,false);
	self.allControlsByName.addNoDuplicates(self.btnLineColour6,false);
	self.allControlsByName.addNoDuplicates(self.btnLineColour7,false);
	self.allControlsByName.addNoDuplicates(self.btnLineColour8,false);
	self.allControlsByName.addNoDuplicates(self.btnLineColour9,false);
	self.allControlsByName.addNoDuplicates(self.btnLineColour10,false);
	self.allControlsByName.addNoDuplicates(self.btnLineColour11,false);
	self.allControlsByName.addNoDuplicates(self.btnLineColour12,false);

	self.allControlsByName.addNoDuplicates(self.btnLineWidth1,false);
	self.allControlsByName.addNoDuplicates(self.btnLineWidth2,false);
	self.allControlsByName.addNoDuplicates(self.btnLineWidth3,false);
	self.allControlsByName.addNoDuplicates(self.btnLineWidth4,false);
	
