    <JadeMethod name="handleNotifications" id="d9c619e2-60dd-445f-986b-b61cec3f63b8">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*

Date		Who		Reason
22 September 2015	cnwer1	Initial creation PAR

*/

vars
	obj : Object;
	roadJob : CM_RoadJob;
	wle : CM_WorkListEntry;
	invalidWLE : Boolean;
	reserveDetail : CM_ReserveDetail;
begin
	
	if theObject.isKindOf(CM_WorkListEntry) then
		if self.myMobileGenericAgent.myReserveSelection = null then
			roadJob:=self.myMobileGenericAgent.myTruck.getCurrentRoadJob;
			on Exception do app.handleDeletedObject(exception,wle,invalidWLE);
			foreach wle in self.myMobileGenericAgent.allWlesToLoad do
				reserveDetail:=wle.myRequest.myReserveDetail;
				if not invalidWLE then
					break;
				endif;
				invalidWLE:=false;
			endforeach;
			
			self.myMobileGenericAgent.allWlesToLoad.clear;
			if reserveDetail &lt;&gt; null then
				roadJob.getWLEsMatchingReserveDetail(reserveDetail,self.myMobileGenericAgent.allWlesToLoad);
			endif;
		endif;
		
		self.setupCargo();
		self.doResizeControls(false);	//08 Jul 2016	NDL	TFS 2275 / 2216
		
		if self.myMobileGenericAgent.allWlesToLoad.isEmpty then
			self.doBackButtonClick();
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
