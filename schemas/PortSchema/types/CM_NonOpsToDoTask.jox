    <JadeMethod name="getToDoObject" id="8ca5c55b-a218-4f2c-9959-72c677b0a95b">
        <source>getToDoObject(): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2024 navhl20 Bug 64261: EUP | VAS - Not able to complete TODO jobs

*/

vars

begin
	return self.myDebtorToDo;
epilog

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="dfe9fcaf-8b92-4118-9ec1-8d0bb735e1b7">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date 		Who	   Reason
06 Jun 2023 navma1 Bug 58265: MTN - Complete ToDo security role setting is missing for all the new event todo tasks.
*/

vars

begin
	if set then
		return;
	endif;
	
	if self.myWODetailToDo &lt;&gt; null then
		_value := self.myWODetailToDo.getMyTerminal();
	elseif self.myWOToDoWLE &lt;&gt; null then
		_value := self.myWOToDoWLE.getMyTerminal();
	else
		_value := null;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="90ba91dc-813f-4318-ad4f-17ae9a4c142a">
        <updating/>
        <source>setForCreate(_status : Integer; _toDoTaskDesc : CM_ToDoTaskDesc; _toDoRemarks : String; _passport : CM_Passport input; _debtor : CM_Debtor; _wod : CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
*/

vars
	transType	: Integer;
	event		: CMEVT_NonOperationalEvent;
begin

	self.setForCreateToDoTask(_status, _toDoTaskDesc, _toDoRemarks, _passport.userCode);
	self.myDebtorToDo := _debtor;
	
	transType :=  self.getToDoTaskCreateEventInt;
	
	if transType &lt;&gt; null then
		event := self.myDebtorToDo.createEvent(transType, app.actualTime(),null,self, _wod); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_toDoRemarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
    <JadeMethod name="updateDebtorComplete" id="d1a5cc00-0892-4b6c-a6e8-6ccd539513cd">
        <updating/>
        <source>updateDebtorComplete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars

begin
	self.myDebtor := self.myDebtorToDo;
	self.myDebtorToDo := null;
epilog

end;</source>
    </JadeMethod>
</Class>
