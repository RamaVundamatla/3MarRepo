// ---------------------------------------------------------------------------
// Created:     March 2004	cnwrs1
//
// Purpose:     if you want the xml attribute to update a  property with data
//              from a different xml attribute return the xml name. 
//			 
// ----------   ----------  --------------------------------------------------
// 
vars
	thing : Integer;
begin
	return _propName;
end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
