//
// Created : by cnwaer1 21 August 2008
//-----------------------------------------
vars
	selectedPorts : String;
begin

	self.frmOpDiscPorts.visible := false;	
	//close the frame and display the selected ports
	selectedPorts := self.lstOptionalPorts.getSelectedString('code');
	if selectedPorts.length &gt; 31 then
		self.txtOptDischPort.text := selectedPorts[1:30] &amp; '...';
	else
		self.txtOptDischPort.text := selectedPorts;
	endif;
	
	self.txtOptDischPort.visible := true;

end;</source>
