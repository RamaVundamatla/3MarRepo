    <JadeMethod name="setForUpdate" id="d38806ab-a13e-45a3-82ff-57b8c78a12e4">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodMarineServiceDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlger1	Initial creation

*/

vars

begin
	inheritMethod(_pxyWoDDtl);
	self.fromDateTime:=_pxyWoDDtl.fromDateTime;
	self.toDateTime:=_pxyWoDDtl.toDateTime;
	if _pxyWoDDtl.myHMSResource &lt;&gt; null then	//04 Dec 2018	NDl	TFS 41980
		self.myHMSResource:=_pxyWoDDtl.myHMSResource;
	endif;
	self.unitsUsed:=_pxyWoDDtl.unitsUsed;
	self.myHMSResourceType := _pxyWoDDtl.myHMSResourceType;		//26 Nov 2018	NDL	TFS 41980
	self.myDebtor := _pxyWoDDtl.myDebtor;		//26 Nov 2018	NDL	TFS 41980

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodMarineServiceDetail"/>
    </JadeMethod>
    <JadeMethod name="setOriginalDateTime" id="eac090c2-1bc3-4623-b9f3-f9a662bc97dc">
        <updating/>
        <source>setOriginalDateTime() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/07/2018	jlgdap1		Initial creation TFS 39741 PEL1 Marine Service Timings Changes
//
vars

begin
	if not self.originalFromDateTime.date.isValid then	//21 Sep 2018	NDL	TFS 39741
		if self.fromDateTime.date.isValid then
			self.originalFromDateTime := self.fromDateTime;
		endif;
	endif;
	if not self.originalToDateTime.date.isValid then	//21 Sep 2018	NDL	TFS 39741
		if self.toDateTime.date.isValid then
			self.originalToDateTime := self.toDateTime;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyBaseValues" id="ba20fe35-714e-4794-b029-f7007b0fb31a">
        <updating/>
        <source>setProxyBaseValues(	_fromDateTime : TimeStamp;
					_toDateTime : TimeStamp;
					_unitsUsed : Real;
					_myResourceType : HMS_ResourceType;
					_myResource : HMS_Resource;
					_myDebtor : CM_Debtor
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

begin

	self.fromDateTime := _fromDateTime;
	self.toDateTime := _toDateTime;
	self.unitsUsed := _unitsUsed;
	self.myHMSResourceType := _myResourceType;
	if _myResource &lt;&gt; null then	//04 Dec 2018	NDl	TFS 41980
		self.myHMSResource := _myResource;
	endif;
	self.myDebtor := _myDebtor;

epilog

end;</source>
        <Parameter name="_fromDateTime" type="TimeStamp"/>
        <Parameter name="_toDateTime" type="TimeStamp"/>
        <Parameter name="_unitsUsed" type="Real"/>
        <Parameter name="_myResourceType" type="HMS_ResourceType"/>
        <Parameter name="_myResource" type="HMS_Resource"/>
        <Parameter name="_myDebtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromResourceUsed" id="040f5874-c7b9-4085-a68c-d74db69cac9e">
        <updating/>
        <source>setProxyFromResourceUsed(_resourceUsed : HMS_ResourceUsed ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlger1	Initial creation

*/

vars

begin
	self.fromDateTime:=_resourceUsed.fromDateTime;
	self.toDateTime:=_resourceUsed.toDateTime;
	self.unitsUsed:=_resourceUsed.unitsUsed;
	if _resourceUsed.myResource &lt;&gt; null then	//04 Dec 2018	NDl	TFS 41980
		self.myHMSResource	:=	_resourceUsed.myResource;
	endif;
	//26 Nov 2018	NDL	TFS 41980
	self.myHMSResourceType := _resourceUsed.myResourceType;
	self.myDebtor := _resourceUsed.myDebtor;
epilog

end;</source>
        <Parameter name="_resourceUsed" type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="84b0480e-1068-4af9-a6b9-edd7c4577288">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2019	jlger1	Initial creation

*/

vars

begin
	if _property = null or
	   _property.name = CM_WodMarineServiceDetail::myMarineServiceDepart.name or
		_property.name = CM_WodMarineServiceDetail::myMarineServiceInitial.name or
		_property.name = CM_WodMarineServiceDetail::myMarineServiceVoyageCargo.name or
		_property.name = CM_WodMarineServiceDetail::myShiftMovement.name or
		_property.name = CM_WodMarineServiceDetail::myExtension.name or
		_property.name = CM_WodMarineServiceDetail::myMarineServiceAdditionalCargo.name or
		_property.name = CM_WodMarineServiceDetail::myPermitRequest.name then
		return false;
	else
		
		return inheritMethod(_rootClass, _property);
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b233a0c1-f0d1-4957-9ca1-c086c6e3fdb7">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	resourceTypeDesc : String;

begin

	inheritMethod();
	
	if self.myMarineServiceVoyageCargo &lt;&gt; null then
		if self.myDebtor = null then
			if self.myHMSResourceType &lt;&gt; null then
				resourceTypeDesc := self.myHMSResourceType.description;
			endif;
			app.raiseCMException1( Debtor_required_resource, resourceTypeDesc, null, null );
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
