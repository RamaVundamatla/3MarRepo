    <JadeMethod name="setOrigLocation" id="adb92be6-e7a6-4bc5-8f93-bbdc86eb2d8b">
        <updating/>
        <source>setOrigLocation() updating;
//--------------------------------------------------------------
//Created: 26 June 2002 By: cnwgd1
//--------------------------------------------------------------
//Set once when tracked items are moved into the yard from off site for the very first time.
vars

begin
	if self.myPlannedLocation = null then
		return;
	endif;
	
	if self.origLocationControllerId = null then
		self.origLocationControllerId 	:= self.myPlannedLocation.getID();
		self.origTerminalAreaId 		:= self.myPlannedLocation.myTerminalArea.id;
	endif;

	self.myPlannedLocation := null;

end;</source>
