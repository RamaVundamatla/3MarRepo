    <JadeMethod name="clearReferences" id="2b1fe78b-3b9b-4289-8c47-7eb2206256f9">
        <updating/>
        <source>clearReferences() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2024	navrv30	ChangeRequest 63763: MTN - [Extra Data][2] Stop Creating Extra Data Object with Null Value - Update Mode

*/

vars

begin
	self.myBOL := null;
	self.myParent := null;
	self.myStateObject := null;
	self.myTrackedItem := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getName" id="1c4a3ce5-af70-43fe-be63-fd2eb1934d5e">
