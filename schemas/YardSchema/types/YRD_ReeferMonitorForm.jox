        <ReturnType type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="getTiDictsForTermArea" id="e0716845-6a9e-4373-ac49-f4e1da2dfa32">
        <source>getTiDictsForTermArea(_ta: CM_TerminalArea; _tiDict: Dictionary io; _tiDictRev: Dictionary io);
// ---------------------------------------------------------------------------
// Created:		04 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ti	: CM_TrackedItem;
	lc	: CM_LocationsController;
begin
	
	if _tiDict = null then
		return;
	endif;
	
	if _ta.isKindOf(CM_GridArea) then
		foreach lc in _ta.CM_GridArea.allGridControllersByRowColumn do
			foreach ti in lc.allTrackedItems do
				if not _tiDict.includes(ti) then
					_tiDict.add(ti);
					if _tiDictRev &lt;&gt; null then
						_tiDictRev.add(ti);	
					endif;
				endif;
			endforeach;
		endforeach;
	elseif _ta.isKindOf(CM_BlockStack) then
		foreach ti in _ta.CM_BlockStack.myLocationsController.allTrackedItems do 
			if not _tiDict.includes(ti) then
				_tiDict.add(ti);
				if _tiDictRev &lt;&gt; null then
					_tiDictRev.add(ti);	
				endif;
			endif;
		endforeach;
	endif;

end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_tiDict" type="Dictionary" usage="io"/>
        <Parameter name="_tiDictRev" type="Dictionary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="768b98ba-d19a-4db5-ae4e-f9feca07d373">
        <updating/>
        <source>handleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		10 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can be a reefer
// 18/03/2015	cnwdap1		PAR #35874 TFS 265 Humidity and Ventilation readings
vars
	now			: TimeStamp;
	ti			: CM_TrackedItem;
	//reefer	: CM_Container;		// CCMS 1007
	tempRead	: CM_TempReading;
	humidRead	: CM_HumidReading;				// PAR #35874
	ventRead	: CM_VentReading;
	event		: Integer;
	lc			: CM_LocationsController;
	lcTIs		: CM_TIArray;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if event = TIEvent_Terminal_Receival or
	event = TIEvent_Terminal_Release or
	eventType = Object_Update_Event or 
	event = TIEvent_Connect then	//gets connects
		//if CM_Container.hasInstance(theObject) then		// CCMS 1007
		if CM_TrackedItem.hasInstance(theObject) then		// CCMS 1007
			//self.redisplayTI(theObject.CM_Container);		// CCMS 1007
			self.redisplayTI(theObject.CM_TrackedItem);		// CCMS 1007
		endif;
	elseif event = EVENT_TEMP_CREATE then	//temp reads
		if userInfo.isKindOf(CM_TempReading) then										// PAR #35874
			tempRead := userInfo.CM_TempReading;
			//reefer := tempRead.myContainer;					// CCMS 1007
			ti := tempRead.myReeferProperties.myParent.CM_TrackedItem;	// CCMS 1007
		elseif userInfo.isKindOf(CM_HumidReading) then									// PAR #35874
			humidRead := userInfo.CM_HumidReading;										// PAR #35874
			ti := humidRead.myTIReeferProperties.myParent.CM_TrackedItem;				// PAR #35874
		elseif userInfo.isKindOf(CM_VentReading) then									// PAR #35874
			ventRead := userInfo.CM_VentReading;										// PAR #35874
			ti := ventRead.myTIReeferProperties.myParent.CM_TrackedItem;				// PAR #35874
		endif;																			// PAR #35874
		//if reefer &lt;&gt; null then 							// CCMS 1007
		if ti &lt;&gt; null then 									// CCMS 1007
			self.tblReadingSortAndShow();
			//self.redisplayTI(reefer);						// CCMS 1007
			self.redisplayTI(ti);							// CCMS 1007
		endif;	
	endif;

epilog
	endLoad;

	delete 	lcTIs;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleTblDataDblClick" id="04d9fd57-90ae-4c18-9594-e0d9a2ae94bc">
        <updating/>
        <source>handleTblDataDblClick(_row: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	obj	: CM_Object;

begin

	if _row &gt; tblData.fixedRows then
		obj := self.tblData.accessRow(_row).itemObject.CM_Object;
		
		if obj &lt;&gt; null then
			self.myAssistant.showCargoEnquiryForm(obj, self.myMasterMenuAction, true, false);
		endif;
	endif;

end;</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="b9d3e823-a9c2-4ca3-af98-7a22308ee36a">
        <updating/>
        <source>includeObject(_objTI: CM_TrackedItem; _passport: CM_Passport): Boolean updating;
//----------------------------------------------------------------
//	Created:	28 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	breakOut	: Boolean;
begin
	
	if (self.filterTerminalArea = null or (self.filterTerminalArea = _objTI.myTerminalArea)) and
	(self.filterVoyage = null or (self.filterVoyage = _objTI.myVoyage)) and
	self.includeObjectTI(_objTI, breakOut) then
		return true;
	endif;
	
	return false;
	

end;</source>
        <Parameter name="_objTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObjectTI" id="730811df-a1c0-4e51-8919-7ddd1b8e2a7d">
        <updating/>
        <source>includeObjectTI(_ti: CM_TrackedItem; _breakOut : Boolean output): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		04 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 08/12/2009	cnwdap1		CCMS MES 1007 Allow other cargo types to be reefer
// 04/03/2010	cnwdap1		PAR #22922 Ignore TIs that don't have a terminal area - connect screen will fail otherwise
// 04/03/2010	cnwdap1		PAR #22924 Correct handling of filters - terminal area and terminal area type
// 20/05/2010	cnwdap1		CCMS 1116 tranship changes
// 09/08/2010	cnwdap1		PAR #25336 Correct terminal area handling - let TIs with no terminal area be displayed, after fixing CMUI_ConnectAttach form terminal area checks
// 09/05/2025   navsp1      JIRA-34514 MTN - Reefer Monitoring Screen Code Changes
// 06 Jan 2026  navah1 		MTN-35878: PEN | Please change the Is Connected and Requires Power filters from Check Boxes to a dropdown
vars

	failedDAC  :CM_DataAccessController;
	
begin

// will already have a filtered collection of TI's, either:	a) by voyage
//															b) by terminal Area
//															c) all onsite containers
// 															(may also be optionally filtered by ID seed too)

	if self.mode = Mode_Search then
		if (self.numItemsSearched mod 500) = 0 then
			self.chkSearchReturnOption(self.tblData.rows);
			if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
				_breakOut := true;
			endif;
		endif;
		self.numItemsSearched := self.numItemsSearched + 1;
	endif;

	// should never look at transship import
	// PAR #23645 CCMS 1116 Tranship TIs now only have one TI object, not one export and one import
	// So we can now be a tranship import and be valid to show
	//if _ti.isTranshipImport then		// PAR #23645 CCMS 1116 
	//	return false;					// PAR #23645 CCMS 1116 
	//endif;							// PAR #23645 CCMS 1116 
	
	// CCMS 1007 Containers are not the only reefer types now
	if not _ti.monitorConnection then
		return false;
	endif;
/*	if _ti.isKindOf(CM_Container) then //should always be
		if not _ti.CM_Container.monitorConnection then
			return false;
		endif;
	else
		return false;
	endif;	*/
	
	if (not _ti.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return false;
	endif;
	
	// PAR #22922 ignore TIs with no terminal area
	// PAR #25336 removed 
	//if _ti.myTerminalArea = null then
	//	return false;
	//endif;

	if self.filterOperator &lt;&gt; null and self.filterOperator &lt;&gt; _ti.myOperator then
		return false;
	endif;

	if self.filterCmdtyGroup &lt;&gt; null and self.filterCmdtyGroup &lt;&gt; _ti.myCommodityGroup then
		return false;
	endif;
	
	if self.filterISOType &lt;&gt; null and self.filterISOType &lt;&gt; _ti.getISOType then	
		return false;
	endif;

	// PAR #22924 correct filter handling
	/*// if a voyage has been entered we need to check terminal area match
	if self.filterVoyage &lt;&gt; null
	and self.filterTerminalArea &lt;&gt; null
	and self.filterTerminalArea &lt;&gt; _ti.myTerminalArea then
		return false;
	endif;	*/
	if self.filterVoyage &lt;&gt; null and self.filterVoyage &lt;&gt; _ti.myVoyage then
		return false;
	endif;
	if self.filterTerminalArea &lt;&gt; null and self.filterTerminalArea &lt;&gt; _ti.myTerminalArea then
		return false;
	endif;
	if self.filterTAType &lt;&gt; null and (_ti.myTerminalArea = null or _ti.myTerminalArea.myType.description &lt;&gt; self.filterTAType) then
		return false;
	endif;
	// PAR #22924 end
	
	//cnwmc5 - 20 Oct 2015 - PAR 37057
	if (self.filterHasExternalMonitoring = Yes and not _ti.getExternalMonitoring())
	or (self.filterHasExternalMonitoring = No and _ti.getExternalMonitoring()) then
		return false;
	endif;
    
    if self.filterCommodity &lt;&gt; null and _ti.commodity &lt;&gt; self.filterCommodity.code then //JIRA-34514
        return false;                                                                   //JIRA-34514
    endif;                                                                              //JIRA-34514
    
	//06.01.2026 navah1 #MTN-35878 Start
	/*
    if self.filterIsConnected and  not _ti.isConnected then                             //JIRA-34514
        return false;                                                                   //JIRA-34514
    endif;                                                                              //JIRA-34514
	
    if self.filterRequiresPower and not _ti.requiresPower then                          //JIRA-34514
        return false;                                                                   //JIRA-34514
    endif;      																		//JIRA-34514
	*/
	if (self.filterIsConnected = Yes and not _ti.isConnected)
	or (self.filterIsConnected = No and _ti.isConnected) then
		return false;
	endif;
	
	if (self.filterRequiresPower = Yes and not _ti.requiresPower)
	or (self.filterRequiresPower = No and _ti.requiresPower) then
		return false;
	endif;
	//06.01.2026 navah1 #MTN-35878 End
	
	return true;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="0c45238a-a05b-47e8-b66c-c0ed91f8ffa5">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:		03 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	self.tblData.setTblDataEntRowsFromDef(self.getTblDataDef);
	self.tblData.multiSelect := CM_DataTable.MultiSelect_Simple;
end;</source>
    </JadeMethod>
    <JadeMethod name="initFilterTable" id="dd1b9162-74bc-4f73-8cd1-5d169aff04b8">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:		03 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 09/08/2010	cnwdap1		PAR #25336 Don't default terminal area type to anything
// 09/05/2025   navsp1      JIRA-34514 MTN - Reefer Monitoring Screen Code Changes
// 06 Jan 2026  navah1 		MTN-35878: PEN | Please change the Is Connected and Requires Power filters from Check Boxes to a dropdown
vars
	tmpCombo		: ComboBox;
	tmpCMUICombo	: CMUI_ComboBox;
begin

	if (not self.setFilterTblDef()) then
		return;
	endif;

	tmpCombo := cmbFiltVoyage;
	self.myAssistant.comboBoxVoyageCurrent(	tmpCombo,
											null,
											true,
											false,
											true,
											true,
											true,
											false,
											false,
											false,
											false); //cnwrs1 par 15258 nov 2007 exclude archived voyages

	tmpCombo := cmbFiltTAType;
	//self.myAssistant.comboBoxTAType(tmpCombo, app.myRoot.allTerminalAreaTypes[TA_TYPE_STRADDLE_STACK], false);	// PAR #25336
	self.myAssistant.comboBoxTAType(tmpCombo, null, false);															// PAR #25336

	self.myAssistant.comboBoxTerminalArea(self.cmbFiltTermArea, null, null);										// PAR #25336
	
	//cnwmc5 - 20 Oct 2015 - PAR 37057
	tmpCMUICombo := self.cmbFiltExternal;
	self.myAssistant.comboBoxYesNoAll_Translated(tmpCMUICombo);
	//06.01.2026 navah1 #MTN-35878 Start
	tmpCMUICombo := self.cmbFiltConnected;
	self.myAssistant.comboBoxYesNoAll_Translated(tmpCMUICombo);
	tmpCMUICombo := self.cmbFiltPower;
	self.myAssistant.comboBoxYesNoAll_Translated(tmpCMUICombo);
	//06.01.2026 navah1 #MTN-35878 End
	
    self.myAssistant.comboBoxCommodityReefer(self.cmbFiltCommodity, null);       //JIRA-34514
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="5732b7bc-d8b9-4796-a190-398904a99971">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:		03 June 2003  by Jason Chapman  (cnwjc2)
// 19 Sep 2023  navhn30 	Bug 59371: PEN - Reefer Monitoring Screen - Searcher not staying docked
// ---------------------------------------------------------------------------

vars

begin
	self.allowAdd	 := false;
	self.allowDelete := false;
	self.allowUpdate := false;

	self.filterAppliesToThumbnail := false;
	self.allowSearch := true;
	self.allowPrint 	:= true;
	self.allowExportCSV	:= false;
	
	self.allowMultiSelectEdit := true;
	self.showFilterOnStartup := true;
	self.useNumRowsShown := true;
	self.showDataOnStartup := false;
	self.frmDetailsBottom.visible := true;
	
	if not self.openWithSavedSettings() then			//19.09.2023 navhn30 #59371
		self.useFloatingFilter := true;
	endif;
	
	self.useTblThumb := false;
	self.initFilterTable();
	self.initMonitorTables();
	self.setNavigatorHeading('Reefer Containers');
	

	
end;</source>
    </JadeMethod>
