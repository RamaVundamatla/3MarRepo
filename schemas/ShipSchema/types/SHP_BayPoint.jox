    </JadeMethod>
    <JadeMethod name="populateControllerCCDischarge" id="c8e2376f-b6bd-4eee-aceb-6c4d3fd62e64">
        <updating/>
        <source>populateControllerCCDischarge(_slotController : CM_SlotController) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theRequest 		: CM_SlotRequest;
	theTI 			: CM_TrackedItem;
	commodityGroup 	: CM_CommodityGroup;		//cnwas3 PAR 24273
	dischargePort	: CM_Port;			//cnwas3 PAR 24273
	job				: CM_Job;				//cnwas3 PAR 24273
begin
	theRequest := _slotController.mySlotRequestDischarge;
	if theRequest = null then
		return;
	endif;
	
	commodityGroup := theRequest.getAttrCommodityGroup();		//cnwas3 PAR 24273
	if commodityGroup &lt;&gt; null then								//cnwas3 PAR 24273
		self.colDischCommodityGroupCode := commodityGroup.code;	//cnwas3 PAR 24273
	endif;
	self.colDischDLR := theRequest.isRehandle;
	
	dischargePort := theRequest.getAttrDischargePort();		//cnwas3 PAR 24273 begin
	if dischargePort &lt;&gt; null then
		self.colDischDischPortColour := dischargePort.colour;
		self.colDischMyDischPort := dischargePort;			//cnwas3 PAR 24273 end
	endif;
	self.colDischDischPortCode := theRequest.dischargePort;

	job := theRequest.myJob;		//cnwas3 PAR 24273 begin
	if job &lt;&gt; null then
		self.colDischMyJob := job.CM_VoyageJob;
		self.colDischMyJobIsComplete := job.isJobComplete;		//cnwas3 PAR 24273 end
	endif;

	self.colDischEmpty := theRequest.getAttrEmpty();
	self.colDischFortyFoot := theRequest.getAttrIs40() or theRequest.fortyBack; // THIS CONTROLLER IS NOT USED ANYMORE
	self.colDischHasPlanned := _slotController.hasTIsOfMode(PLANNING_MODE);
	self.colDischHiCube := theRequest.getAttrHiCubed();
	self.colDischIsHazardous := theRequest.getAttrHazardous();
	self.colDischOverDimensioned := theRequest.getAttrOverDimensioned();
	self.colDischPower := theRequest.getAttrPowerRequired();
// PAR7496 AKB2004FEB	self.colDischReefer := theRequest.reefer;
	self.colDischReqLinked := (theRequest.getLinkedRequest(true) &lt;&gt; null); // PAR 28968 (theRequest.mySlotRequestDLRSOBLoad &lt;&gt; null);
	self.colDischWaterCooled := theRequest.getAttrWaterCooled();
	self.colDischSOB := theRequest.isSOB;
//	self.colDischSeqNum := theRequest.getSeqNum();

	if self.colDischMyJobIsComplete then
		theTI := theRequest.getTrackedItem();
		if theTI &lt;&gt; null then
			self.colDischTIID := theTI.id;
		endif;
	endif;

end;</source>
        <Parameter name="_slotController" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="populateControllerCCLoad" id="7c9163ad-e9ec-4ce1-a709-edbb3034755c">
        <updating/>
        <source>populateControllerCCLoad(_slotController : CM_SlotController) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theRequest 		: CM_SlotRequest;
	theTI,thePTI 	: CM_TrackedItem;
	cargoType 		: CM_CargoType;    //cnwas3 PAR 24273
	commodityGroup  : CM_CommodityGroup; //cnwas3 PAR 24273
	dischargePort	: CM_Port;		//cnwas3 PAR 24273
	job				: CM_Job;		//cnwas3 PAR 24273
begin
	theRequest := _slotController.mySlotRequestLoad;
	if theRequest = null then
		return;
	endif;
	thePTI:= _slotController.getTIAtIndex(PLANNING_MODE,1);
	if thePTI &lt;&gt; null then
		self.colLoadPlannedTIWeight := (thePTI.totalWeight / 1000).Integer.asStringJMT;
	endif;

	cargoType := theRequest.getAttrCargoType();		//cnwas3 PAR 24273
	if cargoType &lt;&gt; null then						//cnwas3 PAR 24273
		self.colLoadMyCargoType := cargoType;		//cnwas3 PAR 24273
	endif;
	commodityGroup := theRequest.getAttrCommodityGroup(); 		//cnwas3 PAR 24273 begin
	if commodityGroup &lt;&gt; null then
		self.colLoadCommodityGroupCode := commodityGroup.code;
		self.colLoadHasTemp := commodityGroup.hasTemp;			//cnwas3 PAR 24273 end
	endif;
	self.colLoadDLR := theRequest.isRehandle;
	
	dischargePort := theRequest.getAttrDischargePort();		//cnwas3 PAR 24273 begin
	if dischargePort &lt;&gt; null then
		self.colLoadDischPortColour := dischargePort.colour;
		self.colLoadMyDischPort := dischargePort;			//cnwas3 PAR 24273 end
	endif;
	self.colLoadDischPortCode := theRequest.dischargePort;

	job := theRequest.myJob;		//cnwas3 PAR 24273
	if job &lt;&gt; null then
		self.colLoadMyJob := job.CM_VoyageJob;
		self.colLoadMyJobIsComplete := job.isJobComplete;		//cnwas3 PAR 24273
	endif;


	self.colLoadEmpty := theRequest.getAttrEmpty();
	self.colLoadFortyFoot := theRequest.getAttrIs40() or theRequest.fortyBack; // THIS CONTROLLER IS NOT USED ANYMORE
	self.colLoadHasPlanned := _slotController.hasTIsOfMode(PLANNING_MODE);
	self.colLoadHiCube := theRequest.getAttrHiCubed();
	self.colLoadIsHazardous := theRequest.getAttrHazardous();
	self.colLoadIsOverDimensioned := theRequest.getAttrOverDimensioned();
	self.colLoadPower := theRequest.getAttrPowerRequired();
	self.colLoadReqLinked := theRequest.isLinked(); // PAR 28968 (theRequest.mySlotRequestDLRSOBDischarge &lt;&gt; null);
	self.colLoadWaterCooled := theRequest.getAttrWaterCooled();
	self.colLoadSOB := theRequest.isSOB;
	self.colLoadUnavailable := theRequest.unavailable;
//	self.colLoadSeqNum := theRequest.getSeqNum();
	self.colLoadHalfHeight := theRequest.getAttrHalfHeight();
//	self.colLoadPortHole := theRequest.



	self.colLoadDoorDirection20 := theRequest.doorsDirection;
	self.colLoadDoorDirection40 := theRequest.doorsDirection;
//	self.colLoadMotor20 := 
//	self.colLoadMotor40 := 
	self.colLoadMotorDirection20 := theRequest.motorDirection;
	self.colLoadMotorDirection40 := theRequest.motorDirection;
	  

end;</source>
        <Parameter name="_slotController" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="populateControllerDefn" id="1e4dd520-629f-4337-aeff-41ab21ed2a19">
        <updating/>
        <source>populateControllerDefn(_slotDefn : CM_SlotDefn) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.bayDefnDoorDirection20 := _slotDefn.doors20Aft;
	self.bayDefnDoorDirection40 := _slotDefn.doors40Aft;
	self.bayDefnFortyFoot := _slotDefn.fortyFront or _slotDefn.fortyBack;
	self.bayDefnThirtyFoot := _slotDefn.is30; // PAR 16415 CCMS 1029
	self.bayDefnFiftyThreeFoot := _slotDefn.is53; // PAR 16415 CCMS 1029
	self.bayDefnFortyFive := _slotDefn.is45; // PAR 18682 CCMS 1055
	self.bayDefnMotorDirection20 := _slotDefn.motor20Aft;
	self.bayDefnMotorDirection40 := _slotDefn.motor40Aft;
	self.bayDefnMtOnly := _slotDefn.mtOnly;
	self.bayDefnHeavy := _slotDefn.heavy;
	self.bayDefnVoltage := _slotDefn.voltageType;
	self.bayDefnPowered := _slotDefn.power;
	self.bayDefnReefer := _slotDefn.reefer;
	self.bayDefnUnavailable := _slotDefn.unavailable;
	self.bayDefnWaterCooled := _slotDefn.watercooled;

end;</source>
        <Parameter name="_slotDefn" type="CM_SlotDefn"/>
    </JadeMethod>
    <JadeMethod name="populateControllerPro" id="bf2bb6e8-fbf7-48ad-8e54-28db0aaad121">
        <updating/>
        <source>populateControllerPro(_slotController : CM_SlotController) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	theTI, theDTI : CM_TrackedItem;
	aGridAttributes : SHP_GridAttributes;
	
	
begin
	self.clearAttributes(PLANNING_MODE);

	create aGridAttributes transient;
	self.myAttributesProposed := aGridAttributes;


	theTI := _slotController.getTIAtIndex(PLANNING_MODE, 1);
	if theTI &lt;&gt; null then
		
		self.tiInfoNumTI := _slotController.allTrackedItems.size;
		self.populateControllerTI(theTI);
	endif;

end;</source>
        <Parameter name="_slotController" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="populateControllerTI" id="b0c39cee-8a2d-49b8-b8f2-f2fe2b70723c">
        <updating/>
        <source>populateControllerTI(_theTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars

	idx				: Integer;
	aVoyage			: CM_Voyage;
	aCommGroup		: CM_CommodityGroup;
	aConsignee		: CM_ConsigneeConsignor;
	aLoadPort		: CM_Port;
	aDishPort		: CM_Port;
	anISOTypeGroup	: CM_ISOTypeGroup;
	anOperator		: CM_Operator;
	productObj		: CM_Product;
	aWeight			: CM_WeightRange;
	
begin
	// ?? Height
	//self.bayActIsExport := _theTI.isExport or _theTI.isRehandle or _theTI.isSOB; 								// PAR #25021
	self.bayActIsExport := _theTI.isExport or _theTI.isTranshipOutbound or _theTI.isRehandle or _theTI.isSOB; 	// PAR #25021
	self.bayActIsImport := not self.bayActIsExport;
	self.tiInfo40 := _theTI.isAttributeTrue(TI_Attrib_IsForty);
	self.tiInfo40BackEnd := null;
	self.tiInfoCommodity := _theTI.commodity;
	self.tiInfoCommodityGroupCode := _theTI.commodityGroup;
	self.tiInfoConsigneeCode := _theTI.consignee;
	self.tiInfoDischargePort := _theTI.dischargePort;
	self.tiInfoISOTypeGroup := _theTI.isoTypeGroup;
	self.tiInfoLoadPort := _theTI.loadPort;
	self.tiInfoOperatorCode := _theTI.operatorCode;
	self.tiInfoProductCode := _theTI.productCode;
	self.tiInfoPlannedLocation := _theTI.plannedLocnId;
	self.tiInfoReeferTemp := _theTI.getDisplayTemperature(true, false);
//	self.tiInfoStatus := _theTI.statusCode;
	self.tiInfoTIID := _theTI.id;
	//self.tiInfoWeight := (_theTI.weight/1000).asStringJMT;				//-cnwml2 MSL CCMS 1017
	self.tiInfoWeight := (_theTI.totalWeight/1000).asStringWeightJMT();		//+cnwml2 MSL CCMS 1017

	self.allTrackedItems.add(_theTI);

	// #######################################
	// ICONS
	// #######################################
	if _theTI.readyToShip then
		self.populatControllerAttribute(PicTIReadyToShip);
	endif;
	if _theTI.isHazardous then
		self.populatControllerAttribute(PicTIHazard);
	endif;
	if _theTI.myMatchedTBA &lt;&gt; null then // PAR 35574
		self.populatControllerAttribute(PicTITBA);
	endif;
	
	if _theTI.myPrimaryQueuedLocation &lt;&gt; null then
		self.populatControllerAttribute(PicTIQueued);
	elseif _theTI.myPrimaryPlannedLocation &lt;&gt; null then
		self.populatControllerAttribute(PicTIPlanned);
	endif;

	// #######################################
	// COLOURS
	// #######################################

	aVoyage := _theTI.myVoyage;
	if aVoyage &lt;&gt; null then
//		_theTI.addColours(self, aVoyage.colour,aVoyage.code,aVoyage,TI_ColourMode_Voyage);
		self.populateControllerAddColours( aVoyage.colour,aVoyage.code,aVoyage,TI_ColourMode_Voyage);
		
	endif;
	aCommGroup := _theTI.myCommodityGroup;
	if aCommGroup &lt;&gt; null then
//		_theTI.addColours(self, aCommGroup.colour,aCommGroup.code,aCommGroup,TI_ColourMode_CommodityGroup);
		self.populateControllerAddColours( aCommGroup.colour,aCommGroup.code,aCommGroup,TI_ColourMode_CommodityGroup);
	endif;
	aConsignee := _theTI.myConsignee;
	if aConsignee &lt;&gt; null then
//		_theTI.addColours(self, aConsignee.colour,aConsignee.code,aConsignee,TI_ColourMode_Consignee);
		self.populateControllerAddColours(aConsignee.colour,aConsignee.code,aConsignee,TI_ColourMode_Consignee);
	endif;
	//aDishPort := _theTI.getRoot.allPorts[_theTI.dischargePort.trimBlanks];
	aDishPort := _theTI.getRoot.allPorts[_theTI.dischargePort.trimBlanks];
	if aDishPort &lt;&gt; null then
//		_theTI.addColours(self, aDishPort.colour,aDishPort.code,aDishPort,TI_ColourMode_DischargePort);
		self.populateControllerAddColours(aDishPort.colour,aDishPort.code,aDishPort,TI_ColourMode_DischargePort);
	endif;

	//aLoadPort := _theTI.getRoot.allPorts[_theTI.loadPort.trimBlanks];
	aLoadPort := _theTI.getRoot.allPorts[_theTI.loadPort.trimBlanks];
	if aLoadPort &lt;&gt; null then
//		_theTI.addColours(self, aLoadPort.colour,aLoadPort.code,aLoadPort,TI_ColourMode_LoadPort);
		self.populateControllerAddColours(aLoadPort.colour,aLoadPort.code,aLoadPort,TI_ColourMode_LoadPort);
	endif;
	anISOTypeGroup := _theTI.getRoot.allISOTypeGroups[_theTI.isoTypeGroup.trimBlanks];
	if anISOTypeGroup &lt;&gt; null then
//		_theTI.addColours(self, anISOTypeGroup.colour,anISOTypeGroup.code,anISOTypeGroup,TI_ColourMode_ISOTypeGroup);
		self.populateControllerAddColours(anISOTypeGroup.colour,anISOTypeGroup.code,anISOTypeGroup,TI_ColourMode_ISOTypeGroup);
	endif;
	anOperator := _theTI.myOperator;
	if anOperator &lt;&gt; null then
//		_theTI.addColours(self, anOperator.colour,anOperator.code,anOperator,TI_ColourMode_Operator);
		self.populateControllerAddColours(anOperator.colour,anOperator.code,anOperator,TI_ColourMode_Operator);
	endif;
	
	productObj	:=	_theTI.myProduct;
	
	if productObj &lt;&gt; null then
		self.populateControllerAddColours(productObj.colour, productObj.code, productObj, TI_ColourMode_Product);
	endif;
	
//	aWeight := app.myRoot.;
	if aWeight &lt;&gt; null then
//		_theTI.addColours(self, aWeight.colour,aWeight.value.String,aWeight,TI_ColourMode_Weight);
		self.populateControllerAddColours(aWeight.colour,aWeight.value.String,aWeight,TI_ColourMode_Weight);
	endif;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="populateGridXML" id="61593263-f2e6-4b16-a303-12ebbeb3ecc9">
        <updating/>
        <source>populateGridXML(_theXMLString: String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTI : CM_TrackedItem;
	theTIOID,theXMLTag,gridPointCoOrds : String;
	theTagNum : Integer;
	theMode, theRow, theCol : Integer;
	aPoint : CMUI_GridPoint;
	theBayArea : SHP_BayArea;
	theXMLString, theXMLSubString: String;
begin
	theXMLString := _theXMLString;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("LC");
	if theXMLTag &lt;&gt; null then

		self.myLocationsController := theXMLTag.trimBlanks.asOid.CM_LocationsController;
	endif;

	theBayArea := self.myGridArea.SHP_BayArea;
	theMode := theBayArea.displayMode;
	if theMode = ShpDisplayMode_GetAll then
		// ### ACTUAL
		theXMLSubString := theXMLString.cnEcGetTagValueOfName(CM_CellularVoyageStructure.XmlTag_All_Actual);
		if theXMLSubString &lt;&gt; null then
			self.populateGridXMLact(theXMLSubString);
		endif;
		// ### LOAD COLOUR CODING
		theXMLSubString := theXMLString.cnEcGetTagValueOfName(CM_CellularVoyageStructure.XmlTag_All_Load);
		if theXMLSubString &lt;&gt; null then
			self.populateGridXMLload(theXMLSubString);
		endif;
		// ### DISCHARGE COLOUR CODING
		theXMLSubString := theXMLString.cnEcGetTagValueOfName(CM_CellularVoyageStructure.XmlTag_All_Discharge);
		if theXMLSubString &lt;&gt; null then
			self.populateGridXMLdis(theXMLSubString);
		endif;
		
	elseif theMode = ShpDisplayMode_Defn and not theBayArea.generatedDEFN then
		self.populateGridXMLdefn(theXMLString);
	elseif theMode = ShpDisplayMode_Actual and (not theBayArea.generatedACT) then
		self.populateGridXMLact(theXMLString);
	elseif theMode = ShpDisplayMode_EDI and (not theBayArea.generatedACT) then
		self.populateGridXMLact(theXMLString);
	elseif theMode = ShpDisplayMode_Proposed and not theBayArea.generatedPRO then
		self.populateGridXMLpro(theXMLString);
	elseif theMode = ShpDisplayMode_ColCodeLoad and not theBayArea.generatedLOAD then
		self.populateGridXMLload(theXMLString);
	elseif theMode = ShpDisplayMode_ColCodeDisch and not theBayArea.generatedDISCH then
		self.populateGridXMLdis(theXMLString);
	endif;

	self.myGridColumn.SHP_BayColumn.setPileWeight(); // PAR 8423
	self.myGridRow.SHP_BayRow.pileWeight := (self.myGridRow.SHP_BayRow.pileWeight.Integer + self.tiInfoWeight.Integer).asStringJMT;
end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateGridXMLact" id="92fe375e-71a2-4df6-8a68-d25c664091ba">
        <updating/>
        <source>populateGridXMLact(_theXMLString: String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theXMLTag : String;
	theXMLString: String;
begin
	theXMLString := _theXMLString;


	theXMLTag := theXMLString.cnEcGetTagValueOfName("RTI");
	if theXMLTag &lt;&gt; null then
		self.setForCreateTIXML(theXMLTag,REAL_MODE);
	else
		self.setForCreateTIXMLNull(REAL_MODE);
	endif;

end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateGridXMLactNull" id="e9d68245-5a49-4a6b-8b07-ab52a0493954">
        <updating/>
        <source>populateGridXMLactNull(_theXMLString: String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theXMLTag : String;
	theXMLString: String;
begin
	theXMLString := _theXMLString;


	theXMLTag := theXMLString.cnEcGetTagValueOfName("RTI");
//	if theXMLTag &lt;&gt; null then
		self.setForCreateTIXML(theXMLTag,REAL_MODE);
//	endif;

end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateGridXMLdefn" id="28d91b47-e697-4a9d-88fe-71d09305d5f2">
        <updating/>
        <source>populateGridXMLdefn(_theXMLString: String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theXMLTag : String;
	theXMLString: String;
begin
	theXMLString := _theXMLString;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("d20");
	if theXMLTag &lt;&gt; null then
		self.bayDefnDoorDirection20 := theXMLTag.Integer.Boolean;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("d40");
	if theXMLTag &lt;&gt; null then
		self.bayDefnDoorDirection40 := theXMLTag.Integer.Boolean;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("f40");
	if theXMLTag &lt;&gt; null then
		self.bayDefnFortyFoot := theXMLTag.Integer.Boolean;
	endif;
	 // PAR 16415 CCMS 1029
	theXMLTag := theXMLString.cnEcGetTagValueOfName("f30");
	if theXMLTag &lt;&gt; null then
		self.bayDefnThirtyFoot := theXMLTag.Integer.Boolean;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("f53");
	if theXMLTag &lt;&gt; null then
		self.bayDefnFiftyThreeFoot := theXMLTag.Integer.Boolean;
	endif;
	
	// PAR 18682 CCMS SFW 1055
	theXMLTag := theXMLString.cnEcGetTagValueOfName("f45");
	if theXMLTag &lt;&gt; null then
		self.bayDefnFortyFive := theXMLTag.Integer.Boolean;
	endif;
	
	theXMLTag := theXMLString.cnEcGetTagValueOfName("m20");
	if theXMLTag &lt;&gt; null then
		self.bayDefnMotorDirection20 := theXMLTag.Integer.Boolean;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("m40");
	if theXMLTag &lt;&gt; null then
		self.bayDefnMotorDirection40 := theXMLTag.Integer.Boolean;
	endif;
				
	theXMLTag := theXMLString.cnEcGetTagValueOfName("mt");
	if theXMLTag &lt;&gt; null then
		self.bayDefnMtOnly := theXMLTag.Integer.Boolean;
	endif;
				
	theXMLTag := theXMLString.cnEcGetTagValueOfName("vt");
	if theXMLTag &lt;&gt; null then
		self.bayDefnVoltage := theXMLTag.Integer;
	endif;
				
	theXMLTag := theXMLString.cnEcGetTagValueOfName("hv");
	if theXMLTag &lt;&gt; null then
		self.bayDefnHeavy := theXMLTag.Integer.Boolean;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("pw");
	if theXMLTag &lt;&gt; null then
		self.bayDefnPowered := theXMLTag.Integer.Boolean;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("rf");
	if theXMLTag &lt;&gt; null then
		self.bayDefnReefer := theXMLTag.Integer.Boolean;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("na");
	if theXMLTag &lt;&gt; null then
		self.bayDefnUnavailable := theXMLTag.Integer.Boolean;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("wc");
	if theXMLTag &lt;&gt; null then
		self.bayDefnWaterCooled := theXMLTag.Integer.Boolean;
	endif;
	
end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateGridXMLdis" id="1a4bdc9a-7e29-48d6-a475-106dfdc6c4b6">
        <updating/>
        <source>populateGridXMLdis(_theXMLString: String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theXMLTag : String;
	fwdSlot : CM_SlotController;
	theBayArea : SHP_BayArea;
	theXMLString: String;
begin
	theXMLString := _theXMLString;

	theBayArea := self.myGridArea.SHP_BayArea;

	// NOTE all the discharge TI info is loaded by the Actual TI XML
	// only do this bit if we have not already done the actual
	/* PAR 7899
	if not theBayArea.generatedACT then
		theXMLTag := theXMLString.cnEcGetTagValueOfName("RTI");
		if theXMLTag &lt;&gt; null then
			self.setForCreateTIXML(theXMLTag,REAL_MODE); 
		endif;
	endif;
	*/

	// PAR 7959 FROM HERE 
	theXMLTag := theXMLString.cnEcGetTagValueOfName("ct");
	if theXMLTag &lt;&gt; null then
		self.colDischMyCargoType := theXMLTag.asOid.CM_CargoType;
	else
		self.colDischMyCargoType := null;
	endif;
	// PAR 7959 FROM HERE 
	theXMLTag := theXMLString.cnEcGetTagValueOfName("dp");
	if theXMLTag &lt;&gt; null then
		self.colDischMyDischPort := theXMLTag.asOid.CM_Port; //app.myRoot.allPorts[theXMLTag];
	else
		self.colDischMyDischPort := null;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("dpc");
	if theXMLTag &lt;&gt; null then
		self.colDischDischPortColour := theXMLTag.Integer;
	else
		self.colDischDischPortColour := -1;
	endif;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("sn");
	self.colDischSeqNum := theXMLTag.Integer;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("hp");
	self.colDischHasPlanned := theXMLTag.Integer.Boolean;
	
	theXMLTag := theXMLString.cnEcGetTagValueOfName("djb");
	if theXMLTag &lt;&gt; null then
		self.colDischMyJob := theXMLTag.asOid.CM_VoyageJob;
	else
		self.colDischMyJob := null;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("djc");
	if theXMLTag &lt;&gt; null then
		self.colDischMyJobIsComplete := theXMLTag.Integer.Boolean;
	else
		self.colDischMyJobIsComplete := null;
	endif;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("rl");
	if theXMLTag &lt;&gt; null then
		self.colDischReqLinked := theXMLTag.Integer.Boolean;
	else
		self.colDischReqLinked := false;
	endif;
	
	theXMLTag := theXMLString.cnEcGetTagValueOfName("MT");
	if theXMLTag &lt;&gt; null then
		self.colDischDLR := theXMLTag.Integer = DLR_MOVETYPE;
		self.colDischSOB := theXMLTag.Integer = SOB_MOVETYPE;
	else
		self.colDischDLR := false;
		self.colDischSOB := false;
	endif;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("pcd");
	self.colDischDischPortCode := theXMLTag;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("ccd");
	self.colDischCommodityGroupCode := theXMLTag;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("id");
	self.colDischTIID := theXMLTag;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("hz");
	if theXMLTag &lt;&gt; null then
		self.colDischIsHazardous := theXMLTag.Integer.Boolean;
	else
		self.colDischIsHazardous := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("od");
	if theXMLTag &lt;&gt; null then
		self.colDischOverDimensioned := theXMLTag.Integer.Boolean;
	else
		self.colDischOverDimensioned := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("f40");
	if theXMLTag &lt;&gt; null then
		self.colDischFortyFoot := theXMLTag.Integer.Boolean;
	else
		self.colDischFortyFoot := false;
	endif;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("mt");
	if theXMLTag &lt;&gt; null then
		self.colDischEmpty := theXMLTag.Integer.Boolean;
	else
		self.colDischEmpty := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("pw");
	if theXMLTag &lt;&gt; null then
		self.colDischPower := theXMLTag.Integer.Boolean;
	else
		self.colDischPower := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("rf");
	if theXMLTag &lt;&gt; null then
		self.colDischReefer := theXMLTag.Integer.Boolean;
	else
		self.colDischReefer := false;
	endif;
//	theXMLTag := theXMLString.cnEcGetTagValueOfName("na");
//	if theXMLTag &lt;&gt; null then
//		self.colDischUnavailable := theXMLTag.Integer.Boolean;
//	else
//		self.colDischUnavailable := false;
//	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("wc");
	if theXMLTag &lt;&gt; null then
		self.colDischWaterCooled := theXMLTag.Integer.Boolean;
	else
		self.colDischWaterCooled := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("hc");
	if theXMLTag &lt;&gt; null then
		self.colDischHiCube := theXMLTag.Integer.Boolean;
	else
		self.colDischHiCube := false;
	endif;


	// for printing to the sequence sheet, normally the aft bay of a forty does not have the job details
	if theBayArea.myJobSeqSheet &lt;&gt; null // this is only set if print seq sheet
	and self.bayIsAft  // aft end of a 40
	and self.colDischMyDischPort &lt;&gt; null // PAR 8424 added - has colour coding
	and self.colDischFortyFoot  // PAR 8424 added - is a 40
	and self.colDischMyJob = null then // no job details
			
		fwdSlot := self.myLocationsController.CM_SlotController.myForwardSlot;
		if fwdSlot &lt;&gt; null then
			if fwdSlot.mySlotRequestDischarge &lt;&gt; null then
				if theBayArea.myJobSeqSheet = fwdSlot.mySlotRequestDischarge.myJob then // it is the same job that is on the seq sheet
					self.colDischMyJob := fwdSlot.mySlotRequestDischarge.myJob.CM_VoyageJob ;
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateGridXMLload" id="a226cfce-e9a6-4348-80f5-44450cb44563">
        <updating/>
        <source>populateGridXMLload(_theXMLString: String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theXMLTag : String;
	theXMLString: String;
	drawHoldVertical : Boolean;
	fwdPoint : SHP_BayPoint;
	fwdArea : CMUI_GridArea;
	bayArea : SHP_BayArea;
	fwdSlot : CM_SlotController;
begin
	theXMLString := _theXMLString;


	theXMLTag := theXMLString.cnEcGetTagValueOfName("ct");
	if theXMLTag &lt;&gt; null then
		self.colLoadMyCargoType := theXMLTag.asOid.CM_CargoType;
	else
		self.colLoadMyCargoType := null;
	endif;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("cm");
	if theXMLTag &lt;&gt; null then
		self.colLoadMyCommodityGroup := theXMLTag.asOid.CM_CommodityGroup;
	else
		self.colLoadMyCommodityGroup := null;
	endif;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("dp");
	if theXMLTag &lt;&gt; null then
		self.colLoadMyDischPort := theXMLTag.asOid.CM_Port;
	else
		self.colLoadMyDischPort := null;
	endif;
	
	theXMLTag := theXMLString.cnEcGetTagValueOfName("ljb");
	if theXMLTag &lt;&gt; null then
		self.colLoadMyJob := theXMLTag.asOid.CM_VoyageJob;
	else
		self.colLoadMyJob := null;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("ljc");
	if theXMLTag &lt;&gt; null then
		self.colLoadMyJobIsComplete := theXMLTag.Integer.Boolean;
	else
		self.colLoadMyJobIsComplete := false;
	endif;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("hz");
	if theXMLTag &lt;&gt; null then
		self.colLoadIsHazardous := theXMLTag.Integer.Boolean;
	else
		self.colLoadIsHazardous := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("od");
	if theXMLTag &lt;&gt; null then
		self.colLoadIsOverDimensioned := theXMLTag.Integer.Boolean;
	else
		self.colLoadIsOverDimensioned := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("f40");
	if theXMLTag &lt;&gt; null then
		self.colLoadFortyFoot := theXMLTag.Integer.Boolean;
	else
		self.colLoadFortyFoot := false;
	endif;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("sn");
	self.colLoadSeqNum := theXMLTag.Integer;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("hp");
	self.colLoadHasPlanned := theXMLTag.Integer.Boolean;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("ht");
	self.colLoadHasTemp := theXMLTag.Integer.Boolean;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("m20");
	if theXMLTag &lt;&gt; null then
		self.colLoadMotor20 := theXMLTag.Integer.Boolean;
		self.colLoadMotorDirection20 := theXMLTag.Integer;
	else
		self.colLoadMotor20 := false;
		self.colLoadMotorDirection20 := null;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("m40");
	if theXMLTag &lt;&gt; null then
		self.colLoadMotor40 := theXMLTag.Integer.Boolean;
		self.colLoadMotorDirection40 := theXMLTag.Integer;
	else
		self.colLoadMotor40 := false;
		self.colLoadMotorDirection40 := null;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("dd20");
	if theXMLTag &lt;&gt; null then
		self.colLoadDoorDirection20 := theXMLTag.Integer;
	else
		self.colLoadDoorDirection20 := null;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("dd40");
	if theXMLTag &lt;&gt; null then
		self.colLoadDoorDirection40 := theXMLTag.Integer;
	else
		self.colLoadDoorDirection40 := null;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("mt");
	if theXMLTag &lt;&gt; null then
		self.colLoadEmpty := theXMLTag.Integer.Boolean;
	else
		self.colLoadEmpty := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("pw");
	if theXMLTag &lt;&gt; null then
		self.colLoadPower := theXMLTag.Integer.Boolean;
	else
		self.colLoadPower := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("rl");
	if theXMLTag &lt;&gt; null then
		self.colLoadReqLinked := theXMLTag.Integer.Boolean;
	else
		self.colLoadReqLinked := false;
	endif;
	
	theXMLTag := theXMLString.cnEcGetTagValueOfName("rf");
	if theXMLTag &lt;&gt; null then
		self.colLoadPortHole := theXMLTag.Integer.Boolean;
	else
		self.colLoadPortHole := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("na");
	if theXMLTag &lt;&gt; null then
		self.colLoadUnavailable := theXMLTag.Integer.Boolean;
	else
		self.colLoadUnavailable := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("wc");
	if theXMLTag &lt;&gt; null then
		self.colLoadWaterCooled := theXMLTag.Integer.Boolean;
	else
		self.colLoadWaterCooled := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("hh");
	if theXMLTag &lt;&gt; null then
		self.colLoadHalfHeight := theXMLTag.Integer.Boolean;
	else
		self.colLoadHalfHeight := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("hc");
	if theXMLTag &lt;&gt; null then
		self.colLoadHiCube := theXMLTag.Integer.Boolean;
	else
		self.colLoadHiCube := false;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("MT");
	if theXMLTag &lt;&gt; null then
		self.colLoadDLR := theXMLTag.Integer = DLR_MOVETYPE;
		self.colLoadSOB := theXMLTag.Integer = SOB_MOVETYPE;
	else
		self.colLoadDLR := false;
		self.colLoadSOB := false;
	endif;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("pcd");
	self.colLoadDischPortCode := theXMLTag;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("pcl");
	if theXMLTag &lt;&gt; null then
		self.colLoadDischPortColour := theXMLTag.Integer;
	else
		self.colLoadDischPortColour := NullColour;
	endif;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("ccd");
	self.colLoadCommodityGroupCode := theXMLTag;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("ptiw");
	self.colLoadPlannedTIWeight := theXMLTag;
	
	// for printing to the sequence sheet, normally the aft bay of a forty does not have the job details
	bayArea := self.myGridArea.SHP_BayArea;
	if bayArea.myJobSeqSheet &lt;&gt; null then // this is only set if print seq sheet
		if self.bayIsAft and self.colLoadFortyFoot then // aft end of a 40
		if self.colLoadMyJob = null then // no job details
			fwdSlot := self.myLocationsController.CM_SlotController.myForwardSlot;
			if fwdSlot &lt;&gt; null then
				if fwdSlot.mySlotRequestLoad &lt;&gt; null then
				if bayArea.myJobSeqSheet = fwdSlot.mySlotRequestLoad.myJob then // it is the same job that is on the seq sheet
					self.colLoadMyJob := fwdSlot.mySlotRequestLoad.myJob.CM_VoyageJob ;
				endif;
				endif;
			endif;
		endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateGridXMLpro" id="624bbb51-26de-4b1b-9843-c5ef5c93c5ce">
        <updating/>
        <source>populateGridXMLpro(_theXMLString: String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theXMLTag : String;

	theXMLString: String;
begin
	theXMLString := _theXMLString;

	// this is a bodge cos the location controller is not avail yet.
	theXMLTag := theXMLString.cnEcGetTagValueOfName("PTI");
	if theXMLTag &lt;&gt; null then
		self.setForCreateTIXML(theXMLTag,PLANNING_MODE);
	else
		self.setForCreateTIXMLNull(PLANNING_MODE);
	endif;

end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setAnAttributeFromController" id="abcbaa15-5e32-4182-a67b-8e3493517a74">
        <updating/>
        <source>setAnAttributeFromController(_attribute : String) updating;
// ---------------------------------------------------------------------------
// Created:     05 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
		// ### FORTY FOOT PEN
		if _attribute = CM_SlotRequest.Attribute_Forty then // PAR 18682 CCMS SFW 1055
			self.bayDefnFortyFoot := not self.bayDefnFortyFoot;
		// ### FORTY FIVE FOOT PEN
		elseif _attribute = CM_SlotRequest.Attribute_FortyFive then // PAR 18682 CCMS SFW 1055
			self.bayDefnFortyFive := not self.bayDefnFortyFive;
		// ### THIRTY FOOT PEN
		elseif _attribute = CM_SlotRequest.Attribute_Thirty then // PAR 18682 CCMS SFW 1055
			self.bayDefnThirtyFoot := not self.bayDefnThirtyFoot;
		// ### FIFTY THREE FOOT PEN
		elseif _attribute = CM_SlotRequest.Attribute_FiftyThree then // PAR 18682 CCMS SFW 1055
			self.bayDefnFiftyThreeFoot := not self.bayDefnFiftyThreeFoot;
		// ### 20 DOOR PEN
		elseif _attribute = CM_SlotRequest.Attribute_D20 then // PAR 18682 CCMS SFW 1055
			self.bayDefnDoorDirection20 := not self.bayDefnDoorDirection20;
		// ### 40 DOOR PEN
		elseif _attribute = CM_SlotRequest.Attribute_D40 then // PAR 18682 CCMS SFW 1055
			self.bayDefnDoorDirection40 := not self.bayDefnDoorDirection40;
		// ### 20 MOTOR PEN
		elseif _attribute = CM_SlotRequest.Attribute_M20 then // PAR 18682 CCMS SFW 1055
			self.bayDefnMotorDirection20 := not self.bayDefnMotorDirection20;
		// ### 40 MOTOR PEN
		elseif _attribute = CM_SlotRequest.Attribute_M40 then // PAR 18682 CCMS SFW 1055
			self.bayDefnMotorDirection40 := not self.bayDefnMotorDirection40;
		// ### MT ONLY PEN
		elseif _attribute =CM_SlotRequest.Attribute_Empty then // PAR 18682 CCMS SFW 1055
			self.bayDefnMtOnly := not self.bayDefnMtOnly;
		// ### HEAVY PEN
		elseif _attribute = CM_SlotRequest.Attribute_Heavy then // PAR 18682 CCMS SFW 1055
			self.bayDefnHeavy := not self.bayDefnHeavy;
		// ### VOLTAGE PEN
		elseif _attribute = CM_SlotRequest.Attribute_VoltageType then // PAR 18682 CCMS SFW 1055
			self.bayDefnVoltage := self.bayDefnVoltage + 1;
			if self.bayDefnVoltage &gt; 2 then
					self.bayDefnVoltage := 0;
			endif;
		// ### POWER PEN
		elseif _attribute = CM_SlotRequest.Attribute_Power then // PAR 18682 CCMS SFW 1055
			self.bayDefnPowered := not self.bayDefnPowered;
		// ### REEFER PEN
		elseif _attribute = CM_SlotRequest.Attribute_Reefer then // PAR 18682 CCMS SFW 1055
			self.bayDefnReefer := not self.bayDefnReefer;
		// ### WATERCOOLED PEN
		elseif _attribute = CM_SlotRequest.Attribute_Watercooled then // PAR 18682 CCMS SFW 1055
			self.bayDefnWaterCooled := not self.bayDefnWaterCooled;
		// ### NOT AVAILABLE PEN
		elseif _attribute = CM_SlotRequest.Attribute_Unavailable then // PAR 18682 CCMS SFW 1055
			self.bayDefnUnavailable := not self.bayDefnUnavailable;
		endif;
epilog

end;</source>
        <Parameter name="_attribute" type="String"/>
    </JadeMethod>
    <JadeMethod name="setController" id="6fe8a2bf-3b40-4549-af85-2f9c6a369b56">
        <updating/>
        <source>setController(_controller : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myLocationsController := _controller;
end;</source>
        <Parameter name="_controller" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ef3cb712-e89d-4d36-94ad-6ff3d7302f9a">
        <updating/>
        <source>setForCreate( _col,_row : Integer; _slotController : CM_SlotController; _bayArea : SHP_BayArea;_slotDefn : CM_SlotDefn; _popuplate : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theXML : String;
	isAft : Boolean;
begin
	self.setForCreateSuperClass(_bayArea, _row, _col);
	self.myLocationsController := _slotController;
	if _slotDefn = null then
		return;
	endif;
	self.mySlotDefn := _slotDefn;
	self.myBay := _slotDefn.myBay.CM_Bay;
//	self.myBay.setGridXMLPoint(self.bayFwdID,self.bayAftID,	self.bayIsAft,self.bayIsForward,self.bayType);

	self.bayIsAft := self.myBay.isAftBay;
	self.bayIsForward := not self.bayIsAft;
	if self.myBay.bayType = BAY_TYPE_TRIPLE then
		if self.myBay.myHold.allBays.indexOf(self.myBay) = 2 then
			self.bayIsForward := true;
		endif;
	endif;


	self.bayFwdID := self.myBay.id;
	self.bayAftID := self.myBay.idBay40;
	self.bayType := self.myBay.bayType;
	
	if _popuplate then
		// ##############################
		// DEFINITION
		theXML := self.mySlotDefn.getGridXMLdefn(CM_CellularVoyageStructure.GRID_VIEW_BAY);
		self.populateGridXMLdefn(theXML);
	endif;
end;</source>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_slotController" type="CM_SlotController"/>
        <Parameter name="_bayArea" type="SHP_BayArea"/>
        <Parameter name="_slotDefn" type="CM_SlotDefn"/>
        <Parameter name="_popuplate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateArray" id="fd972cb7-45b5-4cec-9667-b6b4b9475129">
        <updating/>
        <source>setForCreateArray(_array : StringArray512; _bayArea : SHP_BayArea) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpSlotDefn	: CM_SlotDefn;
	
begin
	self.setForCreateSuperClass(_bayArea, 
								_array[2].Integer, 
								_array[3].Integer);

	tmpSlotDefn 				:= _array[4].asOid.CM_SlotDefn;
	
	self.bayDefnUnavailable 	:= _array[5].Integer.Boolean;
	self.bayDefnWaterCooled 	:= _array[6].Integer.Boolean;
	self.bayDefnDoorDirection20 := _array[7].Integer.Boolean;
	self.bayDefnFortyFoot 		:= _array[8].Integer.Boolean;
	self.bayDefnMotorDirection20 := _array[9].Integer.Boolean;
	self.bayDefnMotorDirection40 := _array[10].Integer.Boolean;
	self.bayDefnMtOnly 			:= _array[11].Integer.Boolean;
	self.bayDefnPowered 		:= _array[12].Integer.Boolean;
	self.bayDefnReefer 			:= _array[13].Integer.Boolean;
	self.myLocationsController	:= _array[14].asOid.CM_LocationsController;

	self.mySlotDefn := tmpSlotDefn;
	self.myBay 		:= tmpSlotDefn.myBay.CM_Bay;
	self.myBay.setGridXMLPoint(self.bayFwdID,self.bayAftID,	self.bayIsAft,self.bayIsForward,self.bayType);

end;</source>
        <Parameter name="_array" type="StringArray512"/>
        <Parameter name="_bayArea" type="SHP_BayArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreateController" id="5d9a4c02-32f7-4414-b879-ddbd114cde05">
        <updating/>
        <source>setForCreateController( _col,_row : Integer; _slotController : CM_SlotController; _bayArea : SHP_BayArea) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	theXML : String;
	isAft : Boolean;
	aSlotController : CM_SlotController;
	myBayArea : SHP_BayArea;
	getActual : Boolean;
	theVoyage : CM_Voyage;
	_drawAttrs : CMIF_DrawingAttrController;
	removeSeqZeros,showOnlyDoorDirections : Boolean;
begin


	self.setForCreateSuperClass(_bayArea, _row, _col);
	if _slotController = null then
		return;
	endif;
	
	_drawAttrs := self.myGridArea.mySDF.myDrawingAttrController;
	
	self.myBay := _slotController.myBayVoyage;
	self.myBay.setGridXMLPoint(self.bayFwdID,self.bayAftID,	self.bayIsAft,self.bayIsForward,self.bayType);
	
	isAft := self.myBay.isAftBay();
	self.myLocationsController := _slotController;

	// ##############################
	aSlotController := self.myLocationsController.CM_SlotController;
	removeSeqZeros := aSlotController.myTerminal.getConfig(ShipRemoveLeadingZeros).Boolean;
	//epr TFS 7006 27/9/17
	showOnlyDoorDirections := aSlotController.myTerminal.getConfig(ShowOnlyDoorDirections).Boolean; // PAR 8190
	
	theVoyage := aSlotController.CM_SlotController.myVoyage;
	
	myBayArea := self.myGridArea.SHP_BayArea;
	getActual := true;
	
	theXML := aSlotController.getGridXMLall(getActual,_drawAttrs,theVoyage.starboardBerthed,removeSeqZeros,showOnlyDoorDirections);
	self.populateGridXML(theXML);
end;</source>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_slotController" type="CM_SlotController"/>
        <Parameter name="_bayArea" type="SHP_BayArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreateEmpty" id="1f81a7c3-d500-4de0-a694-07305cb72efa">
        <updating/>
        <source>setForCreateEmpty( _col,_row : Integer; _bayArea : SHP_BayArea) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTIs : CM_TIArray;
	aColour, idx : Integer;
	aLetter : String;
	aTI : CM_TrackedItem;
	aSlotReq : CM_SlotRequest;
begin
	self.setForCreateSuperClass(_bayArea, _row, _col);
epilog

end;</source>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_bayArea" type="SHP_BayArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreateTI" id="1c092924-7012-416d-a4d4-00126b7387ba">
        <updating/>
        <source>setForCreateTI(_theTI : CM_TrackedItem; _theMode: Integer; _controller : CMIF_DrawingAttrController input) updating;
// NOT USED

// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theWeight : Decimal[8,2];
	
begin
	theWeight := _theTI.totalWeight / 1000;

	inheritMethod(_theTI, _theMode, _controller);

	self.tiInfoCommodityGroupCode	:=	_theTI.commodity.trimBlanks();
	self.tiInfoISOTypeGroup			:=	_theTI.getISOType.trimBlanks();
	self.tiInfoOperatorCode 		:=	_theTI.operatorCode.trimBlanks();
	self.tiInfoProductCode			:=	_theTI.productCode.trimBlanks();
	self.tiInfoDischargePort		:=	_theTI.dischargePort.trimBlanks();
	self.tiInfoLoadPort				:=	_theTI.loadPort.trimBlanks();
	self.tiInfoTIID					:=	_theTI.id.trimBlanks();
	
	self.tiInfoWeight := theWeight.rounded().asStringJMT;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theMode" type="Integer"/>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateTIXML" id="ffbd577f-515d-42d8-ab46-5dcb76b11e9d">
        <updating/>
        <source>setForCreateTIXML(_theXMLString: String; _theMode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theIArray : IntegerArray;
	theTI : CM_TrackedItem;
	theXMLTag : String;
	colorCodeChangeEvent,
	pos, 
	pos2,
	index,
	tmpColour	 : Integer;
	tmpCode,
	theXMLString	: String;
	tmpObjectStr : String;
	theObj : Object;
	theWeight : Decimal[8,2];
	tmpTerminal	: CM_Terminal;
	tmpDisplayColors	: IntegerArray;
	tmpDisplayCodes		: StringArray;
	tmpDisplayObjects	: ObjectArray;
	aGridAttributes : SHP_GridAttributes;
	
begin
	theXMLString := _theXMLString;
	self.clearAttributes(_theMode);

	create aGridAttributes transient;
	if _theMode = REAL_MODE then
		theIArray := self.displayColoursACT;
		self.myAttributesActual := aGridAttributes;
	elseif _theMode = PLANNING_MODE then
		theIArray := self.displayColoursPRO;
		self.myAttributesProposed := aGridAttributes;
	endif;
	
	tmpDisplayColors	:= aGridAttributes.allDisplayColors;
	tmpDisplayCodes		:= aGridAttributes.allDisplayCodes;
	tmpDisplayObjects	:= aGridAttributes.allDisplayObjects;
	
//	colorCodeChangeEvent := app.colorCodeChangeTerminalEvent;
	tmpTerminal := self.myGridArea.mySDF.myTerminal;
	if tmpTerminal &lt;&gt; null then
		colorCodeChangeEvent := EVENT_CODE_COLOUR_CHANGE;
	endif;

	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLTag := theXMLString.cnEcGetNextTagValueOfName(GridXML_ColourDtl, pos);
		if pos = 0 then
			break;
		endif;
		if theXMLTag = null then
			continue;
		endif;
		
		pos2 := 1;
		index 		:= theXMLTag.cnEcGetNextTagValueOfName(GridXML_ColourKey, pos2).Integer;
		tmpCode		:= theXMLTag.cnEcGetNextTagValueOfName(GridXML_ColourCode, pos2);
		tmpColour	:= theXMLTag.cnEcGetNextTagValueOfName(GridXML_Colour, pos2).Integer;
		tmpObjectStr	:= theXMLTag.cnEcGetNextTagValueOfName(GridXML_Object, pos2).asStringJMT;

		if index &gt; 0 then
			theIArray.atPut(index, tmpColour); // &lt;&lt;&lt;&lt; COLOUR
			tmpDisplayColors.atPut(index, tmpColour); // &lt;&lt;&lt;&lt; COLOUR
			tmpDisplayCodes.atPut(index, tmpCode); // &lt;&lt;&lt;&lt; COLOUR
			theObj := null;
			if tmpObjectStr &lt;&gt; null then
				theObj := tmpObjectStr.asOid;
				if theObj &lt;&gt; null then
					self.beginNotification(theObj, colorCodeChangeEvent, Response_Continuous, null);
				endif;
				//tmpTerminal := self.myGridArea.mySDF.myTerminal;
				//if tmpTerminal &lt;&gt; null and theObj &lt;&gt; null then
				//	self.beginNotification(theObj, tmpTerminal.getTerminalEvent(EVENT_CODE_COLOUR_CHANGE), Response_Continuous, null);
				//endif;
			endif;
			tmpDisplayObjects.atPut(index, theObj); // &lt;&lt;&lt;&lt; OBJECT
			
			if index = TI_ColourMode_CommodityGroup then
				self.tiInfoCommodityGroupCode := tmpCode;
			elseif index = TI_ColourMode_Consignee then
				self.tiInfoConsigneeCode := tmpCode;
			elseif index = TI_ColourMode_DischargePort then
				self.tiInfoDischargePort := tmpCode;
			elseif index = TI_ColourMode_ISOTypeGroup then
				self.tiInfoISOTypeGroup := tmpCode;
			elseif index = TI_ColourMode_LoadPort then
				self.tiInfoLoadPort := tmpCode;
			elseif index = TI_ColourMode_Operator then
				self.tiInfoOperatorCode := tmpCode;
			elseif index = TI_ColourMode_Product then
				self.tiInfoProductCode := tmpCode;
			elseif index = TI_ColourMode_Status then
				self.tiInfoStatus := tmpCode;
			//elseif index = TI_ColourMode_Temperature then
				//self.tiInfoTemperature := tmpCode;
			//elseif index = TI_ColourMode_Voyage then
				//self.tiInfoVoyageCode := tmpCode;
			elseif index = TI_ColourMode_Weight then
				theWeight := tmpCode.Integer / 1000;
				self.tiInfoWeight := theWeight.rounded.asStringJMT;

			endif;
		endif;
	endwhile;

	// load in the attributes
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLTag := theXMLString.cnEcGetNextTagValueOfName("at", pos);
		if pos = 0 then
			break;
		endif;
		if theXMLTag = null then
			continue;
		endif;
		
		if _theMode = REAL_MODE then
			if self.bayActAttribute1 = null then
				self.bayActAttribute1 := theXMLTag;
			elseif self.bayActAttribute2 = null then
				self.bayActAttribute2 := theXMLTag;
			elseif self.bayActAttribute3 = null then
				self.bayActAttribute3 := theXMLTag;
			elseif self.bayActAttribute4 = null then
				self.bayActAttribute4 := theXMLTag;
			elseif self.bayActAttribute5 = null then
				self.bayActAttribute5 := theXMLTag;
			elseif self.bayActAttribute6 = null then
				self.bayActAttribute6 := theXMLTag;
			else
				break;
			endif;
		elseif _theMode = PLANNING_MODE then
			if self.bayProAttribute1 = null then
				self.bayProAttribute1 := theXMLTag;
			elseif self.bayProAttribute2 = null then
				self.bayProAttribute2 := theXMLTag;
			elseif self.bayProAttribute3 = null then
				self.bayProAttribute3 := theXMLTag;
			elseif self.bayProAttribute4 = null then
				self.bayProAttribute4 := theXMLTag;
			elseif self.bayProAttribute5 = null then
				self.bayProAttribute5 := theXMLTag;
			elseif self.bayProAttribute6 = null then
				self.bayProAttribute6 := theXMLTag;
			else
				break;
			endif;
		endif;
	endwhile;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("TO");
	if theXMLTag &lt;&gt; null then
		theTI := theXMLTag.asOid.CM_TrackedItem;
		if _theMode = REAL_MODE then
			self.allTrackedItems.add(theTI);
		elseif _theMode = PLANNING_MODE then
			self.allPlannedTrackedItems.add(theTI);
		endif;
	endif;

// ###########################################


	theXMLTag := theXMLString.cnEcGetTagValueOfName("nt");
	self.tiInfoNumTI := theXMLTag.Integer;
	if self.tiInfoNumTI &lt; 1 then
		self.setForCreateTIXMLNull(_theMode);
		return;
	endif;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("4b");
	self.tiInfo40BackEnd := theXMLTag.Integer.Boolean;


	theXMLTag := theXMLString.cnEcGetTagValueOfName("4i");
	self.tiInfo40 := theXMLTag.Integer.Boolean;
//	theXMLTag := theXMLString.cnEcGetTagValueOfName("cm");
//	self.tiInfoCommodityGroupCode := theXMLTag;
//	theXMLTag := theXMLString.cnEcGetTagValueOfName("is");
//	self.tiInfoISOCode := theXMLTag;
//	theXMLTag := theXMLString.cnEcGetTagValueOfName("op");
//	self.tiInfoOperatorCode := theXMLTag;
//	theXMLTag := theXMLString.cnEcGetTagValueOfName("dp");
//	self.tiInfoPortDischCode := theXMLTag;
//	theXMLTag := theXMLString.cnEcGetTagValueOfName("lp");
//	self.tiInfoPortloadCode := theXMLTag;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("id");
	self.tiInfoTIID := theXMLTag;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("cy");
	self.tiInfoCommodity := theXMLTag;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("tp");
	self.tiInfoReeferTemp := theXMLTag;
//	theXMLTag := theXMLString.cnEcGetTagValueOfName("wt");
//	self.tiInfoWeight := (theXMLTag.Integer /1000).Integer.asStringJMT;

	if _theMode = REAL_MODE then
		theXMLTag := theXMLString.cnEcGetTagValueOfName("pl");
		self.tiInfoPlannedLocation := theXMLTag;
		theXMLTag := theXMLString.cnEcGetTagValueOfName("ex");
		self.bayActIsExport := theXMLTag.Integer.Boolean;
		theXMLTag := theXMLString.cnEcGetTagValueOfName("im");
		self.bayActIsImport := theXMLTag.Integer.Boolean;

	elseif _theMode = PLANNING_MODE then
		theXMLTag := theXMLString.cnEcGetTagValueOfName("ex");
		self.bayProIsExport := theXMLTag.Integer.Boolean;
		theXMLTag := theXMLString.cnEcGetTagValueOfName("im");
		self.bayProIsImport := theXMLTag.Integer.Boolean;
	endif;

end;</source>
        <Parameter name="_theXMLString" type="String"/>
        <Parameter name="_theMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateTIXMLNull" id="dea22959-7794-4ab2-8fd6-e1585e193c23">
        <updating/>
        <source>setForCreateTIXMLNull(_theMode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.clearAttributes(_theMode);

	self.tiInfoCommodity			:=	null;
	self.tiInfoReeferTemp			:=	"";
	self.tiInfoNumTI				:=	null;
	self.tiInfo40BackEnd			:=	null;
	self.tiInfo40					:=	null;
	self.tiInfoCommodityGroupCode	:=	null;
	self.tiInfoISOTypeGroup			:=	null;
	self.tiInfoOperatorCode			:=	null;
	self.tiInfoProductCode			:=	null;
	self.tiInfoDischargePort		:=	null;
	self.tiInfoLoadPort				:=	null;
	self.tiInfoTIID					:=	null;
	self.tiInfoWeight				:=	null;
	self.tiInfoPlannedLocation		:=	null;
	
	if _theMode = REAL_MODE then
		self.bayActIsExport	:=	false;
		self.bayActIsImport	:=	false;
	endif;
	
	if _theMode = PLANNING_MODE then
		self.bayProIsExport	:=	false;
		self.bayProIsImport	:=	false;
	endif;
end;</source>
        <Parameter name="_theMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c88782f9-f9f2-4a4a-b1f7-aa5e4b6cb40d">
        <updating/>
        <source>setForUpdate(_controller : CMIF_DrawingAttrController input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
begin
	inheritMethod(_controller);

	self.setForUpdateXML(_controller);
	self.myGridArea.mySDF.myParentForm.sendMsgWithParams("doNoteForObject", self); // this will update the macro info table

end;</source>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateAssociatedPoint" id="024056a4-1709-4d4c-ad20-a34c7404eed1">
        <source>setForUpdateAssociatedPoint(_controller : CMIF_DrawingAttrController input);
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	matchingBayArea : CMUI_GridArea; //SHP_BayArea;
	drawHoldVertical : Boolean;
	matchingPoint : SHP_BayPoint;
begin
	drawHoldVertical := true; //self.myGridArea.myGridAreaForm.sdf01.myParentForm.SHP_VoyageAreaForm.drawHoldVertical;
	matchingPoint := self.getMatching40Point(drawHoldVertical,matchingBayArea,true);
	if matchingPoint &lt;&gt; null then

		matchingPoint.setForUpdate(_controller);
		matchingPoint.drawSelf(matchingBayArea.myGridAreaFrame);
	endif;
end;</source>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateXML" id="9bc045eb-2cf4-4e1c-ba7c-73bc31a24514">
        <updating/>
        <source>setForUpdateXML(_drawAttrs : CMIF_DrawingAttrController input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	theXML,theXMLSubString : String;
//	jobDComplete,jobLComplete : Boolean;
	allPoints : CMUI_GridPointSet;
	aPoint : CMUI_GridPoint;
	removeSeqZeros : Boolean;
	theVoyage : CM_Voyage;
	aSlotController : CM_SlotController;
	myBayArea : SHP_BayArea;
	getActual,showOnlyDoorDirections : Boolean;
begin
	aSlotController := self.myLocationsController.CM_SlotController;
	removeSeqZeros := aSlotController.myTerminal.getConfig(ShipRemoveLeadingZeros).Boolean;
	//showOnlyDoorDirections := aSlotController.myTerminal.getConfig(ShowOnlyDoorDirections).Boolean; // PAR 8190
	showOnlyDoorDirections := true;
	theVoyage := aSlotController.CM_SlotController.myVoyage;
	
	myBayArea := self.myGridArea.SHP_BayArea;
	if myBayArea.displayMode = ShpDisplayMode_Proposed then
		getActual := false;
	else
		getActual := true;
	endif;
	

	theXML := aSlotController.getGridXMLall(getActual,_drawAttrs,theVoyage.starboardBerthed,removeSeqZeros,showOnlyDoorDirections);
	// ### ACTUAL/PROPOSED - We store Actual, Proposed and EDI in the same attributes, so we only get 1 at a time
	/* WAS PAR 7539 AKB2004FEB
	theXMLSubString := theXML.cnEcGetTagValueOfName(CM_CellularVoyage.XmlTag_All_Actual);
	if theXMLSubString &lt;&gt; null then
		if getActual then
			self.populateGridXMLact(theXMLSubString);
		else
			self.populateGridXMLpro(theXMLSubString);
		endif;
	endif;
	NOW */
	if getActual then
		theXMLSubString := theXML.cnEcGetTagValueOfName(CM_CellularVoyageStructure.XmlTag_All_Actual);
		if theXMLSubString &lt;&gt; null then
			self.populateGridXMLact(theXMLSubString);
		endif;
	else
		theXMLSubString := theXML.cnEcGetTagValueOfName(CM_CellularVoyageStructure.XmlTag_All_Proposed);
		if theXMLSubString &lt;&gt; null then
			self.populateGridXMLpro(theXMLSubString);
		endif;
	endif;
	
	
	// ### LOAD COLOUR CODING
	theXMLSubString := theXML.cnEcGetTagValueOfName(CM_CellularVoyageStructure.XmlTag_All_Load);
	if theXMLSubString &lt;&gt; null then
		self.populateGridXMLload(theXMLSubString);
	endif;
	// ### DISCHARGE COLOUR CODING
	theXMLSubString := theXML.cnEcGetTagValueOfName(CM_CellularVoyageStructure.XmlTag_All_Discharge);
	if theXMLSubString &lt;&gt; null then
		self.populateGridXMLdis(theXMLSubString);
	endif;
	// DEFINITION
	theXML := self.mySlotDefn.getGridXMLdefn(CM_CellularVoyageStructure.GRID_VIEW_BAY);
	self.populateGridXMLdefn(theXML);

	self.myGridColumn.SHP_BayColumn.setForUpdate();
	self.myGridRow.SHP_BayRow.setForUpdate();
	

epilog
	delete allPoints;
end;</source>
        <Parameter name="_drawAttrs" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showNoColours" id="515f9829-6621-476f-a5b6-79d3584dddfb">
        <source>showNoColours() : Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myGridArea.SHP_BayArea.showNoColours;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateColourFromNote" id="f75e68f4-22d7-405d-815f-993d0e3d7ef8">
        <updating/>
        <source>updateColourFromNote(theObject: Object; theCode: String; theColour: Integer; _viewModeIndex : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	displayMode,viewMode : Integer;
	drawMe : Boolean;
	viewModeIndex : Integer;
begin
	
	displayMode := self.myGridArea.mySDF.displayMode;
	viewMode := self.myGridArea.mySDF.viewMode;
	viewModeIndex := _viewModeIndex;
	
	if viewModeIndex &gt; 0 
	and viewModeIndex &lt;&gt; TI_ColourMode_Voyage then	//we don't intend to show this colour here
		// ### REAL
		if self.myAttributesActual &lt;&gt; null then
			if self.myAttributesActual.allDisplayObjects[viewModeIndex] = theObject then
				self.displayColoursACT[viewModeIndex] := theColour;
				self.displayIconsACT[viewModeIndex] := theCode;
				
				self.myAttributesActual.allDisplayCodes[viewModeIndex] := theCode;
				self.myAttributesActual.allDisplayColors[viewModeIndex] := theColour;
				drawMe := true;
			elseif viewModeIndex = TI_ColourMode_DischargePort then
				viewModeIndex := TI_ColourMode_LoadPort;
				if self.myAttributesActual.allDisplayObjects[viewModeIndex] = theObject then
					self.displayColoursACT[viewModeIndex] := theColour;
					self.displayIconsACT[viewModeIndex] := theCode;
					
					self.myAttributesActual.allDisplayCodes[viewModeIndex] := theCode;
					self.myAttributesActual.allDisplayColors[viewModeIndex] := theColour;
					drawMe := true;
				endif;
			endif;
		endif;
		// ### PLAN
		if self.myAttributesProposed &lt;&gt; null then
			if self.myAttributesProposed.allDisplayObjects[viewModeIndex] = theObject then
				self.displayColoursPRO[viewModeIndex] := theColour;
				self.displayIconsPRO[viewModeIndex] := theCode;
				
				self.myAttributesProposed.allDisplayCodes[viewModeIndex] := theCode;
				self.myAttributesProposed.allDisplayColors[viewModeIndex] := theColour;
				drawMe := true;
			endif;
		endif;
	endif;
	
	 return drawMe;
end;</source>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="theCode" type="String"/>
        <Parameter name="theColour" type="Integer"/>
        <Parameter name="_viewModeIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
