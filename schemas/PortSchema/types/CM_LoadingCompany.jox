    <JadeMethod name="validateMe" id="c51de0ae-36c3-4191-96bb-ffcbd222c02d">
        <source>validateMe(_passport: CM_Passport input) protected;
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//------------------------------------------------
vars
begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	
	/*foreach  loadingCompany in app.myRoot.allLoader do            //29/07/2016 cnwma1 TFS #2447
		if loadingCompany.code.toUpper = self.code.toUpper then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
		endif;
	endforeach;*/
	
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description, null);
		app.raiseCMException(Input_required_field_Desc, ETRow_Description, null);
	endif;	

	if self.myRoot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Root', null, null);
		app.raiseCMException(Input_required_field_root, null, null); // cnwdb2	PAR 35364
	endif;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
