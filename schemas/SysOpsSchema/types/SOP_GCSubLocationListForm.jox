    <JadeMethod name="setupForm" id="43696761-401f-47b6-9a32-75bdefa572cf">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

begin

	self.minimumWidth := 310;
	self.minimumHeight := 150;

	inheritMethod();
	
	self.lblName.caption := app.getErrorString( GC_RackLocation );
	self.lblSubLocations.caption := app.getErrorString( GC_ShelfLocations );
	self.btnCancel.caption := app.getErrorString(Close);
	self.btnOk.visible := false;
	
	self.populateData();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="95d7023c-3768-4488-8c5a-048dd6e67cb2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 11:52:25.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022881, locale);
	btnDelete.translateCaption(Xlat_0019298, locale);
	btnNew.translateCaption(Xlat_0019299, locale);
	btnUpdate.translateCaption(Xlat_0019300, locale);
	lblName.translateCaption(Xlat_0019301, locale);
	lblSubLocations.translateCaption(Xlat_0019302, locale);
end;</source>
    </JadeMethod>
</GUIClass>
