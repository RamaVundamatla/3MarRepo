    <JadeMethod name="doSave" id="84ef3c0e-f678-49fa-ba82-332e04ccd255">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	pxyInvoiceLineDesc		: CM_InvoiceLineDescGroup;
	table				: CM_EntryTable;
	theReturn : Integer;
	theController : CMIF_InvoiceLineDescGroup;
begin


	table := self.tblEntDetail;

	if self.mode = Mode_Add then
		create pxyInvoiceLineDesc transient;
	elseif self.mode = Mode_Update then
		pxyInvoiceLineDesc := self.myProxyObject.CM_InvoiceLineDescGroup;
	else
		return false;
	endif;
	create theController transient;
	self.msgLines.getSelected(theController.allInvoiceLineDesc);
	
	pxyInvoiceLineDesc.setProxy(self.tblEntDetail.getValueByName(ETRow_Description).asStringJMT,self.tblEntDetail.getValueByName(ETRow_MinimumChargeAmount).Decimal,self.cmbChargeType.listObject.CM_InvoiceLineDesc);
	pxyInvoiceLineDesc.bank := self.myCurrentBank;
								
	theController.myPxyLineDescGroup := pxyInvoiceLineDesc;
	theController.myBank := self.myCurrentBank;
	
	while true do
 
	 	if self.mode = Mode_Add then
			app.myTrxCA.trxCreateInvoiceLineDescGroup(theController,  self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateInvoiceLineDescGroup(theController, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Invoice Line Group", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	
epilog
	if self.mode = Mode_Add then
		delete pxyInvoiceLineDesc;
	endif;
	delete theController;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="82650aee-c932-421c-8478-abac9596cdbc">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	area					: CM_TerminalArea;
	title					: String;
	
begin

	self.setTblDataEntRows(ETDef_InvMaintLineGroupData);

	self.zClearSortColumns();
