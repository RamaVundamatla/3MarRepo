    <JadeMethod name="btnBaseSchema_click" id="45d14ce9-bcee-44fd-83a7-3def349c722d">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBaseSchema_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		09 August 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	aboutForm	: CnEcBaseSchemaAboutForm;

begin
	app.mousePointer	:=	Busy;
	create aboutForm;
	aboutForm.showModal();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCategories_click" id="89283d10-b280-487a-9071-290ca62c1478">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCategories_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:  07 August 2000 by cnwdad1
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	reportForm	: CnEcReportCategoryListSuper;
	
begin
	app.mousePointer	:=	Busy;
	create reportForm as global.cnEcGetReportModuleForm(CnEcReportCategoryListSuper);
	reportForm.show();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="576b2618-a3e6-4ebe-8fb1-9cba4887f049">
