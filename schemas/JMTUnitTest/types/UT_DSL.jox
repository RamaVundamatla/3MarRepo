    <JadeMethod name="addHMSVoyageDelay" id="90653d30-007d-4a73-8521-6d2c6fbbca8d">
        <source>addHMSVoyageDelay(_delayCode,_delayDesc : String ; _isChargeable : Boolean): HMS_Delay;
/*

Purpose:		add Voyage Details	

Date		Who		Reason
06/03/2014	cnwma1	Initial creation

*/

vars
	pxyVoyageDelay,
	voyageDelay			: HMS_Delay;
	hmsObject			: HMS_Object;

begin

	// Delete Voyage Delay
	self.deleteHMSVoyageDelay(_delayCode);
	// Create Voyage Delay
	create pxyVoyageDelay transient;
	
	pxyVoyageDelay.setProxy(app.myRoot);
	
	pxyVoyageDelay.setPropertyValue("code", _delayCode);
	pxyVoyageDelay.setPropertyValue("description", _delayDesc);
	pxyVoyageDelay.setPropertyValue("isChargeable", _isChargeable);

	app.myTrxCA.trxCreateHMSObject(pxyVoyageDelay, hmsObject, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	voyageDelay := hmsObject.HMS_Delay;
	
	
	return voyageDelay;

epilog
	delete pxyVoyageDelay;

end;</source>
        <Parameter name="_delayCode" type="String"/>
