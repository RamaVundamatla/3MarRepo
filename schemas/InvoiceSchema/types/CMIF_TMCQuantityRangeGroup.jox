	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEvent" id="b5766abe-dc41-4c22-9b6b-ef82ea5ca45a">
        <source>isEvent() : Boolean;
/*
Purpose:	TFS 39518		
Date				Who			Reason
JULY 2018		CNWAB1		Initial creation
*/
vars
	aTransSB : CM_ServiceBroker; 
	isEvent	: Boolean;
begin
	if self.myGroup.isKindOf(CMIF_TMCQuantityRangeGroupDeft)    then 
		aTransSB := self.myGroup.myGroup.CMIF_TMCQuantityGroupDefault.myServiceMap;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityGroupDefault)   then 						
		aTransSB := self.myGroup.CMIF_TMCQuantityGroupDefault.myServiceMap;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityGroup)   then 						
		aTransSB := self.myGroup.CMIF_TMCQuantityGroup.myDebtorMap.myServiceBroker;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityRangeGroup)   then
		
		if self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_DebtorMap.myServiceBroker;
		elseif self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_MoveServiceBroker) then
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
		else
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
		endif;
	endif;
	if aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	endif;
	
	return isEvent;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToDoResource" id="36e4fcec-1488-4123-9b4f-a326283aca58">
        <source>isToDoResource() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/05/2023	navkc1	CR 57927 Task 57923: Jade - Transaction Map Export Import

*/

vars
	aTransSB 	: CM_ServiceBroker; 
	isTDR		: Boolean;
	finObj : CM_FinancialObject;
begin
	
	if self.myGroup.isKindOf(CMIF_TMCQuantityRangeGroupDeft)    then 
		aTransSB := self.myGroup.myGroup.CMIF_TMCQuantityGroupDefault.myServiceMap;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityGroupDefault)   then 						
		aTransSB := self.myGroup.CMIF_TMCQuantityGroupDefault.myServiceMap;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityGroup)   then 						
		aTransSB := self.myGroup.CMIF_TMCQuantityGroup.myDebtorMap.myServiceBroker;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityRangeGroup)   then
		finObj := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject;
		if finObj.isKindOf(CM_DebtorMap) then
			aTransSB := finObj.CM_DebtorMap.myServiceBroker;
		else
			aTransSB := finObj.CM_ServiceBroker;
		endif;
	endif;
	
	if aTransSB.isKindOf(CM_ToDoResourceServiceBroker) then
		isTDR := true;
	endif;
	
	return isTDR;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVTMIS" id="2aa711bd-6690-4220-bb6d-02b5d2027b22">
        <source>isVTMIS() : Boolean;
// for 23659
//13/02/2017 cnwma1 TFS #2901//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time

vars
	aTransSB : CM_ServiceBroker; 
	isVTMIS	: Boolean;
begin
	if self.myGroup.isKindOf(CMIF_TMCQuantityGroup)   then 							//09/02/2017 cnwma1 TFS #2901
		aTransSB := self.myGroup.CMIF_TMCQuantityGroup.myDebtorMap.myServiceBroker;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityRangeGroupDeft)    then             //09/02/2017 cnwma1 TFS #2901
		aTransSB := self.myGroup.myGroup.CMIF_TMCQuantityGroupDefault.myServiceMap;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityRangeGroup)   then
		
		if self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_DebtorMap.myServiceBroker;
		elseif self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_MoveServiceBroker) then
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
		else
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
		endif;
	endif;
	if aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	endif;
	
	return isVTMIS;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWorkOrder" id="bfbb35e2-4a09-42cf-b4de-2d66ea026fe9">
        <source>isWorkOrder() : Boolean;
/*
Purpose:	TFS 39518		
Date				Who			Reason
JULY 2018		CNWAB1		Initial creation
*/
vars
	aTransSB : CM_ServiceBroker; 
	isWO	: Boolean;
begin
	if self.myGroup.isKindOf(CMIF_TMCQuantityRangeGroupDeft)    then 
		aTransSB := self.myGroup.myGroup.CMIF_TMCQuantityGroupDefault.myServiceMap;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityGroupDefault)   then 						
		aTransSB := self.myGroup.CMIF_TMCQuantityGroupDefault.myServiceMap;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityGroup)   then 						
		aTransSB := self.myGroup.CMIF_TMCQuantityGroup.myDebtorMap.myServiceBroker;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityRangeGroup)   then
		
		if self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_DebtorMap.myServiceBroker;
		elseif self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_MoveServiceBroker) then
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
		else
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
		endif;
	endif;
	if aTransSB.isKindOf(CM_WorkOrderServiceBroker) then
		isWO := true;
	endif;
	
	return isWO;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="43e04f67-b8fe-46cd-a02e-613b7cd913a6">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time

vars
	aTransSB : CM_ServiceBroker; 
	aCommMap : CM_CommodityMap;
	aDebtorMap : CM_DebtorMap;
	isEvent, isVTMIS : Boolean;
	isBOL : Boolean;	//04 Nov 2019	NDL TFS 47100
begin
	inheritMethod();

	if self.isKindOf(CMIF_TMCQuantityRangeGroupDeft) or  self.isKindOf(CMIF_TMCQuantitySubRangeGroup) then //09/02/2017 cnwma1 TFS #2901
		return;
	endif;
	
	aDebtorMap := self.myGroup.CMIF_TMCQuantityGroup.myDebtorMap;
	aTransSB := aDebtorMap.myServiceBroker;
	
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then	//04 Nov 2019	NDL TFS 47100
		isBOL := true;
	else
		return;
	endif;

	myTMCController.myCurrentMapQuantity := self.myQuantityRangeMap.myQuantityMap;
	myTMCController.myCurrentMapQuantityRange := self.myQuantityRangeMap;
	
	if isVTMIS then
		myTMCController.myCurrentMapTMVoyage := aDebtorMap.myServiceBroker.CM_ResourceServiceBroker.myTransMap;
		myTMCController.myCurrentMapDebtor := aDebtorMap;
		myTMCController.myCurrentMapServiceBroker := aDebtorMap.myServiceBroker;
	elseif isEvent then
		myTMCController.myCurrentMapTMEvent := aDebtorMap.myServiceBroker.CM_EventServiceBroker.myTranMap;
		myTMCController.myCurrentMapDebtor := aDebtorMap;
		myTMCController.myCurrentMapServiceBroker := aDebtorMap.myServiceBroker;
	elseif isBOL then	//04 Nov 2019	NDL TFS 47100
		myTMCController.myCurrentMapTMBOL := aDebtorMap.myServiceBroker.CM_BOLServiceBroker.myTransMap;
		myTMCController.myCurrentMapDebtor := aDebtorMap;
		myTMCController.myCurrentMapServiceBroker := aDebtorMap.myServiceBroker;
	else
		myTMCController.myCurrentMapDebtor := aDebtorMap;
		myTMCController.myCurrentMapServiceBroker := aTransSB;
		myTMCController.myCurrentMapCommodity := aCommMap;
		myTMCController.myCurrentMapContents := aCommMap.contentsMap;
		myTMCController.myCurrentMapIMEX := myTMCController.myCurrentMapContents.imexMap;
		myTMCController.myCurrentMapProduct := myTMCController.myCurrentMapIMEX.myProductMap;
		myTMCController.myCurrentMapProdGrp := myTMCController.myCurrentMapProduct.myProductGroupMap;
		myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
		myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;

	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="52cd7fb1-09eb-43a0-a839-5907fa293908">
        <source>setEnableObjects(form: INV_TransactionMap io);
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
vars
	allowUpdate, allowDelete 	: Boolean;
	isEvent, isVTMIS, isWO 		: Boolean;
	aDebtorMap 					: CM_DebtorMap;
	aTransSB 					: CM_ServiceBroker;
	calcType					: CM_CalculationType;
	isBOL						: Boolean;
	isTDREvent					: Boolean; // 15/05/2023	navkc1	CR 57927 Task 54268
	isTDRWO						: Boolean; // 15/05/2023	navkc1	CR 57927 Task 54268
	aQtyMap : CM_QuantityMap;
begin

	inheritMethod(form);
	form.menuMappingSetActive.visible := false;
	
	if self.isDefault() then
		return;
	endif;
	
	if self.myQuantityRangeMap = null then
		return;
	endif;
	
	if self.isKindOf(CMIF_TMCQuantitySubRangeGroup)   then  //09/02/2017 cnwma1 TFS #2901
		return;
	endif;

	// ### JIRA 34596 14APR2025 NAVAB1
	aQtyMap :=self.myQuantityRangeMap.myQuantityMap;
	if aQtyMap.myParentFinancialObject.isKindOf(CM_QuantityRangeMap ) then
		aQtyMap :=self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_QuantityRangeMap.myQuantityMap;
	
	endif;
	
	if aQtyMap.myParentFinancialObject.isKindOf(CM_ServiceBroker ) then
		aTransSB :=aQtyMap.myParentFinancialObject.CM_ServiceBroker;
	elseif  self.myGroup.isKindOf( CMIF_TMCQuantityGroup) then //09/02/2017 cnwma1 TFS #2901
		aDebtorMap := self.myGroup.CMIF_TMCQuantityGroup.myDebtorMap;
		aTransSB := aDebtorMap.myServiceBroker;
	endif;
	
	
	if aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_WorkOrderServiceBroker) then // TFS 39236
		isWO := true;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then // TFS 39236
		isBOL := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isToDoRsrcServiceBroker() then // 15/05/2023	navkc1	CR 57927 Task 54268
		if aTransSB.CM_ToDoResourceServiceBroker.myServiceBroker.isEventServiceBroker() then
			isTDREvent := true;
		elseif aTransSB.CM_ToDoResourceServiceBroker.myServiceBroker.isWOServiceBroker() then
			isTDRWO := true;
		endif;
	endif;

	allowUpdate := not self.myQuantityRangeMap.myQuantityMap.isDefault();
	allowDelete := (self.myQuantityRangeMap.myQuantityMap.allQuantityRanges.size &gt; 1);
	// 1279
	calcType := self.myQuantityRangeMap.myQuantityMap.myCalculationType;
	if calcType &lt;&gt; null then
		if allowUpdate then
			allowUpdate := (calcType.allQuantityRanges.size = 0);
		endif;
		if allowDelete then
			allowDelete := (calcType.allQuantityRanges.size = 0);
		endif;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(form.myTerminal, form.permissionMaint) then
		allowUpdate := false;
	endif;
	
	
	form.modePropertyNew := INV_TransactionMap.ModeProperty_QuantityRange;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_QuantityRange;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_QuantityRange;
	form.btnDelete.enabled := allowDelete;
	form.btnNew.enabled := false;
	form.btnProperties.enabled := allowUpdate;
	form.menuSItemDelete.visible := allowDelete;
	// from 29499 QNS 2177 development, for Voyage tran map, only allow update of invoice line descs at IIN/OUT contract level, otherwise the update code gets it wrong
	form.mnuSItemUpdate.visible := not isVTMIS;
	form.menuSItemProperties.visible := allowUpdate;
	form.mnuTMExport.visible := false;
	
	//09/02/2017 cnwma1 TFS #2901
	form.menuSItemProperties.visible := true;
	form.btnProperties.enabled := true;
	form.menuSItemNew.visible := true;  
	form.menuSINewSubQTY.enabled := true;
	form.menuSINewSubQTY.visible := true;
	//09/02/2017 cnwma1 TFS #2901
	if isVTMIS then
		form.menuTMVnew.visible := allowUpdate;  // MAIN VTMIS NEW MENU
		form.menuSINewSubQTY.visible := false;  //09/02/2017 cnwma1 TFS #2901
	elseif isWO then // TFS 39236
		form.menuTMWOnew.visible := false;  // MAIN WORK ORDER NEW MENU
		form.menuSINewSubQTY.visible := false; 
	elseif isBOL then // 01 Nov 2019	NDL	TFS 47100
		form.menuTMBOLnew.visible := false;  // MAIN BOL NEW MENU
		form.menuSINewSubQTY.visible := false; 
	elseif isEvent then
		form.menuTMEnew.visible := false; // TFS 2906 allowUpdate;  // MAIN EVENT NEW MENU
		form.menuSINewSubQTY.visible := false; //09/02/2017 cnwma1 TFS #2901
	elseif isTDREvent or isTDRWO then // 15/05/2023	navkc1	CR 57927 Task 54268
		form.menuSINewSubQTY.visible := false; // 15/05/2023	navkc1	CR 57927 Task 54268
	else
		// 17/01/2017 cnwma1 TFS #2885
		if  self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_QuantityRangeMap) then
			form.menuSItemNew.visible := false; // TFS 2906 allowUpdate;  // MAIN CARGO NEW MENU
		endif;
	endif;
	
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="98683f14-a112-45d4-804a-150b5c34cb59">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars
	aTransSB 						: CM_ServiceBroker; 
	aTransSB2 						: CM_ServiceBroker; 
	aCommMap 						: CM_CommodityMap;
	aDebtorMap 						: CM_DebtorMap;
	isEvent, isVTMIS, isWorkOrder 	: Boolean;
	isBOL 							: Boolean;	//04 Nov 2019	NDL	TFS 47100
	isToDoResource  				: Boolean;	// 15/05/2023	navkc1	CR 57927 Task 54268
	isTDREvent						: Boolean;	// 15/05/2023	navkc1	CR 57927 Task 54268
	isTDRWO							: Boolean;	// 15/05/2023	navkc1	CR 57927 Task 54268
begin
	inheritMethod(form);

	if self.isKindOf(CMIF_TMCQuantityRangeGroupDeft) then
		return;
	endif;
	
	form.myTMCQuantityRange := self;
	if self.myGroup.isKindOf(CMIF_TMCQuantityGroup) then 				//09/02/2017 cnwma1 TFS #2901
		aDebtorMap := self.myGroup.CMIF_TMCQuantityGroup.myDebtorMap;
		aTransSB := aDebtorMap.myServiceBroker;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantitySubRangeGroup) then
		if self.myGroup.CMIF_TMCQuantitySubRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_ServiceBroker) then
			aTransSB := self.myGroup.CMIF_TMCQuantitySubRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker; //09/02/2017 cnwma1 TFS #2901
		elseif self.myGroup.CMIF_TMCQuantitySubRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
			aDebtorMap := self.myGroup.CMIF_TMCQuantitySubRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_DebtorMap;
			aTransSB := aDebtorMap.myServiceBroker;
		endif;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityRangeGroup) then
			aDebtorMap := self.myGroup.myGroup.CMIF_TMCQuantityGroup.myDebtorMap;
			if aDebtorMap &lt;&gt; null then
				aTransSB := aDebtorMap.myServiceBroker;
			endif;
	endif;
	
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isKindOf(CM_WorkOrderServiceBroker) then // TFS 39236
		isWorkOrder := true; // TFS 39236
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then	//04 Nov 2019	NDL	TFS 47100
		isBOL := true;
	elseif aTransSB.isToDoRsrcServiceBroker() then // 15/05/2023	navkc1	CR 57927 Task 54268
		isToDoResource := true;
		aTransSB2 := aTransSB.CM_ToDoResourceServiceBroker.myServiceBroker;
		if aTransSB2 &lt;&gt; null then
			if aTransSB2.isEventServiceBroker() then
				isTDREvent := true;
			elseif aTransSB2.isWOServiceBroker() then
				isTDRWO := true;
			endif;
		endif;
	else
		return;
	endif;

	form.myCurrentMapQuantity := self.myQuantityRangeMap.myQuantityMap;
	form.myCurrentMapQuantityRange := self.myQuantityRangeMap;
	
	if isVTMIS then
		form.myCurrentMapTMVoyage := aDebtorMap.myServiceBroker.CM_ResourceServiceBroker.myTransMap;
		form.myCurrentMapDebtor := aDebtorMap;
		form.myCurrentMapServiceBroker := aDebtorMap.myServiceBroker;
	elseif isEvent then
		form.myCurrentMapTMEvent := aDebtorMap.myServiceBroker.CM_EventServiceBroker.myTranMap;
		form.myCurrentMapDebtor := aDebtorMap;
		form.myCurrentMapServiceBroker := aDebtorMap.myServiceBroker;
	elseif isWorkOrder then // TFS 39236
		form.myCurrentMapTMWorkOrder := aDebtorMap.myServiceBroker.CM_WorkOrderServiceBroker.myTransMap;
		form.myCurrentMapDebtor := aDebtorMap;
		form.myCurrentMapServiceBroker := aDebtorMap.myServiceBroker;
	elseif isBOL then //04 Nov 2019	NDL	TFS 47100
		form.myCurrentMapTMBOL := aDebtorMap.myServiceBroker.CM_BOLServiceBroker.myTransMap;
		form.myCurrentMapDebtor := aDebtorMap;
		form.myCurrentMapServiceBroker := aDebtorMap.myServiceBroker;
	elseif isToDoResource then // 15/05/2023	navkc1	CR 57927 Task 54268
		if isTDREvent then
			form.myCurrentMapTMEvent := aTransSB2.CM_EventServiceBroker.myTranMap;
		elseif isTDRWO then
			form.myCurrentMapTMWorkOrder := aTransSB2.CM_WorkOrderServiceBroker.myTransMap;
		endif;
		form.myCurrentMapDebtor := aDebtorMap;
		form.myCurrentMapServiceBroker := aTransSB;
	else
		form.myCurrentMapDebtor := aDebtorMap;
		form.myCurrentMapServiceBroker := aTransSB;
		form.myCurrentMapCommodity := aCommMap;
		form.myCurrentMapContents := aCommMap.contentsMap;
		form.myCurrentMapIMEX := form.myCurrentMapContents.imexMap;
		form.myCurrentMapProduct := form.myCurrentMapIMEX.myProductMap;
		form.myCurrentMapProdGrp := form.myCurrentMapProduct.myProductGroupMap;
		form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
		form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;

	endif;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
