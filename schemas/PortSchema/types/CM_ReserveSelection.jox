    <JadeMethod name="isFullyLoaded" id="723a15bc-687f-4481-9a31-96b3cf50ceb2">
        <source>isFullyLoaded(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2015	cnwndl1	Initial creation	Par 37288
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	ti : CM_TrackedItem;
	loadedCount : Integer;
	loadedWeight : Decimal [16,4];
	lc : CM_LocationsController;
	allTis	: CM_TISet;
begin
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	//foreach ti in self.allTrackedItems do
	foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
		if ti.isNotified then
			// can't have been released or loaded yet
			continue;
		endif;
		lc := ti.myPrimaryActualLocation;
		if lc &lt;&gt; null and ti.isOnSite then
			if lc.isKindOf( CM_YardController ) then
				// its still in the yard, can't be loaded yet
				continue;
			endif;
		endif;
		
		loadedCount := loadedCount + ti.totalQuantity.max(1);
		loadedWeight := loadedWeight + ti.totalWeight;
		
	endforeach;

	if self.weightRequested &gt; 0 then	
		return loadedWeight &gt;= weightRequested;
	else
		return loadedCount &gt;= totalRequested;
	endif;

epilog

	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFullySPL" id="e45ab772-24b7-4f2a-a464-eaae4cf2875f">
        <source>isFullySPL(): Boolean;
/*

Purpose:			 Is Fully Staged, and  Packed or Loaded

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2017	cnwndl1	Initial creation	TFS 4016
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	tiSet : CM_TISet;
	firstStagingLC : CM_LocationsController;
	loadedCount : Integer;
	packedCount : Integer;
	stagedCount : Integer;
	outstandingCount : Integer;
	loadedWeight : Decimal [16,4];
	packedWeight : Decimal [16,4];
	stagedWeight : Decimal [16,4];
	outstandingWeight : Decimal [16,4];
	ti : CM_TrackedItem;
	isPack : Boolean;
	lc : CM_LocationsController;
	totalReleased  : Decimal [16,4];
	allTis	: CM_TISet;
	
begin

	if self.myReserveHeader &lt;&gt; null then
		isPack :=  self.myReserveHeader.isPackingType();
	endif;
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	if isPack then
		//foreach ti in self.allTrackedItems do
		foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			if ti.isNotified then
				// can't have been released or loaded yet
				continue;
			endif;
			if not ti.isChild then
				continue;
			endif;
			
			packedCount := packedCount + ti.totalQuantity.max(1);
			packedWeight := packedWeight + ti.totalWeight;
			
		endforeach;
	else
		//foreach ti in self.allTrackedItems do
		foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			if ti.isNotified then
				// can't have been released or loaded yet
				continue;
			endif;
			lc := ti.myPrimaryActualLocation;
			if lc &lt;&gt; null and ti.isOnSite then
				if lc.isVehicle
				or lc.isTILCController
				or lc.isWagon	//09 Jun 2020	NDL	TFS 49537
				then
					//Its on a truck or trailer
					loadedCount := loadedCount + ti.totalQuantity.max(1);
					loadedWeight := loadedWeight + ti.totalWeight;
				endif;
			endif;
		endforeach;
	endif;
	

	create tiSet transient;
	stagedCount := self.getTotalStaged( tiSet, firstStagingLC, null );
	
	if self.weightRequested &gt; 0 then
		foreach ti in tiSet do
			stagedWeight := stagedWeight + ti.totalWeight;
		endforeach;
		foreach ti in self.allTrackedItemsReleased do
			if ti.isBulkByVolume or ti.isBulkByWeight then
				totalReleased := totalReleased + ti.totalWeight;
			endif;
		endforeach;
		
		outstandingWeight := self.weightRequested  - totalReleased;
		if outstandingWeight.abs &lt;= Measure_AllowableDifference then				
			outstandingWeight:=0;												
		endif;	
		
		return ( stagedWeight + loadedWeight + packedWeight ) &gt;= outstandingWeight;
	else
	
		foreach ti in self.allTrackedItemsReleased do
			//epr par 34406 25/6/14
			if ti.isBulkByVolume or ti.isBulkByWeight then	
				continue;
			endif;
		
			totalReleased := totalReleased + ti.totalQuantity.max(1);
		endforeach;
		
		outstandingCount := self.getTotalRequested - totalReleased.Integer;
		return ( stagedCount + loadedCount + packedCount ) &gt;= outstandingCount;
	endif;
	

epilog

	delete tiSet;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFullyStaged" id="409806a5-12b9-4b0b-9f7b-3b2b84f410fb">
        <source>isFullyStaged(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 October 2015	cnwndl1	Initial creation	Par 37033

*/

vars

	tiSet : CM_TISet;
	firstStagingLC : CM_LocationsController;
	stagedCount : Integer;
	outstandingCount : Integer;
	stagedWeight : Decimal [16,4];
	outstandingWeight : Decimal [16,4];
	ti : CM_TrackedItem;

begin

	create tiSet transient;
	
	
	stagedCount := self.getTotalStaged( tiSet, firstStagingLC, null );
	
	if self.weightRequested &gt; 0 then
		foreach ti in tiSet do
			stagedWeight := stagedWeight + ti.totalWeight;
		endforeach;
		outstandingWeight := self.getWeightOutstanding;
		return stagedWeight &gt;= outstandingWeight;
	else
		outstandingCount := self.getTotalOutstanding;
		return stagedCount &gt;= outstandingCount;
	endif;

epilog

	delete tiSet;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMatch" id="4b51b588-098f-4411-a35d-ce9371d98906">
        <source>isMatch(_reserveSelectionToMatch : CM_ReserveSelection) : Boolean;
/*

Purpose:			Matches the current Reserve Selection against the one passed in

Parameters:			_reserveSelectionToMatch	CM_ReserveSelection	Reserve Selection to match against

Return Value:		Boolean	Whether or not the reserve selection matches

Date				Who		Reason
14 February 2024	navpw1	Initial creation TFS: 59411 (62272)
24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
*/

begin
	if self.clean						= _reserveSelectionToMatch.clean and
		self.myISOType					= _reserveSelectionToMatch.myISOType and
		self.myProduct					= _reserveSelectionToMatch.myProduct and
		self.myCargoType				= _reserveSelectionToMatch.myCargoType and
		self.myISOGroup					= _reserveSelectionToMatch.myISOGroup and
		self.heavyRated					= _reserveSelectionToMatch.myReserveHeader.getHeavyDuty().asBooleanJMT() and
		self.packType					= _reserveSelectionToMatch.packType and
		self.bestPick					= _reserveSelectionToMatch.bestPick and
		self.remarks					= _reserveSelectionToMatch.remarks and
		self.colour						= _reserveSelectionToMatch.colour and
		self.descriptionSelection		= _reserveSelectionToMatch.descriptionSelection and
		self.heightSelection			= _reserveSelectionToMatch.heightSelection and
		self.lengthSelection			= _reserveSelectionToMatch.lengthSelection and
		self.markNumber					= _reserveSelectionToMatch.markNumber and
		self.quantitySelection			= _reserveSelectionToMatch.quantitySelection and
		self.remarksSelection			= _reserveSelectionToMatch.remarksSelection and
		self.volumeSelection			= _reserveSelectionToMatch.volumeSelection and
		self.weightSelection			= _reserveSelectionToMatch.weightSelection and
		self.widthSelection				= _reserveSelectionToMatch.widthSelection and
		self.markSelection				= _reserveSelectionToMatch.markSelection and
		self.densitySelection			= _reserveSelectionToMatch.densitySelection and
		self.typeSelection				= _reserveSelectionToMatch.typeSelection and
		self.myBOLIn					= _reserveSelectionToMatch.myBOLIn and
		self.maxToRelease				= _reserveSelectionToMatch.maxToRelease and
		self.sequence					= _reserveSelectionToMatch.sequence and
		self.myDeliveryParty			= _reserveSelectionToMatch.myDeliveryParty and
		self.myDeliveryAddress			= _reserveSelectionToMatch.myDeliveryAddress and
		self.deliveryInstructions		= _reserveSelectionToMatch.deliveryInstructions and
		self.deliveryFrom				= _reserveSelectionToMatch.deliveryFrom and
		self.deliveryTo					= _reserveSelectionToMatch.deliveryTo and
		self.defaultAnyAmount			= _reserveSelectionToMatch.defaultAnyAmount and
		self.defaultAnyId				= _reserveSelectionToMatch.defaultAnyId and
		self.cargoMatchClientReference	= _reserveSelectionToMatch.cargoMatchClientReference and
		self.cargoMatchOrderNumber		= _reserveSelectionToMatch.cargoMatchOrderNumber and
		self.cargoMatchPurchaseOrder	= _reserveSelectionToMatch.cargoMatchPurchaseOrder and
		self.cargoMatchReceiveDate		= _reserveSelectionToMatch.cargoMatchReceiveDate and
		self.cargoMatchReleaseDate		= _reserveSelectionToMatch.cargoMatchReleaseDate and
		self.cargoMatchRemarks			= _reserveSelectionToMatch.cargoMatchRemarks and
		self.cargoMatchUNDGcode			= _reserveSelectionToMatch.cargoMatchUNDGcode and
		self.cargoMatchVesselCode		= _reserveSelectionToMatch.cargoMatchVesselCode and
		self.maxWeightRequested			= _reserveSelectionToMatch.maxWeightRequested and
		self.customerReference			= _reserveSelectionToMatch.customerReference and
		self.totalRequested				= _reserveSelectionToMatch.totalRequested and
		self.myCargoGroup				= _reserveSelectionToMatch.myCargoGroup and
		self.myCommodity				= _reserveSelectionToMatch.myCommodity
	then
		return true;
	else
		return false;
	endif;
	
end;</source>
        <Parameter name="_reserveSelectionToMatch" type="CM_ReserveSelection"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMatchForISOTypeProduct" id="adb89519-7d4e-452c-b17b-f9b1cd7613c0">
        <source>isMatchForISOTypeProduct(_ti : CM_TrackedItem; _giveError : Boolean) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	08 June 2007 By cnwth2

Purpose:	Compares either ISOType/Group for containers/generators or product for non-containers
			Used when looking for a reserve selection to match when releasing an item (if not already associated)
			
			The rules for ISO Type/Group checking are (as user can enter ISO Type AND/OR ISO Type Group)
				1. if only have ISO Type, then must match ISO Type
				2. if only have ISO Group, then must match ISO Group
				3. if have ISO Type and Group, then check ISO Type first, if no match, then match ISO Group
				   (this is so preference can be given to match Type, but if none found, match group)
			- CNWRS2 20.11.2009


Changed On   Changed By  Reason
20.11.09	 cnwgb1	 	 Rearrange according to rules above. Vaguely related      to PAR 21618
9 Mar 2010	 cnwrs2	 	 Adding in flag to give error or not so can use to find best  match without raising an exception.
25 Mar 2024  navma1		 ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
*/
vars
	tiISOType,
	tiISOGroupCode,
	myISOGroupCode : String;
	tiISOGroup,
	myISOGroup	   		   : CM_ISOTypeGroup;
	cargoType	 		   : CM_CargoType;
	reserveIsoType		   : CM_ISOType;
begin
	
	cargoType := self.myCargoType;										//25.03.2024 navma1 #63141
	
	if _ti = null or cargoType = null then
		return false;
	endif;
	
	if app.isUnitTestGarbageCollect then
		return false;
	endif;
	
	if cargoType.type = TI_CargoType_Container or						//25.03.2024 navma1 #63141
	   cargoType.type = TI_CargoType_Generator then
		if not _ti.isContainer or _ti.isKindOf(CM_Generator) then 
			return false;
		endif;

		reserveIsoType := self.myISOType;								//25.03.2024 navma1 #63141
		
		if reserveIsoType &lt;&gt; null then
			tiISOType := _ti.getISOType();
			
			if reserveIsoType.code = tiISOType then
				return true;
			elseif self.myISOGroup &lt;&gt; null then		//+cnwml2 PAR25325
				if self.myISOGroup.allISOTypes.includes(_ti.getISOTypeObject) then
					return true;
				endif;
			endif;

			if _giveError then
				app.raiseCMException3(ERR_ISO_ATTACH_MISMATCH, tiISOType,_ti.id, reserveIsoType.code, ETRow_TotalRequested, null);
			endif;
			return false;
		endif;
		
		tiISOGroup := _ti.getISOTypeGroup();
		myISOGroup := self.getISOGroupObject();
		if tiISOGroup = myISOGroup then //cnwas3 PAR 20619
			return true;
		else
			//8/12/2009 cnwdz2 par21840
			if tiISOGroup &lt;&gt; null then
				tiISOGroupCode := tiISOGroup.code;
			endif;
			
			if myISOGroup &lt;&gt; null then
				myISOGroupCode := myISOGroup.code;
			endif;
			if _giveError then
				app.raiseCMException3(TI_TestReqISOGroup, _ti.id, tiISOGroupCode, myISOGroupCode, ETRow_TotalRequested, null);
				return false;
			endif;
		endif;
		return false;
	else
		if self.myProduct &lt;&gt; null then
			return self.myProduct = _ti.myProduct;
		else//how to compare just a product description??
			//return _ti.description.toUpper.cnContains(self.productStr.toUpper);
			return  (_ti.description = null and self.productStr = null) or 
					(_ti.description.toUpper.cnContains(self.productStr.toUpper)); //21/05/2024	navkc1 Bug 64182 - If both are null then return true
		endif;
	endif;
	
	return false;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_giveError" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReleaseEdit" id="dc4e1520-aaa9-4bac-9a4a-94f260725843">
        <source>isReleaseEdit(_reserveDetail : CM_ReserveDetail output) : Boolean;
/*

Purpose:			

Parameters:			

