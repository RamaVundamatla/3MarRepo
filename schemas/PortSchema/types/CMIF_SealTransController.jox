<Class name="CMIF_SealTransController" id="a3dd927c-2058-428e-8106-e12bf10aefe9">
    <superclass name="CMIF_TITransactionController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="sealNum" id="6ea23d4f-f5da-43cd-ac12-a55990967681">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFromTransaction" id="e2276d70-bc49-4bf1-8bd1-1319a1828a38">
        <updating/>
        <source>setFromTransaction(_txn: CM_Seal) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_txn);

	self.sealNum := _txn.sealNum;
	
end;</source>
        <Parameter name="_txn" type="CM_Seal"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDetails" id="0698cdd3-802c-4829-9dbe-0386cfa5f338">
        <updating/>
        <source>setTransactionDetails(_txn: CM_Seal input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_txn);
	_txn.setSealDetails(self.sealNum);

end;</source>
        <access>protected</access>
        <Parameter name="_txn" type="CM_Seal" usage="input"/>
    </JadeMethod>
</Class>
