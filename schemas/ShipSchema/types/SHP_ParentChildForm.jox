    <JadeMethod name="setCaption" id="648b2981-96ed-4469-ab2f-0b96dc5ea11c">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	tmpCaption : String;
begin
	if self.mode = self.Mode_View then
		tmpCaption  := "(" &amp; app.getErrorString(View).toUpper() &amp; ") ";
	elseif self.mode = self.Mode_Edit then
		tmpCaption  := "(" &amp; app.getErrorString(Edit).toUpper() &amp; ") ";
	elseif self.mode = self.Mode_New then
		tmpCaption  := "(" &amp; app.getErrorString(New).toUpper() &amp; ") ";

	endif;
	
	tmpCaption  := tmpCaption &amp; self.getChildTypeName;
	if self.myCurrentChild &lt;&gt; null then
		tmpCaption := tmpCaption &amp; " - ";
	endif;
	tmpCaption := tmpCaption &amp; getChildNiceName(self.myCurrentChild);

	inheritMethod(tmpCaption);


epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
