        <updating/>
        <source>doRefresh() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 August 2008	consw1	Initial creation

*/

vars
	imexConfig : CM_YAIMEXConfig;

begin
	inheritMethod();

	imexConfig := self.myProxyYAIMEXConfig.pxyGetRealObject;
	
