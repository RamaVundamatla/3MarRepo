    <JadeMethod name="txtParent_lostFocus" id="1f2027a3-24e8-4e2c-beed-78d6c73fcaa0">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtParent_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation 	Par 36900

*/

vars

	parent : CM_TrackedItem;
	msg : String;

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if self.txtParent.text.trimBlanks = null or self.txtParent.text = self.lblParent.caption.toUpper then
		self.txtParent.text := self.lblParent.caption.toUpper;
		self.txtParent.userObject := null;
		
	else
		if self.findParent( parent ) then
			self.txtParent.text := parent.id;
			self.txtParent.userObject := parent;
		else
			msg := app.getErrorString1( Contain_not_known_site, self.txtParent.text );
			self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
			self.txtParent.userObject := null;
		endif;
		
	endif;
	
	self.txtParent.selStart := 0;
	self.txtParent.selLength := 0;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
