    <JadeMethod name="getSubjectClassName" id="749a8e36-9455-4c7c-8b27-1aff002d90b9">
        <source>getSubjectClassName() : String;
/*

Date		Who		Reason
05 Apr 2017	cnwkpd1	TFS 3369 - Push Events application - invalid object exception
	
*/

vars
	cls 			: Class;
	s 				: String;
	len, 
	startTagLen, 
	endTagLen 		: Integer;
	subject 		: CM_Object;
	invalid			: Boolean;
	
begin
	// if we have a subject, ask it for its class name
	subject := self.mySubject;
	if subject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, subject, invalid);

		cls := subject.class;
		if cls &lt;&gt; null then
			return cls.name;
		endif;
	endif;
	
	// otherwise get the class name from the subject string
	s := self.getClassTag;
	if s = null then
		return null; // no class name tag
	endif;
	len := s.length;
	startTagLen := TagClassStart.length;
	endTagLen := TagEnd.length;
	if len &lt;= (startTagLen + endTagLen) then
		return null; // no class name between start and end tags
	endif;
	// the class name is in between the start and end tags
	return s[startTagLen + 1 : len - (startTagLen + endTagLen)];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSubjectIdString" id="f8cb0881-dc07-4123-9140-2fd3897cebf2">
        <source>getSubjectIdString() : String;
/*

Date		Who		Reason
05 Apr 2017	cnwkpd1	TFS 3369 - Push Events application - invalid object exception
	
*/

vars
	s 				: String;
	lastEndTagPos, 
	startPos, 
	i, 
	len 			: Integer;
	subject			: CM_Object;
	invalid			: Boolean;
	
begin
	subject := self.mySubject;
	// if we have a subject, ask it for its audit string
	if subject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, subject, invalid);
		return subject.auditIdDisplay;
	endif;
	
	// otherwise get the audit string from our subject id string
	s := self.subjectIdString;
	if s = null then
		return null; // no subject id string either
	endif;
	// the audit display string is the part of the string following
	// the last end tag (denoting the end of the class and user tags
	// if we have them)
	len := s.length;
	lastEndTagPos := 0;
	while true do
		startPos := lastEndTagPos + 1;
		if startPos &gt; len then
			break;
		endif;
		i := s.pos(TagEnd, startPos);
		if i &lt; startPos then
			break;
		endif;
		lastEndTagPos := i;
	endwhile;
	if lastEndTagPos &lt; 1 then
		return s; // no class or user tags
	endif;
	return s[lastEndTagPos + TagEnd.length : end];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTime" id="8896aa57-56d2-487e-b964-2ed10d32bd0b">
        <source>getTime(): Time;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2018	jlgmp6	Initial creation	TFS37718

*/

vars

begin
	if self.timestamp.Date.isValid() then
		return self.timestamp.Time;
	endif;
	return "00:00".Time;

epilog

end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="getUserName" id="e7dc155c-7158-471f-a3b8-7298b46dc2f8">
        <source>getUserName() : String;

vars
	s : String;
	len, startTagLen, endTagLen : Integer;
	
begin
	// if we have a user, return their name
	if self.myUser &lt;&gt; null then
		return self.myUser.userName;
	endif;
	// otherwise get the user name from the subject string
	s := self.getUserTag;
	if s = null then
		return null; // no user tag
	endif;
	len := s.length;
	startTagLen := TagUserStart.length;
	endTagLen := TagEnd.length;
	if len &lt;= (startTagLen + endTagLen) then
		return null; // no user name between start and end tags
	endif;
	// the user name is in between the start and end tags
	return s[startTagLen + 1 : len - (startTagLen + endTagLen)];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserTag" id="e115d06a-98c7-4147-a548-6b6236c506e0">
        <source>getUserTag() : String protected;

vars
	s : String;
	startPos, endPos, i : Integer;
	
begin
	s := self.subjectIdString;
	if s = null then
		return null;
	endif;
	startPos := s.pos(TagUserStart, 1);
	if startPos &lt; 1 then
		return null;
	endif;
	i := startPos + TagUserStart.length;
	if i &gt; s.length then
		return null;
	endif;
	endPos := s.pos(TagEnd, i);
	if endPos &lt; i then
		return null;
	endif;
	return s[startPos : (endPos - startPos) + TagEnd.length];
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForTag" id="04cdb74d-5bce-4b27-81ec-8a645aa87ed6">
        <source>getValueForTag(pStr, pTag : String; pValue : String output) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2001 by cnwrs2
//
// Purpose:     Returns true if the tag is found and sets the value
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;
	valLen,
	pos		: Integer;
	
begin

	pos := pStr.pos(pTag &amp; AuditStringSeparator, 1);
	if pos &gt; 1 and pStr[pos-1] &lt;&gt; AuditStringSeparator then
		// Have found incorrect tag so look further ...
		// (i.e. blahTAG:3:111:  instead of TAG:3:222:
		pos := pStr.pos(AuditStringSeparator &amp; pTag &amp; AuditStringSeparator, pos);
		if pos &gt; 0 then
			// move past initial AuditStringSeparator
			pos := pos+1;
		endif;
	endif;

	if pos = 0 then
		// tag not found so "no change" to tag value
		return false;
	endif;
	// cnwrs1 CCMS 1054 Nov 2006 changed it to work
	tmpStr := pStr.cnGetToken(pos, AuditStringSeparator);	// move past the tag name
	valLen := pStr.cnGetToken(pos, AuditStringSeparator).Integer;	// get the length of the value
	pValue := pStr[pos : valLen];
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="pStr" type="String"/>
        <Parameter name="pTag" type="String"/>
        <Parameter name="pValue" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
