    <JadeMethod name="setupForm" id="60989365-b331-42c8-9a1b-7e54ba8e6687">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	ratio : Integer;
	tmpRoot : CM_Root;
	
begin
	inheritMethod();
	
	self.setNavigator();
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	
		
	self.initTblTrainQuery();
	self.initTableInfo();
	self.initFrameRake();

	self.frmGridArea.visible := false;

	self.frmColLegendTIs.left := 5;
	self.frmColLegendTIs.top := 0;
	self.frmColLegendTIs.doResize();	
		
	self.frmModeStatusBar.initFrame();
	self.frmModeStatusBar.myFrameDisplayMode.enabled := false;

	self.mnuToggleMacro.caption := self.MNU_MACRO_HIDE;
	self.mnuToggleToolbar.caption := self.MNU_TOOLBAR_HIDE;
	self.mnuToggleLegend.caption := self.MNU_LEGEND_HIDE;

	self.beginClassNotification(CM_Rail, false, self.myTerminal.getTerminalEvent(Rail_Clear_Rake_Event), Response_Continuous, null);

	self.beginClassNotification(CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Delete_Event), Response_Continuous, null);
	
	self.beginClassNotification(CM_Train, false, Any_System_Event, Response_Continuous, null);

	if self.isDisplayedTrains or self.isDisplayedRailAreas then
		self.myAssistant.comboBoxTrain(self.cmbTrain, self.myFilterTrain, false, self.isDisplayedRailAreas, false);
	endif;

	self.frmModeStatusBar.myFrameDisplayMode.enabled := true;	
	self.getXMLSettingsForSetup();

end;</source>
    </JadeMethod>
    <JadeMethod name="showAreaSelector" id="5b07b76d-0b58-4790-a617-d0675cf6fa77">
        <source>showAreaSelector();
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	obj : Object;
	row : Integer;
	theFrame : CMUI_MoveableFrame;
	
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	theFrame := self.frmSelectAreas;
	
	theFrame.centreHorizontallyInParent();
	theFrame.top := 100;
	
	theFrame.zOrder(1);

	self.doBuildQueryLists();

	if self.isDisplayedTrains then
		self.tblTrains.clearAllSelected();
		foreach obj in self.allTrains do
			self.tblTrains.selectObject(obj,false);
		endforeach;
	elseif self.isDisplayedRailAreas then
		self.lstSelectAreas.clearAllSelected();
		foreach obj in self.allRailAreas do
			self.lstSelectAreas.selectObject(obj);
		endforeach;
	endif;

	self.showAreaSelectorEnable(true);
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showAreaSelectorEnable" id="812edfd5-4e98-4e06-b311-3e8174acfa31">
        <source>showAreaSelectorEnable(_enable : Boolean);
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars
	dockBar : Object;
begin
	self.frmColLegendTIs.enabled := not _enable;
	self.frmToolbar.enabled := not _enable;
	self.frmRakeToolbar.enabled := not _enable;
	self.tblInfo.enabled := not _enable;

	foreach dockBar in self.allGridAreaDockBars do
		dockBar.YRD_RailDockBar.mySDF.enabled := not _enable;
	endforeach;

	self.btnSelectAreasSh.default := _enable;
	self.frmSelectAreas.visible := _enable;
end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCargoPicture" id="cff48efc-7a71-4703-abed-f7294da50a97">
        <source>showCargoPicture(_theTI : CM_Object) : Binary;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	thePicture : Binary;
begin
	
	
	if _theTI = null or not (_theTI.isKindOf(CM_TrackedItem) or _theTI.isKindOf(CM_Wagon)) then
		return null;
	endif;
 	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
		return null;
 	endif;

	if _theTI.isKindOf(CM_Wagon) then
			thePicture := _theTI.CM_Wagon.getPicture();
	else
		if _theTI.CM_TrackedItem.isPallet() then
			thePicture := self.picPallet.picture;
		else
			thePicture := _theTI.CM_TrackedItem.getPicture();
		endif;
	endif;
	
	return thePicture;
	
	
end;</source>
        <Parameter name="_theTI" type="CM_Object"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="showGridArea" id="dfcfd253-ee87-42fe-b0ae-73025cad9784">
        <updating/>
        <source>showGridArea(_railArea : CM_Rail) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sdfLabel : String;
	maxWagons : Integer;
	theSDF : CMUI_ScrollableDrawingFrame;
	train : CM_Train;
	
begin
	theSDF := self.getSDF(_railArea);

	self.removeDynamicGridAreaFrames(theSDF);

	if self.isDisplayedTrains then
		foreach train in self.allTrains do
			if outwardsTrain then
				maxWagons := maxWagons.max(train.allWagonsByOrderOutward.size);
			else
				maxWagons := maxWagons.max(train.allWagonsByOrderInward.size);
			endif;
		endforeach;
		foreach train in self.allTrains do
			self.showTrain(train, maxWagons, theSDF);
		endforeach;
	elseif self.isDisplayedRailAreas then
		sdfLabel := _railArea.getID();
		self.showRakeRailArea(_railArea, theSDF);
	endif;

	theSDF.drawSelf();		

	theSDF.drawFrameLabel(sdfLabel);
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.dkbGridArea.myDragSelectFrame.enabled:= false;
	endif;

epilog

end;</source>
        <Parameter name="_railArea" type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="showHideToolbars" id="047d5c6a-96a5-4447-b90f-045e41aff395">
        <updating/>
        <source>showHideToolbars(_hide: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _hide then
		self.frmToolbar.visible := false;
		self.frmRakeToolbar.visible := false;
	else

		// need to do this to get toolbars correct
		self.frmRakeToolbar.alignContainer := Frame.AlignContainer_None; 
		self.frmToolbar.alignContainer := Frame.AlignContainer_Top; 
		self.frmRakeToolbar.top := self.frmToolbar.height;
		self.frmRakeToolbar.alignContainer := Frame.AlignContainer_Top; 

		self.frmToolbar.visible := true;
		self.frmRakeToolbar.visible := true;

	endif;

	self.doResize();

epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showInfoForWagonGridPoint" id="fd509954-5681-45ee-919f-031969e8b016">
        <updating/>
        <source>showInfoForWagonGridPoint(_gridPoint : CMUI_GridPoint; _x, _y : Real) protected, updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/08/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	bulkRelease		: CM_BulkRelease;
	wgnController 	: CM_WagonController;
	obj				: Object;
	numRows,
	row 			: Integer;
	ti				: CM_TrackedItem;
	wagonCntrl		: CM_WagonController;
	tbl				: CM_DataTable;
begin
	if _gridPoint = null then
		return;
	endif;
	//grid point can be eith YRD_WagonPoint, YRD_WagonBody or YRD_WagonWheels
	//if YRD_WagonPoint, there may be container at this point so display container info
	//else display wagon info
	if YRD_WagonPoint.hasInstance(_gridPoint) then
		ti := _gridPoint.YRD_WagonPoint.getTI(_x, _y); //_gridPoint.x1,_gridPoint.y1);
		if _gridPoint.isBoxcar then	//20 Mar 2013	NDL	Par 31278
			ti := null;
		endif;
		if ti = null then
			bulkRelease := _gridPoint.YRD_WagonPoint.getBulkRelease(_x, _y);
		endif;
	endif;
	
	if CM_WagonController.hasInstance(_gridPoint.myLocationsController) then
		self.myCurrentWagon := _gridPoint.myLocationsController.CM_WagonController.myWagon;
	endif;
	
	self.myCurrentTrackedItem := ti;
	
	if self.myCurrentTrackedItem &lt;&gt; null then
		self.displayExtraInfoForObj(ti);
	elseif bulkRelease &lt;&gt; null then
		self.displayExtraInfoForObj(bulkRelease);
	elseif self.myCurrentWagon &lt;&gt; null then
		if YRD_WagonColorCode.hasInstance(_gridPoint) then
			self.displayExtraInfoForObj(myCurrentWagon.getRailAllocation);
		else
			self.displayExtraInfoForObj(myCurrentWagon);
		endif;
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_gridPoint" type="CMUI_GridPoint"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="showPrintFrame" id="720e0f79-8c25-45a9-a1c7-f2da8a750513">
        <source>showPrintFrame();
// ---------------------------------------------------------------------------
