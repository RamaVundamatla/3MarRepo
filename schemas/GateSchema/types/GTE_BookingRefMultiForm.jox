    <JadeMethod name="addObjectsToTable" id="0251fc10-822d-48c0-9145-21dc90ee010e">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
15 Jul 2011	cnwkpd1	PAR #27874 - Transient leaks in Gate forms
18 Aug 2011	cnwjre1	par 27881 make the search more efficient/avoid locking issues, also do booking ref items here
09 Feb 2011	cnwkpd1	PAR #28731 - fix transient leaks
11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
*/

vars
	breakOut	: Boolean;
	gotException	: Boolean;
	operKey,
	refKey	: String;
	voyageKey	: CM_Voyage;
	edTest		: Integer;
	statusKey	: Integer;
	iter	: Iterator;
	dictOp	: CM_BookingRefsByOperatorRefVoy;
	dictRef : CM_BookingRefsByRefDups;
	dictStatus : CM_BookingRefsByStatusRefDups;
	dictSteve  : CM_BookingRefSet;
//	coll : Collection;
	bookingRef	: CM_BookingRef;
	bookingRefItem 	: CM_BookingRefItem;
	stevedore       : CM_Stevedore;
begin
	//30 Nov 2009	NDL	CCMS 1028 - myCurrentObject set from "CMUI_XTABDisplayForm::doBookingEnquiry"
	//							to a collection...(starting from a single cell of a summary display)
	if not self.isFirstActivateComplete then
		if self.myCurrentObject &lt;&gt; null then
			if self.myCurrentObject.isKindOf(CM_BookingRefSet) then
				self.copyCollectionToTable(self.myCurrentObject.Collection, _numItems);
			elseif self.myCurrentObject.isKindOf(CM_BookingRefItemSet) then
				self.btnShowBookItms.value := true;
				self.initDataTable();
				self.copyCollectionToTable(self.myCurrentObject.Collection, _numItems);
			endif;
		endif;
		return;
	endif;
	
	if self.isFirstActivateComplete then															//+cnwml2 PAR20173 SFW CCMS 1091
		/*
		if self.btnShowBookItms.value then
			coll := self.findBookingRefItems();
			self.copyCollectionToTable(coll.Collection, _numItems);
		else
			self.copyCollectionToTable(self.myTerminal.allBookingRefsByOperatorRef, _numItems);
		endif;
		*/
		// 18 Aug 2011	cnwjre1	par 27881 make the search more efficient - the code above is replaced by the code below

		on Exception do app.handleDeletedObject (exception, bookingRef, gotException);
		
		if self.filterBookingReference &lt;&gt; null then
			dictRef := self.myTerminal.allBookingRefsByRef;
			iter := dictRef.createIterator();
			dictRef.startKeyGeq(self.filterBookingReference, iter);
		elseif self.filterStevedoreCode &lt;&gt; null then                    	  //02.10.2020 cnwma1 TFS #50112
			stevedore := app.myRoot.allStevedores[self.filterStevedoreCode];
			dictSteve := stevedore.allBookingRefs;
			iter := dictSteve.createIterator();
			
		elseif self.filterStatus &lt;&gt; -1 then
			dictStatus := self.myTerminal.allBookingRefsByStatusRef;
			iter := dictStatus.createIterator();
			dictStatus.startKeyGeq(self.filterStatus, null, iter);		
		else
			dictOp := self.myTerminal.allBookingRefsByOperatorRef;
			iter := dictOp.createIterator();
			dictOp.startKeyGeq(self.filterOperatorCode, null, null, iter);
		endif;
	
		while iter.next(bookingRef) do
		
			if dictRef &lt;&gt; null then
				iter.getCurrentKeys(refKey); //MTN-35226
				if not refKey.startsWith(self.filterBookingReference) then
					break;
				endif;
			elseif dictStatus &lt;&gt; null then
				iter.getCurrentKeys(statusKey,refKey); //MTN-35226
				if statusKey &lt;&gt; self.filterStatus then
					break;
				endif;
			elseif dictOp &lt;&gt; null and
			   self.filterOperatorCode &lt;&gt; null then
				iter.getCurrentKeys(operKey,refKey,voyageKey); //MTN-35226
				if operKey &lt;&gt; self.filterOperatorCode then
					break;
				endif;
			endif;
			// invalid object check
			gotException := false;
			edTest := bookingRef.edition;
			if gotException then
				continue;
			endif;
			
			if self.includeObject(bookingRef, app.myPassport) then
				if self.btnShowBookItms.value then
					foreach bookingRefItem in bookingRef.allBookingRefItems do
						self.addObjectToTable(bookingRefItem, _numItems, breakOut);
					endforeach;
				else
					self.addObjectToTable(bookingRef, _numItems, breakOut);
				endif;
				if breakOut then
					break;
				endif;
			endif;
		endwhile;
	endif;	
	
epilog
//	delete coll;			// PAR #27874
	delete iter;
	
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="9b8f22a0-684b-495c-9ed1-9d020da8f084">
        <source>addToolbarControls() protected;
/*
	Created on 08 February 2008
	
	by Debby Hutchison
	
	Purpose:
	
	11/03/2010	cnwcs5	par 22605 - Booking Reconciliation permission.  Hide toolbar buttons if user does not have permission
	25/03/2010	cnwcs5	par 22605 - more fixes
	04 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
*/

vars
	toolbar		: CMUI_Toolbar;
	terminal	: CM_Terminal;
begin
	inheritMethod();
	
	toolbar 	:= self.frmToolbarItem;
	terminal	:= self.myTerminal;		// 11/03/2010 cnwcs5 par 22605
	
	toolbar.addButton(self.btnNewItem, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteItem, CMUI_Toolbar.Control_Alignment_Left);
	
	self.frmToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);			// cnwrs2 - visual improvement
	
	if self.allowUpdate and		// 25/03/2010 cnwcs5 par 22605
		app.myCurrentUserCan (terminal, PmGteBookingRefRollSplit) then	// 11/03/2010 cnwcs5 par 22605
		self.frmToolbar.addButton(self.btnEditVoyage, CMUI_Toolbar.Control_Alignment_Left);	// cnwdad1 19/03/2009 - PAR #19176.
	endif;															// 11/03/2010 cnwcs5 par 22605
	
	if self.allowUpdate then	// 11/03/2010 cnwcs5 par 22605
		self.frmToolbar.addButton(self.btnEditStatus, CMUI_Toolbar.Control_Alignment_Left);	// cnwdad1 27/05/2009 - CCMS SFW 1079.
	endif;															// 11/03/2010 cnwcs5 par 22605
	
	self.frmToolbar.addButton(self.btnShowBookItms, CMUI_Toolbar.Control_Alignment_Left);
	
	if self.allowUpdate and		// 25/03/2010 cnwcs5 par 22605
		app.myCurrentUserCan (terminal, PmGteBookingRefRecon) then	// 11/03/2010 cnwcs5 par 22605
		self.frmToolbar.addButton(self.btnReconciled, CMUI_Toolbar.Control_Alignment_Left);
	endif;															// 11/03/2010 cnwcs5 par 22605
	
	self.frmToolbar.addButton(self.btnBookingRefDis, CMUI_Toolbar.Control_Alignment_Left);	//02 Sep 2009	NDL Par 20521 CCMS 1609
	self.btnBookingRefDis.visible := true;		//02 Sep 2009	NDL Par 20521 CCMS 1609
	
	// 11/03/2010 - cnwcs5	uncommented the following code now that booking summaries have been implemented
	if app.myCurrentUserCan( terminal, PmSummaryDefView ) then
		// NOTE: This is the frmToolbar not frmToolbarItem.
		self.frmToolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
		self.frmToolbar.addButton( self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left );
	endif;
	self.frmToolbar.addButton(self.btnInstruction, CMUI_Toolbar.Control_Alignment_Left);	//03.10.2022 navtnr20 TFS 54967
	
	toolbar.positionToolbarControls();
	toolbar.showCaptions := frmToolbar.showCaptions;
	toolbar.refresh();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="94dbe1f2-e8df-4941-97cf-34dea03006ec">
        <source>allowsTableFilters(_table: Table): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2012	cnwmc5	Initial creation

*/

vars

begin
	//return inheritMethod(_table);
	//25 Oct 2013	NDL	Par 32386
	if _table = self.tblData then
		return true;
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="applyColumnFilter" id="cc9a1745-adea-4854-81a2-4df943f347a7">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2013	cnwndl1	Initial creation	Par 32386

*/

vars
	visibleCount : Integer;
begin
	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
