    <JadeMethod name="addConstantToFile" id="597cdebe-d180-4b2a-8cc8-46e2211e763c">
        <updating/>
        <source>addConstantToFile(_constant : Constant; _tokens : StringArray512) updating;

/*
	
Purpose:		Add Constant to file

Date			Who		Reason
12/09/2016		cnwmh5	Initial creation

*/

vars

	schema						: Schema;
	klass						: Class;
	constant					: Constant;
	
	changedBy					: String;
	changedTS					: TimeStamp;
	constType					: String;
	constDefinition				: String;
	constText					: String;

begin

	if _constant = null then
		schema := rootSchema.getSchema(_tokens[1]);
		if schema = null then
			return;
		endif;
		
		klass := schema.getClass(_tokens[2]);
		if klass = null then
			return;
		endif;
		
		constant := klass.getConstant(_tokens[4]);
		if constant = null then
			return;
		endif;
	else
		constant := _constant;
	endif;
	
	changedBy := constant.cnGetModifierName();
	changedTS := constant.cnGetModifiedTimeStamp();
	constType := constant.getType().name;
	constDefinition := constant.getSource();
	constText := constant.text;
	
	self.elementConstantC := self.elementConstantsC.addElement(constant.name);
	self.elementC := self.elementConstantC.addElement(self.ChangedDateTag);
	self.elementC.setText(changedTS.date.format("dd/MM/yyyy"));
	self.elementC := self.elementConstantC.addElement(self.ChangedTimeTag);
	self.elementC.setText(changedTS.time.String);
	self.elementC := self.elementConstantC.addElement(self.ChangedByTag);
	self.elementC.setText(changedBy);
	self.elementC := self.elementConstantC.addElement(self.TypeTag);
	self.elementC.setText(constType);
	self.elementC := self.elementConstantC.addElement(self.DefinitionTag);
	self.elementC.setText(constDefinition);
	self.elementC := self.elementConstantC.addElement(self.TextTag);
	self.elementC.addCDATA(constText);
	
epilog

end;</source>
        <Parameter name="_constant" type="Constant"/>
        <Parameter name="_tokens" type="StringArray512"/>
    </JadeMethod>
    <JadeMethod name="addGlobalConstantToFile" id="5801faa6-fda5-41cd-8120-c9a19b37945b">
        <updating/>
        <source>addGlobalConstantToFile(_globalConstant : GlobalConstant; _tokens : StringArray512) updating;

/*
	
Purpose:		Add Global Constant to file

Date			Who		Reason
14/09/2016		cnwmh5	Initial creation

*/

vars

	schema						: Schema;
	globalConstant				: GlobalConstant;
	constCategory				: ConstantCategory;
	obj							: Object;
	
	allConstants				: ConstantNDict;
	
	changedBy					: String;
	changedTS					: TimeStamp;
	constType					: String;
	constDefinition				: String;
	constText					: String;

begin


	if _globalConstant = null then
	
		if _tokens[3] = "CATEGORY" then
		return;
	endif;
	
		if _tokens[3] = "CATEGORY" then
			return;
		endif;
	
		schema := rootSchema.getSchema(_tokens[1]);
		if schema = null then
			return;
		endif;
		
		constCategory := schema.getConstantCategory(_tokens[2]);
		if constCategory = null then
			return;
		endif;

		if self.currentCategoryName &lt;&gt; _tokens[2] then
			self.constantsInCategory.clear();
			constCategory.cnEcGetConstants().copy(self.constantsInCategory);
			self.currentCategoryName := _tokens[2];
		endif;
		
		foreach obj in self.constantsInCategory where obj.GlobalConstant.name = _tokens[4] do
			globalConstant := obj.GlobalConstant;
			break;
		endforeach;
		
		if globalConstant = null then
			return;
		endif;
		
	else
	
		globalConstant := _globalConstant;
		
	endif;
	
	
	changedBy := globalConstant.cnGetModifierName();
	changedTS := globalConstant.cnGetModifiedTimeStamp();
	constType := globalConstant.getType().name;
	constDefinition := globalConstant.getSource();
	constText := globalConstant.text;
	
	self.elementConstantC := self.elementGlobalCategoryC.addElement(globalConstant.name);
	self.elementC := self.elementConstantC.addElement(self.ChangedDateTag);
	self.elementC.setText(changedTS.date.format("dd/MM/yyyy"));
	self.elementC := self.elementConstantC.addElement(self.ChangedTimeTag);
	self.elementC.setText(changedTS.time.String);
	self.elementC := self.elementConstantC.addElement(self.ChangedByTag);
	self.elementC.setText(changedBy);
	self.elementC := self.elementConstantC.addElement(self.TypeTag);
	self.elementC.setText(constType);
	self.elementC := self.elementConstantC.addElement(self.DefinitionTag);
	self.elementC.setText(constDefinition);
	self.elementC := self.elementConstantC.addElement(self.TextTag);
	self.elementC.addCDATA(constText);
	
epilog

end;</source>
        <Parameter name="_globalConstant" type="GlobalConstant"/>
        <Parameter name="_tokens" type="StringArray512"/>
    </JadeMethod>
    <JadeMethod name="addMethodToFile" id="ad1108ac-f2c5-4367-a8e4-d1c3653b7a51">
        <updating/>
        <source>addMethodToFile(_method : Method; _tokens : StringArray512) updating;

/*

Purpose:		add the method to the file	

Date			Who		Reason
09/09/2016		cnwmh5	Initial creation

*/

vars

	schema					: Schema;
	klass					: Class;
	meth					: Method;
	
	source					: String;
	changedBy				: String;
	changedTS				: TimeStamp;

begin

	if _method = null then

		schema := rootSchema.getSchema(_tokens[1]);
		if schema = null then
			return;
		endif;
		
		klass := schema.getClass(_tokens[2]);
		if klass = null then
			return;
		endif;
		
		meth := klass.getMethod(_tokens[4]);
		if meth = null then
			return;
		endif;
	else
		meth := _method;
	endif;
	
	source := meth.getSource();
	changedBy := meth.cnGetModifierName();
	changedTS := meth.cnGetModifiedTimeStamp();
	
	self.elementMethodC := self.elementMethodsC.addElement(meth.name);
	self.elementC := self.elementMethodC.addElement(ChangedDateTag);
	self.elementC.setText(changedTS.date.format("dd/MM/yyyy"));
	self.elementC := self.elementMethodC.addElement(ChangedTimeTag);
	self.elementC.setText(changedTS.time.String);
	self.elementC := self.elementMethodC.addElement(self.ChangedByTag);
	self.elementC.setText(changedBy);
	self.elementC := self.elementMethodC.addElement(self.SourceTag);
	self.elementC.addCDATA(source);

	app.writeLog(self.schemaName &amp; Tab &amp; self.className &amp; Tab &amp; meth.name &amp; Tab &amp; 
		changedTS.date.format("dd/MM/yyyy") &amp; Tab &amp; changedTS.time.String &amp; Tab &amp; 
		changedBy.String, LogINFO);
	write self.schemaName &amp; Tab &amp; self.className &amp; Tab &amp; meth.name &amp; Tab &amp; 
		changedTS.date.format("dd/MM/yyyy") &amp; Tab &amp; changedTS.time.String &amp; Tab &amp; 
		changedBy.String;
	
epilog

end;</source>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_tokens" type="StringArray512"/>
    </JadeMethod>
    <JadeMethod name="addPropertyToFile" id="2b6eebf1-e554-44c7-8eba-aea7e4b5e653">
        <updating/>
        <source>addPropertyToFile(_prop : Property; _tokens : StringArray512) updating;

/*

Purpose:		Add prop to file	

Date			Who		Reason
12/09/2016		cnwmh5	Initial creation

*/

vars

	schema						: Schema;
	klass						: Class;
	prop						: Property;
		
	changedBy					: String;
	changedTS					: TimeStamp;		
	accessType					: String;
	length						: Integer;
	scaleFactor					: Integer;
	type						: String;
	isAttribute					: Boolean;
	precision					: Integer;

begin

	if _prop = null then
		schema := rootSchema.getSchema(_tokens[1]);
		if schema = null then
			return;
		endif;
		
		klass := schema.getClass(_tokens[2]);
		if klass = null then
			return;
		endif;
		
		prop := klass.getProperty(_tokens[4]);
		if prop = null then
			return;
		endif;
	else
		prop := _prop;
	endif;

	changedBy := prop.cnGetModifierName();
	changedTS := prop.cnGetModifiedTimeStamp();
	accessType := prop.cnEcGetAccessType();
	isAttribute := prop.cnEcIsAttribute();
	type := prop.getType().name;
	
	self.elementPropertyC := self.elementPropertiesC.addElement(prop.Property.name);
	self.elementC := self.elementPropertyC.addElement(self.ChangedDateTag);
	self.elementC.setText(changedTS.date.format("dd/MM/yyyy"));
	self.elementC := self.elementPropertyC.addElement(self.ChangedTimeTag);
	self.elementC.setText(changedTS.time.String);
	self.elementC := self.elementPropertyC.addElement(self.ChangedByTag);
	self.elementC.setText(changedBy);
	self.elementC := self.elementPropertyC.addElement(self.AccessTypeTag);
	self.elementC.setText(accessType);
	self.elementC := self.elementPropertyC.addElement(self.TypeTag);
	self.elementC.setText(type);
	self.elementC := self.elementPropertyC.addElement(self.IsAttributeTag);
	self.elementC.setText(isAttribute.String);
		
	if isAttribute then
		length := prop.getLength();
		if prop.type = Decimal then
			scaleFactor := prop.getPropertyValue('scaleFactor').Integer;
			precision := prop.getPropertyValue('precision').Integer;
		endif;	
		self.elementC := self.elementPropertyC.addElement(self.LengthTag);
		self.elementC.setText(length.String);
		self.elementC := self.elementPropertyC.addElement(self.ScaleFactorTag);
		self.elementC.setText(scaleFactor.String);
		self.elementC := self.elementPropertyC.addElement(self.PrecisionTag);
		self.elementC.setText(precision.String);	
	endif;
	
epilog

end;</source>
        <Parameter name="_prop" type="Property"/>
        <Parameter name="_tokens" type="StringArray512"/>
    </JadeMethod>
    <JadeMethod name="checkForUnusedVariables" id="c64462fc-3ad1-4ef1-9dcf-b537aef02bbb">
        <source>checkForUnusedVariables(_source : String; _unusedVariablesDiff : Boolean io; _unusedVariables : String io);

/*

Purpose:		check the source for unused variables

Date			Who		Reason
12/09/2016		cnwmh5	Initial creation

*/

constants

	TextVars				: String = "vars";
	TextBegin				: String = "begin";
	AfterCharactersToFailOn : String = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789('+*&amp;%/";

vars

	tokens					: StringArray512;
	attribs					: StringArray512;
	
	posVars					: Integer;
	posBegin				: Integer;
	varsDetails				: String;
	attrib					: String;
	index					: Integer;
	index1					: Integer;
	posAttrib				: Integer;
	posComma				: Integer;
	attrib1					: String;
	attribFoundInSource		: Boolean;
	attribLength			: Integer;
	attribBegin				: Integer;

begin

	posVars := 1;
	posVars := _source.pos(TextVars, posVars);
	
	// posVars = 0, don't need to go any further
	if posVars = 0 then
		return;
	endif;
	
	posVars := posVars + TextVars.length;
	
	posBegin := 1;
	posBegin := _source.pos(TextBegin, posBegin);

	varsDetails := _source[posVars : posBegin - posVars];
		
	posBegin := posBegin + TextBegin.length;
	
	create tokens transient;
	create attribs transient;
	tokens.cnGetTokens(varsDetails, ";", false);
	
	// get all the attributes so we can check if used	
	foreach index in 1 to tokens.size step 1 do
	
		index1 := 1;
		attrib := tokens[index].scanUntil(":", index1);
		
		posComma := 1;
		posComma := attrib.pos(",", posComma);
		
		// if no comma add to attribs
		if posComma = 0 then
			attribs.add(attrib);
			continue;
		endif;
		
		// comma found so need to loop through getting attributes
		while true do
			
			posComma := 1;
			attrib1 := attrib.scanUntil(",", posComma);
			attribs.add(attrib1);
			
			// , not found to time to leave
			if posComma = 0 then
				break;
			endif;
			
			attrib := attrib[posComma + 1:end];
		
		endwhile;
		
	endforeach;	
		
		
	foreach index in 1 to attribs.size step 1 do	
		
		attribFoundInSource := false;
		
		attrib := attribs[index];
		attribLength := attrib.length;
		posAttrib := _source.pos(attrib, posBegin);
		while posAttrib &gt; 0 do
			
			attribBegin := posAttrib - 1;
			posAttrib := posAttrib + attribLength;
			
			if not AfterCharactersToFailOn.cnContains(_source[posAttrib:1]) then
				attribFoundInSource := true;
			endif;
			
			// get the next position
			posAttrib := _source.pos(attrib, posAttrib);
		
		endwhile;
		
		// check to see if found
		if not attribFoundInSource then
			_unusedVariablesDiff := true;
			if _unusedVariables &lt;&gt; null then
				_unusedVariables := _unusedVariables &amp; ", ";
			endif;
			_unusedVariables := _unusedVariables &amp; attrib;	
		endif;
		
	endforeach;
	
epilog

	delete tokens;
	delete attribs;

end;</source>
        <Parameter name="_source" type="String"/>
        <Parameter name="_unusedVariablesDiff" type="Boolean" usage="io"/>
        <Parameter name="_unusedVariables" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="compareChangesClasses" id="ef538340-1c3f-4d8e-ba8e-465494e23d7b">
        <updating/>
        <source>compareChangesClasses() updating;

/*

Purpose:		Traverse XML tree and find what's missing	

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars

	iter						: Iterator;

begin

	self.elementClassesC := self.elementSchemaC.getElementByTagName(self.ClassesTag);
	self.elementClassesO := self.elementSchemaO.getElementByTagName(self.ClassesTag);
	
	iter := self.elementClassesC.childNodes.createIterator;
	while iter.next(self.elementClassC) do
	
		self.className := self.elementClassC.tagName;
		
		self.elementClassO := self.elementClassesO.getElementByTagName(self.className);
		if self.elementClassO &lt;&gt; null then
			self.compareChangesConstants();
			self.compareChangesProperties();
			self.compareChangesMethods();
		endif;
	
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="compareChangesConstants" id="d180466f-a1f7-4386-9899-26ec7111b07b">
        <updating/>
        <source>compareChangesConstants() updating;

/*

Purpose:		Traverse XML tree and find what's missing	

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars

	iter						: Iterator;
	iterConstants				: Iterator;
	
	tagName						: String;
	changedDateDiff				: Boolean;
	changedTimeDiff 			: Boolean;
	changedByDiff 				: Boolean;
	typeDiff					: Boolean;
	definitionDiff				: Boolean;
	textDiff					: Boolean;
	textC						: String;
	textO						: String;
	isString					: Boolean;

begin

	self.elementConstantsC := self.elementClassC.getElementByTagName(self.ConstantsTag);
	self.elementConstantsO := self.elementClassO.getElementByTagName(self.ConstantsTag);
	
	iter := self.elementConstantsC.childNodes.createIterator;
	while iter.next(self.elementConstantC) do
	
		self.constantName := self.elementConstantC.tagName;
		
		self.elementConstantO := self.elementConstantsO.getElementByTagName(self.constantName);
		if self.elementConstantO = null then
			if not self.doFullCompare then
				// put in dict if not already there
				if not self.missingItems.includesKey(self.schemaName, self.className, "CONSTANT", self.constantName) then
					self.missingItems.putAtKey(self.schemaName, self.className, "CONSTANT", self.constantName, self.dummyObject);
				endif;
			else
				app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.constantName &amp; "(Constant) is missing " &amp; self.direction, LogINFO);
				self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.constantName &amp; "(Constant) is missing " &amp; self.direction);
			endif;
			continue;
		endif;
	
		if not doFullCompare then
			continue;
		endif;
		
		changedDateDiff := null;
		changedTimeDiff := null;
		changedByDiff := null;
		typeDiff := null;
		definitionDiff := null;
		textDiff := null;
		isString := null;
			
		delete iterConstants;
		iterConstants := self.elementConstantC.childNodes.createIterator;
		while iterConstants.next(self.elementC) do
		
			tagName  := elementC.tagName;
			elementO := elementConstantO.getElementByTagName(tagName);
			
			if tagName = self.ChangedDateTag then
				changedDateDiff := elementC.text &lt;&gt; elementO.text;
			elseif tagName = self.ChangedTimeTag then
				changedTimeDiff := elementC.text &lt;&gt; elementO.text;
			elseif tagName = self.ChangedByTag then
				changedByDiff := elementC.text &lt;&gt; elementO.text;
			elseif tagName = self.TypeTag then
				typeDiff := elementC.text &lt;&gt; elementO.text;
				if typeDiff then
					app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.constantName &amp; " constant type is different " &amp; self.direction, LogINFO);
					self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.constantName &amp; " constant type is different " &amp; self.direction);
				endif;
				if elementC.text.toUpper() = "STRING" then
					isString := true;
				endif;
			elseif tagName = self.DefinitionTag then
				
				// remove quotes from string if 1st character
				textC := elementC.text;
				textO := elementO.text;
				if isString then
					textC := textC.removeString("'");
					textO := textO.removeString("'");
					textC := textC.removeString('"');
					textO := textO.removeString('"');
				endif;
				
				definitionDiff := textC &lt;&gt; textO;
				if definitionDiff then
					app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.constantName &amp; " constant definition is different " &amp; self.direction, LogINFO);
					self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.constantName &amp; " constant definition is different " &amp; self.direction);
				endif;
			elseif tagName = self.TextTag then
				self.elementCDATAC := elementC.childNodes.first.JadeXMLCDATA;	
				textC := self.elementCDATAC.data;
				textC := self.removeCommentsFromSource(textC);
				textC := textC.removeTabCrLfs();
				textC := textC.removeString(" ");
				
				self.elementCDATAO := elementO.childNodes.first.JadeXMLCDATA;
				textO := self.elementCDATAO.data;
				textO := self.removeCommentsFromSource(textO);
				textO := textO.removeTabCrLfs();
				textO := textO.removeString(" ");
				
				textDiff := textC.Binary &lt;&gt; textO.Binary;		
				
				if textDiff then
					app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.constantName &amp; " constant text is different " &amp; self.direction, LogINFO);
					self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.constantName &amp; " constant text is different " &amp; self.direction);
				endif;
			
			endif;
				
		endwhile;
		
		app.writeLog('changeDateDiff: ' &amp; changedDateDiff.String &amp; Tab &amp; 'changedTimeDiff: ' &amp; changedTimeDiff.String &amp; Tab &amp; 
			'changedByDiff: ' &amp; changedByDiff.String &amp; Tab &amp; 'typeDiff: ' &amp; typeDiff.String &amp; Tab &amp; 
			'definitionDiff: ' &amp; definitionDiff.String &amp; Tab &amp; 'textDiff: ' &amp; textDiff.String, LogINFO);
		write 'changeDateDiff: ' &amp; changedDateDiff.String &amp; Tab &amp; 'changedTimeDiff: ' &amp; changedTimeDiff.String &amp; Tab &amp; 
			'changedByDiff: ' &amp; changedByDiff.String &amp; Tab &amp; 'typeDiff: ' &amp; typeDiff.String &amp; Tab &amp; 
			'definitionDiff: ' &amp; definitionDiff.String &amp; Tab &amp; 'textDiff: ' &amp; textDiff.String;
		
	endwhile;
	
epilog

	delete iter;
	delete iterConstants;

end;</source>
    </JadeMethod>
    <JadeMethod name="compareChangesGlobalConstants" id="9522420b-6d68-40b1-bfea-95802b75d563">
        <updating/>
        <source>compareChangesGlobalConstants() updating;

/*

Purpose:		Traverse XML tree and find what's missing	

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars

	iterCategory				: Iterator;
	iterConstants				: Iterator;
	iterConstantField			: Iterator;
	
	tagName						: String;
	changedDateDiff				: Boolean;
	changedTimeDiff 			: Boolean;
	changedByDiff 				: Boolean;
	typeDiff					: Boolean;
	definitionDiff				: Boolean;
	textDiff					: Boolean;
	textC						: String;
	textO						: String;
	isString					: Boolean;

begin

	self.elementGlobalCategoryC := self.documentC.getElementByTagName(self.GlobalsTag);
	self.elementGlobalCategoryO := self.documentO.getElementByTagName(self.GlobalsTag);
	
	iterCategory := self.elementGlobalCategoryC.childNodes.createIterator;
	while iterCategory.next(self.elementConstantsC) do
	
		self.categoryName := self.elementConstantsC.tagName;
		self.schemaName := self.elementConstantsC.getAttributeByName("Schema").value;
			
		self.elementConstantsO := self.elementGlobalCategoryO.getElementByTagName(self.categoryName);
			
		if self.elementConstantsO = null then
			if not self.doFullCompare then
			// put in dict if not already there
				if not self.missingItems.includesKey(self.schemaName, "", "CATEGORY", self.categoryName) then
					self.missingItems.putAtKey(self.schemaName, "", "CATEGORY", self.categoryName, self.dummyObject);
				endif;
			else
				app.writeLog(self.schemaName &amp; "::" &amp; self.categoryName &amp; "(Global Category) is missing " &amp; self.direction, LogINFO);
				self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.categoryName &amp; "(Global Category) is missing " &amp; self.direction);
			endif;
			continue;
		endif;
		
		iterConstants := self.elementConstantsC.childNodes.createIterator;
		while iterConstants.next(self.elementConstantC) do
		
			self.constantName := self.elementConstantC.tagName;
			
			self.elementConstantO := self.elementConstantsO.getElementByTagName(self.constantName);
			
			if self.elementConstantO = null then
				if not self.doFullCompare then
					// put in dict if not already there
					if not self.missingItems.includesKey(self.schemaName, self.categoryName, "GLOBAL", self.constantName) then
						self.missingItems.putAtKey(self.schemaName, self.categoryName, "GLOBAL", self.constantName, self.dummyObject);
					endif;
				else
					app.writeLog(self.schemaName &amp; "::" &amp; self.categoryName &amp; "::" &amp; self.constantName &amp; " (Global Constant) is missing " &amp; self.direction, LogINFO);
					self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.categoryName &amp; "::" &amp; self.constantName &amp; " (Global Constant) is missing " &amp; self.direction);
				endif;
				continue;
			endif;
		
			if not doFullCompare then
				continue;
			endif;
			
			changedDateDiff := null;
			changedTimeDiff := null;
			changedByDiff := null;
			typeDiff := null;
			definitionDiff := null;
			textDiff := null;
			isString := null;
				
			delete iterConstants;
			iterConstants := self.elementConstantC.childNodes.createIterator;
			while iterConstants.next(self.elementC) do
			
				tagName  := elementC.tagName;
				elementO := elementConstantO.getElementByTagName(tagName);
				
				if tagName = self.ChangedDateTag then
					changedDateDiff := elementC.text &lt;&gt; elementO.text;
				elseif tagName = self.ChangedTimeTag then
					changedTimeDiff := elementC.text &lt;&gt; elementO.text;
				elseif tagName = self.ChangedByTag then
					changedByDiff := elementC.text &lt;&gt; elementO.text;
				elseif tagName = self.TypeTag then
					typeDiff := elementC.text &lt;&gt; elementO.text;
					if typeDiff then
						app.writeLog(self.schemaName &amp; "::" &amp; self.categoryName &amp; "::" &amp; self.constantName &amp; " global constant type is different " &amp; self.direction, LogINFO);
						self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.categoryName &amp; "::" &amp; self.constantName &amp; " global constant type is different " &amp; self.direction);
					endif;
					if elementC.text.toUpper() = "STRING" then
						isString := true;
					endif;
				elseif tagName = self.DefinitionTag then
					
					// remove quotes from string if 1st character
					textC := elementC.text;
					textO := elementO.text;
					if isString then
						textC := textC.removeString("'");
						textO := textO.removeString("'");
						textC := textC.removeString('"');
						textO := textO.removeString('"');
					endif;
					
					definitionDiff := textC &lt;&gt; textO;
					if definitionDiff then
						app.writeLog(self.schemaName &amp; "::" &amp; self.categoryName &amp; "::" &amp; self.constantName &amp; " global constant definition is different " &amp; self.direction, LogINFO);
						self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.categoryName &amp; "::" &amp; self.constantName &amp; " global constant definition is different " &amp; self.direction);
					endif;
				elseif tagName = self.TextTag then
					self.elementCDATAC := elementC.childNodes.first.JadeXMLCDATA;	
					textC := self.elementCDATAC.data;
					textC := self.removeCommentsFromSource(textC);
					textC := textC.removeTabCrLfs();
					textC := textC.removeString(" ");
					
					self.elementCDATAO := elementO.childNodes.first.JadeXMLCDATA;
					textO := self.elementCDATAO.data;
					textO := self.removeCommentsFromSource(textO);
					textO := textO.removeTabCrLfs();
					textO := textO.removeString(" ");
					
					textDiff := textC.Binary &lt;&gt; textO.Binary;		
					
					if textDiff then
						app.writeLog(self.schemaName &amp; "::" &amp; self.categoryName &amp; "::" &amp; self.constantName &amp; " global constant text is different " &amp; self.direction, LogINFO);
						self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.categoryName &amp; "::" &amp; self.constantName &amp; " global constant text is different " &amp; self.direction);
					endif;
				
				endif;
					
			endwhile;
			
			app.writeLog('changeDateDiff: ' &amp; changedDateDiff.String &amp; Tab &amp; 'changedTimeDiff: ' &amp; changedTimeDiff.String &amp; Tab &amp; 
				'changedByDiff: ' &amp; changedByDiff.String &amp; Tab &amp; 'typeDiff: ' &amp; typeDiff.String &amp; Tab &amp; 
				'definitionDiff: ' &amp; definitionDiff.String &amp; Tab &amp; 'textDiff: ' &amp; textDiff.String, LogINFO);
			write 'changeDateDiff: ' &amp; changedDateDiff.String &amp; Tab &amp; 'changedTimeDiff: ' &amp; changedTimeDiff.String &amp; Tab &amp; 
				'changedByDiff: ' &amp; changedByDiff.String &amp; Tab &amp; 'typeDiff: ' &amp; typeDiff.String &amp; Tab &amp; 
				'definitionDiff: ' &amp; definitionDiff.String &amp; Tab &amp; 'textDiff: ' &amp; textDiff.String;
				
		endwhile;
			
	endwhile;
	
epilog

	delete iterCategory;
	delete iterConstants;
	delete iterConstantField;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="compareChangesMethods" id="471c3045-f683-40f9-9f18-64d349cdbf1a">
        <updating/>
        <source>compareChangesMethods() updating;

/*

Purpose:		Traverse XML tree and find what's missing	

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars

	iter						: Iterator;
	iterMethod					: Iterator;
		
	tagName						: String;
	changedDateDiff				: Boolean;
	changedTimeDiff				: Boolean;
	changedByDiff				: Boolean;
	sourceDiff					: Boolean;
	sourceC						: String;
	sourceO						: String;
	unusedVariablesDiff			: Boolean;
	unusedVariables				: String;

begin

	self.elementMethodsC := self.elementClassC.getElementByTagName(self.MethodsTag);
	self.elementMethodsO := self.elementClassO.getElementByTagName(self.MethodsTag);
	
	iter := self.elementMethodsC.childNodes.createIterator;
	while iter.next(self.elementMethodC) do
	
		self.methodName := self.elementMethodC.tagName;
		
		self.elementMethodO := self.elementMethodsO.getElementByTagName(self.methodName);
		if self.elementMethodO = null then
			if not self.doFullCompare then
				// put in dict if not already there
				if not self.missingItems.includesKey(self.schemaName, self.className, "METHOD", self.methodName) then
					self.missingItems.putAtKey(self.schemaName, self.className, "METHOD", self.methodName, self.dummyObject);
				endif;
			else
				app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.methodName &amp; "(Method) is missing " &amp; self.direction, LogINFO);
				self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.methodName &amp; "(Method) is missing " &amp; self.direction);
			endif;
			continue;
		endif;
		
		if not doFullCompare then
			continue;
		endif;
		
		// do the compare
		changedDateDiff	:= null;
		changedTimeDiff := null;
		changedByDiff := null;
		sourceDiff := null;
		unusedVariables := null;
		unusedVariablesDiff := null;
		
		delete iterMethod;
		iterMethod := self.elementMethodC.childNodes.createIterator;
		while iterMethod.next(self.elementC) do
		
			tagName  := elementC.tagName;
			elementO := elementMethodO.getElementByTagName(tagName);
			
			if tagName = self.ChangedDateTag then
				changedDateDiff := elementC.text &lt;&gt; elementO.text;
			elseif tagName = self.ChangedTimeTag then
				changedTimeDiff := elementC.text &lt;&gt; elementO.text;
			elseif tagName = self.ChangedByTag then
				changedByDiff := elementC.text &lt;&gt; elementO.text;
			elseif tagName = self.SourceTag then
				self.elementCDATAC := elementC.childNodes.first.JadeXMLCDATA;	
				sourceC := self.elementCDATAC.data;
				sourceC := self.removeCommentsFromSource(sourceC);
				sourceC := sourceC.removeTabCrLfs();
				sourceC := sourceC.removeString(" ");
				
				self.elementCDATAO := elementO.childNodes.first.JadeXMLCDATA;
				sourceO := self.elementCDATAO.data;
				sourceO := self.removeCommentsFromSource(sourceO);
				sourceO := sourceO.removeTabCrLfs();
				sourceO := sourceO.removeString(" ");
				
				sourceDiff := sourceC.Binary &lt;&gt; sourceO.Binary;	
				
				// check for unused variables
				if self.doCheckForUnusedVars then
					self.checkForUnusedVariables(sourceC, unusedVariablesDiff, unusedVariables);
				endif;
				
			endif;
				
		endwhile;
		
		app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.methodName  &amp; Tab &amp; 'changeDateDiff: ' &amp; changedDateDiff.String &amp; Tab &amp; 'changedTimeDiff: ' &amp; changedTimeDiff.String &amp; Tab &amp; 
			'changedByDiff: ' &amp; changedByDiff.String &amp; Tab &amp; 'sourceDiff: ' &amp; sourceDiff.String &amp; Tab &amp; 
			'unusedVariableDiff: ' &amp; unusedVariablesDiff.String &amp; Tab &amp; unusedVariables, LogINFO);
		write self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.methodName  &amp; Tab &amp; 'changeDateDiff: ' &amp; changedDateDiff.String &amp; Tab &amp; 'changedTimeDiff: ' &amp; changedTimeDiff.String &amp; Tab &amp; 
			'changedByDiff: ' &amp; changedByDiff.String &amp; Tab &amp; 'sourceDiff: ' &amp; sourceDiff.String &amp; Tab &amp; 
			'unusedVariableDiff: ' &amp; unusedVariablesDiff.String &amp; Tab &amp; unusedVariables;
		
		if sourceDiff then
			app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.methodName &amp; " source is different " &amp; self.direction, LogINFO);
			self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.methodName &amp; " source is different " &amp; self.direction);
		endif;
		
		if unusedVariablesDiff then
			app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.methodName &amp; " unused variables " &amp; self.direction, LogINFO);
			self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.methodName &amp; " unused variables " &amp; self.direction);
		endif;
	
	endwhile;
	
epilog

	delete iter;
	delete iterMethod;

end;</source>
    </JadeMethod>
    <JadeMethod name="compareChangesProperties" id="3f7d3c23-b0f9-4c87-bf43-e14a8c3d2fe5">
        <updating/>
        <source>compareChangesProperties() updating;

/*

Purpose:		Traverse XML tree and find what's missing	

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars

	iter						: Iterator;
	iterProperties				: Iterator;
	
	tagName						: String;
	changedDateDiff				: Boolean;
	changedTimeDiff				: Boolean;
	changedByDiff				: Boolean;
	accessTypeDiff				: Boolean;
	typeDiff					: Boolean;
	isAttributeDiff				: Boolean;
	lengthDiff					: Boolean;
	scaleFactorDiff				: Boolean;
	precisionDiff				: Boolean;

begin

	self.elementPropertiesC := self.elementClassC.getElementByTagName(self.PropertiesTag);
	self.elementPropertiesO := self.elementClassO.getElementByTagName(self.PropertiesTag);
	
	iter := self.elementPropertiesC.childNodes.createIterator;
	while iter.next(self.elementPropertyC) do
	
		self.propertyName := self.elementPropertyC.tagName;
		
		self.elementPropertyO := self.elementPropertiesO.getElementByTagName(self.propertyName);
		if self.elementPropertyO = null then
			if not self.doFullCompare then
				// put in dict if not already there
				if not self.missingItems.includesKey(self.schemaName, self.className, "PROPERTY", self.propertyName) then
					self.missingItems.putAtKey(self.schemaName, self.className, "PROPERTY", self.propertyName, self.dummyObject);
				endif;
			else
				app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; "(Property) is missing " &amp; self.direction, LogINFO);
				self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; "(Property) is missing " &amp; self.direction);
			endif;
			continue;
		endif;
		
		if not doFullCompare then
			continue;
		endif;
		
		changedDateDiff	:= null;
		changedTimeDiff := null;
		changedByDiff := null;
		accessTypeDiff := null;
		typeDiff := null;
		isAttributeDiff := null;
		lengthDiff := null;
		scaleFactorDiff := null;
		precisionDiff := null;
			
		delete iterProperties;
		iterProperties := self.elementPropertyC.childNodes.createIterator;
		while iterProperties.next(self.elementC) do
		
			tagName := elementC.tagName;
			elementO := elementPropertyO.getElementByTagName(tagName);
				
			if tagName = self.ChangedDateTag then
				changedDateDiff := elementC.text &lt;&gt; elementO.text;
			elseif tagName = self.ChangedTimeTag then
				changedTimeDiff := elementC.text &lt;&gt; elementO.text;
			elseif tagName = self.ChangedByTag then
				changedByDiff := elementC.text &lt;&gt; elementO.text;		
			elseif tagName = self.AccessTypeTag then
				accessTypeDiff := elementC.text &lt;&gt; elementO.text;	
				if accessTypeDiff then
					app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; " property Access Type is different " &amp; self.direction, LogINFO);
					self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; " property Access Type definition is different " &amp; self.direction);
				endif;
			elseif tagName = self.IsAttributeTag then
				isAttributeDiff := elementC.text &lt;&gt; elementO.text;		
				if isAttributeDiff then
					app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; " property isAttribute is different " &amp; self.direction, LogINFO);
					self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; " property isAttribute definition is different " &amp; self.direction);
				endif;
			elseif tagName = self.LengthTag then
				lengthDiff := elementC.text &lt;&gt; elementO.text;		
				if lengthDiff then
					app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; " property length is different " &amp; self.direction, LogINFO);
					self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; " property length definition is different " &amp; self.direction);
				endif;
			elseif tagName = self.ScaleFactorTag then
				scaleFactorDiff := elementC.text &lt;&gt; elementO.text;		
				if scaleFactorDiff then
					app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; " property scale factor is different " &amp; self.direction, LogINFO);
					self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; " property scale factor definition is different " &amp; self.direction);
				endif;
			elseif tagName = self.PrecisionTag then
				precisionDiff := elementC.text &lt;&gt; elementO.text;
				if precisionDiff then
					app.writeLog(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; " property precision is different " &amp; self.direction, LogINFO);
					self.outputFile.writeLine(self.schemaName &amp; "::" &amp; self.className &amp; "::" &amp; self.propertyName &amp; " property precision definition is different " &amp; self.direction);
				endif;
			endif;
			
		endwhile;
		
		app.writeLog('changeDateDiff: ' &amp; changedDateDiff.String &amp; Tab &amp; 'changedTimeDiff: ' &amp; changedTimeDiff.String &amp; Tab &amp; 
			'changedByDiff: ' &amp; changedByDiff.String &amp; Tab &amp; 'accessTypeDiff: ' &amp; accessTypeDiff.String &amp; Tab &amp; 
			'isAttributeDiff: ' &amp; isAttributeDiff.String &amp; Tab &amp; 'lengthDiff: ' &amp; lengthDiff.String &amp; Tab &amp; 
			'scaleFactorDiff: ' &amp; scaleFactorDiff.String &amp; Tab &amp; 'precisionDiff: ' &amp; precisionDiff.String, LogINFO);
		write 'changeDateDiff: ' &amp; changedDateDiff.String &amp; Tab &amp; 'changedTimeDiff: ' &amp; changedTimeDiff.String &amp; Tab &amp; 
			'changedByDiff: ' &amp; changedByDiff.String &amp; Tab &amp; 'accessTypeDiff: ' &amp; accessTypeDiff.String &amp; Tab &amp; 
			'isAttributeDiff: ' &amp; isAttributeDiff.String &amp; Tab &amp; 'lengthDiff: ' &amp; lengthDiff.String &amp; Tab &amp; 
			'scaleFactorDiff: ' &amp; scaleFactorDiff.String &amp; Tab &amp; 'precisionDiff: ' &amp; precisionDiff.String;
		
	endwhile;
	
epilog

	delete iter;
	delete iterProperties;

end;</source>
    </JadeMethod>
    <JadeMethod name="compareChangesSchemas" id="8a0cfa81-adb9-43ff-b74a-2523c74ecb37">
        <updating/>
        <source>compareChangesSchemas() updating;

/*

Purpose:		Traverse XML tree and find what's missing	

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars

	iter						: Iterator;

begin

	self.elementSchemasC := self.documentC.getElementByTagName(self.SchemasTag);
	self.elementSchemasO := self.documentO.getElementByTagName(self.SchemasTag);
	
	iter := self.elementSchemasC.childNodes.createIterator;
	while iter.next(self.elementSchemaC) do
	
		self.schemaName := self.elementSchemaC.tagName;
		
		self.elementSchemaO := self.elementSchemasO.getElementByTagName(self.schemaName);
		if self.elementSchemaO &lt;&gt; null then
			self.compareChangesClasses();
		endif;
	
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="30699800-9380-42d1-8a06-1e86ff698739">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars
	
	paramNames					: StringArray;
	paramValues					: StringArray;
	
	pos							: Integer;
	commandLine					: String;
	index						: Integer;
	param						: String;
	tempSystemName				: String;
	
begin

	doFullCompare := false;
	doCheckForUnusedVars := false;
	doReleaseSchemasOnly := true;

	// get the system name
	tempSystemName := app.myRoot.getConfig(SystemTitle).String.toUpper();
	pos := 1;
	pos := tempSystemName.reversePos("MAST");
	self.systemName := tempSystemName[pos-1:5];
	
	// fileName
	self.fileName := self.systemName &amp; "SourceChanges.xml";
	
	// set up the required values
	// check to see if there is anything on the command line
	create paramNames transient;
	create paramValues transient;
	commandLine := app.getThinClientCommandLine();
	app.parseCommandLine(commandLine, paramNames, paramValues);
	if paramNames.size = 0 then
		self.fromTS.setDate("30/07/2015".Date);
		self.fromTS.setTime("00:00:00".Time);
		self.directoryName := "C:\temp\CheckSource";
	else
		foreach index in 1 to paramNames.size do
			param := paramNames[index].toUpper;
			if param = "DATE" then
				self.fromTS.setDate(paramValues[index].Date);
			elseif param = "TIME" then
				self.fromTS.setTime(paramValues[index].Time);
			elseif param = "DIRECTORY" then
				self.directoryName := paramValues[index].String;
			elseif param = "DONTCALL" then
				self.dontCall := paramValues[index].Boolean;
			endif;
		endforeach;
	endif;
	
	//create self.missingItems transient;
	self.missingItems.setMembership(Object);
	self.missingItems.addExternalKey(String, 64, false, false);						// Schema Name
	self.missingItems.addExternalKey(String, 64, false, false);						// Class Name
	self.missingItems.addExternalKey(String, 64, false, false);						// Object Type
	self.missingItems.addExternalKey(String, 64, false, false);						// Object Name
	self.missingItems.endKeys(false);
	
	//create self.globalConstsWithDiff transient;
	self.diffGlobalConsts.setMembership(Object);
	self.diffGlobalConsts.addExternalKey(String, 64, false, false);				// Schema Name
	self.diffGlobalConsts.addExternalKey(String, 64, false, false);				// Category Name
	self.diffGlobalConsts.addExternalKey(String, 64, false, false);				// Constant Name
	self.diffGlobalConsts.endKeys(false);
	
	// Get the changed class details
	diffClassMeth.setMembership(Object);
	diffClassMeth.addExternalKey(String, 64, false, false);						// Schema Name
	diffClassMeth.addExternalKey(String, 64, false, false);						// Class Name
	diffClassMeth.addExternalKey(String, 64, false, false);						// Method / Constant / Primative Name
	diffClassMeth.endKeys(false);
	
	// initialise the documents
	create self.documentC transient;
	create self.documentO transient;
	
	create self.dummyObject transient;
	
	if self.systemName = "SMAST" then
		self.direction := "&lt;---------";
	else
		self.direction := "--------&gt;";
	endif;

	app.writeLog(method.qualifiedName() &amp; Tab &amp; "Date: " &amp; self.fromTS.date.format("dd/MM/yyyy") &amp; CrLf &amp; 
		"Time: " &amp; self.fromTS.time.String &amp; CrLf &amp; 
		"Directory: " &amp; self.directoryName &amp; CrLf &amp;
		"dontCall: " &amp; self.dontCall.String &amp; CrLf &amp;
		"systemName: " &amp; self.systemName &amp; CrLf &amp;
		"direction: " &amp; self.direction, LogINFO);
	write method.qualifiedName() &amp; Tab &amp; "Date: " &amp; self.fromTS.date.format("dd/MM/yyyy") &amp; CrLf &amp; 
		"Time: " &amp; self.fromTS.time.String &amp; CrLf &amp; 
		"Directory: " &amp; self.directoryName &amp; CrLf &amp;
		"dontCall: " &amp; self.dontCall.String &amp; CrLf &amp;
		"systemName: " &amp; self.systemName &amp; CrLf &amp;
		"direction: " &amp; self.direction;
		
	create self.outputFile transient;
	self.outputFile.fileName := self.directoryName &amp; "\SystemDifferences.txt"; 
	if self.outputFile.isAvailable() then
		///self.outputFile.purge();
	endif;
	
epilog

	delete paramNames;
	delete paramValues;

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="3b2d8e75-d5c7-41f6-808b-d8612efc8db9">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Date			Who		Reason
08 September 2016	cnwmh5	Initial creation

*/

vars

begin

	delete self.documentC;
	delete self.documentO;

	delete dummyObject;
	
	if self.outputFile &lt;&gt; null then
		delete self.outputFile;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="externalProcessSetupSMAST" id="958d6e06-a14d-432d-9824-8c5d89b5392e">
        <source>externalProcessSetupSMAST(_appName : String; _binDirectory, _command : String io; _args : StringArray io);

/*

Purpose:		Details for calling external process for dmast	

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars

begin

	_args.clear();
	_args.add('appServer=jade1.cnwsmast.cnw.co.nz');                                
	_args.add('appServerPort=51066');							
	_args.add('ini="C:\DevelopmentEnvs\cnwsmast\cnwsmast.ini"');				
	_args.add('app=' &amp; _appName);						
	_args.add('schema=JMTUnitTest');									
	_args.add('endJade');											
	_args.add("DATE=" &amp; self.fromTS.date.format("dd/MM/yyyy"));			
	_args.add("TIME=" &amp; self.fromTS.time.String);							
	_args.add("DIRECTORY=" &amp; self.directoryName);							
	_args.add("DONTCALL=TRUE");	
	
	_binDirectory := "C:\DevelopmentEnvs\cnwsmast\c_bin";				
	_command := _binDirectory &amp; "\jade.exe";			
		

epilog

end;</source>
        <Parameter name="_appName" type="String"/>
        <Parameter name="_binDirectory" type="String" usage="io"/>
        <Parameter name="_command" type="String" usage="io"/>
        <Parameter name="_args" type="StringArray" usage="io"/>
    </JadeMethod>
