    <JadeMethod name="valCamProtocol" id="8168e69f-5b70-412c-94ca-f0b3e0ed1059">
        <source>valCamProtocol(pExistingCamProtocol,pProxyCamProtocol : CM_CamProtocol);
// ---------------------------------------------------------------------------
// Created:     04 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNull(pProxyCamProtocol, 'CamProtocol Proxy');
	self.raiseExceptionIfNull(pExistingCamProtocol, "CamProtocol Existing");
	pProxyCamProtocol.raiseExceptionIfNotProxy(method);
	if pExistingCamProtocol.code = pProxyCamProtocol.code then
		pProxyCamProtocol.validateForUpdate;
		if pExistingCamProtocol.isUserDefinedReport &lt;&gt; pProxyCamProtocol.isUserDefinedReport or
		   pExistingCamProtocol.isUserDefinedEventReport &lt;&gt; pProxyCamProtocol.isUserDefinedEventReport then	// PAR 21905 CCMS MES 1008 - PHB
			app.raiseCMException(Cannot_change_protoco_descrip, null, null);
		endif;
	else
		pProxyCamProtocol.validateForCreate;
	endif;

epilog
	
end;</source>
        <Parameter name="pExistingCamProtocol" type="CM_CamProtocol"/>
        <Parameter name="pProxyCamProtocol" type="CM_CamProtocol"/>
    </JadeMethod>
