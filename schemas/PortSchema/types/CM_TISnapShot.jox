    <JadeMethod name="pxyCreateUpdateProxy" id="0df99e96-6d60-457f-848a-1fad5807c4c3">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars
	proxyme : SelfType;
	realhaz, proxyhaz : CM_HazardSnapShot;
	snapshot : CM_SnapShot;
begin
	proxyme := inheritMethod();

	foreach snapshot in self.allHazSnapShots	discreteLock do
		 realhaz := snapshot.CM_HazardSnapShot;
		proxyhaz := app.createUpdateProxy(realhaz).CM_HazardSnapShot;
		
		proxyhaz.setMyTISnapShot( proxyme);
	endforeach;
	
	
	return proxyme;


end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresPower" id="6366dc1d-ef15-4566-b9ca-a600d1d490f6">
        <methodInvocation>mapping</methodInvocation>
        <source>requiresPower(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	comm : CM_Commodity;
begin

	_value := false;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	if self.cargoType &lt;&gt; TI_CargoType_Container then
		return;
	endif;
	
	comm := app.myRoot.allCommodities[self.commodity];
	if comm = null then
		return;
	endif;
	
	_value := comm.requiresPower;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="requiresTemperature" id="b733decf-423f-4f74-a5c9-7083fee5fbae">
        <methodInvocation>mapping</methodInvocation>
        <source>requiresTemperature(_set: Boolean; _value: Boolean io) mapping;

vars
	comm : CM_Commodity;
begin

	_value := false;
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	if self.cargoType &lt;&gt; TI_CargoType_Container then
		return;
	endif;

	//------------
	// Check to see if we are empty - in which case we don't need power...
	//------------
	if self.contentsStatus = TI_CONTENTS_STATUS_EMPTY or self.contentsStatus = TI_CONTENTS_STATUS_NULL  then
		return;
	endif;
	//------------
	// Now determine if the commodity requires refridgeration...
	//------------
	comm := app.myRoot.allCommodities[self.commodity];
	if comm = null then
		return;
	endif;
	_value := comm.hasTemp;


end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d5083fa3-4cd4-4857-ab8a-ba51b6e96a34">
        <updating/>
        <source>setForUpdate(_pxySnapShot: CM_UserTISnapShot; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	15 May 2006	by Jason Chapman  (cnwjc2)
//	13 May 2022	navgm20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
//	14 Sep 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
//----------------------------------------------------------------
vars
		realhaz, proxyhaz : CM_HazardSnapShot;
	snapshot : CM_SnapShot;
begin
	self.cargoType			:= _pxySnapShot.cargoType;
	self.commodity			:= _pxySnapShot.commodity;
	self.contentsStatus		:= _pxySnapShot.contentsStatus;
	self.dischargePort		:= _pxySnapShot.dischargePort;
	if _pxySnapShot.id &lt;&gt; null then				//cnwas3 par 21935
		self.id					:= _pxySnapShot.id;
	endif;
	self.imExStatus			:= _pxySnapShot.imExStatus;
	self.is40				:= _pxySnapShot.is40;
	self.isTransship		:= _pxySnapShot.isTransship;	
	self.loadPort			:= _pxySnapShot.loadPort;
	self.operatorCode		:= _pxySnapShot.operatorCode;
	self.transitStatus		:= _pxySnapShot.transitStatus;
	self.typeAttributes		:= _pxySnapShot.typeAttributes;

	// TFS 40336
	self.isoType := _pxySnapShot.isoType;
	self.billOfLading	:= _pxySnapShot.billOfLading;
	self.cargoGroupId	:= _pxySnapShot.cargoGroupId;
	self.cargoSubtypeCode	:= _pxySnapShot.cargoSubtypeCode;
	self.cargoSubtypeDescription	:= _pxySnapShot.cargoSubtypeDescription;
	self.cargoTypeCode	:= _pxySnapShot.cargoTypeCode;
	self.cargoTypeDescription	:= _pxySnapShot.cargoTypeDescription;
	self.colour	:= _pxySnapShot.colour;
	self.customsAgentCode 	:= _pxySnapShot.customsAgentCode ;
	self.description	:= _pxySnapShot.description;
	self.destinationPortCode	:= _pxySnapShot.destinationPortCode;
	self.destinationPortDescription	:= _pxySnapShot.destinationPortDescription;
	self.dischargePortDescription	:= _pxySnapShot.dischargePortDescription;
	self.hazard 	:= _pxySnapShot.hazard ;
	self.isotypeDescription	:= _pxySnapShot.isotypeDescription;
	self.loadPortDescription	:= _pxySnapShot.loadPortDescription;
	self.markNumber	:= _pxySnapShot.markNumber;
	self.mark	:= _pxySnapShot.mark;
	self.orderNumber	:= _pxySnapShot.orderNumber;
	self.remarks	:= _pxySnapShot.remarks;
	self.totalQuantity	:= _pxySnapShot.totalQuantity;
	self.totalWeight	:= _pxySnapShot.totalWeight;
	self.totalVolume	:= _pxySnapShot.totalVolume;
	self.voyageCode	:= _pxySnapShot.voyageCode;	
	self.temperature := _pxySnapShot.temperature;
	self.consignee := _pxySnapShot.consignee;
	self.consignor := _pxySnapShot.consignor;
	self.shippingLineCode  := _pxySnapShot.shippingLineCode;	//13 may 2022	navgm20 tfs 53195
	self.myCountryOfOrigin := _pxySnapShot.myCountryOfOrigin; 	//14.09.2022 navtnr20 54441
	

	// TFS 40336 - HAZARDS UPDATE ONLY NO ADD OR DELETE
	if self.allHazSnapShots.isEmpty() 
	and _pxySnapShot.allHazSnapShots.isNotEmpty() then
		foreach snapshot in _pxySnapShot.allHazSnapShots	discreteLock do
			 proxyhaz := snapshot.CM_HazardSnapShot;
			 create realhaz;
			 realhaz.setForUpdate(proxyhaz);
			 realhaz.setMyTISnapShot(self);
		endforeach;
	
	else
		foreach snapshot in _pxySnapShot.allHazSnapShots	discreteLock do
			 proxyhaz := snapshot.CM_HazardSnapShot;
			 
			 realhaz := proxyhaz.pxyGetRealObject();
			 if realhaz &lt;&gt; null then
				realhaz.setForUpdate(proxyhaz);
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_pxySnapShot" type="CM_UserTISnapShot"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setFromProxyLtd" id="842169ba-4743-4f40-a928-553307c38b43">
        <updating/>
        <source>setFromProxyLtd(_pxySnapShot: CM_TISnapShot) updating;
//----------------------------------------------------------------
//	Created:	12 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//set the attributes used to classify this snap shot in the CandH Summary
	self.imExStatus		:= _pxySnapShot.imExStatus;
	self.transitStatus	:= _pxySnapShot.transitStatus;
	self.cargoType		:= _pxySnapShot.cargoType;
	self.contentsStatus := _pxySnapShot.contentsStatus;
	self.is40			:= _pxySnapShot.is40;
	self.sizeAttributes := _pxySnapShot.sizeAttributes;
	self.typeAttributes := _pxySnapShot.typeAttributes;
	self.isTransship 	:= _pxySnapShot.isTransship;
	self.commodity		:= _pxySnapShot.commodity;
	self.operatorCode	:= _pxySnapShot.operatorCode;

	self.setVoyage(_pxySnapShot.myVoyage);
	
end;</source>
        <Parameter name="_pxySnapShot" type="CM_TISnapShot"/>
    </JadeMethod>
    <JadeMethod name="setProxyForSummary" id="04a54ce8-0b2c-4a67-9120-4f575a97447e">
        <updating/>
        <source>setProxyForSummary(_operator: CM_Operator; _voyage: CM_Voyage; _is40: Boolean; _summaryCode: String) updating;
//----------------------------------------------------------------
//	Created:	12 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpSummaryCode	: String;
	terminal		: CM_Terminal;
	attributes		: Integer;
begin

	terminal := _voyage.myTerminal;
	tmpSummaryCode := _summaryCode;
	
	self.setVoyage(_voyage);
	self.operatorCode	:= _operator.code;
	self.is40			:= _is40;
	self.transitStatus	:= TI_TransitStatusNull;
	self.commodity		:= terminal.getConfig(DefCommodity).String;
	self.cargoType		:= TI_CargoType_Container;
	self.isTransship	:= false;
	self.contentsStatus	:= TI_CONTENTS_STATUS_FCL;
	attributes := attributes.bitOr(ISO_GENERAL);
	
	if tmpSummaryCode = CMIF_CandHRpt.ImportDry then
		self.imExStatus			:= TI_IMEX_STATUS_IMPORT;
		
	elseif tmpSummaryCode = CMIF_CandHRpt.ImportDryTShip then
		self.imExStatus			:= TI_IMEX_STATUS_IMPORT;
		self.isTransship		:= true;
		
	elseif tmpSummaryCode = CMIF_CandHRpt.ImportReefer then
		self.imExStatus			:= TI_IMEX_STATUS_IMPORT;
		self.commodity			:= terminal.getConfig(DefReeferComdty).String;
		//self.typeAttributes		:= 672;
		attributes := attributes.bitOr(ISO_REEFER);

	elseif tmpSummaryCode = CMIF_CandHRpt.ImportReeferTShip then
		self.imExStatus			:= TI_IMEX_STATUS_IMPORT;
		self.commodity			:= terminal.getConfig(DefReeferComdty).String;
		self.isTransship		:= true;
		//self.typeAttributes		:= 672;
		attributes := attributes.bitOr(ISO_REEFER);

	elseif tmpSummaryCode = CMIF_CandHRpt.ImportMT then
		self.imExStatus			:= TI_IMEX_STATUS_IMPORT;
		self.commodity			:= terminal.getDefaultEmptyCommodity();
		self.contentsStatus		:= TI_CONTENTS_STATUS_EMPTY;
	
	elseif tmpSummaryCode = CMIF_CandHRpt.ImportMTTShip then
		self.imExStatus			:= TI_IMEX_STATUS_IMPORT;
		self.commodity			:= terminal.getDefaultEmptyCommodity();
		self.contentsStatus		:= TI_CONTENTS_STATUS_EMPTY;
		self.isTransship		:= true;
		
	elseif tmpSummaryCode = CMIF_CandHRpt.ExportDry then
		self.imExStatus			:= TI_IMEX_STATUS_EXPORT;
	
	elseif tmpSummaryCode = CMIF_CandHRpt.ExportDryLCL then
		self.imExStatus			:= TI_IMEX_STATUS_EXPORT;
		self.contentsStatus		:= TI_CONTENTS_STATUS_LCL;
	
	elseif tmpSummaryCode = CMIF_CandHRpt.ExportDryTShip then
		self.imExStatus			:= TI_IMEX_STATUS_EXPORT;
		self.isTransship		:= true;
	
	elseif tmpSummaryCode = CMIF_CandHRpt.ExportReefer then
		self.imExStatus			:= TI_IMEX_STATUS_EXPORT;
		self.commodity			:= terminal.getConfig(DefReeferComdty).String;
		//self.typeAttributes		:= 672;
		attributes := attributes.bitOr(ISO_REEFER);

	elseif tmpSummaryCode = CMIF_CandHRpt.ExportReeferTShip then
		self.imExStatus			:= TI_IMEX_STATUS_EXPORT;
		self.commodity			:= terminal.getConfig(DefReeferComdty).String;
		self.isTransship		:= true;
		//self.typeAttributes		:= 672;
		attributes := attributes.bitOr(ISO_REEFER);

	elseif tmpSummaryCode = CMIF_CandHRpt.ExportMT then
		self.imExStatus			:= TI_IMEX_STATUS_EXPORT;
		self.commodity			:= terminal.getDefaultEmptyCommodity();
		self.contentsStatus		:= TI_CONTENTS_STATUS_EMPTY;

	elseif tmpSummaryCode = CMIF_CandHRpt.ExportMTTShip then
		self.imExStatus			:= TI_IMEX_STATUS_EXPORT;
		self.commodity			:= terminal.getDefaultEmptyCommodity();
		self.contentsStatus		:= TI_CONTENTS_STATUS_EMPTY;
		self.isTransship		:= true;
	
	elseif tmpSummaryCode = CMIF_CandHRpt.ShiftOnBoard then
		self.transitStatus 		:= TI_TransitStatusSOB;
		self.imExStatus			:= TI_IMEX_STATUS_REMAINONBOARD;
		
	elseif tmpSummaryCode = CMIF_CandHRpt.Rehandle then
		self.transitStatus		:= TI_TransitStatusDLR;
		self.imExStatus			:= TI_IMEX_STATUS_REMAINONBOARD;
		
	endif;
	
	self.typeAttributes := attributes;
	
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_is40" type="Boolean"/>
        <Parameter name="_summaryCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxySuperClass" id="6920a26c-9067-4b85-ba5c-9fb08e6b17c7">
        <updating/>
        <source>setProxySuperClass(_is40, _tranship, _isOD : Boolean;
					_id, _commodity, _loadPort, _dischPort, _operator, _type : String;
					_cargoType, _imexStatus, _contentsStatus, _transitStatus : Integer;
					// TFS 40336
					_isotype : String;
					_billOfLading : String;
					_cargoGroupId : String;
					_cargoSubtypeCode : String;
					_cargoSubtypeDescription : String;
					_cargoTypeCode : String;
					_cargoTypeDescription : String;
					_colour : String;
					_customsAgentCode  : String;
					_description : String;
					_destinationPortCode : String;
					_destinationPortDescription : String;
					_dischargePortDescription : String;
					_hazard  : String;
					_isotypeDescription : String;
					_loadPortDescription : String;
					_markNumber : String;
					_mark : String;
					_orderNumber : String;
					_remarks : String;
					_totalQuantity : Integer;
					_totalWeight : Decimal;
					_totalVolume : Decimal;
					_voyageCode : String;
					_temp : Decimal;
					_conee : String;
					_conor : String
						
					) updating;
//----------------------------------------------------------------
//	Created:	15 May 2006	by Jason Chapman  (cnwjc2)

//13 May 2022	navgm20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
//----------------------------------------------------------------
vars
	attributes	: Integer;
begin

	self.cargoType			:= _cargoType;
	self.commodity			:= _commodity;
	self.contentsStatus		:= _contentsStatus;
	self.dischargePort		:= _dischPort;
	self.id					:= _id;	
	self.imExStatus			:= _imexStatus;
	self.is40				:= _is40;
	self.isTransship		:= _tranship;	
	self.loadPort			:= _loadPort;
	self.operatorCode		:= _operator;
	self.transitStatus		:= _transitStatus;
	
	// TFS 40336
	self.isoType := _isotype;
	self.billOfLading := _billOfLading;
	self.cargoGroupId := _cargoGroupId;
	self.cargoSubtypeCode := _cargoSubtypeCode;
	self.cargoSubtypeDescription := _cargoSubtypeDescription;
	self.cargoTypeCode := _cargoTypeCode;
	self.cargoTypeDescription := _cargoTypeDescription;
	self.colour := _colour;
	self.customsAgentCode  := _customsAgentCode;
	self.description := _description;
	self.destinationPortCode := _destinationPortCode;
	self.destinationPortDescription := _destinationPortDescription;
	self.dischargePortDescription := _dischargePortDescription;
	self.hazard  := _hazard;
	self.isotypeDescription := _isotypeDescription;
	self.loadPortDescription := _loadPortDescription;
	self.markNumber := _markNumber;
	self.mark := _mark;
	self.orderNumber := _orderNumber;
	self.remarks := _remarks;
	self.totalQuantity := _totalQuantity;
	self.totalWeight := _totalWeight;
	self.totalVolume := _totalVolume;
	self.voyageCode := _voyageCode;
	self.consignee := _conee;
	self.consignor := _conor;
	
	self.temperature := _temp;
	attributes := null;
	
	if _type = CMIF_CandHRpt.ISO_Reefer then
		attributes := attributes.bitOr(ISO_REEFER);
	else
		attributes := attributes.bitOr(ISO_GENERAL);
	endif;
	
	self.typeAttributes := attributes;
	
end;</source>
        <Parameter name="_is40" type="Boolean"/>
        <Parameter name="_tranship" type="Boolean"/>
        <Parameter name="_isOD" type="Boolean"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_loadPort" type="String"/>
        <Parameter name="_dischPort" type="String"/>
