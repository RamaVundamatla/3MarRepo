    <JadeMethod name="setupForm" id="53c6f071-93e2-45f9-a533-b7457e5a4e2b">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2018	jlgndl1	Initial creation	TFS 37550
4/11/2022   navcs2 ChangeRequest 54898: EUP - Invoice currency symbol - Euro € 

*/

vars

	index : Integer;

begin

	self.minimumWidth := 530;
	self.grpCurrRate.parent := self.frmProperties;
	self.grpCurrRate.left := 4;
	self.grpCurrRate.top := 15;
	self.grpCurrType.parent := self.frmProperties;
	self.grpCurrType.left := 4;
	self.grpCurrType.top := 15;
	self.frmProperties.width := self.grpCurrType.width + 20;
	self.frmProperties.height := self.grpCurrType.height + 20;
	
	self.cmbCharacter.init(); // 4/11/2022   navcs2 ChangeRequest 54898
	
	inheritMethod();
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnNew.enabled:= false;
		self.btnEdit.enabled:= false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showPropertyFrameForObject" id="8513e7be-f5ef-4160-aaf9-99737c4b1948">
        <updating/>
        <source>showPropertyFrameForObject(_currencyObj : CM_Object; _grpBox : CMUI_GroupBox) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars
	theFrame : Frame;
	tmpGrpBox : CMUI_GroupBox;
	localTS : TimeStamp;
	roundingType : String;
begin

	self.fldProperties.visible := false;
	
	self.grpCurrType.visible := false;
	self.txtCurrTypeCode.text := null;
	self.txtCurrTypeDescr.text := null;
	self.txtCurrSymbol.text := null;
	self.txtRounding.text := null;
	self.optNone.value := true;
	self.clickOptions();
	
	self.txtTaxRate.text := null;
	self.effectiveDate.setDate(null);
	self.effectiveTime.setTime(null);	
	self.grpCurrRate.visible := false;
	self.lblTaxRateCode.caption := null;

	if self.updateMode = self.UpdateMode_Update then
		if CM_CurrencyType.hasInstance(_currencyObj) then
			tmpGrpBox := self.grpCurrType;
			self.myCurrentCurrencyType := _currencyObj.CM_CurrencyType;
			self.txtCurrTypeCode.text := self.myCurrentCurrencyType.code;
			self.txtCurrTypeDescr.text := self.myCurrentCurrencyType.description;
			self.txtCurrSymbol.text := self.myCurrentCurrencyType.currencySymbol;
			self.txtRounding.text := self.myCurrentCurrencyType.roundingInterval.asStringJMT;
			roundingType := self.myCurrentCurrencyType.getRoundingTypeString;
			if roundingType = RoundingType_Up_Str then
				self.optUp.value := true;
			elseif roundingType = RoundingType_Down_Str then
				self.optDown.value := true;
			else
				self.optNone.value := true;
			endif;
			self.clickOptions();
			
		elseif CM_CurrencyRate.hasInstance(_currencyObj) then
			tmpGrpBox := self.grpCurrRate;
			self.myCurrentCurrencyRate := _currencyObj.CM_CurrencyRate;
			self.myCurrentCurrencyType := self.myCurrentCurrencyRate.myCurrencyType;
			self.txtTaxRate.text := self.myCurrentCurrencyRate.rate.String;
			localTS := self.systemToLocalTime(self.myCurrentCurrencyRate.effectiveDT);	
			self.effectiveDate.setDate(localTS.date);								
			self.effectiveTime.setTime(localTS.time);								
			self.lblTaxRateCode.caption := app.getErrorString(Currency_type) &amp;': ' &amp; self.myCurrentCurrencyRate.getDisplayDetails(false);
			
		else	
			self.updateMode := null;
			app.msgBox('Please select an item from the list to update.', app.getErrorString(SelectItem), MsgBox_OK_Only+MsgBox_Information_Icon);
//			fromToolbar := false;			
			return;					
		endif;				
	elseif _grpBox &lt;&gt; null then
		tmpGrpBox := _grpBox;
	elseif self.lstData.listIndex &lt; 1 then
		tmpGrpBox := self.grpCurrType;
	elseif self.lstData.itemLevel[self.lstData.listIndex] &lt; 3 then
		tmpGrpBox := self.grpCurrType;
	elseif self.lstData.itemLevel[self.lstData.listIndex] = 3 then
		tmpGrpBox := self.grpCurrRate;		
	else
		self.updateMode := null;	
		app.msgBox('Please select an item from the list.', app.getErrorString(SelectItem), MsgBox_OK_Only+MsgBox_Information_Icon);	
//		fromToolbar := false;							
		return;	// nothing selected		
	endif;
	
	if self.updateMode = self.UpdateMode_New
	and tmpGrpBox = self.grpCurrRate then
		if self.myCurrentCurrencyType = null then
			app.msgBox('Please select a ' &amp; app.getErrorString(Currency_type) &amp; ' from the list to add the new rate to.', app.getErrorString(SelectItem), MsgBox_OK_Only+MsgBox_Information_Icon);				
			return;
		endif;
		localTS := self.systemToLocalTime(app.actualTimeServer);	
		self.effectiveDate.setDate(localTS.date);					
		self.effectiveTime.setTime(localTS.time);					
		self.lblTaxRateCode.caption := app.getErrorString(Currency_type) &amp;': ' &amp; self.myCurrentCurrencyType.getDisplayDetails(false);				
	endif;	
	
	tmpGrpBox.visible := true;
	tmpGrpBox.centreHorizontallyInParent();
	tmpGrpBox.top := self.frmPropToolbar.height;

	theFrame := self.frmProperties;
	theFrame.height := (tmpGrpBox.height + self.frmPropToolbar.height + 20).Integer;	
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;
	tmpGrpBox.setFocus();
	
	self.setEnableObjects(false);

end;</source>
        <access>protected</access>
        <Parameter name="_currencyObj" type="CM_Object"/>
        <Parameter name="_grpBox" type="CMUI_GroupBox"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="99a6096b-f249-4c72-b8fe-bf15087b9678">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2018 08:26:51.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022288, locale);
	btnDelete.translateCaption(Xlat_0022289, locale);
	btnEdit.translateCaption(Xlat_0022290, locale);
	btnInsert.translateCaption(Xlat_0022383, locale);
	btnNew.translateCaption(Xlat_0022291, locale);
	lblCurrSymbol.translateCaption(Xlat_0022292, locale);
	lblCurrTypeCode.translateCaption(Xlat_0022293, locale);
	lblCurrTypeDescr.translateCaption(Xlat_0022294, locale);
	lblRate.translateCaption(Xlat_0022295, locale);
	lblRateDT.translateCaption(Xlat_0022296, locale);
	lblRound.translateCaption(Xlat_0022297, locale);
	lblRounding.translateCaption(Xlat_0022298, locale);
	mnuAddCurrRate.translateCaption(Xlat_0022299, locale);
	mnuAddCurrency.translateCaption(Xlat_0022300, locale);
	mnuAudits.translateCaption(Xlat_0022301, locale);
	mnuDelete.translateCaption(Xlat_0022302, locale);
	mnuListContext.translateCaption(Xlat_0022303, locale);
	mnuUpdate.translateCaption(Xlat_0022304, locale);
	optDown.translateCaption(Xlat_0022305, locale);
	optNone.translateCaption(Xlat_0022306, locale);
	optUp.translateCaption(Xlat_0022307, locale);
end;</source>
    </JadeMethod>
</GUIClass>
