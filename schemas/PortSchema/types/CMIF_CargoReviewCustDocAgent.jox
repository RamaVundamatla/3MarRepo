    </PrimAttribute>
    <PrimAttribute name="displayWeight" id="ecd55e46-3bda-4254-8cfd-f1bc87465f2b">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="createCMIFDetail" id="061bae5e-a746-4583-8b8b-f975dcb778db">
        <updating/>
        <source>createCMIFDetail(_inDoc, _outDoc : CM_CustomDocument; _trackedBy : String) : CMIF_CargoReviewCustDocDetail updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60762: Jade - Custom Doc Summary and Unit Tests

*/

vars
	cmifDetail : CMIF_CargoReviewCustDocDetail;
begin
	
	create cmifDetail transient;
	
	cmifDetail.inwardDocCode := _inDoc.code;
	cmifDetail.inwardDateTime := _inDoc.dateTime;
	cmifDetail.inwardDocTypeCode := _inDoc.myCustomDocumentType.code;
	cmifDetail.trackedBy := _trackedBy;
	
	if _outDoc &lt;&gt; null then
		cmifDetail.outwardDocCode := _outDoc.code;
		cmifDetail.outwardDateTime := _outDoc.dateTime;
		cmifDetail.outwardDocTypeCode := _outDoc.myCustomDocumentType.code;
	endif;
	
	self.allCargoReviewCustDocDetails.add(cmifDetail);
	
	return cmifDetail;
	
epilog

end;</source>
        <Parameter name="_inDoc" type="CM_CustomDocument"/>
        <Parameter name="_outDoc" type="CM_CustomDocument"/>
        <Parameter name="_trackedBy" type="String"/>
        <ReturnType type="CMIF_CargoReviewCustDocDetail"/>
    </JadeMethod>
    <JadeMethod name="delete" id="cadcda5d-d66e-4078-a8cf-9a5a7ef24fbc">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60762: Jade - Custom Doc Summary and Unit Tests

*/

vars

begin
	self.allCargoReviewCustDocDetails.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSummary" id="17d24f17-a7cb-4594-ac7d-b291b50734a8">
        <updating/>
        <source>doSummary() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60762: Jade - Custom Doc Summary and Unit Tests

*/

vars
	ti				: CM_TrackedItem;
	
	cmifDetailPending,
	cmifDetailCleared		: CMIF_CargoReviewCustDocDetail;
	
	inCode,
	outCode			: String;
	tiCustDoc,
	tiCustDocIn,
	tiCustDocOut	: CM_CustomDocument;
	tiCustDocDtl	: CM_CustomDocumentDetail;
	
	cgType			: CM_CargoType;
	tiTrackedBy		: String;
begin
	
	foreach ti in self.allTIs do
		tiCustDocIn := null;
		inCode := null;
		
		tiTrackedBy := null;
		if ti.isBulkByVolume() then
			tiTrackedBy := self.TrackedByVolume;
			self.displayVolume := true;
		elseif ti.isBulkByWeight() then
			tiTrackedBy := self.TrackedByWeight;
			self.displayWeight := true;
		else
			tiTrackedBy := self.TrackedByQuantity;
			self.displayQuantity := true;
		endif;
		
		/* //24/01/2025	navkc1 JIRA Bug MTN-33830 - Moved this into a method in CM_TrackedItem
		// We only want the last Inward custom document
		foreach tiCustDocDtl in ti.allCustomDocDetails reversed, discreteLock where tiCustDocDtl.included do 
			tiCustDoc := tiCustDocDtl.getCustomDocumentHeader();
			
			// ### TFS CR 60425 TASK 60828 14NOV2023 NAVAB1
			if tiCustDoc.isCancelled() then
				continue;
			endif;
			
			if tiCustDoc.isInward() then
				tiCustDocIn := tiCustDoc;
				inCode := tiCustDocIn.code;
				break;
			endif;
		endforeach;
		*/
		
		tiCustDocIn := ti.getCustDocLastInwards(); 	//24/01/2025	navkc1 JIRA Bug MTN-33830
		
		// Couldn't find Inward document for this cargo, somethings wrong. skip this
		if tiCustDocIn = null then
			continue;
		endif;
		
		inCode := tiCustDocIn.code;					//24/01/2025	navkc1 JIRA Bug MTN-33830
		
		// Now we get Outward custom document and do summary
		foreach tiCustDocDtl in ti.allCustomDocDetails discreteLock where tiCustDocDtl.included do
			
			tiCustDocOut := null;
			outCode := null;
			tiCustDoc := tiCustDocDtl.getCustomDocumentHeader();
			
			// ### TFS CR 60425 TASK 60828 14NOV2023 NAVAB1
			if tiCustDoc.isCancelled() then
				continue;
			endif;

			if tiCustDoc.isAdmin() then
				continue;
			endif;
			
			if tiCustDoc.isInward() and tiCustDoc &lt;&gt; tiCustDocIn then
				continue;
			endif;
			
			if tiCustDoc.isOutward() then
				tiCustDocOut := tiCustDoc;
				outCode := tiCustDocOut.code;
			endif;
			
			// Get cmif details for cleared amount, create if not found
			cmifDetailCleared := self.allCargoReviewCustDocDetails[inCode, outCode];
			if cmifDetailCleared = null then
				cmifDetailCleared := self.createCMIFDetail(tiCustDocIn, tiCustDocOut, tiTrackedBy);
			endif;
			
			// Get cmif details for pending amount, create if not found
			cmifDetailPending := self.allCargoReviewCustDocDetails[inCode, null];
			if cmifDetailPending = null then
				cmifDetailPending := self.createCMIFDetail(tiCustDocIn, null, tiTrackedBy);
			endif;
			
			// Update the cleared and pending amount in the cmif details
			cmifDetailCleared.setAmount(tiCustDoc.isInward(), tiCustDocDtl, cmifDetailPending);
			
		endforeach;
	endforeach;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initialize" id="6b6ed30f-4160-4263-b280-0043590487e7">
        <updating/>
        <source>initialize(_tis : CM_TISet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60762: Jade - Custom Doc Summary and Unit Tests

*/

vars

begin
	self.allCargoReviewCustDocDetails.purge();
	self.allTIs.clear();
	_tis.copy(self.allTIs);
	self.displayQuantity := false;
	self.displayVolume := false;
	self.displayWeight := false;
epilog

end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
    </JadeMethod>
</Class>
