    <JadeMethod name="isCompleteWithPrenotes" id="c976c4f3-3c5b-44e1-b2fa-4d25da741256">
        <source>isCompleteWithPrenotes(): Boolean;
/*

Date		Who		Reason
24 September 2014	cnwer1	Initial creation PAR 34935 returns true if weight/quantity of prenotes and received is greater than weight/quantity

*/

vars

begin
	if isBulkMulti then
		return self.getReceivedWeight() + self.getPrenotedWeight()&gt;= self.getWeight();
	endif;
	//change from this to.......
	return self.getRecievedCount() + self.getPrenotedCount &gt;= self.getQuantity;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
