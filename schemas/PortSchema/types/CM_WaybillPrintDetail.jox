    <JadeMethod name="getPrintDescription" id="7309be2b-bdf1-4e16-97e1-7bb9d50a8c13">
        <source>getPrintDescription():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	retStr : String;

begin

	if app &lt;&gt; null then
		if self.isProForma then
			retStr :=  app.getErrorString(Proforma_waybill_report) &amp; " ";
		else
			retStr :=  app.getErrorString(Waybill_report) &amp; " ";
		endif;
	endif;
	
	if printDateTimeStr &lt;&gt; null then
		retStr := retStr &amp; printDateTimeStr;
	else
		retStr := retStr &amp; app.getErrorString(Unprinted);
	endif;
	
	return retStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setAgentsOperativeStr" id="bacf87ba-6bac-4257-a578-fdb01565f496">
        <updating/>
        <source>setAgentsOperativeStr( _tiSet : CM_TISet; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	cusAgent : CM_CustomsAgent;
	allCusAgents : CM_CustomsAgentByCodeDict;
	ti : CM_TrackedItem;
	cusAgentStr : String;
	completeStr : String;

begin

	create allCusAgents transient;
	
	foreach ti in _tiSet do
		cusAgent := ti.myCustomsAgent;
		if cusAgent &lt;&gt; null then
			allCusAgents.addNoDuplicates( cusAgent, false );
		endif;
	endforeach;
	
	foreach cusAgent in allCusAgents do
		cusAgentStr  := cusAgent.name;
		if cusAgentStr.trimBlanks &lt;&gt; null then
			if completeStr = null then
				completeStr := cusAgentStr;
			else
				completeStr := completeStr &amp; _delim &amp; cusAgentStr;
			endif;
		endif;
	endforeach;
	
	self.agentsOperativeStr := completeStr;

epilog

	delete allCusAgents;

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_delim" type="String"/>
    </JadeMethod>
    <JadeMethod name="setBillOfEntryNumberStr" id="e7d1c5ee-5c4b-4b0c-93c9-f0324bcb86de">
        <updating/>
        <source>setBillOfEntryNumberStr( _tiSet : CM_TISet; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	cen : String;
	cens : StringArray;
	ti : CM_TrackedItem;
	cusAgentStr : String;
	completeStr : String;

begin

	create cens transient;
	
	foreach ti in _tiSet do
		cen := ti.customsEntryNumber;
		if cen.trimBlanks &lt;&gt; null and not cens.includes(cen) then
			cens.add( cen );
		endif;
	endforeach;
	
	foreach cen in cens do
		if cusAgentStr.trimBlanks &lt;&gt; null then
			if completeStr = null then
				completeStr := cen;
			else
				completeStr := completeStr &amp; _delim &amp; cen;
			endif;
		endif;
	endforeach;
	
	self.billOfEntryNumberStr := completeStr;

epilog

	delete cens;

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_delim" type="String"/>
    </JadeMethod>
    <JadeMethod name="setBillOfLadingNumberStr" id="0fb2c9c0-0815-4a4f-af14-75c83dbdf9c1">
        <updating/>
        <source>setBillOfLadingNumberStr( _tiSet : CM_TISet; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	bolNumber : String;
	allBolNumbers : StringArray;
	ti : CM_TrackedItem;
	completeStr : String;

begin

	create allBolNumbers transient;
	
	foreach ti in _tiSet do
		bolNumber := ti.billOfLading;
		if bolNumber.trimBlanks = null then
			continue;
		endif;
		if not allBolNumbers.includes(bolNumber) then
			allBolNumbers.add(bolNumber);
		endif;
	endforeach;
	
	foreach bolNumber in allBolNumbers do
		if completeStr = null then
			completeStr := bolNumber;
		else
			completeStr := completeStr &amp; _delim &amp; bolNumber;
		endif;
	endforeach;
	
	self.billOfLadingNumberStr := completeStr;

epilog

	delete allBolNumbers;

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_delim" type="String"/>
    </JadeMethod>
    <JadeMethod name="setConsigneeStr" id="53ccf0e3-7d05-4a6a-afff-e832fd2a7e17">
        <updating/>
        <source>setConsigneeStr( _tiSet : CM_TISet; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	consignee : CM_ConsigneeConsignor;
	allConsignees : CM_ConsigneeConsignorSet;
	ti : CM_TrackedItem;
	consigneeStr : String;
	addStr : String;
	completeStr : String;

begin

	create allConsignees transient;
	
	foreach ti in _tiSet do
		consignee := ti.myConsignee;
		if consignee &lt;&gt; null then
			allConsignees.addNoDuplicates( consignee, false );
		endif;
	endforeach;
	
	foreach consignee in allConsignees do
		consigneeStr  := consignee.description;
		addStr := consignee.getAddress1().trimBlanks;
		if addStr &lt;&gt; null then
			consigneeStr := consigneeStr &amp; CrLf &amp; addStr;
			addStr := null;
		endif;
		addStr := consignee.getAddress2().trimBlanks;
		if addStr &lt;&gt; null then
			consigneeStr := consigneeStr &amp; CrLf &amp; addStr;
			addStr := null;
		endif;
		addStr := consignee.getAddress3().trimBlanks;
		if addStr &lt;&gt; null then
			consigneeStr := consigneeStr &amp; CrLf &amp; addStr;
			addStr := null;
		endif;
		addStr := consignee.getAddressRegion().trimBlanks;
		if addStr &lt;&gt; null then
			consigneeStr := consigneeStr &amp; CrLf &amp; addStr;
			addStr := null;
		endif;
		addStr := consignee.getAddressCountryName().trimBlanks;
		if addStr &lt;&gt; null then
			consigneeStr := consigneeStr &amp; CrLf &amp; addStr;
			addStr := null;
		endif;
		addStr := consignee.getAddressPostCode().trimBlanks;
		if addStr &lt;&gt; null then
			consigneeStr := consigneeStr &amp; CrLf &amp; addStr;
			addStr := null;
		endif;
		if consigneeStr.trimBlanks &lt;&gt; null then
			if completeStr = null then
				completeStr := consigneeStr;
			else
				completeStr := completeStr &amp; _delim &amp; consigneeStr;
			endif;
		endif;
	endforeach;
	
	self.consigneeStr := completeStr;

epilog

	delete allConsignees;

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_delim" type="String"/>
    </JadeMethod>
