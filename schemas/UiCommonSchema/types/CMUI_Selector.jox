        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblResultsDblClick" id="baf3a874-417a-469f-afb6-58876070aebf">
        <updating/>
        <source>doTblResultsDblClick(_table : CM_DataTable input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	queryProp		: CM_QueryProperty;
	name			: String;

begin
	if _table.row &lt;&gt; _table.fixedRows then
		self.doMenuEnquire();
		return;
	endif;
	//if different sorting row, hten always sort ascending initially, 
	//else if same row do the opposite of the last sort order
	if self.sortColumn &lt;&gt; _table.column then
		self.sortAscending := true;
	endif;
	
	self.sortColumn := _table.column;

	_table.accessColumn(self.sortColumn).sortOrder := 1;
	_table.accessedColumn.sortAsc := self.sortAscending;
//	_table.accessedColumn.sortType := Table.SortType_Alpha;
	
	
	if self.allVisibleColumns.isNotEmpty() then //04/09/2025	navkc1 JIRA 35574 In case it's empty
		name := self.allVisibleColumns.at(self.sortColumn);
		queryProp := self.myQDef.allQueryProperties[name];
	endif;
	
	if queryProp &lt;&gt; null then
		_table.accessedColumn.sortType := queryProp.getSortType();
	else
		_table.accessedColumn.sortType := Table.SortType_Alpha;
	endif;
	_table.resort;
	self.sortAscending := (not self.sortAscending);
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblResultsDragTI" id="bf673d37-fc03-4b46-9708-8ca59327a624">
        <updating/>
        <source>doTblResultsDragTI() updating;
/*
----------   ----------  --------------------------------------------------
Created:	21 November 2006 By cnwth2

Purpose:	

Changed On	Changed By  Reason
	
----------	----------  --------------------------------------------------
31/01/2011	cnwdap1		PAR #26830 CCMS 2013 allow move from selector, but only if item is on site
							and only if user has Yard Move View terminal security access
*/
vars
	obj		: Object;
	otherTI,
	theTI	: CM_TrackedItem;
	pic		: Picture;
begin
	
	if (not CM_TrackedItem.hasInstance(self.tblResults.allSelectedObjects.first)) then
		return;
	endif;
	// PAR #26830 check security
	if not app.myCurrentUserCan(self.myTerminal, PmYardMoveView) then
		return;
	endif;
	// PAR #26830 reinstate on-site check
	foreach obj in self.tblResults.allSelectedObjects do
		if not CM_TrackedItem.hasInstance(obj) then
			continue;
		endif;
		theTI := obj.CM_TrackedItem;
		if theTI.site &lt;&gt; TI_SITE_ONSITE then
			app.raiseCMException1(ERR_TI_NOT_ONSITE, theTI.id, null, null);
			return;
		endif;
	endforeach;
		
	theTI := self.tblResults.allSelectedObjects.first.CM_TrackedItem;
	
	app.myDraggedTrackedItem := theTI;
	
	delete app.myMoveController;
	create app.myMoveController transient;
	app.myMoveController.setMyTrackedItem(theTI);
	foreach obj in self.tblResults.allSelectedObjects where obj &lt;&gt; theTI do
		otherTI := obj.CM_TrackedItem;
		if otherTI.site &lt;&gt; TI_SITE_ONSITE then
			continue;
		endif;
		app.myMoveController.allOtherTrackedItems.add(otherTI);
	endforeach;
	
	
	app.myMoveController.isRehandleMove := theTI.isRehandle;
	//app.myMoveController.setMoveMode(REAL_MODE);			// PAR #26830
	app.myMoveController.setMoveMode(self.getMoveMode);		// PAR #26830
	
	self.tblResults.dragMode := DragMode_Drag;

	create pic transient;
	self.setPictureDragCursor(pic);
	if pic.picture &lt;&gt; null then
		self.tblResults.dragCursor := pic.picture;
	endif;

epilog
	if pic &lt;&gt; null then
		delete pic;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doTreeClick" id="47e34cb9-8a15-4696-90f0-aec207ca3ac2">
        <updating/>
        <source>doTreeClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity			: CM_MenuEntity;
begin
	menuEntity := self.lstQuery.listObject.CM_MenuEntity;
	self.tblResults.allSelectedObjects.clear();	// cnwrl1 22/01/2009
	
	if (not menuEntity.isKindOf(CM_MenuUserQuery)) then
		self.myQDef := self.cmbSelectorMode.listObject.CM_QueryDefinition;
		self.valuesCleanUp();		// cnwjre1 May 2011 27097
		self.resetForMode(null);	
	else
		self.showQuery(menuEntity.CM_MenuUserQuery);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTreeContext" id="72701303-8903-4253-bb79-f3cb3ef684de">
        <updating/>
        <source>doTreeContext(listbox: CMUI_NavigatorListBox2 input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	x1, 
	y1					: Real;
	menuEntity			: CM_MenuEntity;
	user				: CM_User;
	terminal			: CM_Terminal;
	idx					: Integer;
begin

	idx := listbox.getListIndex(x,y);
	if idx &lt;= 0 then
		return false; 
	endif;
	
	menuEntity := listbox.itemObject[idx].CM_MenuEntity;
	if (menuEntity = null) then
		return false;
	endif;
	
	user := app.getMyUser;
	if not user.canDo(self.myTerminal, PmAdmSelectorMaint) then
		return false;
	endif;
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if listbox.listIndex &lt; 0 then
	        y1 := 5;
	    else
	        y1 := listbox.positionTop(listbox.listIndex);
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);  
	
	if menuEntity.isKindOf(CM_MenuRoot) then
		self.mnuDeleteQuery.enabled := false;
		
	else
		if menuEntity.isKindOf(CM_MenuUserHdr) then
			self.mnuDeleteQuery.caption := 'Delete Folder';	
		else
			self.mnuDeleteQuery.caption := 'Delete Query';		
		endif;
		self.mnuDeleteQuery.enabled := true;
	endif;
	
	
	self.popupMenu(self.mnuTreeContext, x1.Integer, y1.Integer);

end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="CMUI_NavigatorListBox2" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnassignFromRelease" id="dd8a9f67-eda6-4599-b572-ccd1508e4c4f">
        <updating/>
        <source>doUnassignFromRelease() protected, updating;
//// 25/03/2024   navrv30		Bug 62640: MTN - Selector Translations
vars
//	brCode				: String;
	tiSet				: CM_TISet;
//	realBulkRelease		: CM_BulkRelease;
	tbl					: CM_DataTable;
	passport			: CM_Passport;
	idStr				: String;
	ti					: CM_TrackedItem;
	idx					: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	tbl := self.tblResults;
	if tbl.allSelectedObjects.isEmpty then
		// 25/03/2024   navrv30		Bug 62640
		app.msgBox(app.getErrorString(Must_selec_items_wish_unass_re), app.getErrorString(NO_Items_selected), MsgBox_Exclamation_Mark_Icon);
		return;	
	endif;
	
	create tiSet transient;
	tbl.allSelectedObjects.copy(tiSet);
	
	passport := app.myPassport;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateUnassignRelease(tiSet, passport);
	
		if app.myPassport.trxCompletedOK then
			foreach ti in tiSet do
				idStr := idStr &amp; ti.id &amp; ', ';
				idx := idx + 1;
				if idx mod 5 = 0 then
					idStr := idStr &amp; CrLf;
				endif;
			endforeach;
			idStr := idStr[1: idStr.length -2];
			// 25/03/2024   navrv30		Bug 62640
			app.msgBox(app.getErrorString1(Follo_items_have_been_succe_un, idStr), app.getErrorString(Release_unassign_completed), MsgBox_OK_Only);
					
			break;
		else
			theResult := app.showErrorWarningDialog('Bulk Release assignment update', passport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete tiSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUpdateQuery" id="d5b64f61-92ba-42b5-a59a-17bc6f63adfb">
        <updating/>
        <source>doUpdateQuery() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 March 2003		cnwth2	Initial creation
21 March 2019		jlgzm1	TFS43705 selector query column organiser out of date

*/
vars
	theName,
	theDescription			: String;
	shtIdx,
	numSheets,
	row						: Integer;
	realUserQuery,
	pxyUserQuery			: CM_MenuUserQuery;
	pxyCriteriaLine 		: CM_SelectorCriteriaLine;
	criteriaHolder			: CM_QueryCriteriaLineHolder;
	menuEntity				: CM_MenuEntity;
	parentMenuEntity		: CM_MenuEntity;
	ls						: Boolean;
	tuckAwayIdx				: Integer;
	tbl						: CM_DataTable;
	tblSheet				: JadeTableSheet;
	theReturn : Integer;

begin
	tbl := self.tblCriteria;
	menuEntity := self.lstQuery.listObject.CM_MenuEntity;
	if not menuEntity.isKindOf(CM_MenuUserQuery) then
		app.msgBox(app.getErrorString2(CMUI_MustSelect, app.getErrorString(Query), app.getErrorString(Update)), app.getErrorString(CMUI_Nothing_Selected), 0);
		return;	
	endif;
	
	realUserQuery := menuEntity.CM_MenuUserQuery;
	app.cmsBeginLoad(ls);
	pxyUserQuery := realUserQuery.pxyCreateUpdateProxy();
	
	pxyUserQuery.setProxy(self.tblQueryEnt.getValueByName(ETRow_QueryName).String,
							self.tblQueryEnt.getValueByName(ETRow_QueryDescr).String,
							app.getMyUser.code,
							self.myQDef.mode,
							app.myRoot.myQueryMenuRoot,
							self.myTerminal,
							self.allVisibleColumns);//self.myTerminal could be null - this is fine
							
	pxyUserQuery.allCriteriaLineHolders.purge();
	numSheets := tbl.sheets;
	foreach shtIdx in 1 to numSheets do
		tblSheet := tbl.accessSheet(shtIdx);
		criteriaHolder := tblSheet.itemObject.CM_QueryCriteriaLineHolder;
		pxyUserQuery.allCriteriaLineHolders.add(criteriaHolder);
		
		foreach row in 1 to tblSheet.rows do
			pxyCriteriaLine := tblSheet.accessRow(row).itemObject.CM_SelectorCriteriaLine;
			if pxyCriteriaLine &lt;&gt; null then
				pxyCriteriaLine.clearPrevCirteriaLineHolder();	//20 Nov 2019	NDL	TFS 47499 - remove it first so as to store in the correct order if it has changed.
				pxyCriteriaLine.setMyCriteriaLineHolder(criteriaHolder);
			endif;
		endforeach;
	endforeach;
	
	parentMenuEntity := app.myRoot.myQueryMenuRoot;
	
	//28 Mar 2017	NDL	TFS 3423
	while true do
	
		app.myTrxUA.trxUpdateSelectorQuery(pxyUserQuery, parentMenuEntity, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog('Selector Query', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
	
	endwhile;
	
/*	app.myTrxUA.trxUpdateSelectorQuery(pxyUserQuery,
										parentMenuEntity, 
										app.myPassport);
	
	if (not app.myPassport.trxCompletedOK) then
		app.showErrorWarningDialog('Selector Query', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return;
	endif; 
	
	self.clearErrorWarnings(); */
	
	tuckAwayIdx := self.lstQuery.listIndex;
	
	self.lstQuery.displayTree(true, "filterByMode"); // JLGAB1 30JUL19
	
	if tuckAwayIdx &gt; 0 and
	   tuckAwayIdx &lt; self.lstQuery.listCount then
	   self.lstQuery.listIndex := tuckAwayIdx;
	endif;
	
	self.showHideFrame(self.frmSaveQuery, false, true);
	
epilog
	app.cmsEndLoad(ls);
	if pxyUserQuery &lt;&gt; null then
		pxyUserQuery.allCriteriaLineHolders.clear();
	endif;
	delete pxyUserQuery;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
