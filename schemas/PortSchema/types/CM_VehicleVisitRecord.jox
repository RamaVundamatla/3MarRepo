    <JadeMethod name="getYardIC" id="df1858c7-db25-4e13-8705-a7eba85e5b21">
        <source>getYardIC() : String;
/*
Purpose: Get the Yard IC area where the truck will be loaded/unloaded		

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2012	cnwdw1	Initial creation
*/
vars
	detail	: CM_VehicleVisitRecordDetail;
	startPos: Integer;
begin
	startPos := 1;
	foreach detail in self.allVehicleVisitRecordDetails do
		if detail.recordType = VisitRecord_Complete_AGate_In then
			return detail.getExtraInfo_Yard.cnGetToken(startPos, " ");
		endif;
	endforeach;
	return "";
epilog

end;</source>
