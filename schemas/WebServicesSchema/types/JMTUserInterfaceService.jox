	// Create the response
	create response transient;
	
	// Populate the response
	rootCompany := app.myRoot.myRootCompany;
	foreach debtor in rootCompany.debtors do
		if not debtor.canUserAccessSelf(null,failedDAC,app.myPassport) then
			continue;
		endif;
		create proxyDebtor transient;
		proxyDebtor.setProxyFromObject(debtor);
		response.allDebtors.add(proxyDebtor);
