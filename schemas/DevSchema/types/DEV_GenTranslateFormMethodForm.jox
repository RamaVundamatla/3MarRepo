        <source>btnExtDelGblCnst_click(btn: Button input) updating , serverExecution;

/*

Purpose:		Create JCF of Form Constants that need deleting

Date			Who		Reason
19/09/2014		cnwmh5	Initial creation
16/03/2015		cnsmh5	Transient Leak issue
*/

vars
	folderServer		: FileFolder;
	lsSchema			: LSschema;
	constantsToDelete	: ObjectArray;
	today				: TimeStamp;
begin
	
	app.mousePointer := MousePointer_HourGlass;
	
	self.staMain.caption := "Creating JCF of Form Constants to Delete.  Please wait...";
	self.doWindowEvents(0);
	
	create folderServer transient;
	folderServer.fileName := app.cnGetServerMiscPath() &amp; "\translationsRun\" &amp; app.computerName &amp; "\Transfer" &amp;
		today.date.year.String &amp; today.date.month.padLeadingWith("0", 2) &amp; today.date.day.padLeadingWith("0", 2);
	folderServer.usePresentationFileSystem := false;
	if not folderServer.isAvailable then
		folderServer.make();
	endif;
	
	delete self.myLSschema;
	create self.myLSschema transient;

	self.myFormAgent.allSchemas.purge();
	self.myFormAgent.allConstantsByName.purge();
	self.dictLSconstantsToDisplay.purge();
	
	create lsSchema transient;
//	lsSchema.mySchema := rootSchema.getSchema(PortSchema.name);
	lsSchema.mySchema := self.myPortSchema;	//11 Sep 2020	NDL
	lsSchema.name := lsSchema.mySchema.name;
	self.myFormAgent.allSchemas.add(lsSchema);	
	self.myFormAgent.allSchemas.add(self.myLSschema);

	self.myLSschema.mySchema := lsSchema.mySchema;
	
	constantsToDelete := 	self.myLSschema.produceJCFForDelXlatGlbCnst(folderServer);
	
	if constantsToDelete.size &gt; 0 then
		
		constantsToDelete.inspectModal;
		
		if  app.msgBox("Delete ALL " &amp; constantsToDelete.size.String &amp; " unused Xlat Constants?","Delete Constants",MsgBox_Yes_No) = MsgBox_Return_Yes then
			self.staMain.caption := "Deleteing Unused Constants.  Please wait...";
			self.doWindowEvents(0);
			self.removeConstants(folderServer);
		
			app.msgBox("Constant Delete was successful","", MsgBox_OK_Only + MsgBox_Stop_Icon);
		
		endif;
	else
		app.msgBox("And when Alexander saw the breadth of his domain, he wept for there were no more worlds to conquer." &amp; CrLf &amp; "-Hans Gruber","NO CONSTANTS TO DELETE",MsgBox_OK_Only);
	endif;
	
epilog
	delete constantsToDelete;
	delete folderServer;
	
	self.staMain.caption := "";
	self.doWindowEvents(0);
	
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnExtractAll_click" id="b7fc2bab-fcdf-47fa-a578-ff613784079a">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExtractAll_click(btn: Button input) updating;

/*

Purpose:		Extract out all the details to a csv file (local temp directory)

Date			Who		Reason
19/09/2014		cnwmh5	Initial creation
16/03/2015		cnsmh5	Transient Leak issue
*/

constants

	DELIM				: String = Tab;

vars

	lsSchema			: LSschema;
	file				: File;
	
	listSize			: Integer;
	index				: Integer;
	
	
begin

	app.mousePointer := MousePointer_HourGlass;

	create file transient;
	file.fileName := "c:\temp\FormTranslationDetails.txt";
	if file.isAvailable then
		file.purge;
	endif;
	file.writeLine("Schema" &amp; DELIM &amp; "Class" &amp; DELIM &amp; "Control" &amp; DELIM &amp; "Property" &amp; DELIM &amp; "Constant Name" &amp; DELIM &amp; 
		"Form Text" &amp; DELIM &amp; "Constant Text" &amp; DELIM &amp; "Commented" &amp; DELIM &amp; "Text Diff" &amp; DELIM &amp; "No Longer Exists" &amp; DELIM &amp; "New");

	listSize := cmbAllForms.listCount;
	foreach index in 1 to listSize do
		
		delete self.myLSschema;
		create self.myLSschema transient;
	
		self.myFormAgent.allSchemas.purge();
		self.myFormAgent.allConstantsByName.purge();
		self.dictLSconstantsToDisplay.purge();
		
		create lsSchema transient;
	//	lsSchema.mySchema := rootSchema.getSchema(PortSchema.name);
		lsSchema.mySchema := self.myPortSchema;	//11 Sep 2020	NDL
		lsSchema.name := lsSchema.mySchema.name;
		self.myFormAgent.allSchemas.add(lsSchema);	
		self.myFormAgent.allSchemas.add(self.myLSschema);
	
		self.myLSschema.mySchema := cmbAllForms.itemObject[index].Class.schema;
		self.myLSschema.name := self.myLSschema.mySchema.name;
		self.myLSschema.getLSclass(cmbAllForms.itemObject[index].Class.name);
		self.myLSclass := self.myLSschema.allClasses.first;
		self.btnSave.enabled := self.myLSclass &lt;&gt; null and app.isDevelopmentSystemMain();
		self.processFormMethodDetails();
		self.extractAllDetails(file);		
	
	endforeach;

epilog

	self.staMain.caption := "";
	self.doWindowEvents(0);

	delete file;

	app.mousePointer := MousePointer_Default;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRefresh_click" id="4aff7bf2-6f23-4c13-b69d-4fd779ce6492">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRefresh_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
31 May 2013	cnwmh5	Initial creation

*/

vars
	prof : JadeProfiler;
begin

	prof := process.profiler;
	prof.methodCount := 200;
	prof.fileName := "JadeProfiler_" &amp; method.getNiceClassName &amp; ".log";
	if process.isMPD then
		prof.start;
	endif;

	app.mousePointer := MousePointer_HourGlass;

	if self.optAllForms.value = true then
		self.cmbSelectedForms.visible := false;
		self.cmbAllForms.visible := true;
		self.loadFormCombo();
		
		if self.cmbAllForms.listCount &gt; 0 then											// 27/06/2013 cnwmh5
			self.cmbAllForms.listIndex := 1;											//TFS 36423
			self.showSelectedFormDetails( self.cmbAllForms );							//TFS 36423
		endif;																			//TFS 36423
		
	else
		self.cmbAllForms.visible := false;
		self.cmbSelectedForms.visible := true;
		self.loadComboSelected();
	endif;

	if prof.isProfiling then
		prof.report;
	endif;

epilog

	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSave_click" id="67fdec5c-ed7f-468f-a53d-8c332a4718c9">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>server</executionLocation>
        <source>btnSave_click(btn: Button input) updating, serverExecution;

/*

Purpose:			

Date			Who		Reason
25/01/2012		cnwmh5	Initial creation
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	lsSchema					: LSschema;
	fileFolder					: FileFolder;
	
	today						: TimeStamp;
begin

	if not self.fromUnitTestRun then
		if self.cmbAllForms.text = self.FormConstantTextDiffText then
			if app.msgBox("This will update any form captions / bubbleHelp / constant text that has been changed.  Click 'Yes' to update or 'No' to go back to the form.",
					"Generate / Load translateFrom", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				return;
			endif;
		else
			if app.msgBox("This will update any form captions / bubbleHelp / constant text that has been changed and will create a new translateForm method, which will be loaded. " &amp; 
					"Click 'Yes' to update and load, or 'No' to go back to the form.", "Generate / Load translateFrom", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				return;
			endif;
		endif;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	self.staMain.caption := "Saving translateForm method changes...";
	self.doWindowEvents(0);
	
	// update any
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; self.cmbAllForms.text &amp; Tab &amp; self.FormConstantTextDiffText, LogINFO);
	self.updateLSconstantsFormFromTable();

	if self.cmbAllForms.text &lt;&gt; self.FormConstantTextDiffText then
		
		// create the schema files to be loaded back in
		app.log("Creating translateForm method for " &amp; self.myLSclass.myClass.name &amp; ".  Please wait...");
		app.writeLog("Creating translateForm method for " &amp; self.myLSclass.myClass.name &amp; ".  Please wait...", LogINFO);
		self.staMain.caption := "Creating translateForm method for " &amp; self.myLSclass.myClass.name &amp; ".  Please wait...";
		self.doWindowEvents(0);
		
		today := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		create fileFolder transient;
		fileFolder.usePresentationFileSystem := false;
		fileFolder.fileName := app.cnGetServerMiscPath() &amp; "\translationsRun\" &amp; app.computerName &amp; "\" &amp; self.myLSclass.myClass.name &amp;
			today.date.year.String &amp; today.date.month.padLeadingWith("0", 2) &amp; today.date.day.padLeadingWith("0", 2) &amp; 
			today.time.hour.padLeadingWith("0", 2) &amp; today.time.hour.padLeadingWith("0", 2) &amp; today.time.minute.padLeadingWith("0", 2);
		if not fileFolder.isAvailable then
			fileFolder.make();
		endif;
		
		foreach lsSchema in self.myFormAgent.allSchemas do
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; lsSchema.name &amp; Tab &amp; lsSchema.allConstants.size.String &amp; Tab &amp; Tab &amp; 
				self.myFormAgent.allSchemas.size.String &amp; Tab &amp; self.myFormAgent.allConstantsByName.size.String, LogINFO);
			if lsSchema.name = PortSchemaName then
				// all global constants are defined in PortSchema
				// but first find the constant with the highest number
				lsSchema.produceScmFile_FormXlatGlbCnst(fileFolder, self.myFormAgent.allSchemas, self.myFormAgent.highestConstantNumber);
			endif;
		endforeach;	
		
		// create the method for the classes schema
		if self.myLSschema &lt;&gt; null then
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; self.myLSschema.name &amp; Tab &amp; self.myLSschema.allConstants.size.String , LogINFO);
			self.myLSschema.produceScmFile_FormXlatMethods(fileFolder);
			lsSchema.produceScmFile_Translations(fileFolder);
		endif;
		
		// reload the details back into the system
		app.writeLog("Loading new translateForm and global constants.  Please wait...", LogINFO);
		self.staMain.caption := "Loading new translateForm and global constants.  Please wait...";
		self.doWindowEvents(0);
		self.reloadNewSchemas(fileFolder);	
	
	endif;
	
	if self.optNewOnly.value = true then
		self.cmbSelectedForms.removeItem(self.cmbSelectedForms.listIndex);
		self.noToAdd := self.noToAdd - 1;
		if self.cmbSelectedForms.listCount &gt; 0 then
			self.cmbSelectedForms.listIndex := 1;
			self.cmbSelectedForms_click(self.cmbSelectedForms);		// 15/09/2014 cnwmh5 - moved here
		else
			self.cmbSelectedForms.listIndex := -1;
			self.initTable();										// 15/09/2014 cnmwh5
		endif;
		//self.cmbSelectedForms_click(self.cmbSelectedForms);
		self.setFormCaption();
	else
		self.showSelectedFormDetails( self.cmbAllForms );
	endif;
	
epilog

	delete fileFolder;
	
	self.staMain.caption := null;
	self.doWindowEvents(0);
	
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
