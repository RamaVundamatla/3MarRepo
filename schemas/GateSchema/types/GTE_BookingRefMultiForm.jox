    <JadeMethod name="doInstructions" id="6506b204-db4d-4e52-8c30-abe66fcd31ac">
        <source>doInstructions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	obj : ObjectArray;
begin
	obj := self.tblData.allSelectedObjects;
