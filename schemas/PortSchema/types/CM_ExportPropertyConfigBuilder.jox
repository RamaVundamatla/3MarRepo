<Class name="CM_ExportPropertyConfigBuilder" id="63804c07-2ba3-47a0-8228-ca50b0c592b4">
    <superclass name="CM_ExportImportMaintenanceAgent"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="exportImport"/>
    <ImplicitInverseRef name="currentProperty" id="525e1862-c9e9-4707-9021-577d7acb5b7a">
        <embedded/>
        <type name="CM_ExportImportProperty"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="exportClass" id="2444d320-f42e-4b06-b5c1-1f935c71df34">
        <embedded/>
        <type name="CM_ExportImportClass"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="propertyQueue" id="b540f10a-908b-4437-ac31-8f7d6ff7e18b">
