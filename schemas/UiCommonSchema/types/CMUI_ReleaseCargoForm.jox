    <JadeMethod name="onCargoTypeChange" id="2a353018-462d-4bad-bec3-e95602c1dd6d">
        <updating/>
        <source>onCargoTypeChange() updating, protected;
/*

Date		Who		Reason
25/08/2009	cnwjk3	Initial creation
28/10/2009	cnwdap1	PAR #20964 New parameter to loadSubCargoCommodityCombos
05 Sep 2013 cnwer1	PAR 32408
18 Mar 2019	jlgdi1	TFS# 41721 Added enabling/disabling cargo availability check button
29 Nov 2019	jlgdi1	47771	Added a method call on isCargoAvailCheckEnabled which includes cargo availability feature enhancement
*/
vars
	ct  : CM_CargoType;
begin
	ct :=self.cmbTiType.getObject().CM_CargoType;
	self.loadSubCargoCommodityCombos(ct, null, self.cmbSubCargo, null);
	if ct &lt;&gt; null then
		self.tblWeight.enabled:=self.myTI = null and  ct.isBulkByWeight ;
		self.tblVolume.enabled:= self.myTI = null and ct.isBulkByVolume;
		self.txtNumItems.enabled:=self.myTI = null and not ct.isBulkByWeight and not ct.isBulkByVolume;
		//epr par 32445
		if  ct.isBreakBulkMulti then
			self.txtNumItems.setMyCaption(app.getErrorString(CM_Total_Quantity));
	
		else
			self.txtNumItems.setMyCaption(app.getErrorString(NumberOfItems));
		endif;
		//epr par 34406 26/6/14
		if  ct.isBulkByVolume then
			if self.tblVolume.getRawValue = null then
				self.tblVolume.setValues(" " &amp; ct.myVolumeMeasurementType.shortName);
			endif;
		elseif ct.isBulkByWeight then
			if self.tblWeight.getRawValue = null then
				self.tblWeight.setValues(" " &amp; ct.myWeightMeasurementType.shortName);
			endif;		
		endif;
		
	else
		//self.txtNumItemsBB.enabled:=false;
		self.txtNumItems.setMyCaption(app.getErrorString(NumberOfItems));
	endif;

	self.btnCargoAvailCheck.enabled := self.isCargoAvailCheckEnabled();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="onContainerIdChange" id="5ed653c8-83ca-4da5-bf53-0e033330b7f5">
        <updating/>
        <source>onContainerIdChange(_id: String; _ti: CM_TrackedItem) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/08/2009	cnwjk3	Initial creation
01/07/2013	cnwdap1	PAR #30344 CCMS GTL 2226 Only clear "By Type" fields if we have a TI
						- otherwise we end up clearing the fields we've just set up from the GTE release
29 Aug 2013 cnwer1 	PAR 32330
06 Apr 2017	cnwma1	TFS#3929:PEN - Tabbing error in Cargo Release at Road Gate
*/
vars
	ti	: CM_TrackedItem;
	commodity	: CM_Commodity;
	reason : String;
	msg : String;
	relReqValInt : Integer;	//16 Aug 2021	NDL	TFS 51785
begin
	//inheritMethod(_id, _ti);
	if _ti &lt;&gt; null then
		if _ti = self.myTI and _ti.myTerminal.getConfig(UpdateReleasedCargo).Integer = UpdateDefaultSingle then
			return;
		endif;
		
		self.myTI:=_ti;
		
	else
		if self.myTI &lt;&gt; null and self.myTI.id = _id and self.myTI.myTerminal.getConfig(UpdateReleasedCargo).Integer = UpdateDefaultSingle then
			return;
		endif;
		self.myTI:=null;
		//get the ti from the picker if more than one
		self.showCargoPicker(_id);
		//if still null will be only one
	//	if self.myTI = null then
		if self.myTI = null and _id.trimBlanks &lt;&gt; null then	//26 Aug 2015	NDL	Par 36213
			if not self.isGeneralCargo() then
				self.myTI := self.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container, _id];
			else			
				if self.cmbType.getObject() &lt;&gt; null then//cnwas3 par 21204
					self.myTI := self.myTerminal.allOnsiteTIsByCargoTypeId[self.cmbType.getObject().CM_CargoType.id, _id];				
				endif;
			endif;	
			if self.myTI = null then
				self.myTI := self.myTerminal.allOnsiteTIsByAlternativeId[_id];		// 23/09/2014 cnwar2 #34597
			endif;
		endif;	
	endif;
	
	//17 May 2021	NDL	TFS 51199 - give warning on lost focus
	if self.myReserveDetail &lt;&gt; null and self.myReserveDetail.isKindOf(CM_ReserveSelection) and self.myTI  &lt;&gt; null then
		//17 Aug 2021	NDL	TFS 51785
		relReqValInt := self.myTerminal.getConfig( RoadGateRelReqVal ).Integer;
		if relReqValInt = 2 then
			//They don't care if the selected cargo doesn't match the release request, and don't want to know, do nothing.
		else
			//perform the check.
			if not self.myTI.testAgainstReserveSelection( self.myReserveDetail.CM_ReserveSelection, reason, false, null ) then
				if relReqValInt = 1 then
					//They do care but only want a warning
					msg := app.getErrorString2( Warn_Request_Line_Match, reason, self.myTI.id ) &amp; CrLf &amp; app.getErrorString(Continue);
					if app.msgBox( msg, app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Default_Second + MsgBox_Question_Mark_Icon ) = MsgBox_Return_No then
						return;
					endif;
				elseif relReqValInt = 0 then
					//They want to stop cargo that doesn't match being released, so raise an error.
					app.raiseCMException2(Warn_Request_Line_Match, reason, self.myTI.id, null, self.myTI);
				endif;
			endif;
		endif;
	/*	if not self.myTI.testAgainstReserveSelection( self.myReserveDetail.CM_ReserveSelection, reason, false, null ) then
			if self.myTerminal.getConfig( AllowReleaseMisMatch ).Boolean then	//12 Jul 2021	NDL	TFS 51500
				msg := app.getErrorString2( Warn_Request_Line_Match, reason, self.myTI.id ) &amp; CrLf &amp; app.getErrorString(Continue);
				if app.msgBox( msg, app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Default_Second + MsgBox_Question_Mark_Icon ) = MsgBox_Return_No then
					return;
				endif;
			else
				app.raiseCMException2(Warn_Request_Line_Match, reason, self.myTI.id, null, self.myTI);
			endif;
		endif; */
	endif;
	
	self.enableByTypeFields(false);
	//self.clearByTypeFields();					// PAR #30344  06/04/2017 cnwma1 TFS #3929
	if self.myTI &lt;&gt; null then	
		self.clearByTypeFields();	                           //06/04/2017 cnwma1 TFS #3929
		// Make sure we are showing the correct screen (emty/full) for this particular container
		if self.myTI &lt;&gt; null then
			commodity := app.myRoot.allCommodities[self.myTI.commodity];
			if commodity &lt;&gt; null and not commodity.isEmpty then
				if self.isEmptyContainer() then
					self.switchToReleaseFull();
				endif;
			else
				// Assume we have an empty
				if self.isFullContainer() then
					self.switchToReleaseEmpty();
				endif;
			endif;			
			self.setFieldsFromItem(self.myTI);
		endif;
	else
		self.enableByTypeFields(true);	
	endif;
	
	self.setReleaseByTypeCaption(); //epr par 36674 1/9/15
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="onOperatorChanged" id="208e01e1-59c4-46e0-9e27-571767559028">
        <source>onOperatorChanged() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		TFS		Reason
