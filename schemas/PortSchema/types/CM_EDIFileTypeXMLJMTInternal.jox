    <JadeMethod name="createSampleXMLFile" id="e97a53a8-0a69-4e3d-9053-41e8e34a4a90">
        <source>createSampleXMLFile(_ediData : CM_EDIData; _xmlDoc : JadeXMLDocument io);
/*

Purpose:			Generate a sample XML file for the passed in EDI data type

Parameters:			EDI data type to generate sample file from

Return Value:		XML string for this type

Date		Who		Reason
30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
02 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
//10 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars
	ediAgent : CM_EDIControllerAgent;
	dataType : Integer;
	dataTypeString : String;
	ediDataTypes : IntegerArray;
	xmlString,
	xmlSubString : String;
//	xmlDoc : JadeXMLDocument;
	
begin
	create ediDataTypes transient;
	create ediAgent transient;
	_ediData.getEDIDataTypeChildren(EDIDataType_JMTInternal, ediDataTypes);
	
	xmlString := '&lt;' &amp; _ediData.getJMTInternalName() &amp; ' xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="'&amp;_ediData.getJMTInternalName()&amp;'.xsd"&gt;';
//	xmlString := '&lt;' &amp; _ediData.getJMTInternalName() &amp; '"&gt;';
	
	foreach dataType in ediDataTypes do
		xmlSubString := self.createSampleXMLSubFile(ediAgent, dataType, _ediData);
		xmlString := xmlString &amp; xmlSubString;
	endforeach;
	
	xmlString := xmlString &amp; '&lt;/' &amp; _ediData.getJMTInternalName() &amp; '&gt;';
write xmlString;	
//	create xmlDoc transient;
	_xmlDoc.parseString(xmlString);
	
	_xmlDoc.outputDeclaration := true;
	_xmlDoc.indentString := '  ';
epilog
	delete ediDataTypes;
	delete ediAgent;
//	delete xmlDoc;
	
end;
</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_xmlDoc" type="JadeXMLDocument" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createSampleXMLSubFile" id="30b1fef1-6288-44e5-8d4d-a5f6120a84af">
        <source>createSampleXMLSubFile(_ediAgent : CM_EDIControllerAgent; 
					   _dataType : Integer; 
					   _ediData : CM_EDIData) : String protected;
/*

Purpose:			Return a sample XML string for the passed in type

Parameters:			

Return Value:		XML string to be added to XML document being constructed

Date		Who		Reason
30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML	
02 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
15 May 2017	cnwrs1	add extra data to sample file
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars
	itemFieldClass	: Class;
	tiClass	: Class;
	dataType : Integer;
	dataTypeString : String;
	ediDataTypes : IntegerArray;
	masterEDITI	: CM_EDITrackedItem;
	allFieldsOfType : CM_FieldByTypeSysNameDict;
	fileField : CM_Field;
	xmlField : CM_EDIItemFieldXML;
	xmlString,
	xmlSubString : String;
	property : Property;
	value : String;
	date : Date;
	time : Time;
	dateTime : TimeStamp;
//	strArray : StringArray; 
	nullString : String;
begin
	create ediDataTypes transient;
	create allFieldsOfType transient;
	dataTypeString := _ediAgent.getEDIDisplayStrForType(_dataType).asXMLTagName();
	itemFieldClass := CM_EDIItemFieldXML;
//	tiClass := _ediData.getEDITIType(_dataType);
	tiClass := app.myPassport.myTerminal.myEdiConfig.getEDITIClassFromEDIDataType(_dataType);
	if tiClass = null or
	   tiClass.abstract then		//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		_ediData.getItemFields(allFieldsOfType, itemFieldClass);
	else
		create masterEDITI as tiClass transient;
		masterEDITI.getItemFields(allFieldsOfType, itemFieldClass);
	endif;

//	create masterEDITI as tiClass transient;
//	masterEDITI.getItemFields(allFieldsOfType, itemFieldClass);

	xmlString := "&lt;All" &amp; dataTypeString &amp; "&gt;";
	xmlString := xmlString &amp; "&lt;" &amp; dataTypeString &amp; "&gt;";
	
	foreach fileField in allFieldsOfType do
		xmlField := fileField.CM_EDIItemFieldXML;
		if masterEDITI &lt;&gt; null then
			property := masterEDITI.getPropertyFromColumnName(xmlField.systemName);
		else
			property := _ediData.getPropertyFromColumnName(xmlField.systemName);
		endif;
				if property = null then
					write class.name&amp;'::'&amp;method.name&amp;' no property for '&amp;xmlField.systemName;
					continue;
				endif;
				value := "ABCDEFGHIJKLMNOPQRSTUVWXYZ012345678901234567890123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ012345678901234567890123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ012345678901234567890123456789";
				if property.getLength() = 1 then
					value := value[1:1];
				elseif property.getLength() &gt; 1 then
					value := value[1:property.getLength()-1];
				endif;
				if property.type = Integer then
					value := "1234";	
				elseif property.type = Decimal then
					value := "1234.1234";	
				elseif property.type = Real then
					value := "1234.123456";	
				elseif property.type = Boolean then
					value := "true";
				elseif property.type = Date then
					value := date.asStringJMT;
				elseif property.type = Time then
					value := time.asStringJMT;
				elseif property.type = TimeStamp then
					value := dateTime.asStringJMT;
				endif;
				if property.name = ETRow_ImCodes or
				   property.name = ETRow_AllUNDGCodes then
					value := "34:2014";
				elseif property.name = ETRow_Description then
					if class = CM_EDIConsignoreeTI then
						value := value[1:CM_ConsigneeConsignor::description.getLengthForString()];
					endif;
				elseif property.name = ETRow_DischargePort or
					property.name = ETRow_Destination or
					property.name = ETRow_DestinationPort or
					property.name = ETRow_LoadPort then
					value := "USPOE";
				elseif property.name = ETRow_DischargePorts then
					value := "USPOE USPOL USAAA";
				elseif property.name = ETRow_OperatorCode then
					value := "UTOP";
				elseif property.name = ETRow_CargoTypeDesc or
					property.name = ETRow_CargoTypeDescr then
					value := "Cannon";
				elseif property.name = ETRow_Volume then
					value := "123.123";
					if class = CM_EDIBOLDtlTI or	// a bit weird
					   class = CM_EDIRequestDetailTI or
					   class = CM_EDITransactionTI then
						value := "123.1234";
					endif;
				elseif property.name = ETRow_Status then
					value := "1";
				elseif property.name = ETRow_NewStowageId then
					value := "0YZ0123";
				elseif property.name = ETRow_OutOfGauge then
					value := "Yes";
				elseif property.name = ETRow_IsWaterCooled then
					value := "Yes";
//					ediTi.assignValueSpecial(ETRow_Temperature, "-10", null);	// watercooled nedds a temp
				elseif property.name = ETRow_TransportMode then
					value := "Rail";
				elseif property.name = ETRow_TimeAllowedOffPower or
					   property.name = ETRow_LongPos or
					   property.name = ETRow_MaxCargoHeight  or
					   property.name = ETRow_MaxCargoWeight  or
					   property.name = ETRow_TransPos then
					value := "123.12";
				elseif property.name = ETRow_TareWeight  then
					value := "123.1256";
					if class = CM_EDIWagonTI or	// a bit weird
					   class = CM_EDIFleetWagonMasterTI then
						value := "123.12";
					endif;
				elseif property.name = ETRow_Thickness then
					value := "123.123";
				elseif property.name = ETRow_TypeString then
					value := "ABCD";
				elseif property.name = ETRow_CoolingType then
					value := "WATER";
				elseif property.name = ETRow_VoltageType then
					value := "DUAL";
				elseif property.name = ETRow_WagonSeals then
					value := ":UT_WS=seal21:UT_WS=seal22";
				endif;
				//ediTI.setPropertyByName(entTableRow.name, str);
				write class.name&amp;'::'&amp;method.name&amp;' '&amp;' set '&amp;property.name&amp;' '&amp;value;
		xmlString := xmlString &amp; "&lt;" &amp; xmlField.systemName &amp; "&gt;" &amp; value &amp; "&lt;/" &amp; xmlField.systemName &amp; "&gt;";
write class.name&amp;'::'&amp;method.name&amp;' '&amp;xmlField.systemName&amp;' '&amp;property.String;
	endforeach;
	if masterEDITI &lt;&gt; null then
		masterEDITI.zGetAllExtraDataXSD(nullString, xmlString );	//09 Jun 2017	NDL	TFS 4331
	else
//		_ediData.zGetAllExtraDataXSD(nullString, xmlString );	//09 Jun 2017	NDL	TFS 4331
	endif;
	
	_ediData.getEDIDataTypeChildren(_dataType, ediDataTypes);
	foreach dataType in ediDataTypes do
		xmlSubString := self.createSampleXMLSubFile(_ediAgent, dataType, _ediData);
		xmlString := xmlString &amp; xmlSubString;
	endforeach;
	
	xmlString := xmlString &amp; "&lt;/" &amp; dataTypeString &amp; "&gt;";
	xmlString := xmlString &amp; "&lt;/All" &amp; dataTypeString &amp; "&gt;";
	
	return xmlString;
	
epilog
	if masterEDITI &lt;&gt; null then
		delete masterEDITI;
	endif;
	delete ediDataTypes;
	delete allFieldsOfType;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediAgent" type="CM_EDIControllerAgent"/>
        <Parameter name="_dataType" type="Integer"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractDataXMLFile" id="4fcef951-4468-4f8e-b75b-5fe293d584dc">
        <source>extractDataXMLFile(_ediData : CM_EDIData) : String;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
// this creates a sample xml file.
//10 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
vars
	ediAgent : CM_EDIControllerAgent;
	dataType : Integer;
	ediDataTypes : IntegerArray;
	xmlDoc : JadeXMLDocument;
	rootElem : JadeXMLElement;
	dataTypesExtracted : IntegerArray;
	xmlString : String;
begin
	create ediDataTypes transient;
	create ediAgent transient;
	create dataTypesExtracted transient;
	_ediData.getEDIDataTypeChildren(EDIDataType_JMTInternal, ediDataTypes);
	xmlString := '&lt;' &amp; _ediData.getJMTInternalName() &amp; ' xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="'&amp;_ediData.getJMTInternalName()&amp;'.xsd"&gt;';
	foreach dataType in ediDataTypes do
		xmlString := xmlString &amp; self.extractDataXMLSubFile(ediAgent, dataType, _ediData, dataTypesExtracted);
	endforeach;
	xmlString := xmlString &amp; "&lt;/"&amp;_ediData.getJMTInternalName()&amp;"&gt;";
    create xmlDoc transient;
	xmlDoc.parseString(xmlString);
	
	xmlDoc.outputDeclaration := true;
	xmlDoc.indentString := '  ';
	
	return xmlDoc.writeToString();

epilog
	delete ediDataTypes;
	delete ediAgent;
	delete xmlDoc;
	delete dataTypesExtracted;
end;

</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractDataXMLSubFile" id="5726abc4-e511-4ccb-9672-c5ba0a283568">
        <source>extractDataXMLSubFile(_ediAgent : CM_EDIControllerAgent; _dataType : Integer; _ediData : CM_EDIData; _dataTypesExtracted : IntegerArray io) : String protected;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
// this creates a sample xml file.
//10 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
vars
	itemFieldClass	: Class;
	tiClass	: Class;
	dataClass : Class;
	dataType : Integer;
	dataTypeString : String;
	ediDataTypes : IntegerArray;
	ediTI	: CM_EDITrackedItem;
	allFieldsOfType : CM_FieldByTypeSysNameDict;
	fileField : CM_Field;
	xmlField : CM_EDIItemFieldXML;
	fieldValue : Any;
	xmlString : String;
	dataClassName : String;
begin
	if _dataTypesExtracted.includes(_dataType) then
		return null;
	endif;
	if _ediData.includeAsHeaderInXML then
		dataClass := _ediData.class;
		dataClassName := dataClass.name[7:end];
		xmlString := xmlString &amp; "&lt;All" &amp; dataClassName&amp; "&gt;";
		xmlString := xmlString &amp; "&lt;" &amp; dataClassName&amp; "&gt;";
		xmlString := xmlString &amp; self.extractDataXMLSubFileHeader(_ediAgent, _dataType, _ediData, _dataTypesExtracted);
	endif;
	_dataTypesExtracted.add(_dataType);
	create ediDataTypes transient;
	create allFieldsOfType transient;
	dataTypeString := _ediAgent.getEDIDisplayStrForType(_dataType).asXMLTagName();
	xmlString := xmlString &amp; "&lt;All"&amp;dataTypeString&amp;"&gt;";
	itemFieldClass := CM_EDIItemFieldXML;
//	tiClass := _ediData.getEDITIType(_dataType);
	tiClass := app.myPassport.myTerminal.myEdiConfig.getEDITIClassFromEDIDataType(_dataType);		//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
	foreach ediTI in _ediData.allEDITrackedItems where ediTI.class = tiClass do
		ediTI.getItemFields(allFieldsOfType, itemFieldClass);
		xmlString := xmlString &amp; "&lt;"&amp;dataTypeString&amp;"&gt;";
		foreach fileField in allFieldsOfType do
			xmlField := fileField.CM_EDIItemFieldXML;
			fieldValue := ediTI.getPropertyValue(xmlField.systemName);
			if fieldValue &lt;&gt; null then
				fieldValue := ediTI.getValueSpecial(xmlField.systemName, null);
				if fieldValue &lt;&gt; null then
					fieldValue := fieldValue.String.replaceString('&amp;', "&amp;#038;");
					fieldValue := fieldValue.String.replaceString('&lt;', "");
					fieldValue := fieldValue.String.replaceString('&gt;', "");
					xmlString := xmlString &amp; "&lt;"&amp;xmlField.systemName&amp;"&gt;"&amp;fieldValue.String&amp;"&lt;/"&amp;xmlField.systemName&amp;"&gt;";
				endif;
			endif;
		endforeach;
		_ediData.getEDIDataTypeChildren(_dataType, ediDataTypes);
		foreach dataType in ediDataTypes do
			xmlString := xmlString &amp; self.extractDataXMLSubFile(_ediAgent, dataType, _ediData, _dataTypesExtracted);
		endforeach;
		xmlString := xmlString &amp; "&lt;/"&amp;dataTypeString&amp;"&gt;";
	endforeach;
	xmlString := xmlString &amp; "&lt;/All"&amp;dataTypeString&amp;"&gt;";
	if _ediData.includeAsHeaderInXML then
		xmlString := xmlString &amp; "&lt;/" &amp; dataClassName&amp; "&gt;";
		xmlString := xmlString &amp; "&lt;/All" &amp; dataClassName&amp; "&gt;";
	endif;
	return xmlString;
epilog
	delete ediDataTypes;
	delete allFieldsOfType;
end;

</source>
        <access>protected</access>
        <Parameter name="_ediAgent" type="CM_EDIControllerAgent"/>
        <Parameter name="_dataType" type="Integer"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_dataTypesExtracted" type="IntegerArray" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractDataXMLSubFileHeader" id="5a4dba02-9910-4157-ad56-0ea76d352289">
        <source>extractDataXMLSubFileHeader(_ediAgent : CM_EDIControllerAgent; _dataType : Integer; _ediData : CM_EDIData; _dataTypesExtracted : IntegerArray io) : String protected;

vars
	xmlString : String;
	propertyCollObj	: PropertyColl;
	prop : Property;
	dataClass : Class;
	any : Any;
begin
	dataClass := _ediData.class;
	propertyCollObj := dataClass.allPropertiesUpTo(CM_Object);
	foreach prop in propertyCollObj do
		if prop.isSystemObject or 
		   not prop.isKindOf(Attribute) or	  
		   prop.virtual or 
		   not _ediData.canUserSet(prop.name) then
			continue;
		endif;
		any := _ediData.getPropertyValue(prop.name);
		if any &lt;&gt; null then
			xmlString := xmlString &amp; '&lt;' &amp; prop.name &amp; '&gt;' &amp;any.String&amp; '&lt;/' &amp; prop.name &amp; '&gt;';
		endif;
	endforeach;
	return xmlString;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_ediAgent" type="CM_EDIControllerAgent"/>
        <Parameter name="_dataType" type="Integer"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_dataTypesExtracted" type="IntegerArray" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="0d25aecf-a9f1-48e9-a24b-10fd618ee4a4">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType: Integer io; _fileTypeCode: Integer io);
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
