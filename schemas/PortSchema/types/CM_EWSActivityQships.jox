end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_interface" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_opsViewObject" type="CM_Object"/>
        <Parameter name="_dataAction" type="Character"/>
        <Parameter name="_dataType" type="String"/>
        <Parameter name="_snapshot" type="Boolean"/>
