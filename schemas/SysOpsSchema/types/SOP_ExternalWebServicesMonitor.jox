    <JadeMethod name="tblResponse_click" id="f7053f61-a4a2-427a-901c-8d964df4c222">
        <controlMethod name="CMUI_ListTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResponse_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2025 	navcs2	MTN-34126 EUP |  FR - Search results Issues for Response code "0"

*/

vars
	row : Integer;													
	allSet	: Boolean;
begin
	allSet := true;
	row := 1;														
	
	while row &lt;= self.tblResponse.rows do
		if not self.tblResponse.accessCell(row, 1).text = "1" then
			allSet := false;
		endif;
		
		row := row + 1;
	endwhile;
	
	if allSet then
		self.chkAllResponses.value := true;							
	else
		self.chkAllResponses.value := false;			
	endif;
epilog
	
end; 
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblTerminals_click" id="69f246e3-fa02-49d5-b6e8-2a8803dd356a">
        <controlMethod name="CMUI_ListTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTerminals_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor

*/

vars
	terminalDict : CM_TerminalByCodeDict;
begin
	self.tblInterfaces.clear;
	
	create terminalDict transient;
	self.getTerminals(terminalDict);
	
	if self.isCams then
		self.addCamsProtocols(terminalDict);
	elseif self.isAPIENDPOINT then
		self.addAPIENDPOINTS();
	endif;
epilog
	delete terminalDict;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
