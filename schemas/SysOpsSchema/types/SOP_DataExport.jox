    <JadeMethod name="addObjectsToTable" id="af90aaf2-a699-4601-869f-a4bea0ae51bd">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	itr : Iterator;
	def : CM_DataDumpExtractDef;
	breakOut	: Boolean;
	
begin
	itr := app.myRoot.allDataDumpExtractDefs.createIterator;
	
	while itr.next(def) do
		self.addObjectToTable(def, _numItems, breakOut);
		if breakOut then
			break;
		endif;
	endwhile;
	
epilog
	delete itr;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addProxiesToBeDeleted" id="c2d3750d-a604-4ca9-bd33-894ec91a1a3d">
        <source>addProxiesToBeDeleted(_clsArr : CM_DataDumpExtractClassArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
2 Feb 2024 	navhl20 	Bug 62256: GPHA -- Error Exception 4  (Object not found) when selecting ALL available features on creating a Jade SQL mapping for CM_Voyage class

*/

vars
	pxyExtractClass : CM_DataDumpExtractClass;
begin
	foreach pxyExtractClass in _clsArr do
		if pxyExtractClass.isTransient() then
			self.allDataDumpClassProxiesDeleted.addNoDuplicates(pxyExtractClass,false);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_clsArr" type="CM_DataDumpExtractClassArray"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="f5bd52bf-d4b0-416c-83a9-8bc9d4a2784d">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     28 September 2003 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 30 Sep 2024	navsp1	JIRA 23326 NSW - Unable to Manually Run Data Extract (TFS Bug 65272) 
vars
	toolbar	: CMUI_Toolbar;

begin
	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExtDefAll, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnExtDefChg, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmDataExtract, CMUI_Toolbar.Control_Alignment_Left);		//JIRA 23326
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewChgTrkMon, CMUI_Toolbar.Control_Alignment_Left);

//	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//	if app.getMyUser().canDo(self.myTerminal, PmAdmSelectorView) then
//		toolbar.addButton(self.btnSelector, CMUI_Toolbar.Control_Alignment_Left);
//	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnExtDefAll_click" id="ad4aa4b4-e324-4a90-a959-385d67b6b0ea">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExtDefAll_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	app.mousePointer := Busy;
	self.doDataDumpDef(false);
	
epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnExtDefChg_click" id="6c656170-3e1a-4f48-b3a5-953800f42c07">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExtDefChg_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	app.mousePointer := Busy;
	self.doDataDumpDef(true);

epilog
	app.mousePointer := Idle;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnExtractUpTo_click" id="64963cbc-b814-4bac-94ee-61efd399a735">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExtractUpTo_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	app.mousePointer := Busy;
	self.doUpdateExtractDefTs;
	
epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnExtract_click" id="f80a78e0-e9ae-4c52-9035-c568401d625d">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExtract_click(btn: Button input) updating;

//27 Mar 2019	NDL	TFS 43873 - Allow extarct of objects for XML

vars

begin
	app.mousePointer := Busy;
	
	if self.myCurrentObject &lt;&gt; null then 
		if self.myCurrentObject.CM_DataDumpExtractDef.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then
			self.doUpdateExtractObjs();
		elseif self.myCurrentObject.CM_DataDumpExtractDef.extractFormat = CM_DataDumpExtractDef.FmtXML_Generic then
			self.doExtractObjs();
		endif;
	endif;

epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSelector_click" id="c8f27a84-5e57-482a-b08a-aab336839422">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelector_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     19 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	selectorForm 	: CMUI_Selector;
begin
	selectorForm := app.getSelectorForm(self, self.myMasterMenuAction);
	selectorForm.show;


end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
