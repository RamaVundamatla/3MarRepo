    <JadeMethod name="createShipMapping" id="3a364a34-c9f0-41f5-9045-d6ae57e98ad0">
        <updating/>
        <source>createShipMapping()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2023	navmv20 Bug 60635: FR | 54089 EUP -Invoice Contracts - Shipping Terms

*/

vars
	charge,debtor : CM_DebtorType;
	pxyShippingTermMapping,
	realShippingTermMapping:CM_InvoiceShipTermMapping;
	bank : CM_Bank;
	allInvoice : CM_InvoiceLineDescSet;
	ild : CM_InvoiceLineDesc;
	theReturn : Integer;
begin
	if self.cmbCharge.listIndex &lt;&gt; -1 then
		charge := self.cmbCharge.itemObject[self.cmbCharge.listIndex].CM_DebtorType;
	endif;
	bank := self.myCurrentBank;
	create allInvoice transient;
	self.msgInvlistTypes.getSelected(allInvoice);
	create pxyShippingTermMapping transient;
	pxyShippingTermMapping.setProxy(2,myShipTerm,charge,allInvoice);

		while true do
		app.myTrxCA.trxCreateInvoiceShipMapping(pxyShippingTermMapping, realShippingTermMapping, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			//self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_ship_mapping_created), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	
epilog
	delete	pxyShippingTermMapping;
	delete allInvoice;
end;</source>
    </JadeMethod>
    <JadeMethod name="createShippingTerm" id="c5fd1c4a-2c9e-44b4-bf8e-0aa464485f9a">
        <updating/>
        <source>createShippingTerm()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	code, desc : String;
	bank : CM_Bank;
	pxyShippingTerm,
	realShippingTerm:CM_InvoiceContractShipTerm;
	theReturn : Integer;
begin
	if self.txtCode &lt;&gt; null then
		code := self.txtCode.text.String;
	endif;
	if self.txtDescription &lt;&gt; null then
		desc := self.txtDescription.text.String;
	endif;
	create pxyShippingTerm transient;
	pxyShippingTerm.setProxy(code,desc,self.myCurrentBank);
	while true do
		app.myTrxCA.trxCreateInvContractShpngTerms(pxyShippingTerm, self.myShipTerm, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			//self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Shipping_term_created), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
	delete pxyShippingTerm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbChargesBuild" id="704d8ed6-29ee-487a-8ee6-a847a0f5f7e7">
        <source>doCmbChargesBuild(_combo : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2023	navmv20 Bug 60635: FR | 54089 EUP -Invoice Contracts - Shipping Terms

*/
vars
	aDebtorType : CM_DebtorType;
begin
	
	_combo.clear;
	_combo.sorted := true;
	
	
	foreach aDebtorType in app.myRoot.allDebtorTypes where not aDebtorType.isNotAvailableForEntry do
		if aDebtorType.code = CM_DebtorType.DT_EVENT_TYPE  then
			continue;
		endif;
		
		if aDebtorType.isSystemGenerated or aDebtorType.allDebtors.size &gt; 0 then
			_combo.addItem(aDebtorType.description);
			_combo.itemObject[_combo.newIndex] := aDebtorType;
		endif;
	endforeach;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="ed729361-d44d-40d3-bdf7-7066e0cce18e">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	dataLine	: String;
	shipTerm : CM_InvoiceShipTermMapping;
	event : Integer;
	idx : Integer;
	theDataLine : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_InvoiceShipTermMapping) then
		shipTerm := userInfo.CM_InvoiceShipTermMapping;
	elseif theObject.isKindOf(CM_InvoiceShipTermMapping) then
		shipTerm := theObject.CM_InvoiceShipTermMapping;
	endif;
	
	if event = Event_InvShipMappingCreate then
		if shipTerm &lt;&gt; null then			
			self.tblDisplayRow();
		endif;
	elseif event = Event_InvShipMappingUpdate then
		if shipTerm &lt;&gt; null then
			self.tblData.findObjectInRow(shipTerm,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := shipTerm.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	elseif event = Event_InvShipMappingDelete then
		self.tblData.removeItemObject(shipTerm);
		self.doNotableClear();
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="f49b60f4-fd6c-4cb5-8880-cea0390da8fa">
        <source>doNotableAdd(_shipTerm: CM_InvoiceShipTermMapping);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	invalid : Boolean;
	ed : Integer;
begin
	
	self.allNotableObjects.add(_shipTerm);
	beginNotification(_shipTerm, self.myTerminal.getTerminalEvent(Event_InvShipMappingUpdate), Response_Continuous, null);
	beginNotification(_shipTerm, EventFileAdd, Response_Continuous, null);
	beginNotification(_shipTerm, EventFileDelete, Response_Continuous, null);
epilog

end;</source>
        <Parameter name="_shipTerm" type="CM_InvoiceShipTermMapping"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="5b73b806-63f9-437a-a55e-08d18dfc57cc">
        <source>doNotableClear();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars

	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		endNotification(anObject, self.myTerminal.getTerminalEvent(Event_InvShipMappingUpdate));
		endNotification(anObject, EventFileAdd);
		endNotification(anObject, EventFileDelete);
	endforeach;
	
	self.allNotableObjects.clear;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissions" id="f5ee3236-03b9-45b3-996e-d8d15fdd12d8">
        <source>doPermissions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint
06 October 2023	navmv20 Bug 60635: FR | 54089 EUP -Invoice Contracts - Shipping Terms
*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnRemove.enabled := false;
		self.btnAdd.enabled := false;
		self.btnUpdate.enabled := false;
		self.tblData.enabled := false;
		self.txtCode.enabled := false;
		self.txtDescription.enabled := false;
		self.btnClose.enabled := true;
		self.btnSave.enabled := false;
		self.btnAudits.enabled := false;
		self.cmbCharge.enabled := false; //06/10/2023	navmv20 Bug 60635
		self.msgInvlistTypes.enabled := false; //06/10/2023	navmv20 Bug 60635
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemove" id="c6844f2d-faa1-40b3-9621-1809e894b628">
        <updating/>
        <source>doRemove(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	theReturn : Integer;
	shipMapping	: CM_InvoiceShipTermMapping;
	msgString : String;
begin
	shipMapping := _obj.CM_InvoiceShipTermMapping;
	if shipMapping = null then
		app.msgBox("No record selected", "Warning",MsgBox_OK_Only);
		return;
	endif;
	if app.msgBox(app.getErrorString2(Sure_want_remov_invoi_ship_map, shipMapping.myDebtorType.description,null), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
 	app.myTrxDA.trxDeleteInvoiceShipMapping(shipMapping, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			
		else
			theReturn := app.showErrorWarningDialog("Invoice Contract Ship Term", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doViewAudits" id="713516d1-a5fd-4fcd-8a3f-167231fa8a62">
        <updating/>
        <source>doViewAudits(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars

begin
	if _obj = null then
		return;
	endif;

	if self.myAssistant = null then
		create self.myAssistant as CMUI_Assistant transient;
		self.myAssistant.setMyTerminal(self.myTerminal);		
	endif;
	
	app.viewAuditForm(_obj.CM_InvoiceShipTermMapping, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
