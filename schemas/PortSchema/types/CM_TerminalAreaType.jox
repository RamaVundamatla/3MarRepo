    <JadeMethod name="setProxyFromXML" id="fe32b538-c0a2-43cb-8b6c-0cef06794a75">
        <updating/>
        <source>setProxyFromXML(_id: Integer; _xml: String; _root: CM_Root) updating;
//--------------------------------------------------------------
// Created: 08 August 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	
begin

	self.setProxy(
			_id,
			_xml.cnEcGetTagValueOfName('Name'),
			(_xml.cnEcGetTagValueOfName("isYardAllocationAllowed") = "true"),
			(_xml.cnEcGetTagValueOfName('isNotAvailableForEntry') = "true"),
			(_xml.cnEcGetTagValueOfName('isNotAvailableSys') = "true"),
			_root);

end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_xml" type="String"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="72fcf48d-2e66-4d44-98eb-deda6582f1df">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     14 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.validateForUpdate();
		
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="2f328df0-c8a1-4237-a74b-40cb7da4665a">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTerminalAreaType : CM_TerminalAreaType;
	whereUsed : String;
	
begin
	theTerminalAreaType := app.myPassport.myTerminal.getConfig(DefTAType).CM_TerminalAreaType;
	if theTerminalAreaType = self then
//		app.raiseCMException(ERR_USED_IN_CONFIG,null, null);
		app.raiseCMException3(ERR_USED_IN_CONFIG,"Terminal Area Type", self.description,"Terminal " &amp; app.myPassport.myTerminal.code,null, null);
		return;
	endif;

	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.description, whereUsed, null, self);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="4a195060-78e7-478e-80ff-263dfc15a84a">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     14 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	whereUsed : String;

begin

	if self.type &lt;= TA_TYPE_NULL or
	   self.type &gt; TA_TYPE_MAX then
	   // rs 19/11/2003 allow CPL areatype to be defined
//	   	app.raiseCMException(ERR_KEY_RANGE, 'type', null);
	endif;

	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'description', 'description', null);
		app.raiseCMException(Input_required_field_desc, 'description', null); // cnwdb2	PAR 35364
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
