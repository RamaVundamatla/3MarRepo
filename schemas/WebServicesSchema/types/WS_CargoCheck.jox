        <text>Show the seal value yes/no.</text>
    </PrimAttribute>
    <PrimAttribute name="toDoTaskDescCode" id="3c3f0303-5f01-4812-9582-d18c4510113d">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <text>To do task used, if any, on the cargo check item. 10 characters.</text>
    </PrimAttribute>
    <PrimAttribute name="toDoTaskDescDesc" id="bc86306a-9f68-4d8d-9117-e41493a87019">
        <length>101</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="0b4f3e64-068e-4916-9882-eef6e25fc667">
        <updating/>
        <source>setProxyFromObject(_cargoCheckItem : CM_CargoCheckItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
30 September 2011	cnwer1	Initial creation CCMS MES 1033
06 June      2025   navbk1  Bug 34259: MTN - Cannot add quick damage correctly when damage details are mandatory configs are set
*/

vars

	toDoTaskDesc : CM_ToDoTaskDesc;
	terminal : CM_Terminal;
begin

	inheritMethod(_cargoCheckItem);
	self.context:=_cargoCheckItem.myCargoCheck.context;
	self.name:=_cargoCheckItem.name;
	self.required:=_cargoCheckItem.required;
	self.requiredExtraInfo := _cargoCheckItem.requiredExtraInfo;
	//jlier1 TFS 58968 14/9/23
	terminal:=_cargoCheckItem.myCargoCheck.myTerminal;
	
	if self.requiredExtraInfo = EXTRA_INFO_QUICK_DAMAGE 
	and app.myCurrentUserCan(terminal,PmAdmDamageCodeAdvancedMaint) then
	//and terminal.getConfig(DamageSeverityOptional).Boolean					//06.06.2025 navbk1 #34529
	//and terminal.getConfig(DamageDetailsOptional).Boolean then				//06.06.2025 navbk1 #34529
		self.requiredExtraInfo:=self.requiredExtraInfo &amp; " Advanced";
	endif;
	
	toDoTaskDesc := _cargoCheckItem.myToDoTaskDesc;
	if toDoTaskDesc &lt;&gt; null then
		self.toDoTaskDescCode := toDoTaskDesc.code.String;
		self.toDoTaskDescDesc := toDoTaskDesc.description;
	endif;
	
epilog

end;</source>
        <Parameter name="_cargoCheckItem" type="CM_CargoCheckItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObjectAndSeals" id="59c541ca-6b59-48b4-b6f2-bd6ac959fbe1">
        <updating/>
        <source>setProxyFromObjectAndSeals(_obj : CM_Object; _sealType : CM_SealType; _cargoCheckItem : CM_CargoCheckItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2011	cnwndl1	Initial creation

*/

vars

	toDoTaskDesc : CM_ToDoTaskDesc;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;

begin

	self.setProxyFromObject(_cargoCheckItem);
	
	//Seals check data
	if _cargoCheckItem.requiredExtraInfo = EXTRA_INFO_SEALS then
	
		if _obj = null then
			return;
			
		elseif _obj.isKindOf( CM_TrackedItem ) then
		
			ti := _obj.CM_TrackedItem;
			if _cargoCheckItem.myCargoCheck.context = CARGO_CHECK_CONTEXT_TMANLOAD then
				self.sealCheckType := ti.getSealCheckTypeForContext(CARGO_CHECK_CONTEXT_SHIP_LOAD); // yes deliberately use the Ship one...
			elseif _cargoCheckItem.myCargoCheck.context = CARGO_CHECK_CONTEXT_TMANDISC then
				self.sealCheckType := ti.getSealCheckTypeForContext(CARGO_CHECK_CONTEXT_SHIP_DISC);
			endif;
			
			self.name:=_sealType.description;
			
			if _sealType &lt;&gt; null then
				self.sealValue := ti.getSealValue( _sealType );
			endif;
			
			self.showSealValue := _sealType.showSealOnCheck;
			
		elseif _obj.isKindOf( CM_Terminal) then
			terminal := _obj.CM_Terminal;
			self.sealCheckType := terminal.getSealCheckTypeForContext(_cargoCheckItem.myCargoCheck.context);
			/*if _cargoCheckItem.myCargoCheck.context = CARGO_CHECK_CONTEXT_TMANLOAD then
				self.sealCheckType := terminal.getSealCheckTypeForContext(CARGO_CHECK_CONTEXT_SHIP_LOAD); // yes deliberately use the Ship one...
			elseif _cargoCheckItem.myCargoCheck.context = CARGO_CHECK_CONTEXT_TMANDISC then
				self.sealCheckType := terminal.getSealCheckTypeForContext(CARGO_CHECK_CONTEXT_SHIP_DISC);
			endif;*/
		
		endif;
	
		
		
	endif;
	
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_cargoCheckItem" type="CM_CargoCheckItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromSealType" id="3f999de0-6cab-4ba4-b538-2b8b77c91344">
        <updating/>
        <source>setProxyFromSealType(_sealType : CM_SealType; _cargo : CM_TrackedItem) updating;
/*
Purpose:			
Date				Who			Reason
FEBRUARY		CNWAB1		Initial creation
*/


vars

	toDoTaskDesc : CM_ToDoTaskDesc;
	terminal : CM_Terminal;
begin

	self.cmObjectEdition	:= _sealType.edition();
	self.cmObjectId			:= _sealType.getOidAsString();
	
	self.name:=_sealType.description;
	self.sealType := _sealType.sealType;
	
	self.showSealValue := _sealType.showSealOnCheck;
	
	self.sealCheckType := SEAL_CHECK_FULL;
	self.sealValue := _cargo.getSealValue(_sealType);
	

epilog

end;</source>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromSealTypeCargoCheck" id="ba75eeb9-4326-4e2c-a8c2-8aaf8776ea2d">
        <updating/>
        <source>setProxyFromSealTypeCargoCheck(_cargoCheckItem : CM_CargoCheckItem; _sealType : CM_SealType; _cargo : CM_TrackedItem) updating;
/*
Purpose:			
Date				Who			Reason
FEBRUARY		CNWAB1		Initial creation
*/


vars

	toDoTaskDesc : CM_ToDoTaskDesc;

begin

	self.cmObjectEdition	:= _sealType.edition();
	self.cmObjectId			:= _sealType.getOidAsString();
	
	self.context:=_cargoCheckItem.myCargoCheck.context;
	self.name:=_sealType.description;
	self.sealType := _sealType.sealType;
	
	self.required:=_cargoCheckItem.required;
	self.requiredExtraInfo := _cargoCheckItem.requiredExtraInfo;
	
	self.sealCheckType := _cargo.getSealCheckTypeForContext(self.context );
	self.sealValue := _cargo.getSealValue(_sealType);
	self.showSealValue := _sealType.showSealOnCheck;
	
	toDoTaskDesc := _cargoCheckItem.myToDoTaskDesc;
	if toDoTaskDesc &lt;&gt; null then
		self.toDoTaskDescCode := toDoTaskDesc.code.String;
		self.toDoTaskDescDesc := toDoTaskDesc.description;
	endif;
	
epilog

end;</source>
        <Parameter name="_cargoCheckItem" type="CM_CargoCheckItem"/>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
