<Class name="HMS_WharfLockout">
    <JadeMethod name="importPLXMLReference" id="252f8d49-9f09-4266-b5f1-e2b3559869fa">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = HMS_WharfLockout::myHarbour.name then
		return app.getMyHarbour();
	elseif _name = HMS_WharfLockout::myHarbourPermLockout.name then
		if _theCode &lt;&gt; null then
			return app.getMyHarbour();
		endif;
	elseif _name = HMS_WharfLockout::myWharf.name then
		return app.getMyHarbour().allWharves[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
