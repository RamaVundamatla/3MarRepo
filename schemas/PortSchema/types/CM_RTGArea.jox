    <JadeMethod name="getUniqueLaneRows" id="018e3c93-08ae-4a33-956a-b1e9206ff043">
        <source>getUniqueLaneRows( _arrRows : ObjectArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2009	cnwjk3	SFW1030

*/

vars
	iter		: Iterator;
	row			: CM_RTGRow;
	prevLabel,	
	label		: String;
begin
	iter := self.allGridRows.createIterator();
	while iter.next(row) do
			
		label := row.getLaneLabel();
		if label = null then
			continue;
		endif;
		if label &lt;&gt; prevLabel then
			prevLabel := label;
			_arrRows.add(row);
		endif;
	
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_arrRows" type="ObjectArray" usage="io"/>
    </JadeMethod>
