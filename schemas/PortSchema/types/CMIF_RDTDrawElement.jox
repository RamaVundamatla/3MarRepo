    <JadeMethod name="drawWheels" id="d1584b45-eb7c-4df2-a446-a3e565f3e00f">
        <source>drawWheels(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: Frame input; _scaleFactor: Real; _colourFirstWheel : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2014	cnwndl1	Initial creation

*/

constants
	//       	       --BBGGRR
	WagonColour 	  = #00CC9966;


vars
	wheelYOffsetPixels,
	innerWheelOffsetPixels,
	innerWheelWidthPixels,
	innerWheelHeightPixels,
	wheelWidthPixels,
	wheelHeightPixels,

	x1, y1,
	x2, y2			: Real;
begin
	x1 := _x1;
	y1 := _y1;
	x2 := _x2;
	y2 := _y2;

	wheelYOffsetPixels := self.getSizeInPixels(2.2, _scaleFactor);
	wheelWidthPixels := self.getSizeInPixels(3, _scaleFactor);
	wheelHeightPixels := self.getSizeInPixels(3, _scaleFactor);
	innerWheelWidthPixels := self.getSizeInPixels(2, _scaleFactor);
	innerWheelHeightPixels := self.getSizeInPixels(2, _scaleFactor);
	innerWheelOffsetPixels := self.getSizeInPixels(.5, _scaleFactor);

	// Draw some wheels
	_frame.drawFillColor := Black;
	
	// Left side outer wheel
	_frame.drawEllipse1(x1 + 2, y1 + wheelYOffsetPixels, x1 + 2 + wheelWidthPixels, y1 + wheelYOffsetPixels + wheelHeightPixels, Black);
	
	// Right side outer wheel
	if _colourFirstWheel = 2 then
		_frame.drawFillColor := Yellow;
		_frame.drawEllipse1(x2 - 2, y1 + wheelYOffsetPixels, x2 - 2 - wheelWidthPixels, y1 + wheelYOffsetPixels + wheelHeightPixels, Yellow);
	else
		_frame.drawFillColor := Black;
		_frame.drawEllipse1(x2 - 2, y1 + wheelYOffsetPixels, x2 - 2 - wheelWidthPixels, y1 + wheelYOffsetPixels + wheelHeightPixels, Black);
	endif;
	
	_frame.drawFillColor := Gray;
	
	// Left side inner wheel
	if _colourFirstWheel = 1 then
		_frame.drawFillColor := Yellow;
		_frame.drawEllipse1(x1 + 2 + innerWheelOffsetPixels, y1 + wheelYOffsetPixels + innerWheelOffsetPixels, x1 + 2 + innerWheelOffsetPixels + innerWheelWidthPixels, y1 + wheelYOffsetPixels + innerWheelOffsetPixels + innerWheelHeightPixels, Yellow);
	else
		_frame.drawFillColor := Gray;
		_frame.drawEllipse1(x1 + 2 + innerWheelOffsetPixels, y1 + wheelYOffsetPixels + innerWheelOffsetPixels, x1 + 2 + innerWheelOffsetPixels + innerWheelWidthPixels, y1 + wheelYOffsetPixels + innerWheelOffsetPixels + innerWheelHeightPixels, Gray);
	endif;
	
	_frame.drawFillColor := Gray;
	
	// Right side inner wheel
	_frame.drawEllipse1(x2 - 2 - innerWheelOffsetPixels, y1 + wheelYOffsetPixels + innerWheelOffsetPixels, x2 - 2 - innerWheelOffsetPixels - innerWheelWidthPixels, y1 + wheelYOffsetPixels + innerWheelOffsetPixels + innerWheelHeightPixels, Gray);
	
	
	
epilog

end;</source>
        <access>protected</access>
