    <JadeMethod name="isAboveCellUnavailable" id="92168b81-1ede-4945-baa0-ab384f4d5afb">
        <source>isAboveCellUnavailable(_slot  : CM_SlotDefn;
                       _tiers : CM_TierDefnByOrdinalDict ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Apr 2021 cnwma1  ChangeRequest 51024: MTN - Add Cell and Tier numbers to Tallyman

*/

vars
	slotTier     : CM_TierDefn;
	aboveTier    : CM_TierDefn;
	aboveSlot    : CM_SlotDefn;
begin

	slotTier := _slot.myTierDefinition;
	
	if slotTier &lt;&gt; null then
		aboveTier := _tiers[slotTier.ordinal+1];
		if aboveTier &lt;&gt; null then
			aboveSlot := aboveTier.allSlotDefinitions[_slot.ordinalDeck,_slot.ordinalCell];
			if aboveSlot &lt;&gt; null and aboveSlot.unavailable then
				return true;
			endif;
		endif;
	
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_slot" type="CM_SlotDefn"/>
        <Parameter name="_tiers" type="CM_TierDefnByOrdinalDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLeftCellUnavailable" id="f3517f5f-1094-45f4-8434-684debb73f20">
        <source>isLeftCellUnavailable(_slot  : CM_SlotDefn;
                      _tiers : CM_TierDefnByOrdinalDict ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Apr 2021 cnwma1  ChangeRequest 51024: MTN - Add Cell and Tier numbers to Tallyman
*/

vars
	leftSlot : CM_SlotDefn;
begin
	leftSlot := _slot.myStarboardSlot;
	
	if leftSlot &lt;&gt; null then
		if leftSlot.unavailable then
			return true;
		endif;
		
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_slot" type="CM_SlotDefn"/>
        <Parameter name="_tiers" type="CM_TierDefnByOrdinalDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRightCellUnavailable" id="70b4b297-3f45-4081-afe2-7c999c4eccdd">
        <source>isRightCellUnavailable(_slot  : CM_SlotDefn;
                       _tiers : CM_TierDefnByOrdinalDict ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Apr 2021 cnwma1  ChangeRequest 51024: MTN - Add Cell and Tier numbers to Tallyman
*/

vars
	rightSlot : CM_SlotDefn;
begin
	rightSlot := _slot.myPortSlot;
	
	if rightSlot &lt;&gt; null then
		if rightSlot.unavailable then
			return true;
		endif;
		
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_slot" type="CM_SlotDefn"/>
        <Parameter name="_tiers" type="CM_TierDefnByOrdinalDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="1eebf3de-19ee-44fa-b92f-068f6e5d3cab">
        <updating/>
        <source>setDetails(	_name : String;
			_fillColour, _lineColour : Integer;
			_points : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2012	cnwer1	Initial creation CCMS MES 1026 par 29962

*/

vars

begin
	self.name:=_name;
	self.fillColour:=_fillColour.cnEcGetHexColor.String;
	self.lineColour:=_lineColour.cnEcGetHexColor.String;
	self.points:=_points;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_fillColour" type="Integer"/>
        <Parameter name="_lineColour" type="Integer"/>
        <Parameter name="_points" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="ee61f01e-f052-425b-bde4-68275fa7e3cc">
        <updating/>
        <source>setProxyFromObject(deckItemLayout: CM_DeckItemLayout) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	inheritMethod(deckItemLayout);
	self.name:=deckItemLayout.code;
	
	//epr par 29921  3/7/12
	if deckItemLayout.myDeckItem &lt;&gt; null and not deckItemLayout.myDeckItem.isLocnGC then
		self.fillColour:=White.cnEcGetHexColor.String;
	else
		if deckItemLayout.drawFillColour = null then
			self.fillColour:=White.cnEcGetHexColor.String;
		else
			self.fillColour:=deckItemLayout.drawFillColour.cnEcGetHexColor.String;
		endif;
	endif;
	self.lineColour:=deckItemLayout.lineColour.cnEcGetHexColor.String;
	self.points:=deckItemLayout.myPolygonPixels.asString;
epilog

end;</source>
        <Parameter name="deckItemLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="setStructureLabels" id="ab5f6ec1-44d4-4b8a-b8dc-0fd7ea1b5e56">
        <updating/>
        <source>setStructureLabels(_tier  : CM_TierDefn;
				   _tiers : CM_TierDefnByOrdinalDict;
				   _slot  : CM_SlotDefnVoyage)updating;

/*

Purpose: 

Parameters:			

Return Value:		


Date		Who		Reason
28 Apr 2021 cnwma1  ChangeRequest 51024: MTN - Add Cell and Tier numbers to Tallyman

*/

vars
	firstSlot,
	lastSlot   : CM_SlotDefn;
begin

	if _slot.mySlotController &lt;&gt; null then
		if _slot.mySlotController.ordinalTier = _tiers.size then
			self.labelTop  := _slot.cellId;
		else
			if self.isAboveCellUnavailable(_slot,_tiers) then
				self.labelTop  := _slot.cellId;
				
			endif;
		endif;
	endif;
	
	//Tier Left
	firstSlot := _tier.allSlotDefinitions.first();
	if firstSlot &lt;&gt; null then
		if firstSlot.unavailable  = false then
			if firstSlot = _slot then
				self.labelLeft := _tier.id;
				return;
			endif;
		else
			if self.isLeftCellUnavailable(_slot,_tiers) then
				self.labelLeft := _tier.id;
				return;
			endif;
		endif;
	endif;
		
	//Tier Right
	lastSlot := _tier.allSlotDefinitions.last();
	if lastSlot &lt;&gt; null then
		if lastSlot.unavailable  = false then
			if lastSlot = _slot then
				self.labelRight := _tier.id;
				return;
			endif;
		else
			if self.isRightCellUnavailable(_slot,_tiers) then
				self.labelRight := _tier.id;
				return;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_tier" type="CM_TierDefn"/>
        <Parameter name="_tiers" type="CM_TierDefnByOrdinalDict"/>
        <Parameter name="_slot" type="CM_SlotDefnVoyage"/>
    </JadeMethod>
</Class>
