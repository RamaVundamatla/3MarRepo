<Class name="CMIF_HMS_MovementDelete" id="af7514eb-5b48-4847-8480-0f8bbb9a6d31">
    <superclass name="CMIF_HMS_StackChange"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ImplicitInverseRef name="appliesToMovement" id="c93c7f2d-2db5-41a1-ae72-8495c62ddd4a">
        <embedded/>
        <type name="CMIF_HMS_WorkingMovement"/>
    </ImplicitInverseRef>
    <JadeMethod name="applyChange" id="9f188875-ba21-4796-ba03-df45e8be79fa">
        <updating/>
        <source>applyChange() updating;

vars

begin
 	// Remove movement from current view, and from is workingVoyage collection
 	// and add it to the list of movements to be deleted
 	appliesToMovement.myViewControllerCurrent := null;
 	appliesToMovement.myVoyageForDisplay := null;

 	if appliesToMovement.myPersistentMovement &lt;&gt; null then
 		ofViewController.allDeletedMovements.add(appliesToMovement.myPersistentMovement);
    endif;

    // Update views
 	ofViewController.view_NewSelectedMovement(ofViewController.myCurrentWorkingVoyage.allWorkingMovements.first.CMIF_HMS_WorkingMovement, false);


end;</source>
    </JadeMethod>
    <JadeMethod name="getMyWorkingMovement" id="74407e3e-c5df-4cde-9b57-4d8d9a1792b2">
        <source>getMyWorkingMovement(): CMIF_HMS_WorkingMovement;
//--------------------------------------------------
// Created:	20 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.appliesToMovement;

end;</source>
        <ReturnType type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="undoChange" id="2e79f378-52ad-4ed0-9d1a-915289d07431">
        <updating/>
        <source>undoChange() updating;

vars

begin
	// Add movement to current view, and to its workingVoyage collection
 	// and remove it to the list of movements to be deleted
 	appliesToMovement.myViewControllerCurrent:=ofViewController;
 	appliesToMovement.myVoyageForDisplay:=appliesToMovement.myWorkingVoyage;


 	if appliesToMovement.myPersistentMovement&lt;&gt;null then
 		ofViewController.allDeletedMovements.remove(appliesToMovement.myPersistentMovement);
    endif;

	// Update views
 	ofViewController.view_NewSelectedMovement(appliesToMovement, false);
end;</source>
    </JadeMethod>
</Class>
