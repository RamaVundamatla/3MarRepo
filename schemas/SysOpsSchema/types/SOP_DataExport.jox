    <JadeMethod name="extractDefinitionToFile" id="42914501-dd30-4f39-bd4b-e9be09a7b294">
        <updating/>
        <source>extractDefinitionToFile() updating;
//02/06/2010 cnwdz2 24641
// Changed On	By			reason
// ----------	--------	---------------------------------------------------------------------
// 23/11/2017	jlgdap1		TFS 7511 LNX Changes to allow attributes with the same name in different subclasses to be extracted
vars
	root                : CM_Root;
	definition          : CM_DataDumpExtractDef;
	sqlTable            : CM_DataDumpExtractClass;
	sqlColumn           : CM_DataDumpSQLColumn;
	sqlDataType         : CM_DataDumpSQLDataType;
	jadeFeature         : CM_DataDumpFeature;
	description         : String;
	//file                : File;
	//cmd                 : CMDFileOpen;
	
	filePath			: String;
	file				: File;
begin

	if self.myCurrentObject = null then
		return;
	endif;
	
	definition := self.myCurrentObject.CM_DataDumpExtractDef;
	
	// pass null path so opens where last open at
	filePath := app.getFilePath(null, '*' &amp; self.SQLNative_DefExportFileFormat, definition.description, false);
		
	if filePath = null then
		return;
	endif;	
	
	if filePath.toLower.pos(self.SQLNative_DefExportFileFormat, 1) &lt;= 0 then
		filePath := filePath &amp; self.SQLNative_DefExportFileFormat;
	endif;
	
	create file transient;
	file.fileName := filePath;
	file.mode := File.Mode_Output;

	if (not file.tryOpen) then
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
		return;
	endif;
		
	file.purge();
	app.mousePointer := Busy;
	
	file.writeLine("[Definition]");
	file.writeLine("alertLimit" &amp; Tab &amp; definition.alertLimit.String);
	file.writeLine("createSQLStatements" &amp; Tab &amp; definition.createSQLStatements.String);
	file.writeLine("definitionModified"  &amp; Tab &amp; definition.definitionModified.String);
	file.writeLine("description"         &amp; Tab &amp; definition.description.String);
	file.writeLine("edbConnectionString" &amp; Tab &amp; definition.edbConnectionString.String);
	file.writeLine("edbMachineDSN"       &amp; Tab &amp; definition.edbMachineDSN.String);
	file.writeLine("edbPassword"         &amp; Tab &amp; definition.edbPassword.String);
	file.writeLine("edbServerName"       &amp; Tab &amp; definition.edbServerName.String);
	file.writeLine("edbUserName"         &amp; Tab &amp; definition.edbUserName.String);
	file.writeLine("extractFormat"       &amp; Tab &amp; definition.extractFormat.String);
	file.writeLine("fileFolderName"      &amp; Tab &amp; definition.fileFolderName.String);
	file.writeLine("ignoreDeletesFromUser" &amp; Tab &amp; definition.getIgnoreDeletesFromUserCode.String);	//07 Jan 2014	NDL	Par 33264
	file.writeLine("isActive"            &amp; Tab &amp; definition.isActive.String);
	//file.writeLine("myTerminal"          &amp; Tab &amp; definition.myTerminal.name.String);
	file.writeLine("oidColumnName"       &amp; Tab &amp; definition.oidColumnName.String);
	file.writeLine("oidFormat"           &amp; Tab &amp; definition.oidFormat.String);
	file.writeLine("sqlDatabaseName"     &amp; Tab &amp; definition.sqlDatabaseName.String);
	file.writeLine("sqlServerVersion"    &amp; Tab &amp; definition.sqlServerVersion.String);
	file.writeLine("[Definition End]");

//	file.writeLine("[ExtractClass]");
	foreach sqlTable in definition.allDataDumpExtractClasses do
		file.writeLine("[SQLTable]");
		file.writeLine("className"               &amp; Tab &amp; sqlTable.className.String);
		file.writeLine("deleteAction"            &amp; Tab &amp; sqlTable.deleteAction.String);
		file.writeLine("deleteActionColumnName"  &amp; Tab &amp; sqlTable.deleteActionColumnName.String);
		file.writeLine("deleteActionColumnPos"   &amp; Tab &amp; sqlTable.deleteActionColumnPos.String);
		file.writeLine("exportedTimestampColumnName" &amp; Tab &amp; sqlTable.exportedTimestampColumnName.String);
		file.writeLine("exportedTimestampColumnPos" &amp; Tab &amp; sqlTable.exportedTimestampColumnPos.String);
		file.writeLine("extractedUpToDateTime"   &amp; Tab &amp; sqlTable.extractedUpToDateTime.String);
		file.writeLine("lastOperation"           &amp; Tab &amp; sqlTable.lastOperation.String);
		file.writeLine("lastOperationColumnName" &amp; Tab &amp; sqlTable.lastOperationColumnName.String);
		file.writeLine("lastOperationColumnPos" &amp; Tab &amp; sqlTable.lastOperationColumnPos.String);
		file.writeLine("myDataDumpClass"         &amp; Tab &amp; sqlTable.myDataDumpClass.className.String);
		file.writeLine("myDataDumpExtractDef"    &amp; Tab &amp; sqlTable.myDataDumpExtractDef.description.String);
		file.writeLine("oidColumnPos"            &amp; Tab &amp; sqlTable.oidColumnPos.String);
		file.writeLine("sqlTableName"            &amp; Tab &amp; sqlTable.sqlTableName.String);
		file.writeLine("[SQLTable End]");

//		file.writeLine("[Features]");
		foreach jadeFeature in sqlTable.allDataDumpFeatures do
			file.writeLine("[Feature]");
			file.writeLine("featureName"         &amp; Tab &amp; jadeFeature.featureName.String);
			file.writeLine("featureNiceName"     &amp; Tab &amp; jadeFeature.featureNiceName.String);
			file.writeLine("isFeatureProtected"  &amp; Tab &amp; jadeFeature.isFeatureProtected.String);
			file.writeLine("isProtected"         &amp; Tab &amp; jadeFeature.isProtected.String);
			file.writeLine("myFeature"           &amp; Tab &amp; jadeFeature.myFeature.String);
			file.writeLine("mySubClassFeatureType"&amp; Tab &amp; jadeFeature.mySubClassFeatureType.String);
			file.writeLine("newLength"           &amp; Tab &amp; jadeFeature.newLength.String);
			file.writeLine("newName"             &amp; Tab &amp; jadeFeature.newName.String);
			file.writeLine("newType"             &amp; Tab &amp; jadeFeature.newType.String);
			file.writeLine("returnValueIsAnObject"&amp; Tab &amp; jadeFeature.returnValueIsAnObject.String);
			file.writeLine("subClassName"        &amp; Tab &amp; jadeFeature.subClassName.String);
			file.writeLine("[Feature End]");
		endforeach;
		
//		file.writeLine("[SQLColumns]");
		foreach sqlColumn in sqlTable.allDataDumpSQLColumns do
			file.writeLine("[SQLColumn]");
			file.writeLine("decimalDigits"       &amp; Tab &amp; sqlColumn.decimalDigits.String);
			file.writeLine("isMaximumLength"     &amp; Tab &amp; sqlColumn.isMaximumLength.String);
			file.writeLine("length"              &amp; Tab &amp; sqlColumn.length.String);
			file.writeLine("name"                &amp; Tab &amp; sqlColumn.name.String);
			file.writeLine("myDataDumpFeature"   &amp; Tab &amp; sqlColumn.myDataDumpFeature.featureName);
			file.writeLine("myDataDumpSQLDataType"&amp; Tab &amp; sqlColumn.myDataDumpSQLDataType.name);
			file.writeLine("sqlColumnOrdinalPosition"&amp; Tab &amp; sqlColumn.sqlColumnOrdinalPosition.String);
			file.writeLine("subClassName"		 &amp; Tab &amp; sqlColumn.myDataDumpFeature.subClassName);			// TFS 7511
			file.writeLine("[SQLColumn End]");
		endforeach;
	endforeach;

epilog
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;
	app.mousePointer := Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="findUnusedFeatures" id="3dab1cb9-6b85-413c-9592-fd81e89857a9">
        <source>findUnusedFeatures();

vars
	def : CM_DataDumpExtractDef;
	ddExtClass : CM_DataDumpExtractClass;		
	sysFeature : CM_DataDumpFeature;
	str : String;
	allWarnings : HugeStringArray;
begin
	create allWarnings transient;
	def := self.myCurrentObject.CM_DataDumpExtractDef;
	foreach ddExtClass in def.allDataDumpExtractClasses do
		foreach sysFeature in ddExtClass.myDataDumpClass.allDataDumpFeatures do
			if not ddExtClass.allDataDumpFeatures.includes(sysFeature) then
				allWarnings.add(ddExtClass.className&amp;' '&amp;sysFeature.featureName);
			endif;
		endforeach;
	endforeach;
//	foreach str in allWarnings do
//		write str;
//	endforeach;
	app.showErrorWarningDialogArray("Dat Export Maintanence Features Available", null, allWarnings, ErrWarnMode_CanAckWarnings);
epilog
	delete allWarnings;
end;</source>
    </JadeMethod>
    <JadeMethod name="fldInput_querySheetChg" id="54b5ea78-a803-44c4-a6c9-185f8936d037">
        <controlMethod name="CMUI_Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldInput_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	#cnwdz2	 

*/

vars
	extractFormat : String;
	oidFormat : String;
	oidColName : String;
begin
	if newSheet = self.shtExtractClass then
		extractFormat := self.tblExtractDef.getValueByName(ETRow_ExtractFormat).String;
		if extractFormat = global.getExtractFormatDescr(CM_DataDumpExtractDef.FmtSQLNative) then
			oidFormat := self.tblExtractDef.getValueByName(ETRow_OidFormat).String;
			if oidFormat = null then
				app.msgBox(app.getErrorString(ERR_NULLOIDFORMAT),
					   app.getErrorString(ERR_NULLOIDFORMATMSGTITLE),MsgBox_Exclamation_Mark_Icon);
				return false;
			endif;
			
			oidColName := self.tblExtractDef.getValueByName(ETRow_OidColumnName).String;
			if oidColName = null then
				app.msgBox(app.getErrorString(ERR_NULLOIDCOLUMN),
					   app.getErrorString(ERR_NULLOIDCOLUMNTITLE),MsgBox_Exclamation_Mark_Icon);
				return false;
			endif;
			
			self.tblExtractClass.userInputEnabled := false;
			self.mulFeatures.userInputEnabled := false;
		endif;
	endif;
	return true;
epilog

end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fldInput_sheetChg" id="59baa099-473b-4424-bd79-decb6792cbd5">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldInput_sheetChg(folder: Folder input) updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if folder.topSheet = self.shtExtFeature then
		self.doShtExtFeatureClick(self.cmbSelectedClass);
	elseif folder.topSheet = self.shtExtractObject then
		self.doShtExtFeatureClick(self.cmbSctObjClass);
	else
		if self.mode &lt;&gt; Mode_View then //rs1 mar 2006 par 11448
			self.doSaveSelectedFeatures();
		endif;
	endif;

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
