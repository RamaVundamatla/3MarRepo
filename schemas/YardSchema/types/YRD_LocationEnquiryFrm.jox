    <JadeMethod name="doMnuFIFODateClick" id="3b3bdeb1-396c-499d-a703-0eb62217b7ca">
        <updating/>
        <source>doMnuFIFODateClick(theMenuItem: MenuItem) updating;
//--------------------------------------------------
// Created:	22 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	result : Integer;
begin
	inheritMethod(theMenuItem);
	if self.filterTerminalArea = null then
		return;
	endif;
	if (not self.filterTerminalArea.isKindOf(CM_BlockStack)) then
		return;			
	endif;	
	while true do
		app.myTrxUA.trxUpdateBlockstackFIFODate(self.filterTerminalArea.CM_BlockStack, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Recalculate FIFO Date', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
		
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridPlanDischargeClick" id="a4e06a1f-32de-4c20-8f5e-822bc38e5b4e">
        <updating/>
        <source>doMnuGridPlanDischargeClick(theMenuItem : MenuItem) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	toLocation : CM_LocationsController;
begin
	// NOTE the TI and the source location have already been set on the build of the context menu
	if theMenuItem.userObject &lt;&gt; null then
		toLocation := theMenuItem.userObject.CM_LocationsController;
		if toLocation.myTerminalArea = null or not CM_BlockStack.hasInstance(toLocation.myTerminalArea) then
			return;
		endif;
		self.moveTrackedItemTarget(toLocation);

	endif;
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridPlanLoadClick" id="aa1507cb-8d38-40b6-8173-d279638de796">
        <updating/>
        <source>doMnuGridPlanLoadClick(theMenuItem : MenuItem) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//				July 2010	24442 add bulk plan load
// Purpose:		
// ---------------------------------------------------------------------------
vars
	obj	: Object;
	ti	: CM_TrackedItem;
	tiArray	: CM_TIArray;
begin
	// NOTE the TI and the source location have already been set on the build of the context menu
	if theMenuItem.userObject.isKindOf(CM_LocationsController) then
		self.moveTrackedItemSource();
	else
		create tiArray transient;
		foreach obj in tblData.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) then
				ti := obj.CM_TrackedItem;
				tiArray.add(ti);
			endif;
		endforeach;
		self.moveTrackedItemsSource(tiArray);
	endif;
epilog
	delete tiArray;
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridTBAClick" id="7ffa1cd7-046a-4eb5-9d10-9d3345d847ec">
        <source>doMnuGridTBAClick();
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTA			: CM_TerminalArea;
	voyage 			: CM_Voyage;
	source, target 	: CM_LocationsController;
begin


	theTA := self.filterTerminalArea;
	
	if theTA = null then
		return;
	endif;



	source := theTA.getLocationsController();
	
	if app.myMoveController &lt;&gt; null then
		target := app.myMoveController.myToPrimaryLocation;
		if target &lt;&gt; null then
			if CM_VoyageController.hasInstance(target) then
				voyage := target.CM_VoyageController.myVoyage;
			endif;
		endif;
	else
		//voyage := app.myCurrentVoyage;
		//cnwjo3 par 23105
		voyage := app.getMyCurrentVoyage();
	endif;
	self.myAssistant.showTBAEntryForm(source,target, voyage);		



end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuInterTerminalRelease" id="b6ca05c0-bbda-4fed-9bcf-0a5e376ec7c4">
        <updating/>
        <source>doMnuInterTerminalRelease() protected, updating;
// -------------------------------------------
// Created 23 July 2004 by cnwdvb1
// -------------------------------------------
vars

	tiSet	: CM_TISet;
	obj		: Object;
	ta		: CM_InterTerminalTransferArea;
	result	: Integer;

begin
	inheritMethod();
	if self.filterTerminalArea = null or not CM_InterTerminalTransferArea.hasInstance(self.filterTerminalArea) then
		return;
	endif;
	ta := self.filterTerminalArea.CM_InterTerminalTransferArea;
	create tiSet transient;
	foreach obj in self.tblData.allSelectedObjects do
		tiSet.add(obj.CM_TrackedItem);
	endforeach;
	
	while true do
		app.myTrxUA.trxInterTerminalMove(ta, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Release Inter Terminal Cargo', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;


epilog
	delete tiSet;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuOverlappingClick" id="553c1c65-3f3e-48f6-afc3-48602b4685eb">
        <updating/>
        <source>doMnuOverlappingClick(theMenuItem: MenuItem) updating;
//--------------------------------------------------
// Created:	22 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	result : Integer;
begin
	inheritMethod(theMenuItem);
	if self.filterTerminalArea = null then
		return;
	endif;
	if (not self.filterTerminalArea.isKindOf(CM_BlockStack)) then
		return;			
	endif;
	self.sharedLock(self.filterTerminalArea);
	while true do
		app.myTrxUA.trxUpdateBlockStackOverlapped(self.filterTerminalArea.CM_BlockStack, (not self.mnuOverlapping.checked), app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Mark as Overlapping', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	self.unlock(self.filterTerminalArea);		
end;</source>
