    <JadeMethod name="btnStart_click" id="8dd0c07d-eadd-444d-8cf3-c9233f5b4dba">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStart_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doFormUpdate() then
		unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkIsClassFile_click" id="6511fd84-39f5-4158-8b02-544fe13e1f53">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkIsClassFile_click(checkbox: CheckBox input) updating;
// --------------------------------------------------------------------------------
// Created:		29 October 2002 by cnwdad3
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if checkbox.value then
		lblInputFile.enabled	:=	true;
		txtInputFile.enabled	:=	true;
		btnBrowseInput.enabled	:=	true;
	else
		lblInputFile.enabled	:=	false;
		txtInputFile.enabled	:=	false;
		btnBrowseInput.enabled	:=	false;
		txtInputFile.text		:=	null;
	endif;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkIsHeaderLogo_click" id="79208bc5-5466-4729-8ec7-da11ffd9c132">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkIsHeaderLogo_click(checkbox: CheckBox input) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if checkbox.value then
		lblLogo.enabled			:=	true;
		txtLogo.enabled			:=	true;
		btnBrowseLogo.enabled	:=	true;
	else
		lblLogo.enabled			:=	false;
		txtLogo.cnEcSet(null);
		txtLogo.enabled			:=	false;
		btnBrowseLogo.enabled	:=	false;
	endif;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkIsHeaderPage_click" id="d636ff6b-6122-4dc4-9b1a-f066e81b8507">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkIsHeaderPage_click(checkbox: CheckBox input) updating;
// --------------------------------------------------------------------------------
// Created:		30 October 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if checkbox.value then
		txtGroupName.enabled	:=	true;
		txtDocTitle.enabled		:=	true;
		txtDocVersion.enabled	:=	true;
		txtDocDate.enabled		:=	true;
		chkIsHeaderLogo.enabled	:=	true;
		
		if chkIsHeaderLogo.value then
			lblLogo.enabled			:=	true;
			txtLogo.enabled			:=	true;
			btnBrowseLogo.enabled	:=	true;
		else
			lblLogo.enabled			:=	false;
			txtLogo.cnEcSet(null);
			txtLogo.enabled			:=	false;
			btnBrowseLogo.enabled	:=	false;
		endif;
	else
		txtGroupName.enabled	:=	false;
		txtGroupName.cnEcSet(null);
		txtDocTitle.enabled		:=	false;
		txtDocTitle.cnEcSet(null);
		txtDocVersion.enabled	:=	false;
		txtDocVersion.cnEcSet(null);
		txtDocDate.enabled		:=	false;
		txtDocDate.cnEcSet(null);
		chkIsHeaderLogo.enabled	:=	false;
		chkIsHeaderLogo.cnEcSet(false);
		lblLogo.enabled			:=	false;
		txtLogo.cnEcSet(null);
		txtLogo.enabled			:=	false;
		btnBrowseLogo.enabled	:=	false;
	endif;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkIsPrefacePage_click" id="89dfadde-489a-419f-9601-4e39f3366b5d">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkIsPrefacePage_click(checkbox: CheckBox input) updating;
// --------------------------------------------------------------------------------
// Created:		30 October 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if checkbox.value then
		txtOverview.enabled		:=	true;
		btnSpellCheck.enabled	:=	true;
	else
		txtOverview.text		:=	null;
		txtOverview.enabled		:=	false;
		btnSpellCheck.enabled	:=	false;
	endif;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBottomSchema_displayEntry" id="be4c4d5c-7bca-4779-922f-86710c312440">
