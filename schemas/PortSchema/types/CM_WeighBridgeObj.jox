    <JadeMethod name="validateForCreate" id="b172a4ed-53f8-4570-8994-5ac645109beb">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	self.validateMe();
	
	if self.myTerminal &lt;&gt; null and self.myTerminal.allWeighBridges.getAtKey(self.name) &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.name, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="1a4a88bf-a619-4659-9be3-8c9ce1f6d0ed">
