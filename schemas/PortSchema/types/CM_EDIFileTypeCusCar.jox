    <JadeMethod name="findEDIDataType" id="19fa85f3-6bff-4aa5-a336-21504d324f86">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010

//----------------------------------------------------------------
//	Created:	Nov 2005	by Russell Sargent
//----------------------------------------------------------------
vars

begin
	_ediDataClass := CM_EDIDataBayPlan;
	_dataType := EDIDataType_BayPlan;
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllEDIDataTypes" id="be00349e-5982-410f-8876-442f61ebb743">
        <source>getAllEDIDataTypes(_coll: IntegerArray input);
/*

Purpose: Allows CusCar to be Ship Manifest as well as Bayplan			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2014	cnwgb1	Initial creation CCMS PEN 2352 PAR 33795

*/

vars

begin
	if not _coll.includes (EDIDataType_BayPlan) then
		_coll.add (EDIDataType_BayPlan);
	endif;
	
	if not _coll.includes (EDIDataType_ShipManifest) then
		_coll.add (EDIDataType_ShipManifest);
	endif;
epilog

end;</source>
        <Parameter name="_coll" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="36f57835-1efa-4017-a33d-899fb881a8e0">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2025	navkc1	JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return self.EDI_Bundle_CUSTOM;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEDIPartyRules" id="f8c8379d-80fa-4f59-96d7-b43df19afb0d">
        <source>getEDIPartyRules(_ediParty: CM_EDIParty): CM_EDIPartyRules protected;
/*

Purpose: Obtain the EDI Party rules for this file type		

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2014	cnwgb1	Initial creation CCMS PENN 2352 PAR 33795

*/

vars

begin
	if _ediParty = null then
		return null;
	endif;
	
	return _ediParty.getRulesForFileType (EDIFileType_CusCar);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediParty" type="CM_EDIParty"/>
        <ReturnType type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACTSegment" id="256c46cd-9200-43eb-bea2-1377dd209c75">
        <source>processEDIFACTSegment(_msgHelper: CMIF_EDIFACTHelper io; _ediFile: CM_EDIFile input; _ediData: CM_EDIData io; _ediOperator: CM_Operator io; _ediPartyRules: CM_EDIPartyCuscarRules; _reload: Boolean;_version : String) protected;
/*

Purpose: This contains the loop which processes the segments of a CUSCAR. Only the BGM is processed here.
         At the time of processing the BGM, we decide if this is going to create a Ship Manifest or a BayPlan (EDI Party Rule) 

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2014	cnwgb1	Initial creation for CCMS PENN 2352 PAR 33795
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
14 Jun 2016 cnwma1	TFS #2048 POL - HSD EDI Empty Release Request Adding version to the signature
// 29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
    ediData :CM_EDIData; 				// BGM local variable
    ediType :Integer;
    isManifest :Boolean;
    params :CMIF_EDIFACTParams; 		// BGM local variable
    passport :CM_Passport;
    terminal :CM_Terminal;
    trackedItemDict :DynaDictionary;
	ediFileType : CM_EDIFileType;
begin
    
//BGM
    params := _msgHelper.myCurrentParams;
    // There's nothing special about BGM apart from the fact that it is at the beginning, so we evaluate the rule deciding the Data Type here.
    if _msgHelper.currentTag = "BGM" then
        
        //Determine the kind of Data to return.
		if _ediPartyRules &lt;&gt; null then
			isManifest := _ediPartyRules.ediTypeShipManifest;
		endif;
        
        passport := app.myPassport;
        terminal := passport.myTerminal;
       
        _msgHelper.setCurrentGroup(0);
        _msgHelper.setNextField();
        
        if params &lt;&gt; null then
            params.clearAll();
        endif;

       params.thisPort := terminal.getConfig(PortDestCode).String;
       //params.cargoTypeCode := app.myRoot.getCargoTypeIDFromAbbrev("CHD GEN"); // cnwgb1 PAR 34171 20.5.2014
	   
		if _ediPartyRules &lt;&gt; null and _ediPartyRules.myChildCargoTypeDefault &lt;&gt; null then		
			params.cargoTypeCode :=  _ediPartyRules.myChildCargoTypeDefault.id;//cnwrd1 par 34193
		endif;
 		
        if isManifest then
            ediType := EDIDataType_ShipManifest;
            _ediData := null;
            // See if we have already got a Ship Manifest EDI Data for this file. If so use it
            // (This will only happen if there are multiple Ship Manifest BGMs in the file.
            if _ediFile.allEDIData.size &gt; 0 then
                foreach ediData in _ediFile.allEDIData do
                    if ediData.isKindOf(CM_EDIDataShipManifest) then
                        _ediData := ediData;
                        break;
                    endif;
                endforeach;
            endif;
            // If we don't have a prexisting Ship Manifest EDI Data, create one.
            if _ediData = null then
                app.myUtilityCA.utlCreateEDIData(_ediData, CM_EDIDataShipManifest, ediType, EDIFileType_CusCar, _ediFile.ediConfig, _ediFile, ediFileType, app.myPassport);
                _ediData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
            endif;
            
            if params.allEDIItems = null then
                create trackedItemDict transient;
                trackedItemDict.setMembership(CM_EDICargoOnShipTI);
                trackedItemDict.addMemberKey(CM_EDICargoOnShipTI::id.name, false, false);
                trackedItemDict.endKeys(true);
                params.allEDIItems := trackedItemDict;
            endif;

        else
			_ediData := _ediFile.ediData;
        endif;

        _msgHelper.setNextField();
        _msgHelper.setNextField();
        
        if     _msgHelper.currentField = "1" then
            _msgHelper.setCurrentMessageMode(CM_EDITrackedItem.EDI_ACTION_DELETE);
        elseif _msgHelper.currentField = "5" then
            _msgHelper.setCurrentMessageMode(CM_EDITrackedItem.EDI_ACTION_UPDATE);
        elseif _msgHelper.currentField = "9" then
            _msgHelper.setCurrentMessageMode(CM_EDITrackedItem.EDI_ACTION_ADD);
        else
             _msgHelper.setCurrentMessageMode(CM_EDITrackedItem.EDI_ACTION_ADD);
        endif;

        // get default commodity codes to use for EQD, DGS &amp; TMP segments
        app.getTerminalDefCmdty(params.mtCmdty, params.defCmdty, params.refCmdty, params.hazCmdty);
		
        params.mySenderOperator := _ediOperator;
		
        if _ediOperator &lt;&gt; null then
            params.senderOperatorCode := _ediOperator.code;
        endif;
        
		if _reload then
			_ediData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
		endif;
	else
		if not params.skipTillNextBGM then
			if _ediData.isKindOf(CM_EDIDataBayPlan) /*and
                app.myRoot.canDoEDIFileType(EDIFileType_CusCar) */ then
                self.processFileBayplan(_msgHelper, _ediFile, _ediData, _ediOperator, _ediPartyRules);
			else
                self.processFileManifest(_msgHelper, _ediFile, _ediData, _ediOperator, _ediPartyRules);
			endif;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="io"/>
        <Parameter name="_ediOperator" type="CM_Operator" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCuscarRules"/>
        <Parameter name="_reload" type="Boolean"/>
        <Parameter name="_version" type="String"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="6e1b7991-6b89-4dd6-aa59-58965a370527">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
// 27 Apr 2014 cnwgb1 CCMS PENN 2352 Code refactored out to processEDIFACTSegment, processFileBayplan nd processFileManifest
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
   	ediData : CM_EDIData;
	ediTI : CM_EDITrackedItem;
	ediTI2 : CM_EDITrackedItem;
begin
    self.processEDIFACTFile(_ediFile, ediData, false);
	foreach ediTI in ediData.allEDITrackedItems do
		ediTI.setMyEDIConfig(ediData.ediConfig);
		foreach ediTI2 in ediTI.myAttachedItems do
			ediTI2.setMyEDIConfig(ediData.ediConfig);
		endforeach;
	endforeach;	
	self.cleanupEDIData(_ediFile);

end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processFileBayplan" id="13910e5c-3b64-43f1-a10a-5a1320f91cfd">
        <source>processFileBayplan(_msgHelper: CMIF_EDIFACTHelper io; _ediFile : CM_EDIFile input; _ediData : CM_EDIData input; _ediOperator : CM_Operator io; _ediPartyRules :CM_EDIPartyRules) protected;
/*

Purpose:Bayplan processing is the default for CUSCAR (as it was the original processing) This code has been refactored
		from the original processFile

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
16 Apr 2014	cnwgb1	Initial creation CCMS PEN 2352 BOL Handling via CUSCAR
24 Jan 2018	jlgrs1	TFS 36826 	AAT Cuscar cargotype
08 May 2018	jlgrs1	TFS 36425 	SingleLine Booking partial processing not working
29 Jan 2019	jlgrs1	TFS 43144 	CusCar not working after changes for TFS 41659 42276
07 Apr 2019	jlgrs1	TFS 41913 	STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
13 May 2019	jlgka1	TFS 42732 	PNL - CUSCAR (Bayplan-Style) does not load some attributes from the file.
								Also fixed some stackdump cause by _ediOperator not being check if null before using.
09 Aug 2019	jlgdap1	TFS 45979	PNL Cuscar weight missing - rejig MEA segment processing
============================================================================*/
vars
	params 				: CMIF_EDIFACTParams;
	ediTI				: CM_EDIBayPlanTI;
	ediTIPrior			: CM_EDIBayPlanTI;
	ediDataBayPlan		: CM_EDIDataBayPlan;
	voyageCode			: String;
	operatorVoyageCode	: String;
	vesselName			: String;
	lloydsNumber		: String;
	callSign			: String;
	port				: String;
	dtString			: String;
	operatorVoyage		: CM_Operator;
	temperature 		: Real;
	id 					: String;
	haz 				: String;
	undg 				: String;
	foundMatch 			: Boolean;
	cargoTypeCode 		: String;
	cargoType 			: CM_CargoType;
	ruleFunction 		: Integer;  //jlgka1 TFS 42732
	rule 				: CM_EDICUSCARRule; //jlgka1 TFS 42732
begin
	
	params 		:= _msgHelper.myCurrentParams;

	if params.myEDIItem &lt;&gt; null then
		ediTI := params.myEDIItem.CM_EDIBayPlanTI;
	endif;  
	ediDataBayPlan := _ediData.CM_EDIDataBayPlan;
	
	if params.skipTillNextGID then 
		if _msgHelper.currentTag &lt;&gt; "CNI" and 
		   _msgHelper.currentTag &lt;&gt; "UNT" and
		   _msgHelper.currentTag &lt;&gt; "UNZ" then
			return;
		else
			 params.skipTillNextGID := false;
		endif;
	endif;
	  
//CNI
	if _msgHelper.currentTag = "CNI" then	// consignment information
		create ediTI persistent;
		ediTI.setForCreateNew(_ediFile.ediData);
		_msgHelper.setNextField;
		cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Car]; 
		if cargoType = null then
			if _ediOperator &lt;&gt; null then // jlgka1 TFS 42732 
				cargoTypeCode := _ediOperator.getXlationSystemCode("VE", XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);
				if foundMatch then
					ediTI.setCargoType(cargoTypeCode.Integer);
				endif;					// jlgka1 TFS 42732 
			endif;
		else
			ediTI.setCargoType(TI_CargoType_Car);
		endif;
		
		if _ediOperator &lt;&gt; null then // cnwgb1 PAR 34160 16.5.2014
			ediTI.operatorCode := _ediOperator.code;
		endif;
		params.myEDIItem := ediTI;

//DGS
	elseif _msgHelper.currentTag = "DGS" then	// dangerous goods
		
		_msgHelper.setNextField;
		
		if _msgHelper.currentField = "ICA" then	// IATO ICAO
		
		elseif _msgHelper.currentField = "IMD" then	// IMO IMDG
			_msgHelper.setNextField;
			
			haz := _msgHelper.currentSubItem;
			
			_msgHelper.setNextField;
			
			undg := _msgHelper.currentSubItem;	//par26798 cnwrs1 25 Jan 2011
			
			ediTI.imCodes.add(haz &amp; ":+" &amp; undg);
		endif;
//DTM
	elseif _msgHelper.currentTag = "DTM" then	// date time period
		_msgHelper.setNextField;
		if _msgHelper.currentSubItem = "132" then	// date of arrival/departure
			_msgHelper.setNextSubItem;
			dtString := _msgHelper.currentSubItem.trimBlanks;
			_msgHelper.setNextSubItem;
			ediDataBayPlan.arriveTime := dtString.getUNEDIFACTTimeStamp(_msgHelper.currentSubItem.Integer);
		endif;
//EQD
	elseif _msgHelper.currentTag = "EQD" then	// equipment details
		_msgHelper.setNextField;
		if _msgHelper.currentField = "CN" then	// vehicle
			create ediTI persistent;
			ediTI.setForCreateNew(_ediFile.ediData);
			ediTI.rawEDIData := _msgHelper.currentMessage &amp; "'";// As of 16/4/2014 this is just a flag indicating the TI was created by EDI cnwgb1 33795
			
			if ediTI.loadPort = null then
				ediTI.loadPort := params.loadPort;
			endif;
			if _ediOperator &lt;&gt; null then // cnwgb1 PAR 34160 16.5.2014
				ediTI.operatorCode := _ediOperator.code;
			endif;
			ediTI.setCargoType(TI_CargoType_Container);
			params.myEDIItem := ediTI;
			_msgHelper.setNextField;
			
			//cnwmc5 - 8 June 2016 - TFS 2121 - changed to use 'msgHelper.currentSubItem'
			//if _msgHelper.currentField.length &lt; 12 then
			//	ediTI.id := _msgHelper.currentField;
			//else
			//	ediTI.id := _msgHelper.currentField[1:4] &amp; _msgHelper.currentField[6:7];
			//endif;
			if _msgHelper.currentSubItem.length &lt; 12 then
				ediTI.setId(_msgHelper.currentSubItem);
			else
				ediTI.setId(_msgHelper.currentSubItem[1:4] &amp; _msgHelper.currentSubItem[6:7]);
			endif;

		elseif _msgHelper.currentField = "BB" then
			ediTI.setCargoType(TI_CargoType_BreakBulk);
			params.bulkId := params.bulkId + 1;
			ediTI.setIdDefault(params.bulkId.String);
		endif;
//FTX
	elseif _msgHelper.currentTag = "FTX" then	// free text
		_msgHelper.setNextField;
		if _msgHelper.currentField = "AAI" then	// general information
		elseif _msgHelper.currentField = "AAA" then	// goods description
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			//jlgka1 TFS 42732 --&gt;
			if _ediPartyRules &lt;&gt; null then				
				rule := _ediPartyRules.allEDIPartyRules.getEDICuscarRule(CM_EDICUSCARRule.Item_FTX_1_1);				
				if rule &lt;&gt; null then
					ruleFunction := rule.getFunction();
					
					if ruleFunction = CM_EDICUSCARRule.Function_FTX_1_1_Remarks then
						if ediTI &lt;&gt; null then
							ediTI.remarks := _msgHelper.currentSubItem;
						endif;
					
					//29 Jan 2020	NDL	TFS 48360
					elseif ruleFunction = CM_EDICUSCARRule.Function_FTX_1_1_Description then
						if ediTI &lt;&gt; null then
							ediTI.setDescription(_msgHelper.currentSubItem); // NOT Truncated
						endif;
					else//29 Jan 2020	NDL	TFS 48360
						if ediTI &lt;&gt; null then
							ediTI.setDescription(_msgHelper.currentSubItem[1:30]);
						endif;
					endif;
					
				else	
					if ediTI &lt;&gt; null then
						ediTI.setDescription(_msgHelper.currentSubItem[1:30]);
					endif;
				endif;
			else //jlgka1 TFS 42732 &lt;--
				if ediTI &lt;&gt; null then
					ediTI.setDescription(_msgHelper.currentSubItem[1:30]);
				endif;
			endif;			
		elseif _msgHelper.currentField = "PAC" then	// vehicle identification number
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			if ediTI &lt;&gt; null then
				ediTI.setId(_msgHelper.currentSubItem[1:20]);
			endif;
		endif;
//GID
	elseif _msgHelper.currentTag = "GID" then	// goods item details
		params.gidCount := params.gidCount + 1;
		if ediTI &lt;&gt; null then 
			if ediTI.id = null then
				ediTI.setIdDefault(params.gidCount.String);
			endif;
		endif;
		_msgHelper.setNextField;

		if _msgHelper.currentField.Integer &gt; 1 then // another vehicle in the segment
			ediTIPrior := ediTI;
			create ediTI persistent;
			ediTI.setForCreateNew(_ediFile.ediData);
			ediTI.setForUpdate(ediTIPrior);			
			params.myEDIItem := ediTI;
		endif;
		_msgHelper.setNextField;
		_msgHelper.setNextSubItem;
		
		if _msgHelper.currentSubItem &lt;&gt; "VE" then
			params.skipTillNextGID := true;
		endif;
		if _ediOperator &lt;&gt; null then // jlgka1 TFS 42732 
			cargoTypeCode := _ediOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);
			if foundMatch then
				ediTI.setCargoType(cargoTypeCode.Integer);
			endif;
		endif;						// jlgka1 TFS 42732 
//LOC
	elseif _msgHelper.currentTag = "LOC" then	// place/location identification
		_msgHelper.setNextField;
		if _msgHelper.currentField = "9" then//port of Loading
			_msgHelper.setNextField;
			port := _msgHelper.currentSubItem[1:5].trimBlanks;
			if _ediOperator &lt;&gt; null then
				port := _ediOperator.getXlationSystemCode(port, XLATION_TYPE_PORT_BYOP, foundMatch);
			endif;
			if port.length = 5 then
				if ediTI &lt;&gt; null then
					ediTI.loadPort := port[1:5];
				else
					params.loadPort := port[1:5];
				endif;
			else
				if ediTI &lt;&gt; null then
					ediTI.loadPort := port[1:3];
				else
					params.loadPort := port[1:3];
				endif;
			endif;
		elseif _msgHelper.currentField = "11" then//port of Discharge
			_msgHelper.setNextField;
			port := _msgHelper.currentSubItem[1:5].trimBlanks;
			if _ediOperator &lt;&gt; null then
				port := _ediOperator.getXlationSystemCode(port,XLATION_TYPE_PORT_BYOP, foundMatch);
			endif;
			if port.length = 5 then
				ediTI.dischargePort := port[1:5];
			else
				ediTI.dischargePort := port[1:3];
			endif;
			// FD 29/10/02: for baplie and master plan, we should show the gross TIs and the total of the TIs
			// For the user's port . This is purely for a check or review purpose.
			if ediTI.dischargePort =  params.thisPort then
				ediDataBayPlan.loadRecordsForPort := ediDataBayPlan.loadRecordsForPort + 1;
			else
				params.skipTillNextGID := true;
				delete ediTI;
				ediTI := null;
			endif;
		elseif _msgHelper.currentField = "83" then//place of final delivery
			_msgHelper.setNextField;
			port := _msgHelper.currentSubItem[1:5].trimBlanks;
			if _ediOperator &lt;&gt; null then
				port := _ediOperator.getXlationSystemCode(port,XLATION_TYPE_PORT_BYOP, foundMatch);
			endif;
			if port.length = 5 then
				ediTI.destinationPort := port[1:5];
			else
				ediTI.destinationPort := port[1:3];
			endif;
		endif;
//MEA
	elseif _msgHelper.currentTag = "MEA" then	// measurements
		_msgHelper.setNextField;
		// TFS 45979 rejig the MEA stuff to fix PNL issue where the weight was missing 
		// when the line looked like MEA+WT+AAG+KGM:26000
		if _msgHelper.currentField = "WT" or _msgHelper.currentField = "AAE" then
			_msgHelper.setNextField;
			if _msgHelper.currentField = "AAG" then
				_msgHelper.setNextField;
				if _msgHelper.currentSubItem = "KGM" then
					_msgHelper.setNextSubItem;
					if ediTI &lt;&gt; null then
						ediTI.weight := _msgHelper.currentSubItem.Decimal; //cnwrd1 ccms 1060 12.1.09
					endif;
				// Moller NZ do this thing with the WT+AAG+ segment to add a volume
				elseif _msgHelper.currentSubItem = "CBM" then
					_msgHelper.setNextSubItem;
					if ediTI &lt;&gt; null then
						ediTI.volume := _msgHelper.currentSubItem.Decimal;
					endif;
				endif;
			endif;
		elseif _msgHelper.currentField = "VOL" then 
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			if _msgHelper.currentSubItem = "MTQ" or _msgHelper.currentSubItem = "CBM" then
				_msgHelper.setNextSubItem;
				if ediTI &lt;&gt; null then
					ediTI.volume := _msgHelper.currentSubItem.Decimal; //cnwrd1 ccms 1060 12.1.09
				endif;
			endif;
		endif;
//MOA
	elseif _msgHelper.currentTag = "MOA" then	// monetary amount
//NAD
	elseif _msgHelper.currentTag = "NAD" then	// name and address
		_msgHelper.setNextField;
		if _msgHelper.currentField = "CA" then	// carrier
		elseif _msgHelper.currentField = "CS" then	// consolidator
		elseif _msgHelper.currentField = "CN" then	// consignee
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			if ediTI &lt;&gt; null then			
				//jlgka1 TFS 43732 --&gt;
				if _ediPartyRules &lt;&gt; null then
					rule := _ediPartyRules.allEDIPartyRules.getEDICuscarRule(CM_EDICUSCARRule.Item_NAD_1_1);
					if rule &lt;&gt; null then
						ruleFunction := rule.getFunction();
						
						if ruleFunction = CM_EDICUSCARRule.Function_NAD_1_1_Consignee then
							if ediTI &lt;&gt; null then
								if _ediOperator &lt;&gt; null then
									ediTI.consigneeCode := _ediOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
									if not foundMatch then
										ediTI.consigneeCode := _msgHelper.currentSubItem[1:30];
									endif;
								else
									ediTI.consigneeCode := _msgHelper.currentSubItem[1:30];
								endif;	
							endif;
						endif;
					else	
						self.setEDITIRemarks(ediTI, _msgHelper.currentField); //jlgka1 TFS 43732						
					endif;	
				else//jlgka1 TFS 43732 &lt;--
					self.setEDITIRemarks(ediTI, _msgHelper.currentField); //jlgka1 TFS 43732
				endif;
			endif;
		elseif _msgHelper.currentField = "CZ" then	// consignor
		elseif _msgHelper.currentField = "PK" then	// contact party
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			if ediTI &lt;&gt; null then
				self.setEDITIRemarks(ediTI, _msgHelper.currentField); //jlgka1 TFS 43732
			endif;
		endif;
//PCI
	
//QTY
	
//RFF
	elseif _msgHelper.currentTag = "RFF" then	// reference
		_msgHelper.setNextField;
		if _msgHelper.currentSubItem = "BM" then	//bill of lading
			_msgHelper.setNextSubItem;
			params.bolNumber := _msgHelper.currentSubItem;
			if ediTI &lt;&gt; null then
				ediTI.bol := params.bolNumber;
			endif;
		endif;
//SEL
	elseif _msgHelper.currentTag = "SEL" then		//cnwrs1 CCMS1811 Mar 20098
		_msgHelper.setNextField;
		ediTI.sealNum := _msgHelper.currentField;
//SGP
	elseif _msgHelper.currentTag = "SGP" then	// split goods placement
		_msgHelper .setNextField; //ccms 1811 cnwrs1 may 2009
		id := _msgHelper.currentField.trimBlanks;
		ediDataBayPlan.createBayPlanTI(ediTI, id);
		ediTI.bol := params.bolNumber;
		params.myEDIItem := ediTI;
//TDT
	elseif _msgHelper.currentTag = self.TDT then	// details of transport
		_msgHelper.setNextField;
		if _msgHelper.currentField = "20" then	// main carriage transport
			self.getVoyageDetailsFromTDT(	_msgHelper,
											voyageCode,
											operatorVoyageCode,
											operatorVoyage,			// cnwrl1 26/07/2010 PAR 25093
											vesselName,
											lloydsNumber,
											callSign );
			
			//We have got to the TDT record without knowing who this EDI is from. We are going to use the Voyage Operator
			//since we don't have anything else. Note the foreign code in the UNB is usually different to the foreign code 
			//in the TDT, even though they may refer to the same Operator
			if _ediOperator = null then
				_ediOperator		:= operatorVoyage;
			endif;
			
			if _ediOperator &lt;&gt; null then
				_ediFile.ediData.operatorCode	:= _ediOperator.code;
			endif;
			
			if ediDataBayPlan.voyageCode &lt;&gt; null then
				voyageCode	:= ediDataBayPlan.voyageCode; //ccms 1049
			endif;
			ediDataBayPlan.vesselName	:= vesselName;
			
			// Use the operator voyage code translation if it exists.
			voyageCode	:= self.getXlationOperatorVoyageCode(	_ediOperator,
																operatorVoyage,
																voyageCode,
																vesselName,
																lloydsNumber,
																callSign );
			ediDataBayPlan.voyageCode	:= voyageCode.trimBlanks[1:20];
		endif;
//TMP
	elseif _msgHelper.currentTag = "TMP" then
		_msgHelper.setNextField;
		if _msgHelper.currentField = "2" then
			_msgHelper.setNextField;
			temperature := _msgHelper.currentSubItem.asEDIReal();
			_msgHelper.setNextSubItem;
			if _msgHelper.currentSubItem = "CEL" then
				ediTI.temperature := temperature;
			elseif _msgHelper.currentSubItem = "FAH" then
				ediTI.temperature := app.temperatureConversion(false,temperature);
			endif;
		endif;
	
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_ediOperator" type="CM_Operator" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="processFileManifest" id="fbb7587f-9236-4e7b-b0a7-10dd004097d4">
        <source>processFileManifest(_msgHelper: CMIF_EDIFACTHelper io; _ediFile : CM_EDIFile input; _ediData : CM_EDIData input; _ediOperator : CM_Operator; _ediPartyRules :CM_EDIPartyRules) protected;
/*

Purpose:CCMS PEN 2352 BOL Handling via CUSCAR			

Parameters:			

Return Value:		

Date		Who		Reason
16 Apr 2014	cnwgb1	Initial creation CCMS PEN 2352 PAR 33795
7  May 2014 cnwgb1  CCMS SFW 1384 PAR 34099 (Add support for Multiple BOLs per Container)
// 27 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/

vars
    // REMEMBER this method is called from within a loop; you cannot set a local variable in processing
    // one segment and use it in another. You must use the Param block on _msgHelper
    bol :CM_EDIBOLHdrTI;
    bolItem :CM_EDIBOLDtlTI;
    dtString :String;
    equipmentTI :CM_EDICargoOnShipTI;
    cargoTI :CM_EDICargoOnShipTI;
    foundMatch :Boolean;
    isoType :String;
    linkedId :String;
    params :CMIF_EDIFACTParams;
    portStr :String;
    rawSubItemStr :String;
    vessel :CM_Vessel;
    vesselCode :String;
    sealNumber :String; //PAR 34099 for CCMS SFW 1384 cnwgb1 9/5/2014 
    sealType :String; //PAR 34099 for CCMS SFW 1384 cnwgb1 9/5/2014 
    terminal :CM_Terminal; //PAR 34099 for CCMS SFW 1384 cnwgb1 9/5/2014 
    toDoTaskTI :CM_EDIToDoTaskTI; //PAR 34110 for CCMS 2352 cnwgb1 12/5/2014
	ruleFunction : Integer;  //cnwrd1 par 34193
	extraData : String;
	rule : CM_EDICUSCARRule;
begin

    params := _msgHelper.myCurrentParams;
    
    if false then
    // Process each segment in turn 
    // AUT : Authentication result : Ignore 
    // BGM : Beginning of message : Handled in CM_EDIFIleTypeCusCar::processEDIFACTSegment
    
    // CNI Consignment information
    elseif _msgHelper.currentTag = "CNI" then
        _msgHelper.setCurrentGroup(4);
        create bol persistent;
        bol.setForCreateNew(_ediData);
        _msgHelper.setNextField();
        _msgHelper.setNextField();
        bol.setId(_msgHelper.currentSubItem);
        bol.setVoyageCode(params.voyageCode);
        bol.operatorCode := params.voyageOperatorCode;
        params.myEDIHdr := bol;
        params.bulkId := 0; // cnwgb1 PAR 34171 20.5.2014
    
    // CNT Control total
    elseif _msgHelper.currentTag = "CNT" then
        if _msgHelper.currentGroup &lt;= 3 then
            _msgHelper.setCurrentGroup(0);
        endif;
        if _msgHelper.currentGroup = 0 then
            _msgHelper.setNextField();
            if _msgHelper.currentSubItem = "10" then // Number of consignments (BOLs?)
                // Store off - we haven't read the BOLs yet
            elseif _msgHelper.currentSubItem = "16" then // Number of containers
                // Check that we have the correct number of containers.
                // If not Warning or Error?
            endif;
        elseif _msgHelper.currentGroup = 5 then
            _msgHelper.setNextField();
            if _msgHelper.currentSubItem = "7" then
                // Nowhere to store gross weight of a bol
            elseif _msgHelper.currentSubItem = "8" then
				bol := params.myEDIHdr.CM_EDIBOLHdrTI;			//cnwmc5 - 23 July 2014 - CCMS 2353
                _msgHelper.setNextSubItem();
                rawSubItemStr := _msgHelper.currentSubItem;
                bol.numItems := rawSubItemStr.asIntegerJMT();
            endif;
        else
            // CNT is in the wrong place, confused
            return;
        endif;
    
    // COM Communication contact, ignore 
    // CPI Charge payment instructions, ignore 
    // CST Customs status of goods, ignore 
    // CTA Contact information, ignore 
    // CUX Currencies, ignore 
    // DGS Dangerous goods, ignore 
    
    // DIM Dimensions 
    elseif _msgHelper.currentTag = "DTM" then
        if _msgHelper.currentGroup = 0 then
            _msgHelper.setNextField();
            if _msgHelper.currentSubItem = "137" then		// date of EDI file issue
                _msgHelper.setNextSubItem();
                dtString := _msgHelper.currentSubItem.trimBlanks();
                _msgHelper.setNextSubItem();
                params.ediFileIssueDateTime := dtString.getUNEDIFACTTimeStamp(_msgHelper.currentSubItem.Integer);
            endif;
        endif;     // DOC Document/message details 
    
    // DTM Date/time/period, ignore 
    
    // EQD Equipment details
	elseif _msgHelper.currentTag = "EQD" then
        //The only thing we are going to pull off this record is the ID/Cargo Type. Just enough to identify the Equipment.
        if _msgHelper.currentGroup = 1 then
            _msgHelper.setCurrentGroup(2);
        endif;
        if _msgHelper.currentGroup &lt;&gt; 2 then
            // EQD is in the wrong place, confused
            return;
        endif;
		create equipmentTI persistent; 
		params.myEDIItem := equipmentTI;
		//Update a minimal number of fields to pass validation. The only important field is the Bol number later in the file
		equipmentTI.setForCreateNew(_ediData);
		equipmentTI.messageMode := "M";
		equipmentTI.ediFileIssueDateTime := params.ediFileIssueDateTime;
        equipmentTI.operatorCode := params.voyageOperatorCode;
		equipmentTI.setVoyageCode(params.voyageCode.trimBlanks()[1:30]);
		if params.mySenderOperator &lt;&gt; null then
			params.voyageCode	:= self.getXlationOperatorVoyageCode(params.mySenderOperator, params.myVoyageOperator, params.voyageCode, params.vesselName, params.lloydsNumber, params.callsign );
			equipmentTI.setVoyageCode(params.voyageCode[1:30]);
		else
			// make sure the manual collection on CM_EDIConfig gets maintained
			equipmentTI.setVoyageCode(equipmentTI.getVoyageCode);
		endif;

	
		_msgHelper.setNextField();
		
		if _msgHelper.currentField = "CN" then
			equipmentTI.setCargoType(TI_CargoType_Container);
			_msgHelper.setNextField();
			equipmentTI.setId(_msgHelper.currentField.replaceString(" ", "")[1:11]);

            params.allEDIItems.add(equipmentTI);
		endif;
    
    // FTX Free text 
    elseif _msgHelper.currentTag = "FTX" then
        if _msgHelper.currentGroup = 10 then
            _msgHelper.setNextField();
            if _msgHelper.currentSubItem = "AAA" then
                _msgHelper.setNextField();
                _msgHelper.setNextField();
                _msgHelper.setNextField();
                bolItem := params.myEDIItem.CM_EDIBOLDtlTI;
                if bolItem &lt;&gt; null then
				
					//29 Jan 2020	NDL	TFS 48360
					if _ediPartyRules &lt;&gt; null then				
						rule := _ediPartyRules.allEDIPartyRules.getEDICuscarRule(CM_EDICUSCARRule.Item_FTX_1_1);				
						if rule &lt;&gt; null then
							ruleFunction := rule.getFunction();
							if ruleFunction = CM_EDICUSCARRule.Function_FTX_1_1_Description then
								if bolItem &lt;&gt; null then
									bolItem.setDescription( _msgHelper.currentSubItem ); 
								endif;
							else
								bolItem.remarks := _msgHelper.currentSubItem &amp; bolItem.remarks;
							endif;
						else
							bolItem.remarks := _msgHelper.currentSubItem &amp; bolItem.remarks;
						endif;
					else
						bolItem.remarks := _msgHelper.currentSubItem &amp; bolItem.remarks; //cnwgb1 PAR 34171 20.5.2014
					endif;
					
                endif;
	
            endif;
        endif;
    
    // GID Goods item details
    elseif _msgHelper.currentTag = "GID" then
        if _msgHelper.currentGroup = 5 
            or _msgHelper.currentGroup = 6
            or _msgHelper.currentGroup = 7
            or _msgHelper.currentGroup = 8
            or _msgHelper.currentGroup = 9 then
            _msgHelper.setCurrentGroup(10);
        endif;
        if _msgHelper.currentGroup = 10 then
            create bolItem persistent;
            bolItem.setForCreateNew(_ediData);
            bolItem.setId(params.myEDIHdr.id);
            bolItem.myHeader := params.myEDIHdr.CM_EDIBOLHdrTI;
            bolItem.consignee := params.consignee;
            bolItem.consignor := params.consignor;
            _msgHelper.setNextField();
            _msgHelper.setNextField();
            bolItem.quantity := 1;
            bolItem.remarks := ' (' &amp; _msgHelper.currentSubItem; //cnwgb1 PAR 34171 20.5.2014
            _msgHelper.setNextSubItem();
            _msgHelper.setNextSubItem();
            _msgHelper.setNextSubItem();
            _msgHelper.setNextSubItem();
            bolItem.remarks := bolItem.remarks &amp; ' ' &amp;_msgHelper.currentSubItem &amp; ')';
            if params.cargoTypeCode &lt;&gt; 0 then
                bolItem.setCargoType(params.cargoTypeCode);
            else
                bolItem.setCargoType(TI_CargoType_BreakBulk);
            endif;
            params.myEDIItem := bolItem;
        endif;
    
    // GIS General indicator, ignore 
    // HAN Handling instructions, ignore 
    
    // LOC Place/location identification
    elseif _msgHelper.currentTag = "LOC" then
        if _msgHelper.currentGroup = 5 then
            _msgHelper.setNextField();
			
			

					
            if _msgHelper.currentSubItem = "9" then
                _msgHelper.setNextField();
				portStr := _msgHelper.currentSubItem[1:5].trimBlanks();
                bol := params.myEDIHdr.CM_EDIBOLHdrTI;
				if params.mySenderOperator &lt;&gt; null then
					bol.loadPort := params.mySenderOperator.getXlationSystemCode(portStr, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
				else
					bol.loadPort := portStr;
				endif;
            elseif _msgHelper.currentSubItem = "27" then // This location is a Country
                // Don't know what to do with this, ignore 
            elseif _msgHelper.currentSubItem = "104" then // This location is a place of deconsolidation (Stripping/Unpacking)
                _msgHelper.setNextField();
                _msgHelper.setNextSubItem();
                _msgHelper.setNextSubItem();
                _msgHelper.setNextSubItem();


		
                rawSubItemStr := _msgHelper.currentSubItem;
				
							// cnwrd1 par 34193
				ruleFunction := CM_EDIRule.Function_Undefined;
	
				if _ediPartyRules &lt;&gt; null then
					//here we need to find a rule. we look at the item location, this needs ti match the value, then we need to make sure the match text is contained in segment loc1.5			
					ruleFunction := _ediPartyRules.getFunctionForItemValueMatch(CM_EDICUSCARRule.Item_LOC_1_1, "104",rawSubItemStr, extraData);	// par 34193
				endif;
			
			
				if ruleFunction = CM_EDICUSCARRule.Function_LOC_1_1_TODO then
					//we have a todo task to create, need to find it.
					
					create toDoTaskTI persistent;
					toDoTaskTI.setCargoType(TI_CargoType_Container); //cnwgb1 PAR 34171 20.5.2014
					toDoTaskTI.setForCreateNew(_ediData );
					toDoTaskTI.setId(params.myEDIHdr.id);
					toDoTaskTI.isComplete := false;
					toDoTaskTI.taskCode := extraData;
				endif;

            endif;
        endif;
    
    // MEA Measurements 
    elseif _msgHelper.currentTag = "MEA" then
        if _msgHelper.currentGroup = 10 then
            _msgHelper.setNextField();
            if _msgHelper.currentSubItem = "AAE" then
                _msgHelper.setNextField();
                //G
                _msgHelper.setNextField();
                //KGM !!!
                _msgHelper.setNextSubItem();
                bolItem := params.myEDIItem.CM_EDIBOLDtlTI;
                if bolItem &lt;&gt; null then
                    bolItem.weight := _msgHelper.currentSubItem.asDecimalJMT();
                endif;                
            endif;
        endif;
    
    // MOA Monetary amount, ignore 
    
    // NAD Name and address
    elseif _msgHelper.currentTag = "NAD" then
        if _msgHelper.currentGroup = 6 then
           _msgHelper.setCurrentGroup(7);
        endif;
        if _msgHelper.currentGroup = 7 then
            _msgHelper.setNextField();
            if _msgHelper.currentSubItem = "CN" then //Consignee
                _msgHelper.setNextField();
                if _msgHelper.currentSubItem = null then
                    _msgHelper.setNextField();
                    if _msgHelper.currentSubItem = null then
                        _msgHelper.setNextField();
                    endif;
                endif;
                if _msgHelper.currentSubItem &lt;&gt; null then
                    if params.mySenderOperator &lt;&gt; null then
                        params.consignee := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
                    else
                        params.consignee := _msgHelper.currentSubItem.trimBlanks()[1:30];
                    endif;                
                endif;
            elseif _msgHelper.currentSubItem = "CZ" then //Consignor
				_msgHelper.setNextField();
                if _msgHelper.currentSubItem = null then
                    _msgHelper.setNextField();
                    if _msgHelper.currentSubItem = null then
                        _msgHelper.setNextField();
                    endif;
                endif;
                if _msgHelper.currentSubItem &lt;&gt; null then
                    if params.mySenderOperator &lt;&gt; null then
                        params.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
                    else
                        params.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
                    endif;
                endif;
            endif;
        endif;
    
    // PAC Package, ignore
    // PCI Package identification, ignore 
    // QTY Quantity, ignore 
    
    // RFF Reference, ignore
    elseif _msgHelper.currentTag = "RFF" then
        if  _msgHelper.currentGroup = 4
            or _msgHelper.currentGroup = 10
            or _msgHelper.currentGroup = 11
            or _msgHelper.currentGroup = 12 then
            _msgHelper.setCurrentGroup(5);
        endif;
        if _msgHelper.currentGroup = 5 then
            _msgHelper.setNextField();
            if bol = null or bol.id &lt;&gt; _msgHelper.currentSubItem then
                //WARN 
            endif;
            params.consignee := null;
            params.consignor := null;
        endif;
            
    // RNG Range details, ignore 
    // SEL Seal number
    elseif _msgHelper.currentTag = "SEL" then  //PAR 34099 for CCMS SFW 1384 cnwgb1 9/5/2014
        if _msgHelper.currentGroup = 2 then
            _msgHelper.setNextField();
            //This must have been set up in a previous EQD
            equipmentTI := params.myEDIItem.CM_EDICargoOnShipTI;
            sealNumber := _msgHelper.currentField;
            _msgHelper.setNextField();
            sealType := _msgHelper.currentSubItem;
            if sealType = "CA" or sealType = null then
                equipmentTI.sealNum := sealNumber;
            elseif sealType = "SH" then
                equipmentTI.sealShipper := sealNumber;
            elseif sealType = "CU" then
                equipmentTI.sealCustoms := sealNumber;
            elseif sealType = "TO" then
                equipmentTI.sealTerminalOperator := sealNumber;
            else
                equipmentTI.sealUnknown := sealNumber; //cnwgb1 PAR 34171 20.5.2014
            endif;
        endif;
    
    // SGP Split goods placement
    elseif _msgHelper.currentTag = "SGP" then
        if _msgHelper.currentGroup = 10 then
            _msgHelper.setNextField();
            linkedId := _msgHelper.currentSubItem.replaceString(" ", "")[1:11]; 
            if params.allEDIItems &lt;&gt; null then
                equipmentTI := params.allEDIItems[linkedId].CM_EDICargoOnShipTI;
                if equipmentTI &lt;&gt; null then
                    if false then // Temporary code for PAR 34099 cnwgb1 7.5.2014
                        equipmentTI.myEDIBOLDtl := params.myEDIItem.CM_EDIBOLDtlTI;
                        equipmentTI.myEDIBOLHeader := params.myEDIHdr.CM_EDIBOLHdrTI;
                        bol := params.myEDIHdr.CM_EDIBOLHdrTI;
                        if equipmentTI.bol = null and bol &lt;&gt; null then
                            equipmentTI.bol := bol.id;
                        else
                            //WARN
                        endif;
                    else // cnwgb1 PAR 34099 cnwgb1 7.5.2014
                        terminal := _ediData.getMyTerminal();
                        create cargoTI persistent;
                        cargoTI.messageMode := "A";
                        cargoTI.setForCreateNew(_ediData);
                        cargoTI.ediFileIssueDateTime := params.ediFileIssueDateTime;
                        cargoTI.operatorCode := params.voyageOperatorCode;
                        cargoTI.setVoyageCode(params.voyageCode.trimBlanks()[1:30]);
                        params.bulkId := params.bulkId +1;
                        cargoTI.setId(params.voyageCode &amp; "/" &amp; params.myEDIHdr.id &amp; "/" &amp; params.bulkId.cnEcPad(3));
                        cargoTI.parentCargoID := equipmentTI.id;
                        cargoTI.parentCargoTypeCode := equipmentTI.cargoType;
                        cargoTI.parentCargoType := equipmentTI.cargoTypeDescr;
                        cargoTI.commodity := params.defCmdty;
                        cargoTI.dischargePort := params.thisPort;
                        cargoTI.myEDIBOLDtl := params.myEDIItem.CM_EDIBOLDtlTI;
                        cargoTI.myEDIBOLHeader := params.myEDIHdr.CM_EDIBOLHdrTI;
                        cargoTI.setCargoType(cargoTI.myEDIBOLDtl.cargoType); //cnwgb1 PAR 34171 20.5.2014
                        cargoTI.totalQuantity := cargoTI.myEDIBOLDtl.quantity;
                        _msgHelper.setNextField();
                        cargoTI.quantity := _msgHelper.currentField.asIntegerJMT();
                        cargoTI.remarks  := cargoTI.myEDIBOLDtl.remarks;
						cargoTI.setDescription( cargoTI.myEDIBOLDtl.description );	//29 Jan 2020	NDL	TFS 48360	
                        bol := params.myEDIHdr.CM_EDIBOLHdrTI;
                        if bol &lt;&gt; null then
                            cargoTI.bol := bol.id;
                        endif;
                    endif;
                else
                    //WARN
                endif;
            endif;
        endif;
    
    // TDT Details of transport
	elseif _msgHelper.currentTag = "TDT" then
		if _msgHelper.currentGroup = 0 then
			_msgHelper.setCurrentGroup(1);
        elseif _msgHelper.currentGroup = 5 then
            _msgHelper.setCurrentGroup(6);
		endif;
		_msgHelper.setNextField();
		if _msgHelper.currentGroup = 1 then
			if _msgHelper.currentField = "20" then
				self.getVoyageDetailsFromTDT(	_msgHelper, params.voyageCode, params.voyageOperatorCode, params.myVoyageOperator, params.vesselName, params.lloydsNumber, params.callsign );
				if params.mySenderOperator &lt;&gt; null then
					vesselCode := params.mySenderOperator.getXlationSystemCode(params.vesselName, XLATION_TYPE_VESSEL_BYOP, foundMatch);
					if not foundMatch then
						vessel := app.myRoot.allVesselsByName[vesselCode];
					else
						vessel := app.myRoot.allVessels[vesselCode];
					endif;
					if vessel &lt;&gt; null then
						params.vesselName := vessel.name;
					endif;
					params.voyageCode	:= self.getXlationOperatorVoyageCode(	params.mySenderOperator, params.myVoyageOperator, params.voyageCode, params.vesselName, params.lloydsNumber, params.callsign );
				endif;
            endif;
        endif;    
    
    // TMP Temperature, ignore 
    // TSR Transport service requirements, ignore 
    
    endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_ediOperator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="setEDITIRemarks" id="be9563e7-13aa-4b70-8125-47640f034179">
        <source>setEDITIRemarks(_ediTI : CM_EDIBayPlanTI io; _currentField : String);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 May 2019
TFS#		: 42732
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	_ediTI.remarks := "For " &amp; _currentField;		
end;</source>
        <Parameter name="_ediTI" type="CM_EDIBayPlanTI" usage="io"/>
        <Parameter name="_currentField" type="String"/>
    </JadeMethod>
    <JadeMethod name="tiMarker" id="f51ea178-0e7d-43e0-b952-d811ca7aea16">
        <source>tiMarker() : String protected;
// cnwrs1 mar 2006 so cuscar can use a different marker for ti count
vars

begin
	return "GID";
end;</source>
