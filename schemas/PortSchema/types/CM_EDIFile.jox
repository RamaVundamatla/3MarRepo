    <JadeMethod name="setServiceStringAdviceInfo" id="479b237f-c643-4b1a-80f1-bd14479e0414">
        <updating/>
        <source>setServiceStringAdviceInfo(	_message:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		16 November 2010
//
// Purpose:		Derives the characters defined as separators and delimiters for the
//				message file, as specified by the "UNA" file segment, and stores
//				them on the receiver.
/*
UNA, Service String advice

 Function:	To define the characters selected for use as delimiters and indicators in
			the rest of the interchange that follows:

 The specifications in the Service string advice take precedence over the specifications
 for delimiters etc. in segment UNB.  See clause 4.

 When transmitted, the Service string advice must appear immediately before the
 Interchange Header (UNB) segment and begin with the upper case characters UNA
 immediately followed by the six characters selected by the sender to indicate, in
 sequence, the following functions:

 Repr.        Name								Remarks

 an1    M     COMPONENT DATA ELEMENT SEPARATOR	(i.e. ":")
 an1    M     DATA ELEMENT SEPARATOR			(i.e. "+")
 an1    M     DECIMAL NOTATION					Comma or full stop
 an1    M     RELEASE INDICATOR					If not used, insert space character (i.e. "?")
 an1    M     Reserved for future				Insert space character use
 an1    M     SEGMENT TERMINATOR				(i.e. "'")
*/
// Returns:		True if the UNA line was found, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
// --------------------------------------------------------------------------------
vars
	startPos	: Integer;
	isValid		: Boolean;
	fieldSep	: String;
	itemSep		: String;
	decChar		: String;
	escChar		: String;
	endChar		: String;
	
begin
	startPos	:=	_message.pos(CM_EDIFileTypeUNEDIFACT.UNA, 1);
	
	if startPos = 0 then
		isValid	:=	false;
	endif;
	
	if startPos &lt;&gt; 1 or _message.length() &lt; 9 then
		// The UNA line must be at the very beginning of the message.
		isValid	:=	false;
	endif;
	
	if isValid then
		itemSep		:=	_message[4:1];
		fieldSep	:=	_message[5:1];
		decChar		:=	_message[6:1];
		escChar		:=	_message[7:1];
		endChar		:=	_message[9:1];
	else
		itemSep		:=	":";
		fieldSep	:=	"+";
		decChar		:=	".";
		escChar		:=	QuestionMark;
		endChar		:=	SingleQuote;
	endif;
	
	// Now update these attributes on the receiver.
	
//	self.fieldSeparator	:=	fieldSep;
//	self.itemSeparator	:=	itemSep;
//	self.decimalChar	:=	decChar;
//	self.escapeChar		:=	escChar;
//	self.eolChar		:=	endChar;
epilog
	return isValid;
end;</source>
        <Parameter name="_message" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
