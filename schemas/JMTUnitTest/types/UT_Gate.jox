	assertNotNull(releaseRequest);
	
	// Make sure that the expected source is found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(source.getName(), locations.first.getName());
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.sourceLocationId, bs.id);
	
epilog
	delete locations;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByType_ISO_GateInOut" id="71abe409-6c31-4c8f-8649-ce85b69df1ab">
        <source>tReleaseByType_ISO_GateInOut();
// cnwdap1
//23 December 2008	cnwdw1	
// Test that gate out of a "by type" release request correctly autoplans
vars
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
begin
	
	deleteReleaseRequest("UTRRRoad");
	deleteVehicle("UTTRUCK");
	self.deleteContainer("TEST0000001");
	
	// Setup a YA over a block stack that has a cvontainer that could be released
	ti := self.addContainer("TEST0000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	
	create locations transient;
	locations.add(bs.allLocationsControllers.first.CM_YardController);
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1(yaName, YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	self.move(ti, locations.first);
	assertEqual(ti.myPrimaryActualLocation, locations.first);
	
	// Create the Release
	releaseRequest := addReleaseByTypeRequest("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container, "2200");
	assertNotNull(releaseRequest);
	
	// Gate Out
	self.gateOutPinRelease(releaseRequest.myPinNo.pinNo, "UTTRUCK");
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	
	deleteReleaseRequest("UTRRRoad");
	deleteVehicle("UTTRUCK");

epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseFIFOYA" id="dee67d99-3e20-46fe-8a0d-1c59c0dcbd90">
        <source>tReleaseFIFOYA();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2025	jlier1	Initial creation 13860

*/

vars
term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	locations : CM_LCArray;
	ss1, ss2, ss3 : CM_StraddleStack;
	ya					: CM_YardAllocation;
	 ti1, ti2, ti3 : CM_TrackedItem;
	 releaseRequest : CM_BulkRelease;
	 wle : CM_WorkListEntry;
begin
	term := self.getTerminal;

	
	deleteContainer("TEST0000001");
	deleteContainer("TEST0000002");
	deleteVehicle("UTTRUCK");

	
	//adding straddle stack 1  with oldest recevial container
	create locations transient;
	self.deleteTerminalArea("UTSS1");
	ss1:=self.addStraddleStack("UTSS1",2,2,2);
	self.assertNotNullMsg(ss1,"UTSS1 is null");
	ss1.allGridControllersByName.copy(locations);
	
	
	ti1 := self.addContainerAtLocation("TEST0000001", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE,ss1.allGridControllersByRowColumn[1,1] );
	self.assertNotNullMsg(ti1,"TEST0000001 is null");
	beginTransaction;
	ti1.setReceivedDT("1/1/2024".TimeStamp);
	commitTransaction;
	
	//adding straddle stack 2  with newest recevial container
	self.deleteTerminalArea("UTSS2");
	ss2:=self.addStraddleStack("UTSS2",2,2,2);
	self.assertNotNullMsg(ss2,"UTSS2 not null");
	ss2.allGridControllersByName.copy(locations);
	
	ti2 := self.addContainerAtLocation("TEST0000002", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE,ss2.allGridControllersByRowColumn[1,1] );
	self.assertNotNullMsg(ti2,"TEST0000002 is null");
	beginTransaction;
	ti2.setReceivedDT("1/12/2024".TimeStamp);
	commitTransaction;
	
	//adding straddle stack 3  with no cargo
	self.deleteTerminalArea("UTSS3");
	ss3:=self.addStraddleStack("UTSS3",2,2,2);
	self.assertNotNullMsg(ss3,"UTSS3 not null");
	ss3.allGridControllersByName.copy(locations);
	
	disableAllYA(true);
	self.deleteYA("UTSS1");
	ya := self.addYA1WithFill("UTSS1", YACriteriaType_ISO, 2200, locations, YAFillOption_FIFO, YAFillOption_FIFO,false);
	
	//add some containers in ss1 update with old receival date
	
	// add container in ss2 with receival newer receival date/time
	
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Gate Out
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate ,null);
	
	
	
	self.assertNoTrxErrors();
	
	//should of queued/planned to terminal area 
	self.assertNotNullMsg(vvr.myRoadJob,"Gated in road job");
	self.assertEqualMsg(vvr.myRoadJob.workListEntries.size, 1, "One worklist entry");
	wle:=vvr.myRoadJob.workListEntries.first;
	self.assertEqualMsg(wle.allRTQueueEntries.size,1, "WLE not queued");
	self.assertEqualMsg(wle.allRTQueueEntries.first.allTasks.first.mySourceTerminalArea, ss1,"Test gated in container queued to area UTSS1 with oldest recevial DT cargo");
	
	
epilog	
	disableAllYA(false);
	delete locations;

end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseMTByID" id="7fb26f10-99c1-47ca-807f-1b9e53b39975">
        <updating/>
        <source>tReleaseMTByID() updating;
// cnwdap1
//30 July 2009	cnwdw1	
//
vars
	ti: CM_TrackedItem;
	truck: CM_Vehicle;
