    <JadeMethod name="isFull" id="95b53534-6d92-4c22-a459-36ff758503f7">
        <source>isFull(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 December 2012	cnwrd1	Initial creation

*/

vars
	commodity : CM_Commodity;
	mtCommodity : CM_Commodity;
	contentsStatus : CM_ContentsStatus;

begin

	// 32041 Check the release to see if thuis ia full release
	if self.myDeliveryRequest &lt;&gt; null and self.myDeliveryRequest.myOriginatingBulkRelease &lt;&gt; null then
		if self.myDeliveryRequest.myOriginatingBulkRelease.fullRelease then
			return true;
		endif;
	endif;
	
	//11 May 2012	NDL	Par 29555
	// if either of these are set to a non empty status then return full
	commodity := self.myCommodity;
	if commodity &lt;&gt; null then
		mtCommodity := app.myRoot.allCommodities[self.myTerminal.getDefaultEmptyCommodity()];
		if commodity &lt;&gt; mtCommodity then
			return true;
		endif;
	endif;
	
	
	//if we got this far
	if commodity &lt;&gt; null and commodity = mtCommodity then
		//commodity is set to empty
		return false;
	endif;
	
	if contentsStatus &lt;&gt; null and contentsStatus.code = TI_CONTENTS_STATUS_EMPTY then
		//contentsStatus is set to emopty
		return false;
	endif;
	
	return inheritMethod();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
