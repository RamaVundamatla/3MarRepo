    <JadeMethod name="setDetails" id="6dea031d-82e4-4621-907f-6d52dfbe89be">
        <updating/>
        <source>setDetails(	_screenBackColour,
			_screenForeColour,
			_tableBackColour,
			_tableForeColour,
			_tableSelectColour: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwer1	Initial creation

*/

vars

begin
	self.screenBackColour :=_screenBackColour;
	self.screenForeColour:=_screenForeColour;
	self.tableBackColour:=_tableBackColour;
	self.tableForeColour:=_tableForeColour;
	self.tableSelectColour:=_tableSelectColour;
epilog

end;</source>
        <Parameter name="_screenBackColour" type="Integer"/>
        <Parameter name="_screenForeColour" type="Integer"/>
        <Parameter name="_tableBackColour" type="Integer"/>
        <Parameter name="_tableForeColour" type="Integer"/>
        <Parameter name="_tableSelectColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8798dba7-e417-4e78-8281-6ef6f2ba5bb0">
        <updating/>
        <source>setForCreate(_proxy : CM_RTScreenConfig) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwer1	Initial creation

*/

vars

begin
	self.setForUpdate(_proxy);
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_RTScreenConfig"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e3dcf95d-ee04-4e9a-9e68-0bff49ab2225">
        <updating/>
        <source>setForUpdate(_proxy : CM_RTScreenConfig) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwer1	Initial creation
16 Apr 2012 cnwer1	PAR 29432 - can get exception if on RT app if colors are an invalid value  i.e. negative
*/

vars
	dummyControl : TextBox;
begin
	create dummyControl transient;
	if _proxy.screenBackColour.isValidRGBColor then
		self.screenBackColour:=_proxy.screenBackColour;
	else
		self.screenBackColour:=dummyControl.getSystemColor(Control.Color_3DFace);
	endif;

	if _proxy.screenForeColour.isValidRGBColor then
		self.screenForeColour:=_proxy.screenForeColour;
	else
		self.screenForeColour:=dummyControl.getSystemColor(Control.Color_WindowText);
	endif;
	if _proxy.tableBackColour.isValidRGBColor then
		self.tableBackColour:=_proxy.tableBackColour;
	else
		self.tableBackColour:=White;
	endif;
	
	if _proxy.tableForeColour.isValidRGBColor then
		self.tableForeColour:=_proxy.tableForeColour;
	else
		self.tableForeColour:=dummyControl.getSystemColor(Control.Color_WindowText);
	endif;
	
	if _proxy.tableSelectColour.isValidRGBColor then
		self.tableSelectColour:=_proxy.tableSelectColour;
	else
		self.tableSelectColour:=dummyControl.getSystemColor(Control.Color_WindowText);
	endif;
epilog	
	delete dummyControl;
end;</source>
        <Parameter name="_proxy" type="CM_RTScreenConfig"/>
    </JadeMethod>
</Class>
