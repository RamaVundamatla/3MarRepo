    <JadeMethod name="doBtnExtraDelete" id="539f7464-3fd5-4075-a729-d698281a6667">
        <updating/>
        <source>doBtnExtraDelete() updating;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	table : CM_DataTable;
	idx : Integer;
	pxyMinMax : CM_TerminalAreaProductMinMax;
	proxyTA : CM_TerminalArea;
	pxyStackHeight : CM_GriddedTAStackHeight;
	
begin
	table := self.tblExtraList;
	
	idx := table.row;
	
	if idx &gt; table.fixedRows then
	
		//08 Sep 2020	NDL	TFS 49984
		proxyTA := self.myProxyObject.CM_TerminalArea;
		if proxyTA.allowsGriddedStackHeightCrit() then
			pxyStackHeight := table.accessRow(idx).itemObject.CM_GriddedTAStackHeight;
			if pxyStackHeight &lt;&gt; null then
				delete pxyStackHeight;
			endif;
			
			self.displayStackHeights( proxyTA );
			return;
			
		else
			pxyMinMax := table.accessRow(idx).itemObject.CM_TerminalAreaProductMinMax;
			if pxyMinMax &lt;&gt; null then
				delete pxyMinMax;
				self.oldRows := 1;		// 34353 for cancel change detection
			endif;
			
			self.displayProductMinMaxs(self.myProxyObject.CM_TerminalAreaMaster);
			self.displayProductMinMax(null);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnExtraNew" id="30a90b1d-eb03-446e-b47d-6e6202e17547">
        <updating/>
        <source>doBtnExtraNew() updating;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myCurrentObject.CM_TerminalArea &lt;&gt; null
	and self.myCurrentObject.CM_TerminalArea.allowsGriddedStackHeightCrit() then	//07 Sep 2020	NDL	TFS 49984
		self.displayStackHeightCriteria(null);
	else
		self.displayProductMinMax(null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnExtraSave" id="e364072c-fa83-402c-8fb1-dd4b8cb0eb75">
        <updating/>
        <source>doBtnExtraSave() updating;
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 24/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars
	cargoType :CM_CargoType;
	aProd : CM_Product;
	proxyTA : CM_TerminalArea;
	pxyProdMinMax : CM_TerminalAreaProductMinMax;
	maxVolume,
	minVolume  : Decimal[14,4];
	minWeight, maxWeight  : Integer;
	maxQuantity : Integer;
	weightRow, volumeRow, quantityRow : String;	// TFS 49453
	realLc : CM_LocationsController;	//30 Mar 2021	NDL	TFS 49912
	pxyLc : CM_LocationsController;	//29 Mar 2021	NDL	TFS 49912
	maxWeightDec : Decimal [20,6];

begin

	proxyTA := self.myProxyObject.CM_TerminalArea;

	//07 Sep 2020	NDL	TFS 49984
	if proxyTA.allowsGriddedStackHeightCrit() then
		self.displayStackHeights( proxyTA );
		return;
	endif;
	
	aProd := self.cmbProduct.listObject.CM_Product;
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	// 34353 enforce product if required
	if cargoType &lt;&gt; null and
		cargoType.isSubCargoTypeRequired then
		if aProd = null then
			app.raiseCMException(Must_select_cargo_subtype,app.getErrorString(Unspecified_product),null);
		endif;
	endif;
	if cargoType &lt;&gt; null or aProd &lt;&gt; null then
		realLc := self.cmbColGroup.listObject.CM_LocationsController;	//29 Mar 2021	NDL	TFS 49912
		if realLc = null then
			pxyProdMinMax := proxyTA.getProductMinMaxObject(cargoType,aProd);
		else
			//30 Mar 2021	NDL	TFS 49912
			if realLc.isTransient then
				pxyLc := realLc;
			else
				pxyLc := realLc.pxyGetProxyObject;
			endif;
			if pxyLc &lt;&gt; null then
				pxyProdMinMax := pxyLc.getProductMinMaxObject(cargoType,aProd);
			endif;
		endif;
		if pxyProdMinMax = null then
			create pxyProdMinMax transient;
		endif;
		// TFS 49453 get the correct row depending on terminal area type
//30 Mar 2021	NDL 49912
//		if self.terminalAreaType = TA_TYPE_GEN_CARGO_ALLOC_ROW then
//			weightRow := ETRow_MaxWeightPerCol;
//			volumeRow := ETRow_TaMaxVolPerCol;
//			quantityRow := ETRow_MaxQtyPerCol;
//		else
			weightRow := ETRow_MaxWeight;
			volumeRow := ETRow_TaMaxVolume;
			quantityRow := ETRow_MaxQuantity;
//		endif;
		//maxVolume	:= tblExtra.getMeasurementValueByName(ETRow_TaMaxVolume).String.asDecimalJMT;	// 36603 was .Decimal
		maxVolume	:= tblExtra.getMeasurementValueByName(volumeRow).String.asDecimalJMT;	// 36603 was .Decimal
		
		//maxWeight	:= tblExtra.getMeasurementValueByName(ETRow_MaxWeight).Decimal.Integer;//String.removeCommas.Integer;
		//maxWeight	:= tblExtra.getMeasurementValueByName(weightRow).Decimal.Integer;//String.removeCommas.Integer;
		maxWeightDec	:= tblExtra.getMeasurementValueByName(weightRow).Decimal;	// TFS 53529
		if maxWeightDec &gt; Max_Integer then											// TFS 53529
			app.raiseCMException(Max_Weight_less_999999, null, null);				// TFS 53529
			return;																	// TFS 53529
		endif;																		// TFS 53529
		maxWeight := maxWeightDec.Integer;
		
		//maxQuantity	:= tblExtra.getValueByName(ETRow_MaxQuantity).asStringJMT.Integer;
		maxQuantity	:= tblExtra.getValueByName(quantityRow).asStringJMT.Integer;
		// TFS 49453 end
		
		pxyProdMinMax.setupProxy(pxyLc, cargoType,aProd, proxyTA,minVolume, minWeight, maxVolume, maxWeight,maxQuantity);
		
		self.oldRows := 1;		// 34353 for cancel change detection
	endif;
	self.displayProductMinMaxs(	proxyTA);
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboLaneGrouping" id="ec751164-36d4-48fa-b81a-293f7260c50a">
        <source>doBuildComboLaneGrouping();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwer1	Initial creation

*/

vars
	
begin


	self.myAssistant.comboBoxLaneGrouping(self.myCMIFTerminalArea.taType, self.cmbLaneGroup);

