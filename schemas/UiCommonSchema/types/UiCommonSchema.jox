    <JadeMethod name="showAlertAlarm" id="11b61914-22c3-4547-97da-3cbf29a71326">
        <source>showAlertAlarm(newObject : Object input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	form	: Form;
	vWidth	: Real;
	vHeight	: Real;
	vTop	: Real;
	vLeft	: Real;
	
begin 
	if app.name &lt;&gt; JMTerminal then
		return;
	endif;
	
	vWidth	:=	app.mainForm.clientWidth;
	vHeight	:=	app.mainForm.clientHeight;
	vTop	:=	app.mainForm.top;
	vLeft	:=	app.mainForm.left;
	
	form	:=	app.getForm(CMUI_AlertAlarm.name);
	
	if form = null then
		create form as CMUI_AlertAlarm;
		form.show();
	else
		form.CMUI_AlertAlarm.updateAlert(newObject);
	endif;
	
	//self.doWindowEvents(0);
	//app.cnwdad1_If();
	
	if form.left &lt; 0 then
		form.left	:=	1;
	endif;
	
	if form.top &lt; 0 then
		form.top	:=	1;
	endif;
	
	form.clipControls	:=	false;
	form.autoRedraw		:=	true;
	form.setFocus();
	form.zOrder(1);
end;</source>
        <Parameter name="newObject" type="Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showErrorWarningDialog" id="0c60813f-e53f-4e3e-bb7a-50e4995ad773">
        <source>showErrorWarningDialog(_heading : String; _passport : CM_Passport; 
					_mode : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  Mode	= ErrWarnMode_Update
//						= ErrWarnMode_AddUpdate
//						= ErrWarnMode_Add + ErrWarnMode_CanAckWarnings
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	: CMUI_ErrorWarningDialog;
	result	: Integer;
	
begin

	create form transient;
	form.setMyTerminal(_passport.myTerminal);
	form.init(_heading, _passport, _mode);
	
	result := form.showModal;
	return result;
	
epilog
	delete form;
	
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showErrorWarningDialogArray" id="23360fdc-e324-434a-856c-2060433b91d8">
        <source>showErrorWarningDialogArray(_heading : String;
							_allErrors : HugeStringArray;
							_allWarnings : HugeStringArray;
							_mode : Integer) : Integer;
// --------------------------------------------------------------------------------
// Created:		17 January 2008 by cnwdad1
//
// Purpose:     Display the error/warning dialog using the specified arrays of messages
//				rather than getting the errors/warnings from the Passport.
//
// Parameters:  Mode	= ErrWarnMode_Update
//						= ErrWarnMode_AddUpdate
//						= ErrWarnMode_Add + ErrWarnMode_CanAckWarnings
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	formObj	: CMUI_ErrorWarningDialog;
	result	: Integer;
	
begin
	create formObj transient;
	formObj.setMyTerminal(app.getMyTerminalDO_NOT_USE());
	formObj.initWithoutPassport(_heading, _allErrors, _allWarnings, _mode);
	
	result	:=	formObj.showModal();
	return result;
epilog
	delete formObj;
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_allErrors" type="HugeStringArray"/>
        <Parameter name="_allWarnings" type="HugeStringArray"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
