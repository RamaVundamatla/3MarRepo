    <JadeMethod name="validateId" id="bf461af0-61eb-466b-a478-dd1cbf9ef0b9">
        <source>validateId(_realTerminalAreaMaster : CM_TerminalAreaMaster) protected;
// --------------------------------------------------------------------------------
// Created:		Feb 2014 cnwjre1 from 33418, found that changing a terminal area id was not checking for duplicates.
//
// Purpose:		Refactored this code which was only done for a create to be used in updates as well.
//				Also combined all of the checks for id in one place, from the various validate methods.
//
// Parameters:	_realTerminalAreaMaster is null for a create and is the existing terminal area master for an update.
//				'self' is the proxy to create or update from.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	Original method 18 June 2008 by cnwdad1, unused
// --------------------------------------------------------------------------------
vars
	oldId,
	newId	: String;
	duplicateCheck	: Boolean;
	term	: CM_Terminal;
	tmpTA	: CM_TerminalAreaMaster;

begin
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Terminal", ETRow_Terminal, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_Terminal, null); // cnwdb2	PAR 35364
	endif;
	term := self.myTerminal;
	
	newId := self.id.trimBlanks().toUpper();
	if _realTerminalAreaMaster &lt;&gt; null then
		oldId := _realTerminalAreaMaster.id;
	endif;

	if newId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Terminal Area ID", null, null);
		app.raiseCMException(Input_required_field_termAreID, null, null); // cnwdb2	PAR 35364
	elseif newId.hasInvalidChars() then 
		if _realTerminalAreaMaster &lt;&gt; null then			// if update check real term area to see if originally had spaces. 
			if not _realTerminalAreaMaster.id.hasInvalidChars() then
				// originally no check for spaces when terminal area created. This was causing problems with 
				// moving ti's using location id's. this code checks if original term area has space and if so
				// allows save. Term area id is now editable but was being checked on save causing an error if space present
				app.raiseCMException1(ERR_INVALID_CHARACTERS, newId, null, null);
			endif;
		else
			app.raiseCMException1(ERR_INVALID_CHARACTERS, newId, null, null);
		endif;
	endif;
	
	// new or changed id must be unique
	if _realTerminalAreaMaster = null then
		duplicateCheck := true;
	elseif newId &lt;&gt; oldId then
		duplicateCheck := true;
	endif;
	if duplicateCheck then
		tmpTA := term.allTerminalAreaMastersById[newId];
		if tmpTA &lt;&gt; null then
			app.raiseCMException2(ERR_INVALID_VALUE, "Terminal Area ID is already in use as a " &amp; tmpTA.getName() &amp; ", and therefore", null, null, null);
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_realTerminalAreaMaster" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="yaAddControllersToBlock" id="afbe0c3e-d22a-4a0d-994a-ba4b3f654ae2">
        <source>yaAddControllersToBlock(pYardAllocationObj:CM_YardAllocation;
						pAllControllersObj:CM_LCArray input;
						pBlockObj:CM_YABlock io;
						pAllBlocksInObj:CM_YABlockArray input;
						pAllBlocksOutObj:CM_YABlockArray input) protected;
// --------------------------------------------------------------------------------
// Created:		19 April 2005 by cnwdad1
//
// Purpose:		Adds a set of Locations Controllers to a specified YA Block.  If
//				not YA Block is specified by the parameter, then a new one will
//				be created.
//
// Parameters:	pYardAllocationObj - A reference to the Yard Allocation which the
//					Block will belong to.
//				pAllControllersObj - The set of Locations Controllers to add to the Block.
//				pBlockObj - A reference to the YA Block the Controllers will be added to.
//				pAllBlocksInObj - An array of "In" YA Blocks.
//				pAllBlocksOutObj - An array of "Out" YA Blocks.
//
// Returns:		A reference to the YA Block, and the populated array of Blocks.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isNewBlock	: Boolean;
	
begin

	if pBlockObj = null then
		pBlockObj	:=	self.yaCreateBlock(true);
		pBlockObj.setProxy(self.id, self.CM_TerminalArea);
		pAllControllersObj.copyNoDuplicates(pBlockObj.allYardControllers);
		self.yaUpdateBlock(pBlockObj);
		isNewBlock	:=	true;
	else
		pAllControllersObj.copyNoDuplicates(pBlockObj.allYardControllers);
	endif;
	
	pBlockObj.updateDescriptionFromYAM();//epr 26189 23/11/10 sat view improvements
	if isNewBlock then
		pAllBlocksInObj.add(pBlockObj);
		pAllBlocksOutObj.add(pBlockObj);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
        <Parameter name="pBlockObj" type="CM_YABlock" usage="io"/>
        <Parameter name="pAllBlocksInObj" type="CM_YABlockArray" usage="input"/>
        <Parameter name="pAllBlocksOutObj" type="CM_YABlockArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="yaBuildBlocks" id="391c29de-9c1b-44bb-86cb-ed89ace87554">
        <source>yaBuildBlocks(	pYardAllocationObj:CM_YardAllocation;
				pAllControllersObj:CM_LCArray input;
				pAllBlocksInObj:CM_YABlockArray input;
				pAllBlocksOutObj:CM_YABlockArray input):Boolean;
// --------------------------------------------------------------------------------
// Created:		13 April 2005 by cnwdad1
//
// Purpose:		Assembles a YA Block for the specified Locations Controllers.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockObj	: CM_YABlock;
	isNewBlock	: Boolean;
	
begin
	// Check if we already have a YA Block for this Terminal Area, and if not create one.
	// Note that whilst we only look up a YA Block from the "In" collection, we will
	// add any new blocks to both the "In" and "Out" collections. This is because
	// both the "In" and the "Out" collections contain the same objects, the only
	// difference is that they may be in a different order.
	
	isNewBlock	:=	false;
	blockObj	:=	pAllBlocksInObj.getTerminalAreaBlock(self);
	
	self.yaAddControllersToBlock(pYardAllocationObj, pAllControllersObj, blockObj, pAllBlocksInObj, pAllBlocksOutObj);
	
	return true;
end;</source>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
        <Parameter name="pAllBlocksInObj" type="CM_YABlockArray" usage="input"/>
        <Parameter name="pAllBlocksOutObj" type="CM_YABlockArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="yaCreateBlock" id="ff01e600-5d6b-46cf-bff8-ccf056d8777c">
        <source>yaCreateBlock(pIsTransient:Boolean):CM_YABlock;
// --------------------------------------------------------------------------------
// Created:		07 April 2005 by cnwdad1:2
//
// Purpose:		Creates a new instance of a YA Block.  This method will be reimplemented
//				where a different Type of YA Block must be instantiated.
//
// Parameters:	pIsTransient - True if the YA Block should be instantiated as a transient object.
//
// Returns:		A reference to the new YA Block object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockObj	: CM_YABlock;
	
begin
	if pIsTransient then
		create blockObj as self.yaGetBlockType() transient;
	else
		create blockObj as self.yaGetBlockType() persistent;
	endif;
	
	return blockObj;
end;</source>
        <Parameter name="pIsTransient" type="Boolean"/>
        <ReturnType type="CM_YABlock"/>
    </JadeMethod>
