    <JadeMethod name="addObjectToCollection" id="b33e5ea5-4775-4df2-9f5b-3ec660c6bb37">
        <updating/>
        <source>addObjectToCollection(_locActivity : CMEVT_LocationActivity; _user : CM_User) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if not ( _locActivity.canView(_user) ) then
		return false;
	endif;
		
	if self.numItemsShown &gt; JadeTableRowLimit then
		return true;
	endif;

	self.numItemsShown := self.numItemsShown + 1;
	self.allLocationActivityByDate.addNoDuplicates( _locActivity, false );
	self.allLocationActivitySet.addNoDuplicates( _locActivity, false );
	return false;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_locActivity" type="CMEVT_LocationActivity"/>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="5d93f3c0-c5b7-477c-b52c-33ff3d7e8de8">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	toolbar	: CMUI_Toolbar;

begin
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCSV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then 
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnReCalc, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnCSV_click" id="f01fe61e-c297-4f38-bca3-0c98f9a1d181">
        <controlMethod name="CMUI_Button::click"/>
