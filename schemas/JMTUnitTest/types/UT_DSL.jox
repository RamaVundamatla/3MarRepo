    <JadeMethod name="deleteProcessHarbour" id="9424437e-9b5e-4202-b0bb-a9d5b961d437">
        <source>deleteProcessHarbour( _voyageProcess : CM_VoyageProcess; _harbour : HMS_Harbour );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2019	jlgndl1	Initial creation	TFS 44773

*/

vars

	processHarbour : CM_ProcessHarbour;
	obj : CM_Object;

begin

	if _voyageProcess = null or _harbour = null then
		return;
	endif;

	processHarbour := _voyageProcess.allProcessHarbours.getAtKey( _voyageProcess, _harbour );
	if processHarbour = null then
		return;
	endif;
	
	obj := processHarbour;
		
	app.myTrxDA.trxDeleteCMObject( obj, app.myPassport );

epilog

end;</source>
