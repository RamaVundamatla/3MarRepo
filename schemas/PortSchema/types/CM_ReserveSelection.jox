    <JadeMethod name="getAllCargoMatchingRelease" id="896518d1-32a4-4e96-ba33-6c563ad0037d">
        <source>getAllCargoMatchingRelease(_coll : Collection input;
							minCargoIdLength : Integer output);
/*

Date		Who		Reason
11 September 2015	cnwer1	Initial creation PAR 36908

*/

vars
	ti : CM_TrackedItem;
	cargoType : CM_CargoType;
	startTi : CM_TrackedItem;
	iter : Iterator;
	terminal	: CM_Terminal;
	reason : String;
begin
		
	cargoType := self.getCargoType;
	if cargoType = null then
		return;
	endif;
	
	terminal:=self.getMyTerminal();
	iter := terminal.allOnsiteTIsByCargoTypeId.createIterator;
	terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(cargoType.id,null,iter);
	while iter.next(ti) do
		if ti.myCargoType &lt;&gt; cargoType then
			break;
		endif; 
		if not ti.testAgainstReserveSelection(self, reason, true, null ) then
			continue;
		endif;
		if not _coll.includes(ti) then
			_coll.add( ti );
		endif;
		if minCargoIdLength = 0 then
			minCargoIdLength:=ti.id.length;
		else
			minCargoIdLength:=minCargoIdLength.min(ti.id.length);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
        <Parameter name="minCargoIdLength" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getAllItemsForRelUseSelector" id="369f6eb7-1064-41e4-9b06-9b6f0ff51b54">
        <source>getAllItemsForRelUseSelector(_allTis : Collection input);
/*

Purpose:			This method get the list of tracked items that match the release request using Selector Query

Parameters:			

Return Value:		

Date		Who		Reason
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

*/

vars
	transUserQuery 			: CM_MenuUserQuery;
	transCriteriaLineHolder : CM_QueryCriteriaLineHolder;
	enqController			: CM_EnqControllerTI;
	qryDef					: CM_QueryDefinition;
	
begin
	create transUserQuery transient;
	create transCriteriaLineHolder transient;
	create enqController transient;
	
	transUserQuery.allCriteriaLineHolders.add(transCriteriaLineHolder);
	
	self.buildQueryToMatchDetails(transUserQuery,transCriteriaLineHolder);
	
	qryDef := app.myRoot.allQueryDefinitionObjects[transUserQuery.getType(), transUserQuery.queryMode];
	
	enqController.myCriteriaLineHolder := transUserQuery.allCriteriaLineHolders.first();
	
	create enqController.allObjects as CM_ObjectSet transient;
	
	enqController.doQuery(qryDef);
	
	enqController.allObjects.copyNoDups(_allTis);
	
epilog
	delete transCriteriaLineHolder;
	delete transUserQuery;
	delete enqController.allObjects;
	delete enqController;
end;</source>
        <Parameter name="_allTis" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="f833f453-9634-4016-9071-dbfebb3c5eaa">
        <source>getAuditText(): String;
// 18/04/2008 cnwar2 #16533

vars
	txt, tmpStr : String;
	int, length	: Integer;
	
begin
	txt := inheritMethod();
	
	if self.allAvailabilityGrades.size &gt; 0 then
		foreach int in self.allAvailabilityGrades do
			tmpStr := tmpStr &amp; int.String &amp; ", ";
		endforeach;
		length := tmpStr.length;
		tmpStr := tmpStr[1:length-2]; // remove trailing comma
	endif;
	
	txt := txt &amp; 'availabilityGrades' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		
	return txt;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAvailabilityGradesDescr" id="b7f56084-46d1-489c-8fc6-3a8d9ce40804">
        <source>getAvailabilityGradesDescr():String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 25 Mar 2024   	navma1		ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
// 25 Mar 2024 		navhl20 	ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
// ---------------------------------------------------------------------------
vars
	numGrades, i 	: Integer;
	grade      		: Integer;
	gradesDesc,desc : String;
	obj        		: CM_MTGrade;
	code			: CM_MTGradeCode;
	op				: CM_Operator;
	canDisplay		: Boolean;
	root			: CM_Root;
begin

	
	if self.allAvailabilityGrades.isEmpty then					//25.03.2024 navma1 #63141
		return null;
	endif;
	
	if self.myReserveHeader &lt;&gt; null then
		op := self.myReserveHeader.myOperator;
	endif;
	
	numGrades := self.allAvailabilityGrades.size;
	root	  := app.myRoot;									//25.03.2024 navma1 #63141
	
	foreach i in 1 to numGrades do
	    grade := self.allAvailabilityGrades.at(i);	  
        obj := root.allAvailabilityGrades[grade];
       
	   if obj&lt;&gt;null then
        	code := null;
        	obj.getTranslationForOperator(null, op, null, code, canDisplay);
        	if code &lt;&gt; null then
        		gradesDesc := code.description 			 	 &amp; "," &amp; gradesDesc;
        	elseif canDisplay then
				if gradesDesc = null then						//25.03.2024 navhl20 #62300
					gradesDesc := obj.description.trimBlanks;
				else
					gradesDesc := obj.description.trimBlanks &amp; "," &amp; gradesDesc;
				endif;
        	endif;
        endif;
	endforeach;
	
	return gradesDesc;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAvailabilityGradesIntegers" id="45b8d40e-2170-40a3-b29c-3494677aea41">
        <source>getAvailabilityGradesIntegers() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jan 2017	cnwrh7	Initial creation TFS2929
13 Mar 2017	cnwrs1	TFS3648 add other Release Request fields
25 Mar 2024 navma1	ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
*/

vars
	grade 		: Integer;
	gradesCode  : String;
begin
	
	foreach grade in self.allAvailabilityGrades do
		if gradesCode = null then
			gradesCode := grade.String;
			break;
		endif;
	endforeach;

	return gradesCode;
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
