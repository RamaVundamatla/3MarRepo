<Class name="CM_QDecimalVolumeMethod" id="c8d76f47-bf59-417c-993a-aa9e57917059">
    <superclass name="CM_QDecimalMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="getValueForObject" id="bd9f022c-53ef-40c6-bf4a-c6bb68988751">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Date		    Who			Reason
28 January 2011	cnwas3	 par 25295
23 September 2013 cnwmc5 PAR 32516 - Volume was getting converted based off value stored in database when it should be
									using the default value defined by the user in JMT.
*/

vars
	value 	: Decimal [23,10];
	measure	: CM_MeasurementType;

begin
	if self.myMeasurementType = null then
		measure := app.getDefaultMeasurementForType(Type_Volume);
		value := _obj.sendMsg(self.propertyName).Decimal;
		return app.convertMeasurementForDisplay(measure.shortName, value) &amp; Space &amp; measure.shortName;
	endif;
	
	return _obj.sendMsg(self.propertyName).Decimal;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="ac56ae76-cd8e-4861-afcc-527723ba58de">
        <source>translateToDisplayValue(_value: Any): String;
/*

Date		    Who			Reason
28 January 2011	cnwas3	  	par 25295
10 May 2013		cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
*/

vars

begin
	return inheritMethod(_value);									// PAR #31155
	//return _value.Decimal.asStringJMTWithPrecision(3, false);		// PAR #31155
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
