        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuExportBooking_click(menuItem: MenuItem input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/08/2010	cnwdap1	Initial creation PAR #23925
*/
vars
	ti 		: CM_TrackedItem;

begin
	// get selected tracked item
	if self.tblUnpacked.allSelectedObjects.isEmpty then
		return;
	endif;
	self.doSelectExportBooking(self.tblUnpacked.allSelectedObjects.first.CM_TrackedItem);
epilog
	
end;</source>
