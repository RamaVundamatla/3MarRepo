    <JadeMethod name="setWeightAndCounts" id="628ea368-b4d3-4406-b6e8-961d375e953d">
        <updating/>
        <source>setWeightAndCounts(_release : CM_BulkRelease; _targetLocation : CM_LocationsController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
02 September 2021	jlier1	Initial creation 51879
11 January 2024	navcs2	ChangeRequest 61549: EUP | Release Request by Weight - Pack/Load, Rail Lander

*/

vars
	countLoaded, countToLoad : Integer;
	weightLoaded, weightToLoad : Decimal[16,4];		// 11 January 2024	navcs2	ChangeRequest 61549
	measureType : CM_MeasurementType;
begin
	if _release = null  then
		return;
	endif;
	
	_release.getLoadedAmountsForTarget(_targetLocation,countLoaded,countToLoad,weightLoaded, weightToLoad);
	self.countLoaded:=countLoaded;
	self.countToLoad:=countToLoad;
	if self.countToLoad = 0 then
		self.countToLoad:=countLoaded;
	endif;
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null then
		self.weightLoaded:=app.convertMeasurementForDisplay(measureType.shortName, weightLoaded)&amp; " " &amp; measureType.shortName;
		self.weightToLoad:=app.convertMeasurementForDisplay(measureType.shortName, weightToLoad)&amp; " " &amp; measureType.shortName;	// 11 January 2024	navcs2	ChangeRequest 61549
	else
		self.weightLoaded:= weightLoaded.asStringWeightJMT;
		self.weightToLoad:= weightToLoad.asStringWeightJMT;	// 11 January 2024	navcs2	ChangeRequest 61549
	endif;
epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
    </JadeMethod>
</Class>
