    <JadeMethod name="getMyOperator" id="e7152c7f-6d29-4980-880e-248af46f5b5f">
        <source>getMyOperator():CM_Operator;
/*
Date		Who		Reason
03 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlation	:CM_Xlation;
begin
	xlation := self.myXlation;
	
	if xlation &lt;&gt; null then
		return xlation.getMyOperator;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
