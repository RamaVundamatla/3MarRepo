    <JadeMethod name="setFromCmifAndXtabFields" id="0764260e-6643-49bc-b4dd-fb031d1acedd">
        <updating/>
        <source>setFromCmifAndXtabFields(	_cmifField : CMIF_OutputField;
							_xtabField : CM_XTABField
							) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin

	self.heading := _cmifField.heading;
	self.propertyName := _xtabField.propertyName;						
	self.decimals := _cmifField.getDecimalsValue;
	self.useSeperator := _cmifField.useSeperator;
							
epilog

end;</source>
