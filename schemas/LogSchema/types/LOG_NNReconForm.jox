    <JadeMethod name="populateIntFaceNNLog" id="4d7b4ea8-2c51-4326-b5bd-42ff4b63b377">
        <source>populateIntFaceNNLog(_nnLog : CMIF_LogNNReconDtl input);
// ---------------------------------------------------------------------------
// Created:     02 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin

	_nnLog.mode 	:= self.updateMode;

	if self.cmbEntLot.listObject &lt;&gt; null then
		_nnLog.myLogLot := self.cmbEntLot.listObject.CM_LogLot;
	endif;

	_nnLog.hatch 	:= self.tblData.getValueByName(ETRow_Hatch).Integer;
	_nnLog.place 	:= _nnLog.getPlaceHoldFromString(self.tblData.getValueByName(ETRow_Place).String);

	if self.cmbEntStevedore.listObject &lt;&gt; null then
		_nnLog.myStevedore := self.cmbEntStevedore.listObject.CM_Stevedore;
	endif;

	_nnLog.numberOfPieces := self.tblData.getValueByName(ETRow_PieceCount).Integer;
	_nnLog.comment 	:= self.tblData.getValueByName(ETRow_Comment).String;

	if self.cmbEntLocation.listObject &lt;&gt; null then
		_nnLog.myPlannedLocation := self.cmbEntLocation.listObject.CM_LogController;
	endif;

	_nnLog.myLogVoyageStructure := self.myFiltLogVoyage.myLogVoyageStructure;
	
	if self.cmbEntRejCode.listObject &lt;&gt; null then
		_nnLog.reasonCode := self.cmbEntRejCode.listObject.CM_LogRejectCode.code;	
	endif;
	
	if self.cmbEntRecover.listObject &lt;&gt; null then
		_nnLog.recoveryCode := self.cmbEntRecover.listObject.CM_LogRejectRecoveryCode.code;
	endif;

	_nnLog.myUser := app.getMyUser();
	_nnLog.userCode	:= app.getMyUserCode;
	
end;</source>
        <Parameter name="_nnLog" type="CMIF_LogNNReconDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectCurrentRow" id="a5e63090-ede0-4b0b-97c7-507edac1d3d2">
        <source>selectCurrentRow(table : Table input);
// ---------------------------------------------------------------------------
// Created:     04 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	column,
	row				: Integer;
	checkValue		: String;
begin
	row := table.row;
	column := table.column;
	checkValue := table.accessCell(row,1).text;
	
	if row &lt;&gt; 1 and column &lt;&gt; 1 then
		if checkValue = Row_Checked then
			table.accessCell(row,1).text := Row_Unchecked;
		else
			table.accessCell(row,1).text := Row_Checked;
		endif;
	endif;	
	
	table.accessRow(table.row).selected := false;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectUnselectAll" id="6e6f6229-f512-4b9a-bbcd-2019938a05d3">
