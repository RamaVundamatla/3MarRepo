    <JadeMethod name="doLanderComplete" id="26185433-d499-4fce-839e-a1b8662063ce">
        <source>doLanderComplete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2019	jlger1	Initial creation

*/

vars
	allPropertyNames,
	allPropertyValues : StringArray ;
	cmbService :ComboBox;
	cmbOperation :ComboBox;
begin
	if self.targetLocation = null or self.currentTI = null then
		return;
	endif;
	
	cmbService := self.myWebServiceTestForm.cmbService;
	cmbService.gotFocus(cmbService);
	cmbService.listIndex:=app.atcgGetComboStringIndex(cmbService, 1, 'JMTUserInterfaceService', 3);
	cmbService.click(cmbService); 
	
	app.doWindowEvents(shortPause);
	cmbOperation := self.myWebServiceTestForm.cmbOperation;
	cmbOperation.gotFocus(cmbOperation);
	cmbOperation.listIndex:=app.atcgGetComboStringIndex(cmbOperation, 1, 'doLanderComplete', 51);
	cmbOperation.click(cmbOperation);
	
	create allPropertyNames transient;
	create allPropertyValues transient;
	
	allPropertyNames.add(WS_LanderCompleteRequest::cargoOid.name);
	allPropertyValues.add(self.currentTI);
	if self.isDischarge then
		allPropertyNames.add(WS_LanderCompleteRequest::doDischargeToMachine.name);
		allPropertyValues.add(true.String);
	else
		allPropertyNames.add(WS_LanderCompleteRequest::doLoad.name);
		allPropertyValues.add(true.String);
	endif;
	if not self.isDischarge then
		allPropertyNames.add(WS_LanderCompleteRequest::loadWLEOid.name);
		allPropertyValues.add(self.currentWLE);		
	endif;

	allPropertyNames.add(WS_LanderCompleteRequest::targetLocation.name);
	allPropertyValues.add(self.targetLocation);
	allPropertyNames.add(WS_LanderCompleteRequest::voyageOid.name);
	allPropertyValues.add(self.voyageOid);

	self.myWebServiceTestForm.createEmptyInputMessage(allPropertyNames,allPropertyValues);
	self.sendWebService;
	
epilog
	delete allPropertyNames;
	delete allPropertyValues;
end;</source>
    </JadeMethod>
    <JadeMethod name="getLanderCargo" id="0f369a00-f83a-4732-8e5d-4fb6452bba43">
        <updating/>
        <source>getLanderCargo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2019	jlger1	Initial creation

*/

vars
	allPropertyNames,
	allPropertyValues : StringArray ;
	cmbService :ComboBox;
	cmbOperation :ComboBox;
	iter : Iterator;
	wsCargo : WS_TrackedItem;
	rtQueueEntry,
	o,ti : Object;
	entryStatus : Integer;
	tiId : String;
	imvIndex : Integer;
begin
	//reset

	self.currentTI:=null;
	self.targetLocation:=null;
	self.voyageOid:=null;
	if currentIMV = null  then
		currentIMV:=self.imvs.first;
	else
		//always 5 imvs
		imvIndex:=self.imvs.indexOf(self.currentIMV);
		if imvIndex &gt; 0 and imvIndex &lt; self.imvs.size then
			self.currentIMV:=self.imvs[imvIndex + 1];
		else
			self.currentIMV:=self.imvs.first;
		endif;
	endif;
	
	
	if isDischarge then
		iter:= self.myRTQueue.getPropertyValue("allEntries").Array.createIterator;
		while iter.next(o) do
			
			entryStatus := o.getPropertyValue("status").Integer;
			//get first unactioned
			if entryStatus &lt;&gt; 0 then
				
				continue;
			endif;
			ti:=o.getPropertyValue("allTasks").Array.first.Object.getPropertyValue("ti").Object;			
			if ti = null then
				continue;
			endif;
			tiId:= ti.getPropertyValue("id").String;
			if tiId &lt;&gt; null then
				break;
			endif;
		endwhile;
	endif;
	
	
	
	cmbService := self.myWebServiceTestForm.cmbService;
	cmbService.gotFocus(cmbService);
	cmbService.listIndex:=app.atcgGetComboStringIndex(cmbService, 1, 'JMTUserInterfaceService', 3);
	cmbService.click(cmbService); 
	
	app.doWindowEvents(shortPause);
	cmbOperation := self.myWebServiceTestForm.cmbOperation;
	cmbOperation.gotFocus(cmbOperation);
	cmbOperation.listIndex:=app.atcgGetComboStringIndex(cmbOperation, 1, 'findCargo', 77);
	cmbOperation.click(cmbOperation);
	
	create allPropertyNames transient;
	create allPropertyValues transient;
	allPropertyNames.add(WS_TrackedItemQueryRequest::filterVoyage.name);
	allPropertyValues.add(self.voyageCode);
	allPropertyNames.add(WS_TrackedItemQueryRequest::filterTiType.name);
	allPropertyValues.add(1.String);
	allPropertyNames.add(WS_TrackedItemQueryRequest::doFilterVoyageRequiresJob.name);
	allPropertyValues.add(true.String);
	allPropertyNames.add(WS_TrackedItemQueryRequest::filterVoyageRequiresJob.name);
	allPropertyValues.add(true.String);
	allPropertyNames.add(WS_TrackedItemQueryRequest::filterSite.name);
	if self.isDischarge then
		allPropertyValues.add("5"); // on ship
	else
		allPropertyValues.add("1");  //on site
	endif;
	
	if self.isDischarge and tiId &lt;&gt; null then
		allPropertyNames.add(WS_TrackedItemQueryRequest::filterId.name);
		allPropertyValues.add(tiId );
	endif;


	if not self.isDischarge then
		allPropertyNames.add(WS_TrackedItemQueryRequest::filterYardLocation.name);
		allPropertyValues.add(currentIMV);
	endif;
	
	allPropertyNames.add(WS_TrackedItemQueryRequest::maxReturnedItems.name);
	allPropertyValues.add(20.String);
	self.myWebServiceTestForm.createEmptyInputMessage(allPropertyNames,allPropertyValues);
	self.sendWebService;

	
	if  self.myWebServiceTestForm.myLastOutput = null then
		return;
	endif;
	
	if self.myWebServiceTestForm.myLastOutput.isKindOf(FindCargoResponse) then
		if self.myWebServiceTestForm.myLastOutput.FindCargoResponse.findCargoResult.allTrackedItems.size = 1 then
			wsCargo:=self.myWebServiceTestForm.myLastOutput.FindCargoResponse.findCargoResult.allTrackedItems.first;
		endif;
		if wsCargo &lt;&gt; null then
			currentTI:=wsCargo.cmObjectId;
			if wsCargo.voyageCode &lt;&gt; null then
				voyageOid:= wsCargo.voyageCode.cmObjectId;
			endif;
			if self.isDischarge then
				targetLocation:=currentIMV;
			else

				targetLocation:=wsCargo.locnQueued;
			endif;
		endif;
	endif;
	
epilog
	delete allPropertyNames;
	delete allPropertyValues;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getLanderWLEs" id="bf738b2e-1ede-4367-9272-8fe419da5f70">
        <updating/>
        <source>getLanderWLEs() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2019	jlger1	Initial creation

*/

vars
	allPropertyNames,
	allPropertyValues : StringArray ;
	cmbService :ComboBox;
	cmbOperation :ComboBox;
begin
	self.currentWLE:=null;
	if self.targetLocation = null or self.currentTI = null then
		return;
	endif;
	
	cmbService := self.myWebServiceTestForm.cmbService;
	cmbService.gotFocus(cmbService);
	cmbService.listIndex:=app.atcgGetComboStringIndex(cmbService, 1, 'JMTUserInterfaceService', 3);
	cmbService.click(cmbService); 
	
	app.doWindowEvents(shortPause);
	cmbOperation := self.myWebServiceTestForm.cmbOperation;
	cmbOperation.gotFocus(cmbOperation);
	cmbOperation.listIndex:=app.atcgGetComboStringIndex(cmbOperation, 1, 'getVoyageWLEsForCargoItem', 283);
	cmbOperation.click(cmbOperation);
	
	create allPropertyNames transient;
	create allPropertyValues transient;
	allPropertyNames.add(WS_VoyageWLEQueryRequest::cargoOid.name);
	allPropertyValues.add(self.currentTI);
	allPropertyNames.add(WS_VoyageWLEQueryRequest::checkRequiresJob.name);
	allPropertyValues.add(true.String);
	allPropertyNames.add(WS_VoyageWLEQueryRequest::requiresJob.name);
	allPropertyValues.add(true.String);
	allPropertyNames.add(WS_VoyageWLEQueryRequest::isDischarge.name);
	allPropertyValues.add(self.isDischarge.String);
	allPropertyNames.add(WS_VoyageWLEQueryRequest::voyageOid.name);
	allPropertyValues.add(self.voyageOid);
	allPropertyNames.add(WS_TrackedItemQueryRequest::maxReturnedItems.name);
	allPropertyValues.add(20.String);
	self.myWebServiceTestForm.createEmptyInputMessage(allPropertyNames,allPropertyValues);
	self.sendWebService;
	
	if  self.myWebServiceTestForm.myLastOutput = null then
		return;
	endif;
	
	if self.myWebServiceTestForm.myLastOutput.isKindOf(GetVoyageWLEsForCargoItemResponse) then
		if self.myWebServiceTestForm.myLastOutput.GetVoyageWLEsForCargoItemResponse.getVoyageWLEsForCargoItemResult.allVoyageWLEs.size = 1 then
			self.currentWLE:=self.myWebServiceTestForm.myLastOutput.GetVoyageWLEsForCargoItemResponse.getVoyageWLEsForCargoItemResult.allVoyageWLEs.first.cmObjectId;
		endif;
	endif;
	
epilog
	delete allPropertyNames;
	delete allPropertyValues;
end;</source>
    </JadeMethod>
    <JadeMethod name="getVoyages" id="af1a297c-4aff-4284-9cd2-b9a3843bdea6">
        <updating/>
        <source>getVoyages() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2019	jlger1	Initial creation

*/

vars

	allPropertyNames,
	allPropertyValues : StringArray ;
	cmbService :ComboBox;
	cmbOperation :ComboBox;
	wsVoyage 	: WS_Voyage;
begin
	self.voyageOid:=null;
	
	cmbService := self.myWebServiceTestForm.cmbService;
	cmbService.gotFocus(cmbService);
	cmbService.listIndex:=app.atcgGetComboStringIndex(cmbService, 1, 'JMTUserInterfaceService', 3);
	cmbService.click(cmbService); 
	
	app.doWindowEvents(shortPause);
	cmbOperation := self.myWebServiceTestForm.cmbOperation;
	cmbOperation.gotFocus(cmbOperation);
	cmbOperation.listIndex:=app.atcgGetComboStringIndex(cmbOperation, 1, 'getVoyages', 281);
	cmbOperation.click(cmbOperation);

	
	create allPropertyNames transient;
	create allPropertyValues transient;
	allPropertyNames.add(WS_VoyagesRequest::onlyCellularVoyges.name);
	allPropertyValues.add(true.String);

	self.myWebServiceTestForm.createEmptyInputMessage(allPropertyNames,allPropertyValues);
	self.sendWebService;

	if  self.myWebServiceTestForm.myLastOutput = null then
		return;
	endif;
	
	if self.myWebServiceTestForm.myLastOutput &lt;&gt; null then
		if self.myWebServiceTestForm.myLastOutput.isKindOf(GetVoyagesResponse) then
			foreach wsVoyage in self.myWebServiceTestForm.myLastOutput.GetVoyagesResponse.getVoyagesResult.allVoyages discreteLock do
				if wsVoyage.code = self.voyageCode then
					self.voyageOid:= wsVoyage.cmObjectId;
					break;
				endif;
			endforeach;
		endif;
	endif;	
	
epilog
	delete allPropertyNames;
	delete allPropertyValues;
end;</source>
    </JadeMethod>
