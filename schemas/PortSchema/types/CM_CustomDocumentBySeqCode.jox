<CollClass name="CM_CustomDocumentBySeqCode" id="8df410b9-7e26-426c-978c-1252a9d669cb">
    <loadFactor>66</loadFactor>
    <memberType name="CM_CustomDocument"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_CustomDocument::sequence"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_CustomDocument::code"/>
    </MemberKey>
    <JadeMethod name="getFirstActive" id="6b9f228a-0a40-4d57-bd75-0191915045af">
        <source>getFirstActive() : CM_CustomDocument;
/*
Purpose:			

Date		Who		Reason
13 November 2023	navab1	CR 60425 TASK 60828 
*/

vars
	cd : CM_CustomDocument;
begin
	foreach cd in self discreteLock do
		if cd.isActive() then
			return cd;
		endif;
	endforeach;
	
	return null;
	
epilog
end;</source>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="getLastActive" id="c0b3e154-e9a1-404c-9701-0eebb6dcc312">
        <source>getLastActive() : CM_CustomDocument;
/*
Purpose:			

Date		Who		Reason
13 November 2023	navab1	CR 60425 TASK 60828 
*/

vars
	cd : CM_CustomDocument;
begin
	foreach cd in self discreteLock, reversed do
		if cd.isActive() then
			return cd;
		endif;
	endforeach;
	
	return null;
	
epilog
end;</source>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="getLastActiveOutward" id="5d3022a3-383f-42ca-ab19-ff7ff5f2ecae">
        <source>getLastActiveOutward() : CM_CustomDocument;
/*
Purpose:			

Date		Who		Reason
24 November 2023	navab1	CR 59067
*/

vars
	cd : CM_CustomDocument;
begin
	foreach cd in self discreteLock, reversed do
		if cd.isOutward() then
			if cd.isActive() then
				return cd;
			endif;
		endif;
	endforeach;
	
	return null;
	
epilog
end;</source>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="getPrevForSequence" id="ff441ddb-3ab6-44b5-9f73-b35e3d14790f">
        <source>getPrevForSequence(_prevseq : Integer) : CM_CustomDocument;
/*
Purpose:			

Date		Who		Reason
13 November 2023	navab1	CR 60425 TASK 60828 
*/

vars
	prevCustDoc : CM_CustomDocument;
	iter : Iterator;
begin
	if self.isEmpty() then
		return null;
	endif;
	
	prevCustDoc := self.getAtKeyGeq(_prevseq,"");
	if prevCustDoc &lt;&gt; null
	and prevCustDoc.isActive() then
		return prevCustDoc;
	endif;

	prevCustDoc := self.getAtKeyLss(_prevseq,"");
	
	if prevCustDoc= null then
		return null;
	endif;
	
	iter := self.createIterator();
	
	iter.startAtObject(prevCustDoc);
	while iter.back(prevCustDoc) do
		if prevCustDoc.isActive() then
			return prevCustDoc;
		endif;
	endwhile;
	
	return null;

epilog
	delete iter;
end;</source>
        <Parameter name="_prevseq" type="Integer"/>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
</CollClass>
