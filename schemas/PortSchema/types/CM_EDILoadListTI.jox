    <JadeMethod name="isForLocal" id="3a25a2c4-a0a6-4960-8754-d9302ef0349e">
        <source>isForLocal(_localPort :String): Boolean;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 05/09/2012	cnwcs5	par 29842 - pass in local port to save looking up config multiple times when in loop
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	config		: CM_EDIConfig;
	localPort	: String;
begin
	if _localPort &lt;&gt; null then							// par 29842 Sep 2012
		return self.loadPort.trimBlanks = _localPort;	// par 29842 Sep 2012
	endif;												// par 29842 Sep 2012
	
	if self.myEDIData = null then
		return false;
	endif;
	
	config := self.myEDIData.ediConfig;
	
	if config = null then
		return false;
	endif;

	if config.myTerminal = null then
		return false;
	endif;

	localPort := config.myTerminal.getConfig(PortDestCode).String.trimBlanks;
	
	return self.loadPort.trimBlanks = localPort;

end;</source>
        <Parameter name="_localPort" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
