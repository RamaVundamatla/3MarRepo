    <JadeMethod name="searcherTblInitControls" id="3d2ca116-590d-4f09-b1f9-cf152b93abeb">
        <updating/>
        <source>searcherTblInitControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 14605: EUP | Implement Satellite View of Large Dataset Display using "displayCollection"

*/

vars

begin
	self.tblSearch.setControl(2, self.cmbCargoType);
	self.tblSearch.setControl(3, self.cmbCargoSubtype);
	self.tblSearch.setControl(4, self.cmbIsoType);

	self.tblSearch.hideRowByName(ETRow_FilterProduct, false);
	self.tblSearch.hideRowByName(ETRow_FilterISOType, false);

	self.myAssistant.comboBoxCargoTypes(self.cmbCargoType, null);
	self.myAssistant.comboBoxISOTypeByGroup(self.cmbIsoType, null, null);
	self.adjustSearcherHeight();
	self.frmSearch.relativeHeight := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllTIs" id="41466e22-117f-43f9-aaa5-8caa9f2fd216">
        <source>setAllTIs(_objArr : ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 14605: EUP | Implement Satellite View of Large Dataset Display using "displayCollection"

*/

vars
	obj	: Object;
begin
	foreach obj in _objArr where CM_TrackedItem.hasInstance(obj) do
		self.allTIs.tryAdd(obj.CM_TrackedItem);
	endforeach;
epilog

end;</source>
        <Parameter name="_objArr" type="ObjectArray"/>
    </JadeMethod>
