    <JadeMethod name="getPort" id="b205fda2-1d17-4c87-a1dd-9716af5c0d87">
        <source>getPort( _rawValue : String; _operator : CM_Operator ):CM_Port;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	port : CM_Port;
	translatedCode : String;
	found : Boolean;

begin

	port := app.myRoot.allPorts[ _rawValue ];
		
	if port = null and _operator &lt;&gt; null then
		translatedCode := _operator.getXlationSystemCode( _rawValue, XLATION_TYPE_PORT_BYOP, found );
		if found then
			port := app.myRoot.allPorts[ translatedCode ];
		endif;
	endif;
	
	return port;

epilog

end;</source>
        <Parameter name="_rawValue" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="getShippingLine" id="a8817e4e-2be9-48d7-a56d-f5add45ca3a1">
