    <JadeMethod name="getTblDataXML" id="df73e3af-4f86-4db3-a023-6cc3fd7d6cce">
        <updating/>
        <source>getTblDataXML(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	tmpStr	: String;
	
begin
//	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblData.XMLTag_Table &amp; self.tblData.name);
//	self.xmlStrTblData := global.formatAsXMLPrefix(self.tblData.XMLTag_Table &amp; self.tblData.name) &amp; tmpStr &amp; global.formatAsXMLSuffix(self.tblData.XMLTag_Table &amp; self.tblData.name);
	
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblData.XMLTag_Table &amp; self.tblData.name);
	self.xmlStrTblData := global.formatAsXMLPrefix(self.tblData.XMLTag_Table &amp; self.tblData.name) &amp; tmpStr &amp; global.formatAsXMLSuffix(self.tblData.XMLTag_Table &amp; self.tblData.name);


