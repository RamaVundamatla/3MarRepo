    <JadeMethod name="showMakeLCL" id="4f942d29-2904-45b1-bea8-4a23913255ab">
        <source>showMakeLCL(	_parentForm : CM_BaseForm;
				_relatedObj : Object;
				_modal : Boolean;
				_columns : Integer;
				_controlWidth : Integer;
				_packUnpack : Boolean
				):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2013	cnwndl1	Initial creation	Par 32854

*/

vars

	form	: CMUI_ReceiveCargoForm;

begin

	if _modal then
		form := app.loadForm(	CMUI_ReceiveCargoFormModal, 
								self.class, 
								false, false, false, 
								self.myTerminal, null).CMUI_ReceiveCargoFormModal;
	else
		form := app.loadForm(	CMUI_ReceiveCargoForm, 
								self.class, 
								false, false, false, 
								self.myTerminal, null).CMUI_ReceiveCargoForm;
	endif;
	
	// If user fails security we don't want to show a null form.
	if form &lt;&gt; null then
		
		// PAR 35740 
		if _packUnpack then
			form.setIsGeneralCargo();
		else
			form.setIsAnyCargo();// PAR 35740 
		endif;
		
		form.setColumnsAndControlWidth(_columns, _controlWidth);
		form.initFromPackUnpackForm( _parentForm, _relatedObj );
		
		if _modal then
			form.showModal();
		else
			form.show();
		endif;
		
	else
		return false;
		
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_relatedObj" type="Object"/>
        <Parameter name="_modal" type="Boolean"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_packUnpack" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
