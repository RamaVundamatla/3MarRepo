<CollClass name="CM_InvoiceSet" id="2203fa43-6944-4740-af10-d749ae30dbf1">
    <loadFactor>98</loadFactor>
    <memberType name="CM_Invoice"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <JadeMethod name="isAllMatchingStatus" id="bbe4eafd-192b-4aa7-80c6-79aba32226db">
        <source>isAllMatchingStatus(_status : Integer):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link

*/

vars
	invoice : CM_Invoice;
begin
	foreach invoice in self do
		if not invoice.status &lt;&gt; _status then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
