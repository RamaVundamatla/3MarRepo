    <JadeMethod name="pxyCreateUpdateProxy" id="d1205c5b-eeb6-4aa9-89fc-7a500038eef5">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars
	pxy : SelfType;
	completedOK : Boolean;

begin
	pxy := inheritMethod();
	
	pxy.myReleaseRequest := self.getMyReleaseRequest;
	
	completedOK := true;
	return pxy;

epilog
	if not completedOK then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e8c43c1d-3dca-4231-8160-c0e46754ca3f">
