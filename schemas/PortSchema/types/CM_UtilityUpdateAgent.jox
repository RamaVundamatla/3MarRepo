    <JadeMethod name="utlUpdateTerminal" id="0d53dc6d-14df-4d4f-8a2f-aadd7b51cbda">
        <source>utlUpdateTerminal(pProxyTerminal:CM_Terminal; _cmifConfig : CMIF_Config input; _financeConfig : CMIF_InvoiceSystemDefaults; _passport : CM_Passport input);
//21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
vars
	realTerminal:CM_Terminal;
	expectedEdition:Integer;
begin

	self.initialiseActivity();

	pProxyTerminal.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyTerminal.pxyGetRealObjectAndEdition(realTerminal, expectedEdition);
	
	if realTerminal = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Terminal.name, null, null);
		return;
	endif;

	app.myValUA.valTerminal(realTerminal, pProxyTerminal);
	app.myValUA.valTerminalConfig(realTerminal,_cmifConfig.CMIF_ConfigTerminal); // PAR 17703 AKB2008AUG
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realTerminal);

	if _passport.noErrors and realTerminal.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Terminal', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTerminal, true);
	endif;
	
	// ###############
	// TERMINAL UPDATE
	if _passport.noErrors then
		realTerminal.setForUpdate(pProxyTerminal);
	endif;

	// ###############
	// TERMINAL GRAPHICS
	if _passport.noErrors then
		self.utlUpdateTerminalGraphics(pProxyTerminal, realTerminal, _passport );
	endif;

	if _passport.noErrors then
		_cmifConfig.updatePersistentObject(realTerminal, _passport);
	endif;
	
	// PAR 33572
	if _passport.noErrors and _financeConfig &lt;&gt; null then
		self.utlUpdateInvoiceSystemDefaults( _financeConfig, _passport, false );

	endif;
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.isOpsViewEnabled(realTerminal) then // ### TFS 50669 24AUG2021 NAVAB1
		realTerminal.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
											 BGP_OpsViewWSRequest.OPS_TYPE_TERMINAL,
											 realTerminal);
	endif;
	//21.09.2020 cnwma1 TFS #49906
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTerminal, false);
	endif;

epilog
	
end;</source>
        <Parameter name="pProxyTerminal" type="CM_Terminal"/>
        <Parameter name="_cmifConfig" type="CMIF_Config" usage="input"/>
        <Parameter name="_financeConfig" type="CMIF_InvoiceSystemDefaults"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTerminalArea" id="5bf090da-9fd6-46fc-9f62-396e6722f561">
        <source>utlUpdateTerminalArea(_proxyTA: CM_TerminalAreaMaster input; _passport: CM_Passport input);
//utlUpdateTerminalArea(_proxyTA: CM_TerminalArea input; _theRealTA: CM_TerminalArea output; _passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realTA		 	: CM_TerminalAreaMaster;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();

	
	_proxyTA.raiseExceptionIfNotProxy(method);
	_proxyTA.pxyGetRealObjectAndEdition(realTA, expectedEdition);
	
	
	if realTA = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TerminalArea.name, null, null);
		return;
	endif;

	if expectedEdition &lt; 1 then
		app.raiseCMException2(ExpectedEditionInvalid, expectedEdition.String, method.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	app.myValUA.valTerminalArea(_proxyTA, realTA); 

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	exclusiveLock(realTA);

	if _passport.noErrors then
		if expectedEdition &lt;&gt; realTA.edition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Terminal Area', null, null);
			return;
		endif;
	endif;

	// cnwrd1 4.7.2008 par #17374
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realTA, true);
	endif;
	
	if _passport.noErrors then
		realTA.setForUpdate(_proxyTA);
//		realTA.setForUpdate(_controller);
	
		if _passport.noErrors then
			//set the output reference
//			_theRealTA := realTA;
			// update the graphic display of the yard
			realTA.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,realTA);//epr 11/6/08  par 16956 
		endif; 
	endif;
	

	// cnwrd1 4.7.2008 par #17374
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realTA, false);
	endif;
	
	
epilog
end;</source>
        <Parameter name="_proxyTA" type="CM_TerminalAreaMaster" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTerminalAreaFlag" id="4870a5ef-941b-4c35-85cc-f3fae43bd89a">
        <updating/>
        <source>utlUpdateTerminalAreaFlag(_realTerminalArea : CM_TerminalArea input;
							_isSuitableForLoadFrom,
							_isSuitableForLoadInto : Boolean;
							_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	app.myValUA.valTerminalAreaFlags(_realTerminalArea, _isSuitableForLoadFrom, _isSuitableForLoadInto); 

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	exclusiveLock(_realTerminalArea);
	
	if (not _passport.noErrors) then
		return;
	endif;
	
	//validation ensures both flags can't be true -
	_realTerminalArea.setFlagsForUpdate(_isSuitableForLoadFrom, _isSuitableForLoadInto);
	
	if _passport.noErrors then
		// update the graphic display of the yard
		_realTerminalArea.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA), false, _realTerminalArea); //epr 11/6/08  par 16956 
	endif;

end;</source>
        <Parameter name="_realTerminalArea" type="CM_TerminalArea" usage="input"/>
        <Parameter name="_isSuitableForLoadFrom" type="Boolean"/>
        <Parameter name="_isSuitableForLoadInto" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTerminalAreaGCAlloc" id="1e635dcb-bb53-4f6b-97e9-67de29096f59">
        <source>utlUpdateTerminalAreaGCAlloc(_proxyTA : CM_GeneralCargoAllocRowArea input; _passport: CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/12/2020	jlgdap1		Initial creation TFS 50110 ASPA General Cargo Allocation Row - Label
//
vars
	realTA : CM_GeneralCargoAllocRowArea;
	expectedEdition : Integer;
	tis : CM_TIArray;
	newGroups : StringArray;
	group, pxyGroup : CM_GeneralCargoAllocGroup;
	groupLc, lc : CM_LocationsController;
	column, firstCol : CM_GeneralCargoAllocController;
	groupId : String;
	ti : CM_TrackedItem;
	firstColId, lastColId : String;
	
begin
	self.initialiseActivity();

	_proxyTA.raiseExceptionIfNotProxy(method);
	_proxyTA.pxyGetRealObjectAndEdition(realTA, expectedEdition);
	
	if realTA = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TerminalArea.name, null, null);
		return;
	endif;

	if expectedEdition &lt; 1 then
		app.raiseCMException2(ExpectedEditionInvalid, expectedEdition.String, method.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	app.myValUA.valTerminalArea(_proxyTA, realTA); 

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// We need to see if the groups in the terminal area have changed, so we know whether we need to 
	// move some TIs around later (TIs have the first column in a group as their location, so if a group 
	// changes its first column, we need to move the TIs
	create tis transient;
	create newGroups transient;
	foreach groupLc in realTA.allRowControllersById do
		group := groupLc.CM_GeneralCargoAllocGroup;
		if _proxyTA.allRowControllersById[group.ident] = null then
			// this group no longer exists - does it have any TIs?
			firstCol := group.allLocations.first.CM_GeneralCargoAllocController;
			if not firstCol.allTrackedItems.isEmpty then
				// need to find where this group fits in the proxy groups
				firstColId := group.firstColumn;
				lastColId := group.lastColumn;
				foreach lc in _proxyTA.allRowControllersById do
					pxyGroup := lc.CM_GeneralCargoAllocGroup;
					if firstColId &gt;= pxyGroup.firstColumn and firstColId &lt; pxyGroup.lastColumn 
					or pxyGroup.firstColumn &gt; firstColId and lastColId = pxyGroup.lastColumn then
						foreach ti in firstCol.allTrackedItems do
							if not tis.includes(ti) then
								tis.add(ti);
								newGroups.add(pxyGroup.ident);
							endif;
						endforeach;
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
	
	app.setContinueCMExceptions(false);
	exclusiveLock(realTA);

	if _passport.noErrors then
		if expectedEdition &lt;&gt; realTA.edition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Terminal Area', null, null);
			return;
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTA, true);
	endif;
	
	if _passport.noErrors then
		realTA.setForUpdateAllocArea(_proxyTA, tis, newGroups);
	
		if _passport.noErrors then
			// update the graphic display of the yard
			realTA.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,realTA);//epr 11/6/08  par 16956 
		endif; 
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTA, false);
	endif;
	
epilog
	delete tis;
	delete newGroups;
end;</source>
        <Parameter name="_proxyTA" type="CM_GeneralCargoAllocRowArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTerminalAreaICAreas" id="2d53d4cf-4292-4217-81b7-faac4b33bd15">
