    <JadeMethod name="allowEDIActions" id="f2093ccc-400f-426e-aef3-1e7e539c0706">
        <source>allowEDIActions(): Boolean;
// ---------------------------------------------------------------------------
// Created:     nov 2005 Russell sargent
//
// Purpose:     
// ---------------------------------------------------------------------------

vars

begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
