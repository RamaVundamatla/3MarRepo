    <JadeMethod name="updateId" id="1e1025c3-cae7-42e5-a2de-8009e8e329a0">
        <updating/>
        <source>updateId(_value :String)updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 October 2009 by cnwcs5:1
// Purpose:     Par 21404 - update the id for a terminal area and also fixup
//				any associated locations controllers/tracked items  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc				:CM_LocationsController;
	ti				:CM_TrackedItem;
	newLocationId	:String;
	swapStack		:CM_SwapStack;
	move			:CM_FutureMove;
begin
	// temporary code - in first instance we only want to call this method for VTA
	// we can remove this check once we cover all terminal area types
	if not self.isKindOf (CM_VehicleTransferArea) and
		not self.isKindOf (CM_SwapStack) then	// *** added after Nelson conversion failure
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called for unexpected terminal area type');
	endif;

	if _value = self.id then
		return;
	endif;
	
	self.id := _value;
	
	// we will need to do some updating for the locations controllers
	foreach lc in self.allLocationsControllers do
		if not lc.isPartOfTerminalArea then
			continue;	// skip over any lCs that are not really part of the terminal area
		endif;
		
		// update the terminal area id stored on the locations controller
		//lc.setPropertyValue (CM_LocationsController::terminalAreaId.name, self.id);
		
		// update the ids
		// a VTA will have a pre-gate, post gate and maybe some gate lane controllers
		// pre gate lc has an ident of "Pre Gate" - no change required 
		// post gate lc has an ident of "Post Gate" - no change required
		// gate lane lcs have an ident of the lane number - no change required
		
		// IF YOU USE THIS METHOD FOR OTHER TERMINAL AREAS TYPES YOU WILL NEED TO CHECK EACH LC TYPE 
		// TO DETERMINE WHETHER THE IDENT PROPERTY NEEDS TO BE UPDATED
		
		// any tracked items at any of the locations for this terminal area need their location 
		// strings updated.
		// the location id is the terminal area and location ids appended together (as done in CMUI_MoveToForm)
		// *** this only sets a valid location for a VTA - MUST be reviewed if this method used for other terminal area types
		newLocationId := lc.getFullId;	
		
		foreach ti in lc.allTrackedItems do
			if ti.myPrimaryActualLocation = lc then
				// update CM_TrackedItem::locationId
				ti.setLocationId (newLocationId);
			endif;
		endforeach;
		
		foreach move in lc.allPlannedFutureMoves do
			if not move.isKindOf (CM_FutureMovePlanned) then
				continue;
			endif;
			
			ti := move.CM_FutureMovePlanned.myTrackedItem;
			
			if ti.myPrimaryPlannedLocation = lc then
				// update CM_TrackedItem::plannedLocnId
				ti.setPlannedLocnId (newLocationId);
			endif;
		endforeach;
	endforeach;
	
	// also need to update the is on any swap stack
	swapStack := self.swapStack;
	
	if swapStack &lt;&gt; null then
		swapStack.updateId (self.getIDForSwapStack);	// *** changed after Nelson conversion failure
	endif;
	
	// *** NO QUEUE NAME UPDATE ***
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="validate" id="e8d4629b-a655-4efb-bc2b-2e368b1d59e8">
        <source>validate() protected;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants 
	
vars
	result : Integer;
	realTermArea : CM_TerminalArea;
	term : CM_Terminal;
begin
//	on CM_Exception do self.terminalAreaExceptionHandler(exception);
	
	self.raiseExceptionIfNotTransient(method);
	
	//5 sep 2008 cnwdz2 par 17858
	term := self.myTerminal;
	if term = null then
		term := app.myPassport.myTerminal;
	endif;
	
	// 33418 these checks are now in validateId
	/*
	if self.id = null then
		app.raiseCMException1(REQUIRED_FIELD, "Terminal Area ID", null, null);
	elseif self.id.hasInvalidChars()then // cnContains(" ") then
		if self.pxyIsProxy then // if proxy check real term area to see if originaly had spaces. 
			realTermArea := self.pxyGetRealObject();
			if not realTermArea.id.hasInvalidChars() then //cnContains(" ") then 	
				// originally no check for spaces when terminal area created. This was causing problems with 
				// moving ti's using location id's. this code checks if original term area has space and if so
				// allows save. Term area id not editable but was being checked on save causing an error if space present
					app.raiseCMException1(ERR_INVALID_CHARACTERS, self.id, null, null);
					app.writeStatement( 'invalid characters in the id name');
			endif;
		else
			app.raiseCMException1(ERR_INVALID_CHARACTERS, self.id, null, null);
		endif;
	endif;
	*/
		
	if self.myType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Terminal Area Type", null, null);
		app.raiseCMException(Input_required_field_trmAreTyp, null, null); // cnwdb2	PAR 35364
	endif;
	
	/*
	Date		Who		Reason
	5 Sep 2008	cnwdz2	Par17858 a terminal area is not allowed to have the same id as a vehicle. now in validateId
	*/
	///if term.vehicles[self.id, ""] &lt;&gt; null then
	///	app.raiseCMException3(ERR_DUPLICATE_TA_VEHICLE_ID, term.code, self.id, self.typeString, null, null);
	///endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
