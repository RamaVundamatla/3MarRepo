begin
	self.unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mskImport_click" id="ff261c90-1072-4baa-b753-610a902076af">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mskImport_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		03 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doFormUpdate(false) then
		self.unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateConstantCategories" id="5273ef57-bf54-40f2-b077-70ce9daa366c">
        <source>populateConstantCategories(pTheSchema:Schema; pTheCombobox:ComboBox input) protected;
// --------------------------------------------------------------------------------
// Created:		03 April 2003 by cnwdad1
//
// Purpose:		Populates the specified combobox with a collection of Global 
//				Constant category names.
//
// Parameters:	pTheSchema - The schema who's categories to populate.
//				pTheCombobox - The combobox control to populate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allCategories	: StringArray;
	
begin
	create allCategories transient;
	self.getAllConstantCategories(pTheSchema, allCategories);
	cmbCategory.listCollection(allCategories, false, 0);
epilog
	delete allCategories;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSchema" type="Schema"/>
        <Parameter name="pTheCombobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateGlobalConstants" id="93fab58d-5988-470d-b509-b878694ecb6f">
        <source>populateGlobalConstants(pTheListbox:ListBox input) protected;
// --------------------------------------------------------------------------------
// Created:		03 April 2003 by cnwdad1
//
// Purpose:		Populates the specified listbox control with the global constants
//				in the currently selected Global Constant Category.
//
// Parameters:	pTheListbox - The listbox control to populate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSchema			: Schema;
	theCategory			: ConstantCategory;
	allConstants		: ConstantNDict;
	theConstant			: Constant;
	constantName		: String;
	theImportConstant	: JSSLKImportConstant;
	listPointer			: Integer;
	
begin
	self.listboxClear(pTheListbox);
	
	if cmbSchema.listIndex = JSS_NULL_INDEX then
		app.msgBox("Please select the Schema to import the constants from.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	if cmbCategory.listIndex = JSS_NULL_INDEX then
		app.msgBox("Please select the Constant Category to import from.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	theSchema		:=	cmbSchema.listObject.Schema;
	theCategory		:=	theSchema.getConstantCategory(cmbCategory.text);
	allConstants	:=	theCategory.getConstants();
	
	foreach theConstant in allConstants do
		if theConstant.type &lt;&gt; Integer then
			continue;
		endif;
		
		create theImportConstant transient;
		theImportConstant.setConstant(theConstant);
		
		listPointer	:=	pTheListbox.addItem("(" &amp; theConstant.valueAsInteger.String &amp; ") " &amp; theConstant.name);
		pTheListbox.itemObject[listPointer]	:=	theImportConstant;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
    </JadeMethod>
</GUIClass>
