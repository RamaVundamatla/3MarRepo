    </Constant>
    <Constant name="ListOperation" id="55fbe681-1ecb-4f7c-aa24-986b828192f3">
        <source>"LIST"</source>
        <type name="String"/>
    </Constant>
    <Constant name="UpdateOperation" id="6cc03b99-14e7-4731-b995-f36abc4d269e">
        <source>"UPDATE"</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="myForm" id="4c88a60f-617d-4330-907c-e19b7adaa4cc">
        <embedded/>
