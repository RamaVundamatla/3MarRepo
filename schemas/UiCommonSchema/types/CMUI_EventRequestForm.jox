    <JadeMethod name="showCargoEnquiry" id="b108a7da-8e16-44b6-bc86-c8bf18c2723e">
        <source>showCargoEnquiry();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	eventRequest : CM_EventRequestTI;
begin
	if CM_EventRequestTI.hasInstance(self.myCurrentEventRequest) then
		eventRequest := self.myCurrentEventRequest.CM_EventRequestTI;
		tmpTI := eventRequest.myTrackedItem;
		if tmpTI &lt;&gt; null then
			self.myAssistant.showCargoEnquiry(tmpTI);
		else
			//5/11/2009 cnwdz2 par21266
			tmpTI := self.myTerminal.lookupTrackedItem(eventRequest.cargoId, eventRequest.myCargoType.id, TI_STATE_NORMAL, null, false);			
			if tmpTI &lt;&gt; null then
				self.myAssistant.showCargoEnquiry(tmpTI);
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
