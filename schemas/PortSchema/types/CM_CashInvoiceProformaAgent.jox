    <JadeMethod name="applyCreditOnProxy" id="fa9bf0c4-4a85-4b99-9da7-aa80e69c0b71">
        <updating/>
        <source>applyCreditOnProxy(	_pxyCashPayment        : CM_CashPayment io;
				   _availableCreditAmounts : DecimalArray input;
				   _availableCredits       : ObjectArray input;
				   _ti        	           : CM_TrackedItem;
				   _allPxyCreditDetails    : ObjectArray input ;
				   _now					   : TimeStamp;
				   _terminal 			   : CM_Terminal	)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Sep 2019	cnwma1	Bug 46582: Cash Credit are not being accounted for correctly

*/

vars
	cashCredit 			: CM_CashCredit;
	pxyCreditDetail,
	pxyTaxCreditDetail	: CM_CashCreditDetail;
	pxyCashTaxPayment   : CM_CashPayment;
	obj		  			: Object;
	index	   			: Integer;
	creditAvailable ,
	creditApplied,
	creditOnTax,
	creditOnPayment,
	valueOnPayment,

	valueOnPaymentTax	: Decimal[23,6];
	configCashTax       : String;
	configInvMultiTax   : Boolean;
begin
	

	configCashTax     := _terminal.getConfig(CashAllCashTax).String ;
	configInvMultiTax := _terminal.getConfig(InvoiceMultiTaxRates).Boolean ;
	valueOnPayment 	  := _pxyCashPayment.cashValue;
	
	if _pxyCashPayment.myCashPaymentForTax &lt;&gt; null then
		pxyCashTaxPayment := _pxyCashPayment.myCashPaymentForTax;
		valueOnPaymentTax := _pxyCashPayment.myCashPaymentForTax.cashValue;
	endif;
	
	foreach obj in _availableCredits do
		index           := index +1 ;
		cashCredit		:= obj.CM_CashCredit;
		creditAvailable := _availableCreditAmounts[index];
		
		if creditAvailable &gt; 0 then
			
			if valueOnPayment + valueOnPaymentTax &gt; creditAvailable then
				creditApplied 	:= creditAvailable;
				creditOnPayment := (creditApplied * (valueOnPayment / (valueOnPayment + valueOnPaymentTax))).roundToFiveCents();
				creditOnTax 	:= creditApplied - creditOnPayment;

			else
				creditApplied 	:= valueOnPayment + valueOnPaymentTax;			
				creditOnPayment := valueOnPayment;
				creditOnTax 	:= valueOnPaymentTax;
			endif;
		
			valueOnPayment 	   := valueOnPayment    - creditOnPayment;
			valueOnPaymentTax  := valueOnPaymentTax - creditOnTax;
			
			//Create Credit for Tax
			if creditOnTax &gt; 0 then
				if configCashTax = null and configInvMultiTax then		
					create pxyTaxCreditDetail transient;
					pxyTaxCreditDetail.setAppliedProxy(cashCredit, pxyCashTaxPayment, _ti, creditOnTax, _now);
					_allPxyCreditDetails.add(pxyTaxCreditDetail);
				endif;
			endif;

			if creditOnPayment &gt; 0 then
				create pxyCreditDetail transient;
				pxyCreditDetail.setAppliedProxy(cashCredit, _pxyCashPayment, _ti, creditOnPayment, _now);
			 
				creditAvailable 				 := creditAvailable - creditApplied;
			
				self.totalCreditApplied			 := self.totalCreditApplied + creditApplied;
				_availableCreditAmounts[index]	 := creditAvailable;
				_allPxyCreditDetails.add(pxyCreditDetail);
			endif;
		endif;
		
		if creditAvailable &lt;= 0 then 
			continue;
		endif;
		
		if  valueOnPayment &lt;= 0  then
			break;
		endif;
	endforeach;

	
epilog

end;
</source>
        <Parameter name="_pxyCashPayment" type="CM_CashPayment" usage="io"/>
        <Parameter name="_availableCreditAmounts" type="DecimalArray" usage="input"/>
        <Parameter name="_availableCredits" type="ObjectArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_allPxyCreditDetails" type="ObjectArray" usage="input"/>
        <Parameter name="_now" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="consolidateLines" id="58a9c706-207b-40be-869f-fb116d3a8d50">
        <source>consolidateLines(	inDict         : CM_InvoiceLineSet input;
					outDict        : CM_InvoiceLineSet input;
					_doConsolidate : Boolean);

/*

Purpose:			

Parameters:			_doConsolidate added for Milaha who want to keep the individual lines with their individual invoice line types, for the cash receipt print
					for Ajman it is kept true
Return Value:		


Date		Who		Reason
27 Jul 2012	cnwndl1	Initial creation
11 Feb 2020 cnwma1	Bug 48511: JMT - Duplicate Narration for Manual Cash Payment on Cash Collection Screen
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	total 			: Real;
	unitNarr,
	qty             : String;
	invLine,
	existingInvLine : CM_InvoiceLine;
	charge,
	existingCharge  : CM_Charge; 
	surplusDict     : CM_InvoiceLineBySeqNumDict;
	terminal 	    : CM_Terminal;
	canLogExtra		: Boolean;	//26.02.2025 navah1	#34141
begin

	terminal := self.getTerminal();
	create surplusDict transient;
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	foreach invLine in inDict do
	
		if invLine.debtor &lt;&gt; null then
			if app.isCashOnlyEnabled then // ### JIRA 33188 25OCT2024 NAVAB1
				if not invLine.debtor.isCashOnlyDebtor( terminal) then 
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("Debtor is not Cash - " &amp; invLine.debtor.name &amp; ", ignoring line '"&amp; invLine.invoiceLineDesc.narration &amp;"'", LogINFO.String);
					endif;
					surplusDict.add( invLine );
					continue;
				endif;
			endif;
		endif;

		if invLine.quantity &lt; 0 then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("Line Quantity is zero, ignoring line '" &amp; invLine.invoiceLineDesc.narration &amp;"'", LogINFO.String);
			endif;
			surplusDict.add( invLine );
			continue;
		endif;
		
		if not _doConsolidate then
			outDict.add( invLine );
			continue;
		endif;
		
		existingInvLine := self.findInvLineMatching( outDict, invLine );
		if existingInvLine = null then
			// setting up the first one of each type.
			outDict.add( invLine );
			charge := invLine.charges.first;
			if charge &lt;&gt; null then
				//turn the charge into an explicit value.
				total                       := charge.total;
				charge.isTotalSetExplicitly := true;
				charge.total				:= total;
			endif;
			
			invLine.invoice := null;
			
		else
		
			//adding to an existing one.
			existingInvLine.setForUpdateQuantity(existingInvLine.quantity + invLine.quantity);
			surplusDict.add( invLine );	// so the transient is deleted
			
			existingCharge := existingInvLine.charges.first;
			charge := invLine.charges.first;
			if charge = null then
				continue;
			endif;
			
			if existingCharge = null then
				total 					    := charge.total;
				charge.isTotalSetExplicitly := true;
				charge.total				:= total;
				charge.setPropertyValue( "invoiceLine", existingInvLine);
			
			else
				total 				 := existingCharge.total + charge.total;
				existingCharge.total := total;
				
			endif;
		endif;
		
	endforeach;
	
	// 'remarks' holds the transaction type.  Show this or the invoice line desc depending on the option.
	// If using the Ghana cash screen, show the quantity with the ILD units and include the line total (shown separately in the other cash screen).
	foreach invLine in outDict do
		qty 	  := invLine.quantity.roundedTo(4).String;
		unitNarr  := invLine.invoiceLineDesc.unitNarration;
		
		if unitNarr &lt;&gt; null then
			invLine.setRemarks( invLine.invoiceLineDesc.narration  &amp; " (" &amp; qty &amp; " " &amp; unitNarr &amp; ") " &amp; invLine.getUnpaidAmount.asCurrencyJMT);
		else
			invLine.setRemarks(  invLine.invoiceLineDesc.narration &amp; " (" &amp; qty &amp; ") " &amp; invLine.getUnpaidAmount.asCurrencyJMT);
		endif;

	endforeach;
	
epilog

	if not surplusDict.isEmpty then
		surplusDict.purge;
	endif;
	
	delete surplusDict;

end;</source>
        <Parameter name="inDict" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="outDict" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_doConsolidate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createExtraProformaLines" id="bcc9d5d3-0327-4c56-bd5a-655119ff6d85">
        <updating/>
        <source>createExtraProformaLines(_manualDesc : String; _manualValue : Real) updating;

/*

Purpose:			(Re)create the proforma invoice lines from any user transactions plus an optional manual amount.
					Done separately for Ghana cash as these are not subject to selection.
Parameters:			

Return Value:		


Date		Who		Reason
11/03/2015	cnwjre1	CCMS 2368 BOL cash
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/


vars

	trxTypeArray 	 : IntegerArray;
	localDict 		 : CM_InvoiceLineBySeqNumDict;
	localSet		 : CM_InvoiceLineSet;
	manualInvLine 	 : CM_InvoiceLine;
	now				 : TimeStamp;
	charge 			 : CM_Charge;
	manualDesc		 : String;
	manualAmount 	 : Real;          //21.10.2019 cnwma1 TFS #47081
	allChildren  	 : CM_TISet;

begin

/*  TFS 45953 nothing was adding to allExtraProfInvLines, it is always empty
	if self.includeManual and self.myTrackedItem &lt;&gt; null then
		// save off the manual line cos they might have updated it.

		if not self.allExtraProfInvLines.isEmpty then
		// CCMS 2368 allProformaLines is now a set, read all to find the manual one
			foreach invLine in self.allExtraProfInvLines do
				if invLine.sequenceNum = Max_Integer and invLine.trackedItemId = self.myTrackedItem.id then
					manualInvLine := invLine;
					self.allExtraProfInvLines.remove(manualInvLine);
					break;
				endif;
			endforeach;
		endif;
	endif;
	*/
	/*  TFS 45953 nothing was adding to allExtraProfInvLines, it is always empty	
	if not self.allExtraProfInvLines.isEmpty then
		self.allExtraProfInvLines.purge;
	endif;
	*/
	
	/* TFS 45953 this is redundant because this method now only create manual payments
	create trxTypeArray transient;
	self.getProformaTransactionTypes( trxTypeArray, false, true );
	// logging
	foreach trxType in trxTypeArray do
		trxClass := global.getTiTxnClassForType(trxType, true);
		if trxClass = null then
			logMessage := "User pro forma transaction type " &amp; trxType.String;
		else
			logMessage := "User pro forma transaction type " &amp; trxType.String &amp; " " &amp; trxClass.name;
		endif;
		app.invLog(logMessage);
	endforeach;
	app.invLog("Pro forma invoice lines");
	app.invLog(" ");
	
	localDict := app.myTrxCA.trxCreateProformaInvoiceLines(	trxTypeArray,	//_transactionTypes : IntegerArray;
															self.myTrackedItem,	//_cargoItem : CM_TrackedItem input;
															allChildren,
															self.effectiveDate,	//_endDate : Date;
															self.releaseDate, // _releaseDate : Date;
															lineTrxTypes,	//_lineTrxTypes : IntegerArray io;
															app.myPassport	//_passport : CM_Passport input
															);
															
	if app.myPassport.hasErrors then
		return;
	endif;
	
	self.setTaxAmountFrom( localDict );
	create localSet transient;
	localDict.copy(localSet);
	*/
	/*  TFS 45953 nothing was adding to allExtraProfInvLines, it is always empty
	if not localSet.isEmpty then
		// copies the result to allExtraProfInvLines after removing any non-cash debtor lines
		self.consolidateLines( localSet, self.allExtraProfInvLines, false );
	endif;
	*/
	
	// TFS 45953 this method only create manual(extra) payments so no need to ask
//TFS 45953	if self.includeManual then
//	TFS 45953	if manualInvLine = null then
			
			manualDesc := _manualDesc;
			manualAmount := _manualValue;
			create manualInvLine transient;
			manualInvLine.setForCreate(	Max_Integer,	//_sequenceNum : Integer;
										true,	//_manual : Boolean;
										manualDesc,	//_remarks : String;
										CM_InvoiceLineDesc.firstInstance,	//_invoiceLineDesc : CM_InvoiceLineDesc;
										null,	//_invoice : CM_Invoice;
										null,	//_debtor : CM_Debtor;
										self.myBank,	//_bank : CM_Bank;
										1,	//_quantity : Real;
										now	//_chargeTime : TimeStamp
										);
			
			manualInvLine.setTrackedItem( self.myTrackedItem );
			create charge transient;
			charge.setForCreate(	null,
									manualInvLine, 
									Max_Integer,
									null);
			charge.total := manualAmount;
			manualInvLine.setTotalAmount();  // ### JIRA 35502 21JUL2025 NAVAB1
			self.allProformaInvLines.add( manualInvLine );// TFS 45953 add the manual in here it will be created as a cash payment linked to an invoice line
/* TFS 45953
			else
			manualInvLine.setRemarks(_manualDesc);
			charge := manualInvLine.charges.first;
			change := charge.total;
			charge.total := _manualValue;
			change := charge.total - change;
			// update the estimated cash charges to get the cash collection form refreshed with this change
			self.estimatedCashCharges := self.estimatedCashCharges + change;
		endif;
		// TFS 45953 self.allExtraProfInvLines.add( manualInvLine );
	endif;
*/	
	self.setEstimatedCashCharges();
	
epilog

	delete trxTypeArray;
	delete localDict;
	delete localSet;
	delete allChildren;
	app.allReportObjectSet.purge();		// 31263 app.allReportObjectSet hijacked to hold the temporary new invoices for the proforma lines
end;</source>
        <Parameter name="_manualDesc" type="String"/>
        <Parameter name="_manualValue" type="Real"/>
    </JadeMethod>
    <JadeMethod name="createProformaInvLines" id="731e2374-8c76-4dec-b37a-f6ef487c47bc">
        <updating/>
        <source>createProformaInvLines( _dict : CM_InvoiceLineBySeqNumDict input; _inTranState : Boolean; _doConsolidate : Boolean ) updating;

/*

Purpose:			

Parameters:			_doConsolidate added for Milaha who want to keep the individual lines with their individual invoice line types, for the cash receipt print (so set false)
					for Ajman it is kept true

Return Value:		


Date		Who		Reason
26/07/2012	cnwndl1	Initial creation
15/10/2015	cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charges
18/02/2019  cnwma1	Bug 43451: AAT - Error When Gating Out
21/10/2019  cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	trxType				: Integer;
	transType			: CM_TransactionType;
	typeDesc,
	logMessage			: String;
	trxTypeArray 		: IntegerArray;
	localDict 			: CM_InvoiceLineBySeqNumDict;
	localSet			: CM_InvoiceLineSet;
	manualInvLine 		: CM_InvoiceLine;
	lineTrxTypes 		: IntegerArray;
	showParentAndChild	: Boolean;
	allChildren			: CM_TISet;
	canLogExtra			: Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	if _dict &lt;&gt; null then
		_dict.purge;
	endif;
	
	if not self.allProformaInvLines.isEmpty then
		self.allProformaInvLines.purge;
	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(" ", LogINFO.String);
	endif;
	create trxTypeArray transient;
	self.getProformaTransactionTypes( trxTypeArray, true, true );
	// logging
	foreach trxType in trxTypeArray do
		transType := app.myRoot.allTransactionTypes[trxType];
		if transType &lt;&gt; null then
			typeDesc := transType.description;
		else
			typeDesc := 'Unknown Type ' &amp; trxType.String;
		endif;
		if canLogExtra then	//26.02.2025 navah1	#34141
			logMessage := "Found Selected pro forma transaction type " &amp; typeDesc;
			app.invLog(logMessage, LogINFO.String);
		endif;
	endforeach;
	// if  no transaction types are found, log this explictly
	if trxTypeArray.isEmpty then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("There are NO pro forma transaction types returned", LogINFO.String);
		endif;
	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(" ", LogINFO.String);
	endif;
	
	if _inTranState then
	
		localDict := app.myUtilityCA.utlCreateProformaInvoiceLines(trxTypeArray, self.myTrackedItem, self.effectiveDate, self.releaseDate, lineTrxTypes, app.myPassport);
		
	else
	
		localDict := app.myTrxCA.trxCreateProformaInvoiceLines(	trxTypeArray,	//_transactionTypes : IntegerArray;
																self.myTrackedItem,	//_cargoItem : CM_TrackedItem input;
																allChildren,
																self.effectiveDate,	//_endDate : Date;
																self.releaseDate,
																lineTrxTypes,	//_lineTrxTypes : IntegerArray io;
																app.myPassport	//_passport : CM_Passport input
																);
	endif;
															
	if app.myPassport.hasErrors then	//25 Sep 2013	NDL	Par 32557
		return;
	endif;
	
	self.setDebtor();		// copied up from TFS 1990 testing for zero-rated debtor test in setTaxAmountFrom
	self.setTaxAmountFrom( localDict );
	create localSet transient;
	localDict.copy(localSet);
	
	if not localSet.isEmpty then
		self.consolidateLines( localSet, self.allProformaInvLines, _doConsolidate );
	endif;
	
/* TFS 45953 includeManualis no longer set to true
	if includeManual then
		if manualInvLine = null then
			
			if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.allCashPayments.first &lt;&gt; null then
			
				foreach cashPayment in self.myTrackedItem.allCashPayments do // TFS 7357
					if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
						continue; // TFS 7357
					endif; // TFS 7357
					break; // TFS 7357
				endforeach; // TFS 7357

				 // TFS 7357 cashPayment:=self.myTrackedItem.allCashPayments.first;
				//saved on 
				if cashPayment &lt;&gt; null // TFS 7357
				and cashPayment.isProformaPayment then
				
					cashPayment.getManualProformaDescAndValue( manualDesc, manualAmount, overridden );
				endif;
				
			
			else
				manualDesc:=app.getErrorString(Manual);
				manualAmount:=0;
			endif;
			create manualInvLine transient;
			manualInvLine.setForCreate(	Max_Integer,	//_sequenceNum : Integer;
										true,	//_manual : Boolean;
										manualDesc,	//_remarks : String;
										CM_InvoiceLineDesc.firstInstance,	//_invoiceLineDesc : CM_InvoiceLineDesc;
										null,	//_invoice : CM_Invoice;
										null,	//_debtor : CM_Debtor;
										self.myBank,	//_bank : CM_Bank;
										1,	//_quantity : Real;
										now	//_chargeTime : TimeStamp
										);
			
			manualInvLine.setTrackedItem( self.myTrackedItem );
			create charge transient;
			charge.setForCreate(	null,
									manualInvLine, 
									Max_Integer,
									null);
			charge.total := manualAmount;
			if overridden then		//29 Jan 2019	NDL	TFS 42940
				charge.setOverriden();
			endif;
		endif;
		self.allProformaInvLines.add( manualInvLine );
// TFS 45953		self.selectedEstimated.add(true);			// Feb 2016 from 37141 testing
	endif;
	*/
	
	self.setDebtor();
	self.setEstimatedCashCharges();
	
	if _dict &lt;&gt; null then
		self.allProformaInvLines.copy(_dict);
	endif;
epilog

	delete trxTypeArray;
	delete localDict;
	delete localSet;
	delete allChildren;
	app.allReportObjectSet.purge();		// 31263 app.allReportObjectSet hijacked to hold the temporary new invoices for the proforma lines
end;</source>
        <Parameter name="_dict" type="CM_InvoiceLineBySeqNumDict" usage="input"/>
        <Parameter name="_inTranState" type="Boolean"/>
        <Parameter name="_doConsolidate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProxiesForPayments" id="20278881-46f6-4f15-918a-dfd646f91078">
        <updating/>
        <source>createProxiesForPayments( _paymentTotal : Decimal io; now : TimeStamp; drTerm : CM_DebtorTerminal; allPxyCashPays : ObjectArray input ) updating;

/*

Purpose:			Called from cash receipt forms (duty doc ONLY) to create proxies for the
					spread of the payment over existing and pro forma invoice lines.
Parameters:			

Return Value:		


Date		Who		Reason
27 Dec 2012     Moved from cash collection form
15/05/2014	cnwjre1	Revised for cash reporting to create a CM_CashPayment per invoice line.
*/

vars

	invoice			 : CM_Invoice;
	allInvoices 	 : CM_InvoiceSet;
	pxyCashPay  	 : CM_CashPayment;
	cashPayment		 : CM_CashPayment;
	invLine 		 : CM_InvoiceLine;
	allInvLines 	 : CM_InvoiceLineSet;	
	invCashPayment,
	invCashCharge,
	paidCharges,
	paidProforma,
	priorTotal,
	initialTotal,
	totalAllocated,
	proformaTotal,
	taxAmount,
	totalToAllocate				: Decimal[23, 6]; //21.10.2019 cnwma1 TFS #47081
	paidProfLineDescriptions	: StringArray;
	paidProfLineQuantities		: RealArray;
	paidProfLineTotals			: DecimalArray;

	proformaDesc 				: String;
	allowPartPay,
	manual						: Boolean;
	user 						: CM_User;
	vvr 						: CM_VehicleVisitRecord;
	lc						    : CM_LocationsController;
	truck					    : CM_Vehicle;
	bank 						: CM_Bank;
	terminal 					: CM_Terminal;
begin
	if self.myTrackedItem = null then
		return;
	endif;
	if _paymentTotal &lt;= 0 then
		return;
	endif;
	initialTotal := _paymentTotal;

	create allInvoices transient;
	create allInvLines transient;
	
	user := app.getMyUser;
	
	// 32498 - part payments only if configured
	terminal := self.myTrackedItem.myTerminal;
	allowPartPay := terminal.getConfig(CashCollectAllowUnderpay).Boolean;
	
	totalToAllocate := _paymentTotal;
	
	vvr := null;
	if self.myTrackedItem.isOnSite then
		lc := self.myTrackedItem.myPrimaryActualLocation;
		if lc &lt;&gt; null and lc.isVehicle then
			truck := lc.CM_VehicleController.vehicle;
			if truck &lt;&gt; null then
				vvr := truck.getCurrentVisit();
			endif;
		endif;
	endif;
	
	foreach invLine in self.allCurrentInvLines do
		paidCharges := 0;
		foreach cashPayment in invLine.allCashPayments do
			if cashPayment.voided then		// 35399 skip voided payments
				continue;
			endif;
			paidCharges := paidCharges + cashPayment.cashValue;
		endforeach;
		if paidCharges &gt;= invLine.totalAmount then  // ### JIRA 35502 18JUL2025 NAVAB1 use totalAmount not lineTotal
			continue;
		endif;
		allInvLines.addNoDuplicates(invLine,false);
	endforeach;
	
	// save existing payment details
	create paidProfLineDescriptions transient;
	create paidProfLineQuantities transient;
	create paidProfLineTotals transient;
	// get any existing payments for proforma, handling the existing payments being partial
	foreach cashPayment in self.myTrackedItem.allCashPayments do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue; // TFS 7357
		endif; // TFS 7357
		if cashPayment.voided then		// 35399 skip voided proforma payments
			continue;
		endif;
		if cashPayment.isProformaPayment then
			paidProforma := paidProforma + cashPayment.cashValue;
			
			/* TFS 45953 CM_CashPayment.proformaLineDescriptions no longer used
			detailValue := cashPayment.cashValue;
			index1 := 0;
			foreach proformaDesc in cashPayment.proformaLineDescriptions do
				index1 := index1 + 1;
				lineTotal := cashPayment.proformaLineTotals[index1];
				if lineTotal &gt; detailValue then
					lineTotal := detailValue;
				endif;
				found := false;
				foreach index2 in 1 to paidProfLineDescriptions.size do
					if proformaDesc = paidProfLineDescriptions[index2] then
						found := true;
						// found, add to the quantity and values
						paidProfLineQuantities[index2] := paidProfLineQuantities[index2] + cashPayment.proformaLineQuantities[index1];
						paidProfLineTotals[index2] := paidProfLineTotals[index2] + lineTotal;
						break;
					endif;
				endforeach;
				if not found then
					paidProfLineDescriptions.add(proformaDesc);
					paidProfLineQuantities.add(cashPayment.proformaLineQuantities[index1]);
					paidProfLineTotals.add(lineTotal);
				endif;
				detailValue := detailValue - lineTotal;
				if detailValue = 0 then
					break;
				endif;
			endforeach;
			*/
		endif;
	endforeach;
	
	foreach invLine in allInvLines do
		invCashCharge := invLine.totalAmount; //ineTotal;
		taxAmount := 0;
		
		priorTotal := totalToAllocate;
		paidCharges := 0;
		foreach cashPayment in invLine.allCashPayments do
			if cashPayment.voided then		// 35399 skip voided payments
				continue;
			endif;
			paidCharges := paidCharges + cashPayment.cashValue;
		endforeach;
		//	taxAmount := taxAmount + invLine.getTaxAmountForLine();

		if invCashCharge &gt; 0 then
			// add an extra payment for the difference if any between the total invoiced charges and the invoice payments so far
			//  and leave any existing payments alone
			if invCashCharge &gt; paidCharges then
				invCashPayment := invCashCharge - paidCharges;
			else
				invCashPayment := 0;
			endif;
			// 32498 handle partial payments modified for 33885
			totalToAllocate := totalToAllocate - invCashPayment;
			if allowPartPay and
		       totalToAllocate &lt; 0 then
				///invCashCharge := priorTotal;		// partial last charge
				invCashPayment := priorTotal;		// 34983 partial last charge
			endif;
			if invCashPayment &gt; 0 then
				create pxyCashPay transient;

				totalAllocated := totalAllocated + invCashPayment;
			
				pxyCashPay.setProxy(invCashPayment,		//_cashValue : Decimal;
									taxAmount,   		//_taxAmount : Decimal;
									now,				//_dateTime : TimeStamp;
									null,				//_proformaDesc : String;
									false,				//_manual : Boolean;
									0,					//_status : Integer;
									false,				//_voided : Boolean;	
									drTerm,				//_myDebtorTerminal : CM_DebtorTerminal;
									self.myTrackedItem,	//_myTrackedItem : CM_TrackedItem;
									invoice,			//_myInvoice : CM_Invoice;
									vvr,				//_vvr : CM_VehicleVisitRecord;
									user				//_myUser : CM_User;
									);
				pxyCashPay.setInvoiceLine(invLine);
				allPxyCashPays.add( pxyCashPay );
			endif;
		endif;
		// end of partial payment
		if allowPartPay and
		   totalToAllocate &lt;= 0 then
			break;
		endif;
		
	endforeach;
	_paymentTotal := initialTotal - totalAllocated;
	
	// if partial payment and all used up, exit now
	if allowPartPay and
	   totalToAllocate &lt;= 0 then
		return;
	endif;
	// pay the proforma
	proformaDesc := self.allProformaInvLines.getProformaDesc;
	
	if self.estimatedCashCharges = 0 then
		return;
	endif;

	if self.getManualProforma &lt;&gt; null then
		manual:=true;
	endif;
	// 33885 add an extra payment for the difference if any between the total proforma charges and the proforma payments so far
	//  and leave any existing payments alone
	if self.estimatedCashCharges &gt; paidProforma then
		proformaTotal := self.estimatedCashCharges - paidProforma;
	else
		proformaTotal := 0;
	endif;
	// if partial payment and not enough left, use up the balance; modified for 33885
	if allowPartPay and
	   proformaTotal &gt; totalToAllocate then
		proformaTotal := totalToAllocate;
	endif;
	
	if proformaTotal &gt; 0 then
		// Note that there is still one proforma payment although it may be derived from several invoice lines.
		//  The allocation across invoice lines comes when the cargo is released and this payment is converted into
		//	one or more real payments for the outstanding invoice lines.
		create pxyCashPay transient;
		bank := self.myTrackedItem.companyOid;
		terminal:=self.myTrackedItem.myTerminal;
		if bank = null then
			bank := terminal.getDefaultCompanyBank();
		endif;
	
		//taxAmount:=(self.estimatedCashCharges * (bank.taxPercentageRate / 100));
		pxyCashPay.setProxy(proformaTotal,		//_cashValue : Decimal;
							taxAmount,			//_taxAmount : Decimal;
							now,				//_dateTime : TimeStamp;
							proformaDesc,		//_proformaDesc : String;
							manual,				//_manual : Boolean;
							0,					//_status : Integer;
							false,				//_voided : Boolean;	
							drTerm,				//_myDebtorTerminal : CM_DebtorTerminal;
							self.myTrackedItem,	//_myTrackedItem : CM_TrackedItem;
							null,				//_myInvoice : CM_Invoice;
							vvr,				//_vvr : CM_VehicleVisitRecord;
							user				//_myUser : CM_User;
							);
		pxyCashPay.setProformaDetails2(self.allProformaInvLines, paidProfLineDescriptions, paidProfLineQuantities, paidProfLineTotals);		// save the proforma description, quantity and totals
		allPxyCashPays.add( pxyCashPay );
	endif;

	_paymentTotal := _paymentTotal - proformaTotal;		// 33885 multiple pro forma payments

epilog
	endLoad;															// 19/04/2013 cnwmh5 #31457
	delete allInvoices;
	delete allInvLines;
	delete paidProfLineDescriptions;
	delete paidProfLineQuantities;
	delete paidProfLineTotals;

end;</source>
        <Parameter name="_paymentTotal" type="Decimal" usage="io"/>
        <Parameter name="now" type="TimeStamp"/>
        <Parameter name="drTerm" type="CM_DebtorTerminal"/>
        <Parameter name="allPxyCashPays" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createProxyPaymentForList" id="8d40f88c-6860-49cb-912e-473a11a430eb">
        <source>createProxyPaymentForList(_proforma 		: Boolean;
						_manual				: Boolean; 
						_cashReceipt 		: CM_CashReceipt input; 
						_invLine 			: CM_InvoiceLine; 
						_invCashPayment, 
						_taxCashPayment 	: Real io; 
						_totalAllocated 	: Real io;
						_now 				: TimeStamp; 
						_drTerm 			: CM_DebtorTerminal; 
						_vvr 				: CM_VehicleVisitRecord) : CM_CashPayment;
/*

Purpose:			TFS 44275

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2019	jlgab1	Initial creation
25 Sep 2019 cnwma1	Bug 46582: Cash Credit are not being accounted for correctly
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
15 Jan 2020 cnwma1	Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT
*/

vars
	pxyCashPay, 
	pxyCashPayTax       : CM_CashPayment;
	profDetail          : CM_ProformaDetails;
	invTaxCashPayment   : Decimal [23,6];     //21.10.2019 cnwma1 TFS #47081
	cashInvoice 		: CM_Invoice;
	isPrintProforma     : Boolean;
	terminal            : CM_Terminal;
	remarks 		    : String;
	configCashTax		: String;
	configInvMultiTax,
	assignInv   		: Boolean;
	isMinCharge         : Boolean;
	isOverridden        : Boolean;
begin
	
	isPrintProforma   := (_cashReceipt.isKindOf(CM_CashReceiptProformaPrint));															
	terminal 		  := _drTerm.myTerminal;																						
	configCashTax     := terminal.getConfig(CashAllCashTax).String ;
	configInvMultiTax := terminal.getConfig(InvoiceMultiTaxRates).Boolean ;
	
	
	if configCashTax = null and configInvMultiTax then
		invTaxCashPayment := _taxCashPayment;
	endif;

	if isPrintProforma then
		create pxyCashPay as CM_CashPaymentProformaPrint transient;
	
	else
		create pxyCashPay transient;
	endif;
	
	//16.01.2020 cnwma1 #48298
	if _invLine &lt;&gt; null then
		if _invLine.invoiceLineDesc.isUsedAsMinimumCharge() then
			isMinCharge := true;
		endif;
	endif;
	
	if _invLine.isNegativeAmount then  
		_invCashPayment := _invCashPayment * -1;
	endif;
	_totalAllocated := _totalAllocated + _invCashPayment;

	assignInv := _cashReceipt.myWorkOrder &lt;&gt; null; // TFS 45953 DMAST ONLY REFACTOR to Use this code in PEL WORK ORDERs
	if assignInv then // TFS 45953 DMAST ONLY REFACTOR
		if self.myTrackedItem &lt;&gt; null then // TFS 45953 DMAST ONLY REFACTOR
			cashInvoice := self.myTrackedItem.getCashInvoice(); // TFS 45953 DMAST ONLY REFACTOR
		endif;
	endif;
	
	
	pxyCashPay.setProxy(_invCashPayment,
						0,	
						_now,	
						null,	
						_manual, // TFS 45953
						0,
						false,	
						_drTerm,	
						self.myTrackedItem,
						cashInvoice,	 // TFS 45953 DMAST ONLY REFACTOR
						_vvr,
						app.getMyUser
						);
						
	if _invLine &lt;&gt; null and not _invLine.isTransient then // TFS 47847
		_cashReceipt.allInvoiceLines.add(_invLine);	 // TFS 47847		
	endif; // TFS 47847
						
	if not _proforma then // TFS 45894 only set invoice or proforma
		pxyCashPay.setInvoiceLine(_invLine);
	else
	
		if isMinCharge then
			isOverridden := true;
		endif;
		
		profDetail := _cashReceipt.createProformaDetail(pxyCashPay.cashValue,
														_invLine.quantity,
														_invLine.totalRate, //getRate(),  // ### JIRA 35502 18JUL2025 NAVAB1 use totalRate not  getRate
														"",
														_invLine.invoiceLineDesc,
														pxyCashPay.myTrackedItem,
														_invLine.quantityNoMinMax.Integer, 
														isOverridden);                    	//16.01.2020 cnwma1 #48298

		// TFS 45894 make remarks the same as those on previous cash collection
		remarks := _invLine.invoiceLineDesc.narration &amp; " - " &amp; pxyCashPay.cashValue.asCurrencyJMT; 
		profDetail.setPxyRemarks(remarks);
		
		pxyCashPay.setProformaDetail(profDetail);
		_cashReceipt.allProformaDetails.addNoDuplicates(profDetail,false);
		profDetail.setMyVoyage(self.getVoyage());
		
	endif;
	
	
	pxyCashPay.setMyVoyage(self.getVoyage());
	
	/*cnwma1 18.09.2019 */
	if invTaxCashPayment &gt; 0 then
		if configCashTax = null and configInvMultiTax then
			if isPrintProforma then
				create pxyCashPayTax as CM_CashPaymentProformaPrint transient;
			else
				create pxyCashPayTax transient;
			endif;
			
			pxyCashPayTax.setProxy(invTaxCashPayment,
								0,
								_now,	
								null,	
								_manual, // TFS 45953
								0,
								false,
								_drTerm,
								self.myTrackedItem,	
								null,  // TFS 45953 this stays null
								_vvr,
								app.getMyUser
								);
								
			pxyCashPay.setMyCashPaymentForTax(pxyCashPayTax);
		endif;
	endif;
	
/*
	This will be used to set the isMinimumCharge on payment and it's tax to stop it from being unselected,
	The minimum will be unselected only if it's payment will be unslelcted
	*/
	
	//16.01.2020 cnwma1 #48298
	if isMinCharge then
		pxyCashPay.setIsMinimumCharge(true);
		if pxyCashPay.hasTax  then
			pxyCashPay.myCashPaymentForTax.setIsMinimumCharge(true);
		endif;
	endif;
	
	/*16.01.2020 cnwma1 #48298
	if not _proforma then                          //cnwma1 25.09.2019 46582
		if _invLine &lt;&gt; null then
			if _invLine.invoiceLineDesc.isUsedAsMinimumCharge() then
				pxyCashPay.setIsMinimumCharge(true);
				
				if pxyCashPay.myCashPaymentForTax &lt;&gt; null then
					pxyCashPay.myCashPaymentForTax.setIsMinimumCharge(true);
					//pxyCashPay.setManual(true);
				endif;
			endif;
		endif;
	else
		if profDetail &lt;&gt; null  and profDetail.myInvoiceLineType.isUsedAsMinimumCharge then
			pxyCashPay.setIsMinimumCharge(true);
			if pxyCashPay.myCashPaymentForTax &lt;&gt; null then
				pxyCashPay.myCashPaymentForTax.setIsMinimumCharge(true);
				//pxyCashPay.setManual(true);
			endif;
		endif;
	endif;
	*/
	return pxyCashPay;
epilog

end;</source>
        <Parameter name="_proforma" type="Boolean"/>
        <Parameter name="_manual" type="Boolean"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <Parameter name="_invCashPayment" type="Real" usage="io"/>
        <Parameter name="_taxCashPayment" type="Real" usage="io"/>
        <Parameter name="_totalAllocated" type="Real" usage="io"/>
        <Parameter name="_now" type="TimeStamp"/>
        <Parameter name="_drTerm" type="CM_DebtorTerminal"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <ReturnType type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="createProxyPaymentsForList" id="be238372-7d46-45b8-b7e9-e19e45961c29">
        <updating/>
        <source>createProxyPaymentsForList( _paymentTotal           : Decimal io; 
							_now 				    : TimeStamp; 
							_drTerm 			    : CM_DebtorTerminal; 
							_allPxyCashPays         : ObjectArray input;
							_allPxyCreditDetails    : ObjectArray input;
							_availableCredits 	    : ObjectArray input;
							_availableCreditAmounts : DecimalArray input;
							_cashReceipt 			: CM_CashReceipt input;
							_includeUpdatesToPayments : Boolean) updating;
/*

Purpose:		TTFS 44275

Parameters:			

Return Value:		


Date		Who		Reason
25 Sep 2019 cnwma1	Bug 46582: Cash Credit are not being accounted for correctly
27 Sep 2019 cnwma1	Bug 46674: New Form - Minimum charges does not calculate minimum charges when grouping invoice lines
21 Oct 2019 cnwma1  Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
05 Nov 2019 cnwma1	Bug 47056: JMT - Cash Collection - Not calculating additional days once you have paid for some
*/

vars

	pxyCashPay,
	cashPayment			: CM_CashPayment;
	invLine 			: CM_InvoiceLine;
	profDetail			: CM_ProformaDetails;
	invCashPayment,
	invCashCharge,
	invTaxCashPayment,
	priorTotal,
	initialTotal,
	totalAllocated,
	totalToAllocate		: Decimal[23, 6];		//21.10.2019 cnwma1 TFS #47081
	obj					: Object;
	user 				: CM_User;
	vvr 				: CM_VehicleVisitRecord;
	terminal 			: CM_Terminal;
	invLineSet 			: CM_InvoiceLineSet;
	proformaVoyage 		: CM_Voyage;
	configCashTax		: String;
	configInvMultiTax   : Boolean;
	idx : Integer;
	payments : CM_CashPaymentDict;
	tranType : Integer;
	ti : CM_TrackedItem;
	cancelledReceipt : Boolean;
begin
	
	create invLineSet transient;
	user		 	  := app.getMyUser;
	initialTotal  	  := _paymentTotal;
	proformaVoyage	  := self.getVoyage();
	terminal		  := _drTerm.myTerminal;	
	totalToAllocate   := _paymentTotal;
	vvr 			  := null;
	configCashTax     := terminal.getConfig(CashAllCashTax).String ;
	configInvMultiTax := terminal.getConfig(InvoiceMultiTaxRates).Boolean ;
	ti := self.myTrackedItem;  // ### JIRA 35008 08APR2025 NAVAB1
	
	if ti &lt;&gt; null 
	and _includeUpdatesToPayments then // TFS 54853
		
		vvr := ti.getCurrentVehicleVisitRecord();
		
		if ti.allCashPaymentProformaPrints.isEmpty() then // TFS 47985
			payments := ti.allCashPayments; // TFS 47985
		else // TFS 47985
			payments := ti.allCashPaymentProformaPrints; // TFS 47985
		endif;
		
		foreach cashPayment in payments	discreteLock do // TFS 47985
			
			if cashPayment.myCashPaymentForInvoice &lt;&gt; null then
				continue;
			endif;

			beginLoad;
			pxyCashPay := app.createUpdateProxy(cashPayment).CM_CashPayment;
			endLoad;
			
			// ### JIRA 35502 18JUL2025 NAVAB1 cashPayment.isCancelled() is quite slow and is called alot further on, so check once whether any cash receipts have been cancelled so that later we do not have to check .
			if not cancelledReceipt then
				cancelledReceipt := cashPayment.isCancelled();
			endif;
			_allPxyCashPays.add( pxyCashPay );
			
			
			// ### TFS 45159 If a cash payment has an invoice line and the invoice line has a over ridden rate that means that 
			// the invoice line is now more than the cash payment, create a payment for the difference.
			invLine := pxyCashPay.myInvoiceLine;
			
			if invLine &lt;&gt; null and not invLineSet.includes(invLine) then // we have already created a proxy payment for the unpaid amount on this invoice line
				if not invLine.isPaidFor() then
					invCashPayment:= invLine.totalAmount - invLine.getPaidForValue();
					
					if invCashPayment &gt; 0 then
						totalAllocated := totalAllocated + invCashPayment;
						
						 // TFS 45953 added false manual
						pxyCashPay := self.createProxyPaymentForList(false,false,_cashReceipt,invLine,invCashPayment,invTaxCashPayment, totalAllocated, _now,_drTerm,vvr);
						_allPxyCashPays.add( pxyCashPay );
						
						invLineSet.add(invLine); // getPaidForValue() adds up all the  cash payments so we do not need to compare this invoice line again
					endif;
				endif;
			endif;
		endforeach;
		
	elseif proformaVoyage &lt;&gt; null 
	and _includeUpdatesToPayments then // TFS 54853

	
		foreach cashPayment in proformaVoyage.allCashPayments	discreteLock do
			if not _includeUpdatesToPayments then // TFS 54853
				continue;
			endif;
			
			if cashPayment.myCashPaymentForInvoice &lt;&gt; null then
				continue;
			endif;
			
			beginLoad;
			pxyCashPay := app.createUpdateProxy(cashPayment).CM_CashPayment;
			endLoad;
			
			// ### JIRA 35502 18JUL2025 NAVAB1
			if not cancelledReceipt then
				cancelledReceipt := cashPayment.isCancelled();
			endif;
			
			_allPxyCashPays.add( pxyCashPay );
			
			// ### TFS 45159 If a cash payment has an invoice line and the invoice line has a over ridden rate that means that 
			// the invoice line is now more than the cash payment, create a payment for the difference.
			invLine := pxyCashPay.myInvoiceLine;
			if invLine &lt;&gt; null 
			and not invLineSet.includes(invLine) then // we have already created a proxy payment for the unpaid amount on this invoice line
				if not invLine.isPaidFor() then
					invCashPayment:= invLine.totalAmount - invLine.getPaidForValue();
					
					if invCashPayment &gt; 0 then
						totalAllocated := totalAllocated + invCashPayment;
						 // TFS 45953 added false manual
						 pxyCashPay 	   := self.createProxyPaymentForList(false,false,_cashReceipt,invLine,invCashPayment,invTaxCashPayment,totalAllocated, _now,_drTerm,vvr);
						_allPxyCashPays.add( pxyCashPay );
						
						invLineSet.add(invLine); // getPaidForValue() adds up all the  cash payments so we do not need to compare this invoice line again
					endif;
				endif;
			endif;
		endforeach;
		
	endif;
	
	idx := 1;
	foreach invLine in self.allCurrentInvLines	discreteLock do : outerloop // these will only be cash debtor invoice lines
		
		invCashCharge := invLine.totalAmount;
		
		if invLine.isNegativeAmount   then                 
			invCashCharge := invCashCharge * -1; 
		endif;
		
		taxAmount  		  := 0;
		priorTotal 		  := totalToAllocate;
		invCashPayment    := invCashCharge;
		totalAllocated    := totalAllocated + invCashPayment;
		// TFS 45953 invTaxCashPayment := invLine.getTaxAmountForLine();
		invTaxCashPayment := invLine.getTaxAmountProformaForVoyage(self.getWorkOrder());// TFS 45953 
		
		if not invLine.allCashPayments.isEmpty then
			continue;
		else
			// TFS 45602
			if invLine.myTransactionTI &lt;&gt; null then
				// We have a real invoice line that does not have any cash payments
				// Do we have any matching real cash payments that were created before the invoice line was?
				foreach obj in _allPxyCashPays	discreteLock do
					cashPayment := obj.CM_CashPayment;
					if cashPayment.myProformaDetail &lt;&gt; null then
						if cashPayment.myProformaDetail.transactionType = invLine.myTransactionTI.type 
						and cashPayment.myProformaDetail.myInvoiceLineType = invLine.invoiceLineDesc then
						if cashPayment.pxyGetRealObject &lt;&gt; null then
								cashPayment.setInvoiceLine(invLine);
								continue outerloop;
							endif;
						endif;
					endif;
				endforeach;
			endif;
									
			
			// #####################
			// ### PAYMENT 
			// #####################		
			 // TFS 45953 added false manual
			pxyCashPay := self.createProxyPaymentForList(false,false,_cashReceipt,invLine,invCashPayment,invTaxCashPayment,totalAllocated, _now,_drTerm,vvr);
			_allPxyCashPays.add( pxyCashPay );
			idx := idx + 1; // TFS 45953
			
			// #####################
			// ### CREDITS
			// #####################
			if not invLine.isPaidFor then       //25.09.2019 cnwma1	#46582
				
				if not _availableCredits.isEmpty then
					self.applyCreditOnProxy(pxyCashPay,_availableCreditAmounts,_availableCredits,ti,_allPxyCreditDetails,_now,terminal);
				endif;
			endif;
			
			if pxyCashPay.myProformaDetail &lt;&gt; null  and pxyCashPay.myProformaDetail.myInvoiceLineType.isUsedAsMinimumCharge then
				pxyCashPay.setIsMinimumCharge(true);
			endif;
			
		endif;
		
	endforeach;

	idx := 1;
	foreach invLine in self.allProformaInvLines do : outerloop
		tranType := invLine.quantityNoMinMax.Integer;  // ### JIRA 35008 05JUN2025 NAVAB1

		/* 
		05.11.2019 cnwma1 47056
		Because i noticed if you already have a storage been calculated for 2 days for example in the first cash receipt,
		Then this code will stop calculating another 2 days in the second cash receipt .
		
		*/
		
		
		// TFS 47985 put this back for Proforma Printing with RECORDING, but for TFS 47056 only do it for non storage
		// TFS 47985 things like storage are typically charged by the day. By the time it gets here the quantity of days has already been adjusted
		//						taking into account other payments for storage so always lets storage and reefer daily through
		if (tranType  &lt;&gt; TRANS_TYPE_STORAGE // TFS 47985  this fixes TFS 47056
		and tranType  &lt;&gt; TRANS_TYPE_ReeferDaily) then // TFS 47985 this fixes TFS 47056
			// TFS 47985 put this back for Proforma Printing with RECORDING
			foreach obj in _allPxyCashPays	discreteLock do
				cashPayment := obj.CM_CashPayment;
				if cashPayment.myCashPaymentForInvoice &lt;&gt; null then
					continue;
				endif;
				
				//profDetail := cashPayment.myProformaDetail; //25/02/2025	navkc1 JIRA Story MTN-33928
				// ### JIRA 35502 18JUL2025 NAVAB1 performance getMyProformaDetails() asks if its cancelled, if one of the payment is linked to a cancelled receipt check all of them
				if cancelledReceipt then
					profDetail := cashPayment.getMyProformaDetails(); //25/02/2025	navkc1 JIRA Story MTN-33928
				else
					profDetail := cashPayment.myProformaDetail;
				endif;
				//24/02/2025	navkc1 JIRA Bug MTN-34043
				//if profDetail = null or profDetail.isMyCashReceiptCancelled() then
				if profDetail = null then //25/02/2025	navkc1 JIRA Story MTN-33928
					
					// ### JIRA 35008 04JUN2025 NAVAB1 - if creating first CR whilst TI is on site and on transport, the invoice lines that are for cash debtor will have new proxy cash payment for them
					//  however because the TI has no cash payments at this time it also creates a proforma invoice line for the same real invoice lines
					// if the itme is split it will not have its own receive ship, in which case the invoice lines will have been created on the source ti and they will have been split onto this TI and so they will have proxy cash payments in _allPxyCashPayscm_trackexci
					if ti.myMasterTi &lt;&gt; null 
					and cashPayment.myTrackedItem = ti 
					and cashPayment.myInvoiceLine &lt;&gt; null
					and cashPayment.myInvoiceLine.invoiceLineDesc = invLine.invoiceLineDesc
					and  cashPayment.pxyGetRealObject = null
					then // been split
						if ti.getLastTransOfType(tranType) = null then
							self.allProformaInvLines.remove(invLine);
						
							// Need to delete othererwise it becomes an orphan and never gets deleted, transient leak NAVKC1
							if invLine.isTransient() then
								delete invLine;
							endif;
							
							continue outerloop;
						
						endif;
					endif;
					continue;
				endif;
				
				if 	profDetail.myTrackedItem = ti and
					profDetail.myInvoiceLineType = invLine.invoiceLineDesc and
					profDetail.rate = invLine.getRate() and
					profDetail.quantity = invLine.quantity 
					then
					
					if cashPayment.pxyGetRealObject &lt;&gt; null then // TFS 47985 already paid -  this fixes TFS 47056
						self.allProformaInvLines.remove(invLine);
						
						// Need to delete othererwise it becomes an orphan and never gets deleted, transient leak NAVKC1
						if invLine.isTransient() then
							delete invLine;
						endif;
						
						continue outerloop;
					endif;
				endif;
			endforeach;
		endif;
		//*/
	
		invCashCharge := invLine.totalAmount;
		if invLine.isNegativeAmount   then                
			invCashCharge := invCashCharge * -1; 
		endif;
		taxAmount      := 0;
		priorTotal     := totalToAllocate;
		invCashPayment := invCashCharge;
		
		if configCashTax = null and configInvMultiTax then		//25.09.2019 cnwma1	#46582
			// TFS 45953 invTaxCashPayment := invLine.getTaxAmountForLine();
			invTaxCashPayment := invLine.getTaxAmountProformaForVoyage(self.getWorkOrder());// TFS 45953 
		endif;

		// handle partial payments
		totalToAllocate := totalToAllocate - invCashPayment;

				
		if invCashPayment &lt;&gt; 0 then
			// #####################
			// ### PAYMENT 
			// #####################
			 // TFS 45953 added false manual
			 // TFS 45953 18OCT19 changed manual to invLine.manual, because now the unit test is no longer using allExtraProfInvLines
			pxyCashPay := self.createProxyPaymentForList(true,invLine.manual,_cashReceipt,invLine,invCashPayment,invTaxCashPayment,totalAllocated,_now,_drTerm,vvr);

			_allPxyCashPays.add( pxyCashPay );
			idx := idx + 1; // TFS 45953

			// #####################
			// ### CREDITS
			// #####################
			if not invLine.isPaidFor then              //25.09.2019 cnwma1	#46582
				if not _availableCredits.isEmpty then
					self.applyCreditOnProxy(pxyCashPay,_availableCreditAmounts,_availableCredits,ti,_allPxyCreditDetails,_now,terminal);
				endif;
			endif;			
			if pxyCashPay.myProformaDetail &lt;&gt; null  and pxyCashPay.myProformaDetail.myInvoiceLineType.isUsedAsMinimumCharge then // 27.09.2019 cnwma1 #46674
				pxyCashPay.setIsMinimumCharge(true);
			endif;
		endif;
		
		
	endforeach;
	
	
	
	/*  TFS 45953 nothing was adding to allExtraProfInvLines, it is always empty
	foreach invLine in self.allExtraProfInvLines do : outerloop
	
		foreach obj in _allPxyCashPays	discreteLock do
			cashPayment := obj.CM_CashPayment;
			if cashPayment.myCashPaymentForInvoice &lt;&gt; null then
				continue;
			endif;
			profDetail := cashPayment.myProformaDetail;
			if profDetail &lt;&gt; null then
				if profDetail.myTrackedItem = self.myTrackedItem
				and profDetail.myInvoiceLineType = invLine.invoiceLineDesc 
				and profDetail.rate = invLine.getRate()
				and profDetail.quantity = invLine.quantity then
					self.allExtraProfInvLines.remove(invLine);
					continue outerloop;
				endif;
			endif;
		endforeach;
		
	
		invCashCharge := invLine.lineTotal;
		if invLine.isNegativeAmount   then                
			invCashCharge := invCashCharge * -1; 
		endif;
		taxAmount      := 0;
		priorTotal     := totalToAllocate;
		invCashPayment := invCashCharge;
		
		if configCashTax = null and configInvMultiTax then		//25.09.2019 cnwma1	#46582
			invTaxCashPayment := invLine.getTaxAmountForLine();
		endif;

		// handle partial payments
		totalToAllocate := totalToAllocate - invCashPayment;

				
		if invCashPayment &lt;&gt; 0 then
			// #####################
			// ### PAYMENT 
			// #####################
			 // TFS 45953 added true manual
			pxyCashPay := self.createProxyPaymentForList(true,true,_cashReceipt,invLine,invCashPayment,invTaxCashPayment,totalAllocated,_now,_drTerm,vvr);

			_allPxyCashPays.add( pxyCashPay );

			// #####################
			// ### CREDITS
			// #####################
			if not invLine.isPaidFor then              //25.09.2019 cnwma1	#46582
				if not _availableCredits.isEmpty then
					self.applyCreditOnProxy(pxyCashPay,_availableCreditAmounts,_availableCredits,self.myTrackedItem,_allPxyCreditDetails,_now,terminal);
				endif;
			endif;			
			if pxyCashPay.myProformaDetail &lt;&gt; null  and pxyCashPay.myProformaDetail.myInvoiceLineType.isUsedAsMinimumCharge then // 27.09.2019 cnwma1 #46674
				pxyCashPay.setIsMinimumCharge(true);
			endif;
		endif;
		
		
	endforeach;	
	*/
	
	_paymentTotal := initialTotal - totalAllocated;
	



epilog
	endLoad;
	delete invLineSet;
end;</source>
        <Parameter name="_paymentTotal" type="Decimal" usage="io"/>
        <Parameter name="_now" type="TimeStamp"/>
        <Parameter name="_drTerm" type="CM_DebtorTerminal"/>
        <Parameter name="_allPxyCashPays" type="ObjectArray" usage="input"/>
        <Parameter name="_allPxyCreditDetails" type="ObjectArray" usage="input"/>
        <Parameter name="_availableCredits" type="ObjectArray" usage="input"/>
        <Parameter name="_availableCreditAmounts" type="DecimalArray" usage="input"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_includeUpdatesToPayments" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="511803a4-d5fe-4634-819a-83f4ab86637a">
        <updating/>
        <source>delete() updating;
// delete transients
vars

begin
	self.allProformaInvLines.purge();
// TFS 45953	self.allExtraProfInvLines.purge();
// TFS 45953	self.allConsolidatedProfInvLines.purge();
// TFS 45953	self.allConsolidatedInvLines.purge();
// TFS 45953	self.allConsExtraProfInvLines.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSumValuesForDocDutyValues" id="c0b2ec1a-f460-4fbd-bfd9-52f0ff9ad9ee">
        <source>doSumValuesForDocDutyValues(	_invLine : CM_InvoiceLine;
								_trxType : Integer;
								_dutyCharges : Decimal io;	//18 Dec 2013	NDL	Par 33182
								_termCharges : Decimal io;
								_storageCharges : Decimal io;
								_otherCharges : Decimal io;
								_totalCharges : Decimal io
								) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	trxType : Integer;

begin

	trxType := _trxType;
	
	if trxType = TRANS_TYPE_DUTY_CHARGE then	//18 Dec 2013	NDL	Par 33182
		//Duty charges
		_dutyCharges := _dutyCharges + _invLine.lineTotal;

	elseif trxType = TRANS_TYPE_MOVE	
	or	trxType = TRANS_TYPE_MOVE_PICKUP
	or	trxType = TRANS_TYPE_MOVE_SETDOWN
	then
		//Moves = Handling charges
		_termCharges := _termCharges + _invLine.lineTotal;
		
		
		
	elseif trxType = TRANS_TYPE_STORAGE
	or	trxType = TRANS_TYPE_REL_ROAD
	then
		//Storage = Storage charges
		_storageCharges := _storageCharges + _invLine.lineTotal;
		
		
	else
		// leaving all other cahrges.
		_otherCharges := _otherCharges + _invLine.lineTotal;
		
		
	endif;
	
//	_totalCharges := _termCharges + _storageCharges + _otherCharges;
	_totalCharges := _termCharges + _storageCharges + _otherCharges + _dutyCharges;	//18 Dec 2013	NDL	Par 33182

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <Parameter name="_trxType" type="Integer"/>
        <Parameter name="_dutyCharges" type="Decimal" usage="io"/>
        <Parameter name="_termCharges" type="Decimal" usage="io"/>
        <Parameter name="_storageCharges" type="Decimal" usage="io"/>
        <Parameter name="_otherCharges" type="Decimal" usage="io"/>
        <Parameter name="_totalCharges" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="filterDuplicateActualEstimated" id="d3289a55-b346-48d0-8e38-0370c586a73a">
        <source>filterDuplicateActualEstimated(_trxArray : IntegerArray input) protected;
// GPHA 2368 check if any of the configured transaction types have matching existing transactions of the specified types
//	and remove those from the list
// Date			Who		Reason
// 18 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
//25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	toSkip	: IntegerArray;
	type	: Integer;
	typeDesc	: String;
	tran	: CM_TITransaction;
	trxType	: CM_TransactionType;
	canLogExtra			: Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	create toSkip transient;
	foreach tran in self.myTrackedItem.allTransactions do
		if tran.type &gt; TransactionTypeJMTMax or		// user-defined
		   tran.type = TRANS_TYPE_REC_SHIP or
		   tran.type = TRANS_TYPE_REC_ROAD or
		   tran.type = TRANS_TYPE_REC_RAIL or
		   tran.type = TRANS_TYPE_REL_SHIP or
		   tran.type = TRANS_TYPE_REL_ROAD or
		   tran.type = TRANS_TYPE_REL_RAIL or
		   tran.type = TRANS_TYPE_UNPACK  or
		   tran.type = TRANS_TYPE_UnpackComplete or
		   tran.type = TRANS_TYPE_PACK or
		   tran.type = TRANS_TYPE_PackComplete or
		   tran.type = TRANS_TYPE_WHARFAGE then
			if not toSkip.includes(tran.type) then
				toSkip.add(tran.type);
			endif;
		endif;
	endforeach;
	
	foreach type in toSkip do
		if _trxArray.includes(type) then
			_trxArray.remove(type);
			trxType := app.myRoot.allTransactionTypes[type];
			if trxType &lt;&gt; null then
				typeDesc := trxType.description;
			else
				typeDesc := 'Unknown Type ' &amp; type.String;
			endif;
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("Transaction of type " &amp; typeDesc &amp; " already present, removed from the pro forma transaction list.", LogINFO.String);
			endif;
		endif;
	endforeach;
epilog
	delete toSkip;
end;
</source>
        <access>protected</access>
        <Parameter name="_trxArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findInvLineMatching" id="30b3115c-42f0-418e-9653-442a7e1fc091">
        <source>findInvLineMatching( outDict : CM_InvoiceLineSet; matchLine : CM_InvoiceLine ) : CM_InvoiceLine protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2012	cnwndl1	Initial creation

*/

vars

	invLine : CM_InvoiceLine;

begin

	foreach invLine in outDict do
		if invLine.remarks &lt;&gt; matchLine.remarks then
			continue;
		endif;
		return invLine;
	endforeach;
	
	return null;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="outDict" type="CM_InvoiceLineSet"/>
        <Parameter name="matchLine" type="CM_InvoiceLine"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="getAvailTrxTypesFromRoot" id="37b91c37-359c-43f8-94c0-89d9998df12e">
        <source>getAvailTrxTypesFromRoot( _availTrxTypes : CM_TransactionTypeByType input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	trxType : CM_TransactionType;

begin

	if _availTrxTypes = null then
		return;
	endif;
	
	_availTrxTypes.clear();

	foreach trxType in app.myRoot.allTransactionTypes do
		// 31136 limit to CM_TITransaction sub-classes
		if trxType.trxGroup &lt;&gt; TRANS_TYPE_GROUP_TI then
			continue;
		endif;
		// allow Storage for pack/unpack where a Storage transaciton is not automaticallly created as it is from a Release
	//	if trxType.trxType = TRANS_TYPE_STORAGE then
	//		continue;
	//	else
		if trxType.trxType = TRANS_TYPE_AvailableForRelease then
			continue;
		elseif trxType.trxType = TRANS_TYPE_ReeferMonitor then
			continue;
		// 34917 clean up from GPHA cash - exclude more types
		elseif trxType.trxType = TRANS_TYPE_BOL_STOP_ADD or
			   trxType.trxType = TRANS_TYPE_BOL_STOP_CLEARED or
			   trxType.trxType = TRANS_TYPE_BOLCREATED or
			   trxType.trxType = TRANS_TYPE_CAMSAUDIT or
			   trxType.trxType = TRANS_TYPE_DAIRY or
			   trxType.trxType = TRANS_TYPE_DocketCorrection or
			   trxType.trxType = TRANS_TYPE_FUTURE_STORAGE or
			   trxType.trxType = TRANS_TYPE_INFO_EDI_SENT or
			   trxType.trxType = TRANS_TYPE_FREE_STORAGE_ADJ or
			   trxType.trxType = TRANS_TYPE_LogNoNumberOffload or
			   trxType.trxType = TRANS_TYPE_LogNoNumberRetain or
			   trxType.trxType = TRANS_TYPE_LogNoNumberSwap or
			   trxType.trxType = TRANS_TYPE_NEEDSDAIRYBOARD then
			continue;
		endif;
		
		_availTrxTypes.add(trxType);
	endforeach;

epilog

end;</source>
        <Parameter name="_availTrxTypes" type="CM_TransactionTypeByType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAvailableCritTypes" id="6d6364d7-48b2-4d0a-a3dc-a83354dcbc28">
        <source>getAvailableCritTypes( _critTypes : CM_YACritetriaTypeByTypeDict input);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
24 August 2012	cnwndl1	Initial creation
04/03/2015		cnwmh5	Tranisent Leaks
26/04/2016  	cnwma1  PAR #36914 TFS1768 Communicating/NonCommunciating Reefer Yard Allocation Criteria
*/

vars

	iter : Iterator;
	critType : CM_YACriteriaType;

begin

	_critTypes.clear();
	
	iter := app.myRoot.allYACriteriaTypes.createIterator;
	while iter.next( critType ) do
		if  not critType.isUsed    then		//26/04/2016 cnwma1 PAR #36914 TFS1768 
			continue;
		elseif critType.type = 20 then	//Receive Transport Mode
			continue;
		elseif critType.type = 23 then	// Rehandles
			continue;
		elseif critType.type = 24 then	//Source Terminal Area
			continue;
		elseif critType.type = 25 then	//Source Terminal Area Type
			continue;
		elseif critType.type = 35 then	//Is TransShip
			continue;
		elseif critType.type = 37 then	//Load Port
			continue;
		elseif critType.type = 53 then	// Sub-Terminal
			continue;
		elseif critType.type = 56 then	//Is Available
			continue;
		elseif critType.type = 58 then	//BOL
			continue;
		elseif critType.type = 59 then	//Tranship to Port
			continue;
		elseif critType.type = 67 then	// Voyage Inbound
			continue;
		elseif critType.type = 68 then	//	Voyage Outbound
			continue;
		elseif critType.type = 70 then	//Tranship Discharge Port
			continue;
		endif;
		//write critType.description &amp; " " &amp; critType.type.String;
		_critTypes.add( critType );
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_critTypes" type="CM_YACritetriaTypeByTypeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCashNotPaidDescription" id="587f0eed-5f71-4d1d-9fbb-97b1d243de5b">
        <updating/>
        <source>getCashNotPaidDescription(_ti : CM_TrackedItem; _bank : CM_Bank; _effectiveDate : Date;	_manual : Boolean;_isReceival : Boolean) : String updating;
/*

Purpose:			TFS 8264

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2017	jlgab1	Initial creation

*/

vars
	trxTypeArray : IntegerArray;	
	trxType : Integer;
	transType : CM_TransactionType;
	typeDesc : String;
	addStorage : Boolean;
begin
	self.init( _bank, _ti, _effectiveDate,  _isReceival );


	create trxTypeArray transient;
	self.getProformaTransactionTypes( trxTypeArray, true, true );
	
	
	
	foreach trxType in trxTypeArray do
		transType := app.myRoot.allTransactionTypes[trxType];
		if transType &lt;&gt; null then
			if transType.trxType = TRANS_TYPE_REL_ROAD then
				addStorage := true;
			endif;
		endif;
	endforeach;
	
	if addStorage then
		if not trxTypeArray.includes(TRANS_TYPE_STORAGE) then
			trxTypeArray.add(TRANS_TYPE_STORAGE);
		endif;
	endif;
	
	
	foreach trxType in trxTypeArray do
		transType := app.myRoot.allTransactionTypes[trxType];
		if transType &lt;&gt; null then
			if self.selectedTrxCriteria = null  // TFS 36335
			or not self.selectedTrxCriteria.allTransactionTypes.includes(transType) then
				if typeDesc = null then
					typeDesc := transType.description;
				else
					typeDesc:= typeDesc &amp; ", " &amp; transType.description;
				endif;
			endif;
		endif;
	endforeach;

	return typeDesc;
epilog
	delete trxTypeArray;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_effectiveDate" type="Date"/>
        <Parameter name="_manual" type="Boolean"/>
        <Parameter name="_isReceival" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentInvLines" id="4edcb14b-e9e2-4049-b1a7-f3a872011863">
        <updating/>
        <source>getCurrentInvLines() updating;
/*

Purpose:			Build lists of all non-voided non-zero value invoice lines and existing payments for this cargo item
					to use in the processing of this payment.
Parameters:			

Return Value:		

Date				Who		Reason
19 December 2012	cnwer1	Initial creation HAT 2189
18 Oct 2024 		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	found	: Boolean; // ### JIRA 34719 23APR2025 NAVKC1
	trx 	 : CM_TITransaction;
	invLineLocal, // ### JIRA 34719 23APR2025 NAVKC1
	invLine  : CM_InvoiceLine;
	paymentLocal, // ### JIRA 34719 23APR2025 NAVKC1
	payment	 : CM_CashPayment;
	terminal : CM_Terminal;
	payments : CM_CashPaymentDict;
	canLogExtra			: Boolean;	//26.02.2025 navah1	#34141
	allInvLinesLocal : CM_InvoiceLineBySeqNumDict; // ### JIRA 34719 23APR2025 NAVKC1
	invAmount : Decimal [23,6];
begin
	
	if self.myTrackedItem = null then
		return;
	endif;
	
	create allInvLinesLocal transient; 						// ### JIRA 34719 23APR2025 NAVKC1
	self.myTrackedItem.invoiceLines.copy(allInvLinesLocal); // ### JIRA 34719 23APR2025 NAVKC1
	
	terminal := self.myTrackedItem.myTerminal;
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	

	foreach invLine in self.myTrackedItem.invoiceLines  where invLine.debtor.isCashOnlyDebtor(terminal) do  
		invAmount := invLine.totalAmount; // ### JIRA 35502 21JUL2025 NAVAB1
		
		if invLine.voided or
			invLine.isNotPaidByAPI() or //30/04/2025	navkc1 JIRA Bug MTN-34734
		   invAmount = 0 then
			if invAmount = 0 then // TFS 7311
				// TFS 7311 added logging
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("Invoice Line " &amp; invLine.sequenceNum.String &amp; " ignored - zero value, possibly no RATE", LogINFO.String);
				endif;
			endif;
			
			// ### JIRA 34719 23APR2025 NAVKC1 - Starts
			// Here is where we check whether there's another payment made for this cancelled amount
			if invLine.voided or 
				invLine.isNotPaidByAPI() //30/04/2025	navkc1 JIRA Bug MTN-34734
			then
				foreach payment in invLine.allCashPayments discreteLock do
					found := false;
					
					if payment.isNotPaidByAPI() then
						// Look for other invoice lines that could have made payment for this cancelled amount
						foreach invLineLocal in allInvLinesLocal reversed do : localLinesLoop
							// Voided, not paid
							if invLineLocal.voided or 
								invLineLocal.isNotPaidByAPI() //30/04/2025	navkc1 JIRA Bug MTN-34734
							then
								continue;
							endif;
							
							// We are doing reversed loop, and if it got to the invoice line that we are checking, no point going any further back
							if invLineLocal = invLine then
								break;
							endif;
							
							// Is this the same invoice line type as the one we are checking?
							if invLineLocal.invoiceLineDesc &lt;&gt; invLine.invoiceLineDesc then
								continue;
							endif;
							
							// Are they created for the same transaction?
							if invLineLocal.myTransactionTI &lt;&gt; invLine.myTransactionTI then
								continue;
							endif;
							
							/* ===============================================================================
								If we got in here then likely this invoice line is created for what was cancelled
							=============================================================================== */
							
							// We don't have a cash payment yet, just check the line total
							if invLineLocal.allCashPayments.isEmpty() then
								// Found one that matches the amount
								if invLineLocal.totalAmount = payment.cashValue then
									found := true;
									break localLinesLoop;
								endif;
							else
								// Do we have something here paid for the same amount, and is not cancelled?
								foreach paymentLocal in invLineLocal.allCashPayments discreteLock, reversed do
									// Found one that matches the amount
									if paymentLocal.cashValue = payment.cashValue then
										found := true;
										break localLinesLoop;
									endif;
								endforeach;
							endif;
						endforeach;
						
						if not found then
							self.allCurrentInvLines.tryAdd(invLine);
							self.invoicedCashCharges := self.invoicedCashCharges + invAmount;// ### JIRA 35502 18JUL2025 NAVAB1 use totalAmount (Static)
						endif;
					endif;
				endforeach;
			endif;
			// ### JIRA 34719 23APR2025 NAVKC1 Ends
			
			continue;
			
		endif;
		self.allCurrentInvLines.add(invLine);
	
		self.invoicedCashCharges := self.invoicedCashCharges + invAmount;// ### JIRA 35502 18JUL2025 NAVAB1 use totalAmount (Static)
	endforeach;
	
		
	if self.myTrackedItem.allCashPaymentProformaPrints.isEmpty() then // TFS 47985
		payments := self.myTrackedItem.allCashPayments;				  // TFS 47985
	else 															  // TFS 47985
		payments := self.myTrackedItem.allCashPaymentProformaPrints;  // TFS 47985
	endif;
	
	
	// 33885 show existing payments if they exist, regardless of option settings - they can be from a second payment for remaining gate charges
	//	even if partial payments are not allowed
	// TFS 47985	foreach payment in self.myTrackedItem.allCashPayments do
	
	foreach payment in payments do

		if payment.voided or
			payment.isNotPaidByAPI() //30/04/2025	navkc1 JIRA Bug MTN-34734
			then
			continue;
		endif;
		
		if payment.isTaxPayment  then 
			continue;
		endif;

		self.allCashPayments.add(payment);
		self.cashPayments := self.cashPayments + payment.cashValue;
	endforeach;
	

	self.updateProformaPaid();
	//self.updateInvoicedPaid();		// 36102 TFS 45953

epilog
	delete allInvLinesLocal; // ### JIRA 34719 23APR2025 NAVKC1
end;</source>
    </JadeMethod>
    <JadeMethod name="getCurrentInvLinesDutyDoc" id="67af7776-e35b-47d3-bbeb-90663a910649">
        <updating/>
        <source>getCurrentInvLinesDutyDoc() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2014	cnwma1	Initial creation PAR#34408

*/

vars
	trx : CM_TITransaction;
	invLine : CM_InvoiceLine;
	payment	: CM_CashPayment;
	terminal : CM_Terminal;
begin
	
	if self.myTrackedItem = null then
		return;
	endif;
	
	terminal := self.myTrackedItem.myTerminal;
	foreach trx in self.myTrackedItem.allTransactions do
		if trx.isCharged then
			foreach invLine in trx.allInvoiceLines   do  
				if invLine.voided then
					continue;
				endif;
				self.allCurrentInvLines.add(invLine);
				
				self.invoicedCashCharges := self.invoicedCashCharges + invLine.lineTotal;
			endforeach;
		endif;
	endforeach;
	
	// Cash III 32851 partial payments
	//if terminal.getConfig(CashCollectAllowUnderpay).Boolean then
	// 33885 show existing payments if they exist, regardless of option settings - they can be from a second payment for remaining gate charges
	//	even if partial payments are not allowed
		foreach payment in self.myTrackedItem.allCashPayments do
			if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
				continue;
			endif;
			self.allCashPayments.add(payment);
			self.cashPayments := self.cashPayments + payment.cashValue;
		endforeach;
	//endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDutyDocValues" id="cc4934b7-adc7-4f83-91c9-58db8b69974c">
        <source>getDutyDocValues(	_dutyDoc : CM_DutyDoc;	
					_dutyCharges : Decimal output;	//18 Dec 2013	NDL	Par 33182
					_termCharges : Decimal output;
					_storageCharges : Decimal output;
					_otherCharges : Decimal output;
					_totalCharges : Decimal output
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	trxTypeArray 		: IntegerArray;
	localDict 			: CM_InvoiceLineBySeqNumDict;
	inv 				: CM_Invoice;
	invLine 			: CM_InvoiceLine;
	trxType,
	lineCount,
	index 				: Integer;
	dutyCharges, 
	termCharges,
	storageCharges,
	extraTotChg, 
	extraCash, 
	extraOutstanding,
	otherCharges,
	totalCharges 		: Decimal[23,6];
	lineTrxTypes 		: IntegerArray;
	allExtraChargeInvs  : CM_InvoiceSet;
	debtor              : CM_Debtor;
begin
	
	//find all of the trx types that are supposed to be there eventually.
	create trxTypeArray transient;
	self.getProformaTransactionTypes( trxTypeArray, true, true );
	
	//remove any trx type already invoiced, (one for one) from proformas and
	//total the values already charged.
	foreach inv in self.myTrackedItem.allInvoices do
		foreach invLine in inv.invoiceLines do
			trxType := 0;
			if invLine.myTransactionTI &lt;&gt; null then
				trxType := invLine.myTransactionTI.getType;
				if trxType &gt; 0 then
					index := trxTypeArray.indexOf(trxType);
					if index &gt; 0 then
						trxTypeArray.removeAt(index);
					endif;
				endif;
			endif;
			self.doSumValuesForDocDutyValues(	invLine,	//_invLine : CM_InvoiceLine;
												trxType,	//_trxType : Integer;
												dutyCharges,	//_termCharges : Decimal output;	//18 Dec 2013	NDL	Par 33182
												termCharges,	//_termCharges : Decimal output;
												storageCharges,	//_storageCharges : Decimal output;
												otherCharges,	//_otherCharges : Decimal output;
												totalCharges	//_totalCharges : Decimal output
												);
		endforeach;
	endforeach;
	
	//create local dict of proform inv lines
	create lineTrxTypes transient;
	localDict := app.myTrxCA.trxCreateProformaInvoiceLines(	trxTypeArray,	//_transactionTypes : IntegerArray;
															self.myTrackedItem,	//_cargoItem : CM_TrackedItem input;
															null,			// _children
															self.effectiveDate,	//_endDate : Date;
															null,
															lineTrxTypes,	//_lineTrxTypes : IntegerArray io;
															app.myPassport	//_passport : CM_Passport input
															);
	
	foreach invLine in localDict do
		lineCount := lineCount + 1;
		trxType := lineTrxTypes[lineCount];	// trantype passed back separately because not populated on transient copy...
		self.doSumValuesForDocDutyValues(	invLine,	//_invLine : CM_InvoiceLine;
											trxType,	//_trxType : Integer;
											dutyCharges,	//_termCharges : Decimal output;	//18 Dec 2013	NDL	Par 33182
											termCharges,	//_termCharges : Decimal output;
											storageCharges,	//_storageCharges : Decimal output;
											otherCharges,	//_otherCharges : Decimal output;
											totalCharges	//_totalCharges : Decimal output
											);	
	endforeach;
	
	
	
	//18 Dec 2013	NDL	Par 33182
	debtor := _dutyDoc.getMyDebtor();
	if debtor &lt;&gt; null then
		create allExtraChargeInvs transient;
		debtor.getDutyDocExtraCharges( self.myTrackedItem.myTerminal, allExtraChargeInvs );
		if not allExtraChargeInvs.isEmpty then
				foreach inv in allExtraChargeInvs do
				if inv.isExtraChargeForDutyDocSystem( extraTotChg, extraCash, extraOutstanding ) then
					foreach invLine in inv.invoiceLines where not invLine.voided do
						if invLine.remarks.pos(_dutyDoc.id,1) &lt;&gt; 1 then
							continue;
						endif;
						otherCharges := otherCharges + invLine.lineTotal;
						totalCharges := totalCharges + invLine.lineTotal;
					endforeach;
				endif;
			endforeach;
		endif;
	endif;
	
	_dutyCharges := dutyCharges;	//18 Dec 2013	NDL	Par 33182
	_termCharges := termCharges;
	_storageCharges := storageCharges;
	_otherCharges := otherCharges;
	_totalCharges := totalCharges;
	
epilog

	delete trxTypeArray;
	if localDict &lt;&gt; null and not localDict.isEmpty then
		localDict.purge();
	endif;
	delete localDict;
	delete lineTrxTypes;
	app.allReportObjectSet.purge();	//31 May 2013	NDL	Par 31636
	delete allExtraChargeInvs;	//18 Dec 2013	NDL	Par 33182

end;</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <Parameter name="_dutyCharges" type="Decimal" usage="output"/>
        <Parameter name="_termCharges" type="Decimal" usage="output"/>
        <Parameter name="_storageCharges" type="Decimal" usage="output"/>
        <Parameter name="_otherCharges" type="Decimal" usage="output"/>
        <Parameter name="_totalCharges" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getExpandedDetails" id="3b1de9b5-f352-4e8d-a2a8-6c1e5c152ee5">
        <source>getExpandedDetails(numRows 			:Integer output; 
					invoicedString,
					invoicedAmount, 
					estimatedString,
					estimatedAmount,
					extraTrxs		: String output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	invLine  			: CM_InvoiceLine;
	payment	 			: CM_CashPayment;
	trxType  			: CM_TransactionType;
	strArray 		    : StringArray;
	intArray 		    : IntegerArray;
	invoicedCount,
	estimatedCount,	
	index 				: Integer;
	str,
	proformaDesc		: String;

begin
	
	// current charges
	foreach invLine in self.allCurrentInvLines do
		if invoicedAmount &lt;&gt; null then
			invoicedString := invoicedString &amp; CrLf;
			invoicedAmount := invoicedAmount &amp; CrLf;
		endif;
		invoicedString := invoicedString &amp; invLine.invoiceLineDesc.narration;
		invoicedAmount := invoicedAmount &amp; invLine.lineTotal.asCurrencyJMT();
		invoicedCount  := invoicedCount + 1;
	endforeach;
	// 32851 show (partial) payments as well
	foreach payment in self.allCashPayments where not payment.isProformaPayment do
		if invoicedAmount &lt;&gt; null then
			invoicedString := invoicedString &amp; CrLf;
			invoicedAmount := invoicedAmount &amp; CrLf;
		endif;
		invoicedString := invoicedString &amp; "Paid " &amp; payment.myCashReceipt.getExternalInvoiceNumber();
		invoicedAmount := invoicedAmount &amp; "-" &amp; payment.cashValue.asCurrencyJMT();
		invoicedCount  := invoicedCount + 1;
	endforeach;
	

	foreach invLine in self.allProformaInvLines do
		if estimatedAmount &lt;&gt; null then
			estimatedString := estimatedString &amp; CrLf;
			estimatedAmount := estimatedAmount &amp; CrLf;
		endif;

		if  not invLine.manual then
			estimatedString := estimatedString &amp; invLine.invoiceLineDesc.narration &amp; " (x" &amp; invLine.quantity.roundedTo(4).String &amp; ")";
		else
			estimatedString := estimatedString &amp; invLine.remarks;
		endif;
		
		estimatedAmount :=  estimatedAmount &amp; invLine.lineTotal.asCurrencyJMT();
		estimatedCount  := estimatedCount + 1;
	endforeach;

	
	foreach payment in self.allCashPayments where payment.isProformaPayment do
		if estimatedAmount &lt;&gt; null then
			estimatedString := estimatedString &amp; CrLf;
			estimatedAmount := estimatedAmount &amp; CrLf;
		endif;
		// 34990 show what the payment was for and accumulate paid extras
		proformaDesc    := payment.getPaidProformaDesc();
		estimatedString := estimatedString &amp; "Paid " &amp; payment.myCashReceipt.getExternalInvoiceNumber() &amp; ": " &amp; proformaDesc;
		estimatedAmount := estimatedAmount &amp; "-"     &amp; payment.cashValue.asCurrencyJMT();
		estimatedCount  := estimatedCount + 1;
	endforeach;
	
	//consolidate trx types 
	
	create strArray transient;
	create intArray transient;
	
	index := 0;
	foreach str in strArray do
		index := index + 1;
		if extraTrxs &lt;&gt; null then
			extraTrxs := extraTrxs &amp; CrLf;
		endif;
		if intArray.size &gt;= index then
			extraTrxs := extraTrxs &amp; strArray[index] &amp; " (x" &amp; intArray[index].String &amp; ")";
		else
			extraTrxs := extraTrxs &amp; strArray[index];
		endif;
			
	endforeach;
	
	// number of rows to show is max of invoiced, estimated and extra columns content
	numRows := invoicedCount.max(estimatedCount);
	numRows := numRows.max(strArray.size);
epilog
	delete strArray;
	delete intArray;
end;</source>
        <Parameter name="numRows" type="Integer" usage="output"/>
        <Parameter name="invoicedString" type="String" usage="output"/>
        <Parameter name="invoicedAmount" type="String" usage="output"/>
        <Parameter name="estimatedString" type="String" usage="output"/>
        <Parameter name="estimatedAmount" type="String" usage="output"/>
        <Parameter name="extraTrxs" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getManualProforma" id="dc89ecce-3f5c-4c53-a464-982c4c53d31f">
        <source>getManualProforma() : CM_InvoiceLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

	invLine : CM_InvoiceLine;

begin
	
	// 36353 look in allExtraProfInvLines first to get the current one when maintaining it
	/*  TFS 45953 nothing was adding to allExtraProfInvLines, it is always empty
	foreach invLine in self.allExtraProfInvLines do
		if invLine.sequenceNum = Max_Integer then
			return invLine;
		endif;
	endforeach;
	*/
	//NDL 8 Jan 2013
	// 34917 allProformaInvLines is now a set, read all to find the manual line
	foreach invLine in self.allProformaInvLines do
		if invLine.sequenceNum = Max_Integer then
			return invLine;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="getPaidAmount" id="b9b1dcfb-0c33-4f19-8c69-6857f06ff6fc">
        <source>getPaidAmount():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2013	cnwndl1	Initial creation	Par 30901
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars

	allInvoices 	 : CM_InvoiceSet;
	invLine 		 : CM_InvoiceLine;
	invoice          : CM_Invoice;
	realCashPayment  : CM_CashPayment;
	paidAmount		 : Decimal [23,6];
	cashPayment		 : CM_CashPayment;

begin

	if self.myTrackedItem = null then
		return 0.0;
	endif;

	create allInvoices transient;

	foreach invLine in self.allCurrentInvLines do
		invoice := invLine.invoice;
		if invoice &lt;&gt; null then
			allInvoices.addNoDuplicates(invoice,false);
		endif;
	endforeach;
	
	foreach invoice in allInvoices do
		realCashPayment := self.myTrackedItem.findCashPaymentForInvoice(invoice);
		if realCashPayment &lt;&gt; null then
			paidAmount := paidAmount + realCashPayment.cashValue;
		endif;
	endforeach;
	
	// 33885 with top-up payments, can be more than one proforma payment
	foreach cashPayment in self.allCashPayments do
		if cashPayment.isProformaPayment then
			paidAmount := paidAmount + cashPayment.cashValue;
		endif;
	endforeach;
	
	return paidAmount;

epilog

	delete allInvoices;

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getProformaCashValue" id="2465c3c3-2fe9-4714-94d1-506cc5cae1ff">
        <source>getProformaCashValue() : Decimal;
/*
Purpose:	TFS 44275		
Date		Who	   Reason
MAY 2019	JLGAB1 initial creation
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars
	totalCargoCharges	: Decimal[23,6];	//21.10.2019 cnwma1 TFS #47081
	line				: CM_InvoiceLine;
	index			    : Integer;
	selected	        : Boolean;
begin

	foreach line in self.allProformaInvLines do
		if line.manual then		// skip manual paid lines so the selectedEstimated entries match up
			continue;
		endif;
		totalCargoCharges := totalCargoCharges + (line.quantity * line.totalRate);   		//21.10.2019 cnwma1 TFS #47081		// ### JIRA 35502 18JUL2025 NAVAB1 use totalRate (Static)										
	endforeach;
	
	/*  TFS 45953 nothing was adding to allExtraProfInvLines, it is always empty
	foreach line in self.allExtraProfInvLines do
		totalCargoCharges := totalCargoCharges + line.lineTotal;
	endforeach;
	*/
	return totalCargoCharges;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getProformaTransactionTypes" id="27d2969d-7ce1-4938-baf1-81c3634c1db2">
        <source>getProformaTransactionTypes( _trxArray : IntegerArray input; _includeConfigTypes : Boolean; _includeUserTypes : Boolean) protected;

/*

Purpose:			

Parameters:			_includeConfigTypes added for CCMS 2368 to allow user transaction pro forma lines to be created separately

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars
	
	trxType : CM_TransactionType;
	transArray	: IntegerArray;
	ti			: CM_TrackedItem;
	found		: Boolean;
	tranType	: Integer;
	units : Integer;
	index : Integer;

begin

	if _trxArray = null then 
		return;
	endif;
	
	_trxArray.clear();
	
	if _includeConfigTypes then	//22 Mar 2016	NDL	TFS 1669 - Don't do this for Extra Details processing...
		if self.ignoreProformaForRoadRelease then // in cash collection this means that 'For Cargo Release' is false
			if self.selectedTrxCriteria = null then
				return;
			endif;
// TFS 41295			if _includeConfigTypes then
				foreach trxType in self.selectedTrxCriteria.allTransactionTypes do
					units := self.getUnits( trxType );
					if units &lt; 1 then
						continue;
					endif;
					foreach index in 1 to units do
						_trxArray.add( trxType.trxType );
					endforeach;
				endforeach;
				// TFS 1954 May 2016 if on-ship and ship release date set, add Receive ship transaction type to the list to set the release date onto
				//   if it is not already configured AND do it before any storage transactions
				if self.releaseDate &lt;&gt; null and
				   self.myTrackedItem.isOnShip then
					foreach tranType in _trxArray do
						if tranType = TRANS_TYPE_REC_SHIP then
							found := true;
							break;
						endif;
					endforeach;
					if not found then
						_trxArray.insert(1, TRANS_TYPE_REC_SHIP);
					endif;
				endif;
// TFS 41295			endif;
		else // in cash collection this means that 'For Cargo Release' is true
			self.getReleaseTransactions(_trxArray);		// 34645 expand the range of possible transactions
			// TFS 1954 May 2016 if on-ship and ship release date set, add Receive ship transaction type to the list to set the release date onto
			//   if it is not already configured AND do it before any storage transactions
			if self.releaseDate &lt;&gt; null and
			   self.myTrackedItem.isOnShip then
				foreach tranType in _trxArray do
					if tranType = TRANS_TYPE_REC_SHIP then
						found := true;
						break;
					endif;
				endforeach;
				if not found then
					_trxArray.insert(1, TRANS_TYPE_REC_SHIP);
				endif;
			endif;
		
		endif;
// TFS 41295	endif;
	

	// 32416 need to create special txns for some debtors such as ReeferDaily
// TFS 41295	if _includeConfigTypes then
		self.getTiTxnTypesForDebtorRelease(_trxArray);
	// 34917 CCMS 2368 run hook code to get any extra user-defined transaction types
		if self.selectedTrxCriteria &lt;&gt; null and 
		   self.selectedTrxCriteria.myHookCode &lt;&gt; null then
			create transArray transient;
			_trxArray.copy(transArray);
			ti := self.myTrackedItem;
			// the hook code adds to transArray based on the tracked item attributes
			app.myHookAgent.runHookLinkReturn(HookType_CashProForma, self.selectedTrxCriteria, self.selectedTrxCriteria, transArray, ti);
			_trxArray.clear();
			transArray.copy(_trxArray);
		endif;
		// 34917 'No duplicates actual/estimated' 
//TFS 45953		if self.myTrackedItem.myTerminal.getConfig(CashNoDuplicatesActualEst).Boolean then
		self.filterDuplicateActualEstimated(_trxArray);
//		endif;
	endif;
	
	/* // TFS 45953
	if _includeUserTypes then		// 34990 and 34917 - note done regardless of the CashNoDuplicatesActualEst setting
		foreach trxType in self.userSelectedTransactions do
			if trxType &lt;&gt; null then
				_trxArray.add( trxType.trxType );
			endif;
		endforeach;
	endif;
	*/
epilog
	delete transArray;
end;</source>
        <access>protected</access>
        <Parameter name="_trxArray" type="IntegerArray" usage="input"/>
        <Parameter name="_includeConfigTypes" type="Boolean"/>
        <Parameter name="_includeUserTypes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getReleaseTransactions" id="558b3499-3a9a-4d2a-aa31-1565bee14e83">
        <source>getReleaseTransactions(_intArray : IntegerArray input) protected;
//	34645 for cash receipts, get the list of transactions from a road release
//	instead of just hard-coded a release, to handle reefer daily.
//	5/11/2018 	JLGNS1	Bug 40690: GUQ - Reef Days connected not working on jmt851#200
vars
	lastDisconnect	: TimeStamp;
	lastConnect		: TimeStamp;
	debtor	: CM_Debtor;
	type	: Integer;
begin
	app.addTiTxnSubTerminalRelease(self.myTrackedItem, TI_TRANSMODE_ROAD, _intArray);

	if self.myTrackedItem.isAnInterTerminalRelease() then
		_intArray.add(TRANS_TYPE_REL_ROAD_INTER_TERM);
	else
		_intArray.add(TRANS_TYPE_REL_ROAD);
	endif;

	///_intArray.add(TRANS_TYPE_STORAGE);		the CM_Release create will also create a CM_Storage

	// add disconnect power if reefer and lastDisconnect is not already the effective date, to get the reefer daily invoice line quantity correct
	///////////	Bug 40690
	if self.myTrackedItem.isReefer then
		lastDisconnect := self.myTrackedItem.getLastDisconnectDTAsAt(self.effectiveDate);
		lastConnect := self.myTrackedItem.getLastConnectDTAsAt(self.effectiveDate);				//check if we ever got connected
		if lastConnect &lt;&gt; null then																
			if lastDisconnect = null or lastDisconnect &lt; lastConnect then			   			//check if we are still connected
				_intArray.add(TRANS_TYPE_DISCONNECT_POWER);
			endif;
		endif;
	endif;	
	/*
	if self.myTrackedItem.isReefer then
		lastDisconnect := self.myTrackedItem.getLastDisconnectDT;
		if lastDisconnect = null or
		   (lastDisconnect &lt;&gt; null and
		   lastDisconnect.date &lt;&gt; self.effectiveDate) then
			_intArray.add(TRANS_TYPE_DISCONNECT_POWER);
		endif;
	endif;
	*/
	///////////	Bug 40690
	
	// add reefer daily/reefer flat rate if configured for debtor
	/* TFS 41295
	if self.myTrackedItem.myOperator &lt;&gt; null then
		debtor := self.myTrackedItem.myOperator.debtor;
	endif;
	*/
	debtor := self.myTrackedItem.getDebtorForCashDebtorType(); // TFS 41295 use the debtor for the configured cash debtor

	if debtor = null then
		return;
	endif;
	
	foreach type in debtor.allSpecialReleaseTxnTypes do
		if not _intArray.includes(type) and
		self.myTrackedItem.isRelevantTxnType(type) then
			_intArray.add(type);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="ed9a1488-2aa1-4b9b-bdfe-2a182ebb690e">
        <source>getTerminal() : CM_Terminal;
/*

Purpose:			TFS37454

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2018	jlgab1	Initial creation

*/

vars

begin
	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.myTerminal;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForDebtorRelease" id="e77c8125-a332-4583-928c-89b0dd7ec79f">
        <source>getTiTxnTypesForDebtorRelease(_intArray : IntegerArray input) protected;
// 32416 copied from CMIF_MoveController
// Date				Who		Reason
// 18 Oct 2024 		navlw1	JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	theDebtor	: CM_Debtor;
	txnType		: Integer;
	debtorType : CM_DebtorType;
	tranType : CM_TransactionType;
	canLogExtra			: Boolean;	//26.02.2025 navah1	#34141
begin
/* TFS 41295 WAS
	if not self.isValidDebtorRelease(_intArray) then
		return;
	endif;

	if self.myTrackedItem = null or 
	self.myTrackedItem.myOperator = null then
		return;
	endif;
	
	theDebtor := self.myTrackedItem.myOperator.debtor;
	
	if theDebtor = null then
		return;
	endif;
	
	foreach txnType in theDebtor.allSpecialReleaseTxnTypes do
		if not _intArray.includes(txnType) and
		   self.myTrackedItem.isRelevantTxnType(txnType) then
			_intArray.add(txnType);
		endif;
	endforeach;
	
	TFS 41295 NOW
*/
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	
	if not self.isValidDebtorRelease(_intArray) then
		return;
	endif;

	if self.myTrackedItem = null then
		return;
	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " - Checking for configured release reefer transactions", LogINFO.String);
	endif;
	theDebtor := self.myTrackedItem.getDebtorForCashDebtorType();
	
	if theDebtor = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " - Debtor Derived From is NULL", LogTRACE.String);
		endif;
		return;
	endif;
	
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " - debtor for release reefer transactions is " &amp; theDebtor.name, LogINFO.String);
	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		if self.myTrackedItem.isReefer then
			app.invLog(method.qualifiedName &amp; " - cargo '" &amp; self.myTrackedItem.id &amp;  " is reefer", LogTRACE.String);
		else
			app.invLog(method.qualifiedName &amp; " - cargo '" &amp; self.myTrackedItem.id &amp;  " IS NOT REEFER, no reefer transactions will be chosen", LogTRACE.String);
		endif;
	endif;
	foreach txnType in theDebtor.allSpecialReleaseTxnTypes do
		if not _intArray.includes(txnType) and
		   self.myTrackedItem.isRelevantTxnType(txnType) then
			
			_intArray.add(txnType);
		   
			tranType := app.myRoot.allTransactionTypes[txnType];
			if tranType &lt;&gt; null then
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Adding in reefer transaction '" &amp; tranType.description &amp; "'", LogINFO.String);
				endif;
			endif;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTotal" id="d96d9638-52f7-47f9-9320-76636385e9dd">
        <source>getTotal() : Decimal;
// get the cargo total to pay, taking into account the individual invoice line selection
//10/04/2018 JLGNS1 Bug 37608: PKT - Error 14051
//21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
vars
	totalCargoCharges	: Decimal[23,6];   //21.10.2019 cnwma1 TFS #47081
	line				: CM_InvoiceLine;
	index				: Integer;
	selected			: Boolean;
begin
/* TFS 45953 -  no way to set this anymore the cash collection no longer consolidates
	if self.showingConsolidated then
		index := 0;
		foreach line in self.allConsolidatedInvLines do
			index := index + 1;
			selected := false;
			if index &lt;= self.selectedInvoicedCons.size then
				selected := self.selectedInvoicedCons[index];
			endif;
			if selected then
				totalCargoCharges := totalCargoCharges + line.getUnpaidAmount;
			endif;
		endforeach;
		index := 0;
		foreach line in self.allConsolidatedProfInvLines do
			index := index + 1;
			selected := false;
			if index &lt;= self.selectedEstimatedCons.size then
				selected := self.selectedEstimatedCons[index];
			endif;
			if selected then
				totalCargoCharges := totalCargoCharges + line.getUnpaidAmount;
			endif;
		endforeach;
		foreach line in self.allConsExtraProfInvLines do
			totalCargoCharges := totalCargoCharges + line.lineTotal;
		endforeach;
	else
	*/
		index := 0;
		foreach line in self.allCurrentInvLines do
			index := index + 1;
			/* TFS 45953 we only put invoice lines in allCurrentInvLines when needed, no longer control with selectedInvoiced array
			selected := false;
			if index &lt;= self.selectedInvoiced.size then
				selected := self.selectedInvoiced[index];
			endif;
			if selected then
			*/
				// TFS 45953 if not self.paidInvoiced[index] then		// 36102
				if not line.isPaidFor then // TFS 45953 
					totalCargoCharges := totalCargoCharges + line.getUnpaidAmount;
				endif;
			//endif;
		endforeach;
		index := 0;
		foreach line in self.allProformaInvLines do
			index := index + 1;
			if line.manual then							// Bug 37608
				continue;								// Bug 37608
			endif;										// Bug 37608
// TFS 45953			selected := false;
// TFS 45953			if index &lt;= self.selectedEstimated.size then
// TFS 45953				selected := self.selectedEstimated[index];
// TFS 45953			endif;
// TFS 45953			if selected then
				totalCargoCharges := totalCargoCharges + line.getUnpaidAmount;
// TFS 45953			endif;
		endforeach;
			/*  TFS 45953 nothing was adding to allExtraProfInvLines, it is always empty
		foreach line in self.allExtraProfInvLines do
			totalCargoCharges := totalCargoCharges + line.lineTotal;
		endforeach;
		*/
//	endif;
	
	return totalCargoCharges;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getUnits" id="9e043e2e-c6cc-48fb-a31c-c82f806951d6">
        <source>getUnits(_trxType : CM_TransactionType ):Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	today : Date;
	processDate : Date;
	arrived : Date;
	proformaUnit : CM_ProformaTransactionUnit;

begin
	
	if _trxType = null then
		return 0;
	endif;
	
	if self.selectedTrxCriteria &lt;&gt; null then
		proformaUnit :=  self.selectedTrxCriteria.getUnitDetailsForTrxType( _trxType );
	endif;
	
	if proformaUnit = null then
		return 1;
		
	elseif proformaUnit.unitType = CM_ProformaTransactionCriteria.UnitType_UserUnit then
		return proformaUnit.unitValue.Integer;
		
	elseif proformaUnit.unitType = CM_ProformaTransactionCriteria.UnitType_PerDay then
		arrived := null;
		if self.myTrackedItem.isOnSite then
			arrived := self.myTrackedItem.getReceiveDate();
		elseif self.myTrackedItem.isOnShip then
			arrived := self.myTrackedItem.myVoyage.arrivedDT.Date;
		endif;
		
		if not arrived.isValid then
			arrived := today;
		endif;
		
		processDate := self.effectiveDate;
		if not processDate.isValid then
			processDate := today;
		endif;
		
		return ( processDate - arrived ).Integer + 1;
		
	endif;
	
	return 0;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_trxType" type="CM_TransactionType"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
