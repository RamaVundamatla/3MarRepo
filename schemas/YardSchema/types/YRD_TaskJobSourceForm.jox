    <JadeMethod name="displayBookings" id="08400685-996f-4668-b497-3f018a0dfef4">
        <updating/>
        <source>displayBookings( _bookingRef : CM_BookingRef ) updating;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin


	//self.btnAddBookingRef.visible := false;
	//self.btnRemBookingRef.visible := false;
	
	self.tblThumb.rows := 0;
	
	self.fraThumbNail.parent := self.shtBooking;
	
	self.btnViewSource.visible := true;	

	if _bookingRef = null then
		self.cmbBookingRef.listIndex := -1;
		self.cmbBookingRef.enabled := self.canSourcesBeAdded;
		self.btnAddBookingRef.enabled := self.canSourcesBeAdded;
		self.btnAddBookingRef.visible := self.canSourcesBeAdded;
		self.btnRemBookingRef.visible := false;
		self.btnViewSource.enabled := false;
	else
		self.cmbBookingRef.setObject(_bookingRef);
		self.doShowBookingRefThumb();
		self.btnViewSource.enabled := true;
		//self.cmbBookingRef.enabled := false;
		//self.btnAddBookingRef.enabled := false;
		self.btnRemBookingRef.visible := self.canSourcesBeRemoved or not self.initialBookings.includes(_bookingRef);
	endif;
	
	
	if app.getMyUser().canDo(self.myTerminal,PmWOAddBooking) then
		self.btnAddBookingRef.visible := true;
		self.btnRemBookingRef.visible := true;
	else
		self.btnAddBookingRef.visible := false;
		self.btnRemBookingRef.visible := false;
	endif;
	
	self.showGroup(self.shtBooking);
	self.cmbBookingRef.setFocus();
	
epilog

end;</source>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="displayBulkReleases" id="26504605-50c7-46ab-b115-1db3798462d8">
        <updating/>
        <source>displayBulkReleases( _bulkRelease : CM_BulkRelease ) updating;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin

	//self.btnAddBulkRel.visible := false;
	//self.btnRemBulkRel.visible := false;
	self.tblThumb.rows := 0;
	self.fraThumbNail.parent := self.shtRelease;
	self.btnViewSource.visible := true;	

	if _bulkRelease = null then
		self.cmbBulkRelease.listIndex := -1;
		self.cmbBulkRelease.enabled := self.canSourcesBeAdded;
		self.btnAddBulkRel.enabled := self.canSourcesBeAdded;
		self.btnAddBulkRel.visible := self.canSourcesBeAdded;
		self.btnRemBulkRel.visible := false;
		self.btnViewSource.enabled := false;
	else
		self.cmbBulkRelease.setObject(_bulkRelease);
		self.doShowReleaseThumb();
		//self.cmbBulkRelease.enabled := false;
		//self.btnAddBulkRel.enabled := false;
		self.btnRemBulkRel.visible := self.canSourcesBeRemoved or not self.initialBulkReleases.includes(_bulkRelease);
		self.btnViewSource.enabled := true;
	endif;
	
	
	if app.getMyUser().canDo(self.myTerminal,PmWOAddRelease) then
		self.btnAddBulkRel.visible := true;
		self.btnRemBulkRel.visible := true;
	else
		self.btnAddBulkRel.visible := false;
		self.btnRemBulkRel.visible := false;
	endif;
	
	
	self.showGroup(self.shtRelease);
	self.cmbBulkRelease.setFocus();
	
epilog

end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="displayCargoIDs" id="a11eb9ed-0a5a-4e7c-8854-3fddd4cab9e2">
        <updating/>
        <source>displayCargoIDs() updating;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 10 Sep 2021  navma1 		ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
// -----------------------------------------------------------------------------

vars

begin
	self.cmbCargoType.enabled 	  := canSourcesBeRemoved;
	self.txtCargoIDs.enabled 	  := canSourcesBeAdded;
	self.btnCargoSelector.enabled := canSourcesBeAdded;

	self.btnViewSource.visible 	  := false;	
	
	self.showGroup(self.shtCargoIDs);
	self.cmbCargoType.setFocus();
	self.btnViewSource.enabled := false;
	
	if self.myProxySource &lt;&gt; null and self.myProxySource.isSourceForPack then   //10.09.2021 navma1 #51002
		self.txtCargoIDs.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayRequests" id="9ef981c7-7aab-4a20-b6c0-ddc8b6ceda15">
        <updating/>
        <source>displayRequests( _request : CM_WorkOrderRequestByType ) updating;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	enable : Boolean;
	grade : CM_MTGrade;
	request : CM_WorkOrderRequestByType;
	sourceArea : CM_TerminalArea;
	
begin

	self.btnViewSource.enabled := false;
	self.btnViewSource.visible := false;	
	self.tblThumb.rows := 0;

	if _request = null then
		create request transient;
		self.btnAddRequest.enabled := self.canSourcesBeAdded;
		self.btnDelRequest.visible := false;
		self.btnUpdRequest.visible := false;
	else
		request := _request;
		self.btnAddRequest.enabled := false;
		self.btnDelRequest.visible := self.canSourcesBeRemoved or not self.initialWORequestByType.includes(_request);
		self.btnUpdRequest.visible := self.btnDelRequest.visible;
	endif;

	if not request.allAvailabilityGrades.isEmpty() then
		grade := app.myRoot.allAvailabilityGrades[ request.allAvailabilityGrades.first ];
	endif;
	
	if request.mySourceLocation &lt;&gt; null then
		sourceArea := request.mySourceLocation.myTerminalArea;
	endif;

	self.cmbReqCargoType.setObject( request.myCargoType );
	self.doChangeReqCargoType();
	self.cmbReqISOType.setObject( app.myRoot.allISOTypes[request.isoType] );
	self.cmbReqOperator.setObject( request.myOperator );
	self.cmbReqOperatorGr.setIndexFromObject( request.myOperatorGroup );
	self.txtReqRequested.text := request.totalRequested.asStringJMT;
	//self.chkReqCheckISOGr.value := request.doISOGroupCheck;
	
	self.cmbISOGroup.setIndexFromObject(app.myRoot.allISOTypeGroups[request.isoGroup] );
	
	self.cmbReqAvailGrade.setObject( grade );
	self.chkReqClean.value := request.clean;
	self.chkReqHeavyDuty.value := request.heavyRated;
	self.cmbSourceArea.setIndexFromObject( sourceArea );
	self.cmbReqProduct.setObject( request.myProduct );

	enable := self.btnAddRequest.enabled or self.btnUpdRequest.visible;
	self.cmbReqCargoType.enabled := enable;
	self.cmbReqISOType.enabled := enable;
	self.cmbReqOperator.enabled := enable;
	self.cmbReqOperatorGr.enabled := enable;
	self.txtReqRequested.enabled := enable;
	self.cmbISOGroup.enabled := enable;
	self.cmbReqAvailGrade.enabled := enable;
	self.chkReqClean.enabled := enable;
	self.chkReqHeavyDuty.enabled := enable;
	self.cmbSourceArea.enabled := enable;
	self.cmbReqProduct.enabled := enable;
	
	self.showGroup(self.shtRequestByType);
	self.cmbReqCargoType.setFocus();
	
	
	if app.getMyUser().canDo(self.myTerminal,PmWOAddRequest) then
		self.grpRequests.enabled := true;		
	else
		self.grpRequests.enabled := false;
	endif;
	

epilog
	if _request = null then
		delete request;
	endif;
end;</source>
        <Parameter name="_request" type="CM_WorkOrderRequestByType"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="6caf1da7-8677-4e9c-bc70-eee508af4f0c">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		04 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 10 Sep 2021  navma1 		ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
// -----------------------------------------------------------------------------

vars
	any     	 : Any;
	newTi   	 : Boolean;
	newTiStr	 : String;
	tiArray 	 : StringArray;
	tiList  	 : String;
	tiStr   	 : String;
	pxySource    : CM_WorkOrderTISource;
	
begin
	if _mode &gt; TI_CargoType_Max then
		app.msgBox(app.getErrorString1(Work_order_cannotDisplayMode,_mode.String ) , 
				   app.getErrorString(Invalid_selector_mode) , MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if _resultCollection.isEmpty() then
		return;
	endif;

	pxySource := self.myProxySource ;                			//10.09.2021 navma1 #51002
	
	//10.09.2021 navma1 #51002
	if pxySource &lt;&gt; null and pxySource.isSourceForPack then

		pxySource.myParent.CM_WodPack.allPackingTIs.clear();
		
		foreach any in _resultCollection do
			pxySource.myParent.CM_WodPack.allPackingTIs.addNoDuplicates(any.CM_TrackedItem,false);
		endforeach;
		
		self.txtCargoIDs.text := pxySource.myParent.CM_WodPack.allPackingTIs.asDelimitedString(Comma);
	else
		tiList  := self.txtCargoIDs.text;
		tiList.replaceChar(",", " ");
		tiArray := tiList.getTokens();
		tiList  := self.txtCargoIDs.text;

		foreach any in _resultCollection do
			newTiStr := any.CM_TrackedItem.id;
			newTi := true;
			foreach tiStr in tiArray do
				if tiStr = newTiStr then
					newTi := false;
					break;
				endif;
			endforeach;
			if newTi then
				if tiList &lt;&gt; null then
					tiList := tiList &amp; ", ";
				endif;
				tiList := tiList &amp; newTiStr;
				
			endif;
		endforeach;
		self.txtCargoIDs.text := tiList;
	endif;
	
epilog
	delete tiArray;
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayWorkOrders" id="056fedea-2233-4778-bae9-271ad33e5027">
        <updating/>
        <source>displayWorkOrders( _workOrder : CM_WorkOrder ) updating;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin

	//self.btnAddWorkOrder.visible := false;
	//self.btnRemWorkOrder.visible := false;
	self.tblThumb.rows := 0;
	self.btnViewSource.visible := true;	
	self.fraThumbNail.parent := self.shtWorkOrder;

	if _workOrder = null then
		self.cmbWorkOrder.listIndex := -1;
		self.cmbWorkOrder.enabled := self.canSourcesBeAdded;
		self.btnAddWorkOrder.visible := self.canSourcesBeAdded;
		self.btnRemWorkOrder.visible := false;
		self.btnViewSource.enabled := false;
	else
		self.cmbWorkOrder.setObject(_workOrder);
		self.doShowWorkOrderThumb();
		//self.cmbWorkOrder.enabled := false;
		//self.btnAddWorkOrder.visible := false;
		self.btnRemWorkOrder.visible := self.canSourcesBeRemoved or not self.initialSourceWorkOrders.includes(_workOrder);
		self.btnViewSource.enabled := true;
	endif;
	
	if app.getMyUser().canDo(self.myTerminal,PmWOAddRelease) then
		self.btnAddWorkOrder.visible := true;
		self.btnRemWorkOrder.visible := true;
	else
		self.btnAddWorkOrder.visible := false;
		self.btnRemWorkOrder.visible := false;
	endif;
	
	
	self.showGroup(self.shtWorkOrder);
	self.cmbWorkOrder.setFocus();
	
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
    </JadeMethod>
