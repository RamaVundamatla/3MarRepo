    <JadeMethod name="loadGradeCombo" id="99fec374-2897-4eeb-ae90-7f01e04dbdbc">
        <source>loadGradeCombo(_species : CM_LogSpecies; _tbl : CM_EntryTable input;
			_cmbGrade, _cmbType, _cmbTreat, _cmbLength : ComboBox input) protected;

vars

begin

	
	self.cmbNewLength.clear;
