    <JadeMethod name="spawnEntryButtons" id="01e115eb-bb34-4222-96db-72cfd446c817">
        <updating/>
        <source>spawnEntryButtons(_wagonPosDict : MobileHandHeldThin::DTO_WagonPositionByIdxDict;
					_masterButton : Button;
					_buttonCount : Integer io) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	Builds cloned buttons for the number of positions allowed for the given wagonclass


Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	MaxButtonHeight = 40;
	AvailableWidth 	= 120;
	Gap				= 2;
vars
	
	newButtonTop,
	buttonHeight			: Real;
	buttonIdx				: Integer;
	clonedButton			: Button;
	dtoWagonPos				: MobileHandHeldThin::DTO_WagonPosition;
	startTabIdx				: Integer;
begin
	if _wagonPosDict.size = null then
		return;
	endif;
	//spread buttons heights evenly, but not beyond a certain max hieght
	buttonHeight := (AvailableWidth / _wagonPosDict.size).min(MaxButtonHeight);
	newButtonTop := _masterButton.top;
	startTabIdx := _masterButton.tabIndex;
	
	foreach dtoWagonPos in _wagonPosDict do
		_buttonCount := _buttonCount + 1;
		clonedButton := _masterButton.getControl(_buttonCount);
		if clonedButton = null then
			clonedButton := _masterButton.loadControl(_buttonCount).Button;
			clonedButton.tag := dtoWagonPos.idx.String;
			//clonedButton.setPropertyValue('name', clonedButton.name &amp; buttonIdx.String);
		endif;
		
		startTabIdx 			:= startTabIdx + 1;
		clonedButton.tabIndex 	:= startTabIdx;
		clonedButton.height 	:= buttonHeight;
		clonedButton.top 		:= newButtonTop;
		clonedButton.visible 	:= true;
		newButtonTop 			:= newButtonTop + buttonHeight + Gap;
		dtoWagonPos.myButton 	:= clonedButton;
		dtoWagonPos.setButtonCaption();
	endforeach;
	
	
	
end;


</source>
        <access>protected</access>
        <Parameter name="_wagonPosDict" type="MobileHandHeldThin::DTO_WagonPositionByIdxDict"/>
        <Parameter name="_masterButton" type="Button"/>
        <Parameter name="_buttonCount" type="Integer" usage="io"/>
    </JadeMethod>
