    <JadeMethod name="readShipData" id="db37aefc-1745-41b6-8dec-2fa02cd4f676">
        <updating/>
        <source>readShipData(_nsdFile : CMIF_NSDFile io;
			 _file 	  : File io)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2020	jlgma1	Initial creation

*/


	
vars
	nsd 			: CMIF_NSDFile;
	i,ii   			: Integer;
	bay 			: CMIF_NSDBay;
	shipMaskRef		: CMIF_NSDShipMaskFlags;
	shipFlagsRef	: CMIF_NSDShipFlags;
	flagBinArr      : BinaryArray;
	skip : Integer;
begin
	create nsd transient;
	
	
	_file.readBinary(1);
	self.iOClass	      := _file.readBinary(4).asStringJMT().trimRight();
	//self.iOClass	      := self.readStringBuffer(_file,6).asStringJMT;
	_file.readBinary(1);
	self.numStacks        := nsd.readShort(_file);
	self.numSections      := nsd.readShort(_file);
    self.numStepSchemes   := nsd.readShort(_file);
    self.numColumnSchemes := nsd.readShort(_file);
    self.maxRow			  := nsd.readShort(_file);
    self.lcgRef           := _file.readBinary(1).Integer;
	self.vcgsMode         := _file.readBinary(1).Integer;
    self.lcgsMode         := _file.readBinary(1).Integer;
    self.tcgsMode         := _file.readBinary(1).Integer;
	
	ii      := self.readUnsignedByte(_file,1);
     self.baySchemeName      := _file.readBinary(ii).asStringJMT;
	skip :=  8 - self.baySchemeName.length -1;
	self.skipBytes(_file, skip);
		

	foreach i in  1 to CMIF_NSDShipData.NUM_BAY_ELEMENTS do
		create  bay transient;
	
		bay.tierSchemeName := _file.readBinary(4).asStringJMT();
		bay.tierSchemeId   := nsd.readShort(_file);
        bay.bayName20     := _file.readBinary(4).asStringJMT();

        bay.bayName40       :=_file.readBinary(4).asStringJMT();
		self.skipBytes(_file, skip );
		
		nsd.skipBytes(_file,16);
		self.allBays.add(bay);
	endforeach;
	
	
	//lengthMap // e.g. [20, 40, 45, 0, 0, 0]
	create shipMaskRef transient;
	shipMaskRef.lcgDirectionNegative := nsd.readShort(_file).Boolean;  // Pending
	self.shipMask := shipMaskRef;
	
	self.namingConvention := _file.readBinary(1).Integer;
	nsd.skipBytes(_file,1);
	self.waterLineCm := nsd.readShort(_file);
    self.fwdPerpCm   := nsd.readShort(_file);
    self.aftPerpCm   := nsd.readShort(_file);
	
	foreach i in 1 to 6 do
		lengthMap.add(nsd.readShort(_file));
	endforeach;
	
	self.maxRoStowDeck := nsd.readShort(_file);
	
	foreach i in 1 to CMIF_NSDShipData.NUM_MAX_RO_STOW_DECK_SECTIONS  do
		self.maxRoStowDeckSections.add(nsd.readShort(_file));
	endforeach;
	
	self.maxRoStowStack   := nsd.readShort(_file);
    self.maxRoStowVersion := nsd.readShort(_file);
	
	create shipFlagsRef transient;
 	create flagBinArr transient;

	flagBinArr.add(_file.readBinary(4));

	nsd.skipBytes(_file,80);
	
	
	_nsdFile.shipData := self;
	
epilog
	delete nsd;
end;</source>
        <Parameter name="_nsdFile" type="CMIF_NSDFile" usage="io"/>
        <Parameter name="_file" type="File" usage="io"/>
    </JadeMethod>
</Class>
