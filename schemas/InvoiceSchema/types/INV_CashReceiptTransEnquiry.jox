    <JadeMethod name="setupForm" id="1d280bf3-0e03-4541-b9e4-79025e9e553b">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Dec 2019	NDL		TFS 47284

*/
vars

begin

	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.mnuContext.visible:=false; //epr TFS 2343 28/7/16
	inheritMethod();
	
	if not app.isCashOnlyEnabled then
		self.unloadForm;
		return;
	endif;
	
	self.frmTblFilter.setupControl(self.tblCash, null); //06/08/2024	navkc1 CR 64842 Task 64844
	
	self.setInitialControlValues();
	
	self.beginClassNotification(CM_CashReceipt, false, Any_System_Event, Response_Continuous, null);
	self.beginClassNotification(CM_CashPayment, false, Any_System_Event, Response_Continuous, null);
	self.beginClassNotification(CM_CashCredit, false, Any_System_Event, Response_Continuous, null);
	
	//self.addToolbarControls(); //06/08/2024	navkc1 CR 64842 Task 64844 Not sure why calling this method again here.
	
epilog

end;</source>
