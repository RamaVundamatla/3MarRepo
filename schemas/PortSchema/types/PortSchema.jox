    <JadeMethod name="contentStatusEnumToString" id="68a21c55-cb05-48fa-a090-1f74f323d067">
        <source>contentStatusEnumToString(_contentStatus : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2023	navpw1	Initial creation TFS: 56851

*/

begin
	if _contentStatus = TI_CONTENTS_STATUS_FCL then
		return "FCL";
	elseif _contentStatus = TI_CONTENTS_STATUS_LCL then
		return "LCL";
	elseif _contentStatus = TI_CONTENTS_STATUS_EMPTY then
		return "MT";
	elseif _contentStatus = TI_CONTENTS_STATUS_PRTLOAD then
		return "PLD";
	elseif _contentStatus = TI_CONTENTS_STATUS_PRTLOADLASH then
		return "PLL";
	elseif _contentStatus = TI_CONTENTS_STATUS_FULLLASHED then
		return "FLH";
	else
		return null;
	endif;
	
end;</source>
