    <JadeMethod name="colourTableRows" id="a3da04e0-8f4c-4542-9733-a74a7df3bc56">
        <source>colourTableRows(_table : CM_DataTable input);
/*

Purpose:				set default blue/white alternating row colours

Parameters:			

Return Value:		

Date					Who		Reason
06 December 2023		jlizm1	Initial creation TFS 61426 CUX FLP Screen Enhancements

*/
constants
	PaleBlueRow : Integer = 16772055;
	
vars
	rowIndex : Integer;
	backColour : Integer;

begin

	if _table = null or self.chkColourCells.value then
		return;
	endif;
	
	foreach rowIndex in 1 to _table.rows do
		if rowIndex &lt;= _table.fixedRows then
			continue;
		endif;
		if rowIndex mod 2 = 0 then
			backColour := PaleBlueRow;
		else
			backColour := self.colorRow1;
		endif;
		_table.accessRow(rowIndex).backColor := backColour;
	endforeach;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="confirmCargo" id="17e9c832-83e4-49c3-a8db-0bcc1914f90c">
        <updating/>
        <source>confirmCargo(_table : CM_DataTable input) updating;
/*
Purpose:			

Date		Who		Reason
01 March 2023	navab1	TFS CR 56806 TASK 56807
29 May 2024		jlika1	TFS 64049 CUX | UAT FLP - Retain previous location in Voyage Ops Live Checks
*/

vars
	stowageController : CMIF_StowageConfirmController;
	newTITxn 			: CM_TITransaction;
	confirmationLocn : CM_LocationsController;
	theReturn, height : Integer;
	addOnShip : Boolean;
	tiSet : CM_TISet;
	firstTI: CM_TrackedItem;
begin
	
	if self.myCurrentVoyage = null then
		return;
	endif;

	if _table = null then
		return;
	endif;

	confirmationLocn := self.cmbLocnConfirm.listObject.CM_LocationsController;
	
	
	if confirmationLocn = null then
		global.beep;
		app.msgBox(app.getErrorString(Please_select_locati_confir_ca),app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	endif;	
	
	create tiSet transient;
	self.getAllSelectedTIs(tiSet,false, _table);
	if tiSet.isEmpty then
		app.msgBox(app.getErrorString(Please_select_items_confirm),app.getErrorString(Problem),MsgBox_OK_Only);
		return;
	endif;

	
	theReturn :=  app.msgBox(app.getErrorString1(Confirm_cargo_location, confirmationLocn.getFullId()),app.getErrorString(Confirm_location),MsgBox_Yes_No);
	
	if theReturn = MsgBox_Return_No then
		return;
	endif;
	
	create stowageController transient;

	
	foreach firstTI in tiSet discreteLock do : outerloop
		
		stowageController.type := TRANS_TYPE_STOWAGE_CONFIRM;
		stowageController.dateTime := app.actualTimeAppServer;
		stowageController.noCharge := true;
		stowageController.userId := app.getMyUserCode;
		stowageController.myConfirmationLocation := confirmationLocn;
		stowageController.myVoyage	:= self.myCurrentVoyage;
		stowageController.myTerminal := self.myTerminal;
		stowageController.myTrackedItem := firstTI;
		stowageController.isLoad := true;
		stowageController.myTargetLocation := confirmationLocn;
		stowageController.isForVoyage := true;
		stowageController.transferType := self.getVoyJobTransferType();

		app.myPassport.warningsAcknowledged := true; 
		app.myPassport.setWarningsIgnored(true);
		
		while true do : innerloop
			app.myTrxCA.trxCreateStowageConfirmNoJob(stowageController, newTITxn, app.myPassport);	
			if not app.myPassport.trxCompletedOK then
				theReturn := app.showErrorWarningDialog(app.getErrorString(Confirm_location), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue innerloop;
				endif;
			endif;
			break outerloop;
		endwhile;
		
	endforeach;
	
	//update after modal form close
	if confirmationLocn &lt;&gt; null then
		self.setDefaultLocation(confirmationLocn);
	endif;
	
epilog
	delete tiSet;
	delete stowageController;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="8beddc1a-09e7-44a2-9f89-6fffc2026c1b">
        <updating/>
        <source>create() updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
*/

vars

begin
	self.permissionView	:= PmShpVoyageOpsLineView;
	self.permissionMaint := PmShipVoyageOpsLiveMaint;
	self.helpFileName := HelpFile_Voyage;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createNewCargo" id="ffd27a05-0875-4961-929f-2ef1da9eb52c">
        <source>createNewCargo();
/*
Purpose:			

Date		Who		Reason
01 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars

	lc : CM_LocationsController;
	theReturn, height : Integer;
	addOnShip : Boolean;
begin
	
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	if self.cmbSite.listIndex &lt;= 1  // no site selected
	or self.cmbSite.itemData[self.cmbSite.listIndex] =  TI_SITE_ONSHIP then
		lc := self.cmbLocnConfirm.listObject.CM_LocationsController;

		if lc = null then
			self.myCurrentVoyage.findLocationFromString(self.txtMoveLocation.text,true,lc);
		endif;
		
		if lc = null then
			app.msgBox(app.getErrorString(Pleas_selec_ship_locat_inclu_m),app.getErrorString(Confirm_location),MsgBox_OK_Only);
			return;
		endif;
		
		theReturn :=  app.msgBox(app.getErrorString(Create_cargo_Voyage),app.getErrorString(Confirm_location),MsgBox_Yes_No);
		
		if theReturn = MsgBox_Return_No then
			return;
		endif;
		
		addOnShip := true;
	else
		if self.cmbSite.itemData[self.cmbSite.listIndex] =  TI_SITE_ONSITE then
			self.myTerminal.findLocationFromString(self.txtMoveLocation.text,true,lc, height);
			
			if lc = null then
				app.msgBox(app.getErrorString1(LocationNotFoundForUpdate, self.txtMoveLocation.text ),app.getErrorString(Confirm_location),MsgBox_OK_Only);
				return;
			endif;

			theReturn :=  app.msgBox(app.getErrorString1(Create_cargo_Terminal,  self.txtMoveLocation.text),app.getErrorString(Confirm_location),MsgBox_Yes_No);
		
			if theReturn = MsgBox_Return_No then
				return;
			endif;
		endif;
	endif;
	
	
	
	if lc = null then
		global.beep;
		app.msgBox(app.getErrorString(Pleas_selec_locat_voyag_creat_),app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	endif;
	
	if addOnShip then
		self.myAssistant.showCargoAddFromOnship(self, true, 3, 160, null, null, null, null, self.myCurrentVoyage, false, lc); 
	else
		self.myAssistant.showCargoAddFromOnsite(self, true, 3, 160, null, null, null, null, self.myCurrentVoyage, false, lc); 
	endif;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAutoPlanQueue" id="6333b1c2-822c-41f9-ac38-d2d1ba37ca17">
        <updating/>
        <source>doAutoPlanQueue(_mode : Integer; _all : Boolean; _table : CM_DataTable) protected, updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
15 Apr 2024	jlika1	TFS 63722 CUX | FR - FLP - Discharged Container shows "Not in Queue"
27 Jun 2024	jlizm1	TFS 64880 Cargo loaded then unloaded doesn't queue for loading again
*/

vars
	tiArray	: CM_TIArray;
	str		: String;
	result	: Integer;
	ti		: CM_TrackedItem;
	table 	: CM_DataTable;
	obj 	: Object;
	params 	: CMIF_AutoplanParams;
	idx		: Integer;
	
begin
	table := _table;
	if table = null then 
		return;
	endif;
	if _mode &lt;&gt; PLANNING_MODE and _mode &lt;&gt; QUEUE_MODE then
		return;
	endif;
	
	create tiArray transient;
	create params transient;
	
	if _all then
		foreach idx in table.fixedRows + 1 to table.rows do
			ti := table.accessRow(idx).itemObject.CM_TrackedItem;
			if ti = null then
				continue;
			endif;
			
			if ti.isOnShip then // ### CUX BUG 57417 30MAR2023 NAVAB1
				if ti.hasBeenReleasedToShip() then // no loads
					continue;
				endif;
			 // ### CUX BUG 57417 30MAR2023 NAVAB1
			elseif ti.isOnSite then
				if ti.hasBeenReceivedFromShip() then
					continue;
				endif;
			endif;
			if ti.myPrimaryPlannedLocation = null then
				params.allTrackedItems.add(ti);
			endif;
		endforeach;
	else
		foreach obj in table.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) then
				ti := obj.CM_TrackedItem;
			
				if ti.hasBeenReleasedToShip() then
					if ti.isOnShip then
						continue;
					endif;
				else
					if ti.isOnSite
					and ti.hasBeenReceivedFromShip() 
					and ti.myPrimaryActualLocation &lt;&gt; null 
					and not ti.myPrimaryActualLocation.isCraneLaneController()then
						continue;
					endif;
				endif;
				
				if (_mode = PLANNING_MODE and ti.myPrimaryPlannedLocation = null)
				or (_mode = QUEUE_MODE and ti.myPrimaryQueuedLocation = null) then
					params.allTrackedItems.add(ti);
				endif;
			endif;
		endforeach;
	endif;

	params.moveMode := _mode;
	params.myTerminalArea := null;
	params.myJob := null;
	params.showWarningWhenNoPlan := true;	
	params.isVoyageOps := true;
		
	while true do
		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
		
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		break;
	endwhile;	
	
	if str.trimBlanks &lt;&gt; null  
	and app.myPassport.returnCode = ERR_NO_AUTOPLAN then
		if app.msgBox(str &amp; app.getErrorString(INFO_NO_AUTOPLAN),app.getErrorString(Autoplan_yard), MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		
		endif;
	endif;
epilog
	delete params;
	delete tiArray;
end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuCustPriority" id="fd558325-cedd-4469-b422-630a339bff9e">
        <source>doBuildMnuCustPriority();
/*
Purpose:			

Date		Who		Reason
08MAR2023	NAVAB1	CR 56806 TASK 56807 
01 Dec 2023	jlika1	TFS 61592 CUX | FLP Priority Quick Filters
*/

vars
	mnuChild,
	mnuMaster			: MenuItem;
	numberOfLanes,
	idx,numss 			: Integer;
	customerPriority	: CM_CustomerPriority;
	root 				: CM_Root;
begin
	
	root := app.myRoot;
	
	mnuMaster := self.mnuCustomerPriorityBtn;
	mnuMaster.visible := false; // do not show on main menu
	mnuMaster.enabled := true;
	mnuMaster.userObject := null;
	self.mnuCustomerPriorityAssign.visible := false;	
	
	numss := root.allCustomerPriorities.size;
	
	foreach idx in 1 to numss do
		mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;

	
	foreach customerPriority in root.allCustomerPriorities discreteLock do
		idx := idx+1;
		mnuChild := mnuMaster.getMenuItem(idx); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		mnuChild := mnuMaster.loadSubMenu(idx); // Clone menu
		if customerPriority.description.trimBlanks() &lt;&gt; null then
			mnuChild.caption := customerPriority.getDisplayDetails(false);
		else
			mnuChild.caption := customerPriority.code;
		endif;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.userObject := customerPriority;
	
	endforeach;
	

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doButtonContext" id="867e955e-f902-484d-b4a2-b244520daa19">
        <updating/>
        <source>doButtonContext(cntrl: Button input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
*/

vars
	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_Object;
	loadTo  : CM_LocationsController;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.mnuCustomerPriorityBtn.userObject := cntrl;	
	

	self.popupMenu(self.mnuCustomerPriorityBtn, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <Parameter name="cntrl" type="Button" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCargoChecks" id="9dfecb05-48cf-4903-bc1b-405c09b8614f">
        <updating/>
        <source>doCargoChecks(_table : CM_DataTable input) updating;
/*
Purpose:			

Date				Who		Reason
01 March 2023		navab1	TFS CR 56806 TASK 56807
31 Jan 2024			jlika1	TFS 62154 62155 CUX | Photo Checks for Foreman Live - I just change the context but not the whole logic.
01 February 2024	jlizmq	TFS 62142 Perform checks from voyage ops live
29 May 2024			jlika1	TFS 64049 CUX | UAT FLP - Retain previous location in Voyage Ops Live Checks
04 June 2024		jlizm1	TFS 64317 Voyage Ops Live location issues
*/

vars
	stowageController 	: CMIF_StowageConfirmController;
	newTITxn 			: CM_TITransaction;
	confirmationLocn 	: CM_LocationsController;
	theReturn, 
	height 				: Integer;
	addOnShip 			: Boolean;
	tiSet 				: CM_TISet;
	firstTI				: CM_TrackedItem;
	cargoCheckForm 		: CMUI_CargoChecksForm;
	realGTEEntity		: CMGTE_Receival;
	ti 					: CM_TrackedItem;
	trailer 			: CM_TrackedItem;
	mode 				: Integer;
	canDoChecks			: Boolean;
	isRORO				: Boolean;
	isLOLO				: Boolean;
	
begin
	if _table = null then
		return;
	endif;

	if self.myCurrentVoyage = null then
		return;
	endif;

	create tiSet transient;
	self.getAllSelectedTIs(tiSet,false, _table);
	if tiSet.isEmpty or tiSet.size &gt; 1 then
		app.msgBox(app.getErrorString(Please_select_only_cargo_item), app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	endif;

	mode := CARGO_CHECK_CONTEXT_VOYOP_DISC; // DEFAULT
	ti := tiSet.first;
	
	if ti.isOnSite()
	and ti.hasBeenReceivedFromShip() then
		mode := CARGO_CHECK_CONTEXT_VOYOP_DISC;
	elseif ti.isOnShip() 
	and not ti.hasBeenReleasedToShip() 	then
		mode := CARGO_CHECK_CONTEXT_VOYOP_DISC;
	elseif ti.isOnSite()
	and not ti.hasBeenReleasedToShip() then
		mode := CARGO_CHECK_CONTEXT_VOYOP_LOAD;
	elseif ti.isOnShip() 
	and ti.hasBeenReleasedToShip() 	then
		mode := CARGO_CHECK_CONTEXT_VOYOP_LOAD;
	endif;
	
	isRORO := self.myCurrentVoyage.myROROStructure &lt;&gt; null or self.myCurrentVoyage.isHOLDSorSHIP;
	isLOLO := self.myCurrentVoyage.myCellularVoyageStructure &lt;&gt; null;
	
	if ti.isExport then
		canDoChecks := false;
		if ti.isOnTrailer then
			trailer := ti.getCurrentTrailer();
		endif;
		
		if isRORO then
			if trailer &lt;&gt; null then
				canDoChecks := trailer.myPrimaryActualLocation = self.myCurrentVoyage.myShipBlockStack;
			else
				canDoChecks := ti.myPrimaryActualLocation = self.myCurrentVoyage.myShipBlockStack;
			endif;
			
			if not canDoChecks then
				app.msgBox(app.getErrorString(Cannot_check_until_ship_block), app.getErrorString(Problem), MsgBox_OK_Only);
				return;
			endif;
			
		elseif isLOLO then
			if trailer &lt;&gt; null then
				canDoChecks := trailer.myTerminalArea &lt;&gt; null and trailer.myTerminalArea.isKindOf(CM_CraneTransferArea);
			else
				canDoChecks := ti.myTerminalArea &lt;&gt; null and ti.myTerminalArea.isKindOf(CM_CraneTransferArea);
			endif;
			
			if not canDoChecks then
				app.msgBox(app.getErrorString(Cannot_check_until_crane_trans), app.getErrorString(Problem), MsgBox_OK_Only);
				return;
			endif;
		endif;
	endif;
	
	if not self.myTerminal.hasNoCargoCheckItemsFor(mode) then
		create cargoCheckForm transient;
		//set  cargo checks default location
		if self.myDefaultLocation &lt;&gt; null 
			and ((isRORO and (ti.isImport or ti.isExport))
			or  (isLOLO and ti.isImport)) then
			
			cargoCheckForm.setDefaultLocation(self.myDefaultLocation);
		else
			cargoCheckForm.setDefaultLocation(null);
		endif;
		
		cargoCheckForm.myTerminal := self.myTerminal;
		cargoCheckForm.setBaseDetails(ti,null,mode);
		cargoCheckForm.setVoyageDetails(self.myCurrentVoyage, self.getVoyJobTransferType);
		cargoCheckForm.setParentForm(self);
		cargoCheckForm.showModal;
		
		//update after modal form close
		self.setDefaultLocation(cargoCheckForm.myDefaultLocation);
	endif;

epilog
	delete cargoCheckForm;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeselectAll" id="eeee8452-8cdd-4b7f-a7a6-a0ce121e93fb">
        <source>doDeselectAll();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 November 2023
TFS#		: 61494
Function	:

*** Changes ***
Date			Name		TFS#		Description

***************************************************
08 Feb 2024 jlier1 TFS 62363
*/

begin
	self.tblAllCargoTop.allSelectedObjects.clear;
	self.tblHazardousTop.allSelectedObjects.clear;
	self.tblMAFITop.allSelectedObjects.clear;
	self.tblBookingTop.allSelectedObjects.clear;
	self.tblReefersTop.allSelectedObjects.clear;
	self.tblTrailersTop.allSelectedObjects.clear;
	
	self.doSheetCaption(self.shtAllCargo, self.tblAllCargoTop);
	self.doSheetCaption(self.shtHazardous, self.tblHazardousTop);
	self.doSheetCaption(self.shtMAFI, self.tblMAFITop);
	self.doSheetCaption(self.shtBookingList, self.tblBookingTop);
	self.doSheetCaption(self.shtReefers, self.tblReefersTop);
	self.doSheetCaption(self.shtTrailers, self.tblTrailersTop);
	
	self.tblAllCargoTop.clearAllSelected;
	self.tblHazardousTop.clearAllSelected;
	self.tblMAFITop.clearAllSelected;
	self.tblBookingTop.clearAllSelected;
	self.tblReefersTop.clearAllSelected;
	self.tblTrailersTop.clearAllSelected;

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="63fe6d77-57a7-4670-8151-258c8ac9564d">
        <updating/>
        <source>doQuery(_clearFilters : Boolean) updating;
/*
Purpose:			

Date		Who		Reason
27 Feb 2023	navab1	TFS CR 56806 TASK 56807
22 Nov 2023	jlika1	TFS 61494 CUX | CUX | FLP Enable Filter Functionality
06 Dec 2023	jlizm1	TFS 61426 CUX FLP Screen Enhancements
17JAN20 	navra1	CR 62045/Task 62049 - UI - Export Container Confirmation Location
08 Feb 2024 jlier1 TFS 62363
19 Mar 2024	jlizm1	TFS 62763 moved code to addCargoToCollection for consistent behaviour
*/

vars
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	str : String;
	rowIdx : Integer;
begin
	self.clearFilters(_clearFilters);

	self.tblAllCargoBottom.rows := self.tblAllCargoBottom.fixedRows;
	self.tblAllCargoTop.rows := self.tblAllCargoTop.fixedRows;
	self.tblHazardousBottom.rows := self.tblHazardousBottom.fixedRows;
	self.tblHazardousTop.rows := self.tblHazardousTop.fixedRows;
	self.tblMAFIBottom.rows := self.tblMAFIBottom.fixedRows;
	self.tblMAFITop.rows := self.tblMAFITop.fixedRows;
	self.tblBookingBottom.rows := self.tblBookingBottom.fixedRows;
	self.tblBookingTop.rows := self.tblBookingTop.fixedRows;
	self.tblReefersBottom.rows := self.tblReefersBottom.fixedRows;
	self.tblReefersTop.rows := self.tblReefersTop.fixedRows;
	self.tblTrailersBottom.rows := self.tblTrailersBottom.fixedRows;
	self.tblTrailersTop.rows := self.tblTrailersTop.fixedRows;

	if self.myCurrentVoyage = null then
		return;
	endif;

	self.lblVoyageStatus.caption := self.myCurrentVoyage.statusDescription;
	
	voyage := self.myCurrentVoyage;
	
	// ### Add to collections
	foreach ti in voyage.allNotifiedTIsByCargoTypeId discreteLock do
		self.addCargoToCollection(ti,false);
	endforeach;
	
	foreach ti in voyage.allOnshipTIsByCargoTypeId discreteLock do
		self.addCargoToCollection(ti,true);
		
	endforeach;
	
	foreach ti in voyage.allOnsiteTIsByCargoTypeId discreteLock do
		self.addCargoToCollection(ti,true);
	
	endforeach;
	
	// ### Add to tables
	
	// Booking List is all cargo where ever it is
	foreach ti in self.allCargoBooked discreteLock do
		self.addCargoToTable(ti, self.tblBookingTop, self.shtBookingList);
	endforeach;

	foreach ti in self.allHazardous discreteLock do
		self.addCargoToTable(ti, self.tblHazardousTop, self.shtHazardous);
	endforeach;
	foreach ti in self.allMAFI discreteLock do
		self.addCargoToTable(ti, self.tblMAFITop, self.shtMAFI);
	endforeach;
	foreach ti in self.allCargoToBeWorked discreteLock do											
		self.addCargoToTable(ti, self.tblAllCargoTop, self.shtAllCargo);
	endforeach;
	foreach ti in self.allReefers discreteLock do
		self.addCargoToTable(ti, self.tblReefersTop, self.shtReefers);
	endforeach;
	foreach ti in self.allTrailer discreteLock do
		self.addCargoToTable(ti, self.tblTrailersTop, self.shtTrailers);
	endforeach;
	
	self.doSheetCaptions();
	
	self.colourTableRows(self.tblBookingTop);
	self.colourTableRows(self.tblHazardousTop);
	self.colourTableRows(self.tblMAFITop);
	self.colourTableRows(self.tblAllCargoTop);
	self.colourTableRows(self.tblReefersTop);
	self.colourTableRows(self.tblTrailersTop);
	
	self.picFiltered.visible := self.hasFilters();

epilog

end;</source>
        <Parameter name="_clearFilters" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryColourUp" id="09f29b04-c958-4cf6-86c2-2e7d27a93964">
        <source>doQueryColourUp(_table : CM_DataTable input;_theTI : CM_TrackedItem;_theRow : Integer);
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
29MAR2023	NAVMK20	Task 57224: Jade - New MAFI Columns
04 Jul 2024	jlier1  TFS 65046 - moved from doQueryColourUps so coloring RT column would work from notes 
*/

constants
	PaleBlueRow : Integer = 16772055;
	PaleRedRow : Integer = 15522303;
	PaleGreenRow : Integer = 12058551;

vars
	thePort : CM_Port;
	theColour, theColumn : Integer;
	theCommodity : CM_Commodity;
	theCommodityGrp : CM_CommodityGroup;
	theISOType : CM_ISOType;
	theConsignee : CM_ConsigneeConsignor;
	theConsignor : CM_ConsigneeConsignor;
	theTrain : CM_Train;
	theImexStatus : CM_IMEXStatus;
	theCell : JadeTableCell;
	drwAtt : CM_DrawingAttribute;	
	cs : CM_ContentsStatus;
	ts : CM_TransitStatus;
	ct : CM_CargoType;
	ig : CM_ISOTypeGroup;
	defaultColour : Integer;
	carrier: CM_Carrier;
	
begin
	if _theRow mod 2 = 0 then
		defaultColour := PaleBlueRow;
	else
		defaultColour := self.colorRow1;
	endif;
	
	theColumn := _table.getColumnByRowName(ETRow_RadioTelemetry);
	if theColumn &gt; 0 then
		self.displayWLEsShowRT(_table, _theRow, theColumn);
	endif;
	
	
	// Colour up the rest of the columns only if the "Colour Tables" option is ticked
	if not self.chkColourCells.value then
		return;
	endif;
	
	// COLOUR UP THE ISO Type
	theColumn := _table.getColumnByRowName(ETRow_IsoType);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isKindOf(CM_Container) then 
			theISOType := _theTI.CM_Container.getISOTypeObject();
			if theISOType &lt;&gt; null then
				theColour := theISOType.colour;
			endif;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE ISO Type Description
	theColumn := _table.getColumnByRowName(ETRow_IsoTypeDesc);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isKindOf(CM_Container) then 
			theISOType := _theTI.CM_Container.getISOTypeObject();
			if theISOType &lt;&gt; null then
				theColour := theISOType.colour;
			endif;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Ready To Ship
	theColumn := _table.getColumnByRowName(ETRow_ReadyToShip);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.readyToShip then
			theColour := Green;
		else
			theColour := Red;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Is Special Stow
	theColumn := _table.getColumnByRowName(ETRow_IsSpecialStow);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isSpecialStow then
			theColour := Red;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	theColumn := _table.getColumnByRowName(ETRow_SpecialStowCode);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isSpecialStow then
			theColour := Red;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE ISO Group
	theColumn := _table.getColumnByRowName(ETRow_IsoTypeGroupDesc);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		ig := app.myRoot.allISOTypeGroups[_theTI.isoTypeGroup];
		if ig &lt;&gt; null then
			theColour := ig.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Cargo Type
	theColumn := _table.getColumnByRowName(ETRow_CargoType);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		ct := app.myRoot.allCargoTypesById[_theTI.cargoType];
		if ct &lt;&gt; null then
			theColour := ct.colour;
			if theColour = 0 then // not set?
				if ct.myDrawingAttribute &lt;&gt; null then
					theColour := ct.myDrawingAttribute.colour;					
				endif;
			endif;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Contents Status
	theColumn := _table.getColumnByRowName(ETRow_ContentsStatus);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		cs := app.myRoot.allContentsStatuses[_theTI.getContentsStatus()];
		if cs &lt;&gt; null then
			theColour := cs.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Transit Status
	theColumn := _table.getColumnByRowName(ETRow_TransitStatus);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		ts := app.myRoot.allTransitStatuses[_theTI.getTransitStatus()];
		if ts &lt;&gt; null then
			theColour := ts.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Operator
	theColumn := _table.getColumnByRowName(ETRow_OperatorCode);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.myOperator &lt;&gt; null then
			theColour := _theTI.myOperator.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Discharge Port
	theColumn := _table.getColumnByRowName(ETRow_DischargePort);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		thePort := app.myRoot.allPorts[_theTI.dischargePort];
		if thePort &lt;&gt; null then
			theColour := thePort.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Load Port
	theColumn := _table.getColumnByRowName(ETRow_LoadPort);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		thePort := app.myRoot.allPorts[_theTI.loadPort];
		if thePort &lt;&gt; null then
			theColour := thePort.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Commodity
	theColumn := _table.getColumnByRowName(ETRow_Commodity);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theCommodity := app.myRoot.allCommodities[_theTI.commodity];
		if theCommodity &lt;&gt; null then
			theColour := theCommodity.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Commodity Group
	theColumn := _table.getColumnByRowName(ETRow_CommodityGroup);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theCommodityGrp := app.myRoot.allCommodityGroups[_theTI.commodityGroup];
		if theCommodityGrp &lt;&gt; null then
			theColour := theCommodityGrp.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Voyage
	theColumn := _table.getColumnByRowName(ETRow_VoyageCode);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.myVoyage &lt;&gt; null then
			theColour := _theTI.myVoyage.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;

	// COLOUR UP THE Custom Export Delivery Number
	theColumn := _table.getColumnByRowName(ETRow_CustomExportEntryNumber);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theCell := _table.accessCell(_theRow, theColumn);
		if theCell.text = null then
			theColour := Red;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;

	// COLOUR UP THE Custom Export Hold
	theColumn := _table.getColumnByRowName(ETRow_CustomExportStop);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theCell := _table.accessCell(_theRow, theColumn);
		if theCell.text &lt;&gt; null then
			drwAtt := app.myRoot.allDrawingAttributes[PicTICustomHold];
			if drwAtt &lt;&gt; null then
				theCell.foreColor := drwAtt.colour;
				theCell.text := drwAtt.fontCharacter.Character;	
				theCell.fontName := drwAtt.fontName;
			endif;								
		endif;			
	endif;	
	
	// COLOUR UP THE Tranship Discharge Port
	theColumn := _table.getColumnByRowName(ETRow_TranshipDischargePort);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		thePort := null;
		if _theTI.myTranshipDetail &lt;&gt; null and _theTI.myTranshipDetail.myDischargePort &lt;&gt; null then	
			thePort := app.myRoot.allPorts[_theTI.myTranshipDetail.myDischargePort.code];
		endif;
		if thePort &lt;&gt; null then
			theColour := thePort.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Tranship Voyage
	theColumn := _table.getColumnByRowName(ETRow_TranshipExportVoyage);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isTranshipItem and _theTI.myExportVoyage &lt;&gt; null then
			theColour := _theTI.myExportVoyage.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Location Area
	theColumn := _table.getColumnByRowName(ETRow_LocationArea);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isOnSite 
		and _theTI.myPrimaryActualLocation &lt;&gt; null
		and _theTI.myPrimaryActualLocation.myTerminalArea &lt;&gt; null 
		and	_theTI.myPrimaryActualLocation.myTerminalArea.myLayoutGraphic &lt;&gt; null then		
			theColour := _theTI.myPrimaryActualLocation.myTerminalArea.myLayoutGraphic.drawLineColour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Terminal Area
	theColumn := _table.getColumnByRowName(ETRow_TerminalAreaId);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.isOnSite 
		and _theTI.myPrimaryActualLocation &lt;&gt; null
		and _theTI.myPrimaryActualLocation.myTerminalArea &lt;&gt; null 
		and	_theTI.myPrimaryActualLocation.myTerminalArea.myLayoutGraphic &lt;&gt; null then		
			theColour := _theTI.myPrimaryActualLocation.myTerminalArea.myLayoutGraphic.drawLineColour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Consignee
	theColumn := _table.getColumnByRowName(ETRow_Consignee);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theConsignee := app.myRoot.allConsigneeConsignors[_theTI.consignee];
		if theConsignee &lt;&gt; null then 
			theColour := theConsignee.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Consignor
	theColumn := _table.getColumnByRowName(ETRow_Consignor);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theConsignor := app.myRoot.allConsigneeConsignors[_theTI.consignor];
		if theConsignor &lt;&gt; null then
			theColour := theConsignor.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Assigned Train
	theColumn := _table.getColumnByRowName(ETRow_MyAssignedTrain);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		if _theTI.myTrainAssigned &lt;&gt; null then
			theColour := _theTI.myTrainAssigned.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Actual Train
	theColumn := _table.getColumnByRowName(ETRow_Train);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theTrain := _theTI.getTrainActual;
		if theTrain &lt;&gt; null then
			theColour := theTrain.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	
	// COLOUR UP THE Imex Status
	theColumn := _table.getColumnByRowName(ETRow_ImexStatusString);
	if theColumn &gt; 0 then
		theColour := defaultColour;
		theImexStatus := _theTI.getImExStatusObject;
		if theImexStatus &lt;&gt; null then
			theColour := theImexStatus.colour;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;

	// COLOUR UP THE carrier	
	theColumn := _table.getColumnByRowName(ETRow_Carrier);
	if theColumn &gt; 0 then
		carrier := app.myRoot.allCarriers[_theTI.carrier];
		if carrier &lt;&gt; null then
			theColour := carrier.colour;
		else
			theColour := White;
		endif;
		_table.accessCell(_theRow, theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	theColumn := _table.getColumnByRowName(ETRow_ReleaseCarrier);
	if theColumn &gt; 0 then
		carrier := app.myRoot.allCarriers[_theTI.releaseCarrier];
		if carrier &lt;&gt; null then
			theColour := carrier.colour;
		else
			theColour := White;
		endif;
		_table.accessCell(_theRow,theColumn).backColor := theColour;
		_table.accessedCell.foreColor := theColour.getInverseColour();
	endif;
	// Start 29.3.2023 navmk20 TFS 57224
	theColumn := _table.getColumnByRowName(ETRow_ObHaz);
	if theColumn &gt; 0 then
		theColour := LightYellow;
		theCell := _table.accessCell(_theRow, theColumn);
		if theCell.text &lt;&gt; null then
			theCell.backColor := theColour;
			theCell.foreColor := theColour.getInverseColour();
		else
			theCell.backColor := White;
			theCell.foreColor := Black;
		endif;
	endif;
	
	theColumn := _table.getColumnByRowName(ETRow_ObHazDetails);
	if theColumn &gt; 0 then
		theColour := LightYellow;
		theCell := _table.accessCell(_theRow, theColumn);
		if theCell.text &lt;&gt; null then
			theCell.backColor := theColour;
			theCell.foreColor := theColour.getInverseColour();
		else
			theCell.backColor := White;
			theCell.foreColor := Black;
		endif;
	endif;

	theColumn := _table.getColumnByRowName(ETRow_ObReefer);
	if theColumn &gt; 0 then
		theColour := PaleBlueRow;
		theCell := _table.accessCell(_theRow, theColumn);
		if theCell.text &lt;&gt; null then
			theCell.backColor := theColour;
			theCell.foreColor := theColour.getInverseColour();
		else
			theCell.backColor := White;
			theCell.foreColor := Black;
		endif;
	endif;
	
	theColumn := _table.getColumnByRowName(ETRow_ObStops);
	if theColumn &gt; 0 then
		theColour := LightRed;
		theCell := _table.accessCell(_theRow, theColumn);
		if theCell.text &lt;&gt; null then
			theCell.backColor := theColour;
			theCell.foreColor := theColour.getInverseColour();
		else
			theCell.backColor := White;
			theCell.foreColor := Black;
		endif;
	endif;
	
	theColumn := _table.getColumnByRowName(ETRow_ObStopTypes);
	if theColumn &gt; 0 then
		theColour := LightRed;
		theCell := _table.accessCell(_theRow, theColumn);
		if theCell.text &lt;&gt; null then
			theCell.backColor := theColour;
			theCell.foreColor := theColour.getInverseColour();
		else
			theCell.backColor := White;
			theCell.foreColor := Black;
		endif;
	endif;
	
	theColumn := _table.getColumnByRowName(ETRow_ObDamage);
	if theColumn &gt; 0 then
		theColour := Black;
		theCell := _table.accessCell(_theRow, theColumn);
		if theCell.text &lt;&gt; null then
			theCell.backColor := theColour;
			theCell.foreColor := theColour.getInverseColour();
		else
			theCell.backColor := White;
			theCell.foreColor := Black;
		endif;
	endif;
	// End 29.3.2023 navmk20 TFS 57224
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theRow" type="Integer"/>
