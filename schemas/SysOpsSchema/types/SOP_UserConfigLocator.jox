        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2014	cnwndl1	Initial creation

*/

vars

begin

	if self.shtBaseCode.visible then
		app.cnEcFinalizeBaseSchema();
	endif;
	
	inheritMethod();

epilog

end;</source>
