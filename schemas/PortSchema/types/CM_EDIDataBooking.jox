    <JadeMethod name="canBeDBLoaded" id="879bb0e6-676b-4005-b49b-9845eb3ba72d">
        <source>canBeDBLoaded(): Boolean;
/*
Date		Who		Reason
01 August 2012	cnwcs5	Initial creation - par 
*/
vars
	result 	:Boolean;
begin
	result := inheritMethod();
	
	if not result then
		result := self.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS and self.getMyTerminal.getConfig (EdiBookingAllowPartial).Boolean;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBePartiallyLoaded" id="72d3f703-014a-4dd8-a6cc-43b081631654">
        <source>canBePartiallyLoaded(): Boolean protected;
/*
Date		Who		Reason
16 Aug 2012	cnwcs5	Initial creation - par 30136
11 Oct 2012	cnwrs1	Change to use EdiBookingAllowPartial not EdiReleaseAllowPartial
// 13 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars

begin
	return self.getMyTerminal.getConfig(EdiBookingAllowPartial).Boolean;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeReprocessedByBGP" id="d6cb1e6e-830f-4431-b95f-2e2138475484">
        <source>canBeReprocessedByBGP(): Boolean;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
//18 Sep 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
//13 May 2015	cnwrs1	Par 36099 - never reprocess a delete EDI booking ref
*/
vars
	result		:Boolean;
	status		:Integer;
	purgeDate	:Date;
	createTS	:TimeStamp;
begin
	result := inheritMethod();
	
	if not result then
		status := self.status;
		
		if status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
			status = CM_EDIFile.EDI_STATUS_VERIFIED or 
	        status = CM_EDIFile.EDI_STATUS_LOCKERROR or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			
			if self.canBePartiallyLoaded then	
				result := true;
			endif;
		endif;
	endif;
	
	if result then
		if self.getEDIAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
			result := false;
		endif;
	endif;
	if result then
		// we may have passed the expiry for unprocessed files in which case we should not re-process it after all
	//	purgeDate 	:= self.getUnprocessedExpiryDate (EDIBookingUnprocPurgePeriod);
		purgeDate 	:= self.getUnprocessedExpiryDate (EDIUnprocBookExpiry);	//26 Sep 2014	NDL	Par 34955
		createTS 	:= self.createdTime;
			
		if createTS.date &lt; purgeDate then
			// we are expired - we don't want to re-process
			app.writeLog ('Booking EDI expired ' &amp; self.displayName &amp; ' created ' &amp; createTS.String &amp; ' purge date ' &amp; purgeDate.String, LogDEBUG);
			result := false;
		endif;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canGetStatusFromEDITrackedItem" id="d414e253-b9f5-4d4b-bdaa-2f1d352de5a8">
