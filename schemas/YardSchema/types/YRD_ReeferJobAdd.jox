    <JadeMethod name="buildReeferQuery" id="7fe53c26-ad46-4d5d-8b1a-dbb874cf5701">
        <source>buildReeferQuery( _userQuery : CM_MenuUserQuery io; _criteriaLineHolder : CM_QueryCriteriaLineHolder io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2020	jlgndl1	Initial creation 	TFS 49581
*/

vars

	transQueryLine 	: CM_SelectorCriteriaLine;
	transProperty 	: CM_QueryProperty;
	transOperator 	: CM_QueryOperator;
	term 			: CM_Terminal;
	
begin

	_userQuery.setPropertyValue( "queryMode", 0);
	
	//	Add Site criteria line
	create transQueryLine transient; 
	transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
	
	create transProperty as CM_QTiSiteLookupProperty transient;
	transProperty.set(	"Site",						//_niceName : String
						CM_TrackedItem::site.name,	//_propName : String
						"CM_TrackedItem"			//_className : String
						);
	transProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
	
	create transOperator as CM_QIntegerLookupEqual transient;
	transOperator.setSearchValue( TI_SITE_ONSITE );
	
	transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
										transProperty,	//_myQueryProperty : CM_QueryProperty;
										transOperator,	//_myQueryOperator : CM_QueryOperator;
										transProperty.propertyName,	//_propName : String;
										transProperty.propertyClassName	//_propClassName : String
										);											
	
	//	Add Terminal criteria line
	term := self.getMyTerminal;
	if term &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QRefTerminalProperty transient;
		transProperty.set(	"Terminal",	//_niceName : String
							"myTerminal",	//_propName : String
							"CM_TrackedItem"	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QReferenceLookup transient;
		transOperator.setSearchValue( term );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	//	Add is Reefer criteria line
	create transQueryLine transient; 
	transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
	
	create transProperty as CM_QBooleanProperty transient;
	transProperty.set(	"Is Reefer",	//_niceName : String
						CM_TrackedItem::isReefer.name,	//_propName : String
						"CM_TrackedItem"	//_className : String
						);
	transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
	
	create transOperator as CM_QueryBooleanOperator transient;
	transOperator.setSearchValue( true );
	
	transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
										transProperty,	//_myQueryProperty : CM_QueryProperty;
										transOperator,	//_myQueryOperator : CM_QueryOperator;
										transProperty.propertyName,	//_propName : String;
										transProperty.propertyClassName	//_propClassName : String
										);
	
epilog
	
end;</source>
        <Parameter name="_userQuery" type="CM_MenuUserQuery" usage="io"/>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
    </JadeMethod>
    <JadeMethod name="clearSelection" id="2fd2d2a8-0870-4fea-88d9-adf8fe210d73">
        <source>clearSelection();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

begin

	self.allDisplayedReefers.clear();
	self.tblReefers.rows := 1;
	
	self.txtById.text := null;
	self.cmbVoyage.listIndex := -1;
	self.cmbVoyageJob.listIndex := -1;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clickCmbVoyage" id="450dcced-9fed-4323-ad9e-fcfdeb0c62a3">
        <source>clickCmbVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	voyage : CM_Voyage;
	job : CM_Job;
	index : Integer;

begin

	self.cmbVoyageJob.clear();

	voyage := cmbVoyage.listObject.CM_Voyage;
	if voyage = null then
		return;
	endif;
	
	foreach job in voyage.allVoyageJobs do
		index := self.cmbVoyageJob.addItem( job.CM_VoyageJob.jobTypeId &amp; " - " &amp; job.CM_VoyageJob.jobId );
		self.cmbVoyageJob.itemObject[index] := job;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clickCreateJobs" id="3ea95408-3ebe-4038-bf10-acf00b52529f">
        <source>clickCreateJobs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jul 2020	jlgndl1	Initial creation	TFS 49581
17 Dec 2020	jlgdap1	TFS 50508 MTN Reefer App - Job List
*/

vars

	allSelected : CM_TISet;
	ti : CM_TrackedItem;
	rowIndex : Integer;
	jobType : Integer;
	localActionTime : TimeStamp;
	actionTime : TimeStamp;
	theReturn : Integer;
	columnIndex : Integer;

begin

	jobType := CM_YardActivity@getTypeFromString( self.cmbJobType.text );
	localActionTime.setDate( self.txtDate.getDate );
	localActionTime.setTime( self.txtTime.getTime );
	
	actionTime := self.myTerminal.localToSystemTime( localActionTime );

	columnIndex := self.tblReefers.getColumnByRowName( ETRow_Selected );
	create allSelected transient;
	
	foreach rowIndex in 1 to self.tblReefers.rows do
		ti := self.tblReefers.accessRow( rowIndex ).itemObject.CM_TrackedItem;
		if ti = null then
			continue;
		endif;
		if self.tblReefers.accessCell( rowIndex, columnIndex ).text = "1" then
			allSelected.addNoDuplicates( ti, false );
		endif;
	endforeach;
	
	while true do
		app.myTrxCA.trxCreateYardActivity( allSelected, jobType, actionTime, app.myPassport );
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog( app.getErrorString(Create_reefer_jobs), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		return;
	endwhile;
	
	//self.clearSelection();			// TFS 50508
	self.cmbJobType.listIndex := -1;	// TFS 50508
	
epilog

	delete allSelected;

end;</source>
    </JadeMethod>
