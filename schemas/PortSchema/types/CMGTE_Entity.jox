    <JadeMethod name="validateMe" id="6955c186-2d6e-4378-b58a-ba87859027a5">
        <updating/>
        <source>validateMe(_passport: CM_Passport input; _pxyTIs : CM_ObjectByStringDict input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2025	jlier1	Initial creation MTN-34221

*/

vars
	pxyTI,pxyGen : CM_TrackedItem;
	pxy 	: CMGTE_Entity;
	totWeight : Decimal[14,4];
	tilc	: CM_TILC; //15/10/2025	navkc1 JIRA 36057
begin
	self.validateForCreate(_passport, pxyTI);
	pxy:=self;
	if pxyTI &lt;&gt; null then
		if not _pxyTIs.includes(pxyTI) then
			_pxyTIs[self.getStringDictKey] := pxyTI;	//30 Nov 2016	TFS 2999
		endif;
		
		if pxyTI.isKindOf(CM_TILC)  then
			tilc := pxyTI.CM_TILC; //15/10/2025	navkc1 JIRA 36057
			pxyGen := tilc.getGenerator;
			if pxyGen &lt;&gt; null and  not _pxyTIs.includes(pxyGen) then
				_pxyTIs[ pxyGen.id &amp; "/" &amp;  self.getStringDictKey] := pxyGen;	//30 Nov 2016	TFS 2999
			endif;
			
			//15/10/2025	navkc1 JIRA 36057
			// If the total weight is 0 and the trailer type can be updated
			// Default the total weight to Trailer Type Tare Weight + Cargo on board
			// Doing it here because CM_TILC does not have allChildren/allLC yet
			// Since we have the children here so we get the on board cargo weight here
			if tilc.canUpdateTotalWeight() and pxyTI.totalWeight = null then
				totWeight := self.getAllChildrenTotWeight() + pxyTI.getTareWeight();
				pxyTI.setTotalWeight(totWeight, null, _passport);
			endif;
			
		endif;
	endif;
	
	
	
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	foreach pxy in self.allChildren discreteLock do
		// ### DEFAULT FROM PARENT
		pxy.defaultDetailsFromParentItem(self);
		pxyTI:=null;
		pxy.validateForCreate(_passport, pxyTI);
		if pxyTI &lt;&gt; null then
			if not _pxyTIs.includes(pxyTI) then
				_pxyTIs[pxy.getStringDictKey] := pxyTI;	//30 Nov 2016	TFS 2999
			endif;
			
			if pxyTI.isKindOf(CM_TILC)  then
				tilc := pxyTI.CM_TILC; //15/10/2025	navkc1 JIRA 36057
				pxyGen := tilc.getGenerator;
				if pxyGen &lt;&gt; null and  not _pxyTIs.includes(pxyGen) then
					_pxyTIs[ pxyGen.id &amp; "/" &amp;  pxy.getStringDictKey] := pxyGen;	//30 Nov 2016	TFS 2999
				endif;
			endif;
		endif;
	endforeach;
	
epilog
	if _passport.hasErrors and pxyTI &lt;&gt; null  and pxy &lt;&gt; null and  not _pxyTIs.includes(pxyTI) then
		//if the line "pxyGate.validateForCreate(_passport, pxyTI);" fails we get left with a proxy
		// that is not in the collection, so isn't deleted.
		_pxyTIs[pxy.getStringDictKey] := pxyTI;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTIs" type="CM_ObjectByStringDict" usage="input"/>
    </JadeMethod>
</Class>
