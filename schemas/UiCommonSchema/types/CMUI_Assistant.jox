        <source>showLocationMaintenanceForm(_object : CM_Object; _masterMenuAction : CMUI_MenuAction; _mode :Integer;
					_thumbnailOnly, _doEdit : Boolean);
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
// 21/03/2011	cnwcs5	CCMS CPL 2017/PAR 27126
vars
	form 		: CM_TableViewForm;
	menuAction 	: CMUI_MenuAction;
begin
	if _object = null then
		return;
	endif;
	
	menuAction := app.myController.createMenuAction(PmAdmPadeditView, null, _masterMenuAction, self.myTerminal);
	
	if menuAction = null then
		return;
	endif;
	
	form := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
	
	if form = null then
		return;
	endif;

	if _object &lt;&gt; null then	
		form.sendMsgWithParams("setInitializeWithObject", _object, _mode,  null, false, false);
	endif;
	
	form.show;	
end;</source>
