    <JadeMethod name="getCurrentScrollingFrmValues" id="f585a1ab-6675-48a6-9ce6-f577f4ff7f10">
        <source>getCurrentScrollingFrmValues(_hScrollValue, _vScrollValue : Integer output; _width, _height : Real output);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numCol, numRow : Integer;
begin
	numCol := self.myTerminalArea.CM_GridArea.allGridColumns.size;
	numRow := self.myTerminalArea.CM_GridArea.allGridRows.size;
	
	self.myDockBar.getCurrentScrollingFrmValues(_hScrollValue, _vScrollValue, _width, _height);
	_width := (((self.ColumnWidth + 2) * self.scaleFactor) ) * numCol;
	_height := (((self.RowHeight +2)  * self.scaleFactor) * self.getHeightOfStack) * numRow;	// PAR 21532 CCMS SFW 1025

end;</source>
        <Parameter name="_hScrollValue" type="Integer" usage="output"/>
        <Parameter name="_vScrollValue" type="Integer" usage="output"/>
        <Parameter name="_width" type="Real" usage="output"/>
        <Parameter name="_height" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDeckingRowHeight" id="a09b81c7-db93-4ab5-b164-8c50e1d42f4e">
        <updating/>
        <source>getDeckingRowHeight(frame: CMUI_ScrollableLabelsFrame input)  updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 10;

	RowHeight		: Integer = 12;
	ColWidth		: Integer = 24;

vars
	tmpDrawingController	: YRD_ContainerDrawingController;
	maxX,
	maxY	: Integer;
	tmpTA	: CM_GridArea;
	tmpRow	: CM_GridRow;
	tmpCol	: CM_GridColumn;
	tmpLC	: CM_GridController;
	rowIdx, tmpRowIdx,
	colIdx,rowNum,colNum	: Integer;
	tmpX, tmpY,
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2,
	stackHght	: Integer;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;	//YRD_ContainerDrawingFrame;
	cellHeight, cellIdx, cellY1, cellY2 : Integer;
	
	frameButton, frameShift : Integer;
begin
	self.myCurrentDeckingRow := null;
	self.currentDeckingPosition := 0;
	
	tmpTA := self.myTerminalArea.CM_GridArea;
	if tmpTA = null then
		return;
	endif;
	
	frameButton := frame.origButton;
	
	if frameButton &lt;&gt; Window.MouseButton_Left then
		return ;
	endif;
	
	frameShift := frame.origShift;
	
	stackHght := self.getHeightOfStack;	// PAR 21532 CCMS SFW 1025
	colNum := tmpTA.allGridColumns.size;
	rowNum := tmpTA.allGridRows.size;
	theColWidth	 := (ColWidth * self.scaleFactor).Integer;
	theRowHeight := (RowHeight * stackHght * self.scaleFactor).Integer;
	cellHeight := (theRowHeight / stackHght).Integer;
	
	if frame = self.myHLabels then
/*
		yPos1 := self.LABELGAP;
		yPos2 := (rowNum * theRowHeight).Integer + self.LABELGAP + ((rowNum - 1) * RowSpacing).Integer;
		xPos2 := self.LABELGAP - 1;
		foreach colIdx in 1 to colNum do
			xPos1 :=  xPos2;
			xPos2 := xPos1 + theColWidth + self.columnSpacing;
			
			if frame.origX &gt;= xPos1 and frame.origX &lt;= xPos2 then
				tmpTA.allGridColumns[colIdx].inspect;
			endif;
			
		endforeach;
*/
	elseif frame = self.myVLabels then
		xPos1 := self.LABELGAP;
		xPos2 := (colNum * theColWidth).Integer + self.LABELGAP + ((colNum - 1) * self.columnSpacing).Integer;
		yPos2 := self.LABELGAP - 1;

		foreach rowIdx in 1 to rowNum do
			yPos1 :=  yPos2;
			yPos2 := yPos1 + theRowHeight + RowSpacing;
			
			if frame.origY &gt;= yPos1 and frame.origY &lt;= yPos2 then
			
				if self.flipVertically then
					tmpRowIdx := (rowNum - rowIdx) + 1;
					tmpRow := tmpTA.allGridRows[tmpRowIdx];
				else
					tmpRow := tmpTA.allGridRows[rowIdx];
				endif;
//					tmpRow.inspect;

				self.myCurrentDeckingRow := tmpRow;
				
				yPos2 := yPos2 - RowSpacing;
				cellY1 := yPos2;
				foreach cellIdx in 1 to stackHght do : cellLoop
					cellY2 := cellY1 - cellHeight;
					
					if frame.origY &gt;= cellY2 and frame.origY &lt;= cellY1 then
						break cellLoop;
					endif;
					cellY1 := cellY2;
				endforeach;
				if cellIdx &gt; stackHght then
//					write "* " &amp; tmpRow.label &amp; " Out Of Range";
				else

						self.currentDeckingPosition := cellIdx;
						
//					write "* " &amp; tmpRow.label &amp; " Height " &amp; cellIdx.String &amp; " stackHght: " &amp; stackHght.String;
				endif;			
				break;
			endif;
			
		endforeach;
	endif;
	
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
    </JadeMethod>
