    <JadeMethod name="populateBOL" id="b0ecb00b-a6c8-4f3f-864e-fbad4b5b7a26">
        <source>populateBOL();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Feb 2010	cnwndl1	Initial creation	CCMS MES 1005
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

	beginBOL : CM_BOL;
	voyage : CM_Voyage;
	iter : Iterator;
	bol : CM_BOL;
	index : Integer;

begin

	beginBOL := cmbBOL.listObject.CM_BOL;
	
	self.cmbBOL.clear();
	
	self.cmbBOL.addItem( self.lblBOL.caption );
	
	voyage := cmbVoyage.listObject.CM_Voyage;
	if voyage &lt;&gt; null then
		if not voyage.allBOLInByTypeStatusNumDT.isEmpty then
			iter := voyage.allBOLInByTypeStatusNumDT.createIterator;
			while iter.next( bol ) do
				index := cmbBOL.addItem( bol.number );
				cmbBOL.itemObject[index] := bol;
			endwhile;
		endif;
	endif;
	
	if beginBOL &lt;&gt; null then
		cmbBOL.listIndex := cmbBOL.findObject(beginBOL);
	endif;
	
	if cmbBOL.listIndex &lt; 1 then
		cmbBOL.listIndex := 1;
	endif;
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setActionButtons" id="fda1de44-62e1-45ce-b0d1-4939eaf0a5ba">
        <source>setActionButtons();

