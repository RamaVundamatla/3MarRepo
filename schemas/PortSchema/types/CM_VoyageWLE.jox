    <JadeMethod name="getTwinLiftWLE" id="a661d163-235f-4295-89b0-7ed0d35700b0">
        <source>getTwinLiftWLE(): CM_WorkListEntry;
//----------------------------------------------------------------
//	Created:	19 February 2004	by Jason Chapman  (cnwjc2)
//	Should return the load WLE for a SOB only.  self is the discharge wle

// cnwer1  2/5/09 			CCMS 1032 - doesn't take into account ships berthing direction of twinCustom sequencing
// cnwer1  21/10/11 	PAR 28431 - changes to the work order num caused this not to work changed to check aft &amp; fore
//----------------------------------------------------------------


vars
	ourJob		: CM_Job;
	wle			: CM_WorkListEntry;
	voyageWLE 	: CM_VoyageWLE;
	seqNumToUse,
	otherWLESeqNum: Integer;
	voyage : CM_Voyage;
begin
	if not self.isTwinLift then
		return null;
	endif;
	
	ourJob := self.job;	
	
	if ourJob = null then
		return null;
	endif;
	
	voyage:=self.getVoyage;
	if voyage = null then
		return null;
	endif;
	
	if voyage.starboardBerthed then
		seqNumToUse:=self.numSeqStarboardTwinCustom;
	else
		seqNumToUse:=self.numSeqPortTwinCustom;
	endif;
	
	foreach wle in ourJob.workListEntries do
		if wle = self then
			continue;
		endif;
		
		voyageWLE:=wle.CM_VoyageWLE;
		if voyage.starboardBerthed then
			otherWLESeqNum:=voyageWLE.numSeqStarboardTwinCustom;
		else	
			otherWLESeqNum:=voyageWLE.numSeqPortTwinCustom;
		endif;
		
		if otherWLESeqNum = seqNumToUse then
			//epr par 28431 21/10/11
			if voyageWLE.isAftBay &lt;&gt; self.isAftBay then
				return wle;
			endif;
		endif;
	endforeach;
	
	return null;

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="3b95c4c7-efe1-4ba4-9db1-031a604a6a27">
