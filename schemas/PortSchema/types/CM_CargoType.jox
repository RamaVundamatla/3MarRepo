    <JadeMethod name="getHandlingTypeDisplay" id="949bf0db-4c84-44da-8817-c67134235e13">
        <source>getHandlingTypeDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

