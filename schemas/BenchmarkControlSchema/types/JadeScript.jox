    <JadeMethod name="jhpShowFactors" id="b2bc81f9-47d4-40da-a8e8-668582c66408">
        <source>jhpShowFactors();

vars
	i,j,k,l,target:Integer;
	s,t,u:String;
	prime:Boolean;
begin
	write "";
	foreach i in 1001 to 9001 step 1000 do
		//write "target="&amp;i.String&amp;" sqrt="&amp;((i^0.5).Integer+1).String;
		prime:=true;
		s:="";
		foreach j in 2 to (i^0.5).Integer+1 do
			if i mod j = 0 then
				s:=s&amp;j.String&amp;" ";
				prime:=false;
			endif;
		endforeach;
		if s = "" then 
			//s:="&lt;PRIME&gt;"; write "target="&amp;i.String&amp;" factors="&amp;s;
			write i;
		endif;
	endforeach;
	
	/*foreach i in 69090 to 69400 do
		j:=i*1000000;
		write app.random31(j, 250000-1)+1;
	endforeach;/**/
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpShowQueues" id="1d75fd8a-e715-4a16-a19f-90dd60d92627">
        <source>jhpShowQueues();

vars
	ffBase,ff:FileFolder; fn:FileNode; f:File;
	totalQueued,i,j:Integer; qName,build,s:String;
	qBuildArray,totBuildArray:StringArray; qCountArray,totCountArray:IntegerArray; qTimeStampArray,totTimeStampArray:TimeStampArray;
begin
	create ffBase transient;
	ffBase.usePresentationFileSystem := false;
	ffBase.fileName := "T:\jblpcre\server\c_misc\jobs";
	create ff transient;
	ff.usePresentationFileSystem := ffBase.usePresentationFileSystem;
	create qBuildArray transient;
	create qCountArray transient;
	create qTimeStampArray transient;
	create totBuildArray transient;
	create totCountArray transient;
	create totTimeStampArray transient;
	
	write "";
	foreach fn in ffBase.files reversed where fn.isKindOf(FileFolder) do // and fn.name.contains("contops") do
		ff.fileName := fn.fileName &amp; "\creatorout";
		qName := fn.name;
		qBuildArray.clear;
		qCountArray.clear;
		qTimeStampArray.clear;
		foreach fn in ff.files where fn.isKindOf(File) do
			f := fn.File;
			s := f.readString(f.fileLength);
			i := s.pos("-fastbuildid=", 1) + 13;
			if i = 13 then continue; endif;
			build := s.scanUntil('",', i);
			if build = "jade7104010dailybuildvarUR64" and fn.name[1:15] = "bld_allcurrent_" then f.purge; continue; endif;  // DELETE a particular build
			j := qBuildArray.indexOf(build);
			if j = 0 then
				qBuildArray.add(build);
				qCountArray.add(1);
				qTimeStampArray.add(f.lastModifiedTime);
			else
				qCountArray[j] := qCountArray[j] + 1;
			endif;
		endforeach;
	
		if qBuildArray.size &gt; 0 then
			write qName;
			foreach i in 1 to qBuildArray.size do
				write Tab &amp; qBuildArray[i] &amp; Tab &amp; qCountArray[i].String &amp; Tab &amp; qTimeStampArray[i].String;
				totalQueued := totalQueued + qCountArray[i];
				j := totBuildArray.indexOf(qBuildArray[i]);
				if j = 0 then
					totBuildArray.add(qBuildArray[i]);
					totCountArray.add(qCountArray[i]);
					totTimeStampArray.add(qTimeStampArray[i]);
				else
					totCountArray[j] := totCountArray[j] + qCountArray[i];
				endif;
			endforeach;
		endif;
	endforeach;
	
	write "Totals by build";
	foreach i in 1 to totBuildArray.size do
		write Tab &amp; totBuildArray[i] &amp; Tab &amp; totCountArray[i].String &amp; Tab &amp; totTimeStampArray[i].String;
	endforeach;
	write "totalQueued=" &amp; totalQueued.String &amp; Tab &amp; "at " &amp; app.actualTime.String;
epilog
	delete ffBase;
	delete ff;
	delete qBuildArray;
	delete qCountArray;
	delete qTimeStampArray;
	delete totBuildArray;
	delete totCountArray;
	delete totTimeStampArray;
end;
</source>
    </JadeMethod>
