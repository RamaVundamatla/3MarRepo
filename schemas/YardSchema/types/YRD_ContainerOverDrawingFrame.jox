    <JadeMethod name="getGrabberPoint" id="8b1615d8-e456-4da0-bdf8-652e3be9d4ba">
        <updating/>
        <source>getGrabberPoint(_xIn,_yIn : Integer;_x1,_y1,_x2,_y2 : Integer output) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aPoint,lastPoint : Point;
	idx,x1,x2,y1,y2,x3,y3  : Integer;
begin
	foreach aPoint in self.allPoints do
		idx := idx + 1;
		
		if idx mod 2 = 0 then
			x2 := aPoint.x;
			y2 := aPoint.y;
/*			
			if x1 &gt; x2 or y1 &gt; y2 then
				x3 := x1;
				x1 := x2;
				x2 := x3;
				y3 := y1;
				y1 := y2;
				y2 := y3;
			endif;
*/			
			 // ### TOP LEFT KNOB
			if _xIn &gt;= (x1 - self.grabberWidth) and _xIn &lt;= (x1 + self.grabberWidth)
				and _yIn  &gt;= (y1 - self.grabberWidth) and _yIn &lt;= (y1 + self.grabberWidth) then
				_x1 := x2;
				_y1 := y2;
				_x2 := x1;
				_y2 := y1;
				self.allPoints.remove(lastPoint);
				self.allPoints.remove(aPoint);
				self.grabberPosition := self.grabberTopLeft;
				return true;
			
			 // ### TOP RIGHT KNOB
			elseif _xIn &gt;= (x2 - self.grabberWidth) and _xIn &lt;= (x2 + self.grabberWidth)
				and _yIn  &gt;= (y1 - self.grabberWidth) and _yIn &lt;= (y1 + self.grabberWidth) then
				_x1 := x1;
				_y1 := y2;
				_x2 := x2;
				_y2 := y1;
				self.allPoints.remove(lastPoint);
				self.allPoints.remove(aPoint);
				self.grabberPosition := self.grabberTopRight;
				return true;
			
			 // ### BOTTOM RIGHT KNOB
			elseif _xIn &gt;= (x2 - self.grabberWidth) and _xIn &lt;= (x2 + self.grabberWidth)
				and _yIn  &gt;= (y2 - self.grabberWidth) and _yIn &lt;= (y2 + self.grabberWidth) then
				_x1 := x1;
				_y1 := y1;
				_x2 := x2;
				_y2 := y2;
				self.allPoints.remove(lastPoint);
				self.allPoints.remove(aPoint);
				self.grabberPosition := self.grabberBottomRight;
				return true;
			 // ### BOTTOM LEFT KNOB
			elseif _xIn &gt;= (x1 - self.grabberWidth) and _xIn &lt;= (x1 + self.grabberWidth)
				and _yIn  &gt;= (y2 - self.grabberWidth) and _yIn &lt;= (y2 + self.grabberWidth) then
				_x1 := x2;
				_y1 := y1;
				_x2 := x1;
				_y2 := y2;
				self.allPoints.remove(lastPoint);
				self.allPoints.remove(aPoint);
				self.grabberPosition := self.grabberBottomLeft;
				return true;
			else
			endif;
		else
			x1 := aPoint.x;
			y1 := aPoint.y;
			lastPoint := aPoint;
		endif;
		aPoint.x;
	endforeach;

	_x1 := self.origXPos.Integer;
	_y1 := self.origYPos.Integer;
	_x2 := self.lastMouseX;
	_y2 := self.lastMouseY;
	return false;
end;</source>
        <Parameter name="_xIn" type="Integer"/>
        <Parameter name="_yIn" type="Integer"/>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfSlots" id="27f62f38-3f4a-4457-89d6-cf874ba81725">
        <source>getNumberOfSlots( _x1, _y1, _x2, _y2 : Integer) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2009	cnwjk3	Initial creation

*/

vars
	numSlots 	: Integer;
	locations 	: CM_LCArray;
begin
	create locations transient;
	self.getDrawingController().allGridObjects.findObjectsInDict(_x1, _y1, _x2, _y2, locations, CM_LocationsController, false, false);
	if locations &lt;&gt;  null then
		numSlots := locations.size();
	endif;
	return numSlots;
epilog
	delete locations;
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getObjectAndPointsForPosition" id="5f5be14d-ef9b-478b-ab1c-fdc08e322775">
        <source>getObjectAndPointsForPosition(x, y : Integer; xy1, xy2 : Point output) : Object;
// ---------------------------------------------------------------------------
// Created:     27 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	anObject : Object;
begin

	anObject:= self.allObjects.findObjectInDictByClass(x, y, xy1, xy2,CM_TrackedItem);
	if anObject = null then
		anObject:= self.allObjects.findObjectInDictByClass(x, y, xy1, xy2,CM_Restriction);
	endif;
	if anObject = null then

		anObject:= self.allObjects.findObjectInDict(x, y, xy1, xy2);
	endif;

	
	return anObject;
end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="xy1" type="Point" usage="output"/>
        <Parameter name="xy2" type="Point" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getObjectForPosition" id="e5a2f1a2-f05b-4755-90ec-a3d7e5c2feb4">
