    <DbClassMap file="jssxs_formatted_file"/>
    <ExplicitInverseRef name="allIniKeys" id="a7b159e9-94f2-41ca-9592-f072d2494d15">
        <kind>parent</kind>
        <type name="JSSIniKeyDict"/>
        <access>readonly</access>
        <Inverse name="JSSIniKey::myIniSection"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myIniFile" id="4930a60f-b678-48f7-a247-360a15e3bcff">
        <kind>child</kind>
        <embedded/>
        <type name="JSSIniFile"/>
        <access>readonly</access>
        <Inverse name="JSSIniFile::allIniSections"/>
    </ExplicitInverseRef>
    <PrimAttribute name="sectionName" id="fa95ed79-18e7-4151-82a1-10c59de156dd">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addIniKey" id="b5133980-7ccd-46cb-8559-000750288a38">
        <source>addIniKey(pKeyName:String; pDefaultValue:String);
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniKey	: JSSIniKey;

begin
	iniKey	:=	self.createKey(pKeyName, pDefaultValue);

	if iniKey &lt;&gt; null then
		if (not app.setProfileString(self.myIniFile.fileName, self.sectionName, pKeyName, pDefaultValue)) then
			delete iniKey;
		endif;
	endif;
end;</source>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="createKey" id="52e4be99-72b7-4a9a-9dba-b0570bca4baa">
        <source>createKey(pKeyName:String; pDefaultValue:String):JSSIniKey;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniKey	: JSSIniKey;

begin
	on Exception do global.jssXHandlerDuplicate(exception);

	create iniKey transient;
	iniKey.set(pKeyName, self.myIniFile.getKeyValue(self.sectionName, pKeyName, pDefaultValue), pDefaultValue);
	iniKey.setIniSection(self);
	return iniKey;
end;</source>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
        <ReturnType type="JSSIniKey"/>
    </JadeMethod>
    <JadeMethod name="deleteIniKey" id="0818182d-bd8e-419a-91c1-1d98f8d10276">
        <source>deleteIniKey(pKeyName:String);
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniKey	: JSSIniKey;

begin
	iniKey	:=	self.allIniKeys[pKeyName];

	if iniKey &lt;&gt; null then
		if app.setProfileString(self.getFileName(), self.sectionName, pKeyName, ProfileRemoveKey) then
			delete iniKey;
		endif;
	endif;
end;</source>
        <Parameter name="pKeyName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileName" id="385dda82-c779-411e-be0e-d4a3f57b9ae4">
        <source>getFileName():String;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myIniFile.fileName;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getListDisplay" id="3e87b5f5-3fc3-4e65-8725-c027dec582a5">
        <source>getListDisplay():String;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.sectionName &amp; " [" &amp; self.allIniKeys.size().String &amp; "]";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="4e7f74da-6358-4723-8b3d-207740c04f75">
        <updating/>
        <source>set(pSectionName:String) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.sectionName &lt;&gt; pSectionName then
		self.sectionName	:=	pSectionName;
	endif;
end;</source>
        <Parameter name="pSectionName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setIniFile" id="21b4b5ea-b51c-4fce-91dc-a99b38106884">
        <updating/>
        <source>setIniFile(pIniFile:JSSIniFile) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myIniFile &lt;&gt; pIniFile then
		self.myIniFile	:=	pIniFile;
	endif;
end;</source>
        <Parameter name="pIniFile" type="JSSIniFile"/>
    </JadeMethod>
</Class>
