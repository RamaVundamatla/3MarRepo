    <JadeMethod name="scrollLeft" id="93c92292-16f1-45d8-938b-c6d78c96d3a5">
        <updating/>
        <source>scrollLeft() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation
12 Jul 2010 cnwer1	Par 24901 at smaller scaleFactor need to increase the number of rows that are incremented
*/

vars
	prevScrollOffset : Integer;
	scrollByNumCols		: Integer;
begin
	
	//self.debugCols( "-------- " &amp; method.name &amp; " Before Cols ------- " );

	// New
	if self.myDrawingFrame.left &gt; self.leftStartOffset then
		// We need to adjust the left offsets to maintain the buffer around the viewport
		self.myDrawingFrame.left := self.myDrawingFrame.left - self.hScrollAmount;
		self.myTIFrame.left := self.myTIFrame.left - self.hScrollAmount;
		//24/09/2010 cnwdz2 25642
		if self.myTopHLabelsFrame &lt;&gt; null then
			self.myTopHLabelsFrame.left := self.myTopHLabelsFrame.left - self.hScrollAmount;
		endif;
		if self.myDrawingFrame.left &lt; self.leftStartOffset then
			self.myDrawingFrame.left := self.leftStartOffset;
			self.myTIFrame.left := self.leftStartOffset;
			//24/09/2010 cnwdz2 25642
			if self.myTopHLabelsFrame &lt;&gt; null then
				self.myTopHLabelsFrame.left := self.leftStartOffset;
			endif;
		endif;
	endif;
	//
	
	if self.flipH and self.hScrollOffset = 0 then
		if self.rightGridCol = 1 then
			// New
			self.scrollDrawingFramesLeft();
			//
			return;
		endif;
	elseif self.hScrollOffset = 0 then
		if self.rightGridCol &gt;= self.maxGridCol then
			// New
			self.scrollDrawingFramesLeft();
			//
			return;
		endif;
	endif;
	
	if self.rightOffset &gt; 0 then
		return;
	endif;

	
	if self.leftOffset &gt; 0 then
		self.leftOffset := (self.leftOffset - self.hScrollAmount).Integer;
		if self.leftOffset &lt; 0 then
			self.leftOffset := 0;
		endif;
	else
		prevScrollOffset := self.hScrollOffset;
		self.hScrollOffset := (self.hScrollOffset - self.hScrollAmount).Integer;
		
		if self.hScrollOffset.abs() &gt; self.getGridWidth()-1 then
			scrollByNumCols:=(self.hScrollOffset.abs()/self.getGridWidth()).Integer.max(1);
			self.hScrollOffset := 0;
			if self.flipH then
				if self.leftGridCol = 1 or self.rightGridCol = 1 then 
					self.hScrollOffset := prevScrollOffset;
					// New
					self.scrollDrawingFramesLeft();
					//
				else
				
					self.leftGridCol := self.leftGridCol - scrollByNumCols;
					self.rightGridCol := self.rightGridCol - scrollByNumCols;
				endif;
			else
				if self.rightGridCol = self.maxGridCol or self.leftGridCol = self.maxGridCol  then			
					self.hScrollOffset := prevScrollOffset;
					// New
					self.scrollDrawingFramesLeft();
					//
				else
					self.rightGridCol := self.rightGridCol + scrollByNumCols;
					self.leftGridCol := self.leftGridCol + scrollByNumCols;
				endif;
			endif;
		endif;
	endif;
	
	self.calcViewSizes();
	self.reCalcRowsCols();
	self.calcDrawCols();
	self.drawEverything();
	
	//self.debugCols( "-------- " &amp; method.name &amp; " After Cols ------- " );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollLeft_new" id="86215ffc-315e-444e-a31d-277d1db2bca3">
        <updating/>
        <source>scrollLeft_new() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Sep 2010	cnwdz2	Initial creation 25641
*/

vars
	drawingFrameLeft,
	drawPortionInViewFrame,
	spareSpaceAtRight,
	gridWidthPixels,
	rightMax 		: Real;
	maxX,
	numFullyVisibleCols,
	buttonMenuOffset : Integer;
	drawingWidth    : Real;
	halfColDrawWidth,
	spareSpace,
	frameWidth,
	viewFrameWidth,
	labelFrameWidth,
	scrollAmount	: Real;
begin
	
	//self.debugCols( "-------- " &amp; method.name &amp; " Before Cols ------- " );
	
	frameWidth := self.myDrawingFrame.clientWidth();
	gridWidthPixels := self.getGridWidth();
	drawingFrameLeft := self.myDrawingFrame.left;
	buttonMenuOffset := self.leftStartOffset.abs().Integer - self.getScrollOffsetSize();
	viewFrameWidth := frameWidth - self.getScrollOffsetSize()*2 - buttonMenuOffset;
	
	if self.myRightVLabelsFrame &lt;&gt; null then
		labelFrameWidth := self.myRightVLabelsFrame.width;
	endif;
		
	if self.flipH then
		drawPortionInViewFrame := drawingFrameLeft + self.xDrawStart;
	else	
		drawPortionInViewFrame := drawingFrameLeft + self.xDrawEnd;
	endif;
	
	spareSpaceAtRight := drawPortionInViewFrame + buttonMenuOffset - (viewFrameWidth - labelFrameWidth);
	if spareSpaceAtRight &lt;= 0 then
		return;
	elseif spareSpaceAtRight  &lt; self.hScrollAmount then
		scrollAmount := spareSpaceAtRight;
	else
		scrollAmount :=  self.hScrollAmount;
	endif;
	
	self.myDrawingFrame.left := drawingFrameLeft - scrollAmount;
	self.myTIFrame.left := self.myTIFrame.left - scrollAmount;
	//24/09/2010 cnwdz2 25642
	if self.myTopHLabelsFrame &lt;&gt; null then
		self.myTopHLabelsFrame.left := self.myTopHLabelsFrame.left - scrollAmount;
	endif;
	
	if self.myBottomHLabelsFrame &lt;&gt; null then
		self.myBottomHLabelsFrame.left := self.myBottomHLabelsFrame.left - scrollAmount;
	endif;
	//self.debugCols( "-------- " &amp; method.name &amp; " After Cols ------- " );
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollRight" id="ad35451f-c987-41ce-a482-af1342bca184">
        <updating/>
        <source>scrollRight() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation
12 Jul 2010 cnwer1	Par 24901 at smaller scaleFactor need to increase the number of rows that are incremented
*/

vars
	prevScrollOffset : Integer;
	scrollByNumCols : Integer;
begin
	
	//self.debugCols( "-------- " &amp; method.name &amp; " Before Cols ------- " );
	
	// New
	if self.myDrawingFrame.left &lt; self.leftStartOffset then
		// We need to adjust the left offset to maintain the buffer around the viewport
		self.myDrawingFrame.left := self.myDrawingFrame.left + self.hScrollAmount;
		self.myTIFrame.left := self.myTIFrame.left + self.hScrollAmount;
		//24/09/2010 cnwdz2 25642
		if self.myTopHLabelsFrame &lt;&gt; null then
			self.myTopHLabelsFrame.left := self.myTopHLabelsFrame.left + self.hScrollAmount;
		endif;
		if self.myDrawingFrame.left &gt; self.leftStartOffset then
			self.myDrawingFrame.left := self.leftStartOffset;
			self.myTIFrame.left := self.leftStartOffset;
			//24/09/2010 cnwdz2 25642
			if self.myTopHLabelsFrame &lt;&gt; null then
				self.myTopHLabelsFrame.left := self.leftStartOffset;
			endif;
		endif;
	endif;
	//

	if self.flipH and self.hScrollOffset = 0 then
		if self.leftGridCol &gt;=  self.maxGridCol then
			// New
			self.scrollDrawingFramesRight();
			//
			return;
		endif;	
	elseif self.hScrollOffset = 0 then
		if self.leftGridCol = 1 then
			// New
			self.scrollDrawingFramesRight();
			//
			return;
		endif;	
	endif;
	
	if self.leftOffset &gt; 0 then
		return;
	endif;
	
	
	if self.rightOffset &gt; 0 then
		self.rightOffset := (self.rightOffset - self.hScrollAmount).Integer;
		if self.rightOffset &lt; 0 then
			self.rightOffset := 0;
		endif;
	else
		prevScrollOffset := self.hScrollOffset;		
		self.hScrollOffset := (self.hScrollOffset + self.hScrollAmount).Integer;		
		
		if self.hScrollOffset.abs() &gt; self.getGridWidth()-1 then
			scrollByNumCols:=(self.hScrollOffset.abs()/self.getGridWidth()).Integer.max(1);
			self.hScrollOffset := 0;
			if self.flipH then
				if self.leftGridCol = self.maxGridCol then			
					self.hScrollOffset := prevScrollOffset;
					// New
					self.scrollDrawingFramesRight();
					//
				else
					self.leftGridCol := self.leftGridCol  + scrollByNumCols;
				
				
					// Only adjust right column if it doesn't fit on screen anymore
					if not self.canRightColFitOnScreen(self.rightGridCol) then
						self.rightGridCol := self.rightGridCol + scrollByNumCols;
					endif;

				
				endif;
			else
				if self.leftGridCol = 1 or self.rightGridCol = 1 then 
					self.hScrollOffset := prevScrollOffset;
					// New
					self.scrollDrawingFramesRight();
					//
				else
		
					self.leftGridCol := self.leftGridCol - scrollByNumCols;
			
					// Only adjust right column if it doesn't fit on screen anymore
					if not self.canRightColFitOnScreen(self.rightGridCol) then
						self.rightGridCol := self.rightGridCol - scrollByNumCols;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	self.calcViewSizes();
	self.reCalcRowsCols();
	self.calcDrawCols();
	self.drawEverything();
	
	
	//self.debugCols( "-------- " &amp; method.name &amp; " After Cols ------- " );
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollRight_new" id="8ab1df62-6b2a-410f-ba9e-36edff639b2b">
        <updating/>
        <source>scrollRight_new() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Sep 2010	cnwdz2	Initial creation 25641
*/

vars
	//prevScrollOffset : Integer;
	//scrollByNumCols : Integer;
	drawingFrameLeft,
	spareSpaceAtleft,
	gridWidthPixels,
	labelOffset,
	xStart,
	frameWidth,
	viewFrameWidth,
	drawingWidth,
 	buttonMenuOffset,
	scrollAmount		: Real;
begin
	
	//self.debugCols( "-------- " &amp; method.name &amp; " Before Cols ------- " );
	
	frameWidth := self.myDrawingFrame.clientWidth();
	gridWidthPixels := self.getGridWidth();
	drawingFrameLeft := self.myDrawingFrame.left;
	
	if self.myLeftVLabelsFrame &lt;&gt; null then
		labelOffset := self.myLeftVLabelsFrame.left + self.myLeftVLabelsFrame.width;
	endif;
	
	if self.flipH then
		xStart := drawingFrameLeft + self.xDrawEnd;
	else				
		xStart := drawingFrameLeft + self.xDrawStart;
	endif;

	if xStart &gt;= labelOffset then
		return;
	endif;
	
	if labelOffset &gt; 0 then
		if xStart &gt;= 0 and xStart &lt; labelOffset then
			scrollAmount := labelOffset - xStart;
		elseif self.hScrollAmount - xStart.abs() &gt; labelOffset then
			scrollAmount := xStart + labelOffset;
		else
			scrollAmount := self.hScrollAmount;
		endif;
	elseif labelOffset = 0 then
		if xStart.abs() &lt; self.hScrollAmount then
			scrollAmount := xStart.abs();
		else
			scrollAmount := self.hScrollAmount;
		endif;
	endif;
	
	self.myDrawingFrame.left := drawingFrameLeft + scrollAmount;
	self.myTIFrame.left := self.myTIFrame.left + scrollAmount;
	//24/09/2010 cnwdz2 25642
	if self.myTopHLabelsFrame &lt;&gt; null then
		self.myTopHLabelsFrame.left := self.myTopHLabelsFrame.left + scrollAmount;
	endif;
	
	if self.myBottomHLabelsFrame &lt;&gt; null then
		self.myBottomHLabelsFrame.left := self.myBottomHLabelsFrame.left + scrollAmount;
	endif;
	//self.debugCols( "-------- " &amp; method.name &amp; " After Cols ------- " );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollUp" id="84f3a9b9-058b-4701-8ad8-ac0f7b419ea1">
        <updating/>
        <source>scrollUp() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation
12 Jul 2010 cnwer1	Par 24901 at smaller scaleFactor need to increase the number of rows that are incremented
*/

vars
	prevScrollOffset : Integer;
	scrollByNumRows : Integer;
begin
	
	//self.debugRows( "-------- " &amp; method.name &amp; " Before Rows ------- " );

	// New
	if self.myDrawingFrame.top &gt; self.topStartOffset then
		// We need to adjust the top offsets to maintain the buffer around the viewport
		self.myDrawingFrame.top := self.myDrawingFrame.top - self.vScrollAmount;
		self.myTIFrame.top := self.myTIFrame.top - self.vScrollAmount;
		//24/09/2010 cnwdz2 25642
		if self.myLeftVLabelsFrame &lt;&gt; null then
			self.myLeftVLabelsFrame.top := self.myLeftVLabelsFrame.top - self.vScrollAmount;
		endif;
		if self.myDrawingFrame.top &lt; self.topStartOffset then
			self.myDrawingFrame.top := self.topStartOffset;
			self.myTIFrame.top := self.topStartOffset;
			//24/09/2010 cnwdz2 25642
			if self.myLeftVLabelsFrame &lt;&gt; null then
				self.myLeftVLabelsFrame.top := self.topStartOffset;
			endif;
		endif;
	endif;
	//
	
	if self.flipV and self.vScrollOffset = 0 then
		if self.bottomGridRow = 1 then
			// New
			self.scrollDrawingFramesUp();
			//
			return;
		endif;
	elseif self.vScrollOffset = 0 then
		if self.bottomGridRow &gt;= self.maxGridRow then
			// New
			self.scrollDrawingFramesUp();
			//
			return;
		endif;
	endif;
	
	if self.bottomOffset &gt; 0 then
		return;
	endif;

	
	if self.topOffset &gt; 0 then
		self.topOffset := (self.topOffset - self.vScrollAmount).Integer;
		if self.topOffset &lt; 0 then
			self.topOffset := 0;
		endif;
	else
		prevScrollOffset := self.vScrollOffset;
		self.vScrollOffset := (self.vScrollOffset - self.vScrollAmount).Integer;
		
		if self.vScrollOffset.abs() &gt; self.getGridHeight()-1 then
			scrollByNumRows:=(self.vScrollOffset.abs()/self.getGridHeight()).Integer.max(1);
			self.vScrollOffset := 0;
			if self.flipV then
				if self.topGridRow = 1 or self.bottomGridRow = 1 then 
					self.vScrollOffset := prevScrollOffset;
					// New
					self.scrollDrawingFramesUp();
					//
				else				
					self.topGridRow := self.topGridRow - scrollByNumRows;
					self.bottomGridRow := self.bottomGridRow - scrollByNumRows;
				endif;
			else
				if self.bottomGridRow = self.maxGridRow or self.topGridRow = self.maxGridRow  then			
					self.vScrollOffset := prevScrollOffset;
					// New
					self.scrollDrawingFramesUp();
					//
				else
					self.bottomGridRow := self.bottomGridRow + scrollByNumRows;
					self.topGridRow := self.topGridRow + scrollByNumRows;
				endif;
			endif;
		endif;
	endif;
	
	self.calcViewSizes();
	self.reCalcRowsCols();
	self.calcDrawRows();
	self.drawEverything();
	
	//self.debugRows( "-------- " &amp; method.name &amp; " After Rows ------- " );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollUp_new" id="ca416325-5995-4536-9226-211094c63043">
        <updating/>
        <source>scrollUp_new() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Sep 2010	cnwdz2	Initial creation 25641
*/

vars
	drawingHeight,
	yStart,
	buttonMenuOffset	: Integer;
	bottomMax,
	drawingFrameTop,
	spareSpaceAtTop,
	spareSpaceAtBottom : Real;
	gridHeightPixels,
	drawPortionInViewFrame,
	frameHeight,
	viewFrameHeight,
	labelHeight,
	scrollAmount		: Real;
begin
	
	//self.debugRows( "-------- " &amp; method.name &amp; " Before Rows ------- " );
	
	gridHeightPixels := self.getGridHeight();
	drawingFrameTop := self.myDrawingFrame.top;
	frameHeight := self.myDrawingFrame.clientHeight();
	buttonMenuOffset := self.topStartOffset.abs().Integer - self.getScrollOffsetSize();
	viewFrameHeight := frameHeight - self.getScrollOffsetSize()*2 - buttonMenuOffset;
	//if self.myViewportFrame.height &lt; viewFrameHeight then
	//	viewFrameHeight := self.myViewportFrame.height;
	//endif;
	
	if self.myBottomHLabelsFrame &lt;&gt; null then
		labelHeight := self.myBottomHLabelsFrame.height;
	endif;
		
	if self.flipV then
		drawPortionInViewFrame := drawingFrameTop + self.yDrawStart;
	else	
		drawPortionInViewFrame := drawingFrameTop + self.yDrawEnd;
	endif;
	
	/*
	if self.flipV then
		drawPortionInViewFrame := frameHeight + drawingFrameTop - self.bottomOffset;
		if drawPortionInViewFrame &lt;= viewFrameHeight then
			return;
		endif;
	else	
		drawingHeight := (self.numGridRowsToDraw-1)*gridHeightPixels.Integer;
		drawPortionInViewFrame := drawingFrameTop + self.topOffset + drawingHeight;
		
		if self.myBottomHLabelsFrame &lt;&gt; null then
			labelHeight := self.myBottomHLabelsFrame.height;
		endif;
		
		spareSpaceAtBottom := drawPortionInViewFrame + labelHeight - viewFrameHeight;
		if spareSpaceAtBottom &lt;= 0 then
			return;
		endif;
	endif;
	*/
	spareSpaceAtBottom := drawPortionInViewFrame - (viewFrameHeight - labelHeight);
	if spareSpaceAtBottom &lt;= 0 then
		return;
	elseif spareSpaceAtBottom  &lt; self.vScrollAmount then
		scrollAmount := spareSpaceAtBottom;
	else
		scrollAmount :=  self.vScrollAmount;
	endif;
	
	
	/*
	self.myDrawingFrame.top := drawingFrameTop - self.vScrollAmount;
	self.myTIFrame.top := self.myTIFrame.top - self.vScrollAmount;
	//24/09/2010 cnwdz2 25642
	if self.myLeftVLabelsFrame &lt;&gt; null then
		self.myLeftVLabelsFrame.top := self.myLeftVLabelsFrame.top - self.vScrollAmount;
	endif;
	
	if self.myRightVLabelsFrame &lt;&gt; null then
		self.myRightVLabelsFrame.top := self.myRightVLabelsFrame.top - self.vScrollAmount;
	endif;
	*/
	
	self.myDrawingFrame.top := drawingFrameTop - scrollAmount;
	self.myTIFrame.top := self.myTIFrame.top - scrollAmount;
	//24/09/2010 cnwdz2 25642
	if self.myLeftVLabelsFrame &lt;&gt; null then
		self.myLeftVLabelsFrame.top := self.myLeftVLabelsFrame.top - scrollAmount;
	endif;
	
	if self.myRightVLabelsFrame &lt;&gt; null then
		self.myRightVLabelsFrame.top := self.myRightVLabelsFrame.top - scrollAmount;
	endif;	
	//self.debugRows( "-------- " &amp; method.name &amp; " After Rows ------- " );
epilog

end;</source>
    </JadeMethod>
