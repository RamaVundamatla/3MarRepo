    <JadeMethod name="getRowColour" id="1fe4b9ee-f7c3-4318-bd4c-b8fcedbf25f1">
        <source>getRowColour(_foreColour, _backColour : Integer output);
//--------------------------------------------------------------
//Created: 07 May 2003 By: cnwgd1
// 23 Mar 11 cnwer1 	PAR 25573 - changed to use part complete rather than assigned
// 14/06/2022 	navcs2 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// 23/05/2023 navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
//--------------------------------------------------------------
vars
	toDoTaskDesc : CM_ToDoTaskDesc; //23/05/2023 navmv20 CR 57925 Task 57921
	trxType      : CM_TransactionType; //23/05/2023 navmv20 CR 57925 Task 57921
begin
	_backColour := White;
	_foreColour := Black;	
	
	//23/05/2023 navmv20 CR 57925 Task 57921 - START
	if 	self.job.isKindOf(CM_WOToDoTaskJob) then
		toDoTaskDesc := self.job.CM_WOToDoTaskJob.myToDoTaskDesc;
		if toDoTaskDesc &lt;&gt; null then
			trxType := app.myRoot.allTransactionTypes[toDoTaskDesc.trxTypeOnCompletion];
		endif;
	endif;
	//23/05/2023 navmv20 CR 57925 Task 57921 - END

	//14/06/2022 navcs2 TFS 53038 
	if self.job.isKindOf(CM_WOPackJob) or  // cnwrd1 ccms 1075 work orders 6.8.09
		self.job.isKindOf(CM_WOUnpackJob) or 
		self.job.isKindOf(CM_WOToDoTaskJob) then
		
		//if self.myTrackedItem = null then //23/05/2023 navmv20 CR 57925 Task 57921
		if trxType &lt;&gt; null and trxType.trxGroup &lt;&gt;  TRANS_TYPE_GROUP_WO and self.myTrackedItem=null then //23/05/2023 navmv20 CR 57925 Task 57921
			 _foreColour := Red;
			_backColour := White; 	   
		elseif self.status = WLE_PART_COMPLETE then
			_foreColour := CM_Job.Colour_ReceiptPartComplete;		
			
		elseif self.status = WLE_COMPLETED then
			_foreColour := White;					
			_backColour := CM_Job.Colour_ReceiptComplete;
		else
			_foreColour := CM_Job.Colour_ReleaseUnactioned;
		endif;
		
		return;	
	endif;
	
	if self.myTrackedItem &lt;&gt; null
	   and self.isOverstowedForEntry() then	
	   _foreColour := White;
	   _backColour := Red;	   
	elseif self.myTrackedItem &lt;&gt; null 
	and self.myTrackedItem.myMatchedTBA &lt;&gt; null then // PAR 35574
	   _backColour := LightGreen;
	elseif self.myTrackedItem &lt;&gt; null 
	and self.myTrackedItem.myMatchedActual &lt;&gt; null then // TFS 45590
	   _backColour := LightGreen;
	elseif self.status = WLE_UNACTIONED then
		if self.isReceipt then
			_foreColour := CM_Job.Colour_ReceiptUnactioned;		
		else
			_foreColour := CM_Job.Colour_ReleaseUnactioned;
		endif;
		
		if self.job &lt;&gt; null and self.job.isKindOf(CM_VoyageJob) then
			if self.job.CM_VoyageJob.isTwinLift then
				//par13201 Mohammad 25/1/2006
				if self.isReceipt then
					_backColour := LightSkyBlue; // unactioned receipt job Twinlift
				else
					_backColour := LightOrange; // unaction release job twinlift
				endif;
			endif;
		endif;
		
	elseif self.status = WLE_PART_COMPLETE then
		if self.isReceipt then
			_foreColour := CM_Job.Colour_ReceiptPartComplete;		
		else
			_foreColour := CM_Job.Colour_ReleasePartComplete;
		endif;
	elseif self.status = WLE_COMPLETED then
		_foreColour := White;					
		if self.isReceipt then
			_backColour := CM_Job.Colour_ReceiptComplete;
		else
			_backColour := CM_Job.Colour_ReleaseComplete;
		endif;
	endif;

end;</source>
        <Parameter name="_foreColour" type="Integer" usage="output"/>
        <Parameter name="_backColour" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSourceLocation" id="f0dbcf45-cb7e-44da-a34b-03d84c431c77">
