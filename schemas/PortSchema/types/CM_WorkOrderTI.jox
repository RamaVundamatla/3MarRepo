    <JadeMethod name="getMyOperator" id="ca562cf3-82ef-45ed-8126-df1d6de02cbd">
        <source>getMyOperator() : CM_Operator;
/*

Purpose:			 // TFS 38524

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgab1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
15 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

vars
	op 		: CM_Operator;
	ti 	    : CM_TrackedItem;
	invalid : Boolean;
begin	
	on Exception do app.handleDeletedObject(exception, ti, invalid);			// 15 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests

	ti   := self.allWoDtls.first.CM_WorkOrderTIDtl.allSelectedTIs.first;		//08.02.2023 navma1 #56457 Task#56458
	
	if ti = null then
		return null;
	endif;
	
	ti.edition;
	if invalid then
		return null;
	endif;
	if ti &lt;&gt; null then
		op := ti.myOperator;
	endif;
	
	return op;
epilog
	
end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageObject" id="204df91b-8a0f-48f0-9605-aaccc2e3f9f7">
        <source>getMyVoyageObject(): CM_Voyage;
/*

Purpose:			 // TFS 38524

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgab1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
15 Feb 2023	navcs2	Bug 56329: MTN - Cargo Work Orders - Change Voyage - Not saving cargo when creating in Web Portal
13 Mar 2023 navdp20 Defect 57069: MTN - Object not found exception when searching with voyage on the Work Order Enquiry form
02 Feb 2024	navma1  Bug 62220: MTN - work order enquiry doesn't seem to search as expected App
27 Mar 2024 navma1	Bug 62770: EUP - 1090 exception when clicking on the Instructions button on the Complete To Do Tasks form
*/

vars
	ti  		  : CM_TrackedItem;
	wod 		  : CM_WorkOrderDtl;
	voyage	      : CM_Voyage;
	invalidVoyage : Boolean;
	invalidTI	  : Boolean;
	releaseRequest: CM_BulkRelease;
	bookingRef	  : CM_BookingRef;
begin
	
	on Exception do app.handleDeletedObject(exception, voyage, invalidVoyage);   //15.03.2023 navma1 #57069
	on Exception do app.handleDeletedObject(exception, ti, 		invalidTI);      //15.03.2023 navma1 #57069

	
	wod := self.allWoDtls.first;							  //08.02.2023 navma1 #56457:[56458]
	
	if wod = null then  									 //13.03.2023 navdp20  #57069
		return null;
    endif;

	ti := wod.CM_WorkOrderTIDtl.allSelectedTIs.first();
	
	if ti &lt;&gt; null then												//27.03.2024 navma1 #62770
		ti.edition;
		if invalidTI then
			return null;
		endif;
		
		voyage := ti.myVoyage;
		
	else
		if wod.isKindOf(CM_WodRelease) then							//27.03.2024 navma1 #62770
			//26/11/2024	navkc1 JIRA Story MTN-19092 - Checking booking voyage for Road and Rail
			if wod.CM_WodRelease.transport = TI_TRANSMODE_RAIL or wod.CM_WodRelease.transport = TI_TRANSMODE_ROAD then
				bookingRef := wod.CM_WodRelease.myBookingRef;
				if bookingRef &lt;&gt; null then
					voyage := bookingRef.myVoyage;
				endif;
			endif;
			
			//26/11/2024	navkc1 JIRA Story MTN-19092 - If still dont have voyage then do the ordinary way
			if voyage = null then
				releaseRequest := wod.CM_WodRelease.myReleaseRequest;
				if releaseRequest &lt;&gt; null then
					voyage := releaseRequest.myVoyage;
				endif;
			endif;
		elseif wod.isKindOf(CM_WodReceive) then	//26/11/2024	navkc1 JIRA Story MTN-19092
			if wod.CM_WodReceive.transport = TI_TRANSMODE_RAIL or wod.CM_WodReceive.transport = TI_TRANSMODE_ROAD then
				bookingRef := wod.CM_WodReceive.myBookingRef;
				
				if bookingRef &lt;&gt; null then
					voyage := bookingRef.myVoyage;
				endif;
			endif;
		
		endif;
	endif;

	if voyage &lt;&gt; null then									//13.03.2023 navma1 #57069
		voyage.edition;
		if invalidVoyage then
			return null;
		endif;
	endif;
	
	return voyage;
epilog
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getNewVoyage" id="4849f8ee-cb3e-40de-bfdf-d9891656cb40">
        <source>getNewVoyage() : CM_Voyage;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars

begin
	if not self.allWoDtls.isEmpty and self.allWoDtls.first.isWorkOrderForNullVoyage then
		return self.allWoDtls.first.CM_WodNullVoyage.myNewVoyage;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getPINNumber" id="9d397d69-a6cc-463d-b04a-4f15424e5865">
        <source>getPINNumber() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 May 2018	jlgab1	Initial creation
13 Feb 2023 navhl20 Defect 62455: MTN - Release Work Orders Pin number is different on the column and the macro info
*/

vars
	wod : CM_WorkOrderDtl;
begin
	/*if self.myPinNo&lt;&gt; null then				//13.02.2023 navhl20 #62455
		return self.myPinNo.pinNo.String;
	endif;*/
	
	if not self.hasBeenApproved() then
		return "";
	endif;
	
	wod := self.allWoDtls.first;
	
	if wod &lt;&gt; null then
		return wod.getPINNumber();
	endif;
	
	return inheritMethod();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProgressString" id="0ea8b076-b35f-4d0d-8058-a7d8b2eab2a5">
        <source>getProgressString(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Jul 2009	cnwrd1	Initial creation
08 Feb 2023 navma1 ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
13 Oct 2023	navrv30	ChangeRequest 60458: EUP - Change Work Order Progress to be based on QTY or WT
20 Oct 2023	navrv30	ChangeRequest 60458: EUP - Change Work Order Progress to be based on QTY or WT
23 Nov 2023 navhl20 Bug 61242: EUP | Release Cargo Work order progress not based on the Total Quantity of the cargo items
23 Nov 2023 navhl20 Bug 61240: EUP - Unpack Work order progress not based on the Total Quantity of the cargo items
24 Nov 2023 naviv1	Bug 61241: EUP - Receive Cargo Work order progress not based on the Total Quantity of the cargo items
14 May 2024	navdap1	TFS 64055 EUP - lock/1038 when loading an EDI file while Work Order Screen is open
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
02 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue
09 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
29 Jul 2024 navhl20	Bug 65445: EUP - 1090 error when no reserve child on pack work orders
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
04 Apr 2025	navhl20 Bug MTN-34502: EUP FR | 54014 - Error 4 (Object Not Found) when searching for work orders in WO Enquiry
*/

vars
	task   					: CM_WorkOrderDtl;
	result 					: String;
	completed				: Integer;
	completedWeight			: Decimal[12,4];
	required				: Integer;
	requiredWeight			: Decimal[12,4];
	isUseYardJobsForCargoWO,
	invalid					: Boolean;
	reserveDetail 			: CM_ReserveDetail;
	bulkRelease		 		: CM_BulkRelease;
	trackedItem     		: CM_TrackedItem;
	reserveChild 			: CM_ReserveDetail;
	details 				: CM_WorkOrderDtlArray;			// TFS 64055
	cargoType				: CM_CargoType;
begin
	on Exception do app.handleDeletedObject(exception, trackedItem, invalid);						//04.04.2025 navhl20 #34502

	//08.02.2023 navma1 #56457:[56458]
	create details transient;				// TFS 64055
	self.allWoDtls.copy(details);			// TFS 64055
	isUseYardJobsForCargoWO := self.getMyTerminal.isUseYardJobsForCargoWo; 							//13.10.2023 navrv30 #60458
	//foreach  task in self.allWoDtls do	// TFS 64055
	foreach  task in details discreteLock do// TFS 64055											//28.05.2024 navma1 #64224
		if isUseYardJobsForCargoWO then																//13.10.2023 navrv30 #60458
			if  task.isKindOf(CM_WodRelease) then
				reserveDetail := task.CM_WodRelease.myReserveDetail;
				if reserveDetail &lt;&gt; null and reserveDetail.isKindOf(CM_ReserveSelection) then	
					cargoType := reserveDetail.CM_ReserveSelection.myCargoType;						//09.12.2024 navhl20 #33643
					if not cargoType.isBulk then													//09.12.2024 navhl20 #33643		
						required 	:= required + reserveDetail.CM_ReserveSelection.totalRequested;
						completed	:= completed + task.CM_WodRelease.getTotalCompleted(true).Integer;
					else	
						requiredWeight 	:= requiredWeight + reserveDetail.CM_ReserveSelection.weightRequested;
						completedWeight	:= completedWeight + task.CM_WodRelease.getTotalCompleted(false).Decimal;
					endif;
				else																				//23.11.2023 navhl20 #61242
					trackedItem := task.CM_WorkOrderTIDtl.getFirstSelectedTi();						//09.12.2024 navhl20 #33643	//04.04.2025 navhl20 #34502
					if trackedItem &lt;&gt; null and trackedItem.isBulkCargo then							//09.12.2024 navhl20 #33643
						requiredWeight 	:= requiredWeight + task.CM_WodRelease.getTotalRequest(false).Decimal;
						completedWeight	:= completedWeight + task.CM_WodRelease.getTotalCompleted(false).Decimal;
					else
						required	:=	required + task.CM_WodRelease.getTotalRequest(true).Integer;
						completed	:= completed + task.CM_WodRelease.getTotalCompleted(true).Integer;
					endif;
				endif;
			elseif  task.isKindOf(CM_WodReceive) then												//23.11.2023 naviv1 #61241
				trackedItem := task.CM_WorkOrderTIDtl.getFirstSelectedTi();							//09.12.2024 navhl20 #33643	//04.04.2025 navhl20 #34502
				if trackedItem &lt;&gt; null and trackedItem.isBulkCargo then								//09.12.2024 navhl20 #33643
					requiredWeight 	:= requiredWeight + task.CM_WodReceive.getTotalRequest(false).Decimal;
					completedWeight	:= completedWeight + task.CM_WodReceive.getTotalCompleted(false).Decimal;
				else
					required	:=	required + task.CM_WodReceive.getTotalRequest(true).Integer;
					completed	:= completed + task.CM_WodReceive.getTotalCompleted(true).Integer;
				endif;
			elseif task.isKindOf(CM_WodPack) then													//20.10.2023 navrv30 #60458
				bulkRelease := task.CM_WodPack.myReleaseRequest;
				if bulkRelease &lt;&gt; null and bulkRelease.releaseByType then
					reserveDetail := task.CM_WodPack.myReserveDetail;								//29.07.2024 navhl20 #65445
					if reserveDetail &lt;&gt; null then													//29.07.2024 navhl20 #65445
						required := required + reserveDetail.CM_ReserveSelection.totalRequested;	//09.07.2024 navhl20 #61368
					else
						required := required + bulkRelease.getTotalPackRequested;
					endif;
				else 
					required := required + task.CM_WodPack.getWodTotalRequested(true).Integer;
				endif;
				completed := completed + task.CM_WodPack.getTotalCompleted(true).Integer;
			elseif task.isKindOf(CM_WodUnpack) and app.myPassport.isVASEnabled then					 //02.07.2024 navhl20 #64969
				required := required + task.CM_WodUnpack.getTotalRequest(true).Integer;
				completed := completed + task.CM_WodUnpack.getTotalCompleted(true).Integer;
			/*
			//23.11.2023 navhl20 #61240
			elseif task.isKindOf(CM_WodUnpack) then						                             //20.10.2023 navrv30 #60458
				foreach trackedItem in task.CM_WodUnpack.allSelectedTIs do					
					required := required + trackedItem.totalQuantity;				
				endforeach;
				foreach trackedItem in task.CM_WodUnpack.allCompleteTIs do					
					completed := completed + trackedItem.totalQuantity;				
				endforeach;*/			
			elseif task.isKindOf(CM_WodMove) then													//20.10.2023 navrv30 #60458			
				foreach trackedItem in task.CM_WodMove.allSelectedTIs do
					//Start 04.04.2025 navhl20 #34502
					invalid := false;
					trackedItem.edition;
					if invalid then
						continue;
					endif;	
					//End 04.04.2025 navhl20 #34502
					required := required + trackedItem.totalQuantity;				
				endforeach;
				foreach trackedItem in task.CM_WodMove.allCompleteTIs do
					//Start 04.04.2025 navhl20 #34502
					invalid := false;
					trackedItem.edition;
					
					if invalid then
						continue;
					endif;	
					//End 04.04.2025 navhl20 #34502
					completed := completed + trackedItem.totalQuantity;				
				endforeach;	
			else 
				completed := completed + task.CM_WorkOrderTIDtl.allCompleteTIs.size;
				required  := required  + task.CM_WorkOrderTIDtl.allSelectedTIs.size;
			endif;
		else 			
			completed := completed + task.CM_WorkOrderTIDtl.allCompleteTIs.size;
			required  := required  + task.CM_WorkOrderTIDtl.allSelectedTIs.size;
		endif;
	endforeach;
	
	if requiredWeight &lt;&gt; null then																	//09.12.2024 navhl20 #33643
		result := app.getErrorString2(N_of_n_Complete, completedWeight.String, requiredWeight.String);
	else
		result := app.getErrorString2(N_of_n_Complete, completed.String, required.String);
	endif;
	return result;
epilog
	delete details;		// TFS 64055
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseRequest" id="d9bbcc61-bd65-4d63-86e9-f6bcb6b7f22c">
        <source>getReleaseRequest() : CM_BulkRelease;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars

	relReq : CM_BulkRelease;
	invalid : Boolean;
	edition : Integer;

begin

	if self.isWorkOrderForRelease then
		relReq := self.allWoDtls.first.CM_WodRelease.myReleaseRequest;
	elseif self.isWorkOrderForReleaseExtension then	//12 Mar 2019	NDL	TFS 43405
		relReq := self.allWoDtls.first.CM_WodReleaseExtension.myReleaseRequest;
	endif;
	
	//18 Mar 2019	NDL	TFS 43405
	if relReq &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, relReq, invalid );
		edition := relReq.edition;
		if invalid then
			return null;
		endif;
	endif;
	
	return relReq;
	
epilog

end;</source>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
