epilog

end;</source>
        <Parameter name="_cancelledMove" type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="setMyNextMovement" id="5f8821d3-cbe3-42a0-ad83-dfedf03ffe6b">
        <updating/>
        <source>setMyNextMovement(_movementObj:HMS_Movement) updating;
// --------------------------------------------------------------------------------
// Created:		14 February 2007 by cnwdad1
//
// Purpose:		Sets the receiver's reference to the next HMS Movement object.
//
// Parameters:	_movementObj - A reference to the receiver's next Movement.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myNextMovement	:=	_movementObj;
end;</source>
        <Parameter name="_movementObj" type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="setMyPreviousMovement" id="40adc819-7c7d-4f9c-9760-e101a6ed19cf">
        <updating/>
        <source>setMyPreviousMovement( _movement : HMS_Movement) updating;
//-----------------------------------------------------------------------
//	Created:	09 February 2007 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	self.myPreviousMovement := _movement;
	
	//if _movement &lt;&gt; null then
	//	self.myBerthPrevious := _movement.getMyBerth();
	//endif;
	self.setMyBerthPrevious();
	
epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageGlobal" id="16cc03e7-5490-48ce-8c34-8cdb801bb58c">
        <updating/>
        <source>setMyVoyageGlobal( _value : CM_VoyageGlobal) updating;
//-----------------------------------------------------------------------
//	Created:	20 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	self.myVoyageGlobal := _value;
epilog

end;</source>
        <Parameter name="_value" type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="setNextMovementBerthPrevious" id="2952271d-c110-48e1-a237-c0c5360b1f9f">
        <updating/>
        <source>setNextMovementBerthPrevious(_berth : HMS_Berth) updating;
/* ---------------------------------------------------------------------------
Created:     28 January 2008 by cnwrs2
Purpose:     
Changes

Date		Name	TFS#		Description
============================================================================
18 Sep 2019 jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	nextMove	: HMS_Movement;
begin

	nextMove := self.myNextMovement;

	if nextMove = null then
		return;
	endif;
	
	nextMove.myBerthPrevious := _berth;
end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="setOccursOnDT" id="8e59f354-7e0c-4604-96e0-0650fa07a7e7">
        <updating/>
        <source>setOccursOnDT(_value: TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:     04 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.occursOnDTNEW := _value;
end;</source>
        <Parameter name="_value" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setOccursOnFromTimeDiff" id="8f2db894-d2d9-4e7b-b837-cf43ee92a360">
        <updating/>
        <source>setOccursOnFromTimeDiff(_timeDiff : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     22 November 2007 by cnwrs2
//
// Purpose:     
/* Changes

Date		Name	TFS#		Description
============================================================================
18/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	oldDT	: TimeStamp;
	errMsg	: String;
	errorCodes : IntegerArray;
begin

	oldDT	:= self.occursOnDTNEW;

	if _timeDiff = 0 then
		return;
	endif;
	
	/*create errorCodes transient;	//13 Sep 2012	NDL	Par 30366
	
	if _isDoingRecalc then
		if self.arrivalTimeAtFromRegionLocked then
			//errMsg := 'Voyage ' &amp; self.getVoyageCode &amp; ' has a locked arrival time at ' &amp;
			//		self.getFromLocationDescr &amp; ' of ' &amp; 
			//		self.arrivalTimeAtFromRegion.asStringJMT &amp; '.';  //- cnwmd1, Par 20524
			errMsg := app.getErrorString3(Voyage_locked_arrival_time_at,
					self.getVoyageCode, self.getFromLocationDescr, self.arrivalTimeAtFromRegion.asStringJMT);
			errorCodes.add(Voyage_locked_arrival_time_at);	//13 Sep 2012	NDL	Par 30366

			if _timeDiff &lt; 0 then
				// OK to carry on.  We leave time unchanged and bail out
				if _chkPointController &lt;&gt; null then
					_chkPointController.addInfo(errMsg &amp; 
							' Difference is -ve, ignoring time change based on difference', LogAlways);
				endif;
				return;
			else
				errMsg := errMsg &amp;
					//' This locked time cannot be updated as part of a recalc.  Please update manually'; //- cnwmd1, Par 20524
					app.getErrorString(This_locke_time_canno_updat_pa);
				errorCodes.add(This_locke_time_canno_updat_pa);	//13 Sep 2012	NDL	Par 30366
				
				if _chkPointController &lt;&gt; null then
					_chkPointController.addInfo(errMsg, LogAlways);
				endif;
				//app.raiseCMException1(Full_Replacement_Message, errMsg, null, null); //- cnwmd1, Par 20524
				//app.raiseCMException1(HMS_Movement_Err, errMsg, null, null);
				app.raiseMultiReasonExcOrWarning( errorCodes, errMsg, false, null,  null );	//13 Sep 2012	NDL	Par 30366
			endif;
		endif;
		
		if self.departureTimeLocked then
			errMsg := 'Voyage ' &amp; self.getVoyageCode &amp; ' has a locked departure time at ' &amp;
					self.getFromLocationDescr &amp; ' of ' &amp; 
					self.departureTimeFromFromRegion.asStringJMT &amp; '.';
					
			if _timeDiff &lt; 0 then
				// OK to carry on.  We leave time unchanged and bail out
				if _chkPointController &lt;&gt; null then
					_chkPointController.addInfo(errMsg &amp; 
							' Difference is -ve, ignoring time change based on difference', LogAlways);
				endif;
				return;
			else
				errMsg := errMsg &amp;
					//' This locked time cannot be updated as part of a recalc.  Please update manually'; //- cnwmd1, Par 20524
					app.getErrorString(This_locke_time_canno_updat_pa);
				errorCodes.add(This_locke_time_canno_updat_pa);	//13 Sep 2012	NDL	Par 30366
				
				if _chkPointController &lt;&gt; null then
					_chkPointController.addInfo(errMsg, LogAlways);
				endif;
				//app.raiseCMException1(Full_Replacement_Message, errMsg, null, null); //- cnwmd1, Par 20524
				//app.raiseCMException1(HMS_Movement_Err, errMsg, null, null);
				app.raiseMultiReasonExcOrWarning( errorCodes, errMsg, false, null,  null );	//13 Sep 2012	NDL	Par 30366
			endif;
		endif;
		
		if self.isArrivalTimeAtToRegionLocked(errMsg) then
			if _timeDiff &lt; 0 then
				// OK to carry on.  We leave time unchanged and bail out
				if _chkPointController &lt;&gt; null then
					_chkPointController.addInfo(errMsg &amp; 
							' Difference is -ve, ignoring time change based on difference', LogAlways);
				endif;
				return;
			else
				errMsg := errMsg &amp;
					//' This locked time cannot be updated as part of a recalc.  Please update manually'; //- cnwmd1, Par 20524
					app.getErrorString(This_locke_time_canno_updat_pa);
				errorCodes.add(This_locke_time_canno_updat_pa);	//13 Sep 2012	NDL	Par 30366
				
				if _chkPointController &lt;&gt; null then
					_chkPointController.addInfo(errMsg, LogAlways);
				endif;
				//app.raiseCMException1(Full_Replacement_Message, errMsg, null, null); //- cnwmd1, Par 20524
				//app.raiseCMException1(HMS_Movement_Err, errMsg, null, null);
				app.raiseMultiReasonExcOrWarning( errorCodes, errMsg, false, null,  null );	//13 Sep 2012	NDL	Par 30366
			endif;
		endif;
	endif;*/

	self.setTimings(self.occursOnDTNEW.cnEcAddMinutes(_timeDiff), self.steamingTime, false);

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' ' &amp; self.getVoyageCode &amp; ' ' &amp;
			self.getDescription &amp; ' updating from ' &amp; oldDT.asStringJMT &amp; ' to ' &amp;
			self.occursOnDTNEW.asStringJMT &amp; ' diff ' &amp; _timeDiff.String, LogERROR);

	// so that we maintain order of remaining movements we need to update all movements
	/*.self.rebuildTimingsForward(_timeDiff, true, _isDoingRecalc, _chkPointController);
	
	if _placeInOptimimTimings and
	   self.myVoyageGlobal &lt;&gt; null and
	   self.myNextMovement &lt;&gt; null then
		self.myVoyageGlobal.placeInOptimumTimings(self.myNextMovement);
	endif;*/

epilog
	delete errorCodes;	//13 Sep 2012	NDL	Par 30366;
end;</source>
        <Parameter name="_timeDiff" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStreamingTime" id="fd5c24a6-2ae0-434d-9015-40e614ac4bc1">
        <updating/>
        <source>setStreamingTime(_value : Integer) updating;
//-----------------------------------------------------------------------
//	Created:	01 December 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	self.steamingTime := _value;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTimings" id="d3176ef3-8e2e-4b92-b14b-d3597399c49b">
        <updating/>
        <source>setTimings(_occursOnDT : TimeStamp; _steamingTime : Integer; _calculateSteamingTime : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     22 November 2007 by cnwrs2
//
// Purpose:     
//
// Parameters:	
/* Changes

Date		Name	TFS#		Description
============================================================================
03/04/2019	jlgdap1		TFS 44119 PEL1 Restriction on when shift movements can happen
18/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	pxyMove,					// PAR 26884
	nextMove,
	prevMove	: HMS_Movement;
	newSteamingTime,
	tmpWaitingTime		: Integer;
	earliestPossibleTS,
	prevArriveAtToDT,
	tmpTime,
	departFromDT	: TimeStamp;
	saveOccursOnDT,
	saveDepartTimeFromFromRegion	: TimeStamp;
	isFirstForGlobalVoyage	: Boolean;
	tmpVoyageCode	: String;

begin

	if self.isCancelled() then	//19 Nov 2018	NDL	TFS 42043
		return;
	endif;
	
	if _steamingTime &lt; 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Steaming time cannot be negative');
		return;
	endif;
	
	tmpVoyageCode := self.getVoyageCode();

	newSteamingTime := _steamingTime;
	
	// Need to store this here as departureTimeFromFromRegion is a virtual
	// that is dependent on data we are about to change.
	saveOccursOnDT := self.occursOnDTNEW;
	saveDepartTimeFromFromRegion := self.departureTimeFromFromRegion;
	
	// Need to set this BEFORE doing any updates as isFirstMovementForGlobalVoyage() uses
	// position in dict by date, so update to occursOnDT can change order
	isFirstForGlobalVoyage := self.isFirstMovementForGlobalVoyage;

	prevMove := self.myPreviousMovement;
	if prevMove &lt;&gt; null and prevMove.myBerth &lt;&gt; null and self.myBerth &lt;&gt; null and prevMove.myBerth.getHarbour &lt;&gt; self.myBerth.getHarbour then
		prevMove := null;
	endif;

	// PAR 26884 - need to ensure validation is done against the correct data (CNWRS2, 6 Feb 2011)
	if prevMove &lt;&gt; null then
		if self.isTransient and (not prevMove.isTransient) then
		// we are transient, so want to see if the prev movement
			// also has a transient, and if so do validation against it
			pxyMove := app.myProxyManager.getProxyObject(prevMove).HMS_Movement;
			if pxyMove &lt;&gt; null then
				prevMove := pxyMove;
			endif;
		endif;
	endif;
	// PAR 26884 - end
	
	//jlgka1 TFS 45620 --&gt;
	/*if _isDoingRecalc and
	   (self.arrivalTimeAtFromRegionLocked or
	   self.departureTimeLocked or
	   self.steamingTimeLocked) then
		// Some data is locked so need to check if this update can proceed
		if self.arrivalTimeAtFromRegionLocked then
		endif;
		if self.departureTimeLocked then
			if self.moveType = HMSMovementTypeDeparture and
			   _occursOnDT &lt; saveOccursOnDT then
				// for a departure the occursOnDT is the actual departure time
			else
			endif;
		endif;
		if self.steamingTimeLocked then
		endif;
	endif;*/
	//jlgka1 TFS 45620 &lt;--
	
	if prevMove &lt;&gt; null then
		// Need to determine earliest possible time for this move based on the
		// previous move.  Need to do this BEFORE doing any updates as some of
		// the values here are virtuals.
		if self.moveType = HMSMovementTypeDeparture then
			// For a departure movement the occursOnDT is set to the "Depart from From Berth time" so
			// earliest possible time of departure is the arrival at from region time + min residence time
			
			//jlgka1 TFS 45620 --&gt;
			//earliestPossibleTS := self.arrivalTimeAtFromRegion.addMinutes(self.minWaitingTime); 
			earliestPossibleTS := self.arrivalTimeAtFromRegion; 
			//jlgka1 TFS 45620 &lt;--
		else
			if prevMove.moveType = HMSMovementTypeDeparture then
				//if self.isArrivalDirect or self.isArrivalDirectFromOtherHarbor then   //jlgka1 TFS 45620
				if self.isArrivalDirectFromOtherHarbor then								//jlgka1 TFS 45620
					// the steaming time on the departure movement is the same as the
					// steaming time on this movement
					if _calculateSteamingTime then
						// this move can occur immediately after departure from prev region
						// always allow for a steaming time of 1 min
						earliestPossibleTS := prevMove.departureTimeFromFromRegion.addMinutes(1);
					else
						// in this case self.steamingTime and prevMove.steaming time should be the same
						earliestPossibleTS := prevMove.departureTimeFromFromRegion.addMinutes(prevMove.steamingTime);
					endif;
				else
					// there is an intermediate waypoint (e.g. Weipa-depart to Torres to Gladstone-arrival)
					if _calculateSteamingTime then
						// take the arrival time at the prev region + waiting time
						earliestPossibleTS := prevMove.arrivalTimeAtToRegion.addMinutes(prevMove.waitingTime);
					else
						// Add prevMove details to self.steamingTime to get the earliest time.
						earliestPossibleTS := prevMove.arrivalTimeAtToRegion.addMinutes(prevMove.waitingTime + self.steamingTime);
					endif;
				endif;
			else
				// For all other movements the occursOnDT is set to the "Arrival at To Berth time" so
				// earliest possible time of movement is the departure from the prev location + steaming time.
				//earliestPossibleTS := prevMove.arrivalTimeAtToRegion.addMinutes(self.waitingTime);
				earliestPossibleTS := prevMove.arrivalTimeAtToRegion.addMinutes(prevMove.waitingTime);
				if _calculateSteamingTime then
					// we always force a steaming time of at least 1 minute
					earliestPossibleTS := earliestPossibleTS.addMinutes(1);
				else
					earliestPossibleTS := earliestPossibleTS.addMinutes(self.steamingTime);
				endif;
			endif;
		endif;

		if _occursOnDT &lt; earliestPossibleTS then
//			process.debug;
//			app.raiseCMException1(Full_Replacement_Message, 'You cannot set the time for the movement from ' &amp;
//						self.getFromLocationDescr &amp; ' to ' &amp; self.getToLocationDescr &amp; ' on ' &amp;
//						saveOccursOnDT.asStringJMT &amp; ' to be ' &amp; _occursOnDT.asStringJMT &amp; '. The earliest ' &amp;
//						'time for this movement is ' &amp; earliestPossibleTS.asStringJMT &amp; '.', null, null);
		endif;
	else
		earliestPossibleTS := null;
	endif;
	
	if self.moveType = HMSMovementTypeArrival
	or self.moveType = HMSMovementTypeShift
	or self.moveType = HMSMovementTypePassage
	then
		
		/* do validataion at end as some dependancies here which can only be resolved once all
		   the updates have been done (prevMove.departureTimeFromFromRegion depends on prevMove.steamingTime
		   which can get updated from here by adjustment to arrival time for a voyage).
		*/
		
		self.setOccursOnDT(_occursOnDT);
		
		if prevMove &lt;&gt; null then
			if self.moveType = HMSMovementTypeArrival and
			   isFirstForGlobalVoyage then
				if _occursOnDT &lt;&gt; prevMove.arrivalTimeAtToRegion and
				   prevMove.isTransient() = self.isTransient() then
					// In this case we need to update the steaming time on the previous movement.  Pass 
					// through the arrival time here and it will calculate what the steaming time should 
					// be set to.
					
					//prevMove.setDeptSteamTimeFromNextVoy(_occursOnDT); // jlgka1 TFS 45620
				endif;
			endif;
		
			
			if self.moveType &lt;&gt; HMSMovementTypeShift	// 20/03/2008 cnwar2 #16216, shouldn't do this check if shift movement as steaming time will always be 0
			and newSteamingTime &lt;= 0 then
			
				if saveOccursOnDT = _occursOnDT then	//03 Jun 2020	NDL	TFS 49417
					//this is OK, its not actually changing.
				elseif _occursOnDT &gt; earliestPossibleTS then	//03 Jun 2020	NDL	TFS 49417
					//based on the error message this would be OK too.
				else
				
					app.raiseCMException6(Canno_time_movem_voyag_from_ea, 
							tmpVoyageCode, self.getFromLocationDescr, self.getToLocationDescr, saveOccursOnDT.asStringJMT, _occursOnDT.asStringJMT, earliestPossibleTS.asStringJMT,
							null, null);
					return;
				endif;
			endif;
		endif;
		//jlgka1 TFS 45620 --&gt;
		/*if _isDoingRecalc and
		   self.steamingTimeLocked and 
		   self.steamingTime &lt;&gt; newSteamingTime then
			app.raiseUnexpectedProgramError(class.name, method.name, 
					'Cannot update locked steaming time for movement during a recalc (' &amp; self.String &amp; ')');
		else*/
			self.steamingTime := newSteamingTime;
			
			//if self.isArrivalDirect and prevMove &lt;&gt; null then 			//jlgka1 TFS 45620
			if prevMove &lt;&gt; null then										//jlgka1 TFS 45620
				// for arrival direct the steaming time on the matching
				// departure movement must be kept in sync with the
				// steaming time on the arrival movement
				prevMove.setStreamingTime(newSteamingTime);
			endif;
		//endif;
		//jlgka1 TFS 45620 &lt;--
		
		if isFirstForGlobalVoyage and 
		   self.myVoyageGlobal &lt;&gt; null and
		   self.myVoyageGlobal.isTransient = self.isTransient() then
			self.myVoyageGlobal.setArrivalDT(self.occursOnDTNEW);
		endif;
	
	elseif self.moveType = HMSMovementTypeDeparture then
		self.setOccursOnDT(_occursOnDT);
		self.steamingTime := newSteamingTime;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled moveType (' &amp; self.moveType &amp; ')');
	endif;

	/////
	// Need to calculate the waitingTime in here as a call to self.waitingTime will
	// relies on position in CM_VoyageGlobal.allMovements dict by date.
	// refer comment above for setting of isFirstForGlobalVoyage
	//if self.isArrivalDirect or self.isArrivalDirectFromOtherHarbor() then		//jlgka1 TFS 45620
	if self.isArrivalDirectFromOtherHarbor() then								//jlgka1 TFS 45620
		// in this case the waiting is accounted for on
		// the departure movement
	elseif prevMove &lt;&gt; null then
		if isFirstForGlobalVoyage then
			tmpWaitingTime := prevMove.waitingTime;
		else
			prevArriveAtToDT := prevMove.arrivalTimeAtToRegion;
			departFromDT := self.departureTimeFromFromRegion;
			tmpWaitingTime := prevArriveAtToDT.getDifferenceInMinsFromTo(departFromDT);
		endif;
	
	/////
	
		// Having done all adjustments then do a validation check
		if tmpWaitingTime &lt; 0 then
//process.debug;
			/*app.raiseCMException1(Full_Replacement_Message, 'You cannot set the time for the movement on ' &amp;
						' voyage ' &amp; tmpVoyageCode &amp; ' from ' &amp;
						self.getDescription &amp; ' on ' &amp;
						saveOccursOnDT.asStringJMT &amp; ' to be ' &amp; _occursOnDT.asStringJMT &amp; '. The earliest ' &amp;
						'time for this movement is ' &amp; earliestPossibleTS.asStringJMT &amp; '.', null, null);*/ //- cnwmd1, Par 20524
						app.raiseCMException5(Cnnt_time_movmt_voyag_frm_earl, 
						tmpVoyageCode, self.getDescription, saveOccursOnDT.asStringJMT, _occursOnDT.asStringJMT, earliestPossibleTS.asStringJMT,
						null, null);
			return;
		//jlgka1 TFS 45620 --&gt;	
		/*elseif tmpWaitingTime &lt; self.minWaitingTime then*/
			/*app.raiseCMException1(Full_Replacement_Message, 'You cannot set the time for the movement on ' &amp;
						' voyage ' &amp; tmpVoyageCode &amp; ' from ' &amp;
						self.getDescription &amp; ' on ' &amp; saveOccursOnDT.asStringJMT &amp; ' to be ' &amp; 
						_occursOnDT.asStringJMT &amp; '. The mimimum residence ' &amp; ' time at ' &amp; 
						self.getFromLocationDescr &amp; ' is ' &amp; self.minWaitingTime.asDaysHoursMinutesString &amp; 
						'. The earliest time for this movement is ' &amp; earliestPossibleTS.asStringJMT &amp; '.', null, null); */ //- cnwmd1, Par 20524
			/*app.raiseCMException7(Canno_time_movem_voyag_from_mi, 
						tmpVoyageCode, self.getDescription, _occursOnDT.asStringJMT, self.getFromLocationDescr, self.minWaitingTime.asDaysHoursMinutesString, earliestPossibleTS.asStringJMT, saveOccursOnDT.asStringJMT,
						null, null);
			return;*/
		//jlgka1 TFS 45620 &lt;--
		elseif tmpWaitingTime = 0 and prevMove.isForTerminal then
//process.debug;
			/*app.raiseCMException1(Full_Replacement_Message, 'Cannot have a zero waiting time at (' &amp; 
					_occursOnDT.asStringJMT &amp; ') at terminal (' &amp;
					prevMove.getTerminal.code &amp; ') for voyage ' &amp; tmpVoyageCode, null, null);*/ //- cnwmd1, Par 20524
			app.raiseCMException3(Canno_have_zero_waiti_time_ter, 
					_occursOnDT.asStringJMT, prevMove.getTerminal.code, tmpVoyageCode,
					null, null);
		endif;
	
	endif;


end;</source>
        <Parameter name="_occursOnDT" type="TimeStamp"/>
        <Parameter name="_steamingTime" type="Integer"/>
        <Parameter name="_calculateSteamingTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTimingsForward" id="c05abeac-766d-4851-bcb2-ea41de097128">
        <updating/>
        <source>setTimingsForward(_occursOnDT : TimeStamp; _steamingTime : Integer; _calculateSteamingTime : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     22 November 2007 by cnwrs2
//
// Purpose:     
/* Changes

Date		Name	TFS#		Description
============================================================================
18/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	nextMove	: HMS_Movement;
	diff		: Integer;
	oldDT		: TimeStamp;
begin

	if (self.occursOnDTNEW.isValid) then
		diff := self.occursOnDTNEW.getDifferenceInMinutes(_occursOnDT); //only gives positive value
		
		if _occursOnDT &lt; self.occursOnDTNEW then
			diff := -diff;
		endif;
	endif;
	
	oldDT := self.occursOnDTNEW;

	self.setTimings(_occursOnDT, _steamingTime, _calculateSteamingTime); // jlgka1 TFS 45620

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' ' &amp; self.getVoyageCode &amp; '  ' &amp; self.getDescription &amp; 
		' updating from ' &amp; oldDT.asStringJMT &amp; ' to ' &amp;
		self.occursOnDTNEW.asStringJMT &amp; ' diff ' &amp; diff.String, LogERROR);

	nextMove := self.myNextMovement;

	if diff &lt;&gt; 0 and 
	   nextMove &lt;&gt; null and 
	   nextMove.isTransient() = self.isTransient() then
		// we adjust the next movement occurs on DT by the same
		// time as we have adjusted this one.
		
		nextMove.setOccursOnFromTimeDiff(diff); // jlgka1 TFS 45620

		if nextMove.occursOnDTNEW &lt; self.occursOnDTNEW then
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' ***** ERROR HERE updating next to wrong value!  ' &amp; 
						self.occursOnDTNEW.String &amp; '   ' &amp; nextMove.occursOnDTNEW.String);
		endif;

	elseif diff &lt;&gt; 0 and nextMove &lt;&gt; null then
		
	endif;
end;</source>
        <Parameter name="_occursOnDT" type="TimeStamp"/>
        <Parameter name="_steamingTime" type="Integer"/>
        <Parameter name="_calculateSteamingTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="d7e3db7a-11f1-4ccd-81c3-e2bacb7508a0">
        <source>validateMe(_passport: CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		02 October 2008 by cnwdad1
//
// Purpose:		Standard method to validate the receiver when updated thru a transaction.
//
// Parameters:	_passport - A reference to the current User's passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	lastDT		: TimeStamp;
	interval	:CM_TimeStampInterval;
	startDT, endDT	: TimeStamp;
	count :Integer;
begin
	inheritMethod(_passport);
	
	// cnwdad1 13/10/2008 - PAR #17701.
	// The rules are that either the first and last date/time can be entered, otherwise
	// all four dates/times must be entered, or none at all should be entered.	
	lastDT := null;
	
	foreach interval in self.allCargoOperationsIntervals do
		startDT	:= interval.startDT;
		endDT	:= interval.endDT;
		count	:= count + 1;
		
		// both start and end date/time must be entered
		if startDT = null or endDT = null then
			// from A to B - Both start and end cargo operations times must be entered must be entered
			app.raiseCMException (Cargo_Ops_DateTime_Invalid, null, null);
			break;
		endif;			
		// start and end date/times must both be valid
		if startDT &lt;&gt; null and not startDT.isValid then
			// from A to B - Start cargo operations date is not valid
			app.raiseCMException (Cargo_Ops_DateTime_Invalid, null, null);
			break;
		endif;
		
		if endDT &lt;&gt; null and not endDT.isValid then
			// from A to B - End cargo operations date is not valid
			app.raiseCMException (Cargo_Ops_DateTime_Invalid, null, null);
			break;
		endif;
		// start date.time must be less than end date/time
		if endDT &lt;= startDT then
			// from A to B - End cargo operations date/time must be after start cargo operations date/time
			app.raiseCMException1 (EndBeforeStart, endDT.asStringJMT, null, null);
			break;
		endif;
		// start date/time must be greater than or equal to the previous end date/time (no overlaps)
		if lastDT &lt;&gt; null and startDT &lt;= lastDT then
			// overlap - even across movements
			// from A to B - Cargo operations date/time overlaps previous date/time
			app.raiseCMException (Cargo_Ops_DateTime_Invalid, null, null);
			break;
		endif;
		lastDT := endDT;
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateTimings" id="01bd61f2-b3c5-4b5b-b3a4-2729c88f7473">
        <source>validateTimings();
// --------------------------------------------------------------------------------
// Created:		20 November 2007 by cnwdad1
//
// Purpose:		Validates the receiver's timings.  If any discrepancies are found,
//				they will be reported.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	prevMove	: HMS_Movement;
	
begin
	prevMove := self.myPreviousMovement;
	
	if not self.arrivalTimeAtFromRegion.isValid() then
		if prevMove &lt;&gt; null then
			app.writeStatement( 'tmpMove.arrivalTimeAtFromRegionnot valid');
		endif;
	endif;
	
	if prevMove &lt;&gt; null then
		if self.isSameVoyageGlobal(prevMove) then
			if prevMove.arrivalTimeAtToRegion &lt;&gt; self.arrivalTimeAtFromRegion then
				app.writeStatement( 'MisMatch &gt;&gt; prevMove.arrivalTimeAtToRegion ' &amp; prevMove.arrivalTimeAtToRegion.String &amp; ' &lt;&gt; self.arrivalTimeAtFromRegion ' &amp; self.arrivalTimeAtFromRegion.String); 
			
			endif;
		else
			// need some other check here
		endif;
	endif;

	if self.arrivalTimeAtFromRegion.isValid()
	and self.arrivalTimeAtFromRegion.cnEcAddMinutes(self.waitingTime + self.steamingTime) &lt;&gt; self.arrivalTimeAtToRegion
	then
		app.writeStatement( self.moveType &amp; Tab &amp; self.myVoyageGlobal.code &amp; Tab &amp; self.String);
		app.writeStatement( "ArrivalTime at A plus waiting/steaming time does not match arrivalTime at B - " &amp; 
			self.arrivalTimeAtFromRegion.String &amp; " + " &amp; (self.waitingTime + self.steamingTime).String &amp; 
			' (' &amp; self.arrivalTimeAtFromRegion.cnEcAddMinutes(self.waitingTime + self.steamingTime).String &amp; ') ' &amp;
			" should = " &amp; self.arrivalTimeAtToRegion.String);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validate_OccursOnDT" id="5c54cbc7-2e34-404e-a102-ad79d6ed252a">
        <source>validate_OccursOnDT(_passport: CM_Passport input);
//-----------------------------------------------------------------------
//	Created:	27 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	date			: Date;
	time			: Time;
	now				: TimeStamp;
	prevMovement	: HMS_Movement;
begin

 	date := self.occursOnDTNEW.date;
 	time := self.occursOnDTNEW.time;
 	if (not date.isValid) then
 	//	app.raiseCMException1(REQUIRED_FIELD, self.moveType &amp; ' Movement Date', ETRow_OccursOnDate, null);
		app.raiseCMException1(Input_required_field_moveDate, self.moveType, ETRow_OccursOnDate, null); // cnwdb2	PAR 35364
 	endif;
 	if (not time.isValid) then
 	//	app.raiseCMException1(REQUIRED_FIELD, self.moveType &amp; ' Movement Time', ETRow_OccursOnTime, null);
		app.raiseCMException1(Input_required_field_moveTime, self.moveType, ETRow_OccursOnTime, null); // cnwdb2	PAR 35364
 	endif; 	

	if _passport.hasErrors() then
		return;
	endif;
	
 	if date &lt; '01/01/1900'.Date then
 		app.raiseCMException1(AutoScheduleDateError, 'Movement Date prior the year 1900', ETRow_OccursOnDate, null);
 	elseif date &gt; '01/01/2999'.Date then
 		app.raiseCMException1(AutoScheduleDateError, 'Movement Date after the year 2999', ETRow_OccursOnDate, null); 		
 	endif; 	

	if _passport.hasErrors() then
		return;
	endif;

 	if date &lt; now.date then
 		//Not applicable here, used in graphical view only
 		//app.raiseCMWarning2(HMSMovementActualDT, self.moveType, self.occursOnDT.shortCurrentLocaleFormat(), ETRow_OccursOnDate, null, null);
 	elseif date &gt; now.date.cnEcAddYears(5) then
 		app.raiseCMWarning2(HMSMovementInFuture, self.moveType, '5', ETRow_OccursOnDate, null, self); 		
 	endif; 	
	
	// extra validation for waiting time steaming time type movements
	if self.isMovementTypeArrival then
		prevMovement := self.getMovementPreviousGlobal();
		if prevMovement &lt;&gt; null then
			if self.occursOnDTNEW &lt; prevMovement.occursOnDTNEW then
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate_SteamingTime" id="6d4fca82-0b68-467f-8520-b960d39e6a40">
        <source>validate_SteamingTime(_raiseWarning : Boolean; _errorInfo:String output):Boolean;
// --------------------------------------------------------------------------------
// Created:		03 March 2008 by cnwdad1
//
// Purpose:		Checks whether the receiver's Steaming is greater than or equal to
//				the minimum steaming time for the relevant Path Segment.
//
// Parameters:	_raiseWarning - True if a warning only should be raised, rather then
//					an exception.
//				_errorInfo - Specific information pertinant to any errors/warnings.
//
// Returns:		True if the Vessel is available, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	prevMoveObj		: HMS_Movement;
	regionToObj		: HMS_HarbourRegion;
	regionFromObj	: HMS_HarbourRegion;
	vesselObj		: CM_Vessel;
	minSteamTime	: Integer;
	
begin
	prevMoveObj		:=	self.getMovementPrevious();
	
	if prevMoveObj = null then
		return true;
	endif;

	vesselObj	:=	self.getMyVessel();

	regionToObj		:=	self.getHarbourRegion();
	regionFromObj	:=	prevMoveObj.getHarbourRegion();
	/*
		Date	Who		Reason
	 8 sep 2008	cnwdz2	Par17319
	*/
	if regionFromObj &lt;&gt; null then
		minSteamTime	:=	regionFromObj.getMinimumSteamingTime(regionToObj, vesselObj);
		
		if self.steamingTime &lt; minSteamTime then
			_errorInfo	:=	"Movement details: " &amp; self.getDescription() &amp; " - Time is " &amp; self.steamingTime.asStringJMT() &amp; ", Minimum is " &amp; minSteamTime.asStringJMT();
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <Parameter name="_errorInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="waitingTime" id="76883e18-1b88-4339-913e-a9500a2590db">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>waitingTime(set : Boolean; _value : Integer io) updating, mapping;
//-----------------------------------------------------------------------
//	Created:	04 December 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
29/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	prevMove	: HMS_Movement;
	prevArriveAtToDT,
	departFromDT	: TimeStamp;
begin
//----------------------------------------------------------------
// IMPORTANT:  Any changes to this method may also need to be made
//             to the method HMS_Movement::getWaitingTimeForDepartureDate
//----------------------------------------------------------------

	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := 0;
		//jlgka1 TFS 45620 --&gt;
		/*if self.isArrivalDirect then
			// in this case the waiting is accounted for on
			// the departure movement
			return;
		endif;*/
		//jlgka1 TFS 45620 &lt;--
		
		prevMove := self.myPreviousMovement;
		if prevMove &lt;&gt; null then
			if self.isFirstMovementForGlobalVoyage then
				_value := prevMove.waitingTime;
			else
				prevArriveAtToDT := prevMove.arrivalTimeAtToRegion;
				departFromDT := self.departureTimeFromFromRegion;
				_value := prevArriveAtToDT.getDifferenceInMinsFromTo(departFromDT);
				//if prevArriveAtToDT &gt; departFromDT then
					// This should never happen. getDifferenceInMinutes always returns a +ve number
					// Change to a -ve to highlight a problem
				//	_value := -(_value);
				//endif;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
