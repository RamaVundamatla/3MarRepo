    <JadeMethod name="kpdSetTerminalTimezone" id="c7524637-c30b-41c9-a2fa-d0b58b30a690">
        <source>kpdSetTerminalTimezone();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

constants
	TimezoneID		= "GMT Standard Time";
	ShortTZID		= "GMT";
	
vars
	t				: CM_Terminal;
	
begin
	t := CM_Root.firstInstance.allTerminals['ITS'];
	
	beginTransaction;
	t.setTimeZoneID(TimezoneID);
	t.setPropertyValue(CM_Terminal::timeZoneShortID.name, ShortTZID);
	commitTransaction;
	
epilog

end;</source>
