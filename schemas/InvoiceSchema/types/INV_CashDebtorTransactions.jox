/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	obj : Object;
	objArray : ObjectArray;

begin

	obj := menuItem.userObject;
	
	if obj &lt;&gt; null and CM_TrackedItem.hasInstance(obj) then
		create objArray transient;
		objArray.add(obj);
		self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, false);
	endif;

epilog

	delete objArray;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectDebtor" id="f659283c-a7c9-4310-89dc-c529ef47a9a3">
        <updating/>
        <source>selectDebtor() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation
// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
18/10/2017	MAP		Added tax column	TFS7357
27/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

vars

	drTerm 			: CM_DebtorTerminal;
	cash 			: CM_Cash;
	allCashTrx 		: CM_CashDict;
	dateStr 		: String;
	expandContract 	: String;
	typeString 		: String;
	amount 			: Decimal[23,6]; //[16,4]; // TFS 47529
	amountString 	: String;
	balance 		: Decimal[23,6]; //[16,4]; // TFS 47529
	balanceString 	: String;
	tableLine 		: String;
	index 			: Integer;
	includeArchived : Boolean;
	tax				: Decimal[23,6]; //[16,4]; // TFS 47529
	taxString		: String;
	creditDetail	: CM_CashCreditDetail;
	cashPayment		: CM_CashPayment;

begin

	self.tblCash.rows := self.tblCash.fixedRows;
	self.tblCash.setCellText( self.tblCash.fixedRows, 1, " " &amp; Tab &amp; " "  &amp; Tab &amp; " "  &amp; Tab &amp; " "  );
	
	self.showServiceTax := (self.myTerminal.getConfig(CashAllCashTax).String = null) and self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	self.tblCash.accessColumn(4).visible := self.showServiceTax;			// 18/10/17 MAP TFS7357

	drTerm := self.cmbDebtors.listObject.CM_DebtorTerminal;
	if drTerm = null then
		return;
	endif;
	
	includeArchived := self.chkIncludeArch.value;
	create allCashTrx transient;
	
	if not includeArchived then
		if drTerm.consolidatedBalance &lt;&gt; 0 then
			self.tblCash.setCellText( self.tblCash.fixedRows, 1, " " &amp; Tab &amp; app.getErrorString(Balance_brought_forward)  &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp;  drTerm.consolidatedBalance.asCurrencyJMT  );
			balance := drTerm.consolidatedBalance;
		else
			self.tblCash.setCellText( self.tblCash.fixedRows, 1, " " &amp; Tab &amp; app.getErrorString(Opening_balance) &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; "0.00".Decimal.asCurrencyJMT  );
		endif;
	else
		self.tblCash.setCellText( self.tblCash.fixedRows, 1, " " &amp; Tab &amp; app.getErrorString(Opening_balance) &amp; Tab &amp; " " &amp; Tab &amp; " " &amp; Tab &amp; "0.00".Decimal.asCurrencyJMT  );
		if not drTerm.allConsolidatedCashTrx.isEmpty then
			drTerm.allConsolidatedCashTrx.copy( allCashTrx );
		endif;
	endif;
	
	if not drTerm.allCashReceipts.isEmpty then
		drTerm.allCashReceipts.copy( allCashTrx );
	endif;
	if not drTerm.allCashPayments.isEmpty then
		drTerm.allCashPayments.copy( allCashTrx );
	endif;

	// 37141
	if not drTerm.allCashCredits.isEmpty then
		drTerm.allCashCredits.copy( allCashTrx );
	endif;
	
	foreach cash in allCashTrx do
	
		if cash.isKindOf(CM_CashPayment) and cash.CM_CashPayment.myCashPaymentForInvoice &lt;&gt; null then	// is tax, skip
			continue;
		endif;

		amount := 0;
		tax := 0;

		dateStr := cash.systemToLocalTime(cash.dateTime).asStringJMT;// 14 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		if self.showServiceTax then
			if cash.isKindOf(CM_CashReceipt) then
				amount := cash.CM_CashReceipt.totalCargoCharges;
				tax := cash.CM_CashReceipt.taxValue1 + cash.CM_CashReceipt.taxValue2 + cash.CM_CashReceipt.taxValue3;
			elseif cash.isKindOf(CM_CashPayment) then
				amount := -cash.cashValue;
				if cash.CM_CashPayment.myCashPaymentForTax &lt;&gt; null then
					tax := -cash.CM_CashPayment.myCashPaymentForTax.cashValue;
				endif;
			elseif cash.isKindOf(CM_CashCredit) then
				foreach creditDetail in cash.CM_CashCredit.allDerivedFromCreditDetails where creditDetail.myCashPayment &lt;&gt; null do
					cashPayment := creditDetail.myCashPayment;
					if cashPayment.myCashPaymentForInvoice &lt;&gt; null then
						tax := tax + creditDetail.cashValue;
					elseif cashPayment.myCashPaymentForTax &lt;&gt; null then
						amount := amount + creditDetail.cashValue;
					endif;
				endforeach;
			elseif cash.isKindOf(CM_CashCreditDetail) then
				creditDetail := cash.CM_CashCreditDetail;
				cashPayment := creditDetail.myCashPayment;
				if cashPayment &lt;&gt; null then
					if cashPayment.myCashPaymentForTax &lt;&gt; null then
						amount := cashPayment.cashValue;
						tax := cashPayment.myCashPaymentForTax.cashValue;
					endif;
				endif;
			else
				amount := cash.cashValue;
			endif;
		else
			amount := cash.getAmountForBalanceTotal(drTerm);
		endif;
		typeString := cash.getTypeString(drTerm).replaceString(Tab, " ");		// 33688 stop Tab moving some of the text into the next cell
		amountString := amount.asCurrencyJMT;
		
		// TFS 7357 do not include the tax in the running balance if using tax per invoice line because each tax cash payment is being shown.
//		if not  cash.isKindOf(CM_CashReceipt) // TFS 7357
//		and self.showServiceTax then // TFS 7357
//			balance := balance + amount; 
//		else
			balance := balance + amount + tax;
//		endif;

		balanceString := balance.asCurrencyJMT;
		taxString := tax.asCurrencyJMT();
		
		tableLine := dateStr &amp; Tab
					&amp; typeString &amp; Tab
					&amp; amountString &amp; Tab
					&amp; taxString &amp; Tab
					&amp; balanceString;
					
		index := self.tblCash.addItem( tableLine );
		self.tblCash.accessRow(index).itemObject := cash;
		
		//31 Jan 2014	NDL	Par 33181 - currency delimiters were upsetting the table.
		self.tblCash.setCellText(index,1,dateStr);
		self.tblCash.setCellText(index,2,typeString);
		self.tblCash.setCellText(index,3,amountString);
		self.tblCash.setCellText(index,4,taxString);
		self.tblCash.setCellText(index,5,balanceString);
		
		if includeArchived then
			if cash.isArchived(drTerm) then
				self.tblCash.accessRow(index).backColor := LightGray;
			endif;
		endif;
		if cash.isKindOf(CM_CashReceipt) then // TFS 7357	
			self.tblCash.accessRow(index).backColor := LightYellow; // TFS 7357	
		endif;
		
	endforeach;
	
	dateStr := self.systemToLocalTime(app.actualTimeServer).asStringJMT;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	tableLine := dateStr &amp; Tab
				// 33885 no pre-payments, change the text to 'Closing balance'
				&amp; "Closing Balance" &amp; Tab
				//&amp; app.getErrorString(Unallocated_balance) &amp; Tab
				&amp; " " &amp; Tab
				&amp; " " &amp; Tab
				&amp; balanceString;
				
	index := self.tblCash.addItem( tableLine );
	self.tblCash.accessRow(index).backColor := self.tblCash.accessCell(index,1).backColor;
	
epilog

	delete allCashTrx;

end;</source>
    </JadeMethod>
    <JadeMethod name="setInitialControlValues" id="38be19f3-4f8f-44aa-adcc-5f50a9c8d4d1">
        <updating/>
        <source>setInitialControlValues() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation	Par 29968
18/10/2017	MAP		Added tax column	TFS7357
*/

vars

	drTerm : CM_DebtorTerminal;
	index : Integer;
	headings : String;

begin

	self.setNavigatorHeading( self.caption );

	self.frmMain.borderStyle := 0;
	self.frmMain.top := 0;
	self.frmMain.left := 0;
	
	self.frmTables.borderStyle := 0;
	
	self.minimumHeight := 400;
	self.minimumWidth := 550;
	
	self.cmbDebtors.clear();
	foreach drTerm in self.myTerminal.allDebtorTerminals discreteLock do
		if drTerm.isCashOnly then
			index := self.cmbDebtors.addItem( drTerm.myDebtor.name);
			self.cmbDebtors.itemObject[ index ] := drTerm;
		endif;
	endforeach; 
	
	self.tblCash.rows := 1;
	self.tblCash.fixedRows := 2;
	self.tblCash.columns := 5;
	self.tblCash.fixedColumns := 0; // TFS 7357
	self.tblCash.selectMode := Table.SelectMode_WholeRows; // TFS 7611
	self.tblCash.alignment := Table.Alignment_Left_Top;
	self.tblCash.accessColumn(2).alignment := Table.Alignment_Left_Top;
	self.tblCash.accessColumn(3).alignment := Table.Alignment_Right_Top;
	self.tblCash.accessColumn(4).alignment := Table.Alignment_Right_Bottom;
	self.tblCash.accessColumn(4).visible := false;
	self.tblCash.accessColumn(5).alignment := Table.Alignment_Right_Bottom;
	self.tblCash.accessCell(1,3).alignment := Table.Alignment_Left_Top;
	self.tblCash.accessCell(1,4).alignment := Table.Alignment_Left_Top;
	self.tblCash.accessCell(1,5).alignment := Table.Alignment_Left_Top;
	headings := app.getErrorString(DateStr) &amp; Tab &amp; app.getErrorString(CM_Type) &amp; Tab &amp; app.getErrorString(Amount) &amp; Tab &amp; app.getErrorString(Tax) &amp; Tab &amp; app.getErrorString(Balance);
	self.tblCash.setCellText(1,1,headings);
	self.tblCash.accessRow(1).fontBold := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="dcd7e60e-bc9e-4740-9bbd-20b94edfe3eb">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation	par 29968

*/

vars

begin

	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.mnuContext.visible :=false;
	inheritMethod();
	
	if not self.myTerminal.isCashOnlyEnabled then
		self.unloadForm;
		return;
	endif;
	
	self.setInitialControlValues();
	
	self.beginClassNotification(CM_CashReceipt, false, Any_System_Event, Response_Continuous, null);
	self.beginClassNotification(CM_CashPayment, false, Any_System_Event, Response_Continuous, null);
	
	self.addToolbarControls();
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnArchive.enabled := false;
		self.btnRefund.enabled:= false;
		self.btnTransfer.enabled:= false;
	endif;

	self.chkIncludeArch.visible := false; // TFS 45953
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showCashReceipt" id="f0945d79-5cda-4bb9-9e73-7287c3debb0f">
        <source>showCashReceipt(_receipt : CM_CashReceipt) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 January 2014	cnwjre1	Initial creation

*/

vars
	newForm : INV_CashReceiptList;

begin
	// TFS 45953 NEW CASH COLLECTION
	create newForm transient;
	newForm.myTerminal := self.myTerminal;
	newForm.myQueryCashReceipt := _receipt;
	newForm.show();
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_receipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="b4b05cfb-e01d-4cd4-a010-797203ac47ef">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2012	cnwndl1	Initial creation

*/

vars

begin
	
	self.handleNotifications(eventType, theObject, eventTag, null);

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblCash_click" id="86efa87e-1fa0-400d-9bac-ce1deecfdcb0">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCash_click(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2012	cnwndl1	Initial creation

*/

vars

	cash : CM_Cash;

begin

	self.btnPrintRec.enabled := false;
	cash :=  table.accessRow(table.row).itemObject.CM_Cash;
	if cash &lt;&gt; null and app.isValidObject(cash) and ( cash.isPayment or cash.isReceipt ) then
		self.btnPrintRec.enabled := true;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCash_contextMenu" id="86506734-76c9-4ead-821c-126320791d98">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCash_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2012	cnwndl1	Initial creation

*/

vars

begin

	if self.doMnuContextBuild(table, conwin, mouse, x, y) then
		return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);
	else
		return false;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7cb25158-e1b2-45e3-be33-c3a9977229e8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 February 2016.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018166, locale);
	btnArchive.translateBubbleHelp(Xlat_0018167, locale);
	btnArchive.translateCaption(Xlat_0018168, locale);
	btnClose.translateCaption(Xlat_0018169, locale);
	btnExportCSV.translateBubbleHelp(Xlat_0018170, locale);
	btnExportCSV.translateCaption(Xlat_0018171, locale);
	btnPrintRec.translateBubbleHelp(Xlat_0018172, locale);
	btnPrintRec.translateCaption(Xlat_0018173, locale);
	btnPrintTbl.translateBubbleHelp(Xlat_0018174, locale);
	btnPrintTbl.translateCaption(Xlat_0018175, locale);
	btnRefund.translateBubbleHelp(Xlat_0018178, locale);
	btnRefund.translateCaption(Xlat_0018179, locale);
	btnTransfer.translateBubbleHelp(Xlat_0018180, locale);
	btnTransfer.translateCaption(Xlat_0018181, locale);
	chkIncludeArch.translateCaption(Xlat_0018182, locale);
	lblCashDebtor.translateCaption(Xlat_0018183, locale);
	mnuCashReceipt.translateCaption(Xlat_0019465, locale);
	mnuContext.translateCaption(Xlat_0018184, locale);
	mnuInspect.translateCaption(Xlat_0018186, locale);
	mnuInvoice.translateCaption(Xlat_0018187, locale);
	mnuPrintCredit.translateCaption(Xlat_0021161, locale);
	mnuPrintPayRec.translateCaption(Xlat_0018188, locale);
	mnuPrintReceipt.translateCaption(Xlat_0018189, locale);
	mnuShowCargo.translateCaption(Xlat_0018190, locale);
end;</source>
    </JadeMethod>
