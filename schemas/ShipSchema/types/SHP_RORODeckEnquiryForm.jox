    <JadeMethod name="setupForm" id="24287a75-14fa-4ba4-814c-6df56440bdb9">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin


	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	
	self.mnuInspect.visible:=app.isAllowedToInspect;
	
	self.setupRoRoDeckTable();
	self.loadRoRoDeckTable();
	
	self.startNotes();
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnDeleteDeck.enabled := false;
		self.btnEditDeck.enabled := false;
		self.btnImportXML.enabled := false;
		
		self.btnNewDeck.enabled := false;
		self.btnNewSubDeck.enabled := false;
		self.btnCopyDeck.enabled := false;
		self.btnROROConfig.enabled := false;
		self.mnuCopyDeck.enabled := false;
		self.mnuDeleteDeck.enabled := false;
		self.mnuEditDeck.enabled := false;
		self.mnuImportXML.enabled := false;
		self.mnuNewDeck.enabled := false;
	endif;

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupRoRoDeckTable" id="9a770329-dc5e-4ecd-8cd9-74dd1a17f843">
        <source>setupRoRoDeckTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	entDef : EntTableDef;
begin

	self.tbRoRolDecks.fixedRows:=1;
	self.tbRoRolDecks.multiSelect:=CM_BaseTable.MultiSelect_Simple;
	self.tbRoRolDecks.selectMode:= Table.SelectMode_WholeRows;
	self.tbRoRolDecks.selectionType := CM_BaseTable.SelectionType_Row ;
	self.tbRoRolDecks.disallowColumnSorter	:=	true;
	entDef := app.myController.getEntTableDef(ETDef_RoRoDeckEnquiry);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ETDef_RoRoDeckEnquiry not found');
		return;
	endif;
	
	self.tbRoRolDecks.setTblDataEntRowsFromDef(entDef);

	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
