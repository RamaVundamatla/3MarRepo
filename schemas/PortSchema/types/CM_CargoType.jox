        <source>isUserDefinedAndHandledAs(_productType:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		06 October 2010
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a User-Defined
//				Cargo Type, and whether it is handled as the specified Product Type.
//
// Parameters:	_productType - The Product Type that the receiver is handled as.
//
// Returns:		True if the receiver is User-Defined and is halded as the specified
//				Product Type, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
// --------------------------------------------------------------------------------
begin
	if self.id &gt; TI_CargoBOLType_Max and self.productType = _productType then
