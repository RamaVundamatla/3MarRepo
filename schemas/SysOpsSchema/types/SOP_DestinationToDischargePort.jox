    <JadeMethod name="doResize" id="3991e22f-24d1-4c01-9937-203f982dacbf">
        <updating/>
        <source>doResize() updating;

vars
	x, y : Real;
begin
	if self.frmToolbar.visible then
		self.frmToolbar.repositionAfterResize;
	endif;
//	y := ((self.clientHeight + self.frmToolbar.height - self.frmCenter.height) / 2).max(self.frmToolbar.height);
	y := ((self.tblOperShipLine.height + self.frmToolbar.height));// - self.frmCenter.height) / 2);//.max(self.frmToolbar.height);
	x := (self.clientWidth - self.frmCenter.width) / 2;
	self.frmCenter.move(x, y, self.frmCenter.width, self.frmCenter.height);	
//	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="operShippingLineComboClick" id="32bc53af-367a-4ee0-b546-1f1bdcfab376">
        <updating/>
        <source>operShippingLineComboClick() updating;

vars
	operShippingLine : CM_OperatorShippingLine;
	operator : CM_Operator;
	shippingLine : CM_ShippingLine; 
begin
	if self.cmbOperator.listIndex &gt; 0 and
	   self.cmbShippingLine.listIndex &gt; 0 then
		operator := cmbOperator.listObject.CM_Operator; 
		shippingLine := cmbShippingLine.listObject.CM_ShippingLine; 
		operShippingLine := app.myRoot.allOperatorShippingLines[operator, shippingLine];
		if operShippingLine &lt;&gt; null then
			self.populateTableDestDischPort(operShippingLine, shippingLine);
		endif;
		self.populateComboDestDischPort(shippingLine);
	endif;
//	self.setControlEnable();
	self.tblDestDischPort.clearAllData();
	self.tblOperShipLine.clearAllSelected();
//	self.tblOperShipLine.
	self.setupControls();
end;</source>
    </JadeMethod>
    <JadeMethod name="populateComboDestDischPort" id="d6b53e5b-7f3f-47e5-bb82-18a1b2be50d6">
        <updating/>
        <source>populateComboDestDischPort(_shippingLine : CM_ShippingLine) updating, protected;

vars

begin

	if app.myPassport.myUser.canDo(null, PmAdmDestDischPortMaint/*PmAdmDataExportMaint*/) then
		self.cmbPortDest.enabled := true;
		self.cmbPortDisch.enabled := true;
		self.cmbPortDestBuild();
		self.cmbPortDischBuild(_shippingLine);
	else
		self.cmbPortDest.enabled := false;
		self.cmbPortDisch.enabled := false;
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
    </JadeMethod>
    <JadeMethod name="populateTableDestDischPort" id="7471553c-23bd-4d18-ab47-3b572fb99dda">
        <updating/>
        <source>populateTableDestDischPort(_operShippingLine : CM_OperatorShippingLine; _shippingLine : CM_ShippingLine) updating, protected;
//	created by cnwvu1	19/02/2007

vars
	destDischPort : CM_DestinationToDischargePort;
	strDest, strDisch : String;
	
begin
	self.tblDestDischPort.clearAllData();
	if _operShippingLine &lt;&gt; null then
		foreach destDischPort in _operShippingLine.allDestinationDischargePorts  do
			strDisch := destDischPort.dischargePort.getDisplayFormatted(self.portCmbOrderDescrFirst);
			strDest := destDischPort.destination.getDisplayFormatted(self.portCmbOrderDescrFirst);
			self.tblDestDischPort.addItemObject(destDischPort, strDest&amp;Tab&amp;strDisch);
		endforeach;
		self.tblDestDischPort.resort();
		self.populateComboDestDischPort(_shippingLine);
	else
		if self.cmbOperator.listIndex &gt; 1 and
		   self.cmbShippingLine.listIndex &gt; 1 then
			self.populateComboDestDischPort(self.cmbShippingLine.listObject.CM_ShippingLine);
		else
			self.cmbPortDest.enabled := false;
			self.cmbPortDisch.enabled := false;
		endif;	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_operShippingLine" type="CM_OperatorShippingLine"/>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
    </JadeMethod>
    <JadeMethod name="populateTableOperShippingLine" id="27ba54bd-83e6-4481-ac07-31d5c6071d43">
        <updating/>
        <source>populateTableOperShippingLine() updating, protected;

vars
	opShipLine : CM_OperatorShippingLine;
begin
	self.tblOperShipLine.clearAllData();
	foreach opShipLine in app.myRoot.allOperatorShippingLines  do
		//07/07/2010 cnwdz2 24598
		if opShipLine.myOperator = null or opShipLine.myShippingLine = null then
			continue;
		endif;
		self.tblOperShipLine.addItemObject(opShipLine, opShipLine.myOperator.getDisplayDetailsOther(false)&amp;Tab&amp;opShipLine.myShippingLine.getDisplayDetailsOther(false));
	endforeach;
	self.tblOperShipLine.resort();
	self.setupControls();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeDestToDischPort" id="4f98f7b5-8628-4344-bf6e-b76e57eed003">
        <updating/>
        <source>removeDestToDischPort() updating;

vars
	operShippingLine : CM_OperatorShippingLine;
	destToDischargePort : CM_DestinationToDischargePort;
begin




	destToDischargePort := tblDestDischPort.accessRow(self.tblDestDischPort.row).itemObject.CM_DestinationToDischargePort;
	app.myTrxDA.trxDeleteDestToDischargePort(destToDischargePort, app.myPassport);	
	operShippingLine := app.myRoot.allOperatorShippingLines[cmbOperator.listObject.CM_Operator, cmbShippingLine.listObject.CM_ShippingLine];
//	operShippingLine := app.myRoot.allOperatorShippingLines[self.myOperShippingLine.myOperator, self.myOperShippingLine.myShippingLine];
	
	if operShippingLine &lt;&gt; null and operShippingLine.allDestinationDischargePorts.size = 0 then
		app.myTrxDA.trxDeleteOperShippingLine(operShippingLine, app.myPassport);	
		operShippingLine := null;
		self.populateTableOperShippingLine();
		self.populateTableDestDischPort(operShippingLine, null);
	else
		self.populateTableDestDischPort(operShippingLine, operShippingLine.myShippingLine);
	endif;
	self.setupControls();
end;</source>
    </JadeMethod>
