    <JadeMethod name="getArrivalDT" id="ad34b35c-365a-4a54-b633-beeb22b1ddef">
        <source>getArrivalDT():String protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date			Who		Reason
22 July 2008	concms1	Initial creation
*/

vars

begin
	if self.myJRWVoyageSummary &lt;&gt; null and
		self.myJRWVoyageSummary.myVoyage &lt;&gt; null and
		self.myJRWVoyageSummary.myVoyage.arrivedDT &lt;&gt; null then
		
		return self.myJRWVoyageSummary.myVoyage.arrivedDT.asStringJMT;
	endif;
epilog

end;</source>
