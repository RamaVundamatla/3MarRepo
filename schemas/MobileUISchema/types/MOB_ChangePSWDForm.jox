    <JadeMethod name="setupForm" id="40393430-e2b8-4585-975d-83ead0d0cbc6">
        <updating/>
        <source>setupForm() updating, protected;
/*
	Created on 03 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	inheritMethod();
	setUserName(myMainObject.CM_User.code);
	modalResult := ModalResultCancel;
	self.txtOldPSW.setFocus();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a4ef1fcb-e15d-4bd1-8f0c-b0d9c4a7fd17">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017601, locale);
	btn_Cancel.translateCaption(Xlat_0012991, locale);
	btn_OK.translateCaption(Xlat_0012992, locale);
	lblNewPSWD.translateCaption(Xlat_0012993, locale);
	lblOldPSWD.translateCaption(Xlat_0012994, locale);
	lblPSWDConfirm.translateCaption(Xlat_0012995, locale);
	lbl_Tile.translateCaption(Xlat_0012996, locale);
	lbl_Username.translateCaption(Xlat_0012997, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
