begin
	inheritMethod(_pxyTI, _tiUpdateCntrlr, _passport);
	self.hasRadio 		:= _pxyTI.CM_Car.hasRadio;
	self.selfPropelled 	:= _pxyTI.CM_Car.selfPropelled;
	
	pxyCar := _pxyTI.CM_Car;								// PAR #32215
	self.colour				:= pxyCar.colour;				// PAR #32215
	self.make				:= pxyCar.make;					// PAR #32215
	self.model				:= pxyCar.model;				// PAR #32215
	self.carType			:= pxyCar.carType;				// PAR #32215
	self.year				:= pxyCar.year;					// PAR #32215
