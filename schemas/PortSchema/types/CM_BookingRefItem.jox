    <JadeMethod name="getISOTypeGroupForISOType" id="02c6f85a-e4dc-4df2-81c2-6b0628459ed9">
        <source>getISOTypeGroupForISOType():String;
// ---------------------------------------------------------------------------
// Created:     20 October 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     ISO Type Group code entered for the booking, OR if that is
//				null the ISO Type Group code associated with the ISO Type
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type	:CM_ISOType;
	grp		:CM_ISOTypeGroup;
	result	:String;
begin
	result := self.isoTypeGroup;
	
	if result = null then
		type := self.myISOType;
		
		if type &lt;&gt; null then
			grp := type.myISOTypeGroup;
			
			if grp &lt;&gt; null then
				result := grp.code;
			endif;
		endif;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getISOTypeGroupObject" id="4bcde3e9-98f1-4f32-bae9-de8aaf91c42b">
