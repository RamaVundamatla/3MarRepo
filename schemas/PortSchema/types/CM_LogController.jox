    <JadeMethod name="averageSED" id="1c0eded7-c05d-4ffc-a511-5d5a60ad8097">
        <methodInvocation>mapping</methodInvocation>
        <source>averageSED(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:     25 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	seds,
	lens	: DecimalArray;
	items	: IntegerArray;
	soh		: CM_SOHLocation;
	ext		: CM_SOHLocationExtLog;

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	create lens transient;
	create seds transient;
	create items transient;

	foreach soh in self.allProductLocations do
		if (not soh.myExtension.isKindOf(CM_SOHLocationExtLog)) then
			continue;
		endif;
		ext := soh.myExtension.CM_SOHLocationExtLog;
		lens.add(ext.myProductLog.logLength);
		seds.add(ext.averageSED);
		items.add(ext.countForSEDMean);
	endforeach;

	_value := global.calcAverageSEDMeanMixed(lens, seds, items);
	
epilog
	delete lens;
	delete seds;
	delete items;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="calculateTotalVolume" id="67858fa3-2365-4dbb-a638-c9bac4df7d29">
        <updating/>
        <source>calculateTotalVolume(_theMode : Integer) : Decimal updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theLog : CM_Log;
	theTI : CM_TrackedItem;
	//lTotal : Decimal[12,3];
	lTotal : Decimal[12,4];//par13537,13657
	array : CM_TIArray;
begin
	create array transient;
	self.getTIs(array, _theMode, true); // PAR 27749
	foreach theTI in array do
		if theTI.isKindOf(CM_Log) then
			theLog := theTI.CM_Log;
			lTotal := lTotal + theLog.getMyTotalVolume;
		endif;
	endforeach;	
	return lTotal;
epilog
	delete array;
end;</source>
        <Parameter name="_theMode" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
