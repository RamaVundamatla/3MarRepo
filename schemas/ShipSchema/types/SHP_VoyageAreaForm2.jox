    <JadeMethod name="toolbarClickPreProcessing" id="633798d1-acb5-4d10-a0d2-dc986a3e87c2">
        <updating/>
        <source>toolbarClickPreProcessing(_theIndex : Integer) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.myCurrentVoyage = null and _theIndex &lt;&gt; self.BTN_DRAW then
		return false;
	endif;
	
	if self.frmTips.visible then
		self.showHideTipsFrame();
	endif;

/*
	if _theIndex &lt;&gt; VIEW_SEQUENCE then
		self.currentSeqNumber := 0;
		self.myCurrentJob := null;
	endif;
*/
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_theIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="6f50d9f8-b45f-4529-958f-e7abe71a74f6">
