    <JadeMethod name="setupBerthForActivity" id="b870d644-1eef-4d72-acb8-9b330ef9157d">
        <source>setupBerthForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;
/*
Purpose:			

Date		Who		Reason
26AUG2021	NAVAB1	TFS 51853
*/

vars
	argoQuayCmif	    	: CMIF_ArgoQuay;
	data                    : Any;
begin
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		data := _ewsOpsView.objectOid;
	else
		data := _ewsOpsView.myOpsviewObject;
	endif;
	
	create argoQuayCmif transient;
	argoQuayCmif.initializeForActivity(data,_ewsOpsView);
	
	
	_cmifArray.add(argoQuayCmif);
	return _cmifArray;
	
epilog

end;</source>
