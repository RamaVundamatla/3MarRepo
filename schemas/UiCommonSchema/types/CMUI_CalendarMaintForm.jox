    <JadeMethod name="translateForm" id="9714d209-bed0-49c6-baa3-e728721ca750">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015930, locale);
	btnBulk.translateCaption(Xlat_0015931, locale);
	btnCalSave.translateCaption(Xlat_0015932, locale);
	btnCancel.translateCaption(Xlat_0015933, locale);
	btnClose.translateCaption(Xlat_0015934, locale);
	btnDayType.translateCaption(Xlat_0015935, locale);
	btnNewCalendar.translateCaption(Xlat_0015936, locale);
	btnNewDate.translateCaption(Xlat_0015937, locale);
	btnRemDate.translateCaption(Xlat_0015938, locale);
	btnUpdDate.translateCaption(Xlat_0015939, locale);
	lblCalendar.translateCaption(Xlat_0015940, locale);
	lblCode.translateCaption(Xlat_0015941, locale);
	lblDayType.translateCaption(Xlat_0015942, locale);
	lblDescription.translateCaption(Xlat_0015943, locale);
	lblEndTime.translateCaption(Xlat_0015944, locale);
	lblEntryCount.translateCaption(Xlat_0015945, locale);
	lblHookCode.translateCaption(Xlat_0015946, locale);
	lblStartTime.translateCaption(Xlat_0015947, locale);
	lblYear.translateCaption(Xlat_0015948, locale);
end;</source>
    </JadeMethod>
