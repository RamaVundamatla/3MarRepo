        <source>loadPilot(_pilotProxy:HMS_Pilot io) :Boolean protected;

vars
	realObject: HMS_Object;
	proxyObject: HMS_Pilot;
	error: CM_Error;
	countError,countOK: Integer;
begin
	realObject := _pilotProxy.myCurrentHarbour.allPilots[_pilotProxy.code];
	if realObject = null then
		app.myTrxCA.trxCreateHMSObject(_pilotProxy, realObject, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_pilotProxy.code&amp;" ERROR: "&amp;"Pilot already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_pilotProxy.code&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_pilotProxy.code&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pilotProxy" type="HMS_Pilot" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
