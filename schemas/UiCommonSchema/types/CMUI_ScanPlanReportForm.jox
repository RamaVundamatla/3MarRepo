	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.optSlotDandL.name );
	self.optSlotDandL.value := (xmlText = "true").Boolean;
	
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.optROBGrey.name );
