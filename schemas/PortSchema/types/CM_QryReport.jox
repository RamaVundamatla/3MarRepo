    <JadeMethod name="getJRWFileNames" id="acec2eac-deb4-4853-9231-420b529800b0">
        <source>getJRWFileNames() : String;
// ---------------------------------------------------------------------------
// Created:     19 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str,
	reportNamesStr			: String;
	len						: Integer;
begin
	foreach str in self.jrwReportName do
		reportNamesStr := reportNamesStr &amp; str &amp; ',';
	endforeach;
	
	len := reportNamesStr.length;
	if len &gt; 1 then
		reportNamesStr := reportNamesStr[1: len -1];
	endif;

	return reportNamesStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
