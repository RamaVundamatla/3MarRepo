    <JadeMethod name="doBuildCMbDischTermArea" id="113a3c26-154c-4633-9b94-2af27409e296">
        <source>doBuildCMbDischTermArea(_taType : CM_TerminalAreaType; _theLocation : CM_LocationsController);
/*
Purpose:	

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars

	ta		: CM_TerminalArea;
	type	: Integer;
	idx		: Integer;
begin
	
	type := TA_TYPE_NULL;
	
	if _taType &lt;&gt; null then
		type := _taType.type;
		if _theLocation &lt;&gt; null then
			ta := _theLocation.myTerminalArea;
		endif;
	endif;
	
	self.myAssistant.comboBoxTAType(self.cmbDischargeTAType, _taType, true);

epilog

end;</source>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
        <Parameter name="_theLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doBuildCmbDateType" id="6ee28a25-8d39-4e2a-8d69-9b6743a10540">
        <source>doBuildCmbDateType();
/*
Purpose:			

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars

begin
	self.cmbVoyageDateType.clear();
	self.cmbVoyageDateType.sorted := true;
	
	self.cmbVoyageDateType.addItemWithData(Voyage_Pilot_On_Board_Str, Voyage_Pilot_On_Board); // 2

	self.cmbVoyageDateType.addItemWithData(Voyage_Anchor_Down_Str, Voyage_Anchor_Down); // 3
	self.cmbVoyageDateType.addItemWithData(Voyage_Arrival_Str, Voyage_Arrival); // 4
	self.cmbVoyageDateType.addItemWithData(Voyage_Labour_On_Board_Str, Voyage_Labour_On_Board); // 5
	self.cmbVoyageDateType.addItemWithData(Voyage_Ship_Exchange_Start_Str, Voyage_Ship_Exchange_Start); // 1
	self.cmbVoyageDateType.addItemWithData(Voyage_Rec_Labour_Ashore_Str, Voyage_Rec_Labour_Ashore); // 7
	self.cmbVoyageDateType.addItemWithData(Voyage_Rec_Ship_Exch_End_Str, Voyage_Rec_Ship_Exch_End); // 6
	self.cmbVoyageDateType.addItemWithData(Voyage_General_Landing_Str, Voyage_General_Landing); // 20
	self.cmbVoyageDateType.addItemWithData(Voyage_Departed_Str, Voyage_DepartedUnique); // ### TFS BUG 65730 22AUG2024 NAVAB1

	self.cmbVoyageDateType.text := Voyage_Arrival_Str;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCmbDischLC" id="11f395a1-ea52-4a8c-9302-03d953fe0305">
        <source>doBuildCmbDischLC();
/*
Purpose:	

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
*/

vars
	ta : CM_TerminalArea;
	lc : CM_LocationsController;
begin
	ta := self.cmbDischargeTA.listObject.CM_TerminalArea;
	
	self.cmbDischargeLC.clear();
	self.cmbDischargeLC.sorted	 := true;
	
	foreach lc in ta.allLocationsControllers discreteLock do
		self.cmbDischargeLC.addItemObject(lc.getFullId(), lc);
	endforeach;
	
	if self.cmbDischargeLC.listCount = 1 then
		self.cmbDischargeLC.listIndex := 1;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCmbVoyageStatus" id="9e171f02-77fc-4ad8-bd78-2d0708cf166c">
        <source>doBuildCmbVoyageStatus();
/*
Purpose:	

Date		Who		Reason
16 July 2024	navab1	CR 64616 TASK 64652
*/

vars

	voyProc : CM_VoyageProcess;
	voyStat : CM_VoyageStatus;
begin
	
	self.cmbVoyageStatus.clear();
	self.cmbVoyageStatus.sorted	 := true;
	
	voyProc := app.myRoot.allVoyageProcesses[VoyageProcessAutomatic]; // ### TFS BUG 65730 22AUG2024 NAVAB1
	
	foreach voyStat in voyProc.allStatuses discreteLock do
		if voyStat.description &lt;&gt; Voyage_Status_AutoOn_Auto_Str and voyStat.description &lt;&gt; Voyage_Status_Autoff_Auto_Str then							//navra1 - MTN-33086 - 21st Oct 2024
			self.cmbVoyageStatus.addItemObject(voyStat.description,voyStat);
		endif;																																		//navra1 - MTN-33086 - 21st Oct 2024
	endforeach;
	
	if self.cmbVoyageStatus.listCount = 1 then
		self.cmbVoyageStatus.listIndex := 1;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMSGComparisonFields" id="928e64bd-2f89-4927-af2c-a11e410fb941">
        <source>doBuildMSGComparisonFields();
/*
Purpose:	

Date		Who		Reason
16 July 2024	navab1	CR 64614 TASK 64642
*/

vars

begin
	self.msgCompFields.myAvailableListBox.sorted 	:= true;
	self.msgCompFields.mySelectedListBox.sorted 	:= true;
	self.msgCompFields.setupControl(null, self.allComparisonFieldsObjects,SHP_AutoVoyageConfig::getEDICompFieldNameDisplay.name);
	self.msgCompFields.availableHeading	:= app.getErrorString(Available);
	self.msgCompFields.selectedHeading	:= app.getErrorString(Selected);
	self.msgCompFields.myBaseForm	:= self;
	self.msgCompFields.setSelected(null);
	self.msgCompFields.multiSelect :=  ListBox.MultiSelect_Extended;
	self.msgCompFields.caption := app.getErrorString(Automatic_comparison_fields);


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClearAutoComparison" id="f829dee8-eb46-4685-b810-b345c2ba1d1c">
        <source>doClearAutoComparison();
/*
Purpose:	

Date		Who		Reason
17 July 2024	navab1	CR 64614 TASK 64642
*/

vars

begin
	self.chkDoAutoComp.value := false;
	
	self.msgCompFields.setAvailable(self.allComparisonFieldsObjects, true);
	
