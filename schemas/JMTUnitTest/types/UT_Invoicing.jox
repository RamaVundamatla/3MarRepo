	_iso.add("2200");
	_comm.add("GENL");
	_ids.add("GENL2X22338");
	_iso.add("2200");
	_comm.add("GENL");
	_ids.add("GENL2X22331");
	_iso.add("2200");
	_comm.add("GENL");

	// ### 40 GENERALS
	_ids.add("GENL4X22441");
	_iso.add("4200");
	_comm.add("GENL");
	_ids.add("GENL4X22442");
	_iso.add("4200");
	_comm.add("GENL");
