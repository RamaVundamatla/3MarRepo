// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	//self.myCurrentTrain := null;
	self.setMyTrain( null );	//14 May 2021	NDL	TFS 51199

	if table.row &lt;= table.fixedRows then
		return;
	endif;

