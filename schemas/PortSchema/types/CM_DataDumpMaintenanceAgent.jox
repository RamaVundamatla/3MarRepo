		_classes.add(CM_OwnershipChangeFinancial);
		_sqlTables.add(CM_OwnershipChangeFinancial.name[4 : end]);
		_classes.add(CM_WorkPoint);                     //30.01.2023 navhl20 #55111
		_sqlTables.add(CM_WorkPoint.name[4 : end]);     //30.01.2023 navhl20 #55111
		_classes.add(CM_WorkPointType);                 //28.02.2024 navhl20 #62671
		_sqlTables.add(CM_WorkPointType.name[4 : end]); //28.02.2024 navhl20 #62671
		
		_classes.add(HMS_MarineServicesTimings);					//02.02.2024 navnk30 #62313
		_sqlTables.add(HMS_MarineServicesTimings.name[5 : end]);	//02.02.2024 navnk30 #62313
		_classes.add(CM_CargoForecast);					//03.09.2025 navbs1 #35845
		_sqlTables.add(CM_CargoForecast.name[4 : end]);	//03.09.2025 navbs1 #35845
	else
		// this is a special attempt to create an sql of the full database
		create subClasses transient;
		CM_Object.allSubclasses(subClasses);
		foreach aClass in subClasses do
			if aClass.getSuperclass() &lt;&gt; CM_Object then
				continue;
			endif;
			if aClass = CM_FinancialObject or
			   aClass = HMS_Object or
			   aClass = TST_RecordObject then
				continue;
			endif;
			_classes.add(aClass);
			_sqlTables.add(aClass.name[4:end]);
		endforeach;
	
		subClasses.clear;
		CM_FinancialObject.allSubclasses(subClasses);
		foreach aClass in subClasses do
			if aClass.getSuperclass() &lt;&gt; CM_FinancialObject then
				continue;
			endif;
			_classes.add(aClass);
			_sqlTables.add(aClass.name[4:end]);
		endforeach;
	
		subClasses.clear;
		HMS_Object.allSubclasses(subClasses);
		foreach aClass in subClasses do
			if aClass.getSuperclass() &lt;&gt; HMS_Object then
				continue;
			endif;
			_classes.add(aClass);
			_sqlTables.add(aClass.name[4:end]);
		endforeach;
	
		delete subClasses;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_classes" type="ObjectArray" usage="input"/>
        <Parameter name="_sqlTables" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFeaturesForClassNew" id="28769aba-826c-4ac9-8a6d-c149c27db582">
        <updating/>
        <source>getFeaturesForClassNew(_class: Class; _features : CMIF_ExternalDBFeatureSet input) updating, protected;
// This replaces getFeaturesForClass 
// cnwrs1 sept 2005 
// this returns a list of Jade method/attributes which are to be exported to DSS
// if the SQL item has a different name this is 
// resolved in CM_DataDumpFeature::getExternalDatabaseFeatureName
//
// Now calls a method for each Class
//PAR 24641
//25 Jun 2014	cnwrs1	Par 34470 New SQL native classes are missing edition 
//13 Jan 2016	cnwrs1	Par 37432 TFS 1268 SQL Native Changes for DPH
//16 Mar 2016	cnwrs1	TFS 1656 SQL Native Event Type and Event Transaction
//09 Jun 2016	cnwdap1	POL TFS #1963 SQL Extract for Release Requests
// 19 Dec 2016	cnwrs1	TFS add CM_GLCode to SQL Native
//19/01/2017 	cnwrh7	TFS	2929  Additional Fields Required (CM_ReserveSelection/CM_ReserveTI) in SQL Native for Release Requests
//14/07/2022	navsj20	TFS 53862: EUP - WMS - Damage Recording Extra Details
//29/08/2022	navkc1	ChangeRequest 54568: EUP - Inv Config - Reports and Extracts
//12/09/2022	navpw1	TFS: 54568 - EUP - Inv Config - Reports and Extracts
//14/09/2022    navrk21 TFS ChangeRequest 54635: POL - Are Vessel Crane Move Rates available in SQL Native Extract?
// 04 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// 23 Nov 2022  navmv20 ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
// 16 Feb 2023  navvt20 TFS CR 55655 Task 55687: Jade - Data Extract
// 25 May 2023	navpw1	TFS: 53902 - Added Data Extract for Vehicle Booking Time Slot
// 25 May 2023	navra1	TFS: 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
// 01 June 2023 navlw1 	Bug 58327: MTN - CM_VehicleBookingTimeSlotItem is missing on the data extract
// 30 Jan 2023  navhl20 ChangeRequest 55111: GPHA -- Adding Workpoint to Tracked Item and Transaction Views
// 02 Feb 2024  navnk30 ChangeRequest 62313: ATD - Add feature Marine Service timing
// 28 Feb 2024 	navhl20 Bug 62671: MTN - Expose CM_WorkPointType class for data export to fix the unit test
// 03 Sep 2025 	navbs1	Story 35845: PNL - Cargo forecast string does not contain 'Quantity' field - Dev
vars
	props      : PropertySet;
	property   : Property;
	allprops   : PropertyColl;
	aMethod    : Method;
	allMethods : MethodSet;
	xdbFeature : CMIF_ExternalDBFeature;
begin
	_features.purge();
	if not CM_DataDumpMaintenanceAgent.AllFeatures then
		create xdbFeature transient;
		xdbFeature.setupAndBuildSet("oidBin", _class.name, "oidBin", "", _features);
