<Class name="CM_PackWLE" id="0b2553d2-40d5-4f25-9860-9f1c9a620079">
    <superclass name="CM_WorkListEntry"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>DO NOT USE - Been replaced with CM_WOPackWLE</text>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="erase" id="33f5cbf8-7031-48a1-a3f4-7e94f84b612b">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2010	cnwrd1	Initial creation

*/


vars
begin
	
	// Lock all for update
	exclusiveLock(self);
	sharedLock(myRequest);
	if self.myRequest.myJob &lt;&gt; null then
		//AJA 31/3/00: Yard internals
		sharedLock(self.myRequest.myJob);
	endif;

	
	//=======================
	// automatics should take care
	// of the job.wles and request.wles collections.
	//=======================

	self.causeEvent(self.job.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, self);				  	

  	inheritMethod(_eraseLevel);
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
