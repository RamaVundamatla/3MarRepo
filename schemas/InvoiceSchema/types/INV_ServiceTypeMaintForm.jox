16 August 2022	navkc1	Initial creation

*/

vars

begin
	inheritMethod();
	
	self.tblEntDetail.enabled 	:= false;
	self.cmbGLCode.enabled 		:= false;
	self.cmbGLCode.listIndex 	:= 1;
	self.msgServices.enabled 	:= false;
	
epilog

end;</source>
