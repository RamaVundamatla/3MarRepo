    <JadeMethod name="isTwinLiftCapable" id="6bebc8dd-2389-42c5-96f4-59e22b092f18">
        <source>isTwinLiftCapable(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2009	cnwer1	Initial creation

*/

vars
	theISOType : CM_ISOType;
begin
	theISOType:=  self.getISOTypeObject();
	
	if theISOType = null then
