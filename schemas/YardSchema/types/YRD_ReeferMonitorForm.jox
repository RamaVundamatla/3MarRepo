    <JadeMethod name="initReadingTable" id="4f1c4ae7-d6ef-47a0-a3ac-b7b00ba4b784">
        <source>initReadingTable();
// ---------------------------------------------------------------------------
// Created:		05 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/03/2015	cnwdap1		PAR #35874 TFS 265 Added ventilation and humidity columns
// 16/01/2026	navdap1		MTN-36569 CPL | Reefer Runner Integration
vars
begin
	self.tblReadings.stretchToParent := true;

	self.tblReadings.scrollBars := Table.ScrollBars_Both;	// MTN-36569
	self.tblReadings.clear;
	self.tblReadings.columns := 7;							// MTN-36569
	self.tblReadings.fixedColumns := 0;
	self.tblReadings.rows := 1;
	self.tblReadings.fixedRows := 1;
	self.tblReadings.visible := true;
	//self.tblReadings.accessCell(1, 1).text := 'Date Time'&amp;Tab&amp;'Temperature'&amp;Tab&amp;"User Code";									// PAR #35874
	self.tblReadings.accessCell(1, 1).text := 'Date Time'&amp;Tab&amp;'Temperature'&amp;Tab&amp;"Humidity"&amp;Tab&amp;"Ventilation"&amp;Tab&amp;"CO2"&amp;Tab&amp;"O2"&amp;Tab&amp;"User Code";	// MTN-36569
				   
end;</source>
    </JadeMethod>
