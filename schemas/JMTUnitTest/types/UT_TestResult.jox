    <JadeMethod name="getUserFailEmailedTo" id="e407731e-c4c5-4f19-b759-6592e5cef898">
        <source>getUserFailEmailedTo() : String;

/*

Purpose:			Return 

Parameters:			

Return Value:		


Date		Who		Reason
13 January 2011	cnwmh5	Initial creation

*/

vars

	testController	        : JMTTestController;
	user, user1		        : CM_User;
	userEmailAddress	    : UM_UserEmailAddress;
	root				    : UM_Root;

	userEmailedTo	        : String;
	emailAddress	        : String;
	posAmp		        	: Integer;
    altUser                 : String;
	
begin

	if self.owner &lt;&gt; null then

		user := app.myRoot.allUsers[self.owner.toUpper()];
		if user &lt;&gt; null then
			if user.myEmailEntity &lt;&gt; null then
				emailAddress := user.code;		//cnwmc5 - 12/10/2012
				//TO BE DELETED
				///emailAddress := user.code &amp; "@JADEWORLD.COM";
			else
				emailAddress := owner;		//cnwmc5 - 12/10/2012
				//TO BE DELETED
				///emailAddress := owner &amp; "@JADEWORLD.COM";						// 28/03/2012 cnwmh5
			endif;
			create testController transient;
			emailAddress := testController.getEmailToUser(emailAddress);
			
			emailAddress := emailAddress &amp; app.masterAddress.toUpper();			//cnwmc5 - 12/10/2012 - attaching master address
			
			posAmp := emailAddress.pos("@", 1);
			if posAmp &lt;&gt; 0 then
				user1 := app.myRoot.allUsers[emailAddress[1:posAmp - 1].toUpper];
				if user1 &lt;&gt; null and user1 &lt;&gt; user then
					////userEmailedTo := "(Emailed to " &amp; user1.userName &amp; ")";
					userEmailedTo := user1.userName;									// 05/09/2013 cnwmh5
				endif;
			endif;
		else
			root := UM_Root.firstInstance;						// 26/09/2013 cnwmh5
			if root &lt;&gt; null then
				userEmailAddress := root.allUserEmailAddresses[owner.toUpper()];
				if userEmailAddress &lt;&gt; null then
                    altUser := userEmailAddress.altUser.toUpper();						// 09/10/2013 cnwmh5
                    if altUser = null then
                        altUser := root.getFirstAdminUserEmailAddress().user;
                    endif;	
				//	userEmailedTo := app.myRoot.allUsers[altUser].userName;
					user1 := app.myRoot.allUsers[altUser];
					if user1 &lt;&gt; null then
						userEmailedTo := user1.userName;
					endif;
				endif;
			endif;
		endif;
		
	endif;
	
	return userEmailedTo;
	
epilog

	delete testController;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasPassed" id="fcb86c96-a6e6-4ac9-82fa-219720b6c3b8">
