        <updating/>
        <source>listRemotes_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

vars

	selected	: Boolean;

	
begin

	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	if selected then
		return TableCheckBox_Selected  &amp; Tab &amp; obj.Class.text.cnEcGetTagValueOfName('display');
	else
		return  TableCheckBox_NotSelected &amp; Tab &amp; obj.Class.text.cnEcGetTagValueOfName('display');
	endif;	


end;</source>
