    <JadeMethod name="translateForm" id="da0c8c02-43f6-483b-a289-c8a1c0b274a5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:44:25.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023329, locale);
	btnCancel.translateCaption(Xlat_0023330, locale);
	btnFind.translateBubbleHelp(Xlat_0018872, locale);
	btnOK.translateCaption(Xlat_0023331, locale);
	lblID.translateCaption(Xlat_0018873, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMultiSelection" id="8f514cb2-32af-4d3d-9be9-1a8fd771c949">
        <source>validateMultiSelection(_oa : ObjectArray) : Boolean protected;
// 29287 allow multi-select of pre-notes of a single booking ref, or a single booking ref
vars
	obj			: Object;
	hasBooking	: Boolean;
	ti			: CM_TrackedItem;
	bookingRefItem	: CM_BookingRefItem;
begin
	if _oa = null then
		return true;
	endif;
	
	foreach obj in _oa do
		if obj.isKindOf(CM_BookingRefItem) then
			if hasBooking then
				return false;
			else
				hasBooking := true;
			endif;
		elseif obj.isKindOf(CM_TrackedItem) then
			if hasBooking then
				return false;
			endif;
			ti := obj.CM_TrackedItem;
			if bookingRefItem = null then
				bookingRefItem := ti.myBookingRefItem;
			endif;
			if ti.myBookingRefItem &lt;&gt; bookingRefItem then
				return false;
			endif;
		endif;
	endforeach;
	
	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="_oa" type="ObjectArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
