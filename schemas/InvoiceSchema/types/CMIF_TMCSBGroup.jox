    <JadeMethod name="getAvailableResources" id="8cd10b21-24b1-466c-abf4-40317b0d9790">
        <source>getAvailableResources( _resources : CM_ResourceTypeDict io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	transType : CM_TransactionType;
	obj : Object;
	toDoTask : CM_ToDoTaskDesc;
	cm_Object : CM_Object;
	resourceType : CM_ResourceType;
	
begin

	if _resources = null then
		return;
	endif;

	_resources.clear();

	if self.myServiceBroker &lt;&gt; null then
		if self.myServiceBroker.isTransServiceBroker then
			transType := self.myServiceBroker.CM_TransServiceBroker.myTransactionType;
			if transType &lt;&gt; null then
				foreach obj in transType.allToDoTaskDesc do
					if not obj.isKindOf(CM_ToDoTaskDesc) then
						continue;
					endif;
					toDoTask := obj.CM_ToDoTaskDesc;
					foreach cm_Object in toDoTask.allResourceTypes do
						if not cm_Object.isKindOf(CM_ResourceType) then
							continue;
						endif;
						resourceType := cm_Object.CM_ResourceType;
						_resources.addNoDuplicates(resourceType,false);
					endforeach;
				endforeach;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_resources" type="CM_ResourceTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getItemLevel" id="584d0de8-b3dd-4f4d-8c85-1edd1c5304cf">
        <source>getItemLevel(): Integer;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myServiceBroker.isKindOf(CM_TransServiceBroker) then
		return CMIF_TranMapController.TM_Level_10_TranServiceBroker;
	else
		return CMIF_TranMapController.TM_Level_10_MoveServiceBroker;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
