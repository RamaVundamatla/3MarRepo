    <JadeMethod name="xCheckCaptionTranslated" id="1427681d-53fa-4189-97bc-04a209fba31e">
        <source>xCheckCaptionTranslated(_meth1 : Method ; _constName : String output ) : Boolean ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2017	cnwns1	Initial creation

*/
 
constants 
	TRANS = "self.translateCaption(";
vars
	
	source 		: String;
	linePos 	: Integer;
	line 		: String;	
	transPos	: Integer;
	commPos		: Integer;
	inheritPos 	: Integer;	
	inherits	: Boolean;
	constStart 	: Integer;
	
begin
		
	source := _meth1.getSource;
									
	linePos := 1;
		
	while true do
		// get the line to check
		line := source.cnEcGetNextLine(linePos);
		if linePos = 0 then 
			break;
		endif;
				
		transPos := line.pos(TRANS,1);
		commPos	:= line.pos("//",1);
				
		if transPos &gt; 0 then
			if commPos &gt; 0 then
				if commPos &gt; transPos then
					constStart := transPos + TRANS.length;
					_constName := line.scanUntil(",",constStart);
					return true;
				endif;
			else
				constStart := transPos + TRANS.length;
				_constName := line.scanUntil(",",constStart);
				return true;
			endif;
		endif;
				
		inheritPos := line.pos("inheritMethod",1);
		
		
		if inheritPos &gt; 0 then
			if commPos = 0 or commPos &gt; inheritPos then
				inherits := true;
			endif;
		endif;
	
	endwhile;	
				
		
		
	if inherits then
		return	xCheckCaptionTranslated(_meth1.getSuperMethod,_constName);	
	endif;
		
		
	return false;
epilog
end;</source>
        <Parameter name="_meth1" type="Method"/>
        <Parameter name="_constName" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xCheckHelpKeywords" id="7c121c30-e3bf-4e91-b631-8e582797234f">
        <source>xCheckHelpKeywords(_getBlank : Boolean ; _userSummaryDict: CM_AssociationDict io) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2018	jlgns1	Initial creation

*/

vars
	schemaColl  : SchemaColl;
	schema		: Schema;
	activeSchema: Schema;
	allowableSchemasArray		: StringArray;
	problemClassesArray		: HugeStringArray;
	classColl		: ClassColl;
	class			: Class;
	translateMethod : Method;
	goodKeyword 	: Boolean;
	
	logString 			: String;
	constName 		: String;
	constantCategory : ConstantCategory;
	portSchema 		: Schema;
	constDict 		: ConstantNDict;
	caption : String;
	ignoreList : StringArray;
	gc : GlobalConstant;
	obj : Object;
	trans : XLAT_Translation;
	xlatDeets : String;
	dMastMessage : String;
begin


	portSchema:=rootSchema.getSchema(PortSchemaName);
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);

	create constDict transient;
		
	constantCategory.cnEcGetConstants.copy(constDict);
		
	create allowableSchemasArray transient;	
	create problemClassesArray transient;
	// 12/04/2013 cnwmh5
	allowableSchemasArray.add("UiCommonSchema");
	allowableSchemasArray.add("MobileUISchema");
	allowableSchemasArray.add("PortSchema");
	allowableSchemasArray.add("GateSchema");
	allowableSchemasArray.add("GeneralCargoSchema");
	allowableSchemasArray.add("HmsSchema");
	allowableSchemasArray.add("InvoiceSchema");
	allowableSchemasArray.add("LogSchema");
	allowableSchemasArray.add("ShipSchema");
	allowableSchemasArray.add("SysOpsSchema");
	allowableSchemasArray.add("YardSchema");

	create 	ignoreList transient;
	ignoreList.add("GTE_VehicleBookingEntryForm");
	ignoreList.add("INV_TreeView");
	ignoreList.add("SHP_ShufflePolygons");
	ignoreList.add("SOP_EDICAMSGroupForm");
	ignoreList.add("SOP_EDICAMSProtocolForm");
	ignoreList.add("SOP_TerminalConfig");
	ignoreList.add("YRD_MachineForm");
	ignoreList.add("YRD_RTViewer");
	ignoreList.add("SHP_RepeatingVoyageForm");
	ignoreList.add("YRD_GridAreaForm");
	ignoreList.add("CM_BaseForm");
	ignoreList.add("CMUI_Modal");
	ignoreList.add("CMUI_MasterDetailForm");
	ignoreList.add("HMS_SavedConflictReportsForm");
	ignoreList.add("SHP_ParentChildForm");
	ignoreList.add("SHP_RORODeckEnquiryForm");
	ignoreList.add("SOP_LaneDeviceDefinitionForm");
	ignoreList.add("SOP_RTSessionFormOld");
	ignoreList.add("SOP_RTGTerminalLanes");
	ignoreList.add("SHP_OOWC_CraneDetailsForm");
	ignoreList.add("LOG_Action_Form");
	ignoreList.add("SHP_BayDefinitionForm");
	ignoreList.add("SHP_BayDefinitionWizardForm");
	ignoreList.add("SHP_BayDefnGraphicForm");
	ignoreList.add("SHP_BayListFormTEST");
	ignoreList.add("INV_ReceiveCargoCashDrForm");
	ignoreList.add("INV_InvoiceHealthCheck");
	
	

	// load the schema combo
	activeSchema :=  rootSchema.getSchema("UiCommonSchema");
	
	// get all subschemas
	create schemaColl transient;
	activeSchema.allSubschemas(schemaColl);
	
	foreach schema in schemaColl do
		if allowableSchemasArray.includes(schema.name) then 
			classColl := schema.getAllClasses(false);
			foreach class in classColl do
				if class.schema = schema and not ignoreList.includes(class.name)  then
										
					if schema.name &lt;&gt; activeSchema.name then
						if class.name.pos("CMUI_",1) &gt; 0 or class.name.pos("CM_",1) &gt; 0 then
							continue;
						endif;	
					endif;
					
					if class.getProperties.isEmpty then
						continue;
					endif;
					
					if class.name.pos("ViewForm" ,1) &gt; 0 then
						continue;
					endif;
										
					if class.name = "CMUI_QueryEnquiry" then
						continue;
					endif;
					
					if not xIsBaseForm(class) then
						continue;
					endif;
					
					translateMethod :=	class.getMethod("translateForm");
					caption := "";
					xlatDeets := "";
					if translateMethod &lt;&gt; null then
						if  xCheckCaptionTranslated(translateMethod,constName) then
							goodKeyword := true;
							
							if constName &lt;&gt; null then
								obj := constDict[constName];
								if obj &lt;&gt; null then
									trans := app.zGetUntranslatedText(XLAT_FormCaptions,   obj.GlobalConstant.getSource.Integer );
									if trans &lt;&gt; null then
										caption := trans.text;
									else
										xlatDeets := " " &amp; obj.GlobalConstant.getSource &amp; " " &amp; obj.GlobalConstant.name;
									endif;
								endif;
							endif;
							
							if _getBlank then
								if caption.isBlank  then
									goodKeyword := false;
								endif;
							else	
								if caption.pos("_",1) &gt; 0 then
									goodKeyword := false;
								endif;
							endif;
							
						else
							goodKeyword := false;
						endif;
						if not goodKeyword then
							
							logString :=  schema.name &amp; "::" &amp; class.name &amp; xlatDeets;
							problemClassesArray.add(logString);
						//	_userSummaryDict.addAssociation(class.getModifiedBy, logString);
							_userSummaryDict.addAssociation("JLGNS1", class.getModifiedBy &amp; "_" &amp; logString);
								
						endif;
					else	
						logString :=  schema.name &amp; "::" &amp; class.name;
						problemClassesArray.add( logString);
						_userSummaryDict.addAssociation("JLGNS1", class.getModifiedBy &amp; "_" &amp; logString);
						
					endif;
				endif;
			endforeach;
			delete classColl;
		endif;
	endforeach;	
	
	//Uncomment to see whats wrong
	//problemClassesArray.inspectModal();
	
	if app.isDevelopmentSystemMain then
		dMastMessage := "Make sure Form caption in Painter is set and then run GenTranslateFormMethod app to generate Form captipion";
	else
		// Wmast
		dMastMessage := "Fix up the Form caption in Dmast or check the XLAT translation and regenerate as required";
	endif;
	
		
	if _getBlank then	
		self.assertEqualMsg(problemClassesArray.size,0,"The following forms have no help keyword" &amp; CrLf &amp;  problemClassesArray.asCSV(false).replaceString(",",CrLf) &amp; CrLf &amp; dMastMessage);
	else	
		self.assertEqualMsg(problemClassesArray.size,0,"The following forms have form_name as help keyword" &amp; CrLf &amp;  problemClassesArray.asCSV(false).replaceString(",",CrLf) &amp; CrLf &amp; dMastMessage);	
	endif;
		
epilog
	delete constDict;
	delete schemaColl;	
	delete allowableSchemasArray;
	delete problemClassesArray;
	delete ignoreList;
	delete classColl;

end;</source>
        <Parameter name="_getBlank" type="Boolean"/>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xIsBaseForm" id="bdd90fd9-9dc4-4950-850d-5c142cadcb28">
        <source>xIsBaseForm(class	: Class):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2018	jlgns1	Initial creation

*/

vars
	n : String;
begin
	n := class.name;
	if class.name = "CM_BaseForm" then
		return true;
	else
		if class.getSuperclass &lt;&gt; null then
			return xIsBaseForm(class.getSuperclass);
		endif;
	endif;
	
	
	return false;
	
	
epilog

end;</source>
        <Parameter name="class" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xcheckReturnStatement" id="9577370c-cf7e-40ec-9952-9fbe092fe8e0">
        <source>xcheckReturnStatement(s1: String; s2:String):Boolean;
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
25 Jul 2025	navbs1	Initial creation Story MTN-35186: MTN - Investigate getDisplayStringForAttribute Improvements
 
*/
 
vars
	s1_m : HugeStringArray; 
	c1,c2: String;
begin
	create s1_m transient;
	s1.getHugeTokensForDelimiter("_",s1_m);
	if s1_m.size &gt;1 and s1_m[2] &lt;&gt; null then 
		c1:= s1_m[2].toUpper;
	endif;
	if s2.length &gt;5 then 
		c2 := s2[6:s2.length].toUpper;
	endif;
	if c1 = null  or c2 = null then 
		return false;
	endif;
	if c1= c2 then 
		return true;
	endif;
	return false;
epilog
		
	delete s1_m;
end;</source>
        <Parameter name="s1" type="String"/>
        <Parameter name="s2" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
