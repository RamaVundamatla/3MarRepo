    <DbClassMap file="_usergui"/>
    <CompAttribute name="allXAxisLabels" id="d9455db9-f653-4371-9c28-7b038ce42d13">
        <type name="StringArray"/>
    </CompAttribute>
    <JadeMethod name="calculateGraphSize" id="d13c2a4c-87ca-42e3-a7fc-ece93376ed3f">
        <updating/>
        <source>calculateGraphSize() updating, protected;

begin
	self.graphHeight	:=	(self.height - self.graphLabelHeight - self.graphLabelHeight - 0).Integer;
	self.graphWidth		:=	(self.width - self.maxScaleLabelWidth - 6).Integer;
	
	if self.borderStyle &lt;&gt; 0 then
		self.graphHeight	:=	self.graphHeight - 2;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearGraph" id="d496ba79-de7a-42c8-960d-a41787e00bde">
        <updating/>
        <source>clearGraph() updating;

begin
	inheritMethod();
	self.allXAxisLabels.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="createBars" id="fb8b4aa3-ac56-44d3-97c8-5e84b61c3aa5">
        <updating/>
        <source>createBars(pBarWidth:Integer; pNumberOfBars:Integer; pMaxScale:Integer) updating, protected;

vars
	position			: Integer;
	leftPosition		: Integer;
	barHeight			: Integer;
	colorCount			: Integer;
	barColor			: Integer;
	leftCoordinate		: Integer;
	rightCoordinate		: Integer;
	topCoordinate		: Integer;
	bottomCoordinate	: Integer;

begin
	colorCount	:=	self.allGraphColors.size();

	foreach position in 1 to pNumberOfBars do
		leftCoordinate	:=	leftPosition + self.maxScaleLabelWidth;
		rightCoordinate	:=	leftCoordinate + pBarWidth;
		
		barHeight	:=	(self.allGraphValues[position] * (self.graphHeight / pMaxScale)).Integer;
		
		if barHeight = self.graphHeight then
			barHeight	:=	barHeight - 1;
		endif;
		
		topCoordinate	:=	(self.graphHeight + self.graphLabelHeight) - barHeight;
		bottomCoordinate	:=	topCoordinate + barHeight;		
		
		if position &lt;= colorCount then 
			barColor	:=	self.allGraphColors[position];
		else
			barColor	:=	0;
		endif;
		
		self.drawFillColor	:=	barColor;		
		self.drawFilledRectangle(leftCoordinate, topCoordinate, rightCoordinate, bottomCoordinate, barColor);
		
		leftPosition	:=	leftPosition + pBarWidth;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pBarWidth" type="Integer"/>
        <Parameter name="pNumberOfBars" type="Integer"/>
        <Parameter name="pMaxScale" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawGraph" id="5a1c6388-9dbc-4cde-b632-609a0ea606a1">
        <updating/>
        <source>drawGraph()updating;

vars
	numberOfBars	: Integer;
	
begin
	inheritMethod();
	
	numberOfBars	:=	self.allGraphValues.size();

	if numberOfBars &gt; 0 then
		self.calculateGraphSize();
		
		if (numberOfBars * 2) &gt; self.graphWidth then
			self.doDataError("Too Much Data");
		else
			self.autoRedraw	:=	true;
			self.setMaxScaleLength();
			self.setScale();
			self.setupForm();
		endif;
	else
		self.doDataError("No Data provided");
	endif;
	
	if self.myLegend &lt;&gt; null then
		self.myLegend.drawGraph();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultsInPainter" id="4f749330-344f-4568-acf0-daacad5867b6">
        <updating/>
        <source>setDefaultsInPainter() updating, protected;

begin
	inheritMethod();
	 
	self.allXAxisLabels.add("January"); 
	self.allXAxisLabels.add("February");
	self.allXAxisLabels.add("March");
	self.allXAxisLabels.add("April");
	self.allXAxisLabels.add("May");
	
	if self.height &lt; 100 then
		self.height	:=	100;
	endif;
	
	if self.width &lt; 100 then
		self.width	:=	100;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setScale" id="132b8216-f54b-4f41-83ca-c47c9f36b9ac">
        <updating/>
        <source>setScale() updating, protected;

vars
	position	: Integer;
	startY		: Integer;
	displayText	: String;	
	
begin
	self.drawTextRotation	:=	0;
	
	foreach position in 1 to 5 do
		if position = 1 then
			displayText	:=	self.maxValue.String;
			startY		:=	self.graphLabelHeight;
		elseif position = 2 then
			displayText	:=	(self.maxValue * 0.75).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.25).Integer - 2;
		elseif position = 3 then
			displayText	:=	(self.maxValue * 0.5).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.50).Integer - 4;
		elseif position = 4 then
			displayText	:=	(maxValue * 0.25).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.75).Integer - 6;
		elseif position = 5 then
			displayText	:=	"0";
			startY		:=	(self.graphLabelHeight + self.graphHeight - 8).Integer;
		endif;
		
		if self.maxValue &gt; 10 then
			displayText	:=	displayText.Integer.String;
		endif;
		
		self.drawTextAt(displayText, 1, startY, Black);	
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setXLabels" id="af2a0999-89b8-4c44-aaa0-e03882b7f086">
        <updating/>
        <source>setXLabels(pBarWidth:Integer; pNumberOfBars:Integer) updating, protected;

vars
	startX				: Real; 
	startY				: Real; 
	displayText			: String; 
	textColor			: Integer;
	textPosition		: Integer;
	numberOfXAxisLabels	: Integer;
	
begin
	numberOfXAxisLabels	:=	self.allXAxisLabels.size();
	
	if pNumberOfBars &gt; 1 then
	
		foreach textPosition in 1 to pNumberOfBars where textPosition &lt;= numberOfXAxisLabels do
			
			displayText	:=	self.allXAxisLabels[textPosition];
			
			while (self.getTextExtent(displayText) &gt; pBarWidth)
			and (displayText.length &gt; 1)
			do
				displayText	:=	displayText[1:(displayText.length - 1).Integer];
			endwhile;
			
			if displayText.length = 1 then
				if self.getTextExtent(displayText) &gt; pBarWidth then
					displayText	:=	"";
				endif;
			endif;	
			
			startX	:=	((textPosition - 1) * pBarWidth) + self.maxScaleLabelWidth;				
			startY	:=	self.graphLabelHeight + self.graphHeight;
			
			//draw the text here
			self.drawTextRotation	:=	0;
			self.drawTextAt(displayText, startX, startY, textColor);
		
		endforeach;
		
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="pBarWidth" type="Integer"/>
        <Parameter name="pNumberOfBars" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7798f610-cf7a-40b2-a561-be734bf0195d">
        <updating/>
        <source>setupForm() updating, protected;

vars
	numberOfBars	: Integer;
	barWidth		: Integer;
	
begin
	numberOfBars	:=	self.allGraphValues.size();
	barWidth		:=	(self.graphWidth / numberOfBars).Integer;
	
	self.createBars(barWidth, numberOfBars, self.maxValue);
	self.setXLabels(barWidth, numberOfBars);
end;</source>
        <access>protected</access>
    </JadeMethod>
