04 April 2023	jlier1	Initial creation 56856

*/

vars
	formCls,
	assistCls	: Class;
	externalWebServicesMonitor : CM_BaseForm;
	subSys : CMUI_SubSystem;
begin
	subSys := app.myController.allSubSystems['SysOpsSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('SOP_ExternalWebServicesMonitor', formCls, assistCls);
	endif;
	
	if formCls = null then
		return;
	endif;
	
	externalWebServicesMonitor := app.loadForm(formCls, assistCls, false, false, true, null, null).CM_BaseForm;
	if externalWebServicesMonitor = null then
		return;
	endif;
	
	externalWebServicesMonitor.setFormObject(_obj);
	
	externalWebServicesMonitor.show;
epilog


end;</source>
