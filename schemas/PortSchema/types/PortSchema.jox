    <JadeMethod name="getHelpFileBaseURL" id="e7abc5db-dcc0-485a-adbb-0699d3b7404e">
        <source>getHelpFileBaseURL() : String;
/*

Purpose:			Return the currently active Help File Base URL, either the User Preference or the
					System value, as appropriate

Parameters:			None

Return Value:		Halp File format

Date		Who		Reason
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation

*/

vars
	user			: CM_User;
	helpURL			: String;
	
begin
	if self.helpIsPDFFormat then
		return null;
	endif;
	
	user := self.getMyUser();
	if user &lt;&gt; null then
		helpURL := user.getHelpFileBaseURL();
	endif;
	
	if user = null or helpURL.trimBlanks.length = 0 then
		helpURL := self.myRoot.getConfig(HelpFileBaseURL).String;
	endif;
	
	return helpURL;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHelpFileFormat" id="08f09223-fa57-499c-bd87-e0e597566fb7">
        <source>getHelpFileFormat() : Integer;
/*

Purpose:			Return the currently active Help File Format, either the User Preference or the
					System value, as appropriate

Parameters:			None

Return Value:		Halp File format

Date		Who		Reason
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation

*/

vars
	user			: CM_User;
	helpFormat		: Integer;
	
begin
	user := self.getMyUser();
	if user &lt;&gt; null then
		helpFormat := user.getHelpFileFormat();
	endif;
	
	// If there's no User or the User is using the default, get the system config value
	if user = null or helpFormat = HelpFile_TypeDefault then
		helpFormat := self.myRoot.getConfig(HelpFileFormat).Integer;
	endif;
	
	// If the system config value has not been set, then default to PDF
	if helpFormat = HelpFile_TypeDefault then
		helpFormat := HelpFile_TypePDF;
	endif;
	
	return helpFormat;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getIMEXStringFromIMEXStatus" id="916b9b00-3816-4a8f-bb89-45fe94fad074">
        <source>getIMEXStringFromIMEXStatus(pStatus : Integer) : String;
// ---------------------------------------------------------------------------
