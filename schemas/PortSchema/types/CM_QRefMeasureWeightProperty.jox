    <JadeMethod name="create" id="193f93e1-3337-434a-83d2-d4139e47ba4b">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwma1	Initial creation

*/

vars
	oper	: CM_QueryOperator;
begin

	create oper as CM_QDecimalInRange persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QDecimalNotInRange persistent;
	self.allAllowedOperators.add(oper);
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="e3d92f7b-727f-4ea1-9f2c-3a5fa82d81f2">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwma1	Initial creation

*/

vars

begin
	if _op.isKindOf(CM_QDecimalInRange) or _op.isKindOf(CM_QDecimalNotInRange)  then
		return QueryControl_ComboBox;
	endif;

	return inheritMethod(_op);
end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
