    <JadeMethod name="windowCreated" id="44da1811-ab0c-4475-8302-7e62e2e9530a">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     23 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myCriteriaLineHolder = null then
		create self.myCriteriaLineHolder transient;
	endif;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
