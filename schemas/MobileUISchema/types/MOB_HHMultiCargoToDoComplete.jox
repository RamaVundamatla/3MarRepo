    <JadeMethod name="translateForm" id="a50cd035-eda0-4112-b237-689836c58062">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 01 October 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020981, locale);
	btnAdd.translateCaption(Xlat_0020982, locale);
	lblAvailable.translateCaption(Xlat_0020983, locale);
	lblCargoId.translateCaption(Xlat_0020984, locale);
	lblSelected.translateCaption(Xlat_0020985, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
