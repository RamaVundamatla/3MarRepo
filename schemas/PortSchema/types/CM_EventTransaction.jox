    <JadeMethod name="getMappedWSDef" id="feed78c1-6fee-42bd-b25a-1ad3862d4692">
        <source>getMappedWSDef() : CM_KiwiRailCheckInWSDef;
/*

Purpose:	Get mapped KiwiRail webservice def to use for webservice call set up,
			assuming only 1 mapped webservice
Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2019	jlgsl4	TFS40360 - NXL - KiwiRail EDI message

*/

vars
	mapping : CM_ExtWebServiceEventMapping;
begin
	foreach mapping in self.myEventType.allExtWebServiceEventMappings where mapping.myExternalWebServiceDef.isA(CM_KiwiRailCheckInWSDef) do
		break;
	endforeach;
	if mapping &lt;&gt; null then
		return mapping.myExternalWebServiceDef.CM_KiwiRailCheckInWSDef;
	endif;
	return null;	
epilog

end;</source>
        <ReturnType type="CM_KiwiRailCheckInWSDef"/>
    </JadeMethod>
    <JadeMethod name="getMinutes" id="1d69b1cc-1be6-4190-a76b-3a93643fc94f">
        <source>getMinutes() : Real;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 20 September 2022
TFS#		: 54850
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	diffTimeStamp 	: Real;
	startTimeStamp	: TimeStamp;
	endTimeStamp	: TimeStamp;
begin
	startTimeStamp 	:= self.getStartTS();
	endTimeStamp	:= self.getEndTS();
	diffTimeStamp	:= startTimeStamp.differenceInHoursReal(endTimeStamp);
	
	return (diffTimeStamp * 60).Real;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
