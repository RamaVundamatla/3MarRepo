<CollClass name="Array">
    <JadeMethod name="jssDoSort" id="2ac2a707-21b1-4fac-8aa4-02b82d8a331d">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pSorterObj:JSSSorter) updating, protected, abstract;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Using the JSSSorter class, this method will sort the members of
//				the receiver array, purge the existing members, and then reload
//				the receiver with the sorted members.
// --------------------------------------------------------------------------------
// Parameters:	pTheSorter - A reference to the transient JSSSorter object.
//
// Returns:		Nothing
// --------------------------------------------------------------------------------</source>
        <abstract/>
        <access>protected</access>
        <Parameter name="pSorterObj" type="JSSSorter"/>
    </JadeMethod>
    <JadeMethod name="jssSort" id="ddcaa972-4e81-443a-9d6c-7c54e38c119c">
        <lockReceiver/>
        <updating/>
        <source>jssSort(pIsDescending:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Using the JSSSorter class, this method will sort the members of
//				the receiver array, purge the existing members, and then reload
//				the receiver with the sorted members.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sorterObj		: JSSSorter;
	
begin
	create sorterObj transient;
	sorterObj.setSortType(self.class.CollClass.memberType.name, pIsDescending);
	self.jssDoSort(sorterObj);
epilog
	delete sorterObj;
end;</source>
        <Parameter name="pIsDescending" type="Boolean"/>
    </JadeMethod>
</CollClass>
