        <updating/>
        <source>gd002_CUN_lstTest_click():Integer updating;

begin
	myCM_ErrorWarningForm:=app.getForm('CM_ErrorWarningForm').CM_ErrorWarningForm;
	if myCM_ErrorWarningForm = null then
		return 1;
	endif;
	myCMUI_Navigator:=app.getForm('CMUI_Navigator').CMUI_Navigator;
	if myCMUI_Navigator = null then
		return 2;
	endif;
	myCMS_UserMessageForm:=app.getForm('CMS_UserMessageForm').CMS_UserMessageForm;
	if myCMS_UserMessageForm = null then
		return 3;
	endif;
	myCMUI_SuperAppForm2:=app.getForm('CMUI_SuperAppForm2').CMUI_SuperAppForm2;
	if myCMUI_SuperAppForm2 = null then
		return 4;
	endif;
	app.doWindowEvents(200);  // 13:41:03
	myCMUI_Navigator.lstTest.listIndex:=myCMUI_Navigator.lstTest.findStringExact(1, 'Gate In/Out');  // listIndex=14
	myCMUI_Navigator.lstTest.itemSelected[myCMUI_Navigator.lstTest.listIndex]:=true;
	myCMUI_Navigator.lstTest_click(myCMUI_Navigator.lstTest);
	return 0;
end;</source>
