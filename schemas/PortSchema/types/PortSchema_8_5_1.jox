    <JadeMethod name="updatePoolingPartners" id="6e10a146-1ef1-47ef-a532-c11ed5cb6238">
        <source>updatePoolingPartners();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/05/2017	cnwdap1		Initial creation TFS 4370 Allow pooling partners across multiple terminals
//
vars
	partner : CM_MTPoolingPartner;
	terminal : CM_Terminal;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Set Empty Pool Party mtyTerminal reference", LogINFO);
	beginTransaction;
	foreach partner in CM_MTPoolingPartner.instances do
		if partner.myTerminal = null then
			partner.setPropertyValue(CM_MTPoolingPartner::myTerminal.name, partner.myPoolingParty.myTerminal);
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Set Empty Pool Party mtyTerminal reference - Complete", LogINFO);
	self.addScriptRun(method.name);
end;</source>
