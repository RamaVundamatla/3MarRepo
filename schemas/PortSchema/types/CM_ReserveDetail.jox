    <JadeMethod name="getPlannerReportGroup" id="e537a22e-3016-4135-9857-777ce51f2323">
        <source>getPlannerReportGroup() : String;
/*
Purpose:			Moved from CM_BulkRelease::getPlannerReportGroup

Parameters:			

Return Value:		

Date		Who		Reason
20/07/18	jlgmd1	Initial creation TFS #39261 SNO - Show Reserve Detail lines on Load List
*/
vars
	group 		: Integer;
	cargoType	: CM_CargoType;
	isoCode		: String;
	isoGroup	: CM_ISOTypeGroup;
	commString	: String;
	comm		: CM_Commodity;
	release			: CM_BulkRelease;
	invalidRelease	: Boolean;

begin
	on Exception do app.handleDeletedObject(exception, release, invalidRelease);
	
	group := null;
	release := self.myReserveHeader;
	
	// if we have a voyage, check for voyage allocations
	if release.myVoyage &lt;&gt; null and release.myVoyage.useVoyageAllocations and release.myAssignedTrain = null then
		return self.getVoyageAllocationGroup();
	endif;
	
	if invalidRelease then
		return null;
	endif;
	
	cargoType := self.getMyCargoType();
	if cargoType &lt;&gt; null then
		if cargoType.id = TI_CargoType_Container then
			isoCode := self.getISOCode;
			if isoCode &lt;&gt; null then
				isoGroup := app.myRoot.allISOTypes[isoCode].myISOTypeGroup;
			else
				isoGroup := self.getISOGroup();
			endif;
			if isoGroup &lt;&gt; null then
				// first get length sorted
				if isoGroup.is40ftLong then
					group := PlanningGroup_FortyFoot;
				elseif isoGroup.is30ftLong then
					group := PlanningGroup_ThirtyFoot;
				elseif isoGroup.is45ftLong then
					group := PlanningGroup_FortyFiveFoot;
				elseif isoGroup.is53ftLong then
					group := PlanningGroup_FiftyThreeFoot;
				else
					group := PlanningGroup_TwentyFoot;
				endif;
				
				// Now check special attributes
				if isoGroup.isFlat() then
					group := group + PlanningGroup_FlatRack;
				elseif isoGroup.isCrib() then
					group := group + PlanningGroup_Crib;
				elseif isoGroup.isFrame() then	//05 Feb 2018	NDL	TFS 36752
					group := group + PlanningGroup_Frame;
				elseif isoGroup.isTank() then
					group := group + PlanningGroup_Tank;
				elseif isoGroup.isOpenTop() then
					group := group + PlanningGroup_OpenTop;
				elseif isoGroup.isFantainer() then
					group := group + PlanningGroup_Fantainer;
				endif;
			endif;
			
			// Now empty or power
			if not release.fullRelease then
				commString := release.myTerminal.getDefaultEmptyCommodity();
				comm := app.myRoot.allCommodities[commString];
			endif;
			if comm &lt;&gt; null then
				if comm.isEmpty then
					group := group + PlanningGroup_Empty;
				elseif comm.requiresPower then
					group := group + PlanningGroup_PowerRequired;
				endif;
			endif;
			
		else
			// Non-container cargo, so sort to the end, with System-defined types before
			// User-defined types
			group := cargoType.id;
			if group &lt; TI_CargoBOLType_Max then
				group := TI_CargoBOLType_Max - group;
			endif;
		
		endif;
	endif;
	
	return group.String.padLeadingZeros(5).truncatedAt(5);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPlannerReportGroupDesc" id="8e083c2f-2cfc-4b1c-97b9-fff4e53419f0">
        <source>getPlannerReportGroupDesc() : String;
/*

Purpose:			Moved from CM_BulkRelease::getPlannerReportGroupDesc

Parameters:			

Return Value:		

Date		Who		Reason
20/07/18	jlgmd1	Initial creation TFS #39261 SNO - Show Reserve Detail lines on Load List

*/
vars
	groupDesc		: String;
	cargoType		: CM_CargoType;
	isoCode			: String;
	isoGroup		: CM_ISOTypeGroup;
	cargoTyp		: CM_CargoType;
	comm			: CM_Commodity;
	isGen			: Boolean;
	release			: CM_BulkRelease;
	invalidRelease	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, release, invalidRelease);
	
	groupDesc := null;
	release := self.myReserveHeader;
	
	// PAR #26426 if voyage uses voyage allocations, return voyage allocation code not planner group
	if release.myVoyage &lt;&gt; null and release.myVoyage.useVoyageAllocations and release.myAssignedTrain = null then
		return self.getVoyageAllocationGroupDesc();
	endif;
	// PAR #26426 end
	
	cargoType := self.getMyCargoType();
	if cargoType &lt;&gt; null then
		if cargoType.id = TI_CargoType_Container then
			// First get length sorted
			isoCode := self.getISOCode;
			if isoCode &lt;&gt; null then
				isoGroup := app.myRoot.allISOTypes[isoCode].myISOTypeGroup;
			else
				isoGroup := self.getISOGroup();
			endif;
			if isoGroup &lt;&gt; null then
				if isoGroup.is40ftLong then	
					groupDesc := app.getErrorString(FortyFoot);
				elseif isoGroup.is30ftLong then
					groupDesc := app.getErrorString(ThirtyFoot);
				elseif isoGroup.is45ftLong then
					groupDesc := app.getErrorString(FortyFiveFoot);
				elseif isoGroup.is53ftLong then
					groupDesc := app.getErrorString(FiftyThreeFoot);
				else
					groupDesc := app.getErrorString(TwentyFoot);
				endif;
			
				// Now check special attributes
				if isoGroup.isFlat() then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_FlatRack);
				elseif isoGroup.isCrib() then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Crib);
				elseif isoGroup.isTank() then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Tank);
				elseif isoGroup.isOpenTop() then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_OpenTop);
				elseif isoGroup.isFantainer() then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Fantainer);
				else
					isGen := true;
				endif;
			endif;
				
			// Now empty or power
			if not release.fullRelease then
				comm := app.myRoot.allCommodities[release.myTerminal.getDefaultEmptyCommodity];
			endif;
			if comm &lt;&gt; null then
				if comm.isEmpty then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Empty);
				elseif comm.requiresPower then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Integral);
				elseif isGen then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_General);
				endif;
			endif;
			
		else
			// Non-container cargo, so use Cargo Type Description
			groupDesc := cargoTyp.description;
		endif;
	else
		groupDesc := app.getErrorString(SummaryDesc_Unknown);
	endif;
	
	return groupDesc.truncatedAt(30);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
