    <JadeMethod name="doNotableClear" id="9dbac2e5-a696-434c-8fdc-baf80429bb07">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="21b7b4fb-3ec0-42f9-8b02-c4158d1f056c">
        <updating/>
        <source>doPrint() updating;

vars
	mess, head : String;
	bank : CM_Bank;
begin
	bank := self.myCurrentBank;		// 35872
	// TFS 2076 don't print if the table has not been set up yet
	if self.tblData.columns = self.tblData.fixedColumns then
		return;
	endif;
	if self.cmbDebtor.listObject &lt;&gt; null then
		mess := "Printing Financial Periods for Debtor " &amp; self.cmbDebtor.listObject.CM_DebtorNode.name;
		head := bank.mailingName &amp; " Financial Periods for Debtor "  &amp; self.cmbDebtor.listObject.CM_DebtorNode.name; 
	else
		mess := "Printing Financial Periods for All Debtors ";
		head := bank.mailingName &amp; " Financial Periods for All Debtors " ; 
	endif;

	self.doTblDataPrint(mess,head,"Debtor Financial Periods");

end;</source>
    </JadeMethod>
