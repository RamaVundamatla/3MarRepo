    <JadeMethod name="addTI" id="29dcec6c-5cb9-4e00-9b37-29e183fd38a6">
        <updating/>
        <source>addTI(_ti : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	bulkRel : CM_BulkRelease;
	
begin
	if app.isUnitTestGarbageCollect then
		return;
	endif;
	
	// 23/01/2012 cnwar2 #28841
	if _ti.state = TI_STATE_NOTIFIED then
		app.raiseCMException1(PrenoteAttachToRelReq, _ti.id, null, null);
		return;
	endif;
	if (not self.allTrackedItems.includes(_ti)) then
		self.allTrackedItems.add(_ti);
		//13 Dec 2017	NDL	TFS 8091
		if not self.isTransient then
			self.updateObjectEdition( self );
		endif;
		bulkRel := self.myReserveHeader;
		
// cnwdad1 30/06/2009 - PAR #20126.  This should never happen, but in dev environment,
// some case of this were found, so just adding protection against it so a transaction
// will not udate the database if this occurs.
		if bulkRel = null then
			app.raiseUnexpectedProgramError(self.class.name, method.name, "Reserve Detail has missing reference to Bulk Release.");
			return;
		endif;
	
		bulkRel.addTIAssigned(_ti, null); //cnwrd1 ccms 1075 28.1.10 - checks if already includes later
		
	endif;
	
	if self.allTrackedItemsReleased.includes(_ti) then
		self.allTrackedItemsReleased.remove(_ti);
		//13 Dec 2017	NDL	TFS 8091
		if not self.isTransient then
			self.updateObjectEdition( self );
		endif;
	endif;
	
	if self.myReserveHeader &lt;&gt; null then
		if self.myReserveHeader.allTrackedItemsReleased.includes(_ti) then
			self.myReserveHeader.allTrackedItemsReleased.remove(_ti);
		endif;
		
		if (not self.myReserveHeader.allTrackedItemsAssigned.includes(_ti)) then
			//self.myReserveHeader.allTrackedItemsAssigned.add(_ti);
			self.myReserveHeader.addTIAssigned(_ti, null);  //cnwrd1 ccms 1075 28.1.10 - checks if already includes later
		endif;
	endif;
		
		
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addTIReleased" id="567750da-12cf-4dd3-a2c3-8938c31901a6">
        <updating/>
        <source>addTIReleased(_ti : CM_TrackedItem input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
28/07/2022	 navkc1		 Bug 54305: PRP - Null Object Reference
23/06/2023	 navkc1		CR 58406 Task 58408: Jade - Release Request All Tracked Items
----------   ----------  --------------------------------------------------

*/
vars
	reserveDetail : CM_ReserveDetail;
	bulkRelease : CM_BulkRelease;
begin
	
	if (not self.allTrackedItemsReleased.includes(_ti)) then
		self.allTrackedItemsReleased.add(_ti);
		//13 Dec 2017	NDL	TFS 8091
		if not self.isTransient then
			self.updateObjectEdition( self );
		endif;
	endif;
	if self.allTrackedItems.includes(_ti) then
		self.allTrackedItems.remove(_ti);
		//13 Dec 2017	NDL	TFS 8091
		if not self.isTransient then
			self.updateObjectEdition( self );
		endif;
	endif;
	
	//25 May 2012	NDL	Par 29585	- moved out of the if statement above.
	foreach bulkRelease in _ti.allBulkReleasesAssigned do
		foreach reserveDetail in bulkRelease.allReserveDetails do
			if reserveDetail.allTrackedItems.includes(_ti) then
				reserveDetail.allTrackedItems.remove(_ti);
				//13 Dec 2017	NDL	TFS 8091
				if not reserveDetail.isTransient then
					self.updateObjectEdition( reserveDetail );
				endif;
				
				// 28/07/2022	navkc1	#54305 ---&gt;
				if reserveDetail &lt;&gt; self	// make sure it is not deleting itself
					and reserveDetail.myReserveHeader &lt;&gt; null	
					 and reserveDetail.myReserveHeader &lt;&gt; self.myReserveHeader
					  and not reserveDetail.myReserveHeader.releaseByType	// make sure it is release by ID
					   //and reserveDetail.allTrackedItems.isEmpty()			// make sure there's no other tracked items
					   and not reserveDetail.hasTi() //23/06/2023	navkc1	CR 58406 Task 58408
					    and reserveDetail.validateForDelete(false) then		
					
						delete reserveDetail;
				endif;
				// &lt;-- 28/07/2022	navkc1	#54305
				
			endif;
		endforeach;
	endforeach;
	
	if self.myReserveHeader &lt;&gt; null then
		// As the TI is now released add to the released collection and
		// remove from the assigned collection
		
		if (not self.myReserveHeader.allTrackedItemsReleased.includes(_ti)) then
			// _ti.setMyBulkReleaseReleased(null); //cnwrd1 27.5.09
			_ti.setMyBulkReleaseReleased(self.myReserveHeader);
		endif;
		
		if self.myReserveHeader.allTrackedItemsAssigned.includes(_ti) then
			self.myReserveHeader.allTrackedItemsAssigned.remove(_ti);
		endif;
	
	endif;
	
end;

</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="adjustTotalRequested" id="f9428360-e308-48ea-9f7b-164ea57ce408">
