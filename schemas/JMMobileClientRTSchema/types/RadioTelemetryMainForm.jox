// Created 14 May 2008 by cnwvu1
// -------------------------------------------

vars

begin
	
	self.doQueryResort();
	
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateFromState" id="33a64811-da84-4db2-8150-514de0ef22fa">
        <updating/>
        <source>updateFromState() updating, protected;

/*

Date		Who		Reason
13 Jan 2006	cnwdvb1	Created
11 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
					Also changed enabling of Reject button to be only when we have a task

*/
vars
	myTerminal : CM_Terminal;
begin
	if self.aState = RadioTelemetryGuiAgent.LoggedOnReset then
		self.resetForm();
		self.tblDataToDo.mbEnable(false);
		self.tblDataGrade.mbEnable(false);
		self.aIsAbleToPutOnHold			:=	false;
		self.btnPUEnquiry.visible		:=	false;
		self.btnPDEnquiry.visible		:=	false;
		
		self.setContolsForTandemLift();			// CCMS 1959 cnwyl1 03/12/2007
		self.txtContainerID2.text		:=	null;
		/*			
			Date		Who		Reason			
		 21 Aug 2008	cnwdz2	Par 17782 CCMS Otago 1722 - Thin Client RT Changes: view the list of currently unactioned jobs 
								without pressing the VIEW button after a set down. This is a configurable option at terminal level 								
		*/
		if self.aRTQueueAfterSetdown then
			self.btnAccept.click(self.btnAccept);
		endif;
	elseif self.aState = RadioTelemetryGuiAgent.LoggedOff then
		self.txtContainerID.text		:=	null;
		self.txtContainerID2.text		:=	null;
		self.aIsLoggedOn				:=	false;
		self.setOnHoldBtn(false);
		self.shtMoves.enabled			:=	false;
		self.shtReports.visible			:=	false;
		self.btnLogOff.enabled			:=	false;
		self.btnLogOffExit.enabled		:=	false;
		self.btnChangePass.enabled		:=	false;
		self.btnPreferences.enabled		:=	false;
		self.btnChangeQueue.enabled		:=	false;			// PAR #16010
		self.tblDataToDo.mbEnable(false);
		self.tblDataGrade.mbEnable(false);
		self.showLogonFrame(true);
		self.txtNewPassword.setFocus();
	
	elseif self.aState = RadioTelemetryGuiAgent.OfferedTask then	
		self.btnAccept.caption			:=	Caption_Accept;
//		self.btnAccept.picture			:=	picAccept.picture;
		self.btnTasksUpdate.enabled		:=	false;
		self.btnGradesUpdate.enabled	:=	false;
		self.btnPickup.enabled 			:=	false;
		self.btnInfo.enabled			:=	false;
		self.btnChangePass.enabled 		:=	false;
		self.btnPreferences.enabled 	:=	false;
		self.btnChangeQueue.enabled		:=	false;			// PAR #16010
		//self.txtNewLocation.enabled		:=	false;		// readOnly ???
		self.txtNewLocation.enabled		:=	true;		// readOnly ???
		self.btnLogOff.enabled			:=	false;
		self.btnLogOffExit.enabled		:=	false;
		self.btnReject.enabled			:=	true;
		self.tblDataToDo.mbEnable(false);
		self.tblDataGrade.mbEnable(false);	
		self.txtContainerID.mbEnable(false);
		self.aIsAbleToPutOnHold			:=	false;
		self.txtContainerID2.text		:=	null;
	
	elseif self.aState = RadioTelemetryGuiAgent.AcceptedTask then		
		self.doAcceptedTask();
		//self.txtContainerID2.text		:=	null;	// 03/04/2004 cnwar2 #16377
	
	elseif self.aState = RadioTelemetryGuiAgent.ActionedPickupWithTask then		
		self.btnAccept.caption 			:=	Caption_Accept;
//		self.btnAccept.picture			:=	picAccept.picture;
		self.btnAccept.enabled			:=	false;
		self.btnTasksUpdate.enabled		:=	false;
		self.btnGradesUpdate.enabled	:=	false;
		self.btnPickup.enabled 			:=	true;
		self.btnInfo.enabled			:=	false;
		self.btnChangePass.enabled 		:=	false;
		self.btnPreferences.enabled 	:=	false;
		self.btnChangeQueue.enabled		:=	false;			// PAR #16010
		self.btnReject.enabled			:=	false;
		self.btnPickup.caption			:=	self.Caption_Setdown;
		self.btnPickup.picture			:=	self.picSetDown.picture;
		self.txtNewLocation.enabled		:=	true;
		self.btnLogOff.enabled			:=	false;
		self.btnLogOffExit.enabled		:=	false;
		self.tblDataToDo.mbEnable(false);
		self.tblDataGrade.mbEnable(false);
		self.txtContainerID.mbEnable(false);
		self.aIsAbleToPutOnHold			:=	true;
		//self.txtContainerID2.text		:=	null;	// 04/04/2004 cnwar2 #16380
	
	elseif self.aState = RadioTelemetryGuiAgent.Error then
		// This is now reset to last state by mapping method on self.aState
		self.tblDataToDo.mbEnable(false);
		self.tblDataGrade.mbEnable(false);
		
		// Do nothing.
		
	elseif self.aState = RadioTelemetryGuiAgent.Display_TI then
		self.btnAccept.caption			:=	self.getViewButtonCaption;		// PAR #16010
//		self.btnAccept.picture			:=	picView.picture;
		self.btnTasksUpdate.enabled		:=	self.aIsSaveRequired;
		self.btnGradesUpdate.enabled	:=	true;
		self.btnPickup.enabled 			:=	true;
		self.btnInfo.enabled			:=	true;
		self.btnChangePass.enabled 		:=	true;
		self.btnPreferences.enabled 	:=	true;
		self.btnChangeQueue.enabled		:=	true;			// PAR #16010
		self.btnPickup.caption			:=	self.Caption_Move;
		self.btnPickup.picture			:=	picMove.picture;
		self.btnAccept.enabled			:=	true;
		self.btnReject.enabled			:=	false;			// PAR #16010
		self.txtContainerID.mbEnable(true);
		self.btnLogOff.enabled			:=	true;
		self.btnLogOffExit.enabled		:=	true;
		self.tblDataToDo.mbEnable(true);
		self.tblDataGrade.mbEnable(true);
		self.txtNewLocation.enabled		:=	true;
		self.aIsAbleToPutOnHold			:=	false;
		self.txtNewLocation.setFocus();
		self.txtContainerID2.text		:=	null;
	
	elseif self.aState = RadioTelemetryGuiAgent.DisruptedMediator then
		self.tblDataToDo.mbEnable(false);
		self.tblDataGrade.mbEnable(false);
		self.txtContainerID.mbEnable(false);
		self.recoverFromDisruptedState();

	elseif self.aState = RadioTelemetryGuiAgent.ActionedPickup then
		self.btnPickup.caption			:=	self.Caption_Setdown;
		self.btnPickup.picture			:=	picSetDown.picture;
		self.btnAccept.enabled			:=	false;
		self.btnReject.enabled			:=	false;	
		self.btnPickup.enabled			:=	true;
		self.btnGradesUpdate.enabled	:=	false;
		self.btnTasksUpdate.enabled		:=	false;
		self.btnInfo.enabled			:=	false;
		self.btnPreferences.enabled		:=	false;			// PAR #16010
		self.btnChangeQueue.enabled		:=	false;			// PAR #16010
		self.txtNewLocation.enabled		:=	true;
		self.btnLogOff.enabled			:=	false;
		self.btnLogOffExit.enabled		:=	false;
		self.aIsAbleToPutOnHold			:=	false;
		self.txtNewLocation.setFocus();
		self.tblDataToDo.mbEnable(false);
		self.tblDataGrade.mbEnable(false);
		self.txtContainerID2.text		:=	null;
	
	elseif self.aState = RadioTelemetryGuiAgent.ActionedMove then
		self.btnAccept.caption			:=	self.getViewButtonCaption;		// PAR #16010
//		self.btnAccept.picture			:=	picView.picture;
		self.btnTasksUpdate.enabled		:=	self.aIsSaveRequired;
		self.btnGradesUpdate.enabled	:=	true;
		self.btnPickup.enabled 			:=	true;
		self.btnInfo.enabled			:=	true;
		self.btnChangePass.enabled 		:=	true;
		self.btnPreferences.enabled 	:=	true;
		self.btnChangeQueue.enabled		:=	true;			// PAR #16010
		self.btnPickup.caption			:=	self.Caption_Move;
		self.btnPickup.picture			:=	picMove.picture;
		self.btnAccept.enabled			:=	true;
		self.btnReject.enabled			:=	true;
		self.txtContainerID.mbEnable(true);
		self.btnLogOff.enabled			:=	true;
		self.btnLogOffExit.enabled		:=	true;
		self.tblDataToDo.mbEnable(true);
		self.tblDataGrade.mbEnable(true);
		self.txtNewLocation.enabled		:=	true;
		self.aIsAbleToPutOnHold			:=	false;
		self.txtContainerID.setFocus();
	
	elseif self.aState = RadioTelemetryGuiAgent.Display_TI_Search_Results or			// PAR #16010
		   self.aState = RadioTelemetryGuiAgent.Display_Show_Queue_Entries then	
		self.btnAccept.caption			:=	self.getViewButtonCaption;					// PAR #16010
		self.btnTasksUpdate.enabled		:=	false;
		self.btnGradesUpdate.enabled	:=	false;
		self.btnPickup.enabled 			:=	false;
		self.btnInfo.enabled			:=	true;
		self.btnChangePass.enabled 		:=	true;
		self.btnPreferences.enabled 	:=	true;
		self.btnChangeQueue.enabled		:=	true;
		self.btnPickup.caption			:=	self.Caption_Move;
		self.btnPickup.picture			:=	picMove.picture;
		self.btnAccept.enabled			:=	true;
		self.btnReject.enabled			:=	false;
		self.txtContainerID.mbEnable(true);
		self.btnLogOff.enabled			:=	true;
		self.btnLogOffExit.enabled		:=	true;
		self.tblDataToDo.mbEnable(true);
		self.tblDataGrade.mbEnable(true);
		self.txtNewLocation.enabled		:=	false;
		self.aIsAbleToPutOnHold			:=	false;
		self.txtContainerID.setFocus();
		self.txtContainerID2.text		:=	null;

	endif;
	
	fraDetails.visible	:=	self.aIsLoggedOn;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateViewCaption" id="f1ae7c69-c8bb-4f9d-bafe-a5046944502b">
        <updating/>
        <source>updateViewCaption() updating, protected;

/*

Purpose:			If required, get the new number of entries in the queue, and update 
					the View button caption as appropriate


Return Value:		None


Date		Who		Reason
13 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	acceptCaption	: String;
	len				: Integer;
	
begin
	if self.aShowNumberOfQueueEntries then
		acceptCaption := self.btnAccept.caption;
		len := self.Caption_View.length;
		if acceptCaption[1:len] = self.Caption_View then
			self.doGetCurrentSettings();
			self.btnAccept.caption := self.getViewButtonCaption();
		endif;
	endif;
	
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="userNotify" id="ab498423-8d3b-4012-86d8-a8e28790bce4">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// -------------------------------------------
// Created 24 January 2006 by cnwdvb1
// -------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doUserNotify(eventType, theObject, eventTag, userInfo);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeUseNameToIniFile" id="dda28c3e-7a00-4f36-9629-148a33699f87">
        <source>writeUseNameToIniFile() protected;
// -------------------------------------------
// Created 09 February 2006 by cnwdvb1
// -------------------------------------------
vars

	iniFileName	: String;
	
begin

	iniFileName := app.getIniFileName();
	app.setProfileString(self.aIniFileName, RadioTelemetryIniFileSection, Key_RTLastUser, self.txtUserName.text);


end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
