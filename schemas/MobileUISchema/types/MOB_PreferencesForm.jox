    <JadeMethod name="hasUnsavedChanges" id="2e0c8aec-3770-466f-af23-54c7bdc43a3a">
        <source>hasUnsavedChanges(): Boolean;
/*
	Created on 20 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if self.aGeneralBack &lt;&gt; app.colorBackGeneral
	or self.aGeneralFore &lt;&gt; app.colorForeGeneral
	or self.aTablesBack	&lt;&gt;	app.colorBackTables
	or self.aTablesFore	&lt;&gt;	app.colorForeTables then
		return true;
	endif;
	return inheritMethod();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectColor" id="a10ec184-73a7-4333-b606-479de5ccbf77">
        <updating/>
        <source>selectColor(_isBackground:Boolean; _isForTables:Boolean; _isDefault:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Selects a background and/or foreground color to be used by the whole
//				application.
//
// Parameters:	_isBackground - True if the background color is being set, otherwise
//					the foreground is assumed (if the default is not being set).
//				_isForTables - Trus if the color is being set for the Tables, otherwise
//					a color for the general background will be assumed.
//				_isDefault - True if the background and foreground colors are to be
//					set to the Windows default colors.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	selectedColor	: Integer;
	
begin
	if _isDefault then
		app.getDefaultSystemColors(self.aGeneralBack, self.aGeneralFore, self.aTablesBack, self.aTablesFore);
		self.doChangeToSelectedColors();
		self.modalResult	:=	self.MB_MODAL_UPDATE;
		
	elseif _isForTables then
		if _isBackground then
			selectedColor	:=	self.aTablesBack;
		else
			selectedColor	:=	self.aTablesFore;
		endif;
		
		if self.doGetColor(selectedColor) then
			if _isBackground then
				self.aTablesBack	:=	selectedColor;
			else
				self.aTablesFore	:=	selectedColor;
			endif;
		endif;
		
	else
		if _isBackground then
			selectedColor	:=	self.aGeneralBack;
		else
			selectedColor	:=	self.aGeneralFore;
		endif;
		
		if self.doGetColor(selectedColor) then
			if _isBackground then
				self.aGeneralBack	:=	selectedColor;
			else
				self.aGeneralFore	:=	selectedColor;
			endif;
			
			self.doChangeToSelectedColors();
		endif;
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_isBackground" type="Boolean"/>
        <Parameter name="_isForTables" type="Boolean"/>
        <Parameter name="_isDefault" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4f0ed3bf-55be-4b69-80ac-0f5bea555fe6">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 April 2008 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	centreWindow();
	self.aGeneralBack	:=	app.colorBackGeneral;
	self.aGeneralFore	:=	app.colorForeGeneral;
	self.aTablesBack	:=	app.colorBackTables;
	self.aTablesFore	:=	app.colorForeTables;
	self.doApplyScreenColors();
	self.modalResult	:=	self.MB_MODAL_CANCEL;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2eff5a86-d61a-46a3-b3b4-2913a12dd77c">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017617, locale);
	btn_BackgroundGe.translateCaption(Xlat_0013213, locale);
	btn_BackgroundTb.translateCaption(Xlat_0013214, locale);
	btn_Cancel.translateCaption(Xlat_0013215, locale);
	btn_Default.translateCaption(Xlat_0013216, locale);
	btn_ForegroundGe.translateCaption(Xlat_0013217, locale);
	btn_ForgroundTb.translateCaption(Xlat_0013218, locale);
	btn_Save.translateCaption(Xlat_0013219, locale);
	grp_Colours.translateCaption(Xlat_0013220, locale);
	grp_General.translateCaption(Xlat_0013221, locale);
	grp_Tables.translateCaption(Xlat_0013222, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
