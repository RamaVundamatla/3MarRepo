    <JadeMethod name="populateYardAllocations" id="9e7e8bfc-ec33-4495-8de1-ac6ce4520335">
        <source>populateYardAllocations() protected;
// --------------------------------------------------------------------------------
// Created:		02 May 2005 by cnwdad1
//
// Purpose:		Populated the form's Yard Allocation combobox control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	comboboxObj			: ComboBox;
	yardAllocationObj	: CM_YardAllocation;
	listPointer			: Integer;
	
begin
	comboboxObj	:=	self.cmbYardAlloc;
	comboboxObj.clear();
	
	listPointer	:=	comboboxObj.addItem("&lt;" &amp; app.getErrorString1(Lit_New,app.getErrorString(YardAllocation)) &amp; "&gt;");
//	listPointer	:=	comboboxObj.addItem("&lt;" &amp; $CNEC_NEW("Yard Allocation") &amp; "&gt;");
	comboboxObj.itemData[listPointer]	:=	self.YA_NEW;
	
	if self.myYATemplateGroup &lt;&gt; null then
		foreach yardAllocationObj in self.myYATemplateGroup.allYardAllocations do
			listPointer	:=	comboboxObj.addItem(yardAllocationObj.getListDisplay());
			comboboxObj.itemObject[listPointer]	:=	yardAllocationObj;
			comboboxObj.itemData[listPointer]	:=	self.YA_OTHER;
		endforeach;
	else
		foreach yardAllocationObj in self.myTerminal.allYardAllocations do
			// TFS 1775 Apr 2016 cnwjre1 stop invoice allocations as showing as yard allocations
			if yardAllocationObj.isInvoiceAllocation then
				continue;
			endif;
			listPointer	:=	comboboxObj.addItem(yardAllocationObj.getListDisplay());
			comboboxObj.itemObject[listPointer]	:=	yardAllocationObj;
			comboboxObj.itemData[listPointer]	:=	self.YA_OTHER;
		endforeach;
	endif;
	
	
	yardAllocationObj	:=	self.ctrlYardAlloc.myYardAllocation;
	
	listPointer	:=	self.cmbYardAlloc.findObject(yardAllocationObj);
	
	if listPointer = CNEC_NULL_INDEX then
		comboboxObj.listIndex	:=	1;
	else
		comboboxObj.listIndex	:=	listPointer;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
