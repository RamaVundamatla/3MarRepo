    <JadeMethod name="cnwdad1_Test_ProcessField" id="2f95f5cc-61e1-48d3-91a0-d0e2fddc1507">
        <source>cnwdad1_Test_ProcessField();
// --------------------------------------------------------------------------------
// Created:		03 December 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allFieldNames	: StringArray;
	allFieldValues	: StringArray;
	fieldName		: String;
	fieldIndex		: Integer;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	create allFieldNames transient;
	create allFieldValues transient;
	
	foreach fieldIndex in 1 to 5 do
		allFieldNames.add("FIELD" &amp; fieldIndex.String);
		allFieldValues.add("Value" &amp; fieldIndex.String);
	endforeach;
	
	write "UserInfo=" &amp; process.userInfo;
	fieldIndex	:=	0;

	foreach fieldName in allFieldNames do
		fieldIndex	:=	fieldIndex + 1;
		
		beginTransaction;
		process.jssSetUserInfoFieldValue(allFieldNames[fieldIndex], allFieldValues[fieldIndex]);
		commitTransaction;
		write "UserInfo=" &amp; process.userInfo;
	endforeach;

	write "Field 3=" &amp; process.jssGetUserInfoFieldValue(allFieldNames[3]);

	beginTransaction;
	process.jssSetUserInfoFieldValue(allFieldNames[3], "New Value 3");
	commitTransaction;
	write "UserInfo=" &amp; process.userInfo;

	beginTransaction;
	process.jssSetUserInfoFieldValue(allFieldNames[5], "New Value 5");
	commitTransaction;
	write "UserInfo=" &amp; process.userInfo;

	beginTransaction;
	process.jssSetUserInfoFieldValue(allFieldNames[1], "New Value 1");
	commitTransaction;
	write "UserInfo=" &amp; process.userInfo;

	write "Field 1=" &amp; process.jssGetUserInfoFieldValue(allFieldNames[1]);
	write "Field 3=" &amp; process.jssGetUserInfoFieldValue(allFieldNames[3]);
	write "Field 5=" &amp; process.jssGetUserInfoFieldValue(allFieldNames[5]);
epilog
	delete allFieldNames;
	delete allFieldValues;
	
	write "Process Field completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Sorter" id="6a9948eb-e160-4dc5-971a-457d38ce804e">
        <source>cnwdad1_Test_Sorter();
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSorter	: JSSSorter;
	theValue	: Object;
	loopIndex	: Integer;
	randomValue	: Integer;
	startTime	: Integer;
	createTime	: Integer;
	sortTime	: Integer;
	iterateTime	: Integer;
	deleteTime	: Integer;
	
begin
	// Set up the sorter.
	
	startTime	:=	app.clock();							// Set the clock start time.
	create theSorter;
	theSorter.setSortType(JSSSorter.AS_INTEGER, false);

	createTime	:=	app.clock() - startTime;
	startTime	:=	app.clock();								// Reset the clock start time.
	
	// Load the values to be sorted.
	
	foreach loopIndex in 1 to 1000 do
		randomValue	:=	app.random(1000000);
		theSorter.addValue(randomValue);
	endforeach;

	sortTime	:=	app.clock() - startTime;
	startTime	:=	app.clock();								// Reset the clock start time.

	// Iterate the sorted values.
	
	foreach theValue in theSorter.mySortColl do
		write theValue.jssGetSortValue();			// Show the value in the Output Viewer window.
	endforeach;

	iterateTime	:=	app.clock() - startTime;
	startTime	:=	app.clock();								// Reset the clock start time.
epilog
	delete theSorter;
	deleteTime	:=	app.clock() - startTime;
	
	write "Sorter created in " &amp; (createTime / 1000).String &amp; " seconds.";
	write "Values sorted in " &amp; (sortTime / 1000).String &amp; " seconds.";
	write "Sorted values iterated in " &amp; (iterateTime / 1000).String &amp; " seconds.";
	write "Sorter deleted in " &amp; (deleteTime / 1000).String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_SpellCheck" id="2a16db19-b4be-4f47-9f6f-5fa21aa56b2a">
        <source>cnwdad1_Test_SpellCheck();
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSpellCheck	: JSSSpellCheck;
	prose			: String;
	
begin
	app.jssInitialize();
	
	prose := "The quick brown, fugly, fox jumps over the lazy dog. --    The quick ugly brown fox jumps over the laxy dog.";
	//prose := "big brown bastard bruce beast barrow bilge biscuit bull beef basket";
	
	create theSpellCheck transient;
	write theSpellCheck.checkProse(prose);
epilog
	delete theSpellCheck;
	
	app.jssFinalize();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_SubstringCount" id="86688d2c-5451-4a56-a604-122618ec57f9">
        <source>cnwdad1_Test_SubstringCount();
// --------------------------------------------------------------------------------
// Created:		14 October 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theString	: String;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	theString	:=	"a\b\c\";
	write "There are " &amp; theString.jssSubstringCount("\").String &amp; " occurrences of '\'.";
epilog
	write "Substring Count completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_TotalAvailMemory" id="f23530e4-8f2c-4b48-bb3b-aceac339397c">
        <source>cnwdad1_Test_TotalAvailMemory();
// --------------------------------------------------------------------------------
// Created:		27 November 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	totalMemory		: Integer;
	availableMemory	: Integer;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	node.jssGetServerMemory(totalMemory, availableMemory);
	
	write "Server:" &amp; CrLf &amp; "-------";
	write "Total memory: " &amp; totalMemory.jssNumberFormat();
	write "Available memory: " &amp; availableMemory.jssNumberFormat();

	node.jssGetMemory(totalMemory, availableMemory);
	
	write "";
	write "Client:" &amp; CrLf &amp; "-------";
	write "Total memory: " &amp; totalMemory.jssNumberFormat();
	write "Available memory: " &amp; availableMemory.jssNumberFormat();
epilog
	write CrLf &amp; "Total and Available Memory completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
