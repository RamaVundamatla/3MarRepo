    <JadeMethod name="translateForm" id="25e9fb9a-f2b7-43ae-bb01-e8414d8bb549">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 February 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007189, locale);
	btnCloseReplace.translateBubbleHelp(Xlat_0004078, locale);
	btnCloseReplace.translateCaption(Xlat_0004079, locale);
	btnCloseSearch.translateBubbleHelp(Xlat_0014516, locale);
	btnCloseSearch.translateCaption(Xlat_0004090, locale);
	btnDelete.translateBubbleHelp(Xlat_0004117, locale);
	btnDelete.translateCaption(Xlat_0004121, locale);
	btnEdit.translateBubbleHelp(Xlat_0004128, locale);
	btnEdit.translateCaption(Xlat_0004130, locale);
	btnExport.translateBubbleHelp(Xlat_0004118, locale);
	btnExport.translateCaption(Xlat_0004122, locale);
	btnGenerate.translateBubbleHelp(Xlat_0009739, locale);
	btnGenerate.translateCaption(Xlat_0009740, locale);
	btnImport.translateBubbleHelp(Xlat_0004119, locale);
	btnImport.translateCaption(Xlat_0004123, locale);
	btnLocaleMaint.translateBubbleHelp(Xlat_0004085, locale);
	btnLocaleMaint.translateCaption(Xlat_0004091, locale);
	btnNew.translateBubbleHelp(Xlat_0004129, locale);
	btnNew.translateCaption(Xlat_0004131, locale);
	btnPrint.translateBubbleHelp(Xlat_0004126, locale);
	btnPrint.translateCaption(Xlat_0004127, locale);
	btnReload.translateBubbleHelp(Xlat_0009741, locale);
	btnReload.translateCaption(Xlat_0009742, locale);
	btnReplace.translateBubbleHelp(Xlat_0004115, locale);
	btnReplace.translateCaption(Xlat_0004116, locale);
	btnReportOptions.translateBubbleHelp(Xlat_0004071, locale);
	btnReportOptions.translateCaption(Xlat_0004072, locale);
	btnResetSearch.translateBubbleHelp(Xlat_0004086, locale);
	btnResetSearch.translateCaption(Xlat_0004093, locale);
	btnSearch.translateBubbleHelp(Xlat_0004120, locale);
	btnSearch.translateCaption(Xlat_0004124, locale);
	btnSelectAll.translateBubbleHelp(Xlat_0004102, locale);
	btnSelectAll.translateCaption(Xlat_0004105, locale);
	btnShowReplace.translateBubbleHelp(Xlat_0004087, locale);
	btnShowReplace.translateCaption(Xlat_0004094, locale);
