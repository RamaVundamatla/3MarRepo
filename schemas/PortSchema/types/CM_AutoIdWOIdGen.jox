    <JadeMethod name="getNextId" id="3f086583-04b2-4a89-8fb6-c7c7c6744db4">
        <updating/>
        <source>getNextId(
          _cargoTypeAbbr : String; //1 Sept 2022 navmv20 TFS 54610
		  _terminalCode	 : String  // 19/12/2022	navkc1	TFS CR 55300 TASK 55521
         ): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 January 2019		jlgndl1	Initial creation
01 September 2022 	navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
19 December 2022	navkc1	TFS CR 55300 TASK 55521
*/

vars

	serverDate : Date;
	prefix : String;
	year : String;
	month : String;
	seqNum : Real;
	ttt : String;
	newId : String;
	nextSeqNum : Real;
	
	failSafeCount : Integer;
	inTransactionState : Boolean;

begin

	if self.idStyle &lt;&gt; AutoIdStyle_CargoWOPelindo1 then
		//return inheritMethod(); //1 Sept 2022 navmv20 TFS 54610
		return inheritMethod(_cargoTypeAbbr, null); //1 Sept 2022 navmv20 TFS 54610
	else
	
		serverDate := app.actualTimeServer.Date;
		year := serverDate.format("yy");	
		month := serverDate.format("MM");
		ttt := self.myTerminal.getConfig(AdditionalInfo1).String[1:3].padLeadingZeros(3);
		
		prefix := year &amp; month &amp; ttt;	
		
		seqNum := self.nextSequenceNum;
		
		if seqNum &lt; 1 then
			// never been set
			seqNum := 1;
		endif;
		
		if self.resetOnDateChange( serverDate ) then
			// if new month, it is time to reset the counter.
			seqNum := 1;
		endif;
		
		if seqNum.String.length &gt; self.idSeqNumLength then
			// already blown the limit for seq num, reset
			seqNum := 1;
		endif;
		
		newId := prefix &amp; seqNum.String.padLeadingZeros(self.idSeqNumLength);
		
		nextSeqNum := seqNum + 1;
		if nextSeqNum.String.length &gt; self.idSeqNumLength then
			// next number would blow teh limit, reset next num
			nextSeqNum := 1;
		endif;
		
		inTransactionState:=process.isInTransactionState;
		if not inTransactionState then
			beginTransaction;
		endif;
		self.setLastAndNextValues(	newId, nextSeqNum, 0, serverDate);
		if not inTransactionState then
			commitTransaction;
		endif;
		return newId;
	
	endif;

epilog

end;</source>
        <Parameter name="_cargoTypeAbbr" type="String"/>
        <Parameter name="_terminalCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValidResetOptions" id="02057b6d-904f-493a-8c8c-97afdbc16cd0">
        <source>getValidResetOptions(intArray: IntegerArray input; _styleId: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2019	jlgndl1	Initial creation	TFS 43018

*/

vars

begin

	if _styleId = AutoIdStyle_CargoWOPelindo1 then
		intArray.add( self.Reset_On_Month_Chg_Int );
		return;
	endif;

	intArray.add( self.Reset_On_Overflow_Int );

	if _styleId &gt; 0 then
	
		if _styleId = AutoIdStyle_P_YY_SSS
		or _styleId = AutoIdStyle_YY_SSS
		or _styleId = AutoIdStyle_P_MM_YY_SSS
		or _styleId = AutoIdStyle_P_YY_MM_SSS
		then
			intArray.add( self.Reset_On_Year_Chg_Int );
		endif;
		
		if _styleId = AutoIdStyle_P_MM_YY_SSS
		or _styleId = AutoIdStyle_P_YY_MM_SSS
		then
			intArray.add( self.Reset_On_Month_Chg_Int );
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="intArray" type="IntegerArray" usage="input"/>
        <Parameter name="_styleId" type="Integer"/>
    </JadeMethod>
