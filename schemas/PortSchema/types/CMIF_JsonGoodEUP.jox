    <JadeMethod name="setEffectiveAttributes" id="18af0460-faeb-4e05-a574-f03a4b383559">
        <updating/>
        <source>setEffectiveAttributes(_cargoGroup : CM_CargoGroup; _voyage : CM_Voyage) updating;
/*

Purpose:	To calculate the effective attributes for the cargo discharged to the terminal	

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2025	naviv1	Initial creation
11 Mar 2025 naviv1  JIRA: MTN-34287 : EUP FR | Expected and Effective amounts are incorrect for cargo received via ship 
*/

vars

	ti			: CM_TrackedItem;
	trx	: CM_TITransaction;
begin
	self.quantityEffective		:= 0;
	self.grossWeightEffective	:= 0;
	self.nettWeightEffective	:= 0;
	self.aDMTEffective			:= 0;
	self.volumeEffective		:= 0;
	
	foreach ti in _cargoGroup.allAssignedTrackedItems where ti.myVoyage = _voyage do

		trx := ti.getTransReceive(); 

		// Effective values should be calculated based only on the received items or cargo.
		// If there is no received transaction, skip the tracked item.
		if trx = null then
			continue;
		endif;
		
		// If the item has a discrepancy / overlanded / shortlanded transaction after cargo receival, use the latest related transaction for effective amount calculation
		if ti.hasDiscrepancy() then 
			trx := ti.getLastTransOfType(TRANS_TYPE_DISCREPANCY); 
		elseif ti.isOverlanded() then  
			trx := ti.getLastTransOfType(TRANS_TYPE_OVERLANDED); 
		elseif ti.isShortlanded() then
			trx := ti.getLastTransOfType(TRANS_TYPE_SHORTLANDED);
		endif;

		self.quantityEffective      += trx.totalQuantity;
		self.grossWeightEffective   += app.convertMeasurementForDisplay(weightUOM, trx.totalWeight).asDecimalJMT;
		self.nettWeightEffective    += app.convertMeasurementForDisplay(weightUOM, trx.cargoWeight).asDecimalJMT;
		self.aDMTEffective          += app.convertMeasurementForDisplay(weightUOM, trx.totalWeight).asDecimalJMT();
		self.volumeEffective        += app.convertMeasurementForDisplay(volumeUOM, trx.totalVolume).asDecimalJMT();

	endforeach;

epilog
end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setExpectedAttributes" id="3bf71793-aa8d-42f3-83ed-860d27bf7b73">
        <updating/>
        <source>setExpectedAttributes(_cargoGroup : CM_CargoGroup; _voyage : CM_Voyage; _isForLoadConfirmation : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2024	navnk30	JIRA 19826: EUP | FR 53853 GoodsReceipt - Good/QuantityExpected, Good/GrossWeightExpected and Good/NettWeightExpected Incorrect Values (NTO-884)
10/01/2025	navcs2	MTN-33780  EUP FR | TareWeightExpected is included in the Message but is not in the BRD (NTO-1100)
11 Mar 2025 naviv1	JIRA: MTN-34287 - EUP FR | Expected and Effective amounts are incorrect for cargo received via ship
*/

vars
	ti			: CM_TrackedItem;
	createTrx	: CM_TITransaction;
begin
	self.isSetForCargoGroup		:= false;
	self.quantityExpected		:= 0;
	self.grossWeightExpected	:= 0;
	self.nettWeightExpected		:= 0;
	self.aDMTExpected			:= 0;
	self.tareWeightExpected		:= 0;
	self.volumeExpected			:= 0;
	foreach ti in _cargoGroup.allAssignedTrackedItems where ti.myVoyage = _voyage do
		createTrx := ti.getFirstTransOfType(TRANS_TYPE_CREATED);
		
		if createTrx = null or ti.isOverlanded() then   //JIRA-34287 -- if the cargo is overlanded, then its unexpected one and can be excluded for expected attributes
			continue;
		endif;
		self.quantityExpected		+= createTrx.totalQuantity;
		self.grossWeightExpected	+= app.convertMeasurementForDisplay(weightUOM, createTrx.totalWeight).asDecimalJMT;
		self.nettWeightExpected		+= app.convertMeasurementForDisplay(weightUOM, createTrx.cargoWeight).asDecimalJMT;
		self.aDMTExpected			+= app.convertMeasurementForDisplay(weightUOM, createTrx.totalWeight).asDecimalJMT();
		if _isForLoadConfirmation then				// 10/01/2025	navcs2	MTN-33780																			// 10/01/2025	navcs2	MTN-33780
			self.tareWeightExpected		+= app.convertMeasurementForDisplay(weightUOM, createTrx.tareWeight).asDecimalJMT();
		endif;										// 10/01/2025	navcs2	MTN-33780																			// 10/01/2025	navcs2	MTN-33780
		self.volumeExpected			+= app.convertMeasurementForDisplay(volumeUOM, createTrx.totalVolume).asDecimalJMT();
	endforeach;
	self.isSetForCargoGroup := true;
epilog

end; </source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_isForLoadConfirmation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromReserveDetail" id="8e61a536-aff4-4643-8f09-dc02a86066e4">
        <updating/>
        <source>setFromReserveDetail(_reserveDetail : CM_ReserveDetail) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 24 July 2023
TFS#		: 55938
Function	:

*** Changes ***
Date			Name		TFS#		Description
01/09/2023		navcs2		Bug 60159: EUP | FR 54536 - Damage and Repair CAMS - Transform Change (ID)
25/06/2024		navmd1		TFS 61725 Fix Timestamps not being reported in UTC (as the mapper expects UTC/Zulu time)
****************************************************/
vars
	deliveryParty	: CMIF_JsonDeliveryPartyEUP;
	tso				: TimeStampOffset;
begin
	if _reserveDetail.isKindOf(CM_ReserveSelection) then
		self.iD := _reserveDetail.CM_ReserveSelection.lineNumber.String;	// 01/09/2023 navcs2 Bug 60159
	endif;
	
	if _reserveDetail.myDeliveryParty &lt;&gt; null then
		if self.deliveryParty &lt;&gt; null then
			deliveryParty := self.deliveryParty;
			deliveryParty.setFromReserveDetail(_reserveDetail);			
		else
			create deliveryParty transient;
			deliveryParty.setFromReserveDetail(_reserveDetail);
			self.deliveryParty := deliveryParty;
		endif;
	endif;
	
	if _reserveDetail.deliveryFrom.isValid() then
		self.deliveryDateTimeFrom.setFromLocalTimeStamp(_reserveDetail.deliveryFrom, tso.getUTCBias);
	endif;
	if _reserveDetail.deliveryTo.isValid() then
		self.deliveryDateTimeTo.setFromLocalTimeStamp(_reserveDetail.deliveryTo, tso.getUTCBias);
	endif;
	self.deliveryInstruction := _reserveDetail.deliveryInstructions;
	
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="748f08dd-7cf4-4de0-9f3b-348ab854c667">
        <updating/>
        <source>setFromTI(_ti : CM_TrackedItem ; _translationOperator : CM_Operator ; _isForLoadConfirmation : Boolean; _transaction: CM_TITransaction; _isForEvent : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22/06/2023		jlier1	Initial creation 57077
03/07/2023		jlika1	TFS 58506 - Check for nulls to avoid stackdump
06/07/2023		navcs2	Bug 59014: FR | 54536 EUP - Damage and Repair Missing or Incorrect Fields in Message
21/07/2023		jlika1  TFS 59230 Unable to do Adhoc Run for "EUP Goods Receipt Activity" with early start date
24/07/2023		jlika1	TFS 55938 EUP | Load Confirmation Protocol
07/08/2023		jlika1	TFS 59632 EUP | Goods Receipt and Load Confirmation: Good/Id
11/08/2023		jlika1	TFS 59784 EUP - The CAMS message is not showing the full gridded block stack location
30/08/2023		navcs2	Bug 60155: EUP | FR 54536 - Damage and Repair CAMS - Items found WP1
22/09/2023		navmd1	TFS 60588 Change Good/Goods/CargoType to be the same as its Items
26/09/2023		navlw1	Bug 60601: EUP | FR 53853 GoodsReceipt - Incorrect UOM Value
02/10/2023		navra1  TFS 60662 - EUP | FR - 53853 GoodsReceipt - Output Missing Item Detail/Errors
04/10/2023		navra1  TFS 60687 - EUP | FR - 53853 - GoodsReceipt Missing Data Fields
04/10/2023		navra1  TFS 60586 - EUP | FR - GoodsReceipt - Grammage Value Is Missing In File
05/10/2023		navra1  TFS 60774 - EUP - Container Reference field
06/10/2023		navra1	TFS 60396 -	EUP | FR 54085 - Load Confirmation - Field Mapping
03/11/2023		jlika1	TFS 61087 - EUP - Cargo Type EDI Translations not working
19/12/2023		navcs2	Bug 61010: EUP | FR - 53824 Transport Manifest MilOrderNumber / MillOrderLineNumber Mapping Differences to Call Off
17/01/2024		navcs2	Bug 60687: EUP | FR - 53853 - GoodsReceipt Missing Data Fields
18/04/2024		navdap1	TFS 63732 EUP | FR - 54085 Load Confirmation Stuck in "Extract" Task Status
18/06/2024		navmd1	TFS 61725 Fix Timestamps not being reported in UTC (as the mapper expects UTC/Zulu time)
24/06/2024		navlw1	TFS 61729 EUP | Goods Receipt Technical Debt - Remove code setting item level grammage
10/12/2024		navhn30 Bug MTN-33413: EUP FR | 54085 - NTO-1003 - Mill Order and Mill Order Line Number are missing from the Load Confirmation Message
08/01/2025		navhn30 Bug MTN-33774: EUP FR | StowageMode is missing from the Good level (NTO-1102)
09/01/2025		navcs2	MTN-33773 EUP FR | 53853 - Overlanded product marked as "Repaired" in GoodsReceipt message at the Good Level (NTO-1103)
16/01/2025		navhn30 Bug MTN-33811: EUP FR | 53853 - Incorrect DirectOperation value in Goods Receipt (NTO-1108)
16/01/2025 		naviv1	JIRA 33862 : EUP | FR GoodsReceipt Effective Amounts are incorrect for Shortlanded Cargo
29/03/2025		naviv1	MTN-34323 : EUP | FR Discrepancy Ship transaction is missing from Goods Receipt CAM Protocol
14/04/2025		navhn30 MTN-34603 : EUP FR | 53853 Good Receipt effective Quantity and Weight not correct after Ship Discrepancy
*/

vars
	pxyGoodsOwner			: CMIF_JsonGoodsOwnerEUP;
	pxyMill					: CMIF_JsonMillEUP;
	pxyBuyer				: CMIF_JsonBuyerEUP;
	pxyForwardingAgent		: CMIF_JsonForwardingAgentEUP;
	millOrderPos 			: Integer;
	foundMatch 				: Boolean;
	trx 					: CM_Receive;
	createTrx ,
	disrepancy,
	overlandedTrx,
	splitTrx, createdTrx	: CM_TITransaction;
	address					: CM_Address;
	tiConsignee				: CM_ConsigneeConsignor;
	tiConsignor				: CM_ConsigneeConsignor;
	pxyInstruction			: CMIF_JsonInstructionEUP;
	pxyExportShippingLine	: CMIF_JsonExportShippingLineEUP;
	shippingAddress			: CM_Address;
    xlatCargoType, xlatCommodity,
    xlatLoadStr, xlatUnloadPort,
    xlatFinalDestPort, xlatCargoSubT,
    xlatSortingMethod, xlatShippingLine,
    xlatConsignor,
	totalWgt				: String;
	firstCargoItem,ti		: CM_TrackedItem;
	isOk					: Boolean;
	volume					: Decimal[18,2];
	customsStatus : String;
	cd : CM_CustomDocument;
	cdt : CM_CustomDocumentType;
begin
	
	// If we're the cargo group, then we actually want to report on the 'stuff' in our group
	// The (current) assumption is the Cargo Type, Sub Type, Commodity and IMEX are the same for everything in the group
	if _ti.isCargoGroupItem() then
		firstCargoItem := _ti.CM_CargoGroup.allAssignedTrackedItems.first;
	endif;
	
	if firstCargoItem &lt;&gt; null then
		self.movementType := firstCargoItem.getImexStatusStrDesc;
	else
		self.movementType := _ti.getImexStatusStrDesc;
	endif;
	
	self.bOLNumber := _ti.billOfLading;
	
	//navra1 - TFS 60396 - 6th Oct 2023 - start
	//self.bOLReference := _ti.voyageCode;
	//bOLReference is the carrierRemarks in load confirmation message, and means 
	//remarksAdditional2 in goods receipt message(information from EUP as on 6th Oct 2023)
	if _isForLoadConfirmation then	
		self.bOLReference := _ti.carrierRemarks;
	else
		self.bOLReference := _ti.remarksAdditional2;
	endif;
	//navra1 - TFS 60396 - 6th Oct 2023 - end
	
	create pxyGoodsOwner transient;
	pxyGoodsOwner.code := _ti.operatorCode;
	if _translationOperator &lt;&gt; null then
		pxyGoodsOwner.code :=_translationOperator.getXlationForeignCode(_ti.operatorCode,XLATION_TYPE_OPERATOR_BYOP,foundMatch);
	endif;
	pxyGoodsOwner.name := _ti.operatorDescription;
	self.goodsOwner := pxyGoodsOwner;
	
	if _ti.myOperator &lt;&gt; null and _ti.myOperator.debtor &lt;&gt; null then
		address := _ti.myOperator.debtor.getDefaultDebtorAddress;
		if address &lt;&gt; null then
			create pxyGoodsOwner.address transient;
			pxyGoodsOwner.address.setFromAddress(address);
		endif;
	endif;
	//self.iD := self.goods.size + 1;	// We are setting the id from the PortSchema::CMIF_JsonTransportFullEUP::createGoodFromTI as we are using the collection size to populate it.
	
	//navra1 - TFS 60662 - 2rd Oct 2023 - start
	//if it is itemized, we would have created or matched the Good with the cargo group id, 
	//we dont want to change it with every item in the cargogroup here
	//but if it was non itemized, the good.keyMark would have not been filled up, so fill it 
	//up here with the _ti's id
	if self.keyMarks = null then
		if _ti.myCargoGroup &lt;&gt; null then		//JIRA-34323
			self.keyMarks := _ti.myCargoGroup.id; //JIRA-34323
		else
			self.keyMarks := _ti.id;
		endif;
	endif;
	//navra1 - TFS 60662 - 2rd Oct 2023 - end
	
	self.reference := _ti.mark;
	if firstCargoItem &lt;&gt; null then		//10.12.24	 navhn30	MTN-33413
		millOrderPos:=firstCargoItem.orderNumber.pos("|",1);
		if millOrderPos &gt; 0 then
			self.millOrderNumber :=firstCargoItem.orderNumber[1:millOrderPos -1];
			self.millOrderLineNumber := firstCargoItem.orderNumber[millOrderPos + 1 : end];
		endif;
	else
		millOrderPos:=_ti.orderNumber.pos("|",1);
		if millOrderPos &gt; 0 then
			self.millOrderNumber :=_ti.orderNumber[1:millOrderPos -1];			// 19/12/2023	navcs2	Bug 61010
			self.millOrderLineNumber := _ti.orderNumber[millOrderPos + 1 : end];	// 19/12/2023	navcs2	Bug 61010
		endif;
	endif;
	
	if firstCargoItem &lt;&gt; null then		//16-Jan-2025 naviv1 #33682 - Start
		self.weightUOM 	:= firstCargoItem.getDefaultMeasurementForType(Type_Weight).shortName; 
		self.volumeUOM	:= firstCargoItem.getDefaultMeasurementForType(Type_Volume).shortName; 
		self.lengthUOM 	:= firstCargoItem.getDefaultMeasurementForType(Type_Length).shortName;	
	else								//16-Jan-2025 naviv1 #33682 - End	
		self.weightUOM 	:= _ti.getDefaultMeasurementForType(Type_Weight).shortName; 	// #60601
		self.volumeUOM	:= _ti.getDefaultMeasurementForType(Type_Volume).shortName; 	// #60601
		self.lengthUOM 	:= _ti.getDefaultMeasurementForType(Type_Length).shortName;		// #60601
	endif;
	
	self.description := _ti.description;
	self.grade := _ti.getGrade;
	self.remarks := _ti.remarks;
	//navra1 - TFS 60687 - 3rd October 2023 - start
	//self.colour := _ti.getColour;
	if _ti.isKindOf(CM_CargoGroup) then
		self.colour := _ti.CM_CargoGroup.getCargoGroupColour();
		self.grammage := _ti.CM_CargoGroup.getGrammage(); // navlw1 #61729
		//self.grammage := _ti.CM_CargoGroup.getCargoGroupGrammage();		//navra1 - TFS 60586 - 4th Oct 2023			//navra1 - TFS 60586 - 18th Oct 2023 - Changed requirement
	else
		self.colour := _ti.getColour();
		//self.grammage := _ti.getGrammage();								//navra1 - TFS 60586 - 4th Oct 2023			//navra1 - TFS 60586 - 18th Oct 2023 - Changed requirement
	endif;
	//navra1 - TFS 60687 - 3rd October 2023 - end
	self.width := app.convertMeasurementForDisplay(lengthUOM, _ti.width).asDecimalJMT; 				// #60601
	self.length := app.convertMeasurementForDisplay(lengthUOM, _ti.length).asDecimalJMT; 			// #60601
	self.thickness := app.convertMeasurementForDisplay(lengthUOM, _ti.height).asDecimalJMT; 		// #60601	//MTN-33788
	self.diameter :=  app.convertMeasurementForDisplay(lengthUOM, _ti.getDiameter()).asDecimalJMT; 	// #60601	
	
	//self.grammage := _ti.getGrammage;		//navra1 - TFS 60586 - 4th Oct 2023
	
	self.piecesPerPack := _ti.quantity;	
    
	if firstCargoItem &lt;&gt; null then
		xlatCargoType := firstCargoItem.getCargoTypeID;
		xlatCargoSubT := firstCargoItem.getCargoSubTypeCode;
		xlatCommodity := firstCargoItem.commodity;
	else
		xlatCargoType := _ti.getCargoTypeID;        //10.Aug.2023 navsp1 TFS 59656 &gt;&gt;&gt;&gt;
		xlatCargoSubT := _ti.getCargoSubTypeCode;
		xlatCommodity := _ti.commodity;
	endif;
	
    if _translationOperator &lt;&gt; null then
        xlatCargoType   :=_translationOperator.getXlationForeignCode(xlatCargoType, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch);
        xlatCargoSubT   := _translationOperator.getXlationForeignCode(xlatCargoSubT, XLATION_TYPE_CARGOSUBTYPE_BYOP, foundMatch);
        xlatCommodity   := _translationOperator.getXlationForeignCode(xlatCommodity, XLATION_TYPE_COMMODITY_BYOP, foundMatch);
    endif;

    self.cargoType := xlatCargoType;
    self.packageType:= xlatCargoSubT;
	self.quality := xlatCommodity;              //10.Aug.2023 navsp1 TFS 59656 &lt;&lt;&lt;&lt;
	// 06/07/2023 navcs2 Bug 59014 Start
	if  _ti.myPrimaryActualLocation &lt;&gt; null and _ti.myPrimaryActualLocation.myTerminalArea &lt;&gt; null and _ti.myPrimaryActualLocation.myTerminalArea.isIrregularBlockArea and  _ti.locationId.reversePos(Space) &lt;&gt; 0 then
		self.storageLocation:=_ti.locationId[_ti.locationId.reversePos(Space):end];
	else
		self.storageLocation:=_ti.locationId;
	endif;
	// 06/07/2023 navcs2 Bug 59014 End
	totalWgt := app.convertMeasurementForDisplay(weightUOM, _ti.totalWeight); 	// #60601
	self.aDMTEffective := totalWgt.asDecimalJMT;								// #60601
	
	self.quantityEffective := _ti.totalQuantity;
	self.grossWeightEffective := totalWgt.asDecimalJMT;														// #60601
	self.nettWeightEffective := app.convertMeasurementForDisplay(weightUOM, _ti.weightCargo).asDecimalJMT; 	// #60601
	self.volumeEffective := app.convertMeasurementForDisplay(volumeUOM, _ti.totalVolume).asDecimalJMT; 		// #60601
	//jlier1 TFS  58635 26/6/23
	trx:=_ti.getTransReceive();
	if _ti.hasBeenMerged and trx &lt;&gt; null then
		self.quantityEffective :=trx.totalQuantity;
		self.volumeEffective:=app.convertMeasurementForDisplay(volumeUOM, trx.totalVolume).asDecimalJMT; 		// #60601
		self.grossWeightEffective:=app.convertMeasurementForDisplay(weightUOM, trx.totalWeight).asDecimalJMT; 	// #60601
		self.nettWeightEffective:=app.convertMeasurementForDisplay(weightUOM, trx.cargoWeight).asDecimalJMT; 	// #60601
	endif;
	//jlier1 TFs 59840 30/8/23
	disrepancy:=_ti.getLastTransOfTypeClass(CM_BBDiscrepancy);
	if disrepancy &lt;&gt; null then
		if disrepancy.CM_BBDiscrepancy.quantityChange &lt;&gt; 0 then
			self.quantityEffective := disrepancy.CM_BBDiscrepancy.newTotalQuantity ;
		endif;
		if disrepancy.CM_BBDiscrepancy.weightChange &lt;&gt; 0 then
			totalWgt := app.convertMeasurementForDisplay(weightUOM, disrepancy.CM_BBDiscrepancy.newTotalWeight);	// #60601 
			self.grossWeightEffective := totalWgt.asDecimalJMT;														// #60601 
			if _ti.getDensity &lt;&gt; 0 then
				volume := (totalWgt.asDecimalJMT / _ti.getDensity); 												// #60601
				self.volumeEffective:=app.convertMeasurementForDisplay(volumeUOM, volume).asDecimalJMT; 			// #60601
			else
				self.volumeEffective:=0;
			endif;
			self.volumeEffective := app.convertMeasurementForDisplay(volumeUOM, _ti.totalVolume).asDecimalJMT;
		endif;
		if disrepancy.CM_BBDiscrepancy.cargoWeightChange &lt;&gt; 0 then
			self.nettWeightEffective:= app.convertMeasurementForDisplay(weightUOM, disrepancy.CM_BBDiscrepancy.newCargoWeight).asDecimalJMT; // #60601 
		endif;
	endif;
	

	overlandedTrx := _ti.getTransactionOfType(TRANS_TYPE_OVERLANDED);
	if trx &lt;&gt; null and overlandedTrx &lt;&gt; null and not overlandedTrx.dateTime.isLessThanOrEqualTo(trx.dateTime.addMinutes(1)) then
		overlandedTrx := null; //just a discrepancy after created
	endif;

	createTrx:=_ti.getFirstTransOfType(TRANS_TYPE_CREATED);
	if overlandedTrx &lt;&gt; null  then //if created was overlanded then all 
		self.quantityExpected:=0;
		self.grossWeightExpected:=0;
		self.nettWeightExpected:=0;
		self.volumeExpected:=0;
	else
		//jlier1 TFS  59840 21/8/23
		if createTrx = null then
			createTrx:=_ti.getFirstTransOfType(TRANS_TYPE_SPLIT);
		endif;	
		//no receive transaction expected is what it was created with
		if createTrx &lt;&gt; null then
			//jlier1 TFS 59840 28/8/23
			if createTrx.isKindOf(CM_Split) then
				self.quantityExpected:=createTrx.CM_Split.quantity;
				self.grossWeightExpected:=app.convertMeasurementForDisplay(weightUOM,createTrx.CM_Split.weight).asDecimalJMT; 		// #60601
				self.nettWeightExpected:=app.convertMeasurementForDisplay(weightUOM,createTrx.CM_Split.cargoWeight).asDecimalJMT; 	// #60601
				self.volumeExpected:=app.convertMeasurementForDisplay(volumeUOM,createTrx.CM_Split.volume).asDecimalJMT; 			// #60601
			else
				self.quantityExpected:=createTrx.totalQuantity;
				self.grossWeightExpected:=app.convertMeasurementForDisplay(weightUOM,createTrx.totalWeight).asDecimalJMT; 	// #60601
				self.nettWeightExpected:=app.convertMeasurementForDisplay(weightUOM,createTrx.cargoWeight).asDecimalJMT; 	// #60601
				self.volumeExpected:=app.convertMeasurementForDisplay(volumeUOM,createTrx.totalVolume).asDecimalJMT; 		// #60601
			endif;
			
			
			if trx = null then
				//no receival then effective is 0 otherwise 
				self.quantityEffective:=0;
				self.grossWeightEffective:=0;
				self.nettWeightEffective:=0;
				self.volumeEffective:=0;
			endif;
			
		endif;
	endif;
//	21.04.25	navhn30 	MTN-34603	start
	if _transaction &lt;&gt; null then
		if _transaction.isKindOf(CM_BBDiscrepancy) then
				self.quantityEffective:=0;
				self.grossWeightEffective:=0;
				self.nettWeightEffective:=0;
				self.volumeEffective:=0;
				
				if _transaction.CM_BBDiscrepancy.quantityChange &lt;0 then
					self.quantityExpected:= -1* _transaction.CM_BBDiscrepancy.quantityChange;
				else
					self.quantityExpected:= _transaction.CM_BBDiscrepancy.quantityChange;
				endif;
				if _transaction.CM_BBDiscrepancy.weightChange &lt;0 then
					self.grossWeightExpected:= -1* app.convertMeasurementForDisplay(weightUOM,_transaction.CM_BBDiscrepancy.weightChange).asDecimalJMT;
				else
					self.grossWeightExpected:= app.convertMeasurementForDisplay(weightUOM,_transaction.CM_BBDiscrepancy.weightChange).asDecimalJMT;
				endif;
					if _transaction.CM_BBDiscrepancy.cargoWeightChange &lt;0 then
					self.nettWeightExpected:= -1*app.convertMeasurementForDisplay(weightUOM,_transaction.CM_BBDiscrepancy.cargoWeightChange).asDecimalJMT;
				else
					self.nettWeightExpected:= app.convertMeasurementForDisplay(weightUOM,_transaction.CM_BBDiscrepancy.cargoWeightChange).asDecimalJMT;
				endif;
				
		endif;
		if _transaction.isKindOf(CM_Receive) then
				self.quantityEffective:=_transaction.totalQuantity;
				self.grossWeightEffective:=app.convertMeasurementForDisplay(weightUOM,_transaction.totalWeight).asDecimalJMT;
				self.nettWeightEffective:=app.convertMeasurementForDisplay(weightUOM,_transaction.cargoWeight).asDecimalJMT;
				self.volumeEffective:=app.convertMeasurementForDisplay(volumeUOM,_transaction.totalVolume).asDecimalJMT;
				
				self.quantityExpected:=_transaction.totalQuantity;
				self.grossWeightExpected:=app.convertMeasurementForDisplay(weightUOM,_transaction.totalWeight).asDecimalJMT;
				self.nettWeightExpected:=app.convertMeasurementForDisplay(weightUOM,_transaction.cargoWeight).asDecimalJMT;
				self.volumeExpected:=app.convertMeasurementForDisplay(volumeUOM,_transaction.totalVolume).asDecimalJMT;
		endif;
	endif;
	
	if _isForEvent then
		self.quantityEffective:=_ti.totalQuantity;
		self.grossWeightEffective:=app.convertMeasurementForDisplay(weightUOM, _ti.totalWeight).asDecimalJMT;
		self.nettWeightEffective := app.convertMeasurementForDisplay(weightUOM, _ti.weightCargo).asDecimalJMT;
		self.volumeEffective := app.convertMeasurementForDisplay(volumeUOM, _ti.totalVolume).asDecimalJMT;
		
		createdTrx := _ti.getFirstTransOfType(TRANS_TYPE_CREATED);
		splitTrx  := _ti.getFirstTransOfType(TRANS_TYPE_SPLIT);
				
		if splitTrx &lt;&gt; null and splitTrx.isKindOf(CM_Split) and splitTrx.CM_Split.myParentSplit &lt;&gt; null then
			self.quantityExpected:=splitTrx.CM_Split.myParentSplit.oldQuantity;
			self.grossWeightExpected:=app.convertMeasurementForDisplay(weightUOM,splitTrx.CM_Split.myParentSplit.oldWeight).asDecimalJMT;
			self.nettWeightExpected:=app.convertMeasurementForDisplay(weightUOM,splitTrx.CM_Split.myParentSplit.oldCargoWeight).asDecimalJMT;
			self.volumeExpected:=app.convertMeasurementForDisplay(weightUOM,splitTrx.CM_Split.myParentSplit.oldVolume).asDecimalJMT;
		endif;
		
		if createdTrx &lt;&gt; null then
			self.quantityExpected:=createdTrx.totalQuantity;
			self.grossWeightExpected:=app.convertMeasurementForDisplay(weightUOM,createdTrx.totalWeight).asDecimalJMT;
			self.nettWeightExpected:=app.convertMeasurementForDisplay(weightUOM,createdTrx.cargoWeight).asDecimalJMT;
			self.volumeExpected:=app.convertMeasurementForDisplay(volumeUOM,createdTrx.totalVolume).asDecimalJMT;
		endif;
	endif;
//	21.04.25	navhn30 	MTN-34603	end
	tiConsignor := _ti.getConsignorObject;
	
	create pxyMill transient;
	if tiConsignor  &lt;&gt; null then
        xlatConsignor := tiConsignor.code;  //10.Aug.2023 navsp1 TFS 59656 &gt;&gt;&gt;&gt;
        if _translationOperator &lt;&gt; null then
			xlatConsignor :=_translationOperator.getXlationForeignCode(xlatConsignor ,XLATION_TYPE_CONSIGNEE_BYOP,foundMatch);
		endif;
		pxyMill.code:= xlatConsignor;          //10.Aug.2023 navsp1 TFS 59656 &lt;&lt;&lt;&lt;
		pxyMill.name:= tiConsignor.description;
		address:= tiConsignor.myAddress;
		if address &lt;&gt; null then
			create pxyMill.address transient;
			pxyMill.address.setFromAddress(address);
		endif;
	endif;
	
	self.mill := pxyMill;
	
	tiConsignee := _ti.getConsigneeObject;
	
	create pxyBuyer transient;
	if tiConsignee &lt;&gt; null then
		pxyBuyer.code := tiConsignee.code;
		if _translationOperator &lt;&gt; null then
			pxyBuyer.code :=_translationOperator.getXlationForeignCode(pxyBuyer.code ,XLATION_TYPE_CONSIGNEE_BYOP,foundMatch);
		endif;
		pxyBuyer.name:= tiConsignee.description;
		address:= tiConsignee.myAddress;
		if address &lt;&gt; null then
			create pxyBuyer.address transient;
			pxyBuyer.address.setFromAddress(address);
		endif;
	endif;
	
	self.buyer := pxyBuyer;
	
	create pxyForwardingAgent transient;
	pxyForwardingAgent.code := _ti.freightForwarderCode;
	if _translationOperator &lt;&gt; null then
		pxyForwardingAgent.code :=_translationOperator.getXlationForeignCode(pxyForwardingAgent.code ,XLATION_TYPE_CONSIGNEE_BYOP,foundMatch);
	endif;
	if _ti.myFreightForwarder &lt;&gt; null then
		pxyForwardingAgent.name:=_ti.myFreightForwarder.description;	
		address:=_ti.myFreightForwarder.myAddress;
		if address &lt;&gt; null then
			create pxyForwardingAgent.address transient;
			pxyForwardingAgent.address.setFromAddress(address);
		endif;
	endif;
	self.forwardingAgent := pxyForwardingAgent;

	if not _ti.itemised then					// 06/07/2023 navcs2 Bug 59014
		self.goodsBarcode:=_ti.alternativeId;	// 06/07/2023 navcs2 Bug 59014
	endif;										// 06/07/2023 navcs2 Bug 59014	
	
	self.certificate:=_ti.condition;
	self.containerNumber := _ti.getMyUnpackedFromContainerId;
	
    xlatLoadStr         := _ti.loadPort;                    //10.Aug.2023 navsp1 TFS 59656 &gt;&gt;&gt;&gt;
    xlatUnloadPort      := _ti.dischargePort;
    xlatFinalDestPort   := _ti.destinationPort;
    if _translationOperator &lt;&gt; null then
        xlatLoadStr         := _translationOperator.getXlationForeignCode(xlatLoadStr, XLATION_TYPE_PORT_BYOP, foundMatch);
        xlatUnloadPort      := _translationOperator.getXlationForeignCode(xlatUnloadPort, XLATION_TYPE_PORT_BYOP, foundMatch);
        xlatFinalDestPort   := _translationOperator.getXlationForeignCode(xlatFinalDestPort, XLATION_TYPE_PORT_BYOP, foundMatch);
    endif;
    self.loadingPort            := xlatLoadStr;	
	self.unloadingPort          := xlatUnloadPort;
	self.finalDestinationPort   := xlatFinalDestPort;	
	self.destinationPort        := xlatFinalDestPort;       //10.Aug.2023 navsp1 TFS 59656 &lt;&lt;&lt;&lt;
	
    self.dangerousGoods := _ti.isHazardous;	
	self.iMOClass := _ti.getHazardFirstCode;
	self.flashpoint:=_ti.getHazFlashpoint;
	self.packingGroup:=_ti.getHazardPackingGroup;
	if _ti.getHazardFirst &lt;&gt; null then
		self.uNCode:= _ti.getHazardFirst.getUNDGCode1;
		self.limitedQuantity:=_ti.getHazardFirst.limitedQuantity;
	endif;

	self.customerReference:=_ti.clientRef;
	if firstCargoItem &lt;&gt; null then				//08.01.25	 navhn30	MTN-33774
		self.stowageMode:=firstCargoItem.specialStow;
	else
		self.stowageMode:=_ti.specialStow;
	endif;
	self.countryOfOrigin:=_ti.getCountryOfOriginCode;
	
	if _ti.damaged then	//it has damages				
		self.productCondition := "Damaged";
	endif;
	
	if _ti.isRepaired then	//it has been repaired 		// 09/01/2025 navcs2 MTN-33773
		self.productCondition := "Repaired";
	endif;		
	
	self.operatorVoyageNumber := _ti.remarksAdditional2;
	
	//navra1 - TFS 60687 - 4th October 2023 - start - moved code from inside of if _isForLoadConfirmation
	xlatSortingMethod := _ti.sortingMethod;         //10.Aug.2023 navsp1 TFS 59656 &gt;&gt;&gt;&gt;
    if _translationOperator &lt;&gt; null then
        xlatSortingMethod         := _translationOperator.getXlationForeignCode(xlatSortingMethod, XLATION_TYPE_SORTINGMETHD_BYOP, foundMatch);
    endif;
	self.sortingMethod := xlatSortingMethod;        //10.Aug.2023 navsp1 TFS 59656 &lt;&lt;&lt;&lt;
	//navra1 - TFS 60687 - 4th October 2023 - end - moved code from inside of if _isForLoadConfirmation		
	
	self.containerNumberText := _ti.getContainerNumberText();		//navra1 - TFS 60774 - 5th Oct 2023
		
	if _ti.isCargoGroupItem() then							//16.01.25	 navhn30 	MTN-33811 start
		if firstCargoItem &lt;&gt; null then
			self.directOperation  := firstCargoItem.directDelivery;
			foreach ti in _ti.CM_CargoGroup.allAssignedTrackedItems discreteLock do
				if ti.directDelivery &lt;&gt; firstCargoItem.directDelivery then
					self.directOperation := false;
					break;
				endif;
			endforeach;
		endif;
	else
		self.directOperation := _ti.directDelivery;			//16.01.25	 navhn30 	MTN-33811 end
	endif;
	
	if _isForLoadConfirmation then			//navra1 - TFS 60396 - 6th Oct 2023
		if _ti.myInstructions &lt;&gt; null  then
			create pxyInstruction transient;
			pxyInstruction.setFromInstrucitonsIssued(_ti.myInstructions);
			self.instruction := pxyInstruction;
		endif;
		
		if _ti.myShippingLine &lt;&gt; null then			
			create pxyExportShippingLine transient;
            xlatShippingLine := _ti.myShippingLine.code;    //10.Aug.2023 navsp1 TFS 59656 &gt;&gt;&gt;&gt;
            if _translationOperator &lt;&gt; null then
                xlatShippingLine         := _translationOperator.getXlationForeignCode(xlatShippingLine, XLATION_TYPE_SHIPPINGLINE_BYOP, foundMatch);
            endif;
			pxyExportShippingLine.code := xlatShippingLine;    //10.Aug.2023 navsp1 TFS 59656 &lt;&lt;&lt;&lt;
			if _ti.myShippingLine.myDebtor &lt;&gt; null then
				shippingAddress := _ti.myShippingLine.myDebtor.getDefaultDebtorAddress();
				if shippingAddress &lt;&gt; null then
					create pxyExportShippingLine.address transient;						// TFS 63732
					pxyExportShippingLine.address.setFromAddress(shippingAddress);					
				endif;		
			endif;
			self.exportShippingLine := pxyExportShippingLine;
		endif;
				
		//navra1 - TFS 60687 - 4th October 2023 - start - moved code outside if _isForLoadConfirmation
        /*
        xlatSortingMethod := _ti.sortingMethod;         //10.Aug.2023 navsp1 TFS 59656 &gt;&gt;&gt;&gt;
        if _translationOperator &lt;&gt; null then
            xlatSortingMethod         := _translationOperator.getXlationForeignCode(xlatSortingMethod, XLATION_TYPE_SORTINGMETHD_BYOP, foundMatch);
        endif;
		self.sortingMethod := xlatSortingMethod;        //10.Aug.2023 navsp1 TFS 59656 &lt;&lt;&lt;&lt;
		*/
		//navra1 - TFS 60687 - 4th October 2023 - end - moved code outside if _isForLoadConfirmation
		
		if _ti.allReserveDetailsReleased &lt;&gt; null and _ti.allReserveDetailsReleased.size &gt; 0 then
			self.setFromReserveDetail(_ti.allReserveDetailsReleased.first);
		endif;
		
	endif;
	
	// ### TFS CR 59067 24NOV2023 NAVAB1
	if not _ti.allCustomDocuments.isEmpty() then
		customsStatus := _ti.getCustomsStatus();
		self.customs := customsStatus = app.getErrorString(CustomsStatus_Customs);
		cd := _ti.allCustomDocuments.getLastActiveOutward();
		if cd &lt;&gt; null then
			cdt := cd.myCustomDocumentType;
			self.customsDocumentNumber := cd.code;
			self.customsDocumentDate := cd.dateTime.localToUTCTime();
			if cdt &lt;&gt; null then
				self.customsDocumentType := cdt.code;
			endif;
		else
			cd := _ti.allCustomDocuments.getFirstActive(); // this should be an inward
			if cd &lt;&gt; null then
				cdt := cd.myCustomDocumentType;
				self.customsDocumentNumber := cd.code;
				self.customsDocumentDate := cd.dateTime.localToUTCTime();
				if cdt &lt;&gt; null then
					self.customsDocumentType := cdt.code;
				endif;
			endif;
		endif;
	endif;
	
	isOk := true;
	
epilog
	if not isOk then
		delete pxyGoodsOwner;
		delete pxyMill;
		delete pxyBuyer;
		delete pxyForwardingAgent;
		delete pxyInstruction;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_translationOperator" type="CM_Operator"/>
        <Parameter name="_isForLoadConfirmation" type="Boolean"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_isForEvent" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setID" id="35ab67bd-589a-4a76-a3ba-ce042051805d">
        <updating/>
        <source>setID(_goodsID : String) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 07 August 2023
TFS#		: 59632
Function	:

*** Changes ***
Date			Name		TFS#		Description
01/09/2023		navcs2		Bug 60159: EUP | FR 54536 - Damage and Repair CAMS - Transform Change (ID)
****************************************************/
begin
	self.iD := _goodsID;	// 01/09/2023 navcs2 Bug 60159
end;</source>
        <Parameter name="_goodsID" type="String"/>
    </JadeMethod>
    <JadeMethod name="tareWeightExpected" id="e90a38fe-6a91-4865-b7c8-2fa7d4e5efef">
        <methodInvocation>mapping</methodInvocation>
        <source>tareWeightExpected(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2024	navnk30	JIRA 19826: EUP | FR 53853 GoodsReceipt - Good/QuantityExpected, Good/GrossWeightExpected and Good/NettWeightExpected Incorrect Values (NTO-884)

*/

vars

begin
	if set and self.isSetForCargoGroup then
		_value := self.tareWeightExpected;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="volumeExpected" id="1c0f5b2c-f38b-448b-b987-7ed287ece07b">
        <methodInvocation>mapping</methodInvocation>
        <source>volumeExpected(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2024	navnk30	JIRA 19826: EUP | FR 53853 GoodsReceipt - Good/QuantityExpected, Good/GrossWeightExpected and Good/NettWeightExpected Incorrect Values (NTO-884)

*/

vars

begin
	if set and self.isSetForCargoGroup then
		_value := self.volumeExpected;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
</Class>
