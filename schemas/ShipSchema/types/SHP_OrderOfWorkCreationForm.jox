    <JadeMethod name="btnJobPriority_click" id="8e8620ee-4ad1-4f80-aa64-c968a60cf75c">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnJobPriority_click(btn: Button input) updating;
/*
Purpose:			
Date		Who		Reason
23 August 2012	cnwab1	Initial creation
*/

vars

begin
	self.myAssistant.SHP_Assistant.showVoyageJobPriorityForm(self.myCurrentVoyage, self.myMasterMenuAction, CM_JobPriorityVoyage);

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOOW_click" id="28a59f8e-6420-4bf0-965d-4de290875b3f">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOOW_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin

	if not doCheckVoyage(false) then	// before searching there is null voyage	- cnwvu1
		return;
	endif;

	if self.myCurrentVoyage.allJobSheets.isEmpty then
		app.msgBox("Voyage has no cranes allocated. Cannot produce OOW.",app.getErrorString(Error),MsgBox_OK_Only);
		return;
	else
		if not self.doCheckOOWJobs() then
			return;
		endif;
		if app.msgBox("Are you sure that you want to create the OOW for voyage " &amp; self.myCurrentVoyage.code  &amp; "?", 
						app.getErrorString(Confirmation),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		self.doUpdateOOW(self.myCurrentVoyage.allJobSheets);
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
