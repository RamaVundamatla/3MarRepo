    <JadeMethod name="downloadLogFile" id="b897392c-9cbe-4890-976d-4a1e76ec2d79">
        <updating/>
        <source>downloadLogFile(_changesOnly : Boolean; _logFile : File input; _passport : CM_Passport) updating;
//--------------------------------------------------------------
//Created: 12 August 2002 By: cnwgd1
//--------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 29/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object-based
vars
	//tiSet : CM_TISet;
	tiDict : CM_TIByIdCargoTypeDict;
	ti : CM_TrackedItem;
	log : CM_Log;
	bolIn : CM_BOLIn;
	longStr : CM_LongString;
	cmifMonitor : CMIF_Monitor;
	totalParts : Integer;
	updateProgressAfter : Integer;
	numDone : Integer;
	lastUpdated : Decimal [20];								// PAR #35843
begin

	if _logFile = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null File passed to method.');
		return;
	endif;
	
	create longStr transient;
	
	tiDict := self.myLogController.allTrackedItemsById;
	
	if _passport.myCMIFMonitor &lt;&gt; null then
		totalParts := tiDict.size;
		cmifMonitor := _passport.myCMIFMonitor;
		if (not cmifMonitor.updateProgress("Downloading Log Data For Row " &amp; self.myLogController.id, totalParts, 0)) then
			return;
		endif;
		updateProgressAfter := (totalParts / 20).roundedUp; // update after every 5%
	endif;

	foreach ti in tiDict do
		numDone := numDone + 1;
		//if cmifMonitor &lt;&gt; null and numDone mod updateProgressAfter = 0 then								// PAR #35843
		if cmifMonitor &lt;&gt; null 																				// PAR #35843
		and (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then			// PAR #35843
			if (not cmifMonitor.updateProgress(cmifMonitor.message, cmifMonitor.partsInJob, numDone)) then
				break;
			endif;
			lastUpdated := app.relativeMachineTime;															// PAR #35843
		endif;
		/*if they select "Changes Only", It should use the moveDT on CM_TrackedItem
		 and only take those TI's with a later DT than that. RS email 28/04/03*/
		if _changesOnly and self.lastDownloadTime.isValid then //Par8139
			if ti.moveDT &lt; self.lastDownloadTime then
				continue;
			endif;
		endif;
		if ti.isKindOf(CM_Log) then
			log := ti.CM_Log;
		else	
			log := null;
			continue;
		endif;
		bolIn := log.myReceivalBOL;
		longStr.string := 	',' &amp;		//log status is left blank 
							self.myLogController.getID.csvFormat() &amp; ',' &amp;
							bolIn.dateTime.date.formatAsYYMMDD() &amp; ',' &amp;
							bolIn.number.csvFormat() &amp; ',' &amp;
						  	log.id.csvFormat() &amp; ',' &amp;
						  	log.myOperator.code.csvFormat() &amp; ',' &amp;
						  	log.speciesCode.csvFormat() &amp; ',' &amp;
						  	log.gradeCode.csvFormat() &amp; ',' &amp;
						  	log.typeCode.csvFormat() &amp; ',' &amp;
						  	log.treatmentCode.csvFormat() &amp; ',' &amp;
							log.lengthCode.csvFormat() &amp; ',' &amp;
							log.sedMin.sedStringCSVFormat() &amp; ',' &amp;
							log.sedMax.sedStringCSVFormat() &amp; ',' &amp;
							log.sedMean.sedStringCSVFormat() &amp; ',' &amp;
							log.weightTonnes.csvFormatString() &amp; ',' &amp;
							log.getMyTotalVolume.csvFormatString() &amp; ',' &amp;
							'0' &amp; ',' &amp; //Jason said this is zero
							self.myLogController.isInspected.dataDumpFormat() &amp; ',' &amp;	// 09/09/2009 cnwar2 CCMS-1107/#20627
							self.myLogController.isFumigated.dataDumpFormat();			// 09/09/2009 cnwar2 CCMS-1107/#20627
		_logFile.writeLine(longStr.string);													
	endforeach;
	
epilog
	delete longStr;
	//delete tiSet;
end;</source>
        <Parameter name="_changesOnly" type="Boolean"/>
        <Parameter name="_logFile" type="File" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="downloadLogOutFile" id="b0ba9554-6bd0-4b20-b0d0-1b866e6b3b32">
        <updating/>
        <source>downloadLogOutFile(_changesOnly : Boolean; _logFile : File input) updating;
//--------------------------------------------------------------
//Created: December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tiSet 	: CM_TISet;
	ti 		: CM_TrackedItem;
	log 	: CM_Log;
	bolIn 	: CM_BOLIn;
	longStr : CM_LongString;
	id,
	lot,
	place,
	ave		: String;
	cnt,
	hatch	: Integer;
	order	: CM_StockOrderLine;
	summary	: CM_StockOrderSummary;
	voyOper	: CM_VoyageOperator;
	operFound	: Boolean;
	tmpVoyage : CM_Voyage;
begin

	if _logFile = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null File passed to method.');
		return;
	endif;
	
	create tiSet transient;	
	create longStr transient;
	
	self.myLogController.allTrackedItemsById.copy(tiSet);
	tmpVoyage := self.myLogVoyageStructure.myVoyage;
	hatch := self.myLogVoyageStructure.numHatches;
	
	foreach ti in tiSet do
		if ti.isKindOf(CM_Log) then
			log := ti.CM_Log;
		else	
			log := null;
			continue;
		endif;
		if log.getMyTotalVolume &lt;= 0 then
			continue;
		endif;
		operFound := false;
		foreach voyOper in tmpVoyage.allVoyageIOperators do
			if voyOper.myOperator = log.myOperator then
				operFound := true;
			endif;
		endforeach;
		if (not operFound) then
			continue;
		endif;
		
		if cnt = 0 or cnt = 10 or cnt = 20 then
			foreach summary in tmpVoyage.allStockOrderSummaries do
				foreach order in summary.allStockOrderLines do
					if order.isKindOf(CM_LogStockOrderLine) then
						if order.CM_LogStockOrderLine.lotNo &lt;&gt; null and
						   lot &lt;&gt; order.CM_LogStockOrderLine.lotNo then
							lot := order.CM_LogStockOrderLine.lotNo;
							break;
						endif;
					endif;
				endforeach;
				if lot &lt;&gt; null then
					break;
				endif;
			endforeach;
		endif;
		
		if log.isAverageScaled then
			ave := '1';
		else
			ave := '0';
		endif;
		if cnt &gt; 20 then
			place := 'H';
		else
			place := 'D';
		endif;
		if cnt = 10 or cnt = 20 then
			id := 'N-' &amp; log.id[3:end];
		else
			id := log.id;
		endif;		
		hatch := hatch;

		longStr.string := 	id.csvFormat() &amp; ',' &amp;
							lot.csvFormat() &amp; ',' &amp;
							place &amp; ',' &amp;
							hatch.String &amp; ',' &amp;
							app.serverTimestampAtTrxStart.date.formatAsYYMMDD() &amp; ',' &amp;
							app.serverTimestampAtTrxStart.time.formatAsHHMMSS() &amp; ',' &amp;
							log.getMyTotalVolume.csvFormatString() &amp; ',' &amp;
							ave &amp; ',' &amp;
							tmpVoyage.myTerminal.code.csvFormat() &amp; ',' &amp;
							tmpVoyage.code.csvFormat() &amp; ',' &amp;
						  	log.myOperator.code.csvFormat() &amp; ',' &amp;
						  	log.speciesCode.csvFormat() &amp; ',' &amp;
						  	log.gradeCode.csvFormat() &amp; ',' &amp;
							log.lengthCode.csvFormat() &amp; ',' &amp;						  	
						  	log.typeCode.csvFormat() &amp; ',' &amp;
						  	log.treatmentCode.csvFormat();
		_logFile.writeLine(longStr.string);
		if cnt = 40 then
			cnt := 0;
			hatch := hatch - 1;
		else
			cnt := cnt + 1;													
		endif;
		if hatch = 0 then
			hatch := tmpVoyage.myLogVoyageStructure.numHatches;
		endif;
	endforeach;
	
epilog
	delete longStr;
	delete tiSet;
end;</source>
        <Parameter name="_changesOnly" type="Boolean"/>
        <Parameter name="_logFile" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="downloadShipFile" id="5716c74e-4a4a-40ae-8f50-160abab428a1">
        <updating/>
        <source>downloadShipFile(_shipFile : File input;  _passport : CM_Passport) updating;
//--------------------------------------------------------------
//Created: 12 August 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 29/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object-based
vars
	order 		: CM_StockOrderLine;
	logOrder 	: CM_LogStockOrderLine;	
	longStr 	: String;
	voyContrlr 	: CM_LogVoyageController;
	thePlaceStr : String;
	orderHdr	: CM_StockOrderHeader;
	cmifMonitor : CMIF_Monitor;
	totalParts : Integer;
	updateProgressAfter : Integer;
	numDone : Integer;
	tmpDict : CM_StockOrderByOperOrderNoDict;
	tmpVoyage : CM_Voyage;
	lastUpdated	: Decimal [20];									// PAR #35843
begin

	if _shipFile = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null File passed to method.');
		return;
	endif;
	
	tmpVoyage := self.myLogVoyageStructure.myVoyage;
	tmpDict := tmpVoyage.allOrdersByOperatorOrderNo;
	thePlaceStr := 'H';

	if _passport.myCMIFMonitor &lt;&gt; null then
		totalParts := tmpDict.size;
		cmifMonitor := _passport.myCMIFMonitor;
		if (not cmifMonitor.updateProgress("Downloading Ship Data", totalParts, 0)) then
			return;
		endif;
		updateProgressAfter := (totalParts / 20).roundedUp; // update after every 5%
	endif;
	
	foreach orderHdr in tmpDict do
		numDone := numDone + 1;
		//if cmifMonitor &lt;&gt; null and numDone mod updateProgressAfter = 0 then								// PAR #35843
		if cmifMonitor &lt;&gt; null																				// PAR #35843
		and ((app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates) then		// PAR #35843
			if (not cmifMonitor.updateProgress(cmifMonitor.message, cmifMonitor.partsInJob, numDone)) then
				break;
			endif;
			lastUpdated := app.relativeMachineTime;															// PAR #35843
		endif;

		foreach order in orderHdr.allStockOrderLines do
			if (not order.isKindOf(CM_LogStockOrderLine)) then
				continue;
			else
				logOrder := order.CM_LogStockOrderLine;
			endif;
			longStr	:= 	tmpVoyage.vesselName.csvFormat() &amp; ',' &amp;
						tmpVoyage.myVoyageGlobalArrival.code.csvFormat() &amp; ',' &amp;
						//logOrder.lotNo[1:3].String.csvFormat() &amp; ',' &amp;
						logOrder.lotNo.csvFormat() &amp; ',' &amp;						
						'0' &amp; ',' &amp;
					  	thePlaceStr &amp; ',' &amp;
					  	orderHdr.myOperator.code.csvFormat() &amp; ',' &amp;
					  	logOrder.logSpeciesCode.csvFormat() &amp; ',' &amp;
					  	logOrder.logGradeCode.csvFormat() &amp; ',' &amp;
					  	logOrder.logTypeCode.csvFormat() &amp; ',' &amp;
					  	logOrder.logTreatmentCode.csvFormat() &amp; ',' &amp;
						logOrder.logLengthCode.csvFormat() &amp; ',' &amp;
						logOrder.consigneeCode.csvFormat() &amp; ',' &amp;
						logOrder.reqdQuantity.csvFormatString() &amp; ',' &amp;
						logOrder.dischargePort.csvFormat() &amp; ','; 
						//Jason said the average vol of log is zero so don't show 0 or blank space
			_shipFile.writeLine(longStr);
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_shipFile" type="File" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="901992af-4e84-4d4f-80c5-d2666123fd04">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

vars

begin
	if _attrName = ETRow_RowId then
		if self.myLogController &lt;&gt; null then
			return self.myLogController.getID();
		else
			return null;
		endif;
	elseif _attrName = ETRow_LastDownloadTime then
		if self.lastDownloadTime.isValid then
			return self.systemToLocalTime(self.lastDownloadTime).shortCurrentLocaleFormat();	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return 'Never';
		endif;
	elseif _attrName = ETRow_LastMoveInTime then
		return 'add to lc';
		/*
		if self.myLogController.lastMoveInTime.isValid then
			return self.lastMoveInTime.String;
		else
			return null;
		endif;
		*/

	endif;
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="59fb1a7c-292b-4da8-8c34-9c4ed75d647a">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2016	cnwmp6	Initial creation

*/

vars

begin
	if myLogController &lt;&gt; null then
		return myLogController.getMyTerminal();
	endif;
	if myLogVoyageStructure &lt;&gt; null then
		return myLogVoyageStructure.getMyTerminal();
	endif;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="656a2f5e-8411-4865-9e9d-dd7ff847b5f6">
        <updating/>
        <source>setForCreate(_logController : CM_LogController; _logVoyage : CM_LogVoyageStructure) updating;

vars

begin

	self.lastDownloadTime	:= null;
	self.myLogController	:= _logController;
	self.myLogVoyageStructure := _logVoyage;
//	self.myLogVoyage		:= _voyage;

end;</source>
        <Parameter name="_logController" type="CM_LogController"/>
        <Parameter name="_logVoyage" type="CM_LogVoyageStructure"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateFromProxy" id="62a63fa6-922b-467a-aed7-2de502825a5c">
        <updating/>
        <source>setForUpdateFromProxy(_pxyCMObject: CM_LogVoyageRowDownload; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	08 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _pxyCMObject.lastDownloadTime.isValid() then
		self.lastDownloadTime := _pxyCMObject.lastDownloadTime;
	endif;
	self.myLogController := _pxyCMObject.myLogController;
	self.myLogVoyageStructure := _pxyCMObject.myLogVoyageStructure;
	//self.myLogVoyage := _pxyCMObject.myLogVoyage;
end;</source>
        <Parameter name="_pxyCMObject" type="CM_LogVoyageRowDownload"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="20ead18d-fcd3-42ed-aceb-295024127999">
        <updating/>
        <source>setProxy(_logController : CM_LogController; _logVoyage : CM_LogVoyageStructure) updating;
//-----------------------------------------
// Created: November 2005 By: cnwgd1
//-----------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.myLogController	:= _logController;
	self.myLogVoyageStructure := _logVoyage;
	//self.myLogVoyage		:= _voyage;

end;</source>
        <Parameter name="_logController" type="CM_LogController"/>
        <Parameter name="_logVoyage" type="CM_LogVoyageStructure"/>
    </JadeMethod>
    <JadeMethod name="updateLastDownloadTime" id="0febd985-41d9-419a-8c08-2edbd7f280d1">
        <updating/>
        <source>updateLastDownloadTime(_timeStamp : TimeStamp) updating;

vars

begin

	self.lastDownloadTime	:= _timeStamp;

end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
    </JadeMethod>
