    <JadeMethod name="isSameTIForEDIMerge" id="ef7775d4-593a-4b9f-9dc6-4888dc61e27d">
        <source>isSameTIForEDIMerge(_toTI: CM_TrackedItem; _differences : BooleanArray io);
/*
------------------------------------------------------------------------
Created:			28 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	tiCont : CM_Container;
begin
	inheritMethod(_toTI, _differences);
	//--------------------
	//Carry on and find out what else could be different here..
	//--------------------

	if CM_Container.hasInstance(_toTI) then
		tiCont := _toTI.CM_Container;
	else
		//cargo type change checked in super class - no point cheacking for size change
		return;
	endif;
	
	if self.is40 &lt;&gt; tiCont.is40 then
		//Size has changed
		_differences.atPut(EDIMergeSizeDifference, true);	//its a different size
	endif;

end;</source>
        <Parameter name="_toTI" type="CM_TrackedItem"/>
        <Parameter name="_differences" type="BooleanArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isTIAboveMePlanned" id="f3d331ef-7d6a-499e-9046-05046f74c7b3">
        <source>isTIAboveMePlanned() : Boolean;
// ---------------------------------------------------------------------------
// Created:		06 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	primLocn : CM_LocationsController;
	indexOfMe, indexAbove : Integer;
	topTI : CM_TrackedItem;
begin
	primLocn := self.myPrimaryActualLocation;
	if primLocn = null then
		return true;
	endif;
	
	if not primLocn.isGridLocation() then
		return true;
	endif;
	
	if primLocn.allTrackedItems.size = 1 then
		return true;
	endif;
	
	if primLocn.allTrackedItems.last = self then // TOP TI
		return true;
	endif;
	
	indexOfMe := primLocn.allTrackedItems.indexOf(self);
	indexAbove := indexOfMe + 1;
	
	if indexAbove &lt;= primLocn.allTrackedItems.size then // should be fine
		topTI := primLocn.allTrackedItems[indexAbove];
		if topTI &lt;&gt; null then
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp;  ' 1. ' &amp; topTI.id &amp; " is on top of " &amp; self.id &amp; " &gt;&gt;&gt; " &amp; (topTI.myPrimaryPlannedLocation &lt;&gt; null).String);
			return topTI.myPrimaryPlannedLocation &lt;&gt; null;
		endif;
	endif;
	
	return true;
	
	
	
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTISuitableToRelease" id="a3d2a699-8372-4fae-8baf-e48c7b0af9ce">
        <updating/>
        <source>isTISuitableToRelease(toArea: CM_Object;_errors	: IntegerArray io; _isRelease : Boolean output; _release : CM_Request) updating;
// ---------------------------------------------------------------------------
// Created:     01 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/12/2014	cnwdap1		PAR #35081 New parameter _release
// ---------------------------------------------------------------------------
vars
	
	grade	: CM_MTGrade;

begin
	
	//inheritMethod(toArea,_errors, _isRelease);			// PAR #35081
	inheritMethod(toArea,_errors, _isRelease, _release);	// PAR #35081
	
	if not _isRelease then
		return;
	endif;
	//Check the availability grade if the TI is an empty  container
	if self.isEmpty then
    	grade := app.myRoot.allAvailabilityGrades[availabilityGrade];
    	if grade = null then
 	    elseif grade.isSuitableForRelease = false then	
			_errors.add(ERR_AVAIL_GRADE); //  XPOSE 1808.
    	endif;
	endif;
	
end;</source>
        <Parameter name="toArea" type="CM_Object"/>
        <Parameter name="_errors" type="IntegerArray" usage="io"/>
        <Parameter name="_isRelease" type="Boolean" usage="output"/>
        <Parameter name="_release" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="isTISuitableToShipLoad" id="6a1f3c58-ed39-447d-99e9-7079c5674f7d">
        <source>isTISuitableToShipLoad();
//Called on TI's that are about to be loaded to the Ship Queue
//We test to be sure that the ti is disconnected, and if it has a COU
//is NOT going to be stowed under-deck. Return exceptions as we go.

constants
	MSGBOX_TITLE	=	"Move Warning";
vars
 	aMsg	: String;
 	apEnabled :	Boolean;
 	msgStr	:	String;
begin
	inheritMethod();		//PAR 3469 AJA 14/4/00: Superclass method now has some code !
	apEnabled := self.myTerminal.isAutoPlanningEnabled();   //SFW1030 04/08/2008

	if self.isPlannedUDWithCOU then
		//-------------
		//Attempting to load a TI with a COU to the underdeck area. A NO-NO!
		//-------------
		if apEnabled then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_COU_ATTACHED, self.id.trimRight &amp; " (planned for under deck load)", self.couId.trimRight, null, null);
			return;
		endif;
		//--------------------
		//Autoplanning is NOT enabled, so ask a question...
		//--------------------
		msgStr := app.getErrorString2(WARN_COU_ATTACHED, self.id.trimRight &amp; " (planned for under deck load)", self.couId.trimRight);
		if app.msgBox(msgStr, MSGBOX_TITLE, MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No	then
			//Abort..
			app.setContinueCMExceptions(false);
			app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);
			return;
 		endif;
	endif;
	if self.isConnected and not(self.hasCOU) then
		//-------------
		//If its connected (but NOT to a COU), then complain
		//-------------
		if self.getTower &lt;&gt; null then
			aMsg := "Refrigeration Tower";
		else
			aMsg := "Power Point";
		endif;
		//----------------
		//TI is connected.. A NO-NO!
		//----------------
		if apEnabled then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_STILL_CONNECTED, self.id.trimRight, aMsg, null, null);
			return;
		endif;
		//--------------------
		//Autoplanning is NOT enabled, so ask a question...
		//--------------------

		//PAR 3288 AJA 14/1/00: In non-RT operations, this check is done as part of 'queryMoveFrom'.
		//With this code in place, the question is asked twice when using the 'move it' button on ship ops

		/*msgStr := app.thisXTerminalX.getMsgString(WARN_STILL_CONNECTED, self.id.trimRight , aMsg, "" );
		if app.msgBox(msgStr, MSGBOX_TITLE, MsgBox_Yes_No + MsgBox_Question_Mark_Icon	) = MsgBox_Return_No	then
			//Abort..
			create except;
			except.resetMsgParams;
			except.errorCode := VB_USER_CANCELED_TRANS;
			raise except;
 		endif; */
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="isTMLRCEX" id="8a41658f-f22e-461c-b897-beab059e1b24">
        <source>isTMLRCEX(_transaction: CM_TITransaction; _message: CM_CamMessage): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outbound EDI Depot and Terminal
//
vars
	iter : Iterator;
	tran : CM_TITransaction;

begin
	// RCEX is a Receive Road Empty Export container received to a Marine sub-terminal location
	if not self.isEmpty or not self.isExport then
		return false;
	endif;
	
	// Is the transaction a receive road?
	if _transaction.type &lt;&gt; TRANS_TYPE_REC_ROAD then
		return false;
	endif;
	
	// Is the cam message for a gate in?
	if _message.activity &lt;&gt; CODECO_GATEIN then
		return false;
	endif;
	
	// Is there a Sub-Term Marine Receive (Int) transaction after the Receive - Road?
	iter := self.allTransactions.createIterator;
	iter.startAtObject(_transaction);
	while iter.next(tran) do
		if tran = _transaction then
			continue;
		endif;
		if tran.type = TRANS_TYPE_REC_ST_MARINE_INT then
			break;
		endif;
		if tran.isCamsCodecoRecRelType then
			return false;
		endif;
	endwhile;
	
	return true;

epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_message" type="CM_CamMessage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTMLRCVE" id="d675243e-c92e-4b53-80b8-b7dcbf7ba75f">
        <source>isTMLRCVE(_transaction: CM_TITransaction; _message: CM_CamMessage): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outbound EDI Depot and Terminal
//
vars
	iter : Iterator;
	tran : CM_TITransaction;

begin
	// RCVE is a Receive Road Empty Storage container received to a Depot sub-terminal location
	if not self.isEmpty and not self.isStorage then
		return false;
	endif;
	
	// Is the transaction a receive road?
	if _transaction.type &lt;&gt; TRANS_TYPE_REC_ROAD then
		return false;
	endif;
	
	// Is the cam message for a gate in?
	if not _message.activity = CODECO_GATEIN then
		return false;
	endif;
	
	// Is there a Sub-Term Depot Receive (Int) transaction after the Receive - Road?
	iter := self.allTransactions.createIterator;
	iter.startAtObject(_transaction);
	while iter.next(tran) do
		if tran = _transaction then
			continue;
		endif;
		if tran.type = TRANS_TYPE_REC_ST_DEPOT_INT then
			break;
		endif;
		if tran.isCamsCodecoRecRelType then
			return false;
		endif;
	endwhile;
	
	return true;

epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_message" type="CM_CamMessage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTMLRCVF" id="c029ba82-4f92-45d3-827d-fb11298e96fa">
        <source>isTMLRCVF(_transaction: CM_TITransaction; _message: CM_CamMessage): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outbound EDI Depot and Terminal
//
vars
	iter : Iterator;
	tran : CM_TITransaction;

begin
	// RCVF is a Receive Road Full Export container received to a marine sub-terminal location
	if self.isEmpty or not self.isExport then
		return false;
	endif;
	
	// Is the transaction a receive road?
	if _transaction.type &lt;&gt; TRANS_TYPE_REC_ROAD then
		return false;
	endif;
	
	// Is the cam message for a gate in?
	if not _message.activity = CODECO_GATEIN then
		return false;
	endif;
	
	// Is there a Sub-Term Marine Receive (Int) transaction after the Receive - Road?
	iter := self.allTransactions.createIterator;
	iter.startAtObject(_transaction);
	while iter.next(tran) do
		if tran = _transaction then
			continue;
		endif;
		if tran.type = TRANS_TYPE_REC_ST_MARINE_INT then
			break;
		endif;
		if tran.isCamsCodecoRecRelType then
			return false;
		endif;
	endwhile;
	
	return true;

epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_message" type="CM_CamMessage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTMLSNTC" id="2ba9232e-699a-4bab-8dfa-a65f7b1c9ea6">
        <source>isTMLSNTC(_transaction: CM_TITransaction; _message: CM_CamMessage): Boolean;
//
// Purpose:			Does this TI meet the requirements for a TML SNTC Cams message
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outbound EDI Depot and Terminal
//
vars
	iter : Iterator;
	tran : CM_TITransaction;

begin
	// SNTC is a Release Road Full container released from a Marine sub-terminal location
	if self.isEmpty or not self.isImport then
		return false;
	endif;
	
	// Is the transaction a release road?
	if _transaction.type &lt;&gt; TRANS_TYPE_REL_ROAD then
		return false;
	endif;
	
	// Is the cam message for a gate out?
	if not _message.activity = CODECO_GATEOUT then
		return false;
	endif;
	
	// Is there a Sub-Term Marine Release (Int) transaction before the Release - Road?
	iter := self.allTransactions.createIterator;
	iter.startAtObject(_transaction);
	while iter.back(tran) do
		if tran = _transaction then
			continue;
		endif;
		if tran.type = TRANS_TYPE_REL_ST_MARINE_INT then
			break;
		endif;
		if tran.isCamsCodecoRecRelType then
			return false;
		endif;
	endwhile;
	
	return true;

epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_message" type="CM_CamMessage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTMLSNTS" id="aad565d1-7e78-4b52-9f90-3614996e93a8">
        <source>isTMLSNTS(_transaction : CM_TITransaction; _message : CM_CamMessage) : Boolean;
//
// Purpose:			Does this TI meet the requirements for a TML SNTS Cams message
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outgoing EDI Depot and Terminal
//
vars
	iter : Iterator;
	tran : CM_TITransaction;

begin
	// SNTS is a Release Road for an MT Storage Container from a Depot sub-terminal area
	if not self.isEmpty or not self.isStorage then
		return false;
	endif;
	
	// Is the transaction a release road?
	if _transaction.type &lt;&gt; TRANS_TYPE_REL_ROAD then
		return false;
	endif;
	
	// Is the cam message for a gate out?
	if not _message.activity = CODECO_GATEOUT then
		return false;
	endif;
	
	// Is there a Sub-Term Depot Release (Int) transaction before the Release - Road?
	iter := self.allTransactions.createIterator;
	iter.startAtObject(_transaction);
	while iter.back(tran) do
		if tran = _transaction then
			continue;
		endif;
		if tran.type = TRANS_TYPE_REL_ST_DEPOT_INT then
			break;
		endif;
		if tran.isCamsCodecoRecRelType then
			return false;
		endif;
	endwhile;
	
	return true;
epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_message" type="CM_CamMessage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTMLTRFE" id="d4b35166-31ca-4dd8-9c99-b478f4923ff2">
        <source>isTMLTRFE(_transaction: CM_TITransaction; _message: CM_CamMessage): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outbound EDI Depot and Terminal
// 20/07/2021	navdap1		TFS 51572 TML Swire Outbound EDI TRFE from Marine to Depot values incorrect
// 25/08/2021	navdap1		TFS 51834 TML 1090 occurs when processing new Swire Codeco message for terminal
//
vars
	iter : Iterator;
	tran : CM_TITransaction;

begin
	// TRFE is an Internal Transfer Empty Storage or Export container transferred from 
	// a Depot sub-terminal location to a Marine sub-terminal location 
	// TFS 51572 May also be an Import MT, and moving from a Marine sub-terminal to a Depot	// TFS 51572
	//if not self.isEmpty and not (self.isStorage or self.isExport) then					// TFS 51572
	if not self.isEmpty and not (self.isStorage or self.isExport or self.isImport) then		// TFS 51572
		return false;
	endif;
	
	// Is the transaction a sub-terminal warehouse receive internal?
	// - in this case, we don't need to check where it's come from, we DO want it
	if _transaction.type = TRANS_TYPE_REC_ST_WHOUSE_INT then
		return true;
	endif;
	
	// Is the transaction a sub-terminal marine receive internal?
	// TFS 51572 or a sub-terminal depot receive internal									// TFS 51572
	//if _transaction.type &lt;&gt; TRANS_TYPE_REC_ST_MARINE_INT then								// TFS 51572
	if _transaction.type &lt;&gt; TRANS_TYPE_REC_ST_MARINE_INT and _transaction.type &lt;&gt; TRANS_TYPE_REC_ST_DEPOT_INT then	// TFS 51572
		return false;
	endif;
	
	// Is there a Sub-Term Depot Release (Int) transaction before the Sub-Term Marine Receive (Int)?
	// TFS 51572 Or a Sub-Term Marine Release (Int) transaction before the Sub-Term Depot Receive (Int)?
	iter := self.allTransactions.createIterator;
	iter.startAtObject(_transaction);
	while iter.back(tran) do
		if tran = _transaction then
			continue;
		endif;
		//if tran.type = TRANS_TYPE_REL_ST_DEPOT_INT then
		if (tran.type = TRANS_TYPE_REL_ST_DEPOT_INT and _transaction.type = TRANS_TYPE_REC_ST_MARINE_INT)			// TFS 51572
		or (tran.type = TRANS_TYPE_REL_ST_MARINE_INT and _transaction.type = TRANS_TYPE_REC_ST_DEPOT_INT) then		// TFS 51572
			break;
		endif;
		if tran.isCamsCodecoRecRelType then
			return false;
		endif;
		
		// TFS 51834 If we're dealing with a ship discharge to a Marine subterminal area, this is not a TRFE
		// If there's a Create transaction rather than a Depot release, this Marine receive is not a TRFE
		if tran.type = TRANS_TYPE_CREATED and _transaction.type = TRANS_TYPE_REC_ST_MARINE_INT then
			return false;
		endif;
	endwhile;
	
	return true;

epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_message" type="CM_CamMessage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTank" id="82702b1e-3381-4dc5-bfa2-c95a21517df9">
        <source>isTank() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwas3	Initial creation

*/

vars

begin
	return self.typeAttributes.bitAnd(ISO_TANK) &lt;&gt; 0;
epilog

end;</source>
        <ReturnType type="Boolean"/>
