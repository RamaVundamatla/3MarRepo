    <JadeMethod name="backupException" id="051441cc-68a4-4204-8606-b162a3930545">
        <updating/>
        <source>backupException(_exObj: Exception) :Integer updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	subject,message:String;

begin

	on Exception do app.horribleExceptionHandler(_exObj);

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Error ' &amp; _exObj.errorCode.String, LogAlways);

	abortTransaction;
	abortTransientTransaction;

	if _exObj.errorCode = 3036 then
		// 3036 = File not found
		// Put message onto screen and continue
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; "        Journal number " &amp; logNumber.String &amp; " not backed up.", LogAlways);
		return Ex_Resume_Next;
	endif;

	if _exObj.errorCode = 3071 then
		// 3071 = Overwrite not allowed
		// Put message onto screen and continue
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " ERROR: Journal backup failed due to existing file.", LogAlways);
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; "        Journal number " &amp; logNumber.String &amp; " not backed up.", LogAlways);
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; "        This file should be manually backed up once the problem", LogAlways);
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; "        is corrected.", LogAlways);
		subject := "JacBackup Journal File Exception occured for database "&amp;app.dbPath.trimBlanks&amp;" on "&amp;app.dbServerComputerName.trimBlanks&amp;".";
		message := "An exception ("&amp;_exObj.errorCode.String&amp;") has occured in JacBackup. ERROR: Journal backup failed due to existing file. See backup log for details";
		self.sendEmail(subject, message);
		return Ex_Resume_Next;
	endif;

	if _exObj.errorCode = 3020 or 
	   _exObj.errorCode = 5030 then
		//File is in use by another process
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " ERROR: Journal backup failed due to Journal file in use by another process.", LogAlways);
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; "        Journal number " &amp; logNumber.String &amp; " not backed up.", LogAlways);
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; "        This file should be manually backed up once the problem", LogAlways);
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; "        is corrected.", LogAlways);
		subject := "JacBackup Journal File Exception occured for database "&amp;app.dbPath.trimBlanks&amp;" on "&amp;app.dbServerComputerName.trimBlanks&amp;".";
		message := "An exception ("&amp;_exObj.errorCode.String&amp;") has occured in JacBackup. ERROR: Journal backup failed due to Journal file in use by another process. See backup log for details";
		self.sendEmail(subject, message);
		return Ex_Resume_Next;
	endif;

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " ERROR: Journal backup failed due to unknown cause.", LogAlways);
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; "        Journal number " &amp; logNumber.String &amp; " not backed up.", LogAlways);
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; "        This Journal file should be manually backed up once the problem", LogAlways);
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; "        is corrected.", LogAlways);
	subject := "JacBackup Journal File Exception occured for database "&amp;app.dbPath.trimBlanks&amp;" on "&amp;app.dbServerComputerName.trimBlanks&amp;".";
	message := "An exception ("&amp;_exObj.errorCode.String&amp;") has occured in JacBackup. ERROR: Journal backup failed due to unknown cause. See backup log for details";
	self.sendEmail(subject, message);
	return Ex_Pass_Back;

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="copyFolder" id="805e5f29-b8ba-4ebe-933c-8e2ff50b3d5f">
        <source>copyFolder(_from,_to:String) :Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	folder: CnEcFileFolder;
begin
	create folder transient;
	folder.fileName := _to;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"copyfolder to "&amp;_to&amp;' from '&amp;_from&amp;'.', LogDebug);
	if not folder.isAvailable then
		folder.make;
		if not folder.isAvailable then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;"Creation of directory "&amp;_to&amp;" failed.", LogAlways); 
			return false;
		endif;
	endif;
	folder.fileName := _from;
	if not folder.copy(_to, true) then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;"Local binary backup copy to "&amp;_to&amp;" failed.", LogAlways); 
		return false;
	endif;
	return true;
epilog
	delete folder;
end;</source>
        <Parameter name="_from" type="String"/>
        <Parameter name="_to" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="33bd4e85-6a41-4a97-8428-4993bc9d0ce4">
