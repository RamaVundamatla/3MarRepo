    <JadeMethod name="getHeading" id="46a95a5c-1417-4e3e-8365-53b4e6cd979c">
        <source>getHeading(): String;
// ---------------------------------------------------------------------------
// Created:     28 September 2007 by cnwrs2
//
// Purpose:     PAR 17779
// ---------------------------------------------------------------------------
vars

begin
	if self.isReportMenu then
		return self.getTranslationForCategory(XLAT_ReportNames);
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="String"/>
