vars
	realTI, realTI2		: CM_TrackedItem;
	incomingJsonString,
	terminalCode,
	incomingJson2,
	loginJson,
	expectedResponse	: String;
	expectFailure		: Boolean;
	booking				: CM_BookingRef;
	root				: CM_Root;
	operator 			: CM_Operator;
	voyageOrig			: CM_Voyage;
	terminal 			: CM_Terminal;
	cargoType			: CM_CargoType;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	json				: String;
	params	: String;
	logLevel			: Integer;
	
begin
	//create utHelperTerminal transient;
	logLevel := app.logLevel;
	app.changeLogLevel(LogTRACE);
	
	root := app.myRoot;
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	loginJson := null;	// Use default (REST) operator
	
	self.deleteCargo("API804A25","REBAR");
	self.deleteCargo("API804A29","REBAR");
	// Set up - delete vessel, voyage, terminal area, prenotes, onsite cargo, onship cargo
	self.deleteVoyage(ThisVoyage);
	voyage := self.getVoyage(ThisVoyage);
	self.assertTrueMsg(voyage = null, "Voyage " &amp; ThisVoyage &amp; " not deleted");
	self.deleteVessel(ThisVessel);
	vessel := self.getVessel(ThisVessel);
	self.assertTrueMsg(vessel = null, "Vessel " &amp; ThisVessel &amp; " not deleted");
	
	// Create Vessel / Voyage
	self.createVesselVoyage(ThisVoyage, ThisVessel, operator);
	voyage := self.getVoyage(ThisVoyage);
	self.assertNotNullMsg(voyage, "Voyage " &amp; ThisVoyage &amp; " not found");
	
	//voyageOrig := terminal.lookupVoyage("UTBOLV10", null, true);
	//self.assertTrueMsg(voyageOrig &lt;&gt; null, method.name &amp; " | Setup: voyage is null/could not be found | Voyage Code: " &amp; "UTBOLV10");
	operator := root.allOperators["WEST"];
	self.assertTrueMsg(operator &lt;&gt; null, method.name &amp; " | Setup: operator is null/could not be found | Operator Code: " &amp; "WEST");
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr("REBAR");
	self.assertTrueMsg(cargoType &lt;&gt; null, "Cargo Type REBAR not found");
	
	incomingJsonString := IncomingJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem("API804A25");
	assertEqual(realTI.alternativeId, "TESTY1234");
	assertEqual(realTI.consignee, "ABCNR");
	assertEqual(realTI.getImExStatus, TI_IMEX_STATUS_IMPORT);
	assertEqual(realTI.totalWeight, 2250.Decimal);
	assertEqual(realTI.bookingReference, "1236");
	assertEqual(realTI.isPreNote, true);
	assertEqual(realTI.operatorCode, "WEST");
	assertEqual(realTI.voyageCode,ThisVoyage);
	self.deleteBooking(UTRealBooking);
	// now create a booking
	booking := self.addBookingForGeneralCargo(UTRealBooking, operator, voyageOrig, null, cargoType.id, 100);
	self.assertNotNullMsg(booking, "Booking not created");
	
	// send a second message to create another carog item using bookingId of UTRealBooking
	incomingJson2	:= IncomingJson2;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJson2,expectFailure);
	
	realTI2 := self.getTrackedItem("API804A29");
	assertEqual(realTI2.alternativeId, "TESTY1234");
	assertEqual(realTI2.consignee, "ABCNR");
	assertEqual(realTI2.getImExStatus, TI_IMEX_STATUS_IMPORT);
	assertEqual(realTI2.totalWeight, 2250.Decimal);
	assertEqual(realTI2.bookingReference,UTRealBooking);
	assertEqual(realTI2.isPreNote, true);
	assertEqual(realTI2.operatorCode, "WEST");
	assertEqual(realTI2.voyageCode,ThisVoyage);
	//assertNotNull(realTI2.myBookingRef);
	
	//Start - 22.04.2024 naviv1	#63619 - POST &amp; PUT / Cargo API - Prenotified Trailer Cargo with Onboarded cargo and customs references
	self.deleteCargo("TEST6361904","UTMAFI");
	self.deleteCargo("CH-63619-04","PAPER");
	
	incomingJsonString := PostJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString, expectFailure);
	
	// Make sure we got our pin numbers back
	expectedResponse := '\{"allErrors":null,"allInfo":null,"allWarnings":null,"pinNumbers":\[\{"bookingId":"' &amp; UTRealBooking1 &amp; '","cargoId":"TEST6361904","pin":[0-9]{4}\}\]\}';
	self.assertNotNullMsg(incomingJsonString, "POST /Cargo response is blank, expected pin codes to be returned");
	self.assertTrueMsg(JadeRegex@isMatch(incomingJsonString, expectedResponse, false), "Expcted Pin code to be created for new Prenoted cargo. Response: " &amp; incomingJsonString);
	
	realTI := self.getTrackedItem("CH-63619-04");
	assertEqual(realTI.allCustomsReferences.size, 1);
	
	realTI := self.getTrackedItem("TEST6361904");
	assertEqual(realTI.allCustomsReferences.size, 1);
	assertEqual(realTI.alternativeId, "6361904-ALT");
	assertEqual(realTI.getImExStatus, TI_IMEX_STATUS_EXPORT);
	assertEqual(realTI.totalWeight, 5000.Decimal);
	assertEqual(realTI.bookingReference, "BK-63619-04");
	assertEqual(realTI.isPreNote, true);
	assertEqual(realTI.operatorCode, "UTOP");
	assertEqual(realTI.voyageCode,ThisVoyage);
	//End - 22.04.2024 naviv1	#63619 - POST &amp; PUT / Cargo API - Prenotified Trailer Cargo with Onboarded cargo and customs references
	
	self.deleteCargo("UT699301","UTMAFI");
	incomingJsonString := RailPostJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem("UT699301");
	assertEqual(realTI.allCustomsReferences.size, 1);
	
	self.deleteCargo("TESTPRE01","REBAR");
	
	// Start navlw1 #65030
	if app.isRunningInDMAST() then
		json := PrenoteJsonString.replace("&lt;Priority&gt;", "P1");
	elseif app.isRunningInWMAST() then 
		json := PrenoteJsonString.replace("&lt;Priority&gt;", "CP1");
	endif;
	// end navlw1 #65030
	
	incomingJsonString := json;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem("TESTPRE01");
	
	// Start navlw1 #65030
	if app.isRunningInDMAST() then
		assertEqual(realTI.myCustomerPriority.code,"P1");
	elseif app.isRunningInWMAST() then 
		assertEqual(realTI.myCustomerPriority.code,"CP1");
	endif;
	// end navlw1 #65030
	assertEqual(realTI.shipmentNumber, "HN30");
	
	self.deleteCargo("TESTONSH01","REBAR");
	
	// Start navlw1 #65030
	if app.isRunningInDMAST() then
		json := OnshipCargoJson.replace("&lt;Priority&gt;", "P2");
	elseif app.isRunningInWMAST() then 
		json := OnshipCargoJson.replace("&lt;Priority&gt;", "CP2");
	endif;
	// end navlw1 #65030
		
	incomingJsonString := json;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem("TESTONSH01");
	
	// Start navlw1 #65030
	if app.isRunningInDMAST() then
		assertEqual(realTI.myCustomerPriority.code,"P2");
	elseif app.isRunningInWMAST() then 
		assertEqual(realTI.myCustomerPriority.code,"CP2");
	endif;
	// end navlw1 #65030
	assertEqual(realTI.shipmentNumber, "HN31");
	
	self.deleteCargo("TESTONSI01","REBAR");
	
	// Start navlw1 #65030
	if app.isRunningInDMAST()  then
		json := OnsiteCargoJson.replace("&lt;Priority&gt;", "P3");
	elseif app.isRunningInWMAST() then 
		json := OnsiteCargoJson.replace("&lt;Priority&gt;", "CP3");
	endif;
	// end navlw1 #65030
	
	incomingJsonString := json;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem("TESTONSI01");
	
	// Start navlw1 #65030
	if app.isRunningInDMAST() then
		assertEqual(realTI.myCustomerPriority.code,"P3");
	elseif app.isRunningInWMAST() then  
		assertEqual(realTI.myCustomerPriority.code,"CP3");
	endif;
	// end navlw1 #65030
	assertEqual(realTI.shipmentNumber, "HN32");
	
	//Check content status value added for Prenote, onsite and onship Trailer TI										//TFS 66117
	//POST Request
	self.deleteCargo(TrailerTI01,"TRAILER");																			//TFS 66117
	json := TrailerTypePrenoteJson;																						//TFS 66117
	incomingJsonString := json;																							//TFS 66117
	expectFailure := false;																								//TFS 66117
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);	//TFS 66117	
	verifyPostCargoProperties(TrailerTI01, "ContentStatus");															//TFS 66117
	
	//PUT request
	json := TrailerTypePrenoteJson.replace("[{", "{").replace("}]", "}");												//TFS 66117
	incomingJsonString := json;																							//TFS 66117
	expectFailure := false;																								//TFS 66117
	params := "/Cargo/" &amp; TrailerTI01 &amp; "/" &amp; "UTMAFI"  &amp; "/" &amp; TI_STATE_NOTIFIED.String &amp; "?MasterTerminalAPI";		//TFS 66117	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString, params, expectFailure);	//TFS 66117	
	verifyPostCargoProperties(TrailerTI01, "ContentStatus");															//TFS 66117
	
	//Onsite																											//TFS 66117
	self.deleteCargo(TrailerTI02,"TRAILER");																			//TFS 66117
	json := TrailerTypeOnsiteJson;																						//TFS 66117
	incomingJsonString := json;																							//TFS 66117
	expectFailure := false;																								//TFS 66117
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);	//TFS 66117	
	verifyPostCargoProperties(TrailerTI02, "ContentStatus");															//TFS 66117
	
	//PUT request
	json := TrailerTypeOnsiteJson.replace("[{", "{").replace("}]", "}");												//TFS 66117
	incomingJsonString := json;																							//TFS 66117
	expectFailure := false;																								//TFS 66117
	params := "/Cargo/" &amp; TrailerTI02 &amp; "/" &amp; "UTMAFI"  &amp; "/" &amp; TI_STATE_NORMAL.String &amp; "?MasterTerminalAPI";			//TFS 66117	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString, params, expectFailure);	//TFS 66117	
	verifyPostCargoProperties(TrailerTI02, "ContentStatus");															//TFS 66117
	
	//Onship																											//TFS 66117
	self.deleteCargo(TrailerTI03,"TRAILER");																			//TFS 66117
	json := TrailerTypeOnshipJson;																						//TFS 66117
	incomingJsonString := json;																							//TFS 66117
	expectFailure := false;																								//TFS 66117
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);	//TFS 66117	
	verifyPostCargoProperties(TrailerTI03, "ContentStatus");															//TFS 66117
	
	//PUT request
	json := TrailerTypeOnshipJson.replace("[{", "{").replace("}]", "}");												//TFS 66117
	incomingJsonString := json;																							//TFS 66117
	expectFailure := false;																								//TFS 66117
	params := "/Cargo/" &amp; TrailerTI03 &amp; "/" &amp; "UTMAFI"  &amp; "/" &amp; TI_STATE_ONSHIP.String &amp; "?MasterTerminalAPI";			//TFS 66117	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString, params, expectFailure);	//TFS 66117	
	verifyPostCargoProperties(TrailerTI03, "ContentStatus");															//TFS 66117
	
	//ISO Conatainer Ccheck for content status
	//POST Request
	self.deleteCargo(ISOContainer01,"CONT");																			//TFS 66117
	json := ContainerPrenoteJson;																						//TFS 66117
	incomingJsonString := json;																							//TFS 66117
	expectFailure := false;																								//TFS 66117
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);	//TFS 66117	
	verifyPostCargoProperties(ISOContainer01, "ContentStatus");															//TFS 66117
	
	//PUT request
	json := ContainerPrenoteJson.replace("[{", "{").replace("}]", "}");													//TFS 66117
	incomingJsonString := json;																							//TFS 66117
	expectFailure := false;																								//TFS 66117
	params := "/Cargo/" &amp; ISOContainer01 &amp; "/" &amp; "CONT"  &amp; "/" &amp; TI_STATE_NOTIFIED.String &amp; "?MasterTerminalAPI";		//TFS 66117	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, loginJson, incomingJsonString, params, expectFailure);	//TFS 66117	
	verifyPostCargoProperties(ISOContainer01, "ContentStatus");															//TFS 66117

//	17.09.24	navhn30		TFS 65706	start
	// This tests that the 'prenotified' attribute for child cargo is ignored, and child cargo / 
	// cargo onboard gets created with the same state as the parent

	self.deleteCargo("TEST6570601","UTMAFI");
	self.deleteCargo("CH-65706-01","PAPER");
	
	incomingJsonString := PostJson1;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString, expectFailure);
	
	realTI := self.getTrackedItem("CH-65706-01");
	assertNotNull(realTI);
	self.assertTrue(realTI.isPreNote);
	
	self.deleteCargo("TEST6570602","UTMAFI");
	self.deleteCargo("CH-65706-02","PAPER");
	
	incomingJsonString := PostJson2;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString, expectFailure);
	
	self.logMessagePw("CH-65706-02 | loginJson JSON Response: " &amp; loginJson, LogDEBUG);
	
	self.logMessagePw("CH-65706-02 | incomingJsonString JSON Response: " &amp; incomingJsonString, LogDEBUG);
	
	self.assertTrueMsg(incomingJsonString &lt;&gt; PostJson2, "CH-65706-02 | Got the request json as the response json which is not correct");
	
	self.logMessagePw("Terminal: '" &amp; self.getTerminal.code &amp; "'", LogDEBUG);
	
	realTI := self.getTrackedItem("TEST6570602");
	self.assertNotNullMsg(realTI, "CH-65706-02 | parent MAFI");
	self.assertEqual(realTI.locationId, "UTVOY63113");
	self.assertEqual(realTI.state, 5);
	
	realTI := self.getTrackedItemByCargoType("CH-65706-02", self.getCargoType("PAPER").id);
	if realTI &lt;&gt; null then
		self.logMessagePw("self.getTrackedItemByCargoType - Found: CH-65706-02 tracked item", LogDEBUG);
	endif;
	
	realTI := terminal.lookupTrackedItem("CH-65706-02", self.getCargoType("PAPER").id, TI_STATE_UNDEFINED, null, false);
	if realTI &lt;&gt; null then
		self.logMessagePw("terminal.lookupTrackedItem - Found: CH-65706-02 tracked item using cargo type", LogDEBUG);
	endif;
	
	realTI := terminal.lookupTrackedItem("CH-65706-02", null, TI_STATE_UNDEFINED, null, false);
	if realTI &lt;&gt; null then
		self.logMessagePw("terminal.lookupTrackedItem - Found: CH-65706-02 tracked item without using cargo type", LogDEBUG);
	endif;
	
	realTI := self.getTrackedItem("CH-65706-02");
	self.assertNotNullMsg(realTI, "CH-65706-02 | realTI");
	self.assertEqual(realTI.locationId, "TEST6570602 1");
	self.assertEqual(realTI.state, 5);
	
	self.deleteCargo("TEST6570603","UTMAFI");
	self.deleteCargo("CH-65706-03","PAPER");
	
	incomingJsonString := PostJson3;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString, expectFailure);
	
	realTI := self.getTrackedItem("CH-65706-03");
	assertNotNull(realTI);
	self.assertEqual(realTI.locationId, "TEST6570603 1");
	self.assertEqual(realTI.state, 1);
//	17.09.24	navhn30		TFS 65706	end
epilog
	app.changeLogLevel(logLevel);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostCustomer" id="643500b0-f325-4b36-a204-05914f49beee">
        <source>tPostCustomer();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 August 2022		navlw1	Initial creation tfs 53854
08 September 2022	navmd1	Updated test to conform with latest API definition
19 April 2023		navmd1	TFS 57075 Refactor POST /Customer format
20 June 2023		navmd1	Split out 'normal' POST /Customer from EUP format
16 October 2023		navmd1	Added No Address/RelatedEntities check to pick up future 1090s :(

*/
constants
DebtorName : String = "TFS53854";
DebtorId : String = "UT_53854";

IncomingJsonString = '[
    {
        "id": "'&amp;DebtorId&amp;'",
        "name": "'&amp;DebtorName&amp;'",
        "description": "A Debtor Description/Long Name",
        "accountCode": "53854AccCode",
        "additionalInfo1": "Some Additional Information 1",
        "additionalInfo2": "Some Additional Information 2",
        "badCredit": true,
        "suspended": true,
        "termsOfTradeId": "008",
        "terminalSpecificConfiguration": [
            {
                "id": "MPD",
                "cashOnly": false,
                "paymentType": "Auto Collection",
                "currencyId": "EUR",
                "localeId": "5129",
                "invoiceReportName": "z1Invoices",
                "organisationCode": "53854OrgCode",
                "intercompanyCode": "53854InterCompanyCode"
            },
            {
                "id": "CASH",
                "cashOnly": true,
                "paymentType": "Pre Pay",
                "currencyId": "USD",
                "localeId": "5129",
                "invoiceReportName": "z1InvoicesLines",
                "organisationCode": "53854OrgCode2",
                "intercompanyCode": "53854InterCompanyCode2"
            }
        ],
        "tax": {
            "number": "53854TaxNumber",
            "countryId": "BEL"
        },
        "addresses": [
            {
                "description": "Address 1",
                "type": "Billing",
                "line1": "Address Line 1",
                "line2": "Address Line 2",
                "line3": "Add Ln 3",
                "city": "Christchurch",
                "region": "Canterbury",
				"postCode": "PostCode",
                "isoCountryCode": "NZL",
                "email": "mason.drew@kaleris.com"
            },
            {
                "description": "Address 2",
                "type": "Alternate",
                "line1": "Address Line 1 (2)",
                "line2": "Address Line 2 (2)",
                "line3": "Add Ln 3 (2)",
                "city": "Christchurch",
                "region": "Canterbury",
				"postCode": "PostCode (2)",
                "isoCountryCode": "NZL",
                "email": "mason.drew2@kaleris.com"
            },
            {
                "description": "Address 3",
                "type": "Default",
                "line1": "Address Line 1 (3)",
                "line2": "Address Line 2 (3)",
                "line3": "Add Ln 3 (3)",
                "city": "Christchurch",
                "region": "Canterbury",
				"postCode": "PostCode (3)",
                "isoCountryCode": "NZL",
                "email": "mason.drew3@kaleris.com"
            }
        ],
        "relatedEntities": {
            "carriers": [
                {
                    "id": "'&amp;DebtorId&amp;'C1",
                    "description": "'&amp;DebtorName&amp;' Carrier Description",
                    "rail": true,
                    "road": true
                },
                {
                    "id": "'&amp;DebtorId&amp;'C2",
                    "description": "'&amp;DebtorName&amp;' Carrier Description 2",
                    "subCarrier": true
                }
            ],
            "consignors": [
                {
                    "id": "53854",
                    "description": "'&amp;DebtorName&amp;' Consignee Description",
                    "consignee": true,
                    "consignor": true
                },
                {
                    "id": "53855",
                    "description": "'&amp;DebtorName&amp;' Consign Description 2",
                    "consignor": true
                }
            ],
            "customsAgents": [
                {
                    "id": "'&amp;DebtorId&amp;'CA",
                    "description": "'&amp;DebtorName&amp;' Customs Agent Description"
                },
                {
                    "id": "'&amp;DebtorId&amp;'C2",
                    "description": "'&amp;DebtorName&amp;' Customs Agent Description (2)"
                }
            ],
            "operators": [
                {
                    "id": "UT53",
                    "description": "'&amp;DebtorName&amp;' Operator Description"
                },
                {
                    "id": "UT54",
                    "description": "'&amp;DebtorName&amp;' Operator Description (2)"
                }
            ],
            "shippingLines": [
                {
                    "id": "UT53",
                    "description": "'&amp;DebtorName&amp;' Shipping Line Description"
                },
                {
                    "id": "UT54",
                    "description": "'&amp;DebtorName&amp;' Shipping Line Description (2)"
                }
            ],
            "stevedores": [
                {
                    "id": "'&amp;DebtorId&amp;'S1",
                    "description": "'&amp;DebtorName&amp;' Stevedore Description"
                },
                {
                    "id": "'&amp;DebtorId&amp;'S2",
                    "description": "'&amp;DebtorName&amp;' Stevedore Description (2)"
                }
            ]
        }
    }
]';

IncomingJsonStringUpdate = '[
    {
        "id": "'&amp;DebtorId&amp;'",
        "name": "'&amp;DebtorName&amp;' Update",
        "description": "An Updated Debtor Description/Long Name",
        "accountCode": "53854AccCode2",
        "additionalInfo1": "Some Additional Information 3",
        "additionalInfo2": "Some Additional Information 4",
        "termsOfTradeId": "008",
        "terminalSpecificConfiguration": [
            {
                "id": "CASH",
                "cashOnly": true,
                "paymentType": "Post Pay",
                "currencyId": "EUR",
                "localeId": "5129",
                "invoiceReportName": "z1Invoices",
                "organisationCode": "53854OrgCode3",
                "intercompanyCode": "53854InterCompanyCode3"
            }
        ],
        "tax": {
            "number": "53854TaxNumber2",
            "countryId": "AUS"
        },
        "addresses": [
            {
                "description": "Address 4",
                "type": "Alternate",
                "line1": "Address Line 1 (4)",
                "line2": "Address Line 2 (4)",
                "line3": "Add Ln 3 (4)",
                "city": "Christchurch",
                "region": "Canterbury",
				"postCode": "PostCode (4)",
                "isoCountryCode": "NZL",
                "email": "mason.drew4@kaleris.com"
            }
        ],
        "relatedEntities": {
		    "updateExistingEntities": true,
            "carriers": [
                {
                    "id": "'&amp;DebtorId&amp;'C2",
                    "description": "'&amp;DebtorName&amp;' Carrier Description 3",
                    "rail": true,
					"road": true,
					"subCarrier": true
                }
            ],
            "consignors": [
                {
                    "id": "53855",
                    "description": "'&amp;DebtorName&amp;' Consign Description 3",
                    "consignee": true
                }
            ],
            "customsAgents": [
                {
                    "id": "'&amp;DebtorId&amp;'C2",
                    "description": "'&amp;DebtorName&amp;' Customs Agent Description (3)"
                }
            ],
            "operators": [
                {
                    "id": "UT54",
                    "description": "'&amp;DebtorName&amp;' Operator Description (3)"
                }
            ],
            "shippingLines": [
                {
                    "id": "UT54",
                    "description": "'&amp;DebtorName&amp;' Shipping Line Description (3)"
                }
            ],
            "stevedores": [
                {
                    "id": "'&amp;DebtorId&amp;'S2",
                    "description": "'&amp;DebtorName&amp;' Stevedore Description (3)"
                }
            ]
        }
    }
]';

NoRelatedEntitiesOrAddresses = '[
    {
        "id": "'&amp;DebtorId&amp;'",
        "name": "'&amp;DebtorName&amp;'",
        "description": "A Debtor Description/Long Name",
        "accountCode": "53854AccCode",
        "additionalInfo1": "Some Additional Information 1",
        "additionalInfo2": "Some Additional Information 2",
        "badCredit": false,
        "suspended": false,
        "termsOfTradeId": "008",
        "terminalSpecificConfiguration": [
            {
                "id": "MPD",
                "cashOnly": false,
                "paymentType": "Auto Collection",
                "currencyId": "EUR",
                "localeId": "5129",
                "invoiceReportName": "z1Invoices",
                "organisationCode": "53854OrgCode",
                "intercompanyCode": "53854InterCompanyCode"
            },
            {
                "id": "CASH",
                "cashOnly": true,
                "paymentType": "Pre Pay",
                "currencyId": "USD",
                "localeId": "5129",
                "invoiceReportName": "z1InvoicesLines",
                "organisationCode": "53854OrgCode2",
                "intercompanyCode": "53854InterCompanyCode2"
            }
        ],
        "tax": {
            "number": "53854TaxNumber",
            "countryId": "BEL"
        }
    }
]';

vars
	incomingJsonString,
	terminalCode,
	loginJson		: String;
	expectFailure	: Boolean;
	
	root			: CM_Root;
	debtor			: CM_Debtor;
	carrier			: CM_Carrier;
	consignee		: CM_ConsigneeConsignor;
	operator		: CM_Operator;
	shippingLine	: CM_ShippingLine;
	stevedore		: CM_Stevedore;
	
	bank			: CM_Bank;
	address			: CM_Address;
	customsAgent	: CM_CustomsAgent;
	debtorTerm		: CM_DebtorTerminal;

begin
	root := self.getRoot();
	bank := root.myRootCompany;
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	// Clean up
	debtor := bank.allDebtorsByCode[DebtorId];	// We change the name, so look up by Id/Code instead, so the 'Update' debtor gets deleted too
	if debtor &lt;&gt; null then
		self.opts.purge();
		self.opts.addAssoc("RelatedEntities", true);
		self.deleteDebtor(debtor.name);
		debtor := bank.allDebtorsByCode[DebtorId];
		self.assertDeleted(self.getOidStringForObject(debtor));
	endif;
	
	
	loginJson := '{
	"userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
	"password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
	"applicationId" : "UnitTest",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	// Incoming Json string. Everything OK.
	incomingJsonString := IncomingJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomer.name, loginJson, incomingJsonString, expectFailure);
	
	// 200 Success, so lets check whats on the Debtor
	debtor := bank.debtors[DebtorName];
	self.assertNotNullMsg(debtor, "Debtor " &amp; DebtorName &amp; " not found");
	
	self.assertEqualMsg(debtor.code, DebtorId, "Debtor Code does not match");
	self.assertEqualMsg(debtor.decfinName, "53854AccCode", "Debtor Account Code (decfinName) does not match");
	self.assertEqualMsg(debtor.longName, "A Debtor Description/Long Name", "Debtor Long Name does not match");
	self.assertEqualMsg(debtor.additionalInformation1, "Some Additional Information 1", "Additional Information 1 does not match");
	self.assertEqualMsg(debtor.additionalInformation2, "Some Additional Information 2", "Additional Information 2 does not match");
	
	self.assertTrueMsg(debtor.hasBadCredit, "Bad Credit not true");
	self.assertTrueMsg(debtor.isSuspended, "Suspended not true");
	
	self.assertNotNullMsg(debtor.myTermsOfTrade, "Terms of Trade not set");
	self.assertEqualMsg(debtor.getTermsOfTrade(true), "008", "8 Days Terms of Trade not set");
	
	self.assertEqualMsg(debtor.taxNumber, "53854TaxNumber", "Tax Number does not match");
	self.assertNotNullMsg(debtor.myTaxCountry, "Tax Country not set");
	self.assertEqualMsg(debtor.myTaxCountry.isoCode3, "BEL", "Tax Country not set to Belgium (BEL)");
	
	// Addresses - Billing
	self.assertEqualMsg(debtor.getBillingAddressString, "Address Line 1" &amp; CrLf &amp; "Address Line 2" &amp; CrLf &amp; "Add Ln 3" &amp; CrLf &amp; "Christchurch" &amp; CrLf &amp; "Canterbury" &amp; CrLf &amp; "PostCode" &amp; CrLf &amp; "NEW ZEALAND" &amp; CrLf &amp; "mason.drew@kaleris.com", "Billing Address does not match");
	// Addresses - Default
	address := debtor.allAddressesByCode["1"];
	self.assertNotNullMsg(address, "Default Address not found");
	self.assertTrueMsg(address.isDefault, "Default Flag not set");
	self.assertEqualMsg(address.description, "Address 3", "(Default) Address Description does not match");
	self.assertEqualMsg(address.addr1, "Address Line 1 (3)", "(Default) Address Line 1 does not match");
	self.assertEqualMsg(address.addr2, "Address Line 2 (3)", "(Default) Address Line 2 does not match");
	self.assertEqualMsg(address.addr3, "Add Ln 3 (3)", "(Default) Address Line 3 does not match");
	self.assertEqualMsg(address.region, "Canterbury", "(Default) Region does not match");
	self.assertEqualMsg(address.postCode, "PostCode (3)", "(Default) Post Code does not match");
	self.assertEqualMsg(address.city, "Christchurch", "(Default) City does not match");
	self.assertEqualMsg(address.email, "mason.drew3@kaleris.com", "(Default) Email does not match");
	self.assertNotNullMsg(address.getCountry(), "(Default) Country not set");
	self.assertEqualMsg(address.countryCode, "NZ", "(Default) Country does not match");
	// Addresses - Alternate
	address := debtor.allAddressesByCode["2"];
	self.assertNotNullMsg(address, "Alternate Address not found");
	self.assertTrueMsg(address.isAlternative, "Alternate Flag not set");
	self.assertEqualMsg(address.description, "Address 2", "(Alternate) Address Description does not match");
	self.assertEqualMsg(address.addr1, "Address Line 1 (2)", "(Alternate) Address Line 1 does not match");
	self.assertEqualMsg(address.addr2, "Address Line 2 (2)", "(Alternate) Address Line 2 does not match");
	self.assertEqualMsg(address.addr3, "Add Ln 3 (2)", "(Alternate) Address Line 3 does not match");
	self.assertEqualMsg(address.region, "Canterbury", "(Alternate) Region does not match");
	self.assertEqualMsg(address.postCode, "PostCode (2)", "(Alternate) Post Code does not match");
	self.assertEqualMsg(address.city, "Christchurch", "(Alternate) City does not match");
	self.assertEqualMsg(address.email, "mason.drew2@kaleris.com", "(Alternate) Email does not match");
	self.assertNotNullMsg(address.getCountry(), "(Alternate) Country not set");
	self.assertEqualMsg(address.countryCode, "NZ", "(Alternate) Country does not match");
	
	// Terminal Specific Configuration
	//self.assertEqualMsg(debtor.allDebtorTerminals.size, 2, "Debtor Terminals");	// For some reason we create a CM_DebtorTerminal for all Terminals in the system, not just ones we've customised
	debtorTerm := debtor.allDebtorTerminals[root.allTerminals["MPD"]];
	self.assertNotNullMsg(debtorTerm, "Debtor Terminal MPD");
	self.assertFalseMsg(debtorTerm.isCashOnly, "Debtor Terminal marked as Cash when it shouldn't be");
	self.assertEqualMsg(debtorTerm.paymentType, PaymentType_AutoCollection, "Debtor Terminal Payment Type not set to " &amp; app.getErrorString(PaymentType_AutoCollectionStr));
	self.assertNotNullMsg(debtorTerm.myCurrencyType, "Debtor Terminal Currency Type");
	self.assertEqualMsg(debtorTerm.myCurrencyType, root.allCurrencyTypes["EUR"], "Debtor Terminal Currency Type not set to EUR");
	self.assertNotNullMsg(debtorTerm.myLocale, "Debtor Terminal Locale");
	self.assertEqualMsg(debtorTerm.myLocale, root.allLocales["5129"], "Debtor Terminal Locale not set to 5129 English NZ");
	self.assertEqualMsg(debtorTerm.defaultInvoiceJRW, "z1Invoices", "Debtor Terminal Invoice Report not set to z1Invoices");
	self.assertEqualMsg(debtorTerm.orgCode, "53854OrgCode", "Debtor Terminal Organisation Code not set to 53854OrgCode");
	self.assertEqualMsg(debtorTerm.interTerminalCode, "53854InterCompanyCode", "Debtor Terminal Intercopany Code not set to 53854InterCompanyCode"); 
	debtorTerm := debtor.allDebtorTerminals[root.allTerminals["CASH"]];
	self.assertNotNullMsg(debtorTerm, "Debtor Terminal CASH");
	self.assertTrueMsg(debtorTerm.isCashOnly, "Debtor Terminal not marked as Cash");
	self.assertEqualMsg(debtorTerm.paymentType, PaymentType_PrePay, "Debtor Terminal Payment Type not set to " &amp; app.getErrorString(PaymentType_PrePayStr));
	self.assertNotNullMsg(debtorTerm.myCurrencyType, "Debtor Terminal Currency Type");
	self.assertEqualMsg(debtorTerm.myCurrencyType, root.allCurrencyTypes["USD"], "Debtor Terminal Currency Type not set to USD");
	self.assertNotNullMsg(debtorTerm.myLocale, "Debtor Terminal Locale");
	self.assertEqualMsg(debtorTerm.myLocale, root.allLocales["5129"], "Debtor Terminal Locale not set to 5129 English NZ");
	self.assertEqualMsg(debtorTerm.defaultInvoiceJRW, "z1InvoicesLines", "Debtor Terminal Invoice Report not set to z1InvoicesLines");
	self.assertEqualMsg(debtorTerm.orgCode, "53854OrgCode2", "Debtor Terminal Organisation Code not set to 53854OrgCode2");
	self.assertEqualMsg(debtorTerm.interTerminalCode, "53854InterCompanyCode2", "Debtor Terminal Intercopany Code not set to 53854InterCompanyCode2");
	
	
	// Related Entities
	
	// Carriers
	self.assertEqualMsg(debtor.allCarriers.size, 2, "Carriers");
	carrier := debtor.allCarriers["UT_53854C1"];
	self.assertNotNullMsg(carrier, "Carrier UT_53854C1");
	self.assertEqualMsg(carrier.description, DebtorName&amp;" Carrier Description", "Carrier Description");
	self.assertTrueMsg(carrier.isRail, "Carrier not marked as For Rail");
	self.assertTrueMsg(carrier.isRoad, "Carrier not marked as For Road");
	carrier := debtor.allCarriers["UT_53854C2"];
	self.assertNotNullMsg(carrier, "Carrier UT_53854C2");
	self.assertEqualMsg(carrier.description, DebtorName&amp;" Carrier Description 2", "Carrier Description");
	self.assertTrueMsg(carrier.isSubCarrier, "Carrier not marked as For SubCarrier");
	
	// Consignee/ors
	self.assertEqualMsg(debtor.consignors.size, 2, "Consignee/ors");
	consignee := debtor.consignors["53854"];
	self.assertNotNullMsg(consignee, "Consignee 53854");
	self.assertEqualMsg(consignee.description, DebtorName&amp;" Consignee Description", "Consignee Description");
	self.assertTrueMsg(consignee.isConsignee, "Consignee not marked as Consignee");
	self.assertTrueMsg(consignee.isConsignor, "Consignee not marked as Consignor");
	consignee := debtor.consignors["53855"];
	self.assertNotNullMsg(consignee, "Consignee 53855");
	self.assertEqualMsg(consignee.description, DebtorName&amp;" Consign Description 2", "Consignee Description");
	self.assertTrueMsg(consignee.isConsignor, "Consignee not marked as Consignor");
	
	// Custom Agents
	self.assertEqualMsg(debtor.allCustomsAgents.size, 2, "Custom Agents");
	customsAgent := debtor.allCustomsAgents["UT_53854CA"];
	self.assertNotNullMsg(customsAgent, "Customs Agent UT_53854CA");
	self.assertEqualMsg(customsAgent.name, DebtorName&amp;" Customs Agent Description", "Customs Agent Name");
	customsAgent := debtor.allCustomsAgents["UT_53854C2"];
	self.assertNotNullMsg(customsAgent, "Customs Agent UT_53854C2");
	self.assertEqualMsg(customsAgent.name, DebtorName&amp;" Customs Agent Description (2)", "Customs Agent Name");
	
	// Operators
	self.assertEqualMsg(debtor.operators.size, 2, "Operators");
	operator := debtor.operators["UT53"];
	self.assertNotNullMsg(operator, "Operator UT53");
	self.assertEqualMsg(operator.description, DebtorName&amp;" Operator Description", "Operator Description");
	operator := debtor.operators["UT54"];
	self.assertNotNullMsg(operator, "Operator UT54");
	self.assertEqualMsg(operator.description, DebtorName&amp;" Operator Description (2)", "Operator Description");
	
	// Shipping Lines
	self.assertEqualMsg(debtor.allShippingLines.size, 2, "Shipping Lines");
	shippingLine := debtor.allShippingLines["UT53"];
	self.assertNotNullMsg(shippingLine, "Shipping Line UT53");
	self.assertEqualMsg(shippingLine.description, DebtorName&amp;" Shipping Line Description", "Shipping Line Description");
	shippingLine := debtor.allShippingLines["UT54"];
	self.assertNotNullMsg(shippingLine, "Shipping Line UT54");
	self.assertEqualMsg(shippingLine.description, DebtorName&amp;" Shipping Line Description (2)", "Shipping Line Description");
	
	// Stevedores
	self.assertEqualMsg(debtor.allStevedores.size, 2, "Stevedores");
	stevedore := debtor.allStevedores["UT_53854S1"];
	self.assertNotNullMsg(stevedore, "Stevedore UT_53854S1");
	self.assertEqualMsg(stevedore.description, DebtorName&amp;" Stevedore Description", "Stevedore Description");
	stevedore := debtor.allStevedores["UT_53854S2"];
	self.assertNotNullMsg(stevedore, "Stevedore UT_53854S2");
	self.assertEqualMsg(stevedore.description, DebtorName&amp;" Stevedore Description (2)", "Stevedore Description");
	
	incomingJsonString := IncomingJsonStringUpdate;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomer.name, loginJson, incomingJsonString, expectFailure);
	
	// 200 Success, so lets check whats on the Debtor
	debtor := bank.debtors[DebtorName &amp; ' Update'];
	self.assertNotNullMsg(debtor, "Debtor " &amp; DebtorName &amp; " Update not found");
	
	self.assertEqualMsg(debtor.code, DebtorId, "Debtor Code does not match");
	self.assertEqualMsg(debtor.decfinName, "53854AccCode2", "Debtor Account Code (decfinName) does not match");
	self.assertEqualMsg(debtor.longName, "An Updated Debtor Description/Long Name", "Debtor Long Name does not match");
	self.assertEqualMsg(debtor.additionalInformation1, "Some Additional Information 3", "Additional Information 1 does not match");
	self.assertEqualMsg(debtor.additionalInformation2, "Some Additional Information 4", "Additional Information 2 does not match");
	
	self.assertFalseMsg(debtor.hasBadCredit, "Bad Credit not false");
	self.assertFalseMsg(debtor.isSuspended, "Suspended not false");
	
	self.assertNotNullMsg(debtor.myTermsOfTrade, "Terms of Trade not set");
	self.assertEqualMsg(debtor.getTermsOfTrade(true), "008", "8 Days Terms of Trade not set");
	
	self.assertEqualMsg(debtor.taxNumber, "53854TaxNumber2", "Tax Number does not match");
	self.assertNotNullMsg(debtor.myTaxCountry, "Tax Country not set");
	self.assertEqualMsg(debtor.myTaxCountry.isoCode3, "AUS", "Tax Country not set to Australia (AUS)");
	
	// Addresses - Billing
	self.assertEqualMsg(debtor.getBillingAddressString, null, "Billing Address does not match");
	// Addresses - Default
	address := debtor.getDefaultDebtorAddress();
	self.assertNotNullMsg(address, "Default Address not found");
	self.assertEqualMsg(address, debtor.allAddressesByCode["1"], "Default Address is not the first address");	
	// Addresses - Alternate
	address := debtor.allAddressesByCode["1"];
	self.assertNotNullMsg(address, "Alternate Address not found");
	self.assertTrueMsg(address.isDefault, "Default Flag not set");
	self.assertTrueMsg(address.isAlternative, "Alternate Flag not set");
	self.assertEqualMsg(address.description, "Address 4", "Address Description does not match");
	self.assertEqualMsg(address.addr1, "Address Line 1 (4)", "Address Line 1 does not match");
	self.assertEqualMsg(address.addr2, "Address Line 2 (4)", "Address Line 2 does not match");
	self.assertEqualMsg(address.addr3, "Add Ln 3 (4)", "Address Line 3 does not match");
	self.assertEqualMsg(address.region, "Canterbury", "Region does not match");
	self.assertEqualMsg(address.postCode, "PostCode (4)", "Post Code does not match");
	self.assertEqualMsg(address.city, "Christchurch", "City does not match");
	self.assertEqualMsg(address.email, "mason.drew4@kaleris.com", "Email does not match");
	self.assertNotNullMsg(address.getCountry(), "Country not set");
	self.assertEqualMsg(address.countryCode, "NZ", "Country does not match");
	
	// Terminal Specific Configuration
	//self.assertEqualMsg(debtor.allDebtorTerminals.size, 2, "Debtor Terminals");	// For some reason we create a CM_DebtorTerminal for all Terminals in the system, not just ones we've customised
	debtorTerm := debtor.allDebtorTerminals[root.allTerminals["MPD"]];
	// Confirm everything is null/blank
	self.assertNotNullMsg(debtorTerm, "Debtor Terminal MPD");
	self.assertFalseMsg(debtorTerm.isCashOnly, "Debtor Terminal marked as Cash when it shouldn't be");
	self.assertEqualMsg(debtorTerm.paymentType, 0, "Debtor Terminal Payment Type set when it shouldn't be");
	self.assertNullMsg(debtorTerm.myCurrencyType, "Debtor Terminal Currency Type set when it shouldn't be");
	self.assertNullMsg(debtorTerm.myLocale, "Debtor Terminal Locale set when it shouldn't be");
	self.assertEqualMsg(debtorTerm.defaultInvoiceJRW, null, "Debtor Terminal Invoice Report set when it shouldn't be");
	self.assertEqualMsg(debtorTerm.orgCode, null, "Debtor Terminal Organisation Code set when it shouldn't be");
	self.assertEqualMsg(debtorTerm.interTerminalCode, null, "Debtor Terminal Intercopany Code set when it shouldn't be");
	debtorTerm := debtor.allDebtorTerminals[root.allTerminals["CASH"]];
	self.assertNotNullMsg(debtorTerm, "Debtor Terminal CASH");
	self.assertTrueMsg(debtorTerm.isCashOnly, "Debtor Terminal not marked as Cash");
	self.assertEqualMsg(debtorTerm.paymentType, PaymentType_PostPay, "Debtor Terminal Payment Type not set to " &amp; app.getErrorString(PaymentType_PostPayStr));
	self.assertNotNullMsg(debtorTerm.myCurrencyType, "Debtor Terminal Currency Type");
	self.assertEqualMsg(debtorTerm.myCurrencyType, root.allCurrencyTypes["EUR"], "Debtor Terminal Currency Type not set to EUR");
	self.assertNotNullMsg(debtorTerm.myLocale, "Debtor Terminal Locale");
	self.assertEqualMsg(debtorTerm.myLocale, root.allLocales["5129"], "Debtor Terminal Locale not set to 5129 English NZ");
	self.assertEqualMsg(debtorTerm.defaultInvoiceJRW, "z1Invoices", "Debtor Terminal Invoice Report not set to z1Invoices");
	self.assertEqualMsg(debtorTerm.orgCode, "53854OrgCode3", "Debtor Terminal Organisation Code not set to 53854OrgCode3");
	self.assertEqualMsg(debtorTerm.interTerminalCode, "53854InterCompanyCode3", "Debtor Terminal Intercopany Code not set to 53854InterCompanyCode3");
	
	
	// Related Entities
	
	// Carriers
	self.assertEqualMsg(debtor.allCarriers.size, 1, "Carriers");
	carrier := debtor.allCarriers["UT_53854C2"];
	self.assertNotNullMsg(carrier, "Carrier UT_53854C2");
	self.assertEqualMsg(carrier.description, DebtorName&amp;" Carrier Description 3", "Carrier Description");
	self.assertTrueMsg(carrier.isRail, "Carrier not marked as For Rail");
	self.assertTrueMsg(carrier.isRoad, "Carrier not marked as For Road");
	self.assertTrueMsg(carrier.isSubCarrier, "Carrier not marked as For SubCarrier");
	
	// Consignee/ors
	self.assertEqualMsg(debtor.consignors.size, 1, "Consignee/ors");
	consignee := debtor.consignors["53855"];
	self.assertNotNullMsg(consignee, "Consignee 53855");
	self.assertEqualMsg(consignee.description, DebtorName&amp;" Consign Description 3", "Consignee Description");
	self.assertFalseMsg(consignee.isConsignor, "Consignee marked as Consignor when it shouldn't be");
	self.assertTrueMsg(consignee.isConsignee, "Consignee not marked as Consignee");
	
	// Custom Agents
	self.assertEqualMsg(debtor.allCustomsAgents.size, 1, "Custom Agents");
	customsAgent := debtor.allCustomsAgents["UT_53854C2"];
	self.assertNotNullMsg(customsAgent, "Customs Agent UT_53854C2");
	self.assertEqualMsg(customsAgent.name, DebtorName&amp;" Customs Agent Description (3)", "Customs Agent Name");
	
	// Operators
	self.assertEqualMsg(debtor.operators.size, 1, "Operators");
	operator := debtor.operators["UT54"];
	self.assertNotNullMsg(operator, "Operator UT54");
	self.assertEqualMsg(operator.description, DebtorName&amp;" Operator Description (3)", "Operator Description");
	
	// Shipping Lines
	self.assertEqualMsg(debtor.allShippingLines.size, 1, "Shipping Lines");
	shippingLine := debtor.allShippingLines["UT54"];
	self.assertNotNullMsg(shippingLine, "Shipping Line UT54");
	self.assertEqualMsg(shippingLine.description, DebtorName&amp;" Shipping Line Description (3)", "Shipping Line Description");
	
	// Stevedores
	self.assertEqualMsg(debtor.allStevedores.size, 1, "Stevedores");
	stevedore := debtor.allStevedores["UT_53854S2"];
	self.assertNotNullMsg(stevedore, "Stevedore UT_53854S2");
	self.assertEqualMsg(stevedore.description, DebtorName&amp;" Stevedore Description (3)", "Stevedore Description");
	
	// No name suppiled
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :" &amp; ERR_INVALID_VALUE.String &amp; ". " &amp; app.getErrorString1(ERR_INVALID_VALUE, "Name") &amp; "Name must be entered.");
	incomingJsonString := IncomingJsonString.replace__('        "name": "'&amp;DebtorName&amp;'",', "", false);
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomer.name, loginJson, incomingJsonString, expectFailure);
	
	// No id suppiled
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :" &amp; ERR_INVALID_VALUE.String &amp; ". " &amp; app.getErrorString1(ERR_INVALID_VALUE, "Id") &amp; "Id must be entered.");
	incomingJsonString := IncomingJsonString.replace__('        "id": "'&amp;DebtorId&amp;'",', "", false);
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomer.name, loginJson, incomingJsonString, expectFailure);

	// No Address Information and No Related Entity Information
	
	// Clean up
	debtor := bank.allDebtorsByCode[DebtorId];	// We change the name, so look up by Id/Code instead, so the 'Update' debtor gets deleted too	
	self.opts.purge();
	self.opts.addAssoc("RelatedEntities", true);
	self.deleteDebtor(debtor.name);
	debtor := bank.allDebtorsByCode[DebtorId];
	self.assertDeleted(self.getOidStringForObject(debtor));
	
	self.opts.purge();
	incomingJsonString := NoRelatedEntitiesOrAddresses;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomer.name, loginJson, incomingJsonString, expectFailure);
	
	debtor := bank.allDebtorsByCode[DebtorId];
	self.assertEqualMsg(debtor.code, DebtorId, "Debtor Code does not match");
	self.assertEqualMsg(debtor.decfinName, "53854AccCode", "Debtor Account Code (decfinName) does not match");
	self.assertEqualMsg(debtor.longName, "A Debtor Description/Long Name", "Debtor Long Name does not match");
	self.assertEqualMsg(debtor.additionalInformation1, "Some Additional Information 1", "Additional Information 1 does not match");
	self.assertEqualMsg(debtor.additionalInformation2, "Some Additional Information 2", "Additional Information 2 does not match");
	
	self.assertFalseMsg(debtor.hasBadCredit, "Bad Credit not false");
	self.assertFalseMsg(debtor.isSuspended, "Suspended not false");
	
	self.assertNotNullMsg(debtor.myTermsOfTrade, "Terms of Trade not set");
	self.assertEqualMsg(debtor.getTermsOfTrade(true), "008", "8 Days Terms of Trade not set");
	
	self.assertEqualMsg(debtor.taxNumber, "53854TaxNumber", "Tax Number does not match");
	self.assertNotNullMsg(debtor.myTaxCountry, "Tax Country not set");
	self.assertEqualMsg(debtor.myTaxCountry.isoCode3, "BEL", "Tax Country not set to Belgium (BEL)");
	
	// Addresses - Billing
	self.assertNullMsg(debtor.getBillingAddressString, "Billing Address not null");
	
	// Related Entities
	self.assertEqualMsg(debtor.allCarriers.size, 0, "Carriers");
	self.assertEqualMsg(debtor.consignors.size, 0, "Consignee/ors");
	self.assertEqualMsg(debtor.allCustomsAgents.size, 0, "Custom Agents");
	self.assertEqualMsg(debtor.operators.size, 0, "Operators");
	self.assertEqualMsg(debtor.allShippingLines.size, 0, "Shipping Lines");
	self.assertEqualMsg(debtor.allStevedores.size, 0, "Stevedores");
	
epilog

end;</source>
