    <JadeMethod name="getJadeVersionInfo" id="d95dc0a0-82c8-4b3d-9c01-25f6d7b22674">
        <source>getJadeVersionInfo(_usePresentationClient : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     06 August 2004 by cnwrs2
//
// Purpose:     Returns the results of running jverinfo.exe
// ---------------------------------------------------------------------------
vars
	dir,
	runFile,
	outFile,
	rtnStr	: String;
	args	: StringArray;
	f		: File;
	result	: Integer;
	
begin

	if process.isUsingThinClient and 
	  (not _usePresentationClient) then
		dir := app.getJadeInstallDirAppServer();
	else
		dir := app.getJadeInstallDir();
	endif;
	
	runFile := dir &amp; '\jverinfo.exe';
	outFile := dir &amp; '\jverinfo_out.txt';
	
	create f transient;
	f.usePresentationFileSystem := _usePresentationClient;
	f.fileName := runFile;
	
	if (not f.isAvailable) then
		rtnStr := 'ERROR: ' &amp; f.fileName &amp; ' not found';
		return rtnStr;
	endif;
	
	f.fileName := outFile;
	
	if f.isAvailable then
		f.purge;
	endif;
	
	create args transient;
	args.add('out="' &amp; outFile &amp; '"');
	
	rtnStr := 'Executing &gt;&gt; ' &amp; runFile &amp; ' ' &amp; args[1];
	
	node.createExternalProcess(dir, runFile, args, runFile, _usePresentationClient, true, result); 
				
	rtnStr := rtnStr &amp; CrLf &amp; 'Result = ' &amp; result.String;
	
	if f.isAvailable then
		f.kind := File.Kind_Binary;
		rtnStr := rtnStr &amp; CrLf &amp; CrLf &amp; f.readBinary(f.fileLength).String;
		f.purge;
	else
		rtnStr := rtnStr &amp; CrLf &amp; 'ERROR: output file ' &amp; f.fileName &amp; ' not found';
	endif;

	return rtnStr;

epilog
	if f &lt;&gt; null then
		f.close;
		delete f;
	endif;
	delete args;

end;</source>
        <Parameter name="_usePresentationClient" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMachLiftTypeDescFromCode" id="5ed9dac2-4dca-4a50-b219-8ba6ee1f5802">
