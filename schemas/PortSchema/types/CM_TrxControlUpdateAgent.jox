							_passportObj:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		07 April 2009 by cnwdad1
//
// Purpose:		Transaction to set the Sub-Terminal Options for the specified Terminal.
//
//	NOTE: The first time that Sub-Terminals are turned on, the system needs to take
//	the default Sub-Terminals and update all on-site TI's, all Pre-Notes and all
//	active Voyages.  Suffice to say, it will be a long transaction and should only
//	be done when no other activity is going on in JMT.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/01/2010	cnwdad1		PAR 22205 (CCMS POL 1904).  Added extra Bulk Release
//							Sub-Terminal parameters.
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport(_passportObj, method);

	// Arm our base exception handlers.
	on Exception do agtPassportExHandler(exception, _passportObj);
	on LockException do agtPassportLockExHandler(exception, _passportObj);

	beginTransaction;

	app.myUtilityUA.utlUpdateSubTerminalOptions(_terminalObj,
												_isTurnedOn,
												_isAreaDefined,	//26 Nov 2014	NDL	Par 35295
												_stForExportFullObj,
												_stForExportMTYObj,
												_stForImportFullObj,
												_stForImportMTYObj,
												_stForStorageFullObj,
												_stForStorageMTYObj,
												_stForImportGenObj,
												_stForExportGenObj,
												_stForStorageGenObj,
												_stForCargoOtherObj,
												_stForSourceBulkRdObj,	// cnwdad1 PAR 22205.
												_stForSourceBulkRlObj,	// cnwdad1 PAR 22205.
												_stForSourceBulkShObj,	// cnwdad1 PAR 22205.
												_stForSourceBulkPkObj,	// cnwdad1 PAR 22205.
												_stForTargetBulkObj,
												_stForBOLInwardsObj,
												_passportObj);
epilog	
	self.finaliseActivityWithPassport(_passportObj);
end;</source>
