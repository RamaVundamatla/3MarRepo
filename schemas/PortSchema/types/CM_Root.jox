        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getConfig" id="6b401a3c-75ee-4e1f-b160-92f36a8b5948">
        <source>getConfig( pCode : String ) : Any;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	// Note: If you are getting AutoFileDirectory then use getConfig_AutoFileDirectory method instead
	return self.getStateData(ConfigGrp_System, pCode);
	
end;
</source>
