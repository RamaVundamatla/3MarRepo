<CollClass name="CMUI_FieldFrameArray" id="7b9cd7cd-a32d-487e-88cd-5aaeaf9e20e0">
    <loadFactor>66</loadFactor>
    <memberType name="CMUI_FieldFrame"/>
    <superclass name="ObjectArray"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="cmui"/>
    <JadeMethod name="alignFields" id="d6af0dd6-eaec-4a46-a467-f70379c4f6bf">
        <source>alignFields(_posLeft:Real; _posTop:Real; _posWidth:Real; _isViewOnly:Boolean) : Real;
// --------------------------------------------------------------------------------
// Created:		15 February 2006 by cnwdad1
//
// Purpose:		Aligns all of the receiver's Field Frames, with the first beginning
//				at the specified left and top positions on the form.
//
// Parameters:	_posLeft - The left coordinate of the first field.
//				_posTop - The top coordinate of the first field.
//				_posWidth - The width of the field frame.
//				_isViewOnly - If true, the field will be shown, but disabled.
//
// Returns:		The last or next top position, which ever has the greatest value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fieldObj	: CMUI_FieldFrame;
	isFirst		: Boolean;
	lastTop		: Real;
	nextTop		: Real;
	lastHeight	: Real;
	
begin
	if self.isEmpty() then
		return 0;
	endif;
	
	isFirst		:=	true;
	
	foreach fieldObj in self do
		if isFirst then
			fieldObj.move(_posLeft, _posTop, _posWidth, fieldObj.height);
			lastTop		:=	_posTop;
			lastHeight	:=	fieldObj.height;
			isFirst		:=	false;
		else
			nextTop		:=	lastTop + lastHeight + 3;		// 10
			fieldObj.move(_posLeft, nextTop, _posWidth, fieldObj.height);
			lastTop		:=	nextTop;
			lastHeight	:=	fieldObj.height;
		endif;
		
		fieldObj.setIsEnabled(not _isViewOnly);
		
		fieldObj.visible	:=	true;
	endforeach;
	
	return lastTop.max(nextTop);
end;</source>
        <Parameter name="_posLeft" type="Real"/>
        <Parameter name="_posTop" type="Real"/>
        <Parameter name="_posWidth" type="Real"/>
        <Parameter name="_isViewOnly" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTabOrders" id="49458de7-371c-4da2-a5c3-0f775da77533">
        <source>doTabOrders(_startTab:Integer);
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Orders the field controls sequentially so that the user can tab from
//				the top down thru the fields.
//
// Parameters:	_startTab - The starting tab index.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fieldObj	: CMUI_FieldFrame;
	tabOrder	: Integer;
	
begin
	if self.isEmpty() then
		return;
	endif;
	
	tabOrder	:=	_startTab;
	
	foreach fieldObj in self do
		tabOrder	:=	fieldObj.setTabOrder(tabOrder);
		tabOrder	:=	tabOrder + 1;
	endforeach;
end;</source>
        <Parameter name="_startTab" type="Integer"/>
    </JadeMethod>
</CollClass>
