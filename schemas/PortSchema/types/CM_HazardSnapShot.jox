    </JadeMethod>
    <JadeMethod name="setProxy" id="361c0993-d907-4c0b-b6c7-62f70c13b8b4">
        <updating/>
        <source>setProxy(	_code, _desc, _unNumbers: String; 
			_snap : CM_TISnapShot; 
			_limitedQuant : Boolean; 
			_packGroup : String; 
			_flashpoint : Real; 
			_isMarinePollutant : Integer; 
			_acidsBases : String	) updating;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars

begin
	self.code := _code[1:9];
	self.description := _desc[1:40];
	self.undgCodes :=_unNumbers;
	self.myTISnapShot := _snap;
	self.limitedQuantity := _limitedQuant;
	self.packingGroup := _packGroup;							
	self.flashpointTemperature := _flashpoint;			
	self.isMarinePollutant := _isMarinePollutant; //= MarinePollutant_Yes;		
	self.acidsBases := _acidsBases.toUpper;				
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_unNumbers" type="String"/>
        <Parameter name="_snap" type="CM_TISnapShot"/>
        <Parameter name="_limitedQuant" type="Boolean"/>
        <Parameter name="_packGroup" type="String"/>
        <Parameter name="_flashpoint" type="Real"/>
        <Parameter name="_isMarinePollutant" type="Integer"/>
        <Parameter name="_acidsBases" type="String"/>
    </JadeMethod>
</Class>
