    <JadeMethod name="getDisplayStringForAttribute" id="5642f3ac-014e-4ba9-a4a7-26066b0a0e45">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			Gets the display string for the attribute

Parameters:			_attrName	String	The attribute name of the attribute we are trying to display
					_short		Boolean	

Return Value:		String	Representing the display string for the attribute

Date		Who		Reason
01 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	if _attrName = ETRow_Locale then
		if self.myLocale &lt;&gt; null then
			return self.myLocale.localeDescription;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="781653f5-d8dc-4a0d-982d-8ab1eb9a02c5">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			Creates an update proxy

Parameters:			NONE

Return Value:		SelfType	A proxy object of the same type

Date		Who		Reason
02 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	pxy : SelfType;
	
begin
	pxy 					:= inheritMethod();
	pxy.myInvoiceLineType	:= self.myInvoiceLineType;
	pxy.myLocale 			:= self.myLocale;
	return pxy;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a3751a2d-93ff-4270-98da-70ff03a0c3ef">
        <updating/>
        <source>setForCreate(_pxyInvoiceLineNarration : CM_InvoiceLineNarration) updating;
/*

Purpose:			Sets the persistent object to the values from the proxy object

Parameters:			_pxyInvoiceLineNarration	CM_InvoiceLineNarration	The proxy invoice line nararation to set values from

Return Value:		NONE

Date		Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	self.myLocale 			:= _pxyInvoiceLineNarration.myLocale;
	self.narration 			:= _pxyInvoiceLineNarration.narration;
	self.unitNarration 		:= _pxyInvoiceLineNarration.unitNarration;
	self.myInvoiceLineType 	:= _pxyInvoiceLineNarration.myInvoiceLineType;
	
end;</source>
        <Parameter name="_pxyInvoiceLineNarration" type="CM_InvoiceLineNarration"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4d4760c4-8bff-4df4-a084-d831e9748337">
        <updating/>
        <source>setForUpdate(_pxyInvoiceLineNarration : CM_InvoiceLineNarration) updating;
/*

Purpose:			Sets the persistent object to the values from the proxy object

Parameters:			_pxyInvoiceLineNarration	CM_InvoiceLineNarration	The proxy invoice line nararation to set values from

Return Value:		NONE

Date		Who		Reason
01 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	self.setForCreate(_pxyInvoiceLineNarration);
	
end;</source>
        <Parameter name="_pxyInvoiceLineNarration" type="CM_InvoiceLineNarration"/>
    </JadeMethod>
    <JadeMethod name="setMyInvoiceLineType" id="654344e7-02a5-4d23-bf39-251eb66e6371">
        <updating/>
        <source>setMyInvoiceLineType(_invoiceLineType : CM_InvoiceLineDesc) updating;
/*

Purpose:			Sets the invoice line type for the invoice line narration

Parameters:			_invoiceLineType	CM_InvoiceLineDesc	The invoice line type to set on the proxy

Return Value:		NONE

Date		Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	self.myInvoiceLineType := _invoiceLineType;
	
end;</source>
        <Parameter name="_invoiceLineType" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="0a11210d-43f3-440f-94f1-1f284533a7ad">
        <updating/>
        <source>setProxy(_locale : CM_Locale; _narration, _unitNarration : String) updating;
/*

Purpose:			Sets the proxy object with valuies supplied

Parameters:			_locale			CM_Locale	The locale to set on the proxy
					_narration		String		The narration to set on the proxy
					_unitNarration	String		The unit narration to set on the proxy

Return Value:		NONE

Date		Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	self.myLocale 		:= _locale;
	self.narration 		:= _narration;
	self.unitNarration 	:= _unitNarration;
	
end;</source>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="_narration" type="String"/>
        <Parameter name="_unitNarration" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ae26a5bb-1319-48be-bcc7-28c0ff66966f">
        <source>validateForCreate();
/*

Purpose:			Validates the object for create

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
01 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	if self.myLocale = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Info_Locale), null, null);
	endif;
	
	if self.narration = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(CM_Narration), null, null);
	endif;
	
	if self.unitNarration = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Unit_narration), null, null);
	endif;
	
	if self.myInvoiceLineType = null then
		app.raiseCMException1(Must_be_related, app.getErrorString(Invoice_line_type), null, null);
	endif;
	
end;</source>
    </JadeMethod>
