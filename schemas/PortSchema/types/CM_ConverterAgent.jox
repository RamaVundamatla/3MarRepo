<Class name="CM_ConverterAgent" id="f7db8050-6472-4d85-950c-d0db85100c14">
    <superclass name="CM_MeasurementConverter"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <ExplicitInverseRef name="allConverterObjects" id="b92c310f-8bc8-4d19-b0b4-d1e0436abe02">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <type name="CM_ConverterByConstValueDict"/>
        <access>readonly</access>
        <Inverse name="CM_ConverterObject::myConverterAgent"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myRoot" id="7996b9df-dec4-4075-bbd0-b79250502d65">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::myConverterAgent"/>
    </ExplicitInverseRef>
    <JadeMethod name="buildConverterObject" id="362cf3bd-dfbc-4dc2-aff6-7f39daa99a32">
        <source>buildConverterObject(_const : Constant) : Boolean;
// ---------------------------------------------------------------------------
// Created:     23 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	pxyConverter,
	realConverter			: CM_ConverterObject;
begin

	create pxyConverter transient;
	pxyConverter.setProxy(_const, self);
	app.myTrxCA.trxCreateConverterObject(pxyConverter, realConverter, app.myPassport);
		
epilog
	delete pxyConverter;
	return app.myPassport.trxCompletedOK;

end;</source>
        <Parameter name="_const" type="Constant"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildConverterObjects" id="d75dff2f-f0e8-4a57-ad5e-b3bdd9c7e437">
        <source>buildConverterObjects();
// ---------------------------------------------------------------------------
// Created:     23 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	dict				: CM_ConverterByConstValueDict;
	baseScm 			: Schema;
	category 			: ConstantCategory;
	constDict			: ConstantNDict;
	const 				: Constant;
	realConverter,
	pxyConverter		: CM_ConverterObject;
	
begin
	beginTransaction;
	self.allConverterObjects.purge();
	commitTransaction;
	
	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(Converter_Object_Constants);
	constDict := category.getConstants();

	foreach const in constDict do
		if not self.buildConverterObject(const) then
			break;
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
</Class>
