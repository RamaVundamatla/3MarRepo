    <JadeMethod name="displayEntry" id="9930fa22-1113-4573-a0e6-15978fa74718">
        <updating/>
        <source>displayEntry(combobox: ComboBox input; obj: CM_LogGrade; lstIndex: Integer): String updating;
// ---------------------------------------------------------------------------
// Created:     29 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	
	if obj = null then
		return null;
	endif;
//  is filter so display all
//	if obj.notAvailableForEntry then
//		if self.myObject &lt;&gt; obj then
//			return null;
//		else
//			self.hasDirtyObject := true;
//		endif;
//	endif;
	
	return obj.code.String &amp; Tab &amp; obj.description;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="CM_LogGrade"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
