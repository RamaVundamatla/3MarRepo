    <JadeMethod name="utlUpdateVoyageAllocNumbers" id="61afc613-a255-4a01-b271-677cda519a66">
        <source>utlUpdateVoyageAllocNumbers(_voyAllocs : CM_YardAllocationSet;  _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     MARCH 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 09 Jan 2013		cnwkpd1			PAR #30964 - Add new event for Voyage Allocation maintenance
// ---------------------------------------------------------------------------
vars
	obj : CM_YardAllocation;
	realVoyAlloc : CM_VoyageAllocation;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	foreach obj in _voyAllocs  discreteLock do
		if obj = null then
			continue;
		endif;
		realVoyAlloc := obj.pxyGetRealObject().CM_VoyageAllocation;
		if realVoyAlloc &lt;&gt; null then
			realVoyAlloc.doSetUserEnteredNumbers(obj.CM_VoyageAllocation);
		endif;
		
	endforeach;
	if not _passport.hasErrorsOrWarnings() and realVoyAlloc &lt;&gt; null then // PAR 23817 ONE REFRESHES THE WHOLE LOTS!!!!! 
		app.myEventManager.createSingleObjInfoNoteEvt(realVoyAlloc.myVoyage,_passport.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),realVoyAlloc);
		app.myEventManager.createSingleObjInfoNoteEvt(realVoyAlloc.myVoyage,_passport.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_MAINT),realVoyAlloc);	// PAR #30964
	endif;

end;</source>
        <Parameter name="_voyAllocs" type="CM_YardAllocationSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageArchive" id="5d9a74d8-faf6-4e5c-a451-ab9a93d0fc5a">
        <updating/>
        <source>utlUpdateVoyageArchive(_archiveInt : CMIF_ArchiveVoyage;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/11/2006	cnwdad1		PAR #12870 - When archiving a Voyage, audits were
//							not being done pre and post update.
// ---------------------------------------------------------------------------
vars
	msg				: String;
	partsDone		: Integer;
	partsInJob		: Integer;
	iteratorObj		: Iterator;
	tmpVoyage		: CM_Voyage;
	monitorObj		: CMIF_Monitor;
	
begin
	self.initialiseActivity();
	
	tmpVoyage	:=	_archiveInt.myVoyage;
	
	if tmpVoyage &lt;&gt; null then
		if (not _archiveInt.allVoyages.includes(tmpVoyage)) then
			tmpVoyage.archive(_archiveInt,_passport);
		endif;
	endif;
	
	if (not _archiveInt.allVoyages.isEmpty) then
		monitorObj	:=	_archiveInt.myMonitor;
		partsInJob	:=	_archiveInt.allVoyages.size();
		if monitorObj &lt;&gt; null then
			monitorObj.updateProgress(msg, partsInJob, partsDone);
		endif;
		iteratorObj	:=	_archiveInt.allVoyages.createIterator();
		
		while iteratorObj.next(tmpVoyage) do
			partsDone	:=	partsDone + 1;
			if monitorObj &lt;&gt; null then
				monitorObj.updateProgress('Archiving voyage ' &amp; tmpVoyage.getDisplayDetails(false), partsInJob, partsDone);
			endif;
			
// cnwdad1 21/11/2006 - PAR #12870.
			self.myUpdateAuditAgent.audUpdateGeneric(tmpVoyage, true);
			
			tmpVoyage.archive(_archiveInt, _passport);
			
// cnwdad1 21/11/2006 - PAR #12870.
			if _passport.noErrors then
				self.myUpdateAuditAgent.audUpdateGeneric(tmpVoyage, false);
			endif;
			
			if _passport.hasErrors() then
				break;
			endif;
		endwhile;
	endif;
epilog
	delete iteratorObj;
end;</source>
        <Parameter name="_archiveInt" type="CMIF_ArchiveVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageDocuments" id="abb4d58a-902d-45c1-81be-afd6055c55b9">
        <source>utlUpdateVoyageDocuments(_voyage : CM_Voyage input; _allDocuments : ObjectArray input; _passport : CM_Passport );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2018	jlger1	Initial creation tfs 37939

*/

vars
	obj 		: Object;
	fileData	: CM_FileData;
begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_voyage, 'Voyage');
	self.raiseExceptionIfNull(_allDocuments, 'Documents');
	
	foreach obj in _allDocuments discreteLock do
		create fileData persistent;
		fileData.setForCreateProxy(_voyage,app.myPassport.userCode,obj.CM_FileData);	
	endforeach;
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_allDocuments" type="ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageDrawingDefn" id="bdeca5e6-c0de-40dd-a792-66fb902e660d">
        <source>utlUpdateVoyageDrawingDefn(_proxyVoyage:CM_Voyage; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realVoyage		: CM_Voyage;
	expectedEdition	: Integer;
	eventStr : String;
begin

	self.initialiseActivity();

	_proxyVoyage.raiseExceptionIfNotProxy(method);
	_proxyVoyage.pxyGetRealObjectAndEdition(realVoyage,expectedEdition);

	exclusiveLock(realVoyage);

	if _passport.noErrors and realVoyage.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage drawing definition', null, null);
		return;
	endif;
	
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyage, true);
	endif;
	
	if _passport.noErrors then
// AKB NOT NEEDED		realVoyage.setDrawingDefinition();
	endif;

	if _passport.noErrors then
		//global.causeEvent(realVoyage.myTerminal.getTerminalEvent(Voyage_Update_Event), false, realVoyage);		
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyage, false);
	endif;

end;</source>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageGlobal" id="8d015b8e-e548-43d6-9071-f332bccc9ade">
        <source>utlUpdateVoyageGlobal(_pxyGlobalVoyage : CM_VoyageGlobal; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realGlobalVoyage	: CM_VoyageGlobal;
	expectedEdition		: Integer;
	pxyVoy, realVoy		: CM_Voyage;
	isFound				: Boolean;
	cmifVoyageGlb		: CMIF_VoyageGlobal;
	realCode,
	proxyCode			: CM_CurrencyCode;
	
begin

	self.initialiseActivity();

	create cmifVoyageGlb transient;
	
	_pxyGlobalVoyage.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyGlobalVoyage.pxyGetRealObjectAndEdition(realGlobalVoyage, expectedEdition);
	
	if realGlobalVoyage = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageGlobal.name, null, null);
		return;
	endif;

	app.myValUA.valVoyageGlobal(_pxyGlobalVoyage, null, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realGlobalVoyage); 
	//par 13443 Mohammad 22/2/2007
	foreach realVoy in realGlobalVoyage.allVoyages do
		isFound := false;
		foreach pxyVoy in _pxyGlobalVoyage.allVoyages do
			if pxyVoy.myTerminal = realVoy.myTerminal and pxyVoy.arrivedDT = realVoy.arrivedDT then
				isFound := true;
				break;
			endif;
		endforeach;	
		if not isFound then
			cmifVoyageGlb.allVoyagesToDelete.add(realVoy);
		endif;
	endforeach;


	if _passport.noErrors and realGlobalVoyage.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Global', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realGlobalVoyage, true);
	endif;

	if _passport.noErrors then
		realGlobalVoyage.setForUpdate(_pxyGlobalVoyage, cmifVoyageGlb, true, _passport);		
		// CCMS 1124 save vessel name if IMO is set, in vesselCode
		if realGlobalVoyage.vesselCode &lt;&gt; null and
	       realGlobalVoyage.vesselName &lt;&gt; null then
			realCode := app.myRoot.allCurrencyCodes[realGlobalVoyage.vesselCode];
			if realCode = null then
				create realCode persistent;
				create proxyCode transient;
				proxyCode.setProxy(realGlobalVoyage.vesselCode, realGlobalVoyage.vesselName);
				realCode.setForCreate(proxyCode);
			endif;
		endif;
	endif;

	if _passport.noErrors then
		global.causeEvent(LogVoyageOps_Update_Event, false, realGlobalVoyage);	
		self.myUpdateAuditAgent.audUpdateGeneric(realGlobalVoyage, false);
	endif;
epilog
	delete cmifVoyageGlb;
	delete proxyCode;
end;</source>
        <Parameter name="_pxyGlobalVoyage" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageHoldJob" id="f5b498e5-416e-411a-8cbf-df8f7c3c3a74">
        <updating/>
        <source>utlUpdateVoyageHoldJob(	_jobParams : CMIF_VoyageJobParams input;
						_pxyJob : CM_VoyageHoldJob;
						_realJob : CM_VoyageHoldJob input;
						_passport : CM_Passport input;
						_allWLEs : CM_WLEArray
						) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 19/02/2022	navdap1		TFS 52801 SAL Direct Delivery - End of Shift Job Transfer
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
//
vars
	realHoldJob : CM_VoyageHoldJob;
	expectedEdition : Integer;
	pxyShift, realShift : CM_ShiftEntity;
    voyage : CM_Voyage;
	wle: CM_WorkListEntry;
	removeWLEs: CM_WLEArray;
	holdRequest: CM_Request;
	removeRequests: CM_RequestSet;

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValUA.valVoyageJob(_jobParams);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	_pxyJob.pxyGetRealObjectAndEdition(realHoldJob, expectedEdition);
	
	if realHoldJob = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Job.name, null, null);
		return;
	endif;

	exclusiveLock(realHoldJob);

	if _passport.noErrors and realHoldJob.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Job', null, null);
		return;
	endif;
	
	if _passport.noErrors then
	
		//23 Jun 2017	NDL	TFS 4948
		if _allWLEs &lt;&gt; null and not _allWLEs.isEmpty then
			realHoldJob.processExtraWles( _allWLEs );
		endif;
		
		realHoldJob.setForUpdateVoyage(_jobParams, _passport);
	endif;
	
	// TFS 3646 create/update shift for this job 
	if _jobParams.myProxyJob.myShift &lt;&gt; null then
		pxyShift   := _jobParams.myProxyJob.myShift;
		voyage     := _jobParams.myVoyage;
		realShift  := app.myProxyManager.getRealObject(pxyShift).CM_Shift;
		if realShift = null then
			realShift := voyage.myTerminal.allShiftsDay[pxyShift.CM_Shift.startDateTime, pxyShift.code];
		endif;
		if realShift = null then
			app.myUtilityCA.utlCreateShiftStd(pxyShift, _passport, realShift);
			if realShift&lt;&gt; null then
				realHoldJob.setMyShift(realShift.CM_Shift);
			endif;
		else
			app.myUtilityUA.utlUpdateShift(pxyShift, _passport);
		endif;
	endif;
	// now deal with the shift
	/* TFS 3646  CNWAB1 might be updating job to move to a new shift.
	*/

	// 27/9/18 MAP TFS41031  get rid of WLEs for TIs that have been removed from the job
	create removeWLEs transient;
	create removeRequests transient;
	foreach wle in realHoldJob.workListEntries do
		if not realHoldJob.allReceiveTrackedItems.includes(wle.myTrackedItem) and not realHoldJob.allReleaseTrackeditems.includes(wle.myTrackedItem) then
			removeWLEs.add(wle);
		endif;
	endforeach;
	foreach holdRequest in realHoldJob.allRequests do
		foreach wle in holdRequest.allWorkListEntries do
			if removeWLEs.includes(wle) then
				//removeRequests.add(holdRequest);
				// TFS 42872 jlgzm1 19/07/219
				// Direct Release moves for discherge job could potnetially have more 
				// than one WLE for the same request/ti, so need to account for duplicates 
				removeRequests.addNoDuplicates(holdRequest, false);
			endif;
		endforeach;
	endforeach;
	
	realHoldJob.handleRemoveUnactionedWLEs(removeRequests, removeWLEs);		// TFS 52801
	
	realHoldJob.unqueueRequestsWLEs(removeRequests, _passport);
	realHoldJob.unplanFutureMove(PLANNING_MODE, removeRequests, _passport);
	removeWLEs.purge();
	removeRequests.purge();

	// ### TFS 52618 22DEC2021 NAVAB1 - 'realHoldJob.unplanFutureMove' ABOVE REGENERATES THE REMARKS, NEED TO USE THE REMARKS PASSED IN.
	realHoldJob.setRemarks(_pxyJob.remarks);
	
	// TFS 52801 reset status to Complete if needed		// TFS 52801
	if realHoldJob.isDirectDelivery then				// TFS 52801
		realHoldJob.updateStatus();						// TFS 52801
	endif;												// TFS 52801	
	
	if _passport.noErrors then
		if realHoldJob &lt;&gt; null then
			realHoldJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
		endif;
	endif;

epilog
	delete removeWLEs;
	delete removeRequests;
end;</source>
        <Parameter name="_jobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_pxyJob" type="CM_VoyageHoldJob"/>
        <Parameter name="_realJob" type="CM_VoyageHoldJob" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_allWLEs" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageInvoiceGen" id="e2b5779f-7638-4a58-8296-8922e994a616">
        <source>utlUpdateVoyageInvoiceGen(_proxyVoyage:CM_Voyage; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// 25 Jun 2018	jlgdap1	TFS 39355 PEL1 Pilot Surcharges
// 04 Mar 2019	jlgdap1	TFS 43667 Update HMS_VyoageData edition to rebuild data in graphical view
vars
	realVoyage		: CM_Voyage;
	expectedEdition	: Integer;
	invoice : CM_Invoice;
begin

	self.initialiseActivity();

	_proxyVoyage.raiseExceptionIfNotProxy(method);
	_proxyVoyage.pxyGetRealObjectAndEdition(realVoyage,expectedEdition);

	exclusiveLock(realVoyage);

	if _passport.noErrors and realVoyage.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Invoice Generation', null, null);
		return;
	endif;
	
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyage, true);
	endif;
	
	if _passport.noErrors then
		realVoyage.setForUpdateChargeResources(_passport);
	endif;

	// TFS 37963 - Link Voyage Cash Payment to Invoice Lines
	// The voyage event transaction create their invoice lines  in real time.
	// The HMS Resources  have just created their invoice lines in 'setForUpdateChargeResources'
	// This next method links all the cash payments to the invoice lines.
	if _passport.noErrors then 
		realVoyage.setForUpdateLinkPayments2Lines();
	endif;
	
	// TFS 37963 only for non PELINDO
	// 					for PELINDO we need to create the surcharges for the invoice at this point.
	//						for all other customers the surcharges are applied on posting of invoice
	/*JLGAB1 13JUN18 - Surcharges are for all customers not just PELINDO. Surcharges are applied when the invoice is set to PREPEND (PEL1) or PENDING (JMT DEFAULT)
	if _passport.noErrors then 
		if realVoyage.myDischargeCompany.isUsingPelindo1Process() then
			foreach invoice in realVoyage.allInvoices do
				invoice.applySurcharges();
			endforeach;
		endif;
	endif;
	*/
	
	realVoyage.applySurchargesForMovements();				// TFS 39355
	
	if _passport.noErrors then 
		self.updateObjectEdition(realVoyage);	// par 30292
		if realVoyage.myHMSVoyageData &lt;&gt; null then						// TFS 43667
			self.updateObjectEdition(realVoyage.myHMSVoyageData);		// TFS 43667
		endif;															// TFS 43667
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyage, false);
	endif;

end;</source>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJob" id="83caec2c-339f-4062-ad55-6a49f0c963c7">
        <updating/>
        <source>utlUpdateVoyageJob(_theJobParams:CMIF_VoyageJobParams input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Sep 2020 cnwma1 		ChangeRequest 49906: MTN - Ops View External Webservice
// 31 Mar 2025 navma1  		MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	realJob				: CM_VoyageJob;
	expectedEdition		: Integer;
	theProxyVoyageJob   : CM_VoyageJob;
	wle                 : CM_WorkListEntry;
begin

	self.initialiseActivity();

	theProxyVoyageJob := _theJobParams.myProxyJob;
	
	app.setContinueCMExceptions(true);

	if _theJobParams.useNewMethod then
		_theJobParams.setRequests();
		_theJobParams.validateSlotAndHatchEditions();
	endif;

	app.myValUA.valVoyageJob(_theJobParams);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	theProxyVoyageJob.pxyGetRealObjectAndEdition(realJob, expectedEdition);
	
	if realJob = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Job.name, null, null);
		return;
	endif;

	exclusiveLock(realJob);

	if _passport.noErrors and realJob.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Job', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realJob.setForUpdateVoyage(_theJobParams, _passport);
	endif;

	if _passport.noErrors then
		if realJob &lt;&gt; null then
			realJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
		endif;
		
		//21/09/2020 cnwma1 TFS #49906
		if app.myPassport.isOpsViewEnabled(realJob.getMyTerminal) then
			app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,realJob.getMyTerminal,realJob);
			foreach wle in realJob.workListEntries discreteLock do 
				if wle.status &lt;&gt; WLE_UNACTIONED then
					continue;
				endif;
				if not wle.isSOBLoad() then // ### TFS 51855 01FEB2022 NAVAB1
					app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE,wle.getMyTerminal,wle);
				endif;
			endforeach;
		endif;
		//21/09/2020 cnwma1 TFS #49906
	endif;

end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJobAssignTI" id="641330cb-1cfd-41cc-810c-2bc5316465a8">
        <source>utlUpdateVoyageJobAssignTI(_proxyVoyageJob :CM_VoyageJob; _theTI : CM_TrackedItem input;_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/04/2010	cnwcs5		par 23383 - pass context info (null) to updateTICollections 
//									via new parameter (_extra)
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 31 Mar 2025  navma1 	    MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------

vars
	expectedEdition	: Integer;
	realVoyageJob 	: CM_VoyageJob;
	aSlotRequest	: CM_Request;
	realSlotRequest : CM_SlotRequest;
	theVWLE 		: CM_VoyageWLE;
begin
	self.initialiseActivity();

	_proxyVoyageJob.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	app.myValUA.valVoyageJobTIAssign(_proxyVoyageJob,_theTI);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);


	_proxyVoyageJob.pxyGetRealObjectAndEdition(realVoyageJob, expectedEdition);
	
	if realVoyageJob = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageJob.name, null, null);
		return;
	endif;

	exclusiveLock(realVoyageJob);

	if _passport.noErrors and realVoyageJob.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Job', null, null);
		return;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	realVoyageJob.updateTICollections(_theTI, null); // 01/04/2010 cnwcs5 par 23383
	realVoyageJob.setRemarks(null); 				// pass in null will get auto remarks

	if _passport.hasErrors then
		return;
	endif;
	

	aSlotRequest := null;
	theVWLE 	 := _theTI.getVoyageWLEUnactioned(true); // PAR 8953 added param
	if theVWLE &lt;&gt; null then
		aSlotRequest := theVWLE.myRequest;
	endif;
	
	if aSlotRequest &lt;&gt; null then
		realSlotRequest := aSlotRequest.CM_SlotRequest;
		if realSlotRequest.isRehandle then
			// if DLR do not change the IMEX - Import Export Transit etc
			_theTI.setTransitStatus(TI_TransitStatusDLR, true, _passport);
		elseif realSlotRequest.isSOB then
			// if SOB do not change the IMEX - Import Export Transit etc
			_theTI.setTransitStatus(TI_TransitStatusSOB, true, _passport);
		elseif realSlotRequest.moveType = DISCHARGE_MOVETYPE then
			_theTI.statusEvent(DIS_CCODE_STATUS_EV, true, _passport);
		elseif realSlotRequest.moveType = LOAD_MOVETYPE then
			_theTI.statusEvent(LOAD_CCODE_STATUS_EV, true, _passport);
		elseif realSlotRequest.moveType = NULL_MOVETYPE then
			_theTI.setTransitStatus(TI_TransitStatusNull, true, _passport);
			_theTI.setImExStatus(TI_IMEX_STATUS_NULL);
		endif;						
	endif;

epilog

end;</source>
        <Parameter name="_proxyVoyageJob" type="CM_VoyageJob"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJobLoadLanes" id="c85604f7-310a-470e-b271-413993ce338d">
        <source>utlUpdateVoyageJobLoadLanes(_proxyVoyageJob :CM_VoyageJob ;_startLoadLane : CM_BlockController; 
			_startWle : CM_VoyageWLE; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/03/2018	jlgmd1		TFS #37652 - CPL - Door Directions in Job Operations
// 31 Mar 2025  navma1 		MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------

vars
	expectedEdition	: Integer;
	realVoyageJob 	: CM_VoyageJob;
	
begin

	self.initialiseActivity();

	_proxyVoyageJob.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyVoyageJob.pxyGetRealObjectAndEdition(realVoyageJob, expectedEdition);
	
	if realVoyageJob = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageJob.name, null, null);
		return;
	endif;

	app.myValUA.valVoyageJobLoadLane(realVoyageJob,_startLoadLane,_startWle);
		
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realVoyageJob);

	if _passport.noErrors and realVoyageJob.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Job', null, null);
		return;
	endif;

	if _passport.noErrors then
		realVoyageJob.setDefaultLoadLanes(_startLoadLane,_startWle);
	endif;

	if _passport.noErrors then
		realVoyageJob.causeTerminalEvent(realVoyageJob.Event_Mode_Update);
		// Update the (Voyage) Job Operations screen too
		realVoyageJob.myVoyage.causeEvent(realVoyageJob.getMyTerminal.getTerminalEvent(JobSheet_Update_Event), false, realVoyageJob);		// TFS 37652
	endif;
epilog

end;</source>
        <Parameter name="_proxyVoyageJob" type="CM_VoyageJob"/>
        <Parameter name="_startLoadLane" type="CM_BlockController"/>
        <Parameter name="_startWle" type="CM_VoyageWLE"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJobLoadUnload" id="2cee63ca-9b60-4748-a6ca-889306c96040">
        <source>utlUpdateVoyageJobLoadUnload(_proxyVoyageJob :CM_VoyageJob; _loadMode : Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025  navma1 		 MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------

vars
	expectedEdition	: Integer;
	realVoyageJob 	: CM_VoyageJob;
	
begin

	self.initialiseActivity();

	_proxyVoyageJob.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyVoyageJob.pxyGetRealObjectAndEdition(realVoyageJob, expectedEdition);
	
	if realVoyageJob = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageJob.name, null, null);
		return;
	endif;

	if _loadMode then
		app.myValUA.valVoyageJobLoad(_proxyVoyageJob);
	else
		app.myValUA.valVoyageJobUnload(_proxyVoyageJob);
	endif;
		
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realVoyageJob);

	if _passport.noErrors and realVoyageJob.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Job', null, null);
		return;
	endif;

	if _passport.noErrors then
		if _loadMode then
			realVoyageJob.setShipOpsLoad();
		else
			realVoyageJob.setShipOpsUnload();
		endif;			
	endif;

	if _passport.noErrors then
		realVoyageJob.causeTerminalEvent(realVoyageJob.Event_Mode_Update);	
	endif;

end;</source>
        <Parameter name="_proxyVoyageJob" type="CM_VoyageJob"/>
        <Parameter name="_loadMode" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJobNumber" id="738cc3f4-9729-4ca6-b520-a158706fd499">
        <source>utlUpdateVoyageJobNumber(_proxyVoyageJob :CM_VoyageJob; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------

vars
	expectedEdition	 : Integer;
	realVoyageJob 	 : CM_VoyageJob;
	
begin

	self.initialiseActivity();

	_proxyVoyageJob.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyVoyageJob.pxyGetRealObjectAndEdition(realVoyageJob, expectedEdition);
	
	if realVoyageJob = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageJob.name, null, null);
		return;
	endif;

	app.myValUA.valVoyageJobNumber(_proxyVoyageJob);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realVoyageJob);

	if _passport.noErrors and realVoyageJob.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Job', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		if not realVoyageJob.isLoadedToOperations and not realVoyageJob.isJobComplete then
			realVoyageJob.setJobNum(_proxyVoyageJob.jobNum);
		endif;
	endif;

	if _passport.noErrors then
		realVoyageJob.causeTerminalEvent(realVoyageJob.Event_Mode_Update);
	endif;

end;</source>
        <Parameter name="_proxyVoyageJob" type="CM_VoyageJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJobRemarks" id="9875143e-c72e-46fe-b7d3-b562c5ff9eb1">
        <source>utlUpdateVoyageJobRemarks(_theJob : CM_VoyageJob input; _remarks : String; _passport : CM_Passport input);
//-----------------------------------------
//Created: January 2003 By: cnwgd1
//-----------------------------------------
vars
begin

	self.initialiseActivity();
	
	if _theJob = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _theJob.jobNum, null, null);
		return;
	endif;

	exclusiveLock(_theJob);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Job', null, null);
		return;
	endif;
	
	_theJob.setRemarks(_remarks);
	if _theJob &lt;&gt; null then
		_theJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
	endif;
end;</source>
        <Parameter name="_theJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJobSheet" id="9d942fa6-cdba-4e68-9eb3-c59feb4cf58f">
        <updating/>
        <source>utlUpdateVoyageJobSheet(_theCranes : ObjectArray;_theVoyage : CM_Voyage; _workPointJobSheetClassToCreate : Class; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
01 Aug 2011 cnwer1	CCMS 1033 - roro operations _theCranes can now be either CM_Crane or CM_WorkPoint
								changed method to handle this
*/

vars
	theVoyageJobSheet,
	vjs 	:	CM_VoyageJobSheet;
	aCrane : CM_Machine;
	anObject : Object;
	sheets : ObjectArray;
	theVoyage : CM_Voyage;
	workPointObject : CM_Object;
begin
	theVoyage := _theVoyage;
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	app.myValUA.valVoyageJobSheet(_theCranes,_theVoyage,_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	// ### CHECK if any need removing
	foreach theVoyageJobSheet in _theVoyage.allJobSheets do

		workPointObject := theVoyageJobSheet.getMyWorkPointObject();
		if workPointObject &lt;&gt; null then		
			if not _theCranes.includes(workPointObject) then
				delete theVoyageJobSheet; // remove crane
			endif;
		else
			delete theVoyageJobSheet; // crane does not exist
		endif;
	endforeach;

	// ### CREATE any that  do not exist
	foreach anObject in _theCranes do
		if _theVoyage.allJobSheets[anObject.IF_VoyageWorkPoint.getID] = null then
			
			if anObject.IF_VoyageWorkPoint.getWorkPoint() &lt;&gt; null then // TFS 3646 - work point could be for decks or holds
				create theVoyageJobSheet as  _workPointJobSheetClassToCreate; // TFS 3646
			else
				create theVoyageJobSheet as anObject.IF_VoyageWorkPoint.getVoyageJobSheetClass;
			endif;
			// if the voyage is null or the crane id is null the validation above will have kicked in
			theVoyageJobSheet.setForCreate(_theVoyage,anObject.IF_VoyageWorkPoint.getID,anObject.IF_VoyageWorkPoint.getWorkPoint);
		endif;
	endforeach;

	// ### REORDER SHEETS
	create sheets transient;
	// get new order
	foreach anObject in _theCranes do
	
		sheets.add(_theVoyage.allJobSheets[anObject.IF_VoyageWorkPoint.getID]);
	endforeach;	
	// remove all sheets from voyage
	foreach vjs in theVoyage.allJobSheets do
		vjs.setForCreate(null, vjs.crane,vjs.myWorkPoint);
	endforeach;
	// add them back on in correct order
	foreach anObject in sheets do
		vjs:=anObject.CM_VoyageJobSheet;
		vjs.setForCreate(theVoyage, vjs.crane,vjs.myWorkPoint);
	endforeach;
	
	if _passport.noErrors then
		_theVoyage.causeEvent(_theVoyage.myTerminal.getTerminalEvent(JobSheet_Update_Event), false, _theVoyage);
	endif;
epilog

delete sheets;
end;</source>
        <Parameter name="_theCranes" type="ObjectArray"/>
        <Parameter name="_theVoyage" type="CM_Voyage"/>
        <Parameter name="_workPointJobSheetClassToCreate" type="Class"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJobSheetJob" id="28b0197a-89ba-4cd7-bae2-c1105ce46da3">
        <source>utlUpdateVoyageJobSheetJob(	_jobSheeet : CM_VoyageJobSheet;
							_pxyJob,
							_realJob : CM_VoyageJob input;
							_newIndex : Integer;
							_passport : CM_Passport input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	term : CM_Terminal;
	oldJS : CM_VoyageJobSheet;
	newJob : CM_VoyageJob;
	aCrane : CM_Crane;
	request : CM_Request;
	isTwinLift : Boolean;
	indx : Integer;
begin
	self.initialiseActivity();

	if _jobSheeet = null then // PAR 26945
		return;
	endif;
	
	_realJob.validateForSplit(null);
		
	if _realJob.myVoyage &lt;&gt; _jobSheeet.CM_VoyageJobSheet.myVoyage then
		app.raiseCMException(Cannot_transf_crane_differ_voy, null, null);
	endif;

	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	term := _realJob.getMyTerminal();
	
	if term = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Terminal is null', null, null);
		return;
	endif;
	
	exclusiveLock(_realJob);
	exclusiveLock(_jobSheeet);

	if _realJob &lt;&gt; null then
		oldJS := _realJob.myVoyageJobSheet;

		// Par 12515 DVB
		aCrane := term.machines[_jobSheeet.CM_VoyageJobSheet.crane].CM_Crane;
		if aCrane &lt;&gt; null then	
		// CCMS 1414
			//if aCrane.canTwinLift and _realJob.canBeTwinLiftVoyageJobBays() then
			if aCrane.machineLiftType = TWIN_LIFT 
			and _realJob.canBeTwinLiftVoyageJobBays() then //ccms1595 27/11/07
				foreach request in _realJob.allRequests discreteLock do
					if _realJob.myVoyage.starboardBerthed then
						if request.CM_SlotRequest.isTwinLiftStarboard then
							isTwinLift := true;
							break;
						endif;
					else
						if request.CM_SlotRequest.isTwinLiftPort then
							isTwinLift := true;
							break;
						endif;
					endif;
				endforeach;	
			endif;
		endif;
			
		_realJob.setTwinLift(isTwinLift);
		
		if _realJob.status &lt;&gt; JOB_COMPLETE then
			if _realJob.craneId &lt;&gt; _jobSheeet.crane then
				_realJob.setCrane(null,_jobSheeet.crane);	
				if not isLockedByMe(_realJob.myJobSheet) then
					exclusiveLock(_realJob.myJobSheet);
				endif;
				_realJob.myJobSheet.removeJob(_realJob);
				
			else
				indx:=_jobSheeet.allJobsByOrder.indexOf(_realJob);
				if indx &lt;&gt; 0 then
					_jobSheeet.removeJob(_realJob);
				endif;
			endif;
			_jobSheeet.addJob(_realJob,_newIndex);
			
		else
			return; //silently as job is complete
		endif;
	endif;

	if _passport.hasErrors then				
		return;
	endif;

	if _realJob &lt;&gt; null then
		// Send event to remove job from unallocated list
		_realJob.causeTerminalEvent(_realJob.Event_Mode_Update);
		if _realJob.myJobSheet &lt;&gt; null
			and _realJob.myJobSheet &lt;&gt; oldJS then
			// send event to update new job sheet
			app.myEventManager.createSingleObjInfoNoteEvt(_realJob.myVoyage,term.getTerminalEvent(JobSheet_Update_Event),_realJob.myJobSheet);
		endif;
		if oldJS &lt;&gt; null then
			// Send event to update old job sheet
			app.myEventManager.createSingleObjInfoNoteEvt(_realJob.myVoyage,term.getTerminalEvent(JobSheet_Update_Event),oldJS);
		endif;		
	elseif oldJS &lt;&gt; null then
		// Send event to update old job sheet
		app.myEventManager.createSingleObjInfoNoteEvt(oldJS,term.getTerminalEvent(JobSheet_Update_Event),oldJS);
	endif;
	

end;</source>
        <Parameter name="_jobSheeet" type="CM_VoyageJobSheet"/>
        <Parameter name="_pxyJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_realJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_newIndex" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJobShift" id="70157beb-cbbc-41e0-8867-67276a5719a8">
        <source>utlUpdateVoyageJobShift(_pxyJob : CM_VoyageJob input; _realJob : CM_VoyageJob output; _passport : CM_Passport input);
/*
Purpose:			
Date		Who		Reason
17 February 2017	cnwab1	Initial creation
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars

	realObject	: CM_VoyageJob;
    shift 		: CM_Shift;
	realShift   : CM_ShiftEntity;
    voyage 		: CM_Voyage;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyJob, 'Job');

	app.setContinueCMExceptions(true);
	
	realObject := self.getRealObjectAndEditionCheck(_pxyJob, 'Job', _passport).CM_VoyageJob;

	// create a shift for this job as well
	if _pxyJob.myShift &lt;&gt; null then
		shift := _pxyJob.myShift;
		voyage := _pxyJob.myVoyage;
		realShift := app.myProxyManager.getRealObject(shift).CM_Shift;
		if realShift = null then
			realShift := voyage.myTerminal.allShiftsDay[shift.startDateTime, shift.code];
		endif;
		if realShift = null then
			app.myUtilityCA.utlCreateShiftStd(shift, _passport, realShift);
		else
			app.myUtilityUA.utlUpdateShift(shift, _passport);
		endif;
	endif;
	
	if _passport.noErrors then
		// do updates
		realObject.setForUpdate(_pxyJob, realObject.getMyTerminal());
	endif;

	if _passport.noErrors then
		if realObject &lt;&gt; null then
			realObject.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
		endif;
	endif;
	
	_realJob := realObject;	//17 Mar 2017	NDL	TFS 3785

epilog

end;</source>
        <Parameter name="_pxyJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_realJob" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJobUnassignTI" id="482387dd-8940-4a53-980e-a561ed50c065">
        <source>utlUpdateVoyageJobUnassignTI(_proxyVoyageJob :CM_VoyageJob; _theTI : CM_TrackedItem input;_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------

vars
	expectedEdition	: Integer;
	realVoyageJob 	: CM_VoyageJob;
begin
	self.initialiseActivity();

	_proxyVoyageJob.raiseExceptionIfNotProxy(method);

	_proxyVoyageJob.pxyGetRealObjectAndEdition(realVoyageJob, expectedEdition);
	
	if realVoyageJob = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageJob.name, null, null);
		return;
	endif;

	exclusiveLock(realVoyageJob);

	if _passport.noErrors and realVoyageJob.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Job', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realVoyageJob.updateTICollectionsUnassign(_theTI);
	endif;

epilog
	
end;</source>
        <Parameter name="_proxyVoyageJob" type="CM_VoyageJob"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJobUnplan" id="f3a03f10-dfee-435f-b92f-da1ce5f6a856">
        <updating/>
        <source>utlUpdateVoyageJobUnplan(_realVoyageJob : CM_VoyageJob input;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	theMoveController : CMIF_MoveController;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	app.myValUA.valVoyageJobUnplan(_realVoyageJob);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	// get rid of the future moves
	_realVoyageJob.unplanFutureMove(PLANNING_MODE, null, _passport);

	if _passport.noErrors then
		_realVoyageJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
	endif;

epilog
	delete theMoveController;
end;</source>
        <Parameter name="_realVoyageJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageJobsNumber" id="fd5caa06-e138-4fe2-ab47-56e89ad62382">
        <source>utlUpdateVoyageJobsNumber(_proxyVoyageJobs :CM_VoyageJobByJobNumDict; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------

vars
	expectedEdition	: Integer;
	realVoyageJob,
	proxyVoyageJob,
	tmpObj			: CM_VoyageJob;
	realVoyageJobs	: CM_VoyageJobByJobNumDict;
	theNumber 		: String;
begin

	self.initialiseActivity();

	create realVoyageJobs transient;
	
	foreach proxyVoyageJob in _proxyVoyageJobs do
		proxyVoyageJob.raiseExceptionIfNotProxy(method);
	
		app.setContinueCMExceptions(true);
	
		proxyVoyageJob.pxyGetRealObjectAndEdition(realVoyageJob, expectedEdition);
		
		if realVoyageJob = null then	
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageJob.name, null, null);
			return;
		endif;
		
		realVoyageJobs.add(realVoyageJob);
		
		app.myValUA.valVoyageJobsNumber(proxyVoyageJob, _proxyVoyageJobs);
		
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
		
		app.setContinueCMExceptions(false);
	
		exclusiveLock(realVoyageJob);
	
		if _passport.noErrors and realVoyageJob.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Job', null, null);
			return;
		endif;
		
		if _passport.noErrors then
			if not realVoyageJob.isLoadedToOperations and not realVoyageJob.isJobComplete then
				realVoyageJob.setJobNum("/" &amp; proxyVoyageJob.jobNum);
			endif;
		endif;

		if _passport.noErrors then
			realVoyageJob.causeTerminalEvent(tmpObj.Event_Mode_Update);
		endif;	
	endforeach;
	
	foreach tmpObj in realVoyageJobs do
		theNumber := tmpObj.jobNum;
		theNumber := theNumber[2:end];
		
		tmpObj.setJobNum(theNumber);
	endforeach;
	
epilog
	delete realVoyageJobs;						// 18/02/2014 cnwmh5 - Translient Leak
end;</source>
        <Parameter name="_proxyVoyageJobs" type="CM_VoyageJobByJobNumDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageKPIMoveForTRAN" id="d8418f96-97ad-40b6-892e-088be52b3603">
        <source>utlUpdateVoyageKPIMoveForTRAN(_controller :CMIF_KPIShipMove input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     June 2010 ANDREW BISHOP
// Purpose:		Update KPI figures for s single transaction
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 10/08/2010		cnwcs5			CCMS MES 1033 - RORO KPI. Renamed method
// ---------------------------------------------------------------------------

vars
	js 		: CM_VoyageJobSheet;
	tran	: CM_TITransaction;
	voyage	: CM_Voyage;
begin
	self.initialiseActivity();

	js 		:= _controller.myJobSheet;
	tran	:= _controller.myTiTransaction;
	
	if js &lt;&gt; null then
		// Update Crane/Shift &amp; Work Point/Shift KPIs
		js.setKPIVoyageJSShiftMovesTRAN (tran);
		
		if js.isVoyageROROJobSheet then
			// Update Deck/Work Point KPIs
			js.CM_VoyageDeckJobSheet.setKPIVoyageDeckWPMovesTRAN (tran);
			
		elseif js.isVoyageLOLOJobSheet then
			// Update Bay/Crane KPIs
			js.setKPIVoyageBayCraneMovesTRAN(tran);
		else
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Jobsheet must be RORO or LOLO');
		endif;
		
		// update the totals
		voyage := js.myVoyage;
		
		if voyage &lt;&gt; null then
			// Update KPI Totals for Voyage
			voyage.setKPIVoyageTotalMovesTRAN(tran); // PAR 25363
			// cause an event so the GUI can be updated
			voyage.causeEvent(voyage.myTerminal.getTerminalEvent(EVENT_KPISHIPMOVEUPDATE), false, null);
		endif;
	endif;
epilog
	

end;</source>
        <Parameter name="_controller" type="CMIF_KPIShipMove" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageKPIStats" id="fc6a80b0-91f9-4a52-9d7b-8af587d8e131">
        <source>utlUpdateVoyageKPIStats(_voy : CM_Voyage input; _clear : Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2007 By Andrew Bishop cnwab1
//
// Purpose:		Update all KPI stats for a voyage
//
// ---------------------------------------------------------------------------
// 04/08/2011	cnwcs5	CCMS MES 1033 RORO KPI 

vars
	
begin
	self.initialiseActivity();
	
	app.myValUA.valUpdateVoyageKPIStats (_voy, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	if _voy &lt;&gt; null then
		exclusiveLock(_voy);
		
		// KPIs BY SHIFT - LOLO/RORO
		_voy.setKPIVoyageShiftMoves(_clear);
		// BAY KPIs by CRANE - LOLO
		_voy.setKPIVoyageBayMoves(_clear);
		// Deck KPIS by Work Point - RORO
		_voy.setKPIVoyageDeckMoves (_clear);
		// VOYAGE KPIs TOTALS - LOLO/RORO
		_voy.setKPIVoyageMoves(); 
		
		_voy.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_KPISHIPMOVEUPDATE), false,null);
	endif;
end;</source>
        <Parameter name="_voy" type="CM_Voyage" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageNonPEffectiveDT" id="e20e6e1d-d9eb-4ad4-98d5-36581efe1e1e">
        <source>utlUpdateVoyageNonPEffectiveDT(_realVoyage :CM_Voyage input; _dateTime : TimeStamp; _passport : CM_Passport input);
//-----------------------------------------
// Created: 20 October 2003 By: cnwgd1
//-----------------------------------------
vars
	expectedEdition		: Integer;
begin

	self.initialiseActivity();
	
	if _realVoyage = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _realVoyage.getName, null, null);
		return;
	endif;

	exclusiveLock(_realVoyage);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage', null, null);
		return;
	endif;

// PAR 33644	if _realVoyage.isNonPlannedVoyage or _realVoyage.isNonWorkedVoyage then
	if _realVoyage.isHOLDSorSHIP() then
		if _dateTime.isValid then
			if _dateTime &gt; app.serverTimestampAtTrxStart then
				app.raiseCMException1(AutoScheduleDateError, app.getErrorString(RetrospectiveOperations), null, null);
				return;	
			endif;
		endif;
	endif;	
		
	if _realVoyage.nonPlannedEffectiveDT &lt;&gt; _dateTime then
		app.myAA.auditUpdate(_realVoyage, "Non-Planned Effective Date Time", _dateTime);
		_realVoyage.setNonPlannedEffectiveDT(_dateTime);
	endif;



end;</source>
        <Parameter name="_realVoyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageOOWAuto" id="9462678f-5e57-488e-a3a7-de1250ba9a11">
        <source>utlUpdateVoyageOOWAuto(_controller :CMIF_OOWCreationAutoUpdate; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2006 By Andrew Bishop cnwab1
//
// Purpose:		using the cranes move rate per hour, spread the work within the holds evenly 
//				across the cranes so that hopefully they will finish roughly at the same time.
//
// ---------------------------------------------------------------------------
vars
	realVoyage : CM_Voyage;
	realJS : CM_VoyageJobSheet;
	oowc, oowc2, oowcLast : CM_OOWCreation;
	oowcd : CM_OOWCreationDetail;
	targetItems, lastHoldTotItems, tmpItems, lastoowTotItems : Integer;
	aCrane : CM_Crane;
	bays, oowcByHold : CM_OOWCreationByOrder;
	idx, totItems, oowTotItems : Integer;
	aJS : CM_JobSheet;
	theCranes : CM_MachineSet;
	cvs : CM_CellularVoyageStructure;
	diffHold, splitHolds : Boolean;
	roroStructure : CM_ROROVoyageStructure;
begin

	self.initialiseActivity();

	splitHolds := _controller.splitHolds;
	cvs := _controller.myCellularStructure;
	
	realVoyage := cvs.myVoyage;
	
	exclusiveLock(cvs);
	create theCranes transient;
	create bays transient;
	create oowcByHold transient;
	
	// ### Target items is the percentage of all items for this voyage for this crane.
	// ### The percentage is the crane's rate per hour of all the cranes' rates per hour.
	idx := 1;
	if idx &lt;= _controller.craneRatePC.size then
		targetItems := (_controller.totalItems * (_controller.craneRatePC[idx] / 100)).Integer;
	else
		targetItems := 1;
	endif;
	totItems := 0;
	

	foreach oowc in cvs.allOOWCreations do
		oowcd := oowc.CM_OOWCreationDetail;
		bays.add(oowcd);
		if splitHolds then
			diffHold := true;
		else
			diffHold	:= (oowcLast &lt;&gt; null and oowcLast.myBay.myHold &lt;&gt; oowc.myBay.myHold);
		endif;
		
		oowc2 := null;
		oowTotItems := oowcd.getTotalItems();

		oowcByHold.add(oowcd);
		if diffHold then
			lastHoldTotItems := totItems;
		endif;
		
		// ### this is making sure that although we are attempting to get a percentage share 
		// ### we also need to make sure the share does not split holds
		if (totItems + oowTotItems) &gt; targetItems  // check if we are hitting our share total
		and oowcLast &lt;&gt; null then
			
			// ## if this OOWC is for a different hold from the last oowc then
			if diffHold then
				// if we have gone right through a hold and the items in this hold are more than 50% of the different from last hold and target then go back to the last hold
				if ((lastHoldTotItems - lastoowTotItems) &gt; targetItems)
				and ((totItems - lastHoldTotItems) / 2) &gt; (targetItems - lastHoldTotItems) then
					foreach oowc2 in oowcByHold do
						bays.remove(oowc2.CM_OOWCreationDetail); // take this bay out
						if oowc2 &lt;&gt; oowcd then
							tmpItems := oowcd.getTotalItems();
							totItems := totItems - tmpItems;
						endif;
					endforeach;
					targetItems := totItems; // set this is make it save
					oowc2 := null;
				else
					// add in everything so far, except this bay in the next hold
					bays.remove(oowc.CM_OOWCreationDetail); // take this bay out
					oowc2 := oowc; // save it away
					oowcByHold.clear;
					targetItems := totItems; // set this is make it save
				endif;
			else
				totItems := totItems + oowTotItems;
			endif;
		else
			totItems := totItems + oowTotItems;
		endif;
		
		// place all the bays onto this crane
		if totItems &gt;= targetItems 
		and diffHold then
			aCrane := _controller.allCranes[idx].CM_Crane;
			if aCrane = null then
				continue;
			endif;
			
			aJS := realVoyage.allJobSheets[aCrane.id];
			if aJS = null then
				theCranes.clear;
				theCranes.add(aCrane);
				app.myUtilityCA.utlCreateVoyageJobSheet(theCranes, realVoyage,_passport);
				
				aJS := realVoyage.allJobSheets[aCrane.id];
			endif;
			app.myUtilityUA.utlUpdateVoyageOOWBay(bays, aJS.CM_VoyageJobSheet, _passport);
			bays.clear;
			if oowc2 &lt;&gt; null then
				bays.add(oowc2.CM_OOWCreationDetail);
			endif;
			if not  oowcByHold.isEmpty then
				oowcByHold.copy(bays);
				oowcByHold.clear;
			endif;

			idx := idx + 1;
			if idx &lt;= _controller.craneRatePC.size then
				targetItems := (_controller.totalItems * (_controller.craneRatePC[idx] / 100)).Integer;
			endif;
			totItems := 0;
		endif;
		if diffHold then
			oowcByHold.clear;
			oowcByHold.add(oowcd);
			lastHoldTotItems := totItems;
		endif;
		oowcLast := oowc;
		lastoowTotItems := oowTotItems;
	endforeach;
	
	// ### put all the rest on the last crane
	if idx &lt;= _controller.craneRatePC.size then	
		aCrane := _controller.allCranes[idx].CM_Crane;
		if aCrane &lt;&gt; null then
		
			aJS := realVoyage.allJobSheets[aCrane.id];
			if aJS = null then
				theCranes.clear;
				theCranes.add(aCrane);
				app.myUtilityCA.utlCreateVoyageJobSheet(theCranes, realVoyage,_passport);
				
				aJS := realVoyage.allJobSheets[aCrane.id];
			endif;
			app.myUtilityUA.utlUpdateVoyageOOWBay(bays, aJS.CM_VoyageJobSheet, _passport);
		endif;	
	endif;	

	cvs.reOrderOOWForCreate();
	cvs.reAdjustIfSplitHold(_controller, _passport); // ### PAR 13427
	
	//CCMS 1033 19/9/11
	roroStructure:=_controller.myROROStructure;
	if roroStructure &lt;&gt; null then
		roroStructure.createOOWAutoAssignJobs();
	endif;
	
	if _passport.noErrors then
		cvs.causeEvent(realVoyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, cvs);
	endif;

epilog
	delete bays;
	delete theCranes;
	delete oowcByHold;
end;</source>
        <Parameter name="_controller" type="CMIF_OOWCreationAutoUpdate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageOOWBay" id="5a8a85cd-b8eb-49e3-b301-052b0c9af176">
        <source>utlUpdateVoyageOOWBay(_bays : CM_OOWCreationByOrder; _js : CM_VoyageJobSheet input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
//31 Mar 2025 	navma1  MTN-34387 MTN - Removing Unnecessary Audits
vars
	oowc 	: CM_OOWCreation;
	cvs		: CM_CellularVoyageStructure;
begin

	self.initialiseActivity();

	if _js &lt;&gt; null then
		exclusiveLock(_js);
		_js.allOOWCreations.clear;
	endif;
	foreach oowc in _bays do
		exclusiveLock(oowc);
		
		if _passport.noErrors then
			oowc.setJobSheet(_js);
		endif;
		
		if _passport.noErrors then 
			self.updateObjectEdition(oowc);	// par 30292
		endif;
		cvs := oowc.myVoyageStructure;
	endforeach;
	
	if cvs &lt;&gt; null then
		cvs.tidyUpOOWCreations();
	endif;
end;</source>
        <Parameter name="_bays" type="CM_OOWCreationByOrder"/>
        <Parameter name="_js" type="CM_VoyageJobSheet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageOOWCrane" id="d59a8f51-33b5-4685-8aa1-d8d70e0739f0">
        <source>utlUpdateVoyageOOWCrane(_controller :CMIF_OOWCraneUpdate; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// 29 Aug 2011 cnwer1	CCMS 1033 - changed to also work with work points
//31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars

	workPoint : CM_Object;
	realJS    : CM_VoyageJobSheet;
	cvs 	  : CM_CellularVoyageStructure;
begin

	self.initialiseActivity();

	workPoint:=_controller.myWorkPoint;
	if workPoint = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Crane.name, null, null);
		return;
	endif;
	realJS:= _controller.myJobSheet;
	if realJS = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageJobSheet.name, null, null);
		return;
	endif;

	exclusiveLock(workPoint);
	exclusiveLock(realJS);

	if _passport.noErrors then
		if workPoint.isKindOf(CM_Crane) then
			workPoint.CM_Crane.setOOWCraneDetails(_controller.craneCPH,_controller.craneSeed);
		elseif workPoint.isKindOf(CM_WorkPoint) then
			workPoint.CM_WorkPoint.setOOWCraneDetails(_controller.craneCPH,_controller.targetRatePHLM,_controller.craneSeed);
		endif;
		realJS.setOOWCraneDetails(_controller.exchangeTS, _controller.craneRversed);
	endif;
	
	cvs := _controller.myVoyageStructure;
	if _passport.noErrors 	and cvs &lt;&gt; null then
		cvs.causeEvent(cvs.myVoyage.myTerminal.getTerminalEvent(EVENT_CRANE_UPDATE), false, workPoint);
	endif;

epilog
	
end;</source>
        <Parameter name="_controller" type="CMIF_OOWCraneUpdate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageOOWMoveBay" id="d63a8c2f-c651-428c-a513-515e73b853cf">
        <updating/>
        <source>utlUpdateVoyageOOWMoveBay(_srcOOWC, _trgOOWC : CM_OOWCreation input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cvs : CM_CellularVoyageStructure;
	joinOOWC : CM_OOWCreationDetail;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	_srcOOWC.setJobSheet(_trgOOWC.myCraneJobSheet);
	_srcOOWC.incrementYourOrder(_trgOOWC, true);

	
	
	joinOOWC := _srcOOWC.getMatchingOOWC().CM_OOWCreationDetail;
		
	if joinOOWC &lt;&gt; null then
		if joinOOWC.myCraneJobSheet &lt;&gt; _srcOOWC.myCraneJobSheet then
			_srcOOWC.setMySplitSelf(joinOOWC);
			_srcOOWC.setOrderType(2);
			joinOOWC.setOrderType(2);
		else
			_srcOOWC.setMySplitSelf(null);
			_srcOOWC.setOrderType(1);
			joinOOWC.setOrderType(1);
		
		endif;
	endif;
	
	cvs := _srcOOWC.getCellularVoyageStructure;
	//CCMS 1553
	if cvs &lt;&gt; null then
		cvs.validateOOWCPhysicalOrder();
	
		if _passport.noErrors then
			cvs.causeEvent(cvs.myVoyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, cvs);
		endif;
	endif;
end;</source>
        <Parameter name="_srcOOWC" type="CM_OOWCreation" usage="input"/>
        <Parameter name="_trgOOWC" type="CM_OOWCreation" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageOOWMoveCC" id="fb9e1de7-a755-4f7d-a207-d4095b7d5bf1">
        <updating/>
        <source>utlUpdateVoyageOOWMoveCC(_pxyOOWC, _srcOOWC : CM_OOWCreation input;_attribute : String; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	expectedEdition : Integer;
	realOOWC : CM_OOWCreation;
	cvs : CM_CellularVoyageStructure;
begin
	self.initialiseActivity();

	_pxyOOWC.raiseExceptionIfNotProxy(method);

	_pxyOOWC.pxyGetRealObjectAndEdition(realOOWC, expectedEdition);
	if realOOWC = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_OOWCreation.name, null, null);
		return;
	endif;
	if _passport.noErrors and realOOWC.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'OOW Move CC Update', null, null);
		return;
	endif;

	
	app.setContinueCMExceptions(true);


	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	cvs := realOOWC.myVoyageStructure;
	
	_srcOOWC.setPropertyValue(_attribute,0);
	realOOWC.setForUpdate(_pxyOOWC.CM_OOWCreationDetail);
		
	cvs.tidyUpOOWCreations();
	
	if _passport.noErrors then
		cvs.causeEvent(cvs.myVoyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, cvs);
	endif;

end;</source>
        <Parameter name="_pxyOOWC" type="CM_OOWCreation" usage="input"/>
        <Parameter name="_srcOOWC" type="CM_OOWCreation" usage="input"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageOOWReset" id="9aee5c36-e220-4f26-b1f7-cbc629f4995d">
        <source>utlUpdateVoyageOOWReset(_voyage : CM_Voyage input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	eventStr : String;
	oowc : 	CM_OOWCreation;
	cvs : CM_CellularVoyageStructure;
	roroStructure : CM_ROROVoyageStructure;
begin

	self.initialiseActivity();

	if _voyage = null then
		return;
	endif;
	
	if _voyage.myCellularVoyageStructure &lt;&gt; null then
		cvs:=_voyage.myCellularVoyageStructure;
		cvs.allOOWCreations.purge;
	
	
		if _passport.noErrors then
			cvs.causeEvent(_voyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, cvs);
		endif;
	endif;
	
	if _voyage.myROROStructure &lt;&gt; null then
		roroStructure:=_voyage.myROROStructure;
		roroStructure.allOOWCreations.purge;
		
		if _passport.noErrors then
			roroStructure.causeEvent(_voyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, roroStructure);
		endif;
	
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageOOWSetNumLifts" id="28f4ccf1-c843-42f4-8065-e27060dd09a1">
        <source>utlUpdateVoyageOOWSetNumLifts(_cvs : CM_CellularVoyageStructure; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:		29 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		Getting the twin lift numbers is very complicated and is part of creation 
//					of the job and several terminal configs.
//					at this point we do not have the jobs, they have not been created yet
//					so we will create the jobs and then abort the transaction to get the TL numbers
//
// ---------------------------------------------------------------------------
vars
	realJS, tmpJS : CM_VoyageJobSheet;
	controller : CMIF_VoyageJobParams;
	vJob : CM_VoyageJob;
	aJob : CM_Job;
	oowcs : CM_OOWCreationByOrdinal;
	realOOWC : CM_OOWCreation;
	pxyOOWC : CM_OOWCreationDetail;
begin
	create controller transient;
	create oowcs transient;
	
	beginTransaction;
		foreach realJS in _cvs.myVoyage.allJobSheets discreteLock do
			realJS.createOOWAuto(controller);
			realJS.createOOWAutoSetJobs(); 
	
			foreach realOOWC in realJS.allOOWCreations discreteLock do
				if realOOWC.isKindOf(CM_OOWCreationDetail) then
					pxyOOWC := app.createUpdateProxy(realOOWC).CM_OOWCreationDetail;
					oowcs.add(pxyOOWC);
				endif;
			endforeach;
		endforeach;
	abortTransaction;
	
	beginTransaction;
		foreach pxyOOWC in oowcs do
			realOOWC := _cvs.allOOWCreations[pxyOOWC.order, pxyOOWC.orderType];
			if realOOWC.order = pxyOOWC.order then
				realOOWC.CM_OOWCreationDetail.setNumLifts(0);
				realOOWC.CM_OOWCreationDetail.setNumLifts(pxyOOWC.numberOfLifts);
			endif;
		endforeach;
	commitTransaction;

epilog
	if oowcs &lt;&gt; null then
		oowcs.purge;
	endif;
	delete controller;
	delete oowcs;
end;</source>
        <Parameter name="_cvs" type="CM_CellularVoyageStructure"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageOOWVoyage" id="fad6fe9f-b9cb-4e60-9d53-e0a85ff77f4a">
        <source>utlUpdateVoyageOOWVoyage(_controller :CMIF_OOWVoyageUpdate; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	expectedEdition		: Integer;
	realVoyage : CM_Voyage;
	realJS : CM_VoyageJobSheet;
	cvs : CM_CellularVoyageStructure;
	workPointObj : CM_Object;
	berthingChanged : Boolean;
begin

	self.initialiseActivity();

	_controller.myVoyage.raiseExceptionIfNotProxy(method);

	_controller.myVoyage.pxyGetRealObjectAndEdition(realVoyage, expectedEdition);
	if realVoyage = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Voyage.name, null, null);
		return;
	endif;
	if _passport.noErrors and realVoyage.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'OOW Voyage Update', null, null);
		return;
	endif;


	exclusiveLock(realVoyage);

	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyage, true);
	endif;
	
	berthingChanged := (_controller.starboardBerthed &lt;&gt; realVoyage.starboardBerthed);
	
	if _passport.noErrors then
		realVoyage.setOOWVoyageDetails(_controller.shipExhangeTS,_controller.starboardBerthed);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyage, false);
	endif;
	if berthingChanged then
		realVoyage.causeEvent(realVoyage.myTerminal.getTerminalEvent(EVENT_VOYAGE_BERTHING_CHANGED), false, realVoyage);
	endif;

	realVoyage.causeEvent(realVoyage.myTerminal.getTerminalEvent(EVENT_OOWVOYAGE_UPDATE), false, realVoyage);
	cvs := realVoyage.myCellularVoyageStructure;
	if _passport.noErrors 
	and cvs &lt;&gt; null then
		foreach realJS in realVoyage.allJobSheets do
			workPointObj:=realJS.getMyWorkPointObject;
			if workPointObj &lt;&gt; null then
				cvs.causeEvent(cvs.myVoyage.myTerminal.getTerminalEvent(EVENT_CRANE_UPDATE), false, workPointObj);
			endif;
		endforeach;
	endif;
epilog
	

end;</source>
        <Parameter name="_controller" type="CMIF_OOWVoyageUpdate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageOperator" id="295e9389-b32f-4cea-9625-0b435da19468">
        <source>utlUpdateVoyageOperator(_pxyVoyageOperator : CM_VoyageOperator; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	expectedEdition		: Integer;
	realVoyageOperator 	: CM_VoyageOperator;
	
begin

	self.initialiseActivity();

	_pxyVoyageOperator.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyVoyageOperator.pxyGetRealObjectAndEdition(realVoyageOperator, expectedEdition);
	
	if realVoyageOperator = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageOperator.name, null, null);
		return;
	endif;

	app.myValUA.valVoyageOperator(realVoyageOperator, _pxyVoyageOperator, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realVoyageOperator);
	
	if _passport.noErrors and realVoyageOperator.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Operator', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyageOperator, true);
	endif;

	if _passport.noErrors then
		realVoyageOperator.setForUpdate(_pxyVoyageOperator);
	endif;

	if _passport.noErrors then
		//log voyage ops is multi terminal therefore we need to send this extra note
		//global.causeEvent(LogVoyageOps_Update_Event, false, realVoyageOperator);	
		global.causeEvent(realVoyageOperator.myVoyage.myTerminal.getTerminalEvent(VoyageOperator_Update_Event), false, realVoyageOperator);	
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyageOperator, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_pxyVoyageOperator" type="CM_VoyageOperator"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyagePlanningCode" id="291ab6df-5df5-4963-9d27-803de4135299">
        <updating/>
        <source>utlUpdateVoyagePlanningCode(pProxyVoyagePlanCodeObj:CM_VoyagePlanningCode; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		11 March 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	realVPCodeObj	: CM_VoyagePlanningCode;
	expectedEdition	: Integer;
	
begin
	self.initialiseActivity();

	pProxyVoyagePlanCodeObj.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyVoyagePlanCodeObj.pxyGetRealObjectAndEdition(realVPCodeObj, expectedEdition);
	
	if realVPCodeObj = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_MTGrade.name, null, null);
		return;
	endif;

	app.myValUA.valVoyagePlanningCode(realVPCodeObj, pProxyVoyagePlanCodeObj);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realVPCodeObj);

	if _passport.noErrors and realVPCodeObj.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'AvailabilityGrade', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVPCodeObj, true);
	endif;
	
	if _passport.noErrors then
		realVPCodeObj.setForUpdate(pProxyVoyagePlanCodeObj);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVPCodeObj, false);
	endif;
end;</source>
        <Parameter name="pProxyVoyagePlanCodeObj" type="CM_VoyagePlanningCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageProcAddReps" id="b3cacaae-fe91-4f7d-930d-74a2c85af340">
        <updating/>
        <source>utlUpdateVoyageProcAddReps(	realVoyageProcess : CM_VoyageProcess input;
							_allVoyProcReports : CM_VoyageProcessReportArray;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	if realVoyageProcess = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VoyageProcess.name, null, null);
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realVoyageProcess);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyageProcess, true);
	endif;

	if _passport.noErrors then
		realVoyageProcess.updateAdditionalReps(_allVoyProcReports);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyageProcess, false);
	endif;
	
epilog

end;</source>
        <Parameter name="realVoyageProcess" type="CM_VoyageProcess" usage="input"/>
        <Parameter name="_allVoyProcReports" type="CM_VoyageProcessReportArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageProcAuto" id="bcf5a64a-8bc0-465a-9e00-8ceb4bb9ca56">
        <source>utlUpdateVoyageProcAuto(_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/06/2024	navkc1 CR 64611 Task 64623: Jade - New Voyage Process

*/

vars
	pxyProcess, realProcess, autoProcess : CM_VoyageProcess;
begin
	if CM_VoyageProcessAutomatic.instances.isEmpty() then
		create pxyProcess as CM_VoyageProcessAutomatic transient;
		pxyProcess.setProxy(VoyageProcessAutomatic, "MTN Automatic", null, null, null, null, null, null);
		app.myUtilityCA.utlCreateVoyageProcess(pxyProcess, realProcess, app.myPassport);
		if not app.myPassport.noErrors() then
			app.writeLog(method.qualifiedName() &amp; " Failed to create CM_VoyageProcessAutomatic!!!", LogINFO);
			return;
		endif;
		autoProcess := realProcess;
	else
		autoProcess := app.myRoot.allVoyageProcesses[VoyageProcessAutomatic];
	endif;
	
	self.setupVoyageStatusMovePriority(autoProcess);
	
	self.setupVoyageStatus(autoProcess, Voyage_Status_Pending_Auto, 1, Voyage_Status_Pending_Auto_Str);
	self.setupVoyageStatus(autoProcess, Voyage_Status_Arrived_Auto, 2, Voyage_Status_Arrived_Auto_Str);
	//self.setupVoyageStatus(autoProcess, Voyage_Status_Loading_Auto, 3, Voyage_Status_Loading_Auto_Str);				//navra1 - MTN-33086 - 21st Oct 2024
	//self.setupVoyageStatus(autoProcess, Voyage_Status_LdCmplt_Auto, 4, Voyage_Status_LdCmplt_Auto_Str);				//navra1 - MTN-33086 - 21st Oct 2024
	self.setupVoyageStatus(autoProcess, Voyage_Status_AutoOn_Auto, 3, Voyage_Status_AutoOn_Auto_Str);					//navra1 - MTN-33086 - 21st Oct 2024
	self.setupVoyageStatus(autoProcess, Voyage_Status_Autoff_Auto, 4, Voyage_Status_Autoff_Auto_Str);					//navra1 - MTN-33086 - 21st Oct 2024
	self.setupVoyageStatus(autoProcess, Voyage_Status_Closed_Auto, 5, Voyage_Status_Closed_Auto_Str);
	self.setupVoyageStatus(autoProcess, Voyage_Status_Depart_Auto, 6, Voyage_Status_Depart_Auto_Str);
	self.setupVoyageStatus(autoProcess, Voyage_Status_Cancel_Auto, 7, Voyage_Status_Cancel_Auto_Str);
	self.setupVoyageStatus(autoProcess, Voyage_Status_Archive_Auto, 8, Voyage_Status_Archive_Auto_Str);
	
	self.setupVoyageStatusDelPriority(autoProcess);
	
epilog
	delete pxyProcess;
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageProcDefault" id="9dac62d9-2f6a-4627-a9f1-f4ada9b31821">
        <source>utlUpdateVoyageProcDefault(_passport : CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2018	jlgdap1		Initial creation TFS 38851 PEL1 Voyage Statuses INAPORTNET
// 15/09/2021	jlizm1		TFS 51963 SAL Voyage Request Changes
//
vars
	pxyProcess, realProcess, defaultProcess : CM_VoyageProcess;

begin
	// create the default voyage process object
	if CM_VoyageProcessDefault.instances.isEmpty then
		create pxyProcess as CM_VoyageProcessDefault transient;
		pxyProcess.setProxy(VoyageProcessDefault, "MTN Default", null, null, null, null, null, null);
		app.myUtilityCA.utlCreateVoyageProcess(pxyProcess, realProcess, app.myPassport);
		if not app.myPassport.noErrors then
			app.writeLog(method.qualifiedName &amp; " Failed to create CM_VoyageProcessDefault!!!", LogINFO);
			return;
		endif;
		defaultProcess := realProcess;
	else
		defaultProcess := app.myRoot.allVoyageProcesses[VoyageProcessDefault];
	endif;
	
	// in case there's been a change in status priority, get everything in priority order out of the way
	// Add 10000 to all priorities
	self.setupVoyageStatusMovePriority(defaultProcess);
	
	// now create / update all statuses
	self.setupVoyageStatus(defaultProcess, Voyage_Status_Pending, 		1, 	Voyage_Status_Pending_Str);
	self.setupVoyageStatus(defaultProcess, Voyage_Status_Arrived, 		2, 	Voyage_Status_Arrived_Str);
	self.setupVoyageStatus(defaultProcess, Voyage_Status_Loading, 		3, 	Voyage_Status_Loading_Str);
	self.setupVoyageStatus(defaultProcess, Voyage_Status_LoadComplete, 	4, 	Voyage_Status_LoadComplete_Str);
	self.setupVoyageStatus(defaultProcess, Voyage_Status_Closed, 		5, 	Voyage_Status_Closed_Str);
	self.setupVoyageStatus(defaultProcess, Voyage_Status_Departed, 		6, 	Voyage_Status_Departed_Str);
	self.setupVoyageStatus(defaultProcess, Voyage_Status_Cancelled, 	7, 	Voyage_Status_Cancelled_Str);
	self.setupVoyageStatus(defaultProcess, Voyage_Status_Archived, 		8, 	Voyage_Status_Archived_Str);
	
	// now check for any statuses left with priorities above 10000
	self.setupVoyageStatusDelPriority(defaultProcess);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageProcEUP" id="aa002fba-2c70-43c6-8193-8362015b56ef">
        <source>utlUpdateVoyageProcEUP();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 August 2022		jlizm1	Initial creation TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars

	pxyProcess, realProcess, eupProcess : CM_VoyageProcess;

begin

	if CM_VoyageProcessEUP.instances.isEmpty then
		// Create the EUP voyage process object
		create pxyProcess as CM_VoyageProcessEUP transient;
		pxyProcess.setProxy(VoyageProcessEUP, "EUP Default",null,null,null,null, null, null);
		app.myUtilityCA.utlCreateVoyageProcess(pxyProcess, realProcess, app.myPassport);
		if not app.myPassport.noErrors then
			app.writeLog(method.qualifiedName &amp; " Failed to create CM_VoyageProcessEUP!!!", LogINFO);
			return;
		endif;
		eupProcess := realProcess;
	else
		eupProcess := app.myRoot.allVoyageProcesses[VoyageProcessEUP];
	endif;
	
	// in case there's been a change in status priority, get everything in priority order out of the way
	// Add 10000 to all priorities
	self.setupVoyageStatusMovePriority(eupProcess);

	// now create/update all statuses
	self.setupVoyageStatus(eupProcess, Voyage_Status_EUP_VoyReq, 		1, 	"Voyage Requested");
	self.setupVoyageStatus(eupProcess, Voyage_Status_EUP_VoyReqSubm,	2, 	"Voyage Request Submitted");
	self.setupVoyageStatus(eupProcess, Voyage_Status_EUP_VoyReqRej, 	3, 	"Voyage Request Rejected");
	self.setupVoyageStatus(eupProcess, Voyage_Status_EUP_Pending, 		4, 	Voyage_Status_Pending_Str);
	self.setupVoyageStatus(eupProcess, Voyage_Status_EUP_Arrived, 		5, 	Voyage_Status_Arrived_Str);
	self.setupVoyageStatus(eupProcess, Voyage_Status_EUP_Loading, 		6, 	Voyage_Status_Loading_Str);
	self.setupVoyageStatus(eupProcess, Voyage_Status_EUP_Complete, 		7, 	Voyage_Status_LoadComplete_Str);
	self.setupVoyageStatus(eupProcess, Voyage_Status_EUP_Closed, 		8, 	Voyage_Status_Closed_Str);
	self.setupVoyageStatus(eupProcess, Voyage_Status_EUP_Departed, 		9, 	Voyage_Status_Departed_Str);
	self.setupVoyageStatus(eupProcess, Voyage_Status_EUP_Cancelled, 	10, Voyage_Status_Cancelled_Str);
	self.setupVoyageStatus(eupProcess, Voyage_Status_EUP_Archived, 		11, Voyage_Status_Archived_Str);
	
	// now check for any statuses left with priorities above 10000
	self.setupVoyageStatusDelPriority(eupProcess);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageProcINAPORTNET" id="6b6158b8-b1cf-4824-8724-582ff0279e37">
        <updating/>
        <source>utlUpdateVoyageProcINAPORTNET(_passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2018	jlgdap1		Initial creation TFS 38851 PEL1 Voyage Statuses INAPORTNET
//
vars
	pxyProcess, realProcess, inaPortNetProcess : CM_VoyageProcess;
	
begin
	if CM_VoyageProcessIPN1.instances.isEmpty then
		create pxyProcess as CM_VoyageProcessIPN1 transient;
		pxyProcess.setProxy(VoyageProcessInaportnet, "INAPORTNET1", null, null, null, null, null, null);
		app.myUtilityCA.utlCreateVoyageProcess(pxyProcess, realProcess, app.myPassport);
		if not app.myPassport.noErrors then
			app.writeLog(method.qualifiedName &amp; " Failed to create CM_VoyageProcessIPN1!!!", LogINFO);
			return;
		endif;
		inaPortNetProcess := realProcess;
	else
		inaPortNetProcess := app.myRoot.allVoyageProcesses[VoyageProcessInaportnet];
	endif;

	// in case there's been a change in status priority, get everything in priority order out of the way
	// Add 10000 to all priorities
	self.setupVoyageStatusMovePriority(inaPortNetProcess);
	
	// now create / update all statuses
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IVoyCreated, 		10, 	"Voyage Created INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IVoyRequested, 		20, 	"Voyage Requested INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IETMALCalculated, 	30, 	"ETMAL Calculated");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IVoyReqRejected, 	40, 	"Voyage Request Rejected");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_ICargoReqPending, 	50, 	"Cargo Request Pending");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_ICargoRequested, 	60, 	"Cargo Requested");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_ICargoReqReject, 	70, 	"Cargo Request Rejected");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IServicesPending, 	80, 	"Initial Marine Services Pending");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IInitSerRquested, 	90, 	"Initial Marine Services Requested");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IInitSerApproved, 	100, 	"Initial Marine Services Approved");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IInitSerRejected, 	110, 	"Initial Marine Services Rejected");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IInitSerIPNPend, 	120, 	"Initial Marine Services Pending INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IInitSerIPNAppr, 	130, 	"Initial Marine Services Approved INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IInitSerConfirm, 	140, 	"Initial Marine Services Confirmed");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IAppPendIPN, 		150, 	"Voyage Approval Pending INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IApprovalPending, 	160, 	"Voyage Approval Pending");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IApprovalReject, 	170, 	"Voyage Approval Rejected");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IVoyageApproved, 	180, 	"Voyage Approved");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IVoyageArrived, 	190, 	"Voyage Arrived");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IVoyageArrIPN, 		200, 	"Voyage Arrived INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_ICargoPreInvGen, 	210, 	"Cargo Pre-Invoice Generated");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_ICargoTaxInvGen, 	220, 	"Cargo Tax Invoice Generated");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IExtReqIPN, 		230, 	"Voyage Extension Requested INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IExtMSReq, 			240, 	"Voyage Extension Marine Services Requested");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IExtApproved, 		250, 	"Voyage Extension Approved");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IExtPendIPN, 		260, 	"Voyage Extension Pending INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IExtAppIPN, 		270, 	"Voyage Extension Approved INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IShiftReqIPN, 		280, 	"Voyage Shift Requested INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IShiftReqApp, 		290, 	"Voyage Shift Request Approved");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IShiftRPendIPN, 	300, 	"Voyage Shift Request Pending INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IShiftRAppIPN, 		310, 	"Voyage Shift Request Approved INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IShiftApp, 			320, 	"Voyage Shift Approved");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IShiftPendIPN, 		330, 	"Voyage Shift Approval Pending INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IShiftAppIPN, 		340, 	"Voyage Shift Approved INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IShiftConfirm, 		350, 	"Voyage Shift Confirmed");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IShiftSentIPN, 		360, 	"Voyage Shift Confirmed INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_ICancelReqIPN, 		370, 	"Voyage Cancellation Requested INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_ICancelApproved, 	380, 	"Voyage Cancel Approved");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IDepServPending, 	390, 	"Departure Marine Services Pending");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IDepServRequest, 	400, 	"Departure Marine Services Requested");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IDepServApproved, 	410, 	"Departure Marine Services Approved");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IDepRPendIPN, 		420, 	"Departure Request Pending INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IDepRAppIPN, 		430, 	"Departure Request Approved INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IDepReqApp, 		440, 	"Departure Request Approved");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IDepReqIPN, 		450, 	"Voyage Departure Requested INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IDepAppIPN, 		460, 	"Voyage Departure Approved INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IServPreInvGen, 	470, 	"Marine Pre-Invoice Generated");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IServTaxInvGen, 	480, 	"Marine Tax Invoice Generated");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IVesselDeparted, 	490, 	"Vessel Departed");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IVessDepIPN, 		500, 	"Vessel Departed INAPORTNET");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IVesselArchived, 	510, 	"Vessel Archived");
	self.setupVoyageStatus(inaPortNetProcess, Voyage_Status_IVoyCancelled, 		520, 	"Voyage Cancelled");	//02 Aug 2018	NDL	TFS 39924
	
	// now check for any statuses left with priorities above 10000
	self.setupVoyageStatusDelPriority(inaPortNetProcess);
epilog

end;</source>
