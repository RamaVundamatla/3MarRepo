    <JadeMethod name="clickFilter" id="5273e67c-be93-4317-9b8f-424fa68786f5">
        <updating/>
        <source>clickFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2016	cnwndl1	Initial creation	TFS 3129

*/

vars

	buttonNumber : Integer;
	menuButton : MOB_Button;
	realCount : Integer;
	selectedTi : CM_TrackedItem;
	userObj : Object;
	buttonWidth : Real;

begin

	//option 2 = filter the list
	//option 3 = filter the list and if there is only one left, click it.
	
	self.setupInYard();
	
	buttonWidth := getButtonWidthSetScrollBar( self.inYardButtonCount, self.frmCargoInYard, self.btnInYardTemp.height, self.scrCargoInYard );
	foreach buttonNumber in 1 to self.inYardButtonCount do
		menuButton := self.btnInYardTemp.getControl( buttonNumber ).MOB_Button;
		if menuButton &lt;&gt; null then
			if menuButton.width &lt;&gt; buttonWidth then
				menuButton.width := buttonWidth;
			endif;
		endif;
	endforeach;
	
	if self.allowDirectScan = 3 then
		//If there is only one button for a real TI then click it
		if self.inYardButtonCount &lt; 4 then
			//because there can be one for 'Find more cargo' and another for 'Swap Cargo'
			foreach buttonNumber in 1 to self.inYardButtonCount do
				menuButton := self.btnInYardTemp.getControl( buttonNumber ).MOB_Button;
				if menuButton &lt;&gt; null then
					userObj := menuButton.userObject;
					if userObj &lt;&gt; null and userObj.isKindOf( CM_TrackedItem ) then
						realCount := realCount + 1;
						selectedTi := userObj.CM_TrackedItem;
					endif;
				endif;
			endforeach;
		endif;
		if realCount = 1 then
			self.clickInYardItem( selectedTi );
		endif;
		
	endif;
	

epilog

end;</source>
    </JadeMethod>
