    <JadeMethod name="copyReportItemsToCollection" id="0dd9a90b-98a8-48fc-90bd-bcf9b0f1f33d">
        <updating/>
        <source>copyReportItemsToCollection(_collection: Collection; _collectionItem: Integer) updating;
// Jan 2012 CCMS 1262 Transaction Enquiry, for Send to Report from the enquiry form
vars
	tran : CM_TITransaction;
begin
	_collection.copy(self.allTransactions);
	

	// TFS 40632
	foreach tran in self.allTransactions 	discreteLock do
		tran.copySnapShotForReporting(self);
	endforeach;
	
	
end;
</source>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_collectionItem" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="b71763a5-7d8d-4c76-8b8e-3bab34ab3a07">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2021	navndl1	Initial creation	TFS 50799

*/

vars

begin

	if not self.allSnapShotReportings.isEmpty then
		self.allSnapShotReportings.purge();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllSitesString" id="75a2d4e3-1093-47a5-9647-14c8c93b4291">
        <source>getAllSitesString():String;

/*

Purpose:
				for report writer

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29118

*/

vars

	int : Integer;
	str : String;
	retString : String;

begin

	if self.allSites = null or self.allSites.isEmpty then
		return "*** Any ***";
	endif;
	
	foreach int in self.allSites do
		if int = TI_SITE_ONSHIP then
			str := TI_SITE_ONSHIP_str;
		elseif int = TI_SITE_ONSITE then
			str := TI_SITE_ONSITE_str;
		elseif int = TI_SITE_OFFSITE then
			str := TI_SITE_OFFSITE_str;
		else
			continue;
		endif;
		if retString = null then
			retString := str;
		else
			retString := retString &amp; ", " &amp; str;
		endif;
	endforeach;
	
	return retString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDateTimeFromLocalTZ" id="3f7cace0-6248-4ba5-80e0-d5d1fed8d4dd">
        <source>getDateTimeFromLocalTZ() :TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2016	cnwns1	Initial creation
// 03 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.dateTimeFrom);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
