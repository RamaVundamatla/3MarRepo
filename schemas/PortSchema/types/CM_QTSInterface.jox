    <JadeMethod name="createInvoiceLine2" id="3a551106-2fb4-424b-b31f-a36466d6685f">
        <source>createInvoiceLine2(_file : File input; _invoice : CM_Invoice);
/*

Purpose:			
		Mapping RA_INTERFACE_DISTRIBUTIONS_ALL , 100 Col
		Mandatory Col: 4
		7	Line Transactions Flexfield Segment 1										invLine.sequenceNum									
		23	Accounting Flexfield Segment 2	Segment 2 from GL Code (Cost Center)        GLCode(2)
		24	Accounting Flexfield Segment 3	Segment 3 from GL Code (Line of Business)   GLCode(3)
		25	Accounting Flexfield Segment 4	Segment 4 from GL Code (Account Segment)    GLCode(4)
Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud
*/

vars
	str,
	strGLSeg2,
	strGLSeg3,
	strGLSeg4	: String;
	invLine 	: CM_InvoiceLine;
	glcode      : CM_GLCode;
	fileEx			: FileException;
begin
	
	on FileException do self.fileExceptionHandler(fileEx);
	
	
	/////////////////////////////
	///////Writing To file///////
	/////////////////////////////
	foreach invLine in _invoice.invoiceLines discreteLock do
		
		strGLSeg2 := null;
		strGLSeg3 := null;
		strGLSeg4 := null;
		if invLine.getGLCode &lt;&gt; null then
			strGLSeg2 := invLine.getGLCode.getSegmentValue('.' ,2);
			strGLSeg3 := invLine.getGLCode.getSegmentValue('.' ,3);
			strGLSeg4 := invLine.getGLCode.getSegmentValue('.' ,4);
		endif;
		
		str :=
		Space                         &amp; Comma &amp;                           //001 - Business Unit Identifier
		Space                         &amp; Comma &amp;                           //002 - REV
		Space                         &amp; Comma &amp;                           //003 - Amount
		Space                         &amp; Comma &amp;                           //004 - Percent
		Space                         &amp; Comma &amp;                           //005 - Accounted Amount in Ledger Currency
		Space                         &amp; Comma &amp;                           //006 - Line Transactions Flexfield Context
		_invoice.sequenceNum.String   &amp; Comma &amp;                           //007 - Line Transactions Flexfield Segment 1  - Mandatory
		Space                         &amp; Comma &amp;                           //008 - Line Transactions Flexfield Segment 2
		Space                         &amp; Comma &amp;                           //009 - Line Transactions Flexfield Segment 3
		Space                         &amp; Comma &amp;                           //010 - Line Transactions Flexfield Segment 4
		Space                         &amp; Comma &amp;                           //011 - Line Transactions Flexfield Segment 5
		Space                         &amp; Comma &amp;                           //012 - Line Transactions Flexfield Segment 6
		Space                         &amp; Comma &amp;                           //013 - Line Transactions Flexfield Segment 7
		Space                         &amp; Comma &amp;                           //014 - Line Transactions Flexfield Segment 8
		Space                         &amp; Comma &amp;                           //015 - Line Transactions Flexfield Segment 9
		Space                         &amp; Comma &amp;                           //016 - Line Transactions Flexfield Segment 10
		Space                         &amp; Comma &amp;                           //017 - Line Transactions Flexfield Segment 11
		Space                         &amp; Comma &amp;                           //018 - Line Transactions Flexfield Segment 12
		Space                         &amp; Comma &amp;                           //019 - Line Transactions Flexfield Segment 13
		Space                         &amp; Comma &amp;                           //020 - Line Transactions Flexfield Segment 14
		Space                         &amp; Comma &amp;                           //021 - Line Transactions Flexfield Segment 15
		Space                         &amp; Comma &amp;                           //022 - Accounting Flexfield Segment 1         
		strGLSeg2                     &amp; Comma &amp;                           //023 - Accounting Flexfield Segment 2          - Mandatory
		strGLSeg3                     &amp; Comma &amp;                           //024 - Accounting Flexfield Segment 3          - Mandatory
		strGLSeg4                     &amp; Comma &amp;                           //025 - Accounting Flexfield Segment 4          - Mandatory
		Space                         &amp; Comma &amp;                           //026 - Accounting Flexfield Segment 5
		Space                         &amp; Comma &amp;                           //027 - Accounting Flexfield Segment 6
		Space                         &amp; Comma &amp;                           //028 - Accounting Flexfield Segment 7
		Space                         &amp; Comma &amp;                           //029 - Accounting Flexfield Segment 8
		Space                         &amp; Comma &amp;                           //030 - Accounting Flexfield Segment 9
		Space                         &amp; Comma &amp;                           //031 - Accounting Flexfield Segment 10
		Space                         &amp; Comma &amp;                           //032 - Accounting Flexfield Segment 11
		Space                         &amp; Comma &amp;                           //033 - Accounting Flexfield Segment 12
		Space                         &amp; Comma &amp;                           //034 - Accounting Flexfield Segment 13
		Space                         &amp; Comma &amp;                           //035 - Accounting Flexfield Segment 14
		Space                         &amp; Comma &amp;                           //036 - Accounting Flexfield Segment 15
		Space                         &amp; Comma &amp;                           //037 - Accounting Flexfield Segment 16
		Space                         &amp; Comma &amp;                           //038 - Accounting Flexfield Segment 17
