    <JadeMethod name="getObjects" id="42d8dbdc-1dde-4af4-b92b-c1731ab66a5f">
        <source>getObjects(objects: ObjectLongNameDict input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/09/2013	cnwdap1		Initial creation PAR #32215
//
vars
	vehicleType    : CM_VehicleType;
	
begin
	foreach vehicleType in app.myDutyDocRoot.allVehicleTypes do 
		objects[vehicleType.getYADisplay()] := vehicleType;
	endforeach;
epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
