	return null;
epilog
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <ReturnType type="CMIF_RoadOpObject"/>
    </JadeMethod>
    <JadeMethod name="getAllRoadOpObjectsByDockOrder" id="c9da444a-40b5-4a1c-85a9-5f2352921bd5">
        <source>getAllRoadOpObjectsByDockOrder(allRoadOpObjects : CMIF_RoadOpObjects input)protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	roadOpObj : CMIF_RoadOpObject;
begin
	if allRoadOpObjects = null then
		return;
	endif;

	roadOpObj:=self.allCMIFRoadOpObjects[RoadOpsForm_PreGate];
	allRoadOpObjects[roadOpObj.getDockOrder]:=roadOpObj;
	
	//if self.myVTA.isDualGate then
		roadOpObj:=self.allCMIFRoadOpObjects[RoadOpsForm_Yard];
		allRoadOpObjects[roadOpObj.getDockOrder]:=roadOpObj;
	
		roadOpObj:=self.allCMIFRoadOpObjects[RoadOpsForm_GateIn];
		allRoadOpObjects[roadOpObj.getDockOrder]:=roadOpObj;
		
		roadOpObj:=self.allCMIFRoadOpObjects[RoadOpsForm_GateOut];
		allRoadOpObjects[roadOpObj.getDockOrder]:=roadOpObj;	
	//endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="allRoadOpObjects" type="CMIF_RoadOpObjects" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAreaCaption_NameAndTotal" id="10ea94da-092b-4b35-9ae4-d856615e3a37">
        <source>getAreaCaption_NameAndTotal(_table :CM_DataTable; _area :CM_TerminalArea):String;
// ---------------------------------------------------------------------------
// Created:     09 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj	:CMIF_RoadOpObject;
begin
	obj := self.findCMIF_RoadOpObjWithTable (_table);
	
	return obj.getAreaCaption_NameAndTotal(_area);
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_area" type="CM_TerminalArea"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCMIFRoadOpObjFromVehicle" id="63adde37-5b94-44c1-bcee-ea9fc6c4fd59">
        <source>getCMIFRoadOpObjFromVehicle(_vehicle : CM_Vehicle input) : CMIF_RoadOpObject protected;
/*
Purpose:		Find road op object correspoding to vehicle	
Return Value:	Road op object	

Date			Who		Reason
16 August 2006	cnwer1	Initial creation - PAR#xxxx
02 Sept 2009	cnwcs5	ccms 1061 - remove old VTA handling
*/
vars
	lc 		: CM_YardController;
	area	: CM_TerminalArea;
	obj		: CMIF_RoadOpObject;
	coll	: CM_ObjectSet;
begin
	lc	 := _vehicle.myPrimaryActualLocation;
	
	if lc = null then
		return null;	// vehicle not in terminal
	endif;	
	
	area := lc.myTerminalArea;

	if area.isKindOf (CM_GateArea) then
		if area.CM_GateArea.laneCount &gt; 0 and lc.isKindOf(CM_GateAreaLaneController) then
			// these are real gate lanes
			if lc.CM_GateAreaLaneController.laneDirection =  CM_GateAreaLaneController.Is_Out_Lane then
				obj := self.allCMIFRoadOpObjects[RoadOpsForm_GateOut];
			elseif lc.CM_GateAreaLaneController.laneDirection =  CM_GateAreaLaneController.Is_In_Lane then
				obj := self.allCMIFRoadOpObjects[RoadOpsForm_GateIn];
			endif;
		else
			// must be default gate lane or in-transit-to LC for gate area
			obj := self.allCMIFRoadOpObjects[RoadOpsForm_PreGate];
		endif;
		
		if obj &lt;&gt; null then
			// only return the object if the vehicle location is one we are monitoring.
			create coll transient;
			
			obj.getAllGateAreas (coll);	// Note: could optimise to store when gates selected
			
			if coll.includes (area) then
				return obj;
			endif;
		endif;
		
	elseif area.isKindOf (CM_InterchangeArea) and self.allInterchangeAreas.includes (area.CM_InterchangeArea) then
		return self.allCMIFRoadOpObjects[RoadOpsForm_Yard];
		
	//31 Jan 2013	NDL	Par 31102
	elseif area.isKindOf (CM_CraneTransferArea) and self.allInterchangeAreas.includes (area.CM_CraneTransferArea) then
		return self.allCMIFRoadOpObjects[RoadOpsForm_Yard];
		
	else
		// should not happen as we should only be able to move a vehicle to an interchange area or gate area
	endif;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <ReturnType type="CMIF_RoadOpObject"/>
    </JadeMethod>
    <JadeMethod name="getForm" id="02f87338-bb21-4fb4-a47b-03f0830ce851">
        <source>getForm():YRD_RoadOperationsForm protected;
// ---------------------------------------------------------------------------
// Created:     18 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/10/2012	cnwcs5	par 29653 - change of return type
// ---------------------------------------------------------------------------
vars

begin
