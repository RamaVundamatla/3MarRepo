    <JadeMethod name="loadToolbar" id="0abb799d-b67c-464a-a9bd-ef1970ddbf6f">
        <source>loadToolbar();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	user			: CM_User;
	frm				: CMUI_Toolbar;
	navigatorForm	: CMUI_Navigator;
	
begin
	user := app.getMyUser();
	if user = null then
		return;
	endif;
	
	frm := self.frmToolbar;
	frm.left := 2;
	
	frm.loadToolbarFromMenuRoot(user.myMenuUserToolbarRoot, self.picSeperatorBase.picture);
	frm.showCaptions := user.myMenuUserToolbarRoot.showCaption;
	
	self.frmToolbar.height := frm.height + 6;
	
	navigatorForm := app.getForm(CMUI_Navigator.name).CMUI_Navigator;
	if navigatorForm &lt;&gt; null then
		navigatorForm.move(0, navigatorForm.left, navigatorForm.width, navigatorForm.height);
		if user.myMenuUserToolbarRoot &lt;&gt; null and user.myMenuUserToolbarRoot.showCaption then
			navigatorForm.clientHeight := self.height.Integer - 170;
		else
			navigatorForm.clientHeight := self.height.Integer - 150;
		endif;
		navigatorForm.resize();
	endif;
	
	if (app.toolbarHidden) then
		frm.visible := false;
	else
		frm.visible := true;
	endif;
	
	
end;</source>
    </JadeMethod>
