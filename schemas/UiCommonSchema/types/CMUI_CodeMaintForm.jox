    <JadeMethod name="doBaseFormSave" id="e01ce993-2956-4098-a94f-fe9ea7881219">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tableCodeData : CM_DataTable;
	obj : Object;
	pxyProductAttrCode	: CM_ProductAttributeCode;
	strCode,
	strDescription		: String;
	colCode,
	colDesc,
	int : Integer;
begin

	if self.validateCodesForSave() then 
		return;
	endif;
	
	tableCodeData := self.tblCodeData;
	colCode := tableCodeData.getColumnByRowName(ETRow_EntCode);
	colDesc := tableCodeData.getColumnByRowName(ETRow_EntDescription);
	
	self.myProductAttr.allCodes.clear();

	foreach int in tableCodeData.fixedRows + 1 to tableCodeData.rows do

		strCode := tableCodeData.accessCell(int, colCode).text;
		strDescription := tableCodeData.accessCell(int,colDesc).text;
	
		if strCode = null then 
			// ignore
			continue;
		endif;

		obj := tableCodeData.accessRow(int).itemObject;
	
		if obj = null then 
			// is row without proxy so create one and populate. 
			create pxyProductAttrCode transient;
//			tableCodeData.accessRow(beforeRow).itemObject := pxyProductAttrCode;	
		else
			pxyProductAttrCode := obj.CM_ProductAttributeCode;
		endif;

		self.myProductAttr.allCodes.add(pxyProductAttrCode);
					
		if strCode &lt;&gt; pxyProductAttrCode.code or strDescription &lt;&gt; pxyProductAttrCode.description then 
		//	if code has changed
			strCode := strCode.toUpper();
			pxyProductAttrCode.setProxy(strCode, strDescription, false, null);
		endif;
		
	endforeach;
	
	self.myForm.setIsCodesEdited();
	self.myForm.isCodesPressedSave := true;

	self.unloadForm();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCloneCodes" id="f67f2551-a60a-409e-ac39-e6b1821d6b83">
        <source>doCloneCodes(): Boolean;
// ---------------------------------------------------------------------------
// Created:     21 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	cloneProdAttr,
	prodAttr	: CM_ProductAttr;
	newCode,
	cloneCode	: CM_ProductAttributeCode;
	row			: Integer;
	codeTable	: CM_DataTable;
begin
	codeTable := self.tblCodeData;
	cloneProdAttr := self.cmbCloneAttr.listObject.CM_ProductAttr;
	prodAttr := self.myProductAttr;
	
	if cloneProdAttr = null then
		app.msgBox( app.getErrorString(SelecCargoSubAttrFromWithToClo),'Error', 0);
		return false;
	endif;
	
	if cloneProdAttr.allCodes.isEmpty then
		app.msgBox(app.getErrorString(SelectCargoSubAttrHasNoCodes), 'Error', 0);
		return false;
	endif;
	
	//if we're over writing then clear the codes table
	if self.cbOverwriteCodes.value then
		codeTable.rows := codeTable.fixedRows;
		foreach row in codeTable.fixedRows + 1 to codeTable.rows do
//			newCode := codeTable.accessRow(row).itemObject.CM_ProductAttributeCode;
//			prodAttr.allCodes.remove(newCode);
			codeTable.removeItem(row);
		endforeach;
	endif;
	
	foreach cloneCode in cloneProdAttr.allCodes do
		create newCode transient;
		newCode := cloneCode.cloneSelf(true);
		self.addCodeRow(newCode);
	endforeach;	

	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCmbCloneTypeLostFocus" id="d00e45fe-ce00-4a3c-9c0d-29be18d312e1">
        <source>doCmbCloneTypeLostFocus();
// ---------------------------------------------------------------------------
// Created:     21 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	cargoType		: CM_CargoType;
begin
	cargoType		:= self.cmbCloneType.myObject.CM_CargoType;

	if self.cmbCloneProduct.myCargoType &lt;&gt; cargoType then 
		self.cmbCloneProduct.clear();
		self.cmbCloneProduct.setCargoType(cargoType);
		self.cmbCloneAttr.clear();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadCloneDataTbl" id="06940be4-3568-4eed-b5d3-9cc3fa2730b8">
        <source>doLoadCloneDataTbl();
// ---------------------------------------------------------------------------
// Created:     22 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	cloneProdAttr : CM_ProductAttr;
	table		: CM_DataTable;
	code			: CM_ProductAttributeCode;
begin

	cloneProdAttr := self.cmbCloneAttr.listObject.CM_ProductAttr;
	table		:= self.tblCloneData;
	table.rows := table.fixedRows;
	
	if cloneProdAttr  = null then 
		return;
	endif;
	
	foreach code in cloneProdAttr.allCodes do 	
	//idx :=
	 table.addItem(code.code &amp; Tab &amp; code.description);
//	tmpTable.accessRow(idx).itemObject := prodCode;
	endforeach;

		
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryRowColumnChange" id="7c63ea6b-a19f-4be1-ba1d-4a190c99bddf">
        <updating/>
        <source>doQueryRowColumnChange(table: Table input; newRow: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     23 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theRow,
	cols,
	idx,
	col : Integer;
begin

	theRow := table.row;

	cols := table.columns;
	col := table.column+1;
	
	if col &gt; cols then
		//end of row
		foreach idx in theRow+1 to table.rows do
			if table.accessRow(idx).enabled then
				return;
			endif;
		endforeach;				

		self.addNewRowTblCodeData(theRow);
		return;
	endif;		
	
	while col &lt;= cols do
		if table.accessCell(theRow, col).enabled then
			break;
		endif;
		if col+1 &gt; cols then
			foreach idx in theRow+1 to table.rows do
				if table.accessRow(idx).enabled then
					return;
				endif;
			endforeach;		
			//end of row

		self.addNewRowTblCodeData(theRow);
			return;
		endif;
		col := col+1;			
	endwhile;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRemoveCode" id="dc0fa8fc-dad2-4be9-bc9f-ba49089c66f4">
        <source>doRemoveCode();
// ---------------------------------------------------------------------------
// Created:     20 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	row		: Integer;
	tableCodeData : CM_DataTable;
	obj : Object;
//	pxyProductAttrCode	: CM_ProductAttributeCode;
	strCode,
	strDescription		: String;
//	int : Integer;
begin
	tableCodeData := self.tblCodeData;
//	beforeRow := tableCodeData.accessedCell.row;
	row := tableCodeData.row;

	
	if row &lt;= tableCodeData.fixedRows or row &gt;tableCodeData.rows then 
	//	coming from a click on the header row so no update
		return;
	endif;
	
	tableCodeData.removeItem(row);

epilog

//delete obj;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="ce670e93-764d-4529-a2e1-040419a76ec1">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     22 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	
	self.tblCodeData.width := self.tblCodeData.parent.width - 10;
	self.tblCodeData.height := self.tblCodeData.parent.height - 50;
	
	
	if self.tblCodeData.columns &gt; 0 then
		self.tblCodeData.columnWidth[self.tblCodeData.columns] := self.tblCodeData.clientWidth - self.tblCodeData.leftColumn - 100;
	endif;
	
	self.tblCloneData.width := self.tblCloneData.parent.width - 10;
	self.tblCloneData.height := self.tblCloneData.parent.height - 10;
	
	
	if self.tblCodeData.columns &gt; 0 then
		self.tblCloneData.columnWidth[self.tblCloneData.columns] := self.tblCloneData.clientWidth - self.tblCloneData.leftColumn - 100;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doRowChangeForNewRow" id="46b480bb-9f05-43b3-afca-7dd344cc6ac5">
        <source>doRowChangeForNewRow(_currentRow : Integer; _tmpTable : CM_DataTable);
// ---------------------------------------------------------------------------
// Created:     26 September 2005	cnwhjg1
//
// Purpose:     ** for new rows. Checks values have been entered correctly etc.
//				Note there is another method that is called for normal row/col 
//				changes. doTblCodeDataRowChange. additional changes should be
//				included in there as well. 
// ----------   ----------  --------------------------------------------------
vars
	beforeRow,
	afterRow 		: Integer;
	tableCodeData : CM_DataTable;
//	obj : Object;
//	pxyProductAttrCode	: CM_ProductAttributeCode;
	strCode,
	strDescription		: String;
	int : Integer;
begin
	tableCodeData := _tmpTable ;
	beforeRow := _currentRow;
	afterRow := tableCodeData.row;
	
	
	if tableCodeData.row &gt; tableCodeData.fixedRows then
		if tableCodeData.column = 1 then
			tableCodeData.accessCell(tableCodeData.row, 1).cellControl.TextBox.case := TextBox.Case_Upper;
		else
			tableCodeData.accessCell(tableCodeData.row, 1).cellControl.TextBox.case := TextBox.Case_None;
		endif;
	endif;

	if beforeRow = afterRow then
	// no change of row so no update or new row. 
		return;
	endif;
	
	if beforeRow = tableCodeData.fixedRows or beforeRow &gt; tableCodeData.rows then 
	//	coming from a click on the header row so no update or from deleted row
		return;
	endif;

	strCode := tableCodeData.accessCell(beforeRow, tableCodeData.getColumnByRowName(ETRow_EntCode)).text;
	strDescription := tableCodeData.accessCell(beforeRow, tableCodeData.getColumnByRowName(ETRow_EntDescription)).text;

	if strCode = null then 
		app.msgBox('You must enter a value for "Code" before continuing','Insufficient input', 0);
		tableCodeData.row := beforeRow;
		return;
	endif;

	strCode := strCode.toUpper();
	tableCodeData.accessCell(beforeRow, tableCodeData.getColumnByRowName(ETRow_EntCode)).text := strCode; 
	
	
	if strCode.length &gt; 10 then 
		app.msgBox('Code values must be 10 Characters or less.','Max Code Length 10 Characters', 0);
		tableCodeData.row := beforeRow;		
		return;
	endif;

	if self.validateNewCode(strCode, beforeRow) then 
		tableCodeData.row := beforeRow;
		return;
	endif;	
	
epilog

end;</source>
        <Parameter name="_currentRow" type="Integer"/>
        <Parameter name="_tmpTable" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doTblCodeDataContex" id="2a1e47a9-b388-4963-a628-eb1e5005bd7f">
        <updating/>
        <source>doTblCodeDataContex(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_Object;
	visibleBeforeSep : Boolean;
	visibleAfterSep : Boolean;
	
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	
//	self.doMnuContextDetailBuild();
	self.mnuNew.visible := true;
	self.mnuRemove.visible := true;
	self.mnuInspect.visible := app.isAllowedToInspect();

	self.popupMenu(self.mnuContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblCodeDataRowChange" id="39bfeda8-7d64-4b54-98ea-045de31852fb">
        <source>doTblCodeDataRowChange(_table : CM_DataTable input);
// ---------------------------------------------------------------------------
// Created:     23 August 2005	cnwhjg1
//
// Purpose:     ** for existing rows. Checks values have been entered correctly etc.
//				Note there is another method that is called when new row added as 
//				this method was not being fired and there was a needed for the action
//				to be handled slightly differently. method doRowChangeForNewRow 
//				additional changes should be included in there as well. 
// ----------   ----------  --------------------------------------------------
vars
	beforeRow,
	afterRow 		: Integer;
	tableCodeData : CM_DataTable;
	strCode,
	strDescription		: String;
	int : Integer;
begin
	tableCodeData := _table;
	beforeRow := tableCodeData.accessedCell.row;
	afterRow := tableCodeData.row;

	if _table.row &gt; _table.fixedRows then
		if _table.column = 1 then
			_table.accessCell(_table.row, 1).cellControl.TextBox.case := TextBox.Case_Upper;
		else
			_table.accessCell(_table.row, 1).cellControl.TextBox.case := TextBox.Case_None;
		endif;
	endif;

	if beforeRow = afterRow then
		return;
	endif;
	
	if beforeRow = tableCodeData.fixedRows or beforeRow &gt; tableCodeData.rows then 
	//	coming from a click on the header row so no update or from deleted row
		return;
	endif;

	strCode := tableCodeData.accessCell(beforeRow, tableCodeData.getColumnByRowName(ETRow_EntCode)).text;
	strDescription := tableCodeData.accessCell(beforeRow, tableCodeData.getColumnByRowName(ETRow_EntDescription)).text;

	if strCode = null then 
		app.msgBox('You must enter a value for "Code" before continuing','Insufficient input', 0);
		tableCodeData.row := beforeRow;
		return;
	endif;

	strCode := strCode.toUpper();
	tableCodeData.accessCell(beforeRow, tableCodeData.getColumnByRowName(ETRow_EntCode)).text := strCode; 
	
	
	if strCode.length &gt; 10 then 
		app.msgBox('Code values must be 10 Characters or less.','Max Code Length 10 Characters', 0);
		tableCodeData.row := beforeRow;		
		tableCodeData.column := 1; 
		return;
	endif;

	if self.validateNewCode(strCode, beforeRow) then 
		tableCodeData.row := beforeRow;
		return;
	endif;	
	
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTblCloneData" id="6c53a084-2c2b-451d-9006-0ac1ad719a32">
        <source>initTblCloneData();
// ---------------------------------------------------------------------------
// Created:     22 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	table		: CM_DataTable;
	entDef		:EntTableDef;
begin

	entDef := app.myController.getEntTableDef(ETDef_CodeEntry);
	table := self.tblCloneData;
//	table.tabKey := J_key_Tab;

	self.setColorsForTable(table);
	table.setColumnHeadingsFromDef(entDef.name, false);
	table.setTblDataEntRowsFromDef(entDef);
	table.userInputEnabled := false;
//	table.selectionType := CM_DataTable.SelectMode_Single;
	table.left := self.HorizontalSpacing;
	table.setDistanceFromBottom(5);
	self.tblCloneData.top := self.HorizontalSpacing;
	self.tblCloneData.visible := true; 
	self.tblCloneData.columnWidth[1]	:= 100;

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblCodeData" id="0064e414-8fe2-4787-9e37-202337250861">
        <source>initTblCodeData();
// ---------------------------------------------------------------------------
// Created:     04 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	table		: CM_DataTable;
	entDef		:EntTableDef;
	idx, numFixedRows : Integer;
begin

	entDef := app.myController.getEntTableDef(ETDef_CodeEntry);
	table := self.tblCodeData;
	table.tabKey := J_key_Tab;

	numFixedRows := table.fixedRows;
		
	foreach idx in 1 to numFixedRows do
		table.accessRow(idx).backColor := self.colorHeadingColumn;
	endforeach;

	table.setColumnHeadingsFromDef(entDef.name, false);
	table.setTblDataEntRowsFromDef(entDef);
	table.userInputEnabled := true;
	table.selectionType := CM_DataTable.SelectMode_WholeRows;
	table.left := self.HorizontalSpacing;
	table.setDistanceFromBottom(5);
	self.tblCodeData.columnWidth[1]	:= 100;
end;</source>
    </JadeMethod>
    <JadeMethod name="isDuplicateCode" id="6158bb73-5c9f-4120-a654-1cc815c548e6">
        <source>isDuplicateCode(_code : String) : Boolean ;
// ---------------------------------------------------------------------------
// Created:     07 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	prodAttrCode	: CM_ProductAttributeCode;
	prodAttr		: CM_ProductAttr;
	num : Integer;
	tmpTable : CM_DataTable;
	idx, row, numRows : Integer;

begin
	tmpTable := self.tblCodeData;
	prodAttr := self.myProductAttr;
	row := self.tblCodeData.fixedRows + 1;
	numRows := self.tblCodeData.rows;
	
	if prodAttr = null then
		return true;
	endif;
	
	foreach idx in num to numRows do
		prodAttrCode := tmpTable.accessRow(idx).itemObject.CM_ProductAttributeCode;	
		if prodAttrCode &lt;&gt; null then // is self
			if prodAttrCode.code = _code then
			// may be self so continue
				app.msgBox('A code with this value has already exsists','Duplicate code', 0);
	//			self.tblEntCode.setFocus();
	//			self.tblEntCode.goToRowByName(ETRow_EntCode);
				return true;
				break;
			endif;
		endif;
	endforeach;
		
	return false;
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCmbCloneAttr" id="7cfb4068-0f5b-49da-9067-64dfe1651c08">
        <source>loadCmbCloneAttr();
// ---------------------------------------------------------------------------
// Created:     11 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	cargoType	: CM_CargoType;
	pro			: CM_Product;
	prodAttrStr	: String;
	prodAttr	: CM_ProductAttr;
	attrCmb		: CMUI_ComboBox;
	idx			: Integer;
	entRow		: EntTableRow;
	entDef		: EntTableDef;
begin
	pro := self.cmbCloneProduct.myObject.CM_Product;
	if pro = null then
		return;
	endif;
	entDef := app.myController.getEntTableDef(ETDef_AllAttributes);
	
	attrCmb := self.cmbCloneAttr;
	attrCmb.clear();
	cargoType := pro.myCargoType;
	
	foreach entRow in entDef.allEntTableRows do
		if cargoType.allAttributesOnProduct.includes(entRow.name) then
		// This is the new one for after 7.4.1 release	
		//if cargoType.getAttributeValue(entRow.name).Boolean then
			prodAttr := pro.getProdAttrFromName(entRow.name);
			if prodAttr.validationType = CM_ProductAttr.ValidationType_Codes then
				idx := attrCmb.addItem(prodAttr.displayName);
				attrCmb.itemObject[idx] := prodAttr;
			endif;
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
