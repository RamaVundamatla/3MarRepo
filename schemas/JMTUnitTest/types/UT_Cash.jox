    <JadeMethod name="tranMapLoadCashSAL52163" id="95f23dd6-696a-4d48-9536-a1ea24f9c03c">
        <source>tranMapLoadCashSAL52163();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Oct 2021 navma1 ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements

*/
constants
	UT_ILT08Narration	: String = "UT_ILT08 Line1 - Cash be used to Test change Request 52163 SAL - Unicode Arabic Support Business Requirements 52001 SAL - SD Unicode Database Requirements - Arabic Support v_0.2.52001 SAL - SD-Unicode";
	UT_ILT09Narration 	: String = "UT_ILT09 Line2 - Cash be used to Test change Request 52163 SAL - Unicode Arabic Support Business Requirements 52001 SAL - SD Unicode Database Requirements - Arabic Support v_0.2.52001 SAL - SD-Unicode";
	UT_ILT10Narration 	: String = "UT_ILT10 Line3 - Cash be used to Test change Request 52163 SAL - Unicode Arabic Support Business Requirements 52001 SAL - SD Unicode Database Requirements - Arabic Support v_0.2.52001 SAL - SD-Unicode";
	UT_ILT11Narration 	: String = "UT_ILT10 Line4 - Cash be used to Test change Request 52163 SAL - Unicode Arabic Support Business Requirements 52001 SAL - SD Unicode Database Requirements - Arabic Support v_0.2.52001 SAL - SD-Unicode";

vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin

	fileName := "UTSAL52163";
	mapName := "UTSAL52163";

	
		fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' 				&amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' 		&amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' 			&amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' 				&amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Released - Road,,(Default),(Default) ›,(Default),All,'				&amp; UT_ILT09Narration  &amp; CrLf &amp; 
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Received,,(Default),(Default) ›,(Default),All,'						&amp; UT_ILT08Narration  &amp; CrLf &amp; 
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Storage,,(Default),CCT06 Days Since Receival »,0 to 5,All,'			&amp; UT_ILT10Narration  &amp; CrLf &amp; 
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Storage,,(Default),CCT06 Days Since Receival »,6 to MAX,All,'		&amp; UT_ILT11Narration  &amp; CrLf &amp; 
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Washed,,(Default),(Default) ›,(Default),All,'						&amp; UT_ILT09Narration  &amp; CrLf &amp; 
					'Cargo,'&amp;mapName&amp;',CONT| ISO Container,(Default),(Default),Import,FCL,(Default),(Move),Yard -&gt; Yard,(Default),(Default) ›,(Default),All,'			&amp; UT_ILT09Narration  ; 
					
					
	// DELETE TRAN MAP
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
 	if cargoMap &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(cargoMap, app.myPassport);
	endif;
	
	// CREATE TRAN MAP
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog

end;</source>
    </JadeMethod>
