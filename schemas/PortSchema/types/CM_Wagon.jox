    <JadeMethod name="getOperatorCode" id="53f0004d-08a6-46c9-95cb-4c6c59d95875">
        <source>getOperatorCode():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning
02-May-2023 navtnr20	Bug 57780: EUP -FR 53740 | Wagon Track Planning - Multiple Values
*/

vars
	ti : CM_TrackedItem;
	cont : CM_WagonController;
	data : String;
	code : String;
begin
	foreach cont in self.allLocationsControllers do
		foreach ti in cont.allTrackedItems do
			//if ti.myOperator &lt;&gt; null then
			//	return ti.myOperator.code;		// Start navtnr20 02-05-2023 Bug : 57780
			code := ti.myOperator.code;
			if code &lt;&gt; null then
				/*
				if data.pos(code,1) = 0 then
					if data = null then
						data := code;
					else
						data := data &amp; ", " &amp; code;
					endif;
				endif;		// End navtnr20 02-05-2023 Bug : 57780
				*/
				
				data.addStringToList(code, ", ");//04/04/2025	navkc1 JIRA Story MTN-33940
			endif;
		endforeach;
	endforeach;
	return data;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperatorDesc" id="12f15803-7f3f-4fbc-aef3-8a22ad7ab181">
        <source>getOperatorDesc():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02-May-2023 navtnr20	Bug 57780: EUP -FR 53740 | Wagon Track Planning - Multiple Values
*/

vars
	ti : CM_TrackedItem;
	cont : CM_WagonController;
	data : String;
	code : String;
begin
	foreach cont in self.allLocationsControllers do
		foreach ti in cont.allTrackedItems do
			code := ti.myOperator.description;
			if code &lt;&gt; null then
				/*
				if data.pos(code,1) = 0 then
					if data = null then
						data := code;
					else
						data := data &amp; ", " &amp; code;
					endif;
				endif;
				*/
				
				data.addStringToList(code, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			endif;
		endforeach;
	endforeach;
	return data;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPickupTasks" id="7e4ed7d1-42e8-4c29-ac56-ddada6d2ca1f">
        <source>getPickupTasks(arbiter: CM_RTQueueArbiter input);
/*
	method that returns the work required to pick up a TI.
*/
vars
	task	: CM_RTQueueTask;
begin
	create task;
	//parent will be set higher up.

	if arbiter.job.isKindOf(CM_YardInternalJob) then
		if arbiter.job.CM_YardInternalJob.isSwapJob then
			//SwapJob! Bad thing here!
			return;
		endif;
	endif;
	
	task.setDetails(	arbiter.ti.getPrimaryLocation(REAL_MODE),
						arbiter.ti.getPrimaryLocation(QUEUE_MODE),
						TASK_UNACTIONED,
						TASK_PICKUP,
						arbiter.ti);
	
	arbiter.entry.addTask(task);

end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="3f773f0c-2e6b-4e3f-b309-c321d65e4066">
        <source>getPicture() : Binary;
// ---------------------------------------------------------------------------
// Created:     04 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars


	thePicture : Binary;
begin
	if not self.getTerminal().getConfig(ShowCargoPicture).Boolean then // PAR 21182
		return null;
	endif;

	if self.isBoxcar then
		if app.isSpecial then
			thePicture := app.myRoot.getConfig(PicBoxcarJMT).Binary;
		elseif self.isBulkGraphic then
			thePicture := app.myRoot.getConfig(PicBulkCar).Binary; // ### TFS 50421 17SEP2021 NAVAB1
		
		elseif self.isTransporterGraphic then
			thePicture := app.myRoot.getConfig(PicTransportCar).Binary; // ### TFS 50421 17SEP2021 NAVAB1
		
		else
			thePicture := app.myRoot.getConfig(PicBoxcar).Binary;
		endif;
	elseif self.isSkeletonCar() then
		thePicture := app.myRoot.getConfig(PicSkeletoncarJMT).Binary;
	elseif self.isWellcarVisit() then
		thePicture := app.myRoot.getConfig(PicWellcarJMT).Binary;
	else
		thePicture := app.myRoot.getConfig(PicWagon).Binary;
	endif;
	return thePicture;

epilog

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getPlannedLocation" id="c2dc8c13-069d-461c-a790-89e9f813fbbf">
