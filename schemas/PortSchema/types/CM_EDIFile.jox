    <JadeMethod name="setFileStatus" id="c7eb24ec-db44-4a10-a564-35793c7ecc0f">
        <updating/>
        <source>setFileStatus(_newStatus: Integer) updating;
//----------------------------------------------------------------
//	Created:	30 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpEdiData		: CM_EDIData;
begin

	self.fileStatus := _newStatus;

	if self.fileStatus = CM_EDIFile.EDI_STATUS_LOADED_ERRORS then
		tmpEdiData := self.ediData;
//		if tmpEdiData &lt;&gt; null  // cnwrs1 Par 24207 ccms 1117 11 May 2010
//		and tmpEdiData.singleDataFile then
//			self.unloadErrors();
//		else
		self.ediData := null; //undo reference else delete ediData will remove ediFile
		tmpEdiData.unload;
		delete tmpEdiData;
//		endif;	
	else
		if self.ediData &lt;&gt; null then
			//set to same
			self.ediData.setStatus(_newStatus);
		endif;
	endif;


end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="48694509-fb89-483d-b74c-5bf6d6d3f39f">
        <updating/>
        <source>setForCreate(
	_fileName		: String;
	_fileCreatedTs	: TimeStamp;
	_status			: Integer;
	_ediConfig		: CM_EDIConfig;
	_fileType		: CM_EDIFileType;
	_ediClientRef	: String;					// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link
	_messageType	: String;					// cnwrl1 25/09/2009 PAR 20320 - MES 1011 New Messina Messages
	_message		: String ) updating;		// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jan 2003 cnwdvb1 Initial creation
02 Dec 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
//12 Jan 2014	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 12 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
*/
vars
	ediTrans		: CMIF_EdiTransformWrap;
	transformedMsg	: String;
	messageType		: String;
	
begin
	self.computerName	:= app.computerName;
	self.fileName		:= _fileName;
	self.fileCreatedTs	:= _fileCreatedTs;
//	self.fileNameShort	:= _fileName[1:30];
	self.fileStatus		:= _status;
	self.ediConfig		:= _ediConfig;
	self.myEDIFileType	:= _fileType;
	
	messageType := _messageType;
	
	// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link - start of coding
	// if the _message is not null attempt to break it up into lines of data and load into self.allCompressedFileLines
	if _message &lt;&gt; null then
	
		// PAR #34713 - Call out to .NET EDI
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
//		create ediTrans transient;
//		if ediTrans.transformMessage(null, null, null, _message.String, transformedMsg) then
//			self.setOriginalFileDataString(_message.String);
//			self.loadRawData(transformedMsg.String);
//			messageType := System_EDIFileType;
//		else
			self.loadRawData(_message.String);
//		endif;
	endif;
	self.setEdiClientRef( _ediClientRef );
	self.setEdiMessageType( messageType );				// cnwrl1 02/03/2010 PAR 22677
	// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link - end of coding
	
epilog
	delete ediTrans;
	
end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_fileCreatedTs" type="TimeStamp"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig"/>
        <Parameter name="_fileType" type="CM_EDIFileType"/>
        <Parameter name="_ediClientRef" type="String"/>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
