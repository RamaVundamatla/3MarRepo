    <JadeMethod name="gio01_showInOutSheets" id="988d0daa-2ba9-4729-8c8b-39ddc2ad4cbe">
        <updating/>
        <source>gio01_showInOutSheets():Integer updating;

vars
	txt:TextBox;
	i:Integer;
begin
	if     loopCount mod 6 = 0    then containersIn:=1; containersOut:=0;
	elseif loopCount mod 6 = 1    then containersIn:=2; containersOut:=0;
	elseif loopCount mod 6 = 2    then containersIn:=1; containersOut:=1;
	elseif loopCount mod 6 = 3    then containersIn:=2; containersOut:=2;
	elseif loopCount mod 6 = 4    then containersIn:=0; containersOut:=1;
	elseif loopCount mod 6 = 5    then containersIn:=0; containersOut:=2;
	endif;
	/*
	if     loopCount mod 3 = 0    then containersIn:=2; containersOut:=0;
	elseif loopCount mod 3 = 1    then containersIn:=1; containersOut:=1;
	elseif loopCount mod 3 = 2    then containersIn:=0; containersOut:=2;
	endif;
	*/
	if allTrackedItems.size &lt;= 4 then containersIn:=2; containersOut:=0; endif;
	app.logMessage(method.qualifiedName&amp;" dropping off "&amp;containersIn.String&amp;", picking up "&amp;containersOut.String&amp;", allTrackedItems "&amp;allTrackedItems.size.String);

	allGateInOutFormSheets.clear;
	txt:=myGateInOutForm.getPropertyValue("txtNewItem").TextBox;

	foreach i in 1 to containersIn do
		txt.text:=myGH.selectRandomBookingRef;
		txt.lostFocus(txt);  // shows In sheet, populates it from the booking ref
	endforeach;
	
	foreach i in 1 to containersOut do
		myGateInOutForm.getPropertyValue('btnRelease').Button.click(null);  // shows Out sheet
	endforeach;

	return 0;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="gio03_enterGateInDetails" id="284545d1-53b4-4ca3-baff-7a4bf9f53ee3">
        <updating/>
        <source>gio03_enterGateInDetails():Integer updating;
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	cmb		: CMUI_ComboCarrier;
	ti		: CM_TrackedItem;
	id,cid	: String;
	sheet	: CMUI_Sheet;
	i:Integer;
begin
	id:=app.sequenceId.String&amp;'X'&amp;app.actualTimeServer.time.format("HHmmss");	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	setEntryTableValue(myGateInOutForm, 'tblCommon', ETRow_RegNumber, id);

	cmb:=myGateInOutForm.getPropertyValue('cmbCarrier').CMUI_ComboCarrier;
	cmb.setObject(myGH.selectRandomCarrier);
	setEntryTableValue(myGateInOutForm, 'tblCommon', ETRow_CarrierCode, cmb.text);

	zGetSheetsOnGateForm;  // places sheets into allGateInOutFormSheets in order of creation - In then Out
	foreach i in 1 to containersIn do
		sheet:=allGateInOutFormSheets[i].CMUI_Sheet;
		cid:='C'&amp;id&amp;(i+64).Character;
		app.logMessage(method.qualifiedName&amp;" truck "&amp;id&amp;" to drop off container "&amp;cid);
		zSetMainExtraValueOnGateForm(ETRow_IdTextBox, cid, sheet);
		zSetMainExtraValueOnGateForm(ETRow_WeightTotal, 3501, sheet);
		zSetMainExtraValueOnGateForm(ETRow_CarriageTempC, NULL_TEMPERATURE, sheet);
		zSetMainExtraValueOnGateForm(ETRow_VoyageCode, app.getMyTerminal.getNullVoyage.code, sheet);
		
	endforeach;
		
	foreach i in 1 to containersOut do
		sheet:=allGateInOutFormSheets[containersIn+i].CMUI_Sheet;
		ti:=allTrackedItems.first;
		app.logMessage(method.qualifiedName&amp;" truck "&amp;id&amp;" to pick up container "&amp;ti.id);
		zSetMainExtraValueOnGateForm(ETRow_IdCombo, ti.id, sheet);
		zSetMainExtraValueOnGateForm(ETRow_DeliveryReleaseNumber, ti.id, sheet);
		allTrackedItems.remove(ti);
	endforeach;
	
	// btnSaveBase_click might get a lock exception, so we wait up to 5 seconds and try again
	myRFIDTagForm:=null;
	while myRFIDTagForm = null do :gotform
		app.logMessage(method.qualifiedName &amp; '-clicking save button on the GateInOut screen.');	
		myGateInOutForm.btnSaveBase_click(myGateInOutForm.btnSaveBase);
		
		foreach i in 1 to 10 do
			if pauseAndStop(500) then
				app.logMessage(method.qualifiedName &amp; '-pauseAndStop recieved a stop - returning 0.');	
				return 0;
			endif;
			
			app.logMessage(method.qualifiedName &amp; '-pause #' &amp; i.String &amp; ' complete. Looking for RFID tag form...');	
			self.myRFIDTagForm := app.getForm(CMUI_RFIDTag.name).CMUI_RFIDTag;
			if myRFIDTagForm &lt;&gt; null then
				app.logMessage(method.qualifiedName &amp; '-myRFIDTagForm found (' &amp; self.myRFIDTagForm.String &amp; ')');
				break gotform;
			else
//				app.logMessage(method.qualifiedName &amp; '-myRFIDTagForm was not found! (' &amp; self.myRFIDTagForm.String &amp; ')');
			endif;
		endforeach;
		break;
	endwhile;
	
	return 0;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="gio04_rfidTagSwipeGateIn" id="df0bfd1f-ad51-4a38-8813-39fa4e42ac46">
        <updating/>
        <source>gio04_rfidTagSwipeGateIn() updating;

begin
	myRFIDTag:=myGH.selectRandomRFIDTag;
	app.logMessage(method.qualifiedName &amp; ' swiping rfid tag ' &amp; myRFIDTag.serialNumber);
	app.logMessage(method.qualifiedName &amp; ' RFIDTagForm at this point = ' &amp; self.myRFIDTagForm.String);
	
	myRFIDTagReaderPC.doProcessBinary((CM_RFIDAccess7CERead.Msg_Begin_Delimiter &amp; myRFIDTag.serialNumber).Binary);
end;
</source>
    </JadeMethod>
    <JadeMethod name="gio05_rfidTagFormProceed" id="7cbbe742-a6d4-4280-8bdd-31c1e7dfab2c">
        <updating/>
        <source>gio05_rfidTagFormProceed() updating;

begin
	if myRFIDTagForm = null then
		app.logMessage(method.qualifiedName &amp; ' myRFIDTagForm = null, skipping');
	else
		app.logMessage(method.qualifiedName &amp; ' proceding');
	//	myRFIDTagForm:=app.getForm(CMUI_RFIDTag.name).CMUI_RFIDTag;  //moved to gio03
		myRFIDTagForm.btnProceed_click(myRFIDTagForm.btnProceed);
		if containersIn &gt; 0 then
			myRFIDTag.myRoadJob.allReceiveTrackedItems.copy(allTrackedItems);
		endif;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="gio06_rfidTagSwipeGateLaneIn" id="e6f1474a-b283-4a25-9760-081052b761f0">
        <source>gio06_rfidTagSwipeGateLaneIn();

begin
	app.logMessage(method.qualifiedName &amp; ' entering gate lane using rfid tag ' &amp; myRFIDTag.serialNumber);
	myRFIDTagReaderGLIn.doProcessBinary((CM_RFIDAccess7CERead.Msg_Begin_Delimiter &amp; myRFIDTag.serialNumber).Binary);
end;
</source>
    </JadeMethod>
    <JadeMethod name="gio07_handHeldGateLaneIn" id="807cf4e3-6182-4ed9-b164-4e8966397ee6">
        <source>gio07_handHeldGateLaneIn():Integer;

vars
	wle				: CM_WorkListEntry;
	wleArray		: CM_WLEArray;
	lc				: CM_LocationsController;
	laneController	: CM_RTGLaneController;
	roadJob			: CM_RoadJob;
begin
	roadJob := self.myRFIDTag.myRoadJob;
	create wleArray transient;
	roadJob.getAllWLEs(wleArray);
	
	foreach wle in wleArray where wle.status &lt;&gt; WLE_COMPLETED and wle.isReceipt do
		lc := wle.getLocationForMode(QUEUE_MODE);
		
		if CM_RTGController.hasInstance(lc) then
			lc := lc.CM_RTGController.getMyLaneController();
		endif;
		
		if lc &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	if lc = null then
		lc := roadJob.myJobSheet.CM_RoadJobSheet.myInTerminalUnknownLC;
	endif;
	
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveVehicle(roadJob.myVehicle, lc.CM_YardController, app.myPassport);
	assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	
	return 0;
epilog
	delete wleArray;
end;

</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="gio08_rtgContainerInTake" id="5fa9532f-1474-48a5-ad19-77a955c58d4c">
        <updating/>
        <source>gio08_rtgContainerInTake() updating;
//addapted from MobileServerSchema::VehicleMountedAgent::doAcceptTask
vars
	rtQueueTask 		: CM_RTQueueTask;
	rtQueueEntry 		: CM_RTQueueEntry;
	passport			: CM_Passport;
	taskStatus			: Integer;
	ti					: CM_TrackedItem;
begin
	if myRFIDTag = null or myRFIDTag.myRoadJob = null then
		app.logMessage(method.qualifiedName&amp;' error, null reference in '&amp;myRFIDTag.String);
	else
		passport := app.myPassport;
		taskStatus := TASK_ACCEPTED;
		
		
		foreach rtQueueEntry in myRFIDTag.myRoadJob.allEntries do
			if rtQueueEntry.status = ENTRY_SYSTEM_HELD then	//22 Apr 2015	NDL	Par 36014
				beginTransaction;
				rtQueueEntry.setPropertyValue('status', ENTRY_UNACTIONED);
				foreach rtQueueTask in rtQueueEntry.allTasks do
					if rtQueueTask.status = TASK_SYS_HELD then	//22 Apr 2015	NDL	Par 36014
						rtQueueTask.setPropertyValue('status', TASK_UNACTIONED);
					endif;
				endforeach;
				commitTransaction;
			endif;
			
			rtQueueTask	:= rtQueueEntry.allTasks.first;
			
			beginTransaction;
			//myUtlRT.sendMsgWithIOParams('utlChangeTaskStatus', rtQueueTask, myRTGCrane, taskStatus, passport);
			commitTransaction;
		endforeach;
	endif;
end;
</source>
    </JadeMethod>
