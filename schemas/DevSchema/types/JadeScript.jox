    <JadeMethod name="rh_testReferenceCode" id="509d90a1-0138-407d-bbb6-f45bdd017166">
        <source>rh_testReferenceCode(_term : CM_Terminal; _vessel : CM_Vessel) : String;
/*
getVoyageCode (_term : CM_Terminal; _vessel : CM_Vessel) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2018	jlgrh7	Initial creation

*/

vars
	root                : CM_Root;
	currentTerm,rootTerminal            : CM_Terminal;
	uniqueCode : Integer;
	minimum, maximum : Integer;
	prefix, sysVoyCode : String;

	existingPermVoyage : CM_Voyage;
	archivedVoyage : CM_Voyage;
	bigEachTerminaVoyage,bigArchivedVoyage : CM_Voyage;
	archivedExtCode : Integer;
	bigEachExtCode : Integer;
	biggestExtCode : Integer;
	reference : Integer;
	isFound : Boolean;
begin

	prefix := "P";
	minimum := 500000;
	maximum := 799999;
	biggestExtCode := 0;	
	reference := HookType_VoyageCode; 
	currentTerm := _term;
	app.initialize;
    
 //  root := CM_Root.firstInstance;
	
	//currentTerm :=app.myRoot.allTerminals['T01'];
	
	if currentTerm.allVoyagesArchived.size &gt; 0 then
		foreach archivedVoyage in currentTerm.allVoyagesArchived  do				//get biggest external code form the passing terminal's archived voayges
			if archivedVoyage &lt;&gt; null and archivedVoyage.voyageCodeExternal &lt;&gt; null  and
				archivedVoyage.voyageCodeExternal[2:end].Integer &gt; minimum and
				archivedVoyage.voyageCodeExternal[2:end].Integer &lt; maximum then
					archivedExtCode := archivedVoyage.voyageCodeExternal[2:end].Integer ;
			endif;
			if archivedVoyage.voyageCodeExternal[2:end].Integer= minimum then
				isFound := true;
			endif;
			if biggestExtCode &lt; archivedExtCode then
				biggestExtCode := archivedExtCode;
			endif;
		endforeach;
	endif;
	
	foreach rootTerminal in app.myRoot.allTerminals do																				// add up all existingvoyages from all terminals
		if rootTerminal &lt;&gt; null and  rootTerminal.allVoyagesByExternalCode.size &gt; 0 then
			if  rootTerminal.allVoyagesByExternalCode[prefix&amp;minimum.String.padLeadingZeros(6)] &lt;&gt; null then
				isFound := true;
			endif;
			bigEachTerminaVoyage := rootTerminal.allVoyagesByExternalCode.getAtKeyLss(prefix&amp;maximum.String.padLeadingZeros(6)).CM_Voyage;
			if bigEachTerminaVoyage &lt;&gt; null and bigEachTerminaVoyage.voyageCodeExternal &lt;&gt; null then
				bigEachExtCode := bigEachTerminaVoyage.voyageCodeExternal[2:end].Integer;
			endif;
			if bigEachExtCode &gt; minimum then
				if biggestExtCode &lt; bigEachExtCode then
					biggestExtCode := bigEachExtCode;
				endif;
			else
				continue;
			endif;
		endif;	
	endforeach;
	
	if biggestExtCode &lt;&gt; 0 then
			sysVoyCode := prefix &amp; (biggestExtCode+1).String.padLeadingZeros(6);
			
	elseif isFound then
			sysVoyCode := prefix &amp; (minimum+1).String.padLeadingZeros(6);
		
	else	
			sysVoyCode := prefix &amp; (minimum).String.padLeadingZeros(6);
	endif;

	return sysVoyCode;


epilog
	
end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="rh_testRoadExitCargo" id="a650fa9c-932a-4ca9-9a44-5dc1f1e0b2d8">
        <source>rh_testRoadExitCargo();

vars
	aTI : CM_TrackedItem;
	aTerm : CM_Terminal;
	lFile	: File;
begin
beginTransientTransaction;
      create lFile transient;
 	lFile.usePresentationFileSystem := true; // only if not shared transient;
    lFile.fileName := "c:\temp\AKB01.txt";
    lFile.open;

	foreach aTerm in CM_Root.firstInstance.allTerminals discreteLock do
		foreach aTI in aTerm.allOnsiteTIsByCargoTypeId do
			if aTI.isChild then
				continue;
			endif;
			if aTI.isOffSite then
				lFile.writeLine( aTI.cargoBOLTypeDescr &amp; "," &amp; aTI.String &amp; ", " &amp; aTI.id &amp; ", " &amp; aTI.myPrimaryActualLocation.String &amp; ", " &amp; aTI.locationId);
				beginTransaction;
					aTI.changeState(TI_STATE_OFFSITE, null);
				commitTransaction;
			endif;
		endforeach;
	endforeach;
	lFile.close;
    delete lFile;
commitTransientTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="rh_testStorageDetailDesc" id="2d7c9f16-9dab-4285-9726-fa684528941d">
        <source>rh_testStorageDetailDesc();
/*

Purpose:			

Parameters:			

