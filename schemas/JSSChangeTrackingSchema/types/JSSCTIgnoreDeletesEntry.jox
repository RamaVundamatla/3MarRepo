    <JadeMethod name="ignoreThisDelete" id="9bc0b4c6-f690-464f-b0b4-48240ee7a853">
        <source>ignoreThisDelete(pInstance: Integer): Boolean;
/*
*/
begin
	//	check if the instance is within the range
	if pInstance &lt; self.instanceStart or pInstance &gt; self.instanceEnd then
		return (false);
	endif;
	//	it is within range (inclusive)
	return (true);
end;</source>
        <Parameter name="pInstance" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
