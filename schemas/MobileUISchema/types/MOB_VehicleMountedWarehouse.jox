    <JadeMethod name="clearTableData" id="67dea6ff-dfc8-4e48-b944-63801d57f82c">
        <source>clearTableData(_table : Table input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwer1	Initial creation

*/

vars
	row,col : Integer;
	headerIsTopRow : Boolean;
begin
	
	
	self.if_getTableOrientation(_table,headerIsTopRow);
	
	if headerIsTopRow then
		row:=_table.fixedRows + 1;
		while row &lt;= _table.rows do
			_table.deleteRow(row);
		endwhile;
		_table.rows:=_table.fixedRows;
	else
		col:=2;
		while col &lt;= _table.columns do
			_table.deleteColumn(col);
		endwhile;
		_table.columns:=1;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
