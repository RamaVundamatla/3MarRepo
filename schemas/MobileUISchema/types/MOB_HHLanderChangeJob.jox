    <JadeMethod name="doClickSelect" id="4d574116-084e-4d78-bb21-23a4b400bba8">
        <source>doClickSelect():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2012	cnwndl1	Initial creation	Par 30842

*/

vars
	newVoyageJob : CM_VoyageJob;
	wle : CM_WorkListEntry;
	oldVoyageJob : CM_VoyageJob;
	task				: CM_RTQueueTask;
	aEntry				: CM_RTQueueEntry;
	errMess				: String;
begin


	newVoyageJob := self.tblJobs.accessRow( self.tblJobs.row ).itemObject.CM_VoyageJob;

	if newVoyageJob = null then
		return false;
	endif;
	
	wle := self.myTrackedItem.getVoyageWLEUnactioned( true );
	if wle &lt;&gt; null then
		oldVoyageJob := wle.job.CM_VoyageJob;
		aEntry := wle.allRTQueueEntries.last;	
		if aEntry &lt;&gt; null then
			task := aEntry.allTasks.last;	
		endif;
	endif;
				
	app.myTrxUA.trxUpdateTaskSwitchJobs( task,wle, oldVoyageJob,newVoyageJob, app.myPassport); //cnwrd1 34038
	
	if not app.myPassport.trxCompletedOK then
	//	errMess := app.myPassport.getErrorsAsString;
		errMess := app.myPassport.getAllErrorsWarningsAsString;	// 10 Aug 2012	NDL	Par 29885
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif;

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="d8175c44-fc55-4df4-bc05-d695fe133db9">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	height : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	height := self.clientHeight - top - self.getCMDHeight();
	
	if _initialSetup then
		self.tblJobs.setAndIncrementTabIndex( tabIndex );
		self.tblJobs.visible := true;
	endif;
	self.tblJobs.move(	stdLeft,
						top,
						stdWidth,
						height );
						
	self.tblJobs.cnAdjustColumnWidths();

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
