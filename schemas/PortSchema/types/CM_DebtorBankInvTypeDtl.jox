    <JadeMethod name="setProxy" id="30062cd0-9d12-4aef-a37a-097678fadd4c">
        <updating/>
        <source>setProxy(_bank : CM_Bank; _debtor : CM_Debtor; _period : CM_FinancialPeriodEnd; _type : CM_InvoiceDesc) updating;

vars

begin
	self.myDebtor := _debtor;
	self.myFinancialPeriodEnd := _period;
	self.myInvoiceType := _type;
	self.myBank	:= _bank;
end;
</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_period" type="CM_FinancialPeriodEnd"/>
        <Parameter name="_type" type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="448c2024-e778-4dbf-a60d-c7d7f3d54b01">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_DebtorBankInvTypeDtl::myChildQuantityMap.name or 
		propName = CM_DebtorBankInvTypeDtl::myFinancialPeriodEnd.name or
		propName = CM_DebtorBankInvTypeDtl::myInvoiceType.name or 
		propName = CM_DebtorBankInvTypeDtl::myBank.name or 
		propName = CM_DebtorBankInvTypeDtl::myDebtor.name  
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
	


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="d8838ddd-eae4-4678-9c85-5c5829b8828f">
        <source>validateForCreate();

vars
	aDebtor : CM_Debtor; 
	aType : CM_InvoiceDesc;
	aPeriod : CM_FinancialPeriodEnd;
	aMap : CM_DebtorBankInvTypeDtl;
	blnReturn : Boolean;
begin
	aDebtor := self.myDebtor;
	aPeriod := self.myFinancialPeriodEnd;
	aType := self.myInvoiceType;
	if aDebtor = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'debtor', ETRow_Debtor, null);
		app.raiseCMException(Input_required_field_debtor, ETRow_Debtor, null); // cnwdb2	PAR 35364
		blnReturn := true;
	endif;
	if aPeriod = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'period', ETRow_Charges, null);
		app.raiseCMException(Input_required_field_period, ETRow_Charges, null); // cnwdb2	PAR 35364
		blnReturn := true;
	endif;	
	if aType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'invoice type', ETRow_InvoiceType, null);
		app.raiseCMException(Input_required_field_invtype, ETRow_InvoiceType, null); // cnwdb2	PAR 35364
		blnReturn := true;
	endif;

	if blnReturn then
		return;
	endif;

	aMap := self.myBank.allDebtorBankInvTypeDtls[aDebtor, aType];
	if aMap &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE, "Mapping", 
				"A mapping for " &amp; aDebtor.name &amp; "/" &amp; aType.description &amp; " already exists.", null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="9e348b84-4083-428c-968c-31838dd27146">
        <source>validateForDelete();

vars

begin
	app.raiseCMWarning2(CONFIRM_REMOVE, "Financial Period Mapping", self.getDescription(), null, null, self);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="dd9061ba-dcae-487b-8107-20ac19a21afd">
        <source>validateForUpdate();

vars
	
begin
	if self.myFinancialPeriodEnd = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'period', ETRow_Charges, null);
		app.raiseCMException(Input_required_field_period, ETRow_Charges, null); // cnwdb2	PAR 35364
	endif;	
end;</source>
    </JadeMethod>
