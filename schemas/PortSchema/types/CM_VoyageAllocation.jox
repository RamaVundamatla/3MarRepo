    <JadeMethod name="getDefaultDescription" id="e0d101a2-91cf-483e-b7b8-fc71ee831ad6">
        <source>getDefaultDescription() : String;
// ---------------------------------------------------------------------------
// Created:     08 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	port : CM_Port;
	criteria : CM_YACriteria;	
	imex : CM_IMEXStatus;
	type : CM_CargoType;
	tmpDesc : String;
	iso : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;
	term : CM_Terminal;
begin
	
	criteria := self.getCriteriaOfTypeValue(YACriteriaType_ImexStatus);
	if criteria &lt;&gt; null then
		imex := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_IMEXStatus;
		if imex &lt;&gt; null then
			tmpDesc := imex.abbreviation[1];
		endif;
	endif;
	
	term := getTerminal();
	
	if term &lt;&gt; null
	and term.getConfig(ReportGrpDescriptionType).Integer = RepGrpDscType_Attributes then // PAR 34184
		port := getDischargePort();
		if port &lt;&gt; null then
			return tmpDesc &amp; " " &amp; port.code &amp; " " &amp; self.getVoyageAllocationGroupDesc();
		else
			return tmpDesc &amp; " " &amp; self.getVoyageAllocationGroupDesc();
		endif;
	endif;

	
	// PAR 28581 the desc was hand crafted, now is auto and uses all attributes.
	foreach criteria in self.allCriteriaByType discreteLock do
	
		if criteria.myYACriteriaType.type = YACriteriaType_ImexStatus then
			continue;
		endif;
		tmpDesc := tmpDesc &amp; " " &amp; criteria.myYACriteriaType.getDataDisplay(criteria.myYAData);
	endforeach;
	
	
return tmpDesc;	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
