<Class name="MallardDuck" id="ba4ef7a8-1afe-437d-8840-db04e19f732f">
    <superclass name="Duck"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <JadeMethod name="create" id="51270f61-c1b1-4b46-920b-873593f663ec">
        <updating/>
        <source>create() updating;
//25 August 2009	cnwdw1	
//
vars
begin
	write "I am a Mallard Duck";
	create self.flyer as FlyWithWings transient;
	self.flyBehaviour := self.flyer.FlyWithWings; 
	create self.quackBehaviour as Quack transient;
end;</source>
    </JadeMethod>
</Class>
