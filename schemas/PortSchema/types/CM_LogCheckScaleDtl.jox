    <JadeMethod name="finalizeProxySettings" id="c009ee2d-1b5d-456d-a208-9038194d0b4e">
        <updating/>
        <source>finalizeProxySettings(_log : CM_Log) updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     This is called to set the log related fields from inside the trx.
//				This is done so that if the validation neccessary to aquire the real
//				log raises an exception, it can be continued by BGP.		 
// ----------   ----------  --------------------------------------------------
vars
	
begin
	if _log &lt;&gt; null then
		self.logLocationId			:= _log.getPrimaryLocationId(REAL_MODE);
		self.scalerCode				:= _log.scalerCode;
	
		self.logConditionCode 		:= _log.conditionCode;
		self.operatorCode 			:= _log.operatorCode;
		self.speciesCode 			:= _log.speciesCode;
		self.gradeCode 				:= _log.gradeCode;
		self.typeCode 				:= _log.typeCode;
		self.treatmentCode 			:= _log.treatmentCode;
		self.lengthCode 			:= _log.lengthCode;
		self.logSEDMin 				:= _log.sedMin;
		self.logSEDMax 				:= _log.sedMax;
		self.logSEDMean 			:= _log.sedMean;
		self.logJASVolume 			:= _log.getMyTotalVolume;
	else
		self.logLocationId			:= null;
		self.scalerCode				:= null;
	
		self.logConditionCode 		:= null;
		self.operatorCode 			:= null;
		self.speciesCode 			:= null;
		self.gradeCode 				:= null;
		self.typeCode 				:= null;
		self.treatmentCode 			:= null;
		self.lengthCode 			:= null;
		self.logSEDMin 				:= null;
		self.logSEDMax 				:= null;
		self.logSEDMean 			:= null;
		self.logJASVolume 			:= null;			
	endif;	
	
	self.setCalcAttributes();	
end;</source>
        <Parameter name="_log" type="CM_Log"/>
    </JadeMethod>
    <JadeMethod name="findLog" id="e4d83276-1120-4596-9b0c-cba84081581a">
        <source>findLog(_logId : String) : CM_Log;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	terminal		: CM_Terminal;
	log				: CM_Log;
begin
	terminal := app.myRoot.allTerminals[self.myCheckScaleHdr.terminalCode];
	
	if (_logId = null) or (terminal = null) then
		return null;
	endif;
	
	log := self.findLogOnTerminal(_logId, terminal);
	
	return log;
	
end;</source>
        <Parameter name="_logId" type="String"/>
        <ReturnType type="CM_Log"/>
    </JadeMethod>
    <JadeMethod name="findLogOnTerminal" id="e7b52b40-22a8-4489-8671-45458d53a3fc">
        <source>findLogOnTerminal(_logId : String; _terminal : CM_Terminal) : CM_Log protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	log					: CM_Log;

begin

	log := _terminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Log, _logId].CM_Log;
	if log &lt;&gt; null then
		return log;
	endif;
	
	log := _terminal.allOffsiteTIsByCargoTypeId[TI_CargoType_Log, _logId, null].CM_Log;
	if log &lt;&gt; null then
		return log;
	endif;

	log := _terminal.allNotifiedTIsByCargoTypeId[TI_CargoType_Log, _logId].CM_Log;
	
	return log;
end;</source>
        <access>protected</access>
        <Parameter name="_logId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_Log"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c3b74789-5d61-4fb7-b2e9-cb92110bac5a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_CalcJASVolDifference then
		return self.calcJASVolumeDifference.String;
	
	elseif _attrName = ETRow_LocationId then
		return self.logLocationId.String;
	
	elseif _attrName = ETRow_LogSpecies then
		return self.speciesCode;
	elseif _attrName = ETRow_LogGrade then
		return self.gradeCode;
	elseif _attrName = ETRow_LogType then
		return self.typeCode;
	elseif _attrName = ETRow_LogTreatment then
		return self.treatmentCode;
	elseif _attrName = ETRow_LogLength then
		return self.lengthCode;
	endif;
	
	return inheritMethod(_attrName, _short);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setCalcAttributes" id="da5cf4a1-80fc-46b9-af9c-8b6e18733d41">
        <updating/>
        <source>setCalcAttributes() protected, updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.calcSEDMean := global.calcSEDMean(self.checkSEDMin, self.checkSEDMax);
	self.calcSEDDifference := self.calcSEDMean - self.logSEDMean;

	self.calcJASVolume := global.calcJASVolume(self.calcSEDMean, self.lengthCode.Decimal);
	self.calcJASVolumeDifference := self.logJASVolume - self.calcJASVolume;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="905ab221-8d72-4525-b413-74aa08382f27">
        <updating/>
        <source>setForCreate(_pxyChkScaleDtl : CM_LogCheckScaleDtl; _parentChkScaleHdr : CM_LogCheckScaleHdr) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _parentChkScaleHdr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Real checkscaling parent is null');
		return;
	endif;
	
	self.index 				:= _pxyChkScaleDtl.index;
	self.myCheckScaleHdr 	:= _parentChkScaleHdr;
	
	self.setForUpdate(_pxyChkScaleDtl);

end;</source>
        <Parameter name="_pxyChkScaleDtl" type="CM_LogCheckScaleDtl"/>
        <Parameter name="_parentChkScaleHdr" type="CM_LogCheckScaleHdr"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d3033fe1-6c52-48cf-8bc8-579eaaf751e7">
        <updating/>
        <source>setForUpdate(_pxyChkScaleDtl : CM_LogCheckScaleDtl) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.logId 					:= _pxyChkScaleDtl.logId;
	self.logLocationId			:= _pxyChkScaleDtl.logLocationId;
	self.scalerCode				:= _pxyChkScaleDtl.scalerCode;
	self.checkConditionCode 	:= _pxyChkScaleDtl.checkConditionCode;
	self.checkSEDMin			:= _pxyChkScaleDtl.checkSEDMin;
	self.checkSEDMax	 		:= _pxyChkScaleDtl.checkSEDMax;

	self.logConditionCode 		:= _pxyChkScaleDtl.logConditionCode;
	self.operatorCode 			:= _pxyChkScaleDtl.operatorCode;
	self.speciesCode 			:= _pxyChkScaleDtl.speciesCode;
	self.gradeCode 				:= _pxyChkScaleDtl.gradeCode;
	self.typeCode 				:= _pxyChkScaleDtl.typeCode;
	self.treatmentCode 			:= _pxyChkScaleDtl.treatmentCode;
	self.lengthCode 			:= _pxyChkScaleDtl.lengthCode;
	
	self.logSEDMin 				:= _pxyChkScaleDtl.logSEDMin;
	self.logSEDMax 				:= _pxyChkScaleDtl.logSEDMax;
	self.logSEDMean 			:= _pxyChkScaleDtl.logSEDMean;
	self.logJASVolume 			:= _pxyChkScaleDtl.logJASVolume;

	self.calcSEDMean 			:= _pxyChkScaleDtl.calcSEDMean;
	self.calcSEDDifference 		:= _pxyChkScaleDtl.calcSEDDifference;
	self.calcJASVolume 			:= _pxyChkScaleDtl.calcJASVolume;
	self.calcJASVolumeDifference:= _pxyChkScaleDtl.calcJASVolumeDifference;
	

end;</source>
        <Parameter name="_pxyChkScaleDtl" type="CM_LogCheckScaleDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="3960704f-6bff-4398-bedd-8f7d3ec9b8df">
        <updating/>
        <source>setProxy(_batchHdr			: CM_LogCheckScaleHdr;
		_logId,
		_chkConditionCode	: String;
		_chkSEDMin,
		_chkSEDMax 			: Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin	
	self.logId := _logId;
	//assign unique ID then add to collection
	self.index 					:= _batchHdr.getNextCheckScaleIndex();
	self.myCheckScaleHdr		:= _batchHdr;
	self.checkConditionCode 	:= _chkConditionCode;
	self.checkSEDMin			:= _chkSEDMin;
	self.checkSEDMax	 		:= _chkSEDMax;
	
	self.setCalcAttributes();	
end;</source>
        <Parameter name="_batchHdr" type="CM_LogCheckScaleHdr"/>
        <Parameter name="_logId" type="String"/>
        <Parameter name="_chkConditionCode" type="String"/>
        <Parameter name="_chkSEDMin" type="Decimal"/>
        <Parameter name="_chkSEDMax" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f092ea94-8352-4d19-b3b4-7f1efebb4aac">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.index = null then
//		app.raiseCMWarning1(REQUIRED_FIELD, 'Index', 'index', null, self);
		app.raiseCMWarning(Input_require_field_lndex, 'index', null, self); // cnwdb2	PAR 35364
	endif;
	
	if self.myCheckScaleHdr = null then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Check scaling header', 'checkScalingHdr', null, self);
		app.raiseCMWarning(Input_required_field_chkSclHed, 'checkScalingHdr', null, self); // cnwdb2	PAR 35364
		return;
	endif;
	
	self.validateForUpdate();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="919a993c-5906-4924-9596-77774b882598">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
// ----------   ----------  --------------------------------------------------
vars
	realScaleDtl,
	scaleDtl			: CM_LogCheckScaleDtl;
	
begin
	//check for dups
	foreach scaleDtl in self.myCheckScaleHdr.allCheckScaleDtls do
		if scaleDtl.index = self.index then
			realScaleDtl := self.pxyGetRealObject();
			if (realScaleDtl &lt;&gt; null) and (scaleDtl &lt;&gt; realScaleDtl) then
				//app.raiseCMWarning2(DuplicateItem, 'Log check scaling detail', self.myCheckScaleHdr.batchNoDescr, null, null, self); //13.06.2022 navds20 53760
				// Log check scaling detail already exists for %1 : Check_scalin_detail_alread_exi
				app.raiseCMWarning1(Check_scalin_detail_alread_exi, self.myCheckScaleHdr.batchNoDescr, null, null, self); //13.06.2022 navds20 53760
				return;
			endif;
		endif;
	endforeach;
	

end;</source>
    </JadeMethod>
</Class>
