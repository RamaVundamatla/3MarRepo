    <JadeMethod name="assignValueSpecial" id="61a467dd-ad57-4b2e-a6c3-9a5104a17c6c">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2023	navra1	Initial creation for 57808 - EUP - Manifest Processing - Train - Create

*/

vars

begin

	if _propName = CM_EDITrainTI::trainCode.name then
		self.trainCode := _processedValue;
		return true;
	elseif _propName = CM_EDITrainTI::scheduledArrivalDT.name then
		self.scheduledArrivalDT := _processedValue.TimeStamp;
		return true;
	elseif _propName = CM_EDITrainTI::scheduledDepartureDT.name then
		self.scheduledDepartureDT := _processedValue.TimeStamp;
		return true;
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="5b3af1e9-5892-4040-8f6b-d473a68b4180">
        <source>canUserSet(_propName: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/

vars

begin
	if _propName = CM_EDITrackedItem::id.name 
	or _propName = CM_EDITrackedItem::cargoTypeDescr.name then
//	or _propName = CM_EDITrainTI::subTerminalCode.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
