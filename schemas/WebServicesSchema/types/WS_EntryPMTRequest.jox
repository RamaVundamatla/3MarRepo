    <JadeMethod name="getValidCurrentStatuses" id="652dc876-087e-4d45-b174-20a49958a94b">
        <source>getValidCurrentStatuses(_validStatuses: IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	pelindo1VoyProcess : CM_VoyageProcess;
	includeLessThanPriorityValue : Integer;
	voyageStatus : CM_VoyageStatus;

begin

	//Any with Priority less than the Priority of Voyage_Status_IDepServPending 

	voyageStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IDepServPending );
	if voyageStatus &lt;&gt; null then
		pelindo1VoyProcess := voyageStatus.myProcess;
	
		includeLessThanPriorityValue := voyageStatus.priority;
	
		foreach voyageStatus in pelindo1VoyProcess.allStatuses do
			if voyageStatus.priority &gt;= includeLessThanPriorityValue then
				break;
			endif;
			_validStatuses.add( voyageStatus.id );
		endforeach;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_validStatuses" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processMessage" id="7547b1c5-441c-4c36-bc90-aaae8586d617">
        <source>processMessage( voyage : CM_Voyage io );
/*   EXTENSION WORK ORDER

Purpose:			

Parameters:	
"	This is the INAPORTNET Web Service equivalent functionality to creating a Marine Services Request for an Extension
	to the Voyage visit.
"	Voyage must be able to be identified by PKK number.
"	Voyage must be at the "Voyage Arrived" status, otherwise the request will be rejected.
"	Update - TBC.  Some further design work required here with AB and KPD to deal with probable additional statuses in
	the INAPORTNET process based on recent updated INAPORTNET process flow.
		

Return Value:		

Date		Who		Reason
23 Apr 2018	jlgndl1	Initial creation	TFS 38135
13 Nov 2018	jlger1	TFS 41880 - create the permit requests as well
20 Nov 2018 jlger1	TFS 41880 - changed there mind not creating permits now
03 Apr 2019	jlgdap1	TFS 43694 PEL1 Charging for Vessels that use a Ramp
*/

vars
	pxyPermitWorkOrder,
	pxyWorkOrder : CM_WorkOrderVoyage;
	pxyWorkOrderExtension : CM_WodExtension;
	departureTS : TimeStamp;
	realWorkOrder : CM_WorkOrder;
	pxyPermit  	: CM_WodPermitRequest;
	etmal 		: Decimal[ 12,2];
begin

	departureTS:=self.tanggalSelesai.asTimeStampFromInaportnet;
	
	if voyage &lt;&gt; null then
		if departureTS &gt; voyage.departedDT then
			etmal:= (departureTS - voyage.departedDT).inDaysAndPartOf;
		endif;
	endif;
	
	create pxyWorkOrder  transient;
	pxyWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,app.myPassport.myUser,null,null,app.myPassport.myTerminal,null,null,null, WO_STATUS_PENDING);
	pxyWorkOrder.setMyVoyage(voyage);	
	pxyWorkOrder.setLengthOfTime(etmal);
		
	if voyage = null then
		pxyWorkOrder.setVoyageExternalCode(nomorPkk);
	endif;
	
	create pxyWorkOrderExtension transient;
	//pxyWorkOrderExtension.setProxyWodExtension(departureTS);					// TFS 43694
	pxyWorkOrderExtension.setProxyWodExtension(departureTS, false);				// TFS 43694
	pxyWorkOrder.allWoDtls.add(pxyWorkOrderExtension);
	
	app.myPassport.setWarningsIgnored( true);
	app.myPassport.setWarningsAcknowledged( true);
	app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder,realWorkOrder,app.myPassport);
	if app.myPassport.hasErrors then
		return;
	endif;
	
	//epr TFS 41880 13/11/18
/*	if voyage &lt;&gt; null then
		if departureTS &gt; voyage.departedDT then
			etmal:= (departureTS - voyage.departedDT).inDaysAndPartOf;
		endif;
		
		create pxyPermitWorkOrder transient;
		pxyPermitWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,app.myPassport.myUser,null,null,app.myPassport.myTerminal,null,null,null, WO_STATUS_PENDING);
		pxyPermitWorkOrder.setMyVoyage(voyage);
		pxyPermitWorkOrder.setLengthOfTime(etmal);
		
		create pxyPermit transient;
		pxyPermit.setProxyPermitRequest(null,WO_TASK_VOY_EXTENSION,null);
		pxyPermit.setMyPermitWodVoyageDetail(realWorkOrder.allWoDtls.first.CM_WorkOrderVoyageDtl);
		pxyPermitWorkOrder.allWoDtls.add(pxyPermit);
		
		app.myPassport.setWarningsIgnored( true);
		app.myPassport.setWarningsAcknowledged( true);
		app.myTrxCA.trxCreateWorkOrder(pxyPermitWorkOrder,realWorkOrder,app.myPassport);
		if app.myPassport.hasErrors then
			return;
		endif;
		realWorkOrder:=null;
	endif;*/
	
	
	
	self.doUpdateVoyageStatus(voyage);
epilog
	delete pxyPermitWorkOrder;
	delete pxyWorkOrder;	
end;</source>
        <Parameter name="voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForVoyageUpdate" id="92daf7e0-241f-4873-9740-791d50fa8a69">
        <source>validateForVoyageUpdate( _voyage : CM_Voyage output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	term : CM_Terminal;
	ts1 : TimeStamp;
	ts2 : TimeStamp;
	ts3 : TimeStamp;
	arrivalStatus,
	voyageStatus : CM_VoyageStatus;
	voyageStatusStr : String;


begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	

	term := app.myPassport.myTerminal;
	
	_voyage := term.allVoyagesByExternalCode.getAtKey( self.nomorPkk);
	//epr TFS 40629 7/9/18
	if _voyage &lt;&gt; null then
		voyageStatus := _voyage.getVoyageStatusObject;
		if voyageStatus &lt;&gt; null then
			if voyageStatus &lt;&gt; null then
				arrivalStatus:= voyageStatus.myProcess.allStatusesById[Voyage_Status_IVoyageArrived];
			endif;
			voyageStatusStr := voyageStatus.description;
		else
			voyageStatusStr := app.getErrorString(Null);
		endif;
		if voyageStatus = null or voyageStatus.id &lt; arrivalStatus.priority then
			app.raiseCMException2( Voyage_incorr_status_this_acti, _voyage.code, voyageStatusStr, null, null );
		endif;
	endif;
	
	/*//7. Unknown date Time, Mandatory
	ts1:=self.tanggalPermohonan.asTimeStampFromInaportnet;
	if not ts1.Date.isValid
	or not ts1.Time.isValid
	then
		app.raiseCMException2(ErrInvalidRptTemplateDateStr,"yyyy-mm-dd hh:mm:ss", WS_EntryPMTRequest::tanggalPermohonan.name, null, null); 
	endif;*/
	
	//8. Unknown start date Time, Mandatory
	ts2:=self.tanggalMulai.asTimeStampFromInaportnet;
	if not ts2.Date.isValid
	or not ts2.Time.isValid
	then
		app.raiseCMException2(ErrInvalidRptTemplateDateStr,"yyyy-mm-dd hh:mm:ss", WS_EntryPMTRequest::tanggalMulai.name, null, null); 
	endif;
	
	//9. Unknown end date Time, Mandatory
	ts3:=self.tanggalSelesai.asTimeStampFromInaportnet;
	
	if not ts3.Date.isValid
	or not ts3.Time.isValid
	then
		app.raiseCMException2(ErrInvalidRptTemplateDateStr,"yyyy-mm-dd hh:mm:ss", WS_EntryPMTRequest::tanggalSelesai.name, null, null); 
	endif;
	

epilog

	return not app.myPassport.hasErrors;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMandFieldsPresent" id="93d189f0-8594-41cf-9c03-008c98df46b7">
        <source>validateMandFieldsPresent():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	
	
	//1. self.user - Checked in superClass ::validareCredentials
	
	//2. self.password - Checked in superClass ::validareCredentials
	
	//3. Number of PKK (voyage notification), Mandatory
	if self.nomorPkk = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPMTRequest::nomorPkk.name, null, null);
	endif;
	
	//4. Number of PPKB, Optional
	// self.nomorMasaTambat
	
	//5. Unknown, Mandatory
	if self.kodeDermaga = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPMTRequest::kodeDermaga.name, null, null);
	endif;
	
	//6. Unknown, Mandatory
	if self.nomorRpkRo = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPMTRequest::nomorRpkRo.name, null, null);
	endif;
	
/*	//7. Unknown date Time, Mandatory
	if self.tanggalPermohonan = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPMTRequest::tanggalPermohonan.name, null, null);
	endif;*/
	
	//8. Unknown date Time, Mandatory
	if self.tanggalMulai = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPMTRequest::tanggalMulai.name, null, null);
	endif;
	
	//9. Unknown date Time, Mandatory
	if self.tanggalSelesai = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPMTRequest::tanggalSelesai.name, null, null);
	endif;
	
	//10. Unknown, Optional
	//self.alasan
	
	//11. Unknown, Optional
	//self.cataan
	
	//12 Port Code - Checked in superClass ::validareCredentials

epilog

	return not app.myPassport.hasErrors;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
