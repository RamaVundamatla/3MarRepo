    <JadeMethod name="doSave" id="5a57349c-19cc-46bf-bcbb-cad4a0e1efb8">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation

*/

vars
	proxyTankContentType	: CM_VesselTankContentsType;
	theForm 				: SOP_TableMaintForm;	
	code,
	description,
	remarks,
	contentType 			: String;
	isAvailableForEntry : Boolean;
begin
  	theForm 				:= self.myForm;   	
	code					:=	theForm.tblInput1.getValueByName(ETRow_Code).String;
	description 			:=	theForm.tblInput1.getValueByName(ETRow_Description).String;
	remarks 				:= theForm.tblInput1.getValueByName(ETRow_Remarks).String;
	isAvailableForEntry	:=	theForm.tblInput1.getValueByName(ETRow_IsAvailableForEntry).Boolean;
  	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_VesselTankContentsType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	proxyTankContentType := theForm.myProxyObject.CM_VesselTankContentsType;
	proxyTankContentType.setProxyForTankContentsType(code,description,remarks,isAvailableForEntry,app.myRoot);
	
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateVesselTankContentType(proxyTankContentType, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateVesselTankContentType(proxyTankContentType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK();
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
