15 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	//check the current ti is the same we are moving
	//if _tiString &lt;&gt; self.myVehicleMountedAgent.getCurrentTaskTIId then
		//_errorString:="Current Container does not match the one you are moving";
		//write "Current Container does not match the one you are moving";
	//	return;
	//endif;
	
	
	self.myVehicleMountedAgent.doMoveCurrentTask(_locId, _errorMsgs);

epilog

end;</source>
        <Parameter name="_tiString" type="String"/>
        <Parameter name="_locId" type="String"/>
        <Parameter name="_errorMsgs" type="MobileHandHeldThin::DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
