    <JadeMethod name="actionEventRequestEmail" id="f30a29bf-97cf-4148-a3cf-ded8433663b5">
        <updating/>
        <source>actionEventRequestEmail(_eventRequestType : Integer; _passport : CM_Passport input)updating;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	typeValid : Boolean;
	iter : Iterator;
	tmpEmail : CM_EventRequestEmail;
	tmpBGPEmailDict : BGP_EmailReqByUserAddressDict;
begin

	//typeValid := _eventRequestType &gt; EventRequestTypeNull and _eventRequestType &lt; EventRequestTypeMax;
	iter := self.allEventRequestEmails.createIterator();
	
//	if typeValid then
		self.allEventRequestEmails.startKeyGeq(_eventRequestType, null, iter);
//	endif;
	
//	create tmpBGPEmailDict transient;
	
	while iter.next(tmpEmail) do
		//if typeValid then
			if tmpEmail.type &lt;&gt; _eventRequestType then
				break;
			endif;
		//endif;
		//tmpEmail.getEventRequestEmails(tmpBGPEmailDict, _passport);
		tmpEmail.sendEventRequestEmails2(_passport);
	endwhile;

//	app.myUtilityUA.utlUpdateBGPEmailRequests(tmpBGPEmailDict, _passport);
	
epilog
//	delete tmpBGPEmailDict;
	delete iter;
end;</source>
        <Parameter name="_eventRequestType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addBGPMutex" id="81584a47-68f6-49cb-82f8-ef35a10e2799">
        <source>addBGPMutex(_constant : Constant; _passport : CM_Passport);
//
// 18 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
//
vars
/*	stringConstant : Constant;
	terminal : CM_Terminal;
	pxyBGPMutex : BGP_Mutex;
	mutex : BGP_Mutex;
	text : String;
	descr : String; */
begin

	return;	//No longer used, uses CM_Mutex class via "addUpdateRootMutexes" instead of BGP_Mutex
	
	/*
	if _constant.valueAsInteger &lt;= Mutex_Permissions or
	   _constant.valueAsInteger &gt;= Mutex__Max then
	   	return;
	endif;
	text := _constant.text;
	if text  = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No text for cargo type constant (' &amp; _constant.name &amp; ')');
		return;
	endif;
	descr := text.cnEcGetTagValueOfName('Name');
	foreach terminal in app.myRoot.allTerminals do
		create pxyBGPMutex transient;
		pxyBGPMutex.update(_constant.valueAsInteger, descr, 0, null, terminal, "TerminalObj"); 
		app.myTrxCA.trxCreateBGPMutex(pxyBGPMutex, mutex, app.myPassport);
		delete pxyBGPMutex;
	endforeach; */
epilog
//	delete pxyBGPMutex;
end;</source>
        <Parameter name="_constant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="addBOLType" id="b3be7539-787c-4168-b815-6b2b1e7e2a50">
        <source>addBOLType(pConstant : Constant; _passport:CM_Passport);
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     This is used as a "callBack" method from "initBOLTypes".
//				There are no references to this method BUT it is still called
//
// Parameters:  The constant which should be of type TI_BOLTypes
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	text,
	descr,
	abbr,
	className	: String;
	class		: Class;
	proxyBOLType,
	realBOLType	: CM_BOLType;
	
begin

	if pConstant.valueAsInteger &lt;= BOLType_Min or
	   pConstant.valueAsInteger &gt;= BOLType_Max then
	   	return;
	endif;

	text := pConstant.text;

	if text  = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No text for cargo type constant (' &amp; pConstant.name &amp; ')');
		return;
	endif;

	create proxyBOLType transient;
	proxyBOLType.setProxyFromXML(pConstant.valueAsInteger, text, true, self);
	
	app.myUtilityCA.utlCreateBOLType(proxyBOLType, realBOLType, app.myPassport);
epilog
	delete proxyBOLType;
	
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="addCargoType" id="8d24aa8e-e5f2-4a95-95e0-9ca804a4917b">
        <source>addCargoType(pConstant : Constant; _passport:CM_Passport);
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     This is used as a "callBack" method from "initCargoTypes".
//				There are no references to this method BUT it is still called
//
// Parameters:  The constant which should be of type TI_CargoTypes
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	text,
	descr,
	abbr,
	className	: String;
	class		: Class;
	proxyCargoType,
	realCargoType	: CM_CargoType;
	
begin

	if pConstant.valueAsInteger &lt;= TI_CargoType_Null or
	   pConstant.valueAsInteger &gt;= TI_CargoType_Max then
	   	return;
	endif;

	text := pConstant.text;

	if text  = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No text for cargo type constant (' &amp; pConstant.name &amp; ')');
		return;
	endif;
	
	create proxyCargoType transient;
	proxyCargoType.setProxyFromXML(pConstant.valueAsInteger, text, true, self);
		
	app.myUtilityCA.utlCreateCargoType(proxyCargoType, realCargoType, null, null, app.myPassport);
epilog
	delete proxyCargoType;
	
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="addCodeGroupType" id="ffe7d08e-12d8-4f27-9c52-ecdba35b7815">
        <source>addCodeGroupType(pConstant : Constant; _passport:CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwsb1
//
// Purpose:     This is used as a "callBack" method from "initCodeGroupTypes".
//				There are no references to this method BUT it is still called
//
// Parameters:  The constant which should be of type CodeGroupTypes
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	text,
	descr,
	abbr,
	className	: String;
	class		: Class;
	proxyCodeGroupType,
	realCodeGroupType	: CM_CodeGroupType;
	
begin
	if pConstant.valueAsInteger &lt;= CodeGroup_Null or
	   pConstant.valueAsInteger &gt; CodeGroup_MaxNumber then
	   	return;
	endif;

	text := pConstant.text;
	if text  = null then
		app.raiseUnexpectedProgramError(class.name, method.name,
				'No text for code group type constant (' &amp; pConstant.name &amp; ')');
		return;
	endif;
	
	descr := text.cnEcGetTagValueOfName('Descr');
	if descr = null and pConstant.valueAsInteger = CodeGroup_MaxNumber then
		// A Code group type is not created.
		return;
	endif;
	
	create proxyCodeGroupType transient;
	proxyCodeGroupType.setProxyFromXML(pConstant.valueAsInteger, text, self);
		
	app.myUtilityCA.utlCreateCodeGroupType(proxyCodeGroupType, realCodeGroupType, app.myPassport);
//	self.allCodeGroupTypes.add(realCodeGroupType); //removed rs 11/06/2002 as causes duplicate exception in new system
epilog
	delete proxyCodeGroupType;
	
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="addStatii" id="85858bd7-24d0-4013-86a8-7edf8814e204">
        <source>addStatii(pConstant : Constant);
// ---------------------------------------------------------------------------
// Created:     10 January 2002 by cnwrs1
//
// Purpose:     This is used as a "callBack" method from "initStatii".
//				There are no references to this method BUT it is still called
//
// Parameters:  The constant which should be of type TI_Status
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	text, descr, abbr : String;
	imExStatus, contentsStatus : Integer;
	proxyStatus, realStatus	: CM_ContentsStatus;
	
begin

	if pConstant.valueAsInteger &lt; null then
//	   pConstant.valueAsInteger &gt;= MAX_STATUS then
	   	return;
	endif;

	text := pConstant.text;

	if text = null then
		return;
	endif;
		
	descr := text.cnEcGetTagValueOfName('Descr');
	abbr := text.cnEcGetTagValueOfName('Abbr');
	
	if descr = null or abbr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid format for text for cargo type constant (' &amp; pConstant.name &amp; ')');
		return;
	endif;

	create proxyStatus transient;
	proxyStatus.setProxyForNewStructure(pConstant.valueAsInteger, White, descr, abbr);
	create realStatus persistent;	
	realStatus.setForCreate(proxyStatus);

epilog
	delete proxyStatus;
	
end;</source>
        <Parameter name="pConstant" type="Constant"/>
    </JadeMethod>
    <JadeMethod name="addTAType" id="013f9dab-0bd9-4c54-8062-0f4722b6af75">
        <source>addTAType(pConstant : Constant; _passport:CM_Passport);
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     This is used as a "callBack" method from "initTATypes".
//				There are no references to this method BUT it is still called
//
// Parameters:  The constant which should be of type TerminalAreaTypeConstant
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	text,
	descr,
	abbr					: String;
	isYardPlanningAllowed,
	isNotAvailableSys,
	isNotAvailableForEntry	: Boolean;
	className				: String;
	class					: Class;
	proxyTAType,
	realTAType				: CM_TerminalAreaType;
	
begin

	if pConstant.valueAsInteger &lt;= TA_TYPE_NULL or
	   pConstant.valueAsInteger &gt;= TA_TYPE_MAX then
	   	return;
	endif;

	text := pConstant.text;

	if text = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No text for Terminal Area Type constant (' &amp; pConstant.name &amp; ')');
		return;
	endif;
	
	descr 	  				:=	text.cnEcGetTagValueOfName('Name');
	isYardPlanningAllowed	:=	(text.cnEcGetTagValueOfName('isYardPlanningAllowed') = "true");
	isNotAvailableForEntry	:=	(text.cnEcGetTagValueOfName('isNotAvailableForEntry') = "true");
	isNotAvailableSys		:=	(text.cnEcGetTagValueOfName('isNotAvailableSys') = "true");
	
	if descr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid format for text for terminal area type constant (' &amp; pConstant.name &amp; ')');
		return;
	endif;

	create proxyTAType transient;
	proxyTAType.setProxy(pConstant.valueAsInteger, descr, isYardPlanningAllowed,isNotAvailableForEntry,	isNotAvailableSys, self);
	
	app.myUtilityCA.utlCreateTerminalAreaType(proxyTAType, realTAType, app.myPassport);
epilog
	delete proxyTAType;
	
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="addUpdateRootMutexes" id="3d73174d-1d31-4f64-8548-20a9ee7bca52">
        <source>addUpdateRootMutexes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2021	navndl1	Initial creation	TFS	TFS 51142

*/

vars

	rootMutexContexts : IntegerArray;
	rootMutexNames : StringArray;
	mutexContext : Integer;
	mutexName : String;
	mutexObj : CM_Mutex;
	index : Integer;
	pxyMutex : CM_Mutex;

begin

	create rootMutexContexts transient;						create rootMutexNames transient;
	if app.isDevelopmentSystem then
		rootMutexContexts.add( Mutex_Permissions );			rootMutexNames.add( Mutex_Permissions_String );
	endif;
	rootMutexContexts.add( Mutex_RefreshSysConfigs );		rootMutexNames.add( Mutex_RefreshSysConfigsString );
	
	
	foreach index in 1 to rootMutexContexts.size do
		mutexContext := rootMutexContexts[index];
		mutexName := rootMutexNames[index];
		mutexObj := self.allMutexes.getAtKey( mutexName, mutexContext );
		if mutexObj = null then
			//create One
			create pxyMutex transient;
			pxyMutex.setDetails(	self,	//_root : CM_Root;
									null,	//_term : CM_Terminal;
									mutexName,	//_name : String;
									mutexContext	//_context : Integer
									); 
			app.myUtilityCA.utlCreateMutex( pxyMutex, mutexObj, app.myPassport );
			delete pxyMutex;
		endif;
	endforeach;

epilog

	delete rootMutexContexts;
	delete rootMutexNames;
	delete pxyMutex;

end;</source>
    </JadeMethod>
    <JadeMethod name="allowMultiTerminal" id="4051de00-a243-44a6-bafa-84cda0f2db65">
        <source>allowMultiTerminal() : Boolean;
// ---------------------------------------------------------------------------
// Created:     14 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	return (self.numTerminalsAllowed &gt; 1);

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="allowTranshipInterModal" id="ae8eaaa8-55e2-49ec-99bf-2e2af641ab29">
        <source>allowTranshipInterModal() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 May 2022			jlizm1	Initial creation TFS 53083 GPHA revceival/release of tranship cargo

*/

vars

	imexStatus : CM_IMEXStatus;
	
begin

	imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];
