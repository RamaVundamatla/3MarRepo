		inheritMethod();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="ff9d121c-d044-4cc8-a457-e954c87f1fa1">
        <updating/>
        <source>doSave():Boolean updating, protected;
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 05/12/2012	cnwcs5	par 30852
// 27/02/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Derive units for saving measurements
// 10/03/2023	jlika1	TFS 56923 - Add width to Trailer
// 25/09/2023	jlizm1	TFS 59737 Kiosk Trailer Type Image ID
vars
	proxy 			: CM_TILCType; 
	realType 		: CM_TILCType;
	result, index	: Integer;
	cargoType 		: CM_CargoType;
	passport		: CM_Passport;
	lengthType,								// PAR #31155
	weightType		: CM_MeasurementType;	// PAR #31155
	length			: Decimal [23,4];		// PAR #31155
	maxHeight			: Decimal [23,4];		// PAR #31155
	weight			: Decimal [23,4];		// PAR #31155
	tareWeight		: Decimal [23,4];
	lengthText		: String;				// PAR #31155
	maxHeightText,
	heightText		: String;				
	height 			: Decimal[23,4];
	widthText		: String;
	width 			: Decimal[23,4];
	allowUpdateTotWeight : Boolean;			//15/10/2025	navkc1 JIRA 36057
	
begin
	passport := app.myPassport;
	
	beginLoad;
	
	if self.isEdit then
		proxy := app.createUpdateProxy(self.myTILCType).CM_TILCType;
	else
		create proxy transient;
	endif;
	
	endLoad;
	
	index := self.cmbCargoType.listIndex;
	
	if index &gt; 0 then
		cargoType := self.cmbCargoType.itemObject[index].CM_CargoType;
	endif;
	
	lengthType 	:= app.getDefaultMeasurementForType(self.lblLength.tag);									// PAR #31155
	weightType 	:= app.getDefaultMeasurementForType(self.lbMaxWeight.tag);									// PAR #31155
	weight		:= app.convertMeasurementForStorage(weightType.shortName, self.txtMaxWeight.text.Decimal);	// PAR #31155
	tareWeight	:= app.convertMeasurementForStorage(weightType.shortName, self.txtTareWeight.text.Decimal);	// 11/04/2013 cnwar2 #31332
	if lengthType.isFeetAndInches then																		// PAR #31155
		lengthText 	:= self.txtFtInLength.getFeetInches;													// PAR #31155
		length 		:= app.convertMeasurementForStorage(lengthType.shortName, lengthText.Decimal);			// PAR #31155
		maxHeightText 	:= self.txtFtInMaxHeight.getFeetInches;													// PAR #31155
		maxHeight 		:= app.convertMeasurementForStorage(lengthType.shortName, maxHeightText.Decimal);			// PAR #31155
		
		heightText 	:= self.txtFtInHeight.getFeetInches;													// TFS 54700
		height 		:= app.convertMeasurementForStorage(lengthType.shortName, heightText.Decimal);			// TFS 54700
		
		widthText 	:= self.txtFtInWidth.getFeetInches;
		width 		:= app.convertMeasurementForStorage(lengthType.shortName, widthText.Decimal);
		
	else																									// PAR #31155
		length 		:= app.convertMeasurementForStorage(lengthType.shortName, self.txtLength.text.Decimal);	// PAR #31155
		maxHeight	:= app.convertMeasurementForStorage(lengthType.shortName, self.txtMaxHeight.text.Decimal);// PAR #31155
		height		:= app.convertMeasurementForStorage(lengthType.shortName, self.txtHeight.text.Decimal); //TFS 54700
		width		:= app.convertMeasurementForStorage(lengthType.shortName, self.txtWidth.text.Decimal); 
	endif;																									// PAR #31155
	
	allowUpdateTotWeight := self.chkAllowUpdateTotWeight.value; //15/10/2025	navkc1 JIRA 36057
	
	proxy.setProxy(	self.txtCode.text,
					self.txtDescription.text,
					cargoType,
					length,																			
					self.txtNumLCs.text.Integer,
					maxHeight,																			
					weight,																			
					tareWeight,																		
					self.cmbColour.getColor,
					self.chkNotAvailable.value,
					height,
					self.cmbCategory.getCurrentItemData,
					width,					// par 39852 Dec 2012
					self.txtImageID.text,
					allowUpdateTotWeight	//15/10/2025	navkc1 JIRA 36057
					);	
	
	if proxy = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
		return false;
	endif;
	
	while true do
		if not self.isEdit then
			app.myTrxCA.trxCreateTILCType(proxy, realType, passport);
		else
			app.myTrxUA.trxUpdateTILCType(proxy, passport);
		endif;
		
		if passport.trxCompletedOK then
			self.myTILCType :=realType;	
			return true;
		else
			result := app.showErrorWarningDialog(app.getErrorString(SHP_Tranship_Update), passport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if passport.noErrors and  result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	return false;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	
	if proxy &lt;&gt; null then
		delete proxy;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadData" id="e3bc2819-5f36-4e0f-9cb4-7eb6e34d5ea5">
        <source>loadData();
/*
Date		Who		Reason
05 April 2007	cnwer1	Initial creation - PAR#xxxx
05 Dec 2012		cnwcs5	par 30753 - can't change cargo type for edit
06 Dec 2012		cnwcs5	par 30852 - add is not available for entry
25 Feb 2013		cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
10 Mar 2023		jlika1	TFS 56923 - Add width to Trailer
25 Sep 2023		jlizm1	TFS 59737 Kiosk Trailer Type Image ID
*/
vars
	type			: CM_TILCType;
	measureLength	: CM_MeasurementType;	// PAR #31155
	feetInches		: String;				// PAR #31155
	measureWeight	: CM_MeasurementType;	
	measureHeight	: CM_MeasurementType;	
	measureWidth	: CM_MeasurementType;	
begin
	
	type	:= self.myTILCType;
	measureLength := app.getDefaultMeasurementForType(Type_Length);
	measureWeight := app.getDefaultMeasurementForType(Type_Weight);
	measureHeight := app.getDefaultMeasurementForType(Type_Height);
	measureWidth :=  app.getDefaultMeasurementForType(Type_Width);	
		
	if type = null then
		if self.cmbCargoType.listCount = 1 then
			self.cmbCargoType.listIndex	:=	1;
		endif;
		self.lblLength.tag := measureLength.measurementType;																// PAR #31155
		self.lbMaxWeight.tag := measureWeight.measurementType;	
		self.lblheight.tag := measureHeight.measurementType;					
		self.lblwidth.tag := measureWidth.measurementType;
	else
		self.txtCode.text			:= type.code;
		self.txtDescription.text	:= type.description;
		self.txtImageID.text 		:= type.imageID;
		
		// linear measurements - length																// PAR #31155		
		if measureLength.isFeetAndInches then																				// PAR #31155
			feetInches 					:= app.convertMeasureForMaskDisplay(measureLength.shortName, type.length);		// PAR #31155
			self.txtFtInLength.textUser	:= feetInches;																// PAR #31155
		else	
			// PAR #31155
			self.txtLength.maxLength := null;
			self.txtLength.decimals		:= measureLength.getDecimalPrecision;												// PAR #31155
			self.txtLength.text			:= app.convertMeasurementForDisplay(measureLength.shortName, type.length);		// PAR #31155
		endif;
		self.lblLength.tag				:= measureLength.measurementType;		
		
		if measureWidth.isFeetAndInches then
			feetInches 					:= app.convertMeasureForMaskDisplay(measureWidth.shortName, type.length);
			self.txtFtInWidth.textUser	:= feetInches;																
		else
			self.txtWidth.maxLength := null;
			self.txtWidth.decimals		:= measureWidth.getDecimalPrecision;
			self.txtWidth.text			:= app.convertMeasurementForDisplay(measureWidth.shortName, type.width);
		endif;
		self.lblwidth.tag				:= measureWidth.measurementType;		
		
		// linear measurements - max height		
		if measureHeight.isFeetAndInches then																				// PAR #31155
			feetInches 					:= app.convertMeasureForMaskDisplay(measureHeight.shortName, type.maxHeight);		// PAR #31155
			self.txtFtInMaxHeight.textUser := feetInches;																// PAR #31155
			feetInches	:= app.convertMeasureForMaskDisplay(measureHeight.shortName, type.height);
			self.txtFtInHeight.textUser := feetInches;	
		else	
			self.txtMaxHeight.maxLength :=null;
			self.txtMaxHeight.decimals	:= measureHeight.getDecimalPrecision;												// PAR #31155
			self.txtMaxHeight.text		:= app.convertMeasurementForDisplay(measureHeight.shortName, type.maxHeight);		// PAR #31155
			
			self.txtHeight.maxLength :=null;
			self.txtHeight.decimals	:= measureHeight.getDecimalPrecision;												// PAR #31155
			self.txtHeight.text		:= app.convertMeasurementForDisplay(measureHeight.shortName, type.height);
		endif;// PAR #31155
															// PAR #31155
		self.lbMaxHeight.tag			:= measureHeight.measurementType;													// PAR #31155
				
		// weight measurement - max weight																			// PAR #31155		
		self.txtMaxWeight.decimals		:= measureWeight.getDecimalPrecision;												// PAR #31155
		self.txtMaxWeight.text			:= app.convertMeasurementForDisplay(measureWeight.shortName, type.maxWeight);		// PAR #31155
		self.lbMaxWeight.tag			:= measureWeight.measurementType;													// PAR #31155
		self.txtTareWeight.decimals		:= measureWeight.getDecimalPrecision;												// 11/04/2013 cnwar2 #31332
		self.txtTareWeight.text			:= app.convertMeasurementForDisplay(measureWeight.shortName, type.tareWeight);	// 11/04/2013 cnwar2 #31332
		self.lbTareWeight.tag			:= measureWeight.measurementType;													// 11/04/2013 cnwar2 #31332
		self.txtNumLCs.text			:= type.numControllers.String;
		self.chkNotAvailable.value	:= type.isNotAvailableForEntry;	
		self.chkAllowUpdateTotWeight.value := type.allowUpdateTotalWeight; //15/10/2025	navkc1 JIRA 36057
		
		self.cmbColour.setColor(type.colour);
		
		// par 30753 - can't change cargo type on edit
		self.cmbCargoType.enabled	:= false;
		self.cmbCargoType.setIndexFromObject(type.myCargoType);
		
		self.cmbCategory.setIndexForItemData(type.category);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTILCType" id="01588f8b-1a71-4d71-9ad9-a33e815846b8">
        <updating/>
        <source>setMyTILCType(_value : CM_TILCType; _isEdit : Boolean) updating;
/*
Date		Who		Reason
05 April 2007	cnwer1	Initial creation - PAR#xxxx
05 Dec 2012		cnwcs5	par 30852 - changed _value usage to constant
*/
vars

begin
    self.isEdit	:= _isEdit;
	
	if _isEdit then
		self.myTILCType := _value;
	else
		self.myTILCType := null;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="CM_TILCType"/>
        <Parameter name="_isEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupCmbCategory" id="67e34b6f-9205-4a9d-bed7-bef26abce1e2">
        <source>setupCmbCategory();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2022	jlier1	Initial creation 54700

*/

vars

begin
	self.cmbCategory.clear;
	self.cmbCategory.addItemWithData(app.getErrorString(Trailer),TRAILER_CATEGORY_TRAILER);
	self.cmbCategory.addItemWithData(app.getErrorString(Mafi),TRAILER_CATEGORY_MAFI);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupComboCargoType" id="a53cad3e-41cf-4779-9687-a453d0126890">
        <source>setupComboCargoType();
/*
Date			Who		Reason
04 April 2007	cnwer1	Initial creation - PAR#xxxx
05 Dec 2012		cnwcs5	par 30852
*/
vars
	cargoType  	: CM_CargoType;
	index 		: Integer;
	combo		: CMUI_ComboBox;
begin
	combo := self.cmbCargoType;
	
	combo.clear;
	
	foreach cargoType in app.myRoot.allCargoTypesById  discreteLock do
		// from 31981 skip not-available-for-entry cargo types
		if cargoType.isNotAvailableForEntry then
			continue;
		endif;
		if cargoType.productType &lt;&gt; ProductType_Trailer then
			continue;
		endif;
		
		index := combo.addItem(cargoType.description);
		
		combo.itemObject[index] := cargoType;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3f05a325-34b2-473e-b825-aeb77397a16d">
        <updating/>
        <source>setupForm() updating;
/*
Date			Who		Reason
03 April 2007	cnwer1	Initial creation - PAR#xxxx
05 Dec 2012		cnwcs5	par 30852 - fix up form caption translation inpainter and standard text
								  - rework form to be standard modal dialog
25 Feb 2013		cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
10 Mar 2023		jlika1	TFS 56923 - Add width to Trailer
*/
constants
	StandardSpacing = 8;
vars

begin
	inheritMethod();
	
	self.showToolbar 				:= false;
	
	self.setupComboCargoType();
	self.setupCmbCategory();
	
	if self.isEdit then
		self.btnNext.visible:= false;
	else 
		self.btnNext.tabIndex	:= btnCancel.tabIndex;
		self.height				:= self.minimumHeight;
		
		// squeeze the next button in between ok &amp; cancel
		self.btnNext.left	:= self.btnOk.left;
		self.btnOk.left 	:= self.btnNext.left - btnNext.width - StandardSpacing;
	endif;
	
	// PAR #31155 get system default measurement type for length and weight, 				// PAR #31155
	// and insert unit in to appropriate labels												// PAR #31155
	self.lbMaxHeight.setCaptionForMeasurementType(Type_Height);								// PAR #31155
	self.lbMaxWeight.setCaptionForMeasurementType(Type_Weight);								// PAR #31155
	self.lbTareWeight.setCaptionForMeasurementType(Type_Weight);							// 11/04/2013 cnwar2 #31332
	self.lblLength.setCaptionForMeasurementType(Type_Length);								// PAR #31155
	self.lblheight.setCaptionForMeasurementType(Type_Height);
	self.lblwidth.setCaptionForMeasurementType(Type_Width);
	// check if the default linear measurement type is ft - if so, 							// PAR #31155
	// display the edit mask text boxes for entering feet and inches						// PAR #31155
	if app.getDefaultMeasurementForType(Type_Height).isFeetAndInches then					// PAR #31155
		self.txtMaxHeight.visible 	:= false;												// PAR #31155
		self.txtFtInMaxHeight.visible	:= true;												// PAR #31155
		self.txtFtInMaxHeight.tabIndex	:= self.txtMaxHeight.tabIndex;							// PAR #31155
		self.txtFtInMaxHeight.move(self.txtMaxHeight.left, self.txtMaxHeight.top, self.txtMaxHeight.width, self.txtMaxHeight.height);	// PAR #31155
		//jlier1 TFS 54700 6/9/22
		self.txtHeight.visible 	:= false;												
		self.txtFtInHeight.visible	:= true;												
		self.txtFtInHeight.tabIndex	:= self.txtHeight.tabIndex;							
		self.txtFtInHeight.move(self.txtHeight.left, self.txtHeight.top, self.txtHeight.width, self.txtHeight.height);	
	endif;	
	if app.getDefaultMeasurementForType(Type_Length).isFeetAndInches then					// PAR #31155
		self.txtLength.visible 		:= false;												// PAR #31155
		self.txtFtInLength.visible	:= true;												// PAR #31155
		self.txtFtInLength.tabIndex	:= self.txtLength.tabIndex;								// PAR #31155
		self.txtFtInLength.move(self.txtLength.left, self.txtLength.top, self.txtLength.width, self.txtLength.height);				// PAR #31155
	endif;
	
	if app.getDefaultMeasurementForType(Type_Width).isFeetAndInches then
		self.txtWidth.visible 		:= false;							
		self.txtFtInWidth.visible	:= true;							
		self.txtFtInWidth.tabIndex	:= self.txtWidth.tabIndex;			
		self.txtFtInWidth.move(self.txtWidth.left, self.txtWidth.top, self.txtWidth.width, self.txtWidth.height);
	endif;
	
	self.loadData;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7f436e5c-5697-40f3-bd8e-393c977b0f22">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 November 2025 09:45:47.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017482, locale);		               // note - standard text for this is 'Trailer Type Maintenance
	btnNext.translateBubbleHelp(Xlat_0005327, locale);
	btnNext.translateCaption(Xlat_0005328, locale);
	chkAllowUpdateTotWeight.translateCaption(Xlat_0027139, locale);
	chkNotAvailable.translateCaption(Xlat_0018140, locale);
	cmbColour.translateBubbleHelp(Xlat_0014620, locale);
	lbColour.translateCaption(Xlat_0005330, locale);
	lbMaxHeight.translateCaption(Xlat_0005331, locale);
	lbMaxWeight.translateCaption(Xlat_0005332, locale);		             
	lbNumLCs.translateCaption(Xlat_0005333, locale);
	lbTareWeight.translateCaption(Xlat_0019015, locale);
	lblCargoType.translateCaption(Xlat_0014621, locale);
	lblCategory.translateCaption(Xlat_0025072, locale);
	lblCode.translateCaption(Xlat_0005335, locale);
	lblDescription.translateCaption(Xlat_0005336, locale);
	lblImageID.translateCaption(Xlat_0026476, locale);
	lblLength.translateCaption(Xlat_0005337, locale);
	lblheight.translateCaption(Xlat_0025073, locale);
	lblwidth.translateCaption(Xlat_0025796, locale);
end;</source>
    </JadeMethod>
</GUIClass>
