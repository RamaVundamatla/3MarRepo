    <JadeMethod name="trxDeleteDataAccessController" id="9ec7b2c0-b8e0-41ac-8bf0-d28239e61419">
        <updating/>
        <source>trxDeleteDataAccessController(_dac : CM_DataAccessController; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toDelete	: CM_DataAccessController;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _dac = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'Data Access Controller', null, null);
		return;
	endif;
	toDelete := _dac;

	// Start the transaction
	beginTransaction;

	app.myUtilityDA.utlDeleteDataAccessController(toDelete, _passport);
		
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_dac" type="CM_DataAccessController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
