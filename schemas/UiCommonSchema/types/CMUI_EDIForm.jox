    <JadeMethod name="setControlsForVoyage" id="eade60c1-93dd-4c73-96e6-8b916612f3cf">
        <source>setControlsForVoyage(_voyageCode: String);
//----------------------------------------------------------------
//	Created:	02 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	voyage		: CM_Voyage;
	vessName	: String;	
begin
	
	voyage := self.myTerminal.lookupVoyage(_voyageCode, null, false);

	if voyage &lt;&gt; null then
		vessName := voyage.vesselName;
	else
		return;
	endif;
	
	self.myAssistant.comboBoxOperator(cmbOperator, null, voyage);

	self.tblEDIDetails.setValueByControlName(cmbVessel.name, vessName);	

end;</source>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDataClassFromCombo" id="64ecddb4-1875-40c7-8acc-45a408078ae9">
        <updating/>
        <source>setDataClassFromCombo( combobox: ComboBox) protected, updating;
// ---------------------------------------------------------------------------
// Created:	08 September 2009 By Graeme Black cnwgb1
// Status: 	Tested
// Purpose:	To retrieve  the data class from the 
// ---------------------------------------------------------------------------
vars
begin
	if self.myEDIConfig &lt;&gt; null then 
		self.myDataClass := self.myEDIConfig.getEDIDataClassForType(combobox.itemData[combobox.listIndex]);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="combobox" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="setEDIDataCaptions" id="1812731b-5d2d-4e5d-b19d-5a06362078c3">
        <source>setEDIDataCaptions( _dataType : Integer);
// ---------------------------------------------------------------------------
// Created:	25 September 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	Setup the captions on the EDI items tabs
// ---------------------------------------------------------------------------
// 30/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - coparn release requests
//29 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
vars
	tiDefNames 		: StringArray;
	tiDefName 		: String;
	childDataTypes 	: IntegerArray;
	index 			: Integer;
	tmpData 		: CM_EDIData;
	oldShtIndex 	: Integer;
	sheet 			: CMUI_Sheet;
begin	
	//epr par 36354 29/6/15
	tmpData := self.myCurrentObject.CM_EDIData;
	if tmpData &lt;&gt; null then
		create tiDefNames transient;
		create childDataTypes transient;
		tmpData.getMyTIDisplayDefNames( tiDefNames );
		if tmpData.isKindOf(CM_EDIDataCallOff) then		//23 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
			tiDefNames.remove(ETDef_EDITITaskActionRelReq);
		endif;
		tmpData.getEDIChildDataTypes( childDataTypes );
		if tmpData.isKindOf(CM_EDIDataCallOff) then		//23 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
			childDataTypes.remove(EDIDataType_CallOff);
			childDataTypes.remove(EDIDataType_ReqBookToDo);
		endif;
		if tmpData.isKindOf(CM_EDIDataTransManifest) then		//29 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
			childDataTypes.remove(EDIDataType_TransportManifest);
		endif;
		foreach tiDefName in tiDefNames do
			sheet := self.shtEDIData.getControl(index);
			if sheet = null then
				self.cloneTISheet( index );
				sheet := self.shtEDIData.getControl(index);
			endif;
			
			sheet.caption 	:= self.myAssistant.getEDIDisplayStrForType( childDataTypes[index+1] );
			sheet.visible 	:= true;
			index 			:= index+1;
		endforeach;
		
		foreach oldShtIndex in index to self.MAXSHEETS do
			sheet := self.shtEDIData.getControl(oldShtIndex);
			
			if sheet &lt;&gt; null then 
				sheet.visible := false;
			else
				break;
			endif;
		endforeach;
	endif;
	
epilog
	delete tiDefNames;
	delete childDataTypes;
end;</source>
