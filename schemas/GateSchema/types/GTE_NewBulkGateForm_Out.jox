    <JadeMethod name="deleteCurrentJobEntry" id="69a07270-39d6-4208-b324-8b4e16ef0c2b">
        <updating/>
        <source>deleteCurrentJobEntry(_reason : String ) updating, protected;
//--------------------------------------------------------------

//--------------------------------------------------------------
//Confirm deletion of the current WLE for the RoadJob
//We have to do a number of things here..
//If the job is a receipt of a TI, we have to MOVE the TI to the LOGICAL delete
//area of the system, &amp; adjust the roadJob etc accordingly,
//If the job is a release, we simply amend the request etc.
//18/10/17 jlgns1 TFS 7115 PKT - Vehicle visit dispute occurs at GATE OUT
vars
	result		: Integer;
	wleArray 	: CM_WLEArray;
	wle			: CM_WorkListEntry;
	
	
begin
  	app.mousePointer := MousePointer_HourGlass;
  	
	create wleArray transient;

	if tblItems.allSelectedObjects.size &gt; 0 then
		tblItems.allSelectedObjects.first.CM_VehicleVisitRecord.vehicle.allRoadJobs.first.workListEntries.copy(wleArray ); 
	endif;
	
	if wleArray.isEmpty then
		return;
	endif;
	

	foreach wle in wleArray discreteLock do
		while true do
			app.myTrxDA.trxDeleteJobEntry(wle, _reason, app.myPassport); 
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Bulk_gate_out), app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endforeach;

epilog
	delete wleArray;
	app.mousePointer := MousePointer_Default;  	
end;</source>
        <access>protected</access>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
