    <JadeMethod name="getService" id="26006309-5e81-4bd9-9619-143984431313">
        <source>getService():CM_Service;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jan 2019	jlgma1	Bug 42984: QNS - RE: Report - Revenues by Service Lines

*/
	
vars
	service : CM_Service;
	invLineDesc :CM_InvoiceLineDesc;
	proforma    : CM_ProformaDetails;
begin
		
	if self.myProformaDetail &lt;&gt; null then
		if self.myProformaDetail.myInvoiceLineType &lt;&gt; null then
			service := self.myProformaDetail.myInvoiceLineType.services.first;
		endif;
	endif;
	
	if service = null then
		if self.myInvoiceLine &lt;&gt; null then
			service := self.myInvoiceLine.invoiceLineDesc.services.first;
		
		endif;
	endif;
	
	//21.01.2019 cnwma1 Bug 42984
	if service = null or service.isKindOf(CM_VoidService) then
		if self.proformaDesc &lt;&gt; null then
			invLineDesc := self.getBank.invoiceLineDescriptors[self.proformaDesc];
			if invLineDesc &lt;&gt; null then
				if not invLineDesc.services.isEmpty then
					service := invLineDesc.services.first;	
				endif;
			endif;
		endif;
	endif;
	
	//21.01.2019 cnwma1 Bug 42984
	if service = null or service.isKindOf(CM_VoidService) then
		if self.myProformaDetail = null then
			proforma := self.getMatchingProforma();
			if proforma &lt;&gt; null then
				if  proforma.myInvoiceLineType &lt;&gt; null then
					if not proforma.myInvoiceLineType.services.isEmpty then
						service := proforma.myInvoiceLineType.services.first;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	return service;
epilog

end;</source>
        <ReturnType type="CM_Service"/>
    </JadeMethod>
