    <JadeMethod name="isSystemProductType" id="b6132907-7a82-4ae2-b7fd-a05b64d10a84">
        <source>isSystemProductType() : Boolean;
// --------------------------------------------------------------------------------
// Created:		13 April 2010 by cnwjo3
//
// Purpose:		to identify if this product is just a dummy product for CargoTypes with no subcargo types.
//				par 23669
//
vars

begin
	if self.code = SystemProductCode and self.description = SystemProductCode then
		return true;
	else
		return false;
	endif;
end;</source>
