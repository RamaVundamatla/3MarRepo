    <JadeMethod name="getType" id="f6ca198d-57a0-443c-8a3f-38550ad90455">
        <source>getType() : String;
//
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//26 Feb 2015	CNWRS1	pAR 35765 - Return Gondola if the wagonclass code is "CVD GON"	
vars

