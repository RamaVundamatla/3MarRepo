    <JadeMethod name="setProxy" id="cae4c466-470f-4a39-8784-8d02c2523c16">
        <updating/>
        <source>setProxy(_name : String; _field : CM_DataExtractField) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

begin
	self.raiseExceptionIfNotTransient(method);	
	
	self.setCommon(_field);	
	
	self.name := _name[1:self.name.maxLength].trimBlanks;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_field" type="CM_DataExtractField"/>
    </JadeMethod>
    <JadeMethod name="validateCommon" id="c2248f1a-4583-4727-b745-4271d330bd62">
        <source>validateCommon();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

vars
	className : String;
	class     : Class;
	feature   : Feature;
begin
	class := self.getDataExtractClass.getObjectClass();
	className := class.name;
	
	feature := self.getDataExtractClass.getFeatureForClass(class, self.name);
	if feature = null and not self.myDataExtractClass.isFeatureForSubClass(self.name) then
		//app.raiseCMException2(Err_InvalidAttrForClass, self.name, className, null, null);
	endif;
end;</source>
    </JadeMethod>
