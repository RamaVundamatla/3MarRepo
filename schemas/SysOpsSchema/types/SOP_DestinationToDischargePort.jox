    <JadeMethod name="cmbPortDischBuild" id="6546b5d4-2c7f-4412-909d-9e9bd103d43e">
        <source>cmbPortDischBuild(_shippingLine : CM_ShippingLine) protected;
// ---------------------------------------------------------------------------
// Created:		June 2006 cnsrs1 ccms 1031
// ---------------------------------------------------------------------------
vars
	port : CM_Port;
	idx : Integer;
	dischargePorts : CM_PortSet;
	str : String;
begin
	self.cmbPortDisch.clear;
	
	//07/07/2010 cnwdz2 24598
	if _shippingLine = null then
		return;
	endif;
	
	create dischargePorts transient;
	_shippingLine.getAllDischargePorts(dischargePorts);
	foreach port in dischargePorts do
		str := port.getDisplayFormatted(self.portCmbOrderDescrFirst);
		idx := self.cmbPortDisch.addItem(str);
		self.cmbPortDisch.itemObject[idx] := port;
	endforeach;

	self.cmbPortDisch.listIndex := -1;
epilog
	delete dischargePorts;
end;</source>
        <access>protected</access>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
    </JadeMethod>
