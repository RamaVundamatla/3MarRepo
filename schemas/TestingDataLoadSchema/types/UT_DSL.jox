    <JadeMethod name="addForkLiftStack" id="95f7b3a3-3340-41e6-94f3-25cb3088cc21">
        <source>addForkLiftStack(_name: String; _rows,_columns,_height: Integer): CM_ForkLiftStack;
/*

Purpose:		aka Gridded Block Stack	

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwer1	Initial creation

*/


//
vars

	pxyForkStack: CM_ForkLiftStack;
	pxyGridCol: CM_GridColumn;
	pxyGridRow: CM_GridRow;
	pxyStackCntrl: CM_StackController;
	column, row: Integer;
	label: String;
	pDO: CM_YADeckingOptionsTA;
	realTA 	: CM_TerminalAreaMaster;
	
	pxyTA				: CM_TerminalAreaMaster;
	pxyCMIFTerminalArea	: CMIF_GridArea;
	use40ftIds			: Boolean;
	power				: Boolean;
	accessBack			: Boolean;
	accessFront			: Boolean;
	
begin
	self.deleteTerminalArea(_name);
	
	use40ftIds := self.opts.bool("use40ftIds");			// 26/08/2011 cnwmh5
	power := self.opts.bool("WithPower");				// 21/07/2015 cnwmh5
	accessBack := self.opts.bool("AccessBack");
	accessFront := self.opts.bool("AccessFront");
		
	create pxyForkStack transient;

	pxyForkStack.setProxy(_name, 
					"",
					TA_TYPE_FORK_LIFT_STACK, 
					_rows, 
					_columns, 
					_height,
					"Gridded Block Stack",
					accessBack,  //back
					accessFront, //front
					HEIGHT_FULL_HIGH_CUBE*_height, //full height //
					HEIGHT_FULL_HIGH_CUBE*_height, //MT height
					HEIGHT_FULL_HIGH_CUBE*_height, //power height
					null,
					false, //release point
					self.getTerminal,
					false, //stock
					false, // hide ove
					0, //deck start type
					false, false, false, false, false, null,null, true, use40ftIds,				// 26/08/2011 cnwmh5
					"West", "East", "North", "Sourth");
	
	create pDO transient;
	pDO.setProxy(false, true, pxyForkStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	foreach row in 1 to _rows do
		label := row.stringWithLeadingZeros(2);
		create pxyGridRow transient;
		pxyGridRow.setForProxy(row, label, pxyForkStack);
		foreach column in 1 to _columns do
			label := column.stringWithLeadingZeros(4);
			pxyGridCol := pxyForkStack.allGridColumns[column].CM_GridColumn;
			if pxyGridCol = null then
				create pxyGridCol transient;
				pxyGridCol.setForProxy(column, label, pxyForkStack);
			endif;
			
			create pxyStackCntrl transient;
			pxyStackCntrl.setForProxy(PAD_AVAILABLE, 
							NORMAL_USE, 
							pxyGridRow.row, 
							pxyGridCol.column,
							pxyGridRow.label &amp; pxyGridCol.label,
							2,
							power,											// 21/07/2015 cnwmh5
							false,
							null,
							pxyForkStack, false,null, false, null, false, null);
	

			pxyStackCntrl.setForProxyGridController(pxyGridRow.label &amp; pxyGridCol.label, 
								pxyGridCol,
								pxyGridRow,
								2);

		endforeach;
	endforeach;

	// 26/08/2011 cnwmh5
	pxyTA := pxyForkStack;
	// only do this if use40ftIds is set as returns correct location but slightly different format
	if use40ftIds then
		create pxyCMIFTerminalArea transient;
		pxyCMIFTerminalArea.numRows :=  _rows;
		pxyCMIFTerminalArea.numColumns := _columns;
		pxyCMIFTerminalArea.myPxyTerminalAreaMaster := pxyForkStack;
		pxyCMIFTerminalArea.startNumColumn := 1;
		pxyCMIFTerminalArea.startNumRow := 1;
		pxyCMIFTerminalArea.labelLengthCol := 4;
		pxyCMIFTerminalArea.labelLengthRow := 4;
		pxyCMIFTerminalArea.use40ftIds := use40ftIds;
		pxyCMIFTerminalArea.createProxyStructure();
		pxyTA := pxyCMIFTerminalArea.myPxyTerminalAreaMaster;
	endif;
		
	app.myTrxCA.trxCreateTerminalArea(pxyTA, realTA, app.myPassport);				// 26/08/2011 cnwmh5
	self.assertNoTrxErrorsOrWarnings();

	return realTA.CM_ForkLiftStack;
epilog
	delete pxyForkStack;
	delete pxyCMIFTerminalArea;
	if app.isValidObject(pDO) then
		delete pDO;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="CM_ForkLiftStack"/>
    </JadeMethod>
    <JadeMethod name="addFutureStorageMapping" id="580522e9-afe4-4847-abc6-15e88bbfc65f">
        <source>addFutureStorageMapping(_tasg : CM_TerminalAreaStorageGroup; _ild : CM_InvoiceLineDesc; _storageDetail : CM_StorageDetail) : CM_FutureStorageMapping;

vars
	proxyFSM	: CM_FutureStorageMapping;
