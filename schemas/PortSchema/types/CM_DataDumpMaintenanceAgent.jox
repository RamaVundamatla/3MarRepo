    <JadeMethod name="maintainDataDumpDefStoredProcs" id="5236116d-31dc-489e-9fe0-bf04d2c7471d">
        <source>maintainDataDumpDefStoredProcs();

/*

Purpose:		for par 32645 - set flag on data dump defs to get the stored procs rebuilt next process.

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2014	cnwrd1	Initial creation

*/

vars
	aDef : CM_DataDumpExtractDef;
begin

	beginTransaction;
	
	foreach aDef in  CM_DataDumpExtractDef.instances do
		aDef.setDefinitionModified(true);	
	endforeach;
	
	commitTransaction;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="maintainDataDumpFeatureUpdate" id="17df7575-07b4-4e35-8869-80ab84905ec0">
        <source>maintainDataDumpFeatureUpdate();
//PAR19114 DSS speed up cnwrs1 apr 2009
vars
	aClass : Class;
	ddFeature : CM_DataDumpFeature;
	featureAlias : String;
	newType : Type;
	newLength : Integer;
	ddClass: CM_DataDumpClass;
	newTypeName : String;
begin
	foreach ddClass in app.myRoot.allDataDumpClasses do
		aClass := ddClass.myClass;
		
        beginTransaction;
		foreach ddFeature in ddClass.allDataDumpFeatures do
			ddFeature.setAvailabilityForDSS();
			featureAlias := ddFeature.getExternalDatabaseFeatureName(aClass, newType, newLength);
			if newType &lt;&gt; null or
			   newLength &lt;&gt; null or
			   featureAlias &lt;&gt; ddFeature.featureName then
				newTypeName := null;
				if newType &lt;&gt; null then
					newTypeName := newType.name;
				endif;
		        ddFeature.setupFeatureChanges(featureAlias, newTypeName, newLength);
        	endif;
            if ddFeature.isRestrictedToExpose and not ddFeature.isOidBin then //cnwgb1 PAR 31663 11 June 2013
                app.raiseUnexpectedProgramError(class.name, method.name, 'The Feature ' &amp; aClass.name &amp; '::' &amp; ddFeature.featureName &amp; ' cannot be used in SQL Server, please correct');
            endif;
			
		endforeach;
		commitTransaction;
        
	endforeach;
epilog
end;</source>
    </JadeMethod>
