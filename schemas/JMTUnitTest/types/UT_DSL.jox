    <JadeMethod name="addCannonAtLocation" id="6baa7aa8-5bf8-4f3f-9c63-7f224b275032">
        <source>addCannonAtLocation(_id: String; _operator: CM_Operator; _location: Any): CM_TrackedItem;
//30 May 2008	cnwdw1	
// Create a Cannon and put it at a specified location
// 18/02/2016	cnwmh5	Change to return ti so can check for errors before returning, add test created by
vars
	cargoType: CM_CargoType;
	location: CM_LocationsController;
	ti : CM_TrackedItem;
begin
	location := getLocationsController(_location);
	cargoType := self.getCargoType("CANNON");
	self.deleteCargo(_id, cargoType);
	ti := location.createCargoAtLocation(cargoType, cargoType.mySystemProductType, _operator, _id);
	self.assertNoTrxErrorsOrWarnings();
	beginTransaction;
	ti.setRemarks(self.createdByUnitTest(ti.remarks), true);					// 15/09/2015 cnwmh5
	commitTransaction;
	return ti;
epilog
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="Any"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addCargoAtLocation" id="f59d0e60-ebe8-4821-9844-df9872379875">
        <source>addCargoAtLocation(_id: String; _cargoType: Any; _operator: CM_Operator; _location: CM_LocationsController): CM_TrackedItem;
//30 May 2008	cnwdw1	
// Create Cargo and put it at a specified location
//15 Feb 2024	navpw1	TFS: 59411 (62272) - Added support for Product
//16 Feb 2024	navpw1	TFS: 59411 (61867) - Added support for Train and wagons
//12 Sep 2024	navpw1	TFS: 65623 (65624) - Added support for quantity
//18 Sep 2024	navpw1	TFS: 65623 (65624) - Added support for weight
//04 Dec 2024	navcs2	MTN-33047 EUP - NTO-1000 - EUP - Additional Data Fields in EDI Operations


vars
	product  	: CM_Product;
	cargoType	: CM_CargoType;
	ti 	     	: CM_TrackedItem;
	
begin
	if _cargoType.isKindOf(CM_Product) then
		product   := _cargoType.CM_Product;
		cargoType := product.myCargoType;
	elseif _cargoType.isKindOf(CM_CargoType) then
		product   := _cargoType.CM_CargoType.mySystemProductType;
		cargoType := _cargoType.CM_CargoType;
	elseif _cargoType.isKindOf(String) then
		cargoType := self.getCargoType(_cargoType.String);
		product   := cargoType.mySystemProductType;
	endif;	
	
	// ### TFS 59411 (62272) 05Feb2024 NAVPW1
	if self.opts.includesKey(UT_OPTS_Product) then
		product := self.opts.obj(UT_OPTS_Product).CM_Product;
	endif;
	// ### TFS 59411 (62272) 05Feb2024 NAVPW1
	
	ti := _location.createNewCargoForLocation(cargoType, product, _id, _operator);
	
	if ti &lt;&gt; null then																	//27.07.2023 navma1
		beginTransaction;
			if self.opts.includesKey("CargoComodity") then
				ti.setCommodity(opts.str("CargoComodity"));
			endif;
			ti.setRemarks(self.createdByUnitTest(ti.remarks), true);					// 15/09/2015 cnwmh5
			if self.opts.includesKey(UT_OPTS_ImexStatus) then
				ti.setImExStatus(self.opts.int(UT_OPTS_ImexStatus));
			endif;
			if self.opts.includesKey(UT_OPTS_Train) then
				ti.setMyTrainAssigned(self.opts.obj(UT_OPTS_Train).CM_Train, app.myPassport);
			endif;
			if self.opts.includesKey(UT_OPTS_Quantity) then
				ti.setTotalQuantity(self.opts.int(UT_OPTS_Quantity));
			endif;
			if self.opts.includesKey(UT_OPTS_Weight) then
				ti.setTotalWeightWithoutTrans(self.opts.dec(UT_OPTS_Weight));
			endif;
			if self.opts.includesKey("quantity") then				//04 Dec 2024	navcs2	MTN-33047
				ti.setQuantity(self.opts.int("quantity"));			//04 Dec 2024	navcs2	MTN-33047
			endif;													//04 Dec 2024	navcs2	MTN-33047
		commitTransaction;
	endif;
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString()); //27.07.2023 navma1
	self.assertNoTrxErrorsOrWarnings();	
	
	return ti;
	
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Any"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addCargoAtLocationCommodity" id="5e1732ad-2ad2-46e8-9cbd-7ee8293f3d99">
        <source>addCargoAtLocationCommodity(_id: String; _cargoType: Any; _operator: CM_Operator; _location: CM_LocationsController): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2023	navpw1	Initial creation TFS: 61769 (61773)

*/

vars
	product			: CM_Product;
	cargoType		: CM_CargoType;
	pxyTI,
	realTI			: CM_TrackedItem;
	terminal		: CM_Terminal;
	passport		: CM_Passport;
	state,
	imexStatus		: Integer;
	moveController	: CMIF_MoveController;
	
begin
	//Check cargo type and product
	if _cargoType.isKindOf(CM_Product) then
		product   := _cargoType.CM_Product;
		cargoType := product.myCargoType;
	elseif _cargoType.isKindOf(CM_CargoType) then
		product   := _cargoType.CM_CargoType.mySystemProductType;
		cargoType := _cargoType.CM_CargoType;
	elseif _cargoType.isKindOf(String) then
		cargoType := self.getCargoType(_cargoType.String);
		product   := cargoType.mySystemProductType;
	endif;	
	
	//Get Passport
	passport := app.myPassport;
	terminal := passport.myTerminal;
	
	pxyTI := terminal.createTI(cargoType, true);
	
	if _id = null then
		pxyTI.zSetPxyId(_location.getTrackedItemID(product));
	else
		pxyTI.zSetPxyId(_id);
	endif;
	
	//pxyTI.zSetPxyOperator(operator);
	pxyTI.zSetPxyTerminal(terminal);
	passport.setMyTerminal(terminal);
	pxyTI.setCargoType(cargoType.id);
	pxyTI.setMyProduct(product);
	pxyTI.setMyOperator(_operator);
	
	imexStatus := TI_IMEX_STATUS_EXPORT;
	if self.opts.includesKey(UT_OPTS_ImexStatus) then
		imexStatus := self.opts.int(UT_OPTS_ImexStatus);
	endif;
	
	pxyTI.setImExStatus(imexStatus);
	
	if self.opts.includesKey(UT_OPTS_OnShip) and self.opts.bool(UT_OPTS_OnShip) then
		pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
	endif;
	
	if self.opts.includesKey(UT_OPTS_Commodity) then
		pxyTI.setCommodity(self.opts.str(UT_OPTS_Commodity));
	endif;
	
	if self.opts.includesKey(UT_OPTS_TotalQuantity) then
		pxyTI.setTotalQuantity(self.opts.int(UT_OPTS_TotalQuantity));
		pxyTI.zSetPxyQuantity(self.opts.int(UT_OPTS_TotalQuantity));
	endif;
	
	if self.opts.includesKey(UT_OPTS_TotalVolume) then
		pxyTI.setTotalVolumeWithoutTrans(self.opts.dec(UT_OPTS_TotalVolume));
	endif;
	
	if self.opts.includesKey(UT_OPTS_TotalWeight) then
		pxyTI.setTotalWeightWithoutTrans(self.opts.dec(UT_OPTS_TotalWeight));
	endif;
	
	if self.opts.includesKey(UT_OPTS_DestinationPort) then
		pxyTI.setDestinationPort(self.opts.str(UT_OPTS_DestinationPort));
	endif;
	
	if self.opts.includesKey(UT_OPTS_LoadPort) then
		pxyTI.setLoadPort(self.opts.str(UT_OPTS_LoadPort));
	endif;
	
	if self.opts.includesKey(UT_OPTS_DischargePort) then
		pxyTI.setDischargePort(self.opts.str(UT_OPTS_DischargePort));
	endif;
	
	if app.isSubTerminalsOn(terminal) then
		pxyTI.setSubTerminalDefaultFromTerm(terminal);
	endif;
	
	state := _location.getStateForNewCargo();
	
	if state = 0 then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Invalid State', null, null);
		return null;
	endif;
	
	if state = TI_STATE_ONSHIP and _location.isKindOf(CM_VoyageController) then
		pxyTI.setMyVoyage(_location.CM_VoyageController.myVoyage, passport);
	endif;
	
	pxyTI.changeState(state, passport);
	
	if ( pxyTI.isKindOf(CM_Bulk) and pxyTI.myCargoType.isTrackByWeight )
	or pxyTI.isKindOf(CM_BreakBulkGeneric)	//03 Oct 2017	NDL	TFS 5744
	then
		pxyTI.setTotalWeightWithoutTrans(1);
	endif;
	
	passport.warningsAcknowledged := true;
	passport.setIsBackgroundWarningsIgnored(true);
	
	create moveController transient;
	moveController.setMyToPrimaryLocation(_location);
	
	if process.isInTransactionState then
		app.myUtilityCA.utlCreateTrackedItem(pxyTI, realTI, passport);
		
		if not passport.noErrors() then
			return null;
		endif;
		moveController.setMyTrackedItem(realTI);
		
		realTI.setMyLocationsPublic(moveController);
		return realTI;
	else
	//create the persistent TI
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport);
		if passport.trxCompletedOK() then
			return realTI;
		endif;
	endif;
	
	if realTI &lt;&gt; null then
		beginTransaction;
			realTI.setRemarks(self.createdByUnitTest(realTI.remarks), true);
		commitTransaction;
	endif;
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNoTrxErrorsOrWarnings();	
	
	return realTI;
	
epilog
	delete moveController;
	
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Any"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addCargoAtLocationDetailed" id="fd2ecc62-667c-42c0-890c-7b7c7200de33">
        <source>addCargoAtLocationDetailed(_id: String; 
							_cargoType : CM_CargoType;
							_product: CM_Product; _location: CM_LocationsController;_dPort : String; _imex : Integer; _voyage : CM_Voyage; _op : CM_Operator): CM_Cargo;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		NAVAB1		Initial creation
*/

// Create Cargo and put it at a specified location
vars
	cargo: CM_Cargo;
	qty : Integer;
begin

	qty := 1;
	
	if self.opts.includesKey("TotalQuantity") then
		qty := self.opts.int("TotalQuantity");
	endif;
	
	if qty &lt;= 0 then
		qty := 1;
	endif;

	cargo := _location.createNewCargoForLCDetailed(_cargoType,_product, _id, _dPort, _imex, _voyage, _op, qty, null).CM_Cargo;
	self.assertNoTrxErrorsOrWarnings();										// 18/02/2016 cwmh5
	beginTransaction;														// 10/09/2015 cnwmh5
	cargo.setRemarks(self.createdByUnitTest(cargo.remarks), false);
	commitTransaction;
	return cargo;
epilog
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_dPort" type="String"/>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_op" type="CM_Operator"/>
        <ReturnType type="CM_Cargo"/>
    </JadeMethod>
    <JadeMethod name="addCargoBreakBulkAtLocation" id="a794a267-fdde-41f5-a539-170d626ff6de">
        <source>addCargoBreakBulkAtLocation(_id: String; _cargoType : CM_CargoType;	_quantity: Integer; _location: CM_LocationsController;
		_dPort : String; _imex : Integer; _voyage : CM_Voyage; _op : CM_Operator): CM_Cargo;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011			NAVAB1		Initial creation
29 Aug 2022			jlika1		TFS 54420 - PRP - Enstructure - Financial Requirements
08 Dec 2022 		navpw1 		TFS: 54571 - Added global constants for setting options
*/

// Create Cargo and put it at a specified location
vars
	cargo			: CM_Cargo;
	cargoSubType 	: CM_Product;	// ### TFS 54032 06JULY2022 NAVPW1
	
begin
	// ### TFS 54032 06JULY2022 NAVPW1
	if _cargoType.isSubCargoTypeRequired then
		if self.opts.includesKey(UTTI_CargoSubType) then
			cargoSubType := self.opts.obj(UTTI_CargoSubType).CM_Product;
		elseif self.opts.includesKey("Product") then
			cargoSubType := self.opts.obj("Product").CM_Product;
		endif;
		self.assertNotNullMsg(cargoSubType, "No Sub Cargo Type Specified. Cargo Type: '" &amp; _cargoType.abbreviation &amp; " requires a sub cargo type to be specified!" );
	endif;
	// ### TFS 54032 06JULY2022 NAVPW1
	
	//cargo := _location.createNewCargoForLCDetailed(_cargoType,null, _id, _dPort, _imex, _voyage, _op, 1).CM_Cargo;
	cargo := _location.createNewCargoForLCDetailed(_cargoType,cargoSubType, _id, _dPort, _imex, _voyage, _op, 1, null).CM_Cargo; 	// ### TFS 54032 06JULY2022 NAVPW1
	self.assertNoTrxErrorsOrWarnings();													// 18/02/2016 cnwmh5
	beginTransaction;
	cargo.setTotalQuantity(_quantity);
	cargo.setRemarks(self.createdByUnitTest(cargo.remarks), false);						// 09/09/2015 cnwmh5
	
	if self.opts.includesKey(UTTI_Length) then
		cargo.setLength(self.opts.dec(UTTI_Length));
	endif;
	if self.opts.includesKey(UTTI_Width) then
		cargo.setWidth(self.opts.dec(UTTI_Width));
	endif;
	if self.opts.includesKey(UTTI_Height) then
		cargo.setHeight(self.opts.dec(UTTI_Width));
	endif;
	// ### TFS 54571 08Dec2022 NAVPW1
	if self.opts.includesKey(UTTI_CommodityCode) then
		cargo.setCommodity(self.opts.str(UTTI_CommodityCode));
	endif;
	// ### TFS 54571 08Dec2022 NAVPW1
	
	commitTransaction;
	return cargo;
epilog
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_location" type="CM_LocationsController"/>
