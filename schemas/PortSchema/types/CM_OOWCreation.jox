    <JadeMethod name="setProxyAttribute" id="aff50451-9fe7-44b2-a237-6c88f911a639">
        <updating/>
        <source>setProxyAttribute(_srcOOWC : CM_OOWCreation; _attribute : String; _targetJS : CM_VoyageJobSheet;  _order, _subOrder : Integer; _is40 : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myBay := _srcOOWC.myBay;
	self.myCraneJobSheet := _targetJS;
	self.myVoyageStructure := _srcOOWC.myVoyageStructure;
	self.ordinalDeck := _srcOOWC.ordinalDeck;
	self.orderType := _subOrder;
	self.order := _order;

end;</source>
