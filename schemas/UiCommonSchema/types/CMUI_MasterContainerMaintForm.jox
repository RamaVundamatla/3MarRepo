*/

vars

begin
	inheritMethod();
	
	if self.hasChanged then
		if self.confirmCancel(app.getErrorString(The_Current_Item)) then
			self.unloadForm();
		else
			return;
		endif;
	else	
	self.unloadForm();
	endif;
	
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="6b019654-0e40-42b2-8447-d9279b41eadf">
