    <JadeMethod name="getDebtorForInvoiceLine" id="f799d080-68c0-4ce6-8320-be9cb52af932">
        <source>getDebtorForInvoiceLine(_invLineDesc : CM_InvoiceLineDesc) : CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
31 October 2019	jlgndl1	Initial creation	TFS 47100
18 Nov 2019 - 			TFS 47100, new way to get debtors
18 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	doLog : Boolean;
	debtor : CM_Debtor;
	debtorType : CM_DebtorType;
	lMessageText : String;
	myDebtorTypeCode : String;
	canLogExtra			: Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " STARTING", LogINFO.String);
	endif;
	
	if self.myBOL = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("myBOL = null", LogINFO.String);
		endif;
	endif;
		
	debtorType := _invLineDesc.myDebtorType;
	if debtorType = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("debtor type = null", LogINFO.String);
		endif;
	endif;
	
	if debtorType &lt;&gt; null and self.myBOL &lt;&gt; null then
		myDebtorTypeCode := debtorType.code;
		
		if myDebtorTypeCode = CM_DebtorType.DT_BOL_ITEM_FIRST_CONSEE then
			lMessageText := "Debtor for BOL First Item Consignee Charge";
			debtor := self.getDebtorFromConsignee;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_BOL_ITEM_FIRST_CONSOR then
			lMessageText := "Debtor for BOL First Item Consignor Charge";
			debtor := self.getDebtorFromConsignor;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_BOL_OPERATOR then
			lMessageText := "Debtor for BOL Operator Charge";
			debtor := self.getDebtorFromOperator;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_BOL_VOY_OPERATOR then
			lMessageText := "Debtor for BOL Voyage Operator Charge";
			debtor := self.getDebtorFromShipOperator;
			
		endif;
		
	endif;
	
	if debtor &lt;&gt; null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
		endif;
		if debtor.isSuspended then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(debtor.name &amp; " is suspended, not used", LogINFO.String);
			endif;
			debtor := null;
		endif;
	endif;
	
	if debtor = null then
		debtor := _invLineDesc.getDefaultDebtorFromTran(doLog,self);
	endif;

	return debtor;

epilog

end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorForSelector" id="bab591e6-99bc-4520-93ec-ab6b7c8a6bd1">
        <source>getDebtorForSelector():CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	invLine: CM_InvoiceLine;

begin

	if not self.allInvoiceLines.isEmpty then
		invLine := self.allInvoiceLines.first;
		if invLine.debtor &lt;&gt; null then
			return invLine.debtor;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromConsignee" id="12cb1ac1-29cc-48de-bc69-e87bb9ad8688">
        <source>getDebtorFromConsignee():CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2019	jlgndl1	Initial creation	TFS 47100 - default behaviour, can be re-implemented

*/

vars

	bolDtl: CM_BOLDtl;
	tmpConsigneeOr : CM_ConsigneeConsignor;

begin

	if self.myBOL = null then
		return null;
	endif;

	
	foreach bolDtl in self.myBOL.allBOLDtls discreteLock do
		if bolDtl.consigneeCode &lt;&gt; null then
			tmpConsigneeOr := app.myRoot.allConsigneeConsignors[bolDtl.consigneeCode];
			if tmpConsigneeOr &lt;&gt; null then
				return tmpConsigneeOr.debtor;
			endif;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromConsignor" id="f00df712-d0bf-462b-995b-1cc83e31d06e">
        <source>getDebtorFromConsignor():CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2019	jlgndl1	Initial creation	TFS 47100	default behaviour, can be re-implemented

*/

vars

	bolDtl: CM_BOLDtl;
