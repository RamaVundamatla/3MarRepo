    <JadeMethod name="setProxy" id="516e2618-fc5c-4993-9413-d9844137ee8d">
        <updating/>
        <source>setProxy(	_type : Integer; 
			_description : String; 
			_isYardPlanningAllowed:Boolean; 
			_isNotAvailableForEntry,
			_isNotAvailableSys	: Boolean;
			_root : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.type					:=	_type;
	self.isYardPlanningAllowed	:=	_isYardPlanningAllowed;
	self.isNotAvailableForEntry	:=  _isNotAvailableForEntry;
	self.isNotAvailableSys		:= 	_isNotAvailableSys;
	self.description			:=	_description;
	self.myRoot					:=	_root;

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isYardPlanningAllowed" type="Boolean"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isNotAvailableSys" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
