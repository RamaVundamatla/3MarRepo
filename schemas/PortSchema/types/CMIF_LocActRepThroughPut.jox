    <JadeMethod name="isToVessel" id="c76e3017-8bfb-4839-a2cb-d95af7145b58">
        <source>isToVessel(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin
	return self.modeInt.isOneOf( LocnActMoveDir_BargeToVessel, LocnActMoveDir_RailToVessel, LocnActMoveDir_YardToVessel );

