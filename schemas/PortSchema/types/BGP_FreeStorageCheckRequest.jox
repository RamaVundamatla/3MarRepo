        <Parameter name="_task" type="CM_AutoTask"/>
    </JadeMethod>
    <JadeMethod name="processCheckRequest" id="f3c14717-ed1a-4689-82ea-49827aebb028">
        <source>processCheckRequest() protected;
// --------------------------------------------------------------------------------
// Created:		03 May 2006 by cnwdad1
//
// Purpose:		Processes the receiver's request by iterating thru all of the Operators
//				and invoking the Free Storage Check "code hook" for each one.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalObj				: CM_Terminal;
	operatorTerminalObj		: CM_OperatorTerminal;
	trackedItemObj			: CM_TrackedItem;
	allTrackedItemsObj		: CM_TISet;
	
begin
	terminalObj	:=	self.myTerminal;
	create allTrackedItemsObj transient;
	
/*	foreach operatorTerminalObj in terminalObj.allOperatorTerminals do
		//operatorObj	:=	operatorTerminalObj.myOperator;
		//th2 for PAR 14641
		if operatorTerminalObj.emptyFreeStorageDays = 0
		and operatorTerminalObj.fullFreeStorageDays = 0
		then
			continue;
		endif;
		
		foreach trackedItemObj in operatorTerminalObj.allOnsiteTIsByCargoTypeId do
			if trackedItemObj.getContentsStatus() &lt;&gt; TI_CONTENTS_STATUS_EMPTY
			and trackedItemObj.isImport
			then
				allTrackedItemsObj.add(trackedItemObj);
			endif;
		endforeach;
	endforeach; */
	
	//23 Jul 2019	NDL	TFS 45574
	foreach operatorTerminalObj in terminalObj.allOperatorTerminals do
		foreach trackedItemObj in operatorTerminalObj.allOnsiteTIsByCargoTypeId do
			if trackedItemObj.getMatchingFreeStorageDetail( null ) = null then
				continue;
			endif;
			allTrackedItemsObj.add(trackedItemObj);
		endforeach;
	endforeach;
	
	app.myHookAgent.runHookLinkPublic(HookType_BGPFreeStorageCheck, self.myTerminal, self.myTerminal, allTrackedItemsObj);
epilog
	delete allTrackedItemsObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
