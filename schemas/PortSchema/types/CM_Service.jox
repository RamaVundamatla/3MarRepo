    <JadeMethod name="healthCheckIsValid" id="b6afc373-7c35-42c6-a19e-91a3b28c023e">
        <source>healthCheckIsValid(_agent : CMIF_InvoiceHealthAgent) : Boolean;
/*
Purpose:			
Date		Who		Reason
13 September 2016	cnwab1	Initial creation
*/
vars
	message : String;
	resultType : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
	bu : CM_Bank;
begin
	
	bu := self.getBank();
	if bu = null then
		return true;
	endif;
	if not _agent.allBusinessUnits.includes(bu) then
		return true;
	endif;
	
//	term := self.getMyTerminal();
//	if term = null then
//		return true;
//	endif;
//	if not _agent.allTerminals.includes(term) then
//		return true;
//	endif;
	// ### Calculation Type
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_CalcType)
	and not self.healthCheckObject(self.myCalculationType, resultType) then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_CalcType, self.name, CMIF_InvoiceHealthAgent.ItemType_Service, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	return inheritMethod(_agent);
epilog

end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
