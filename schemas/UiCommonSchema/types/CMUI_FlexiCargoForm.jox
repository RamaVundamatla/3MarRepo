    <JadeMethod name="isReceivalByType" id="39f7a416-64c1-422c-a72c-bc8e745a53b1">
        <source>isReceivalByType(): Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2010	cnwjk3	PAR 22518

*/

vars

begin
	if self.myPxyGTEEntity &lt;&gt; null and self.myPxyGTEEntity.isKindOf(CMGTE_ReceivalByType) then
		return true;
	else
		return false;
	endif;
