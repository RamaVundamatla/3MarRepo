    <JadeMethod name="trxDeleteTerminalBRXref" id="f4da38de-1418-46d3-a7fa-7d8872fce409">
        <updating/>
        <source>trxDeleteTerminalBRXref(_terminal : CM_Terminal input;
						_passport : CM_Passport input) updating;

/*

Purpose:			Delete the Booking Reference cross reference for the passed in Terminal

Parameters:			Terminal 

Return Value:		None


Date		Who		Reason
01 Sep 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

vars
	lockedXref,
	brXref			: CM_TerminalTIsByBR;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	// Start the transaction
	beginTransaction;
	
	// Reserve lock on CM_Terminal to single thread through the check for an existing
	// cross reference
	reserveLock(_terminal);
	brXref := _terminal.getBookingRefXref();
	
	// If the Booking Reference cross ref doesn't exist, then exit, there's nothing to do
	if _passport.noErrors() and brXref = null then
		return;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	// Firstly take a Session Duration reserve lock on the xref parent to stop other users
	// from trying to initiate a rebuild or delete
	self.lock(brXref, Reserve_Lock, Session_Duration, LockTimeout_Server_Defined);
	if _passport.hasErrors then
		return;
	endif;
	lockedXref := brXref;

	// Then delete any child objects in multi transaction mode
	self.doDeleteTerminalBRXrefObjects(_terminal, brXref, _passport);

	// And if there are no errors then delete the header
	if _passport.noErrors() then
		app.myUtilityDA.utlDeleteTerminalBRXref(_terminal, brXref, _passport);
	endif;

	
epilog		
	self.finaliseActivityWithPassport(_passport);

	// If we got the session lock, then we need to unconditionally release it AFTER the 
	// trx is committed
	if lockedXref &lt;&gt; null then
		self.unlock(lockedXref);
	endif;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
