    <JadeMethod name="validateCreate" id="097de1dd-9fda-4441-9818-a83d7c707457">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin

	self.validateUpdate(_passport);
	
	//24 Nov 2017	NDl	TFS 7792
	if self.myTerminal.machines[code] &lt;&gt; null then
		app.raiseCMException1(XLAT_is_is_machine, self.code, null, null);
	endif;
	
	//24 Nov 2017	NDl	TFS 7792
	if self.myTerminal.allWorkPointsByCode[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;


epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="2f165a94-5f3b-498b-abf4-224c21d02dd6">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwer1	Initial creation CCMS MES 1116
//11/04/2019 	JLGNS1		Bug 44243: PEL1 add inverses to prevent deleting consigniees if used in a WODCargoRequest
*/

vars

begin
	//inheritMethod(_passport);
	
	//24 Nov 2017	NDL	TFS 7792
	if not self.allCraneOpHrsExchange.isEmpty 
	or not self.allCraneOpHrsLabour.isEmpty 
	or not self.allDelays.isEmpty 
	or not self.allJobSheets.isEmpty 
	or not self.allKPIVoyageMoveDtls.isEmpty 
	or not self.allVoyageWorkPointQueues.isEmpty 
	or not self.allWodCargoRequests.isEmpty 		//Bug 44243
	then
		app.raiseCMException(This_workpoi_not_delete, null, null);
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="1abbea57-8e2f-46bc-ae91-a2447f2cfc09">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Code),null,null );
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Code),null,null ); // cnwdb2	PAR 35364
	endif;

	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Terminal),null,null );
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Terminal),null,null );
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
