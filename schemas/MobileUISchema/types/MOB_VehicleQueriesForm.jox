    <JadeMethod name="deleteAllCriteriaLines" id="9d3fb6d9-53a1-4836-a68e-1d6bbf7f7224">
        <source>deleteAllCriteriaLines() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwer1	Initial creation

*/

vars
	criteriaLine : JadeDynamicObject;
	sheet		:Sheet;
	fld			:Folder;
	frame		: Frame;
	label		: Label;
	searchA,
	searchB		: TextBox;
	optTrue,
	optFalse	: OptionButton;
begin
	if self.allCriteriaLines.size = 0 then
		return;
	endif;
	
	
	foreach criteriaLine in self.allCriteriaLines do
		label:=criteriaLine.getPropertyValue(CriteriaDescriptor).Label;
		if label &lt;&gt; null then
			delete label;
		endif;
		searchA:=criteriaLine.getPropertyValue(CriteriaSearchA).TextBox;
		if searchA &lt;&gt; null then
			delete searchA;
		endif;
		
		searchB:=criteriaLine.getPropertyValue(CriteriaSearchB).TextBox;
		if searchB &lt;&gt; null then
			delete searchB;
		endif;
		
		optTrue:=criteriaLine.getPropertyValue(CriteriaBoolTrue).OptionButton;
		if optTrue &lt;&gt; null then
			delete optTrue;
		endif;
		
		optFalse:=criteriaLine.getPropertyValue(CriteriaBoolFalse).OptionButton;
		if optFalse &lt;&gt; null then
			delete optFalse;
		endif;
		
		frame:=criteriaLine.getPropertyValue(CriteriaFrame).Frame;
		if frame &lt;&gt; null then
			delete frame;
		endif;
				
	endforeach;

	fld:=self.allCriteriaLines.first.getPropertyValue(self.CriteriaFolder).Folder;
	if fld &lt;&gt; null then
		delete fld;
	endif;
	
	
	self.allCriteriaLines.purge;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
