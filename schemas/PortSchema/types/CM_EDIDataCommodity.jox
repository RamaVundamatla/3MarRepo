    <JadeMethod name="verifyEDIDataTIs" id="2dbe1cc6-4213-4b23-8bcf-554771b537a8">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
18 Jul 2018	jlgrs1	TFS PLI01
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/
vars
	partsDone 			 : Integer;
	partsInJob 			 : Integer;
	progressStr 		 : String;
	progressTS 			 : TimeStamp;
	ediTI 				 : CM_EDITrackedItem;
	passport 			 : CM_Passport;
	terminal 			 : CM_Terminal;
	allAddCommodityorees : CM_CommodityArray;
	allUpdCommodityorees : CM_CommodityArray;
	allDelCommodityorees : CM_CommodityArray;
	pxyCommodityObj 	 : CM_Commodity;
	realCommodityObj 	 : CM_Commodity;
	ediCommodityTI 		 : CM_EDICommodityTI;
begin
	// Arm our base exception handlers.9
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible
	
	passport	:= _passport;
	partsInJob	:= self.allEDITrackedItems.size();
	partsDone	:= null;
	terminal	:= self.getMyTerminal();
	
	if terminal = null then
		// should never happen but just in case!
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return passport.allErrorWarnings.size();
	endif;
	
	progressStr	:= app.getString(Verifying_Loaded_Details, partsInJob.display());
	progressTS	:= app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
	create allAddCommodityorees transient;
	create allUpdCommodityorees transient;
	create allDelCommodityorees transient;
	
	foreach ediTI in self.allEDITrackedItems do
		partsDone			:= partsDone + 1;
		self.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, passport);
		
		// Now validate each ediTrackedItem.
		//self.zValidateEdiData(ediTI.CM_EDICommodityoreeTI, passport);
		
		ediCommodityTI	:=	ediTI.CM_EDICommodityTI;
		realCommodityObj	:=	app.myRoot.allCommodities[ediCommodityTI.code];
		
		if realCommodityObj = null then
			if ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				continue;
			endif;
			
			create pxyCommodityObj transient;
			ediCommodityTI.setProxyFromEDI(pxyCommodityObj);
			allAddCommodityorees.add(pxyCommodityObj);
		else
			if ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				allDelCommodityorees.add(realCommodityObj);
			else
				pxyCommodityObj	:=	app.createUpdateProxy(realCommodityObj).CM_Commodity;
				allUpdCommodityorees.add(pxyCommodityObj);
			endif;
		endif;
	endforeach;
	
	self.validateCommoditys(allAddCommodityorees, allUpdCommodityorees, allDelCommodityorees);
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
	return passport.allErrorWarnings.size();
epilog
	allAddCommodityorees.purge();
	allUpdCommodityorees.purge();
	
	delete allAddCommodityorees;
	delete allUpdCommodityorees;
	delete allDelCommodityorees;
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
