    <JadeMethod name="create" id="ec5423f5-e2a4-4965-be6b-7f735bbe9f3e">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues

*/

vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
epilog

end;</source>
    </JadeMethod>
