// ---------------------------------------------------------------------------
// Created:		04 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin

	if combobox.listObject &lt;&gt; null then
//		endNotification(self.filterTerminalArea, self.myTerminal.getTerminalEvent(EVENT_UPDATE_GRID_AREA)); // AKB2003MAY added
		self.endNotificationForSubscriber(self.tblData);
		self.filterTerminalArea := combobox.listObject.CM_TerminalArea;	

//		beginNotification(self.filterTerminalArea, self.myTerminal.getTerminalEvent(EVENT_UPDATE_GRID_AREA), Response_Continuous, null);// AKB2003MAY added
		self.tblData.beginNotification(self.filterTerminalArea, self.myTerminal.getTerminalEvent(EVENT_TI_MOVE_FROM_LOCATION), Response_Continuous, null); // PAR 10328 AKB2005JUL
		self.tblData.beginNotification(self.filterTerminalArea, self.myTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION), Response_Continuous, null); // PAR 10328 AKB2005JUL
	else
		self.filterTerminalArea := null;
	endif;

end;</source>
