    <JadeMethod name="doMnuCargoLabelPrint" id="3d13023b-2ade-44e3-8831-f1db89d18626">
        <source>doMnuCargoLabelPrint();
/*

Purpose:			Print Bar Code Labels

Parameters:			

Return Value:		

Date			Who		Reason
08 March 2010	conkc1	Initial creation
04/05/2010		cnwmh5	PAR23634 - Change to allow multiselect printing
*/
vars
	tiArray : CM_ObjectArrayActual;
	obj     : Object;
	control	: Control;
	table	: CM_GroupingTable;
	request : CM_Request;
	gateEntity : CMGTE_Entity;
begin

	table 	:= myCurrentTable.CM_GroupingTable;
	
	if table.allSelectedObjects.isEmpty and self.mnuPrintLabels.userObject = null then
		return;
	endif;
	
	create tiArray transient;
	
	foreach obj in table.allSelectedObjects do
		if obj.isKindOf(CM_YardWLE) then
			if obj.CM_YardWLE.myTrackedItem &lt;&gt; null and obj.CM_YardWLE.isReceipt then
				tiArray.add( obj.CM_YardWLE.myTrackedItem.CM_TrackedItem );
			endif;
		endif;
	endforeach;
	
	if self.mnuPrintLabels.userObject &lt;&gt; null then
		if not tiArray.includes(self.mnuPrintLabels.userObject.CM_TrackedItem) then
			tiArray.add( self.mnuPrintLabels.userObject.CM_TrackedItem );
		endif;
	endif;
	
	//02 Sep 2010	NDL	Par 25614 - Receiving Cargo with no ids (i.e. no tracked items yet.)
	if tiArray.isEmpty then
		foreach obj in table.allSelectedObjects do
			if obj.isKindOf(CM_YardWLE) then
				if obj.CM_YardWLE.isReceipt then
					request := obj.CM_YardWLE.myRequest;
					if request &lt;&gt; null and request.isKindOf(CM_YardRequest) then
						gateEntity := request.CM_YardRequest.myGateEntity;
						if gateEntity &lt;&gt; null then
							if gateEntity.isKindOf(CMGTE_Receival) or gateEntity.isKindOf(CMGTE_ReceivalByType) then
								tiArray.add( gateEntity );
							endif;
						endif;
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
	if tiArray.isEmpty then
		return;
	endif;
	
	self.myAssistant.showCargoIdLabelPrintForm(tiArray);
	
	/*
	if self.myCurrentWLE = null then
		return;
	endif;
	
	if self.myCurrentWLE.myTrackedItem = null then
		return;
	endif;
	
	create tiArray transient;

	tiArray.add( self.myCurrentWLE.myTrackedItem.CM_TrackedItem );
	
	self.myAssistant.showCargoIdLabelPrintForm(tiArray);
	*/
	
epilog

	delete tiArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuDisconnect" id="1c81c0a9-158e-4c57-81e8-74e08421ffef">
        <updating/>
        <source>doMnuDisconnect(_ti : CM_TrackedItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/01/2013	cnwdap1	Initial creation PAR #31018 CCMS POL 2223
*/
vars
	connectParams	: CMIF_ConnectParams;
	nowTimeStamp	: TimeStamp;
	noCharge		: Boolean;
	proxyTI			: CM_TrackedItem;
	loadState		: Boolean;
	txn				: CM_TITransaction;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if _ti = null then
		return;
	endif;
	nowTimeStamp := app.actualTimeServer;// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	app.cmsBeginLoad(loadState);
	proxyTI := _ti.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadState);
	
	//check time stamp will be after the last txn on the ti
	//have to do this to prevent on going time comaprison errors introduced
	//with the Time EditMask changes (i.e. uses can't input seconds!)
	txn := _ti.allTransactions.last;
	if txn &lt;&gt; null and txn.dateTime &gt; nowTimeStamp then
		if txn.dateTime.date = nowTimeStamp.date
		and txn.dateTime.time.hour = nowTimeStamp.time.hour
		and txn.dateTime.time.minute = nowTimeStamp.time.minute then
			//bump it by 1
			nowTimeStamp.setTime(txn.dateTime.time.addSeconds(1));
		endif;
	endif;
	
	create connectParams transient;
	connectParams.dateTime := nowTimeStamp;
	connectParams.noCharge := noCharge;
	connectParams.myTerminal := self.myTerminal;
	connectParams.myTrackedItem := proxyTI;
	connectParams.allTrackedItems.add(proxyTI);
	if connectParams.myTrackedItem &lt;&gt; null then
		connectParams.locationsController := connectParams.myTrackedItem.myPrimaryActualLocation;
	endif;
	connectParams.userId := app.getMyUserCode();
	connectParams.action := ACTION_DISCONNECT;
	connectParams.radioTelemetryUser := false;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateDisconnect(connectParams, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Disconnect', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
epilog
	app.cmsEndLoad(loadState);

	delete proxyTI;
	
	if connectParams &lt;&gt; null then
		connectParams.allTrackedItems.purge();
		delete connectParams;
	endif;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuRecClick" id="b808dcb7-2ad6-4af1-9325-72abc0ef8f90">
        <updating/>
        <source>doMnuRecClick(_sealCheck : Integer) : Boolean updating;
//27 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	gate : CM_Gate;
	pxyGate : CM_Gate;
	result : Integer;
begin
	if self.myCurrentRoadJob &lt;&gt; null then
		gate := self.myCurrentRoadJob.myGate;
	endif;
	
	if gate &lt;&gt; null then
		beginLoad;
			pxyGate := gate.pxyCreateUpdateProxy();
		endLoad;
		
		pxyGate.setSealCheckReceival(_sealCheck);
		
		while true do 
			app.myTrxUA.trxUpdateGate(pxyGate, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				return true;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
		return false;
		endwhile;
	endif;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	if pxyGate &lt;&gt; null then
		pxyGate.erase(NORMAL_ERASE);
	endif;
end;</source>
        <Parameter name="_sealCheck" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuRelClick" id="3f460af1-bfbe-443f-a1bc-57bc57f9fd87">
        <updating/>
        <source>doMnuRelClick(_sealCheck : Integer) : Boolean updating;
//27 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	gate : CM_Gate;
	pxyGate : CM_Gate;
	result : Integer;
begin
	if self.myCurrentRoadJob &lt;&gt; null then
		gate := self.myCurrentRoadJob.myGate;
	endif;
	
	if gate &lt;&gt; null then
		
		beginLoad;
			pxyGate := gate.pxyCreateUpdateProxy();
		endLoad;
		
		pxyGate.setSealCheckRelease(_sealCheck);
		
		while true do
			app.myTrxUA.trxUpdateGate(pxyGate, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				return true;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
		return false;
		endwhile;
	endif;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	if pxyGate &lt;&gt; null then
		pxyGate.erase(NORMAL_ERASE);
	endif;
end;</source>
        <Parameter name="_sealCheck" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMove_ForMode" id="a8592697-1674-484a-8e57-ab82322edc1d">
        <updating/>
        <source>doMove_ForMode(_moveMode : Integer; _all : Boolean) updating, protected;
//-----------------------------------------
// Created: May 2003 By: cnwgd1
//nds TFS 2867 17/01/17PKT - Bulk Process
// 28 June 2018	jlgrh7 TFS 39153 PKT - Priority 1 Issue in JMT - Gate out error
//15/08/2019 	JLGNS1	ChangeRequest 45889: PEN - Move All Command in Road Operation
//-----------------------------------------
vars
	wleArray,
	wlesWithWarnings : CM_WLEArray;	
	result	: Integer;
	wleTable : CM_DataTable;
	includeBulkVisitWLEs :Boolean;	//nds TFS 2867 17/01/17 PKT - Bulk Process
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create wleArray transient;
	
	// cnwjk3 PAR 17951 - 31 October 2008 - current table now associated with last mouse click
	wleTable := self.myCurrentTable;
	if wleTable = null then
		if self.mnuTableContext.userObject.CM_DataTable = null then
			return;
		else
			wleTable:=self.mnuTableContext.userObject.CM_DataTable;
		endif;
	endif;
	
//	includeBulkVisitWLEs := _moveMode &lt;&gt; REAL_MODE;								//nds TFS 2867 17/01/17PKT - Bulk Process			//-TFS39153
	includeBulkVisitWLEs :=  false;																																											//+TFS39153 Alway not allowed to use the Queue All Functio for Bulk Item
	if _all then
		if _moveMode = REAL_MODE then																																//ChangeRequest 45889
			if 	app.msgBox(app.getErrorString(Sure_want_move)  ,app.getErrorString(WLES_MOVE_ALL),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then//ChangeRequest 45889
				return;																																				//ChangeRequest 45889
			endif;																																					//ChangeRequest 45889
		endif;																																						//ChangeRequest 45889
	
		self.getAllWLEsInTable(wleArray,wleTable,includeBulkVisitWLEs );		//nds TFS 2867 17/01/17PKT - Bulk Process
	else
		self.getAllWLEsInTableSelected(wleArray,wleTable,includeBulkVisitWLEs);	//nds TFS 2867 17/01/17PKT - Bulk Process
	endif;
	
	create wlesWithWarnings transient;

	while true do
		app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, _moveMode, false, null,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				//do show it here, ask Q below.
				result := 1;				
			else
				result := app.showErrorWarningDialog('Operations Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			endif;
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;	
				continue;
			endif;
		endif;
		break;
	endwhile;	

	if app.myPassport.returnCode = INFO_NO_AUTOPLAN then
		if app.msgBox(app.getErrorString(app.myPassport.returnCode), "Information",
					 MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
		
epilog
	delete wlesWithWarnings;
	delete wleArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMove_Unplan" id="95f0e3ee-8eff-4886-b975-3f1a6f1cad45">
        <updating/>
        <source>doMove_Unplan(_all : Boolean) updating, protected;
//-----------------------------------------
// Created: Feb 2002 By: cnwgd1
//nds TFS 2867 17/01/17 PKT - Bulk Process
//-----------------------------------------
vars
	result : Integer;
	wlesWithWarnings,
	wleArray : CM_WLEArray;
	wleTable : CM_DataTable;
begin
	app.mousePointer := MousePointer_HourGlass;	
	create wleArray transient;
	create wlesWithWarnings transient;
	
	wleTable:=self.mnuTableContext.userObject.CM_DataTable;
	if wleTable = null then
		return;
	endif;

	if _all then
		self.getAllWLEsInTable(wleArray,wleTable,true);//nds TFS 2867 17/01/17 PKT - Bulk Process
	else
		self.getAllWLEsInTableSelected(wleArray,wleTable,true);//nds TFS 2867 17/01/17 PKT - Bulk Process
	endif;

	while true do
		app.myTrxUA.trxUpdateWLEsUnplan(wleArray, wlesWithWarnings, NO_MODE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog 
	delete wleArray;
	delete wlesWithWarnings;
	app.mousePointer := MousePointer_Default;		
end;</source>
        <access>protected</access>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMove_Unqueue" id="7086fd59-d64d-4e48-a018-189f6eba2091">
        <updating/>
        <source>doMove_Unqueue(_all : Boolean) updating, protected;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//nds TFS 2867 17/01/17 PKT - Bulk Process
//-----------------------------------------

vars
	result : Integer;
	wleArray,
	wlesWithWarnings : CM_WLEArray;
	wleTable : CM_DataTable;
begin
	app.mousePointer := MousePointer_HourGlass;	
	create wleArray transient;
	create wlesWithWarnings transient;
	
	wleTable:=self.mnuTableContext.userObject.CM_DataTable;
	if wleTable = null then
		return;
	endif;

	if _all then
		self.getAllWLEsInTable(wleArray,wleTable,true);//nds TFS 2867 17/01/17 PKT - Bulk Process
	else
		self.getAllWLEsInTableSelected(wleArray,wleTable,true);//nds TFS 2867 17/01/17 PKT - Bulk Process
	endif;

	while true do
		app.myTrxUA.trxUpdateWLEsUnqueue(wleArray, wlesWithWarnings, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Unqueue', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog 
	app.mousePointer := MousePointer_Default;	
	delete wleArray;
	delete wlesWithWarnings;
end;</source>
        <access>protected</access>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNoteHandlingObject" id="024e48e1-d803-4f42-bab1-d58bd6d73fbc">
        <updating/>
        <source>doNoteHandlingObject(_cmifNoteRecord: CMIF_NotificationRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2025	navkc1 	JIRA Story MTN-34156: MTN | Road Operations - Handle Notifications
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	idx					: Integer;
	vehicle 			: CM_Vehicle;
	roadJob 			: CM_RoadJob;
	expanded 			: Boolean;
	tmpTable			: CM_GroupingTable;
	cmifRoadOpObject 	: CMIF_RoadOpObject;
	displayed   		: Boolean;
	deletedObject 		: Boolean;
	expandedObjects 	: ObjectSet;
	invalid 			: Boolean;
	gate 				: CM_Gate;
	operator 			: CM_Operator;
	event				: Integer;
	object				: CM_Object;
begin
	
	event := _cmifNoteRecord.eventType;
	
	//27/03/2025	navkc1 JIRA Story MTN-34156
	if _cmifNoteRecord.myUserInfo &lt;&gt; null then
		object := _cmifNoteRecord.myUserInfo.CM_Object;
	endif;
	global.cnwer1Write(method.name &amp; Tab &amp; event.String &amp; Tab &amp; _cmifNoteRecord.eventTag.String);
	
	if not global.isValidObject(object) then
		if event = WLE_Delete_Event then
			self.myRoadOpController.handleUserNotification(event,object);
		endif;
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalid );
	if object.isKindOf(CM_Vehicle) then
		vehicle := object.CM_Vehicle;
		roadJob := vehicle.allRoadJobs.first.CM_RoadJob;
		
	elseif object.isKindOf(CM_RoadJob) then
		roadJob := object.CM_RoadJob;
		vehicle := roadJob.myVehicle;
		
	elseif object.isKindOf(CM_WorkListEntry) then
		if object.CM_WorkListEntry.job &lt;&gt; null and object.CM_WorkListEntry.job.isKindOf(CM_RoadJob) then
			roadJob := object.CM_WorkListEntry.job.CM_RoadJob;
		endif;
		
	elseif object.isKindOf(CM_RFIDTag) then
		if event = Event_RFIDTagInUse then
			roadJob := object.CM_RFIDTag.myRoadJob;
			
			if roadJob &lt;&gt; null then
				vehicle := roadJob.myVehicle;
				
				if vehicle &lt;&gt; null then
					self.myRoadOpController.handleUserNotification(Vehicle_Update_Event,vehicle);
				endif;
			endif;
		endif;
		return;
		
	elseif event = Event_GateLane_Change then
		self.doLaneRefresh(); 
		return;
	endif;
	
	if roadJob = null then
		if event &lt;&gt; RoadJob_Delete_Event and event &lt;&gt; Vehicle_Update_Event then
			return;
		endif;
	else
		if roadJob.status = JOB_UNVERIFIED or roadJob.status = JOB_TROUBLE then
			return;
		endif;
	endif;
	
	if self.dkcVehicles.visible then
		if event = RoadJob_Delete_Event or roadJob = null then
			idx := self.lstJobs.findObject(vehicle);
			
			if idx &gt; 0 then
				self.lstJobs.clearBelowLevel(idx);
				self.lstJobs.removeItem(idx);
			endif;
			
		elseif event = RoadJob_Create_Event then
			if roadJob &lt;&gt; null then
				self.lstJobsAddRoadJob(roadJob);		
			endif;
			
		elseif event = RoadJob_Update_Event then
			idx := self.lstJobs.findObject(vehicle);
			if idx &gt; 0 then 
				expanded :=	self.lstJobs.itemExpanded[idx];
				create expandedObjects transient;
				if expanded then
					self.getExpandedForByCriteriaList( expandedObjects, vehicle, false );
				endif;
				self.lstJobsUpdateVehicle(vehicle, expanded, false, expandedObjects);
			else
				if roadJob &lt;&gt; null then
					self.lstJobsAddRoadJob(roadJob);		
				endif;
			endif;
			
		elseif (event = Vehicle_Update_Event or event = Vehicle_VTA_Area_Update) and  vehicle &lt;&gt; null then 
			idx := self.lstJobs.findObject(vehicle);	
			
			if idx &gt; 0 then 
				expanded :=	self.lstJobs.itemExpanded[idx];
			endif;
			
			create expandedObjects transient;
			if expanded then
				self.getExpandedForByCriteriaList( expandedObjects, vehicle, false );
			endif;
			
			if optGate.value then
				if roadJob &lt;&gt; null then
					gate := roadJob.myGate;
				endif;
				if not allGates.includes(gate) then
					return;
				endif;
			elseif optOperator.value then
				if roadJob &lt;&gt; null then
					operator := roadJob.myOperator;
				endif;
				if not allOperators.includes(operator) then
					return;
				endif;
			else
				self.lstJobsUpdateVehicle(vehicle, expanded, false, expandedObjects);
			endif;
			
		endif;
	endif;
	
	if not global.isValidObject(self.myCurrentWLE) then
		self.myCurrentWLE := null;
	endif;
	
	self.myRoadOpController.handleUserNotification(event, object);

epilog
	if self.dkcVehicles.visible then
		
		delete expandedObjects;
		
		on Exception do app.handleDeletedObject (exception, self.myCurrentTable.allSelectedObjects.last, deletedObject);
		foreach cmifRoadOpObject in self.myRoadOpController.allCMIFRoadOpObjects discreteLock do	
			tmpTable := self.tblStage.getControl((cmifRoadOpObject.getDockOrder.String &amp; tblStage.tabIndex.String).Integer);
			if tmpTable = self.myCurrentTable and not self.myCurrentTable.allSelectedObjects.isEmpty() then
				if not deletedObject then
					displayExtraInfoForObj(self.myCurrentTable.allSelectedObjects.last.CM_Object);
					displayed := true;
				endif;
			endif;
		endforeach;
	endif;
	
	if not displayed then
		if self.dkbMacro.visible then
			displayExtraInfoForObj(null);
		endif;
	endif;
	endLoad;
end;</source>
        <Parameter name="_cmifNoteRecord" type="CMIF_NotificationRecord"/>
    </JadeMethod>
    <JadeMethod name="doNoteRefresh" id="72793b71-9fb1-4185-b878-6c7f120cf231">
        <updating/>
        <source>doNoteRefresh() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2025	navkc1 JIRA Story MTN-34156: MTN | Road Operations - Handle Notifications

*/

vars

begin
	self.doRefresh();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOperatorAdd" id="166d82b9-e992-4aed-9479-a9e40035af88">
        <updating/>
        <source>doOperatorAdd() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2022	navlw1	Initial creation
27/07/2022 navmv20 Bug 54200: EUP - Lists showing Operator/Stevedore codes rather than Name

*/

vars
	int				: Integer;
	operator		: CM_Operator;
	coll			: CM_IntegerArray;
	invalidObject 	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, operator, invalidObject);
	create coll transient;
	
	lstOperators_Avail.getSelectedEntries (coll);
	
	foreach int in coll do
		operator	:= lstOperators_Avail.itemObject[int].CM_Operator;
		// add to selected list
		// 27/07/2022 navgm20 TFS 54200 -start
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then    
			int := lstOperators_Sel.addItem (operator.description);
		else                                                       
			int := lstOperators_Sel.addItem (operator.code); 
		endif;    
		// 27/07/2022 navgm20 TFS 54200 -end		
		//int := lstOperators_Sel.addItem (operator.code); //27/07/2022 navgm20 TFS 54200
		
		if invalidObject then	
			invalidObject	:= false;
			continue;					
		endif;							
		
		lstOperators_Sel.itemObject[int] := operator;
		
	endforeach;
	lstOperators_Avail.removeSelectedObjects;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOperatorAddAll" id="b70bbf65-9474-41f1-b644-399bdab981dd">
        <updating/>
        <source>doOperatorAddAll() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2022	navlw1	Initial creation TFS# 52455
27/07/2022 navmv20 Bug 54200: EUP - Lists showing Operator/Stevedore codes rather than Name
*/

vars
	listBoxCount 		: 	Integer;
	operator 			:	CM_Operator;
	invalidObject		: 	Boolean;
	count 				:	Integer;
	countSelectedItems 	: 	Integer;
begin
	on Exception do app.handleDeletedObject (exception, operator, invalidObject);
	listBoxCount := lstOperators_Avail.listCount;
	countSelectedItems := lstOperators_Sel.listCount;
	
	count := 1;
    while count &lt;= listBoxCount do
		countSelectedItems += 1;
		operator := lstOperators_Avail.itemObject[count].CM_Operator;
		// 27/07/2022 navgm20 TFS 54200 -start
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then    
			lstOperators_Sel.addItem (operator.description);
		else                                                       
			lstOperators_Sel.addItem (operator.code); 
		endif;   
		// 27/07/2022 navgm20 TFS 54200 -end
		//lstOperators_Sel.addItem(operator.code); // 27/07/2022 navgm20 TFS 54200
		if invalidObject then			
			invalidObject	:= false;	
			continue;					
		endif;
		lstOperators_Sel.itemObject[countSelectedItems] := operator;
		count += 1;
    endwhile;
	lstOperators_Avail.clear;
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOperatorRemove" id="fd36b93d-f23a-49c8-933a-908657453b2f">
        <updating/>
        <source>doOperatorRemove() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2022	navlw1	Initial creation TFS# 52455
27/07/2022 navmv20 Bug 54200: EUP - Lists showing Operator/Stevedore codes rather than Name
*/

vars
	int				:	Integer;
	operator		:	CM_Operator;
	coll			:	CM_IntegerArray;
	invalidObject 	:	Boolean;
begin
	on Exception do app.handleDeletedObject (exception, operator, invalidObject);
	create coll transient;
	
	lstOperators_Sel.getSelectedEntries (coll);
	
	foreach int in coll do
		invalidObject	:= false;
		
		operator := lstOperators_Sel.itemObject[int].CM_Operator;
		// 27/07/2022 navgm20 TFS 54200 -start
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then    
			int := lstOperators_Avail.addItem (operator.description);
		else                                                       
			int := lstOperators_Avail.addItem (operator.code); 
		endif;     
		// 27/07/2022 navgm20 TFS 54200 -end
		
		// add to available list
		//int := lstOperators_Avail.addItem (operator.code); //27/07/2022 navgm20 TFS 54200
		
		if not invalidObject then	
			lstOperators_Avail.itemObject[int] := operator;
		endif;						
		
	endforeach;
	
	lstOperators_Sel.removeSelectedObjects;
epilog
	//btnOperator_Remove.enabled	:= false;
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOperatorRemoveAll" id="03322599-eb71-4ce7-b6c8-ae461ac71c9d">
        <updating/>
        <source>doOperatorRemoveAll() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2022	navlw1	Initial creation TFS# 52455
27/07/2022 navmv20 Bug 54200: EUP - Lists showing Operator/Stevedore codes rather than Name
*/

vars
	operator			: 	CM_Operator;
	invalidObject		: 	Boolean;
	listBoxCount 		: 	Integer;
	count 				: 	Integer;
	countAvailableItems : 	Integer;
begin
	on Exception do app.handleDeletedObject (exception, operator, invalidObject);
	listBoxCount := lstOperators_Sel.listCount;
	countAvailableItems := lstOperators_Avail.listCount;
	
	count := 1;
    while count &lt;= listBoxCount do
		countAvailableItems +=1;
		operator := lstOperators_Sel.itemObject[count].CM_Operator;
		
		// 27/07/2022 navgm20 TFS 54200 -start
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then   
			lstOperators_Avail.addItem (operator.description);
		else                                                       
			lstOperators_Avail.addItem (operator.code); 
		endif;    
		// 27/07/2022 navgm20 TFS 54200 -end		
		//lstOperators_Avail.addItem(operator.code); // 27/07/2022 navgm20 TFS 54200
		if invalidObject then
			continue;			
		endif;
		lstOperators_Avail.itemObject[countAvailableItems] := operator;
		count += 1;
    endwhile;
	lstOperators_Sel.clear();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrint" id="28abe638-e3a4-4100-8214-8799c9047097">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:     14 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theReport		: CMUI_ReportLine;
	theCode			: String;
	pxyJadeReport	: JadeReport;
	tblPrintParams	: CMIF_PrintTableParams;
//	tblClone	
begin
//
//
//		######  CHANGE THIS TO USE THE GENERIC TABLE PRINT  ######
//
//
	create theReport transient;
	theReport.initReport;
	theReport.lblTitle01.caption 		:= self.caption;
	theReport.lblTitle03.caption 		:=  '';
	theReport.lblTitle02.caption 		:= ''; 
	theReport.lblTitle04.caption 		:= "";
	theReport.lblPrintedBy.caption 		:= null;
	theReport.lblPrintedBylbl.caption 	:= null;
	
	app.printer.setHeader(theReport.frHeader);
	app.printer.setFooter(null);
	app.printer.suppressDialog := true;

	create tblPrintParams transient;
	tblPrintParams.closePrinter := true;
	tblPrintParams.jadeReport := pxyJadeReport;
	tblPrintParams.newReport := true;
	tblPrintParams.printFrame := self.frmReport;
	tblPrintParams.printLabel := self.lblReport;
	tblPrintParams.title := self.caption[1:100];
	tblPrintParams.useSmallFont := true;
//should really add something to entTableDef &gt; report col width, report col heading?
	tblPrintParams.colWidths.setFromDelimitedString("0/65/65/65/90/65/65/40/0/65/65/65/0/65/65/65/65/65/65/65/65");

	app.printer.orientation := Print_Landscape;
	
//EPR NEED TO FINISH
//	self.tblWorkEntries.doPrintTable(tblPrintParams);

	self.doPrintDriversReceipt();

epilog
	self.doResize();
	delete theReport;
	delete tblPrintParams;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintDriversReceipt" id="dc9e67dd-b3bf-4708-bdce-e464d8c7b8eb">
        <updating/>
        <source>doPrintDriversReceipt()updating;
//--------------------------------------------------------------
//Created: 28 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	job 	: CM_RoadJob;
	dialog	: CMUI_ReceiptCopies;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

begin
	
	if self.myCurrentRoadJob = null then
		return;
	endif;
	
	job := self.myCurrentRoadJob;
	
	create dialog transient;
	dialog.init(false, 1);
	dialog.centreWindow;
	if dialog.showModal &lt;&gt; MsgBox_Return_OK then
  		return;		
  	endif;

	app.mousePointer := MousePointer_HourGlass;	
	sharedLock(job);

	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateRoadJobPrintReceipt(job, dialog.copies, dialog.printPreview, true, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Road Receipt', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete dialog;
	if job &lt;&gt; null then
		unlock(job);
	endif;
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doProcessRoadExit" id="d7e7f763-d254-4093-a445-ecdacdc3dcb8">
        <updating/>
        <source>doProcessRoadExit(_object : Object)updating, protected;
/*--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
// 15/09/2009	cnwcs5	ccms 1061 - do not let them do road exit if they have an outward p-check to go through
//						Replace literals with translatable strings

24 Aug 2012	cnwer1	CCMS 1280 CASH - had to be able to acknowledge warnings tidied up method a bit
25/02/2025	naviv1	JIRA-29374- EUP | Transaction Instrumentation - Gate
16 Jun 2025	navbs1	Story MTN-34429: MTN - DeadLock Retry Required for trxVehicleRoadExit
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/
vars
	theVehicle		: CM_Vehicle;
	theRoadJob		: CM_RoadJob;
	theWLE			: CM_WorkListEntry;
	alertCreated	: Boolean;
	userResponse	: Integer;
	invalidJob,
	invalidWLE		: Boolean;	
	visit 			: CM_VehicleVisitRecord;
	printReceipt 	: Boolean;
	preview 		: Boolean;
	copies 			: Integer;
	showWeighForm	: Boolean;	//08 Jul 2019	NDL	TFS 44965
	weighBridge		: CM_WeighBridgeObj;	//08 Jul 2019	NDL	TFS 44965
	
begin
	
	on Exception do app.handleDeletedObject(exception, theRoadJob, invalidJob);	// PAR 17757
	on Exception do app.handleDeletedObject(exception, theWLE, invalidWLE);		// 14/03/2013 cnwar2 #30578
	
	if not app.myCurrentUserCan(self.myTerminal, PmGteRoadExitUpdate) then
		app.msgBox(app.getErrorString (NoPermission2), self.mnuProcessRoadExit2.caption, MsgBox_OK_Only);
		return;
	endif;	

	app.mousePointer := MousePointer_HourGlass;		

	if self.myTerminal.getConfig(GateInAutoCompleteBkgrnd).Boolean then
		app.myTrxUA.trxRoadJobCompleteReceipt(app.myPassport, alertCreated);
		if app.myPassport.hadDeadlock = true then							//16.06.2025 navbs1 #34429
			return;
		endif;
		if (not app.myPassport.trxCompletedOK) then
			app.showErrorWarningDialog(self.mnuProcessRoadExit2.caption, app.myPassport, ErrWarnMode_Update);
			return;
		endif;
	//	return;	//20 July 2015	NDL	Par 36523 - needs to carry on so it can process the release items.
	endif;
	
	if _object &lt;&gt; null then
		//only ever Vehicle or WLE
		if _object.isKindOf(CM_Vehicle) then
			theVehicle  := _object.CM_Vehicle;		
		elseif _object.isKindOf(CM_WorkListEntry) then
			theWLE 		:=_object.CM_WorkListEntry;
			theRoadJob	:= theWLE.job.CM_RoadJob;
		endif;
	else
		if self.myCurrentVehicle &lt;&gt; null then
			theVehicle := self.myCurrentVehicle;
		elseif self.myCurrentRoadJob &lt;&gt; null then
			theRoadJob := self.myCurrentRoadJob;
		elseif self.myCurrentWLE &lt;&gt; null then
			theRoadJob := self.myCurrentWLE.job.CM_RoadJob;			
		endif;
	endif;
	
	if theRoadJob = null and theVehicle &lt;&gt; null then
		theRoadJob:= theVehicle.allRoadJobs.first.CM_RoadJob;
	endif;
	
	if theVehicle = null and theRoadJob &lt;&gt; null then
		theVehicle:=theRoadJob.myVehicle;
	endif;
	
	if theVehicle = null then
		app.msgBox(app.getErrorString (XLAT_Select_VehicleJob), self.mnuProcessRoadExit2.caption, MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	// Look thru all of its road jobs set and check if any of them still have any devices in their working devices IDs collection.
	if theRoadJob &lt;&gt; null and theRoadJob.status &lt;&gt; JOB_COMPLETE then
		if theRoadJob.allWorkingDeviceIDs.cnEcIsNotEmpty() then
			userResponse	:=	app.msgBox(	app.getErrorString (XLAT_RoadExit_Warning1), app.getString(Warning), MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
			if userResponse &lt;&gt; MsgBox_Return_Yes then
				return;
			endif;
		endif;
	endif;
	
	if not invalidJob and theRoadJob &lt;&gt; null then
		if theRoadJob.status &lt;&gt; JOB_COMPLETE then
			if theRoadJob.autoComplete then
				//Don't display the message box
				app.msgBox(app.getErrorString (XLAT_Road_Exit_Error1), self.mnuProcessRoadExit2.caption, MsgBox_Information_Icon + MsgBox_OK_Only);
				return;
			else
				app.msgBox(app.getErrorString (XLAT_Road_Exit_Error2), self.mnuProcessRoadExit2.caption, MsgBox_Information_Icon + MsgBox_OK_Only);
				return;	
			endif;
		endif;	
	endif;

	if invalidJob then
		app.msgBox(app.getErrorString (XLAT_Select_VehicleJob), self.mnuProcessRoadExit2.caption, MsgBox_Information_Icon + MsgBox_OK_Only);
		return;	
	endif;
	
	// if the vehicle is going out a gate that has a p-check lcation then 
	if not self.doProcessRoadExit_CheckLocn (theVehicle) then
		return;
	endif;
	
	//08 Jul 2019	NDL	TFS 44965
	visit := theVehicle.visitRecords.last(); 
	if visit&lt;&gt; null and visit.hasWeighInVVRD &lt;&gt; null then
		//check we have an inward weight, cos can't do two reading outward processing without one...
		weighBridge := self.myTerminal.allWeighBridges.getMyTwoReadingsWeighBridge();
		if weighBridge &lt;&gt; null then
			//we do have a 'two readings' weigh bridge, are the rest of the stars aligned.
			showWeighForm := visit.autoShowWeighBridgeAtGate();
			if showWeighForm then
				self.myAssistant.showWeighForm( self, theVehicle, null, null );
			endif;
		endif;
	endif;

	//epr 24/8/12 loop so can acknowledge warnings
	while true do
		app.myTrxDA.trxVehicleRoadExit(theVehicle, app.myPassport);
		if app.myPassport.hadDeadlock = true then					//16.06.2025 navbs1 #34429
			return;
		endif;
		if (not app.myPassport.trxCompletedOK) then
			userResponse:=app.showErrorWarningDialog(self.mnuProcessRoadExit2.caption, app.myPassport, ErrWarnMode_AddUpdate+ ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				userResponse = IDOK then
				app.myPassport.warningsAcknowledged     := true;
				continue;
			else
				return;
			endif;
		endif;
		break;
	endwhile;
	
	//cnwjo3 par 24747.
	printReceipt := self.myTerminal.getConfig(GateReceiptRequired).Boolean;
	//last resort.  Get last vehicle visit record instead of road job's vehicle visit.
	visit := theVehicle.visitRecords.last();	
	if visit &lt;&gt; null and printReceipt then
		copies := self.myTerminal.getConfig(GateReceiptCopies).Integer;
		preview := self.myTerminal.getConfig(PrintPreview).Boolean;
		if copies &gt; 0 then
			visit.printRoadReceipt(	copies,	//_copies : Integer;
									preview,	//_printPreview : Boolean;
									null	//_printerLogicalName : String
									);
		endif;
	endif;
	
	global.beep;		
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doProcessRoadExitDLRT" id="a3a9d75f-aec8-4604-b821-03738f7d27a3">
        <updating/>
        <source>doProcessRoadExitDLRT(_object : Object) updating;
/*
Purpose:			DLRT = DEAD LOCK RE-TRY. If get a dead lock the transaction will be aborted and this method will pause, loop round and retry the TRX. It will do this 10 times

Date		Who		Reason
16 Jun 2025	navbs1	Initial Creation Story MTN-34429: MTN - DeadLock Retry Required for trxVehicleRoadExit
*/

vars
	localCaption : String;
begin

	localCaption := self.caption;
	
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(-10, 2000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	while true do
	
		
		//call the code that was originally in this method
		self.doProcessRoadExit(_object);
		
		//if we did NOT have a dead lock, just bail out.
		if app.myPassport.hadDeadlock = false then
			return;
		endif;
		
		self.caption := localCaption &amp; " DLRT " &amp; app.myPassport.silentDeadlockRetryCount.String;
		
		//OK so we had a deadlock, log it, and get ready to retry if appropriate
		
		if app.myPassport.silentDeadlockRetryCount &lt; app.myPassport.silentDeadlockLimit then
			// give the other guy a chance to do his processing and release the locks we want.
			process.sleep(app.myPassport.silentDeadlockSleepTime);
		
			//reset the boolean ready to try again.
			app.myPassport.hadDeadlock := false;
		else
			//We did deadlock, and we returned from 'doSave' before we had a chance to pop up a message to the user, so tell'em now.
			app.showErrorWarningDialog(self.mnuProcessRoadExit2.caption, app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); 
			return;
		endif;
		
	endwhile;

	
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	
	app.myPassport.resetSilentDeadlockHandler;

	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doProcessRoadExit_CheckLocn" id="d1683402-7a6b-4572-a104-444e1c472757">
        <source>doProcessRoadExit_CheckLocn(_vehicle :CM_Vehicle):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     15 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/11/2009	cnwcs5		par 21328 - 
// ---------------------------------------------------------------------------
vars
	obj		:Object;
	job		:CM_RoadJob;
	gate	:CM_Gate;
	lc		:CM_YardController;
begin
	// we really only expect there to be one job for the vehicle and it should be complete
	foreach obj in _vehicle.allRoadJobs discreteLock do	// 31890 add discreteLock
		job := obj.CM_RoadJob;
		
		if job.status &lt;&gt; JOB_COMPLETE then
			// par 21328 app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called for vehicle with incomplete job');
			app.msgBox(app.getErrorString (XLAT_Road_Exit_Error2), self.mnuProcessRoadExit2.caption, MsgBox_Information_Icon + MsgBox_OK_Only);	// par 21328 - 11/11/2009
			return false;
		endif;
		
		gate 	:= job.getExitGate;
		
		if gate &lt;&gt; null and gate.hasPGateAreas_OUT then
			lc := _vehicle.myPrimaryActualLocation;
			
			if not lc.isGateAreaLocation then
				// cannot road exit from yard
				app.msgBox (app.getErrorString (XLAT_Road_Exit_Error3), self.mnuProcessRoadExit2.caption, MsgBox_Information_Icon + MsgBox_OK_Only);
				return false;
			endif;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRebuildJobStatus" id="f3e06772-f2ee-420f-ab6b-4b6faec1174b">
        <updating/>
        <source>doRebuildJobStatus(_obj : CM_Object input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	job : CM_RoadJob;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	if _obj = null or not _obj.isKindOf(CM_RoadJob) then
		return;
	endif;
	job:= _obj.CM_RoadJob; 
	
	app.mousePointer := MousePointer_HourGlass;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateJobStatus(job, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Rebuild Job Status', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;


end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRebuildWLEStatus" id="ffad4b38-343b-43f0-9db2-cb6e16a5a3cf">
        <updating/>
        <source>doRebuildWLEStatus(_wle : CM_WorkListEntry input)updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	rtnValue : Boolean;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin	

	if _wle = null then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEStatus(_wle, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Rebuild Entry Status', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="247d1e4b-34ef-4250-bfd0-2dd55e8df55d">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/02/2025	naviv1		JIRA-29374- EUP | Transaction Instrumentation - Gate
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------

vars
	cmifRoadOpObject : CMIF_RoadOpObject;
begin
	
	inheritMethod();
	self.loadListJobsForTerminal (false); //13 Apr 2016	NDL	TFS 1819

	
	foreach cmifRoadOpObject in self.myRoadOpController.allCMIFRoadOpObjects do
		cmifRoadOpObject.init;
		cmifRoadOpObject.loadDataTable;
	endforeach;
	

	if (not self.timerRefreshActive) then
		self.beginTimerForRefresh();
	endif;	

epilog

end;</source>
        <access>protected</access>
