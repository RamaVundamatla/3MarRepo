    <JadeMethod name="setProcess" id="117f28d6-9dd8-4675-a202-02002458f4c6">
        <updating/>
        <source>setProcess(_process : Process; _startTime : TimeStamp; _isNotify : Boolean) updating;

// cnwdvb1 12 November 2002 
//
//27 Aug 2012	cnwrs1	Par 28196 fixup typo
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//14 Jan 2014	cnwrs1	Par 33264 change process usercode to be actiula user code not controller name
vars

begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' myCurrentRequest='&amp;self.myCurrentRequest.String&amp;' _process='&amp;_process.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	if not app.isSDSSecondaryDB() then	// CCMS1150 cnwrs1 04 July 2011
		self.myProcess 			:= _process;
		self.myCurrentRequest	:= null;
		self.dateTimeLastStarted := _startTime;
	
		if self.myProcess &lt;&gt; null then
			self.machineName := app.computerName();
			self.myProcess.userInfo := self.displayString;
			self.myProcess.changeUserCode(self.getUserCode[1:30]);
		else
			self.machineName := null;
		endif;
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent BGP_SDSSecondaryProcess', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.sdsCauseEvent(BGP_Object.BGP_SDSSecondaryProcess, true, _process);	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification
	endif;
	if _isNotify then
		self.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);
	endif;
end;</source>
        <Parameter name="_process" type="Process"/>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_isNotify" type="Boolean"/>
    </JadeMethod>
