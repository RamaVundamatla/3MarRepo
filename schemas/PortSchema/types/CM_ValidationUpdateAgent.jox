/*
Purpose:			
Date				Who			Reason
JANUARY 2012		CNWAB1		Initial creation
*/
vars
begin
	self.raiseExceptionIfNull(_req, 'Voyage RORO Request');

	_req.validateQuantityUpdate(_qty);


end;</source>
        <Parameter name="_req" type="CM_VoyageRequest"/>
        <Parameter name="_qty" type="Decimal"/>
    </JadeMethod>
