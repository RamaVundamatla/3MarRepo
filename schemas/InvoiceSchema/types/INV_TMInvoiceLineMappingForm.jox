    <JadeMethod name="translateForm" id="5904ac74-a0e6-4603-adf4-ec0a8838287c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018454, locale);
	btnLinesCancel.translateBubbleHelp(Xlat_0018455, locale);
	btnLinesCancel.translateCaption(Xlat_0018456, locale);
	btnLinesDelete.translateBubbleHelp(Xlat_0018457, locale);
	btnLinesDelete.translateCaption(Xlat_0018458, locale);
	btnLinesNew.translateBubbleHelp(Xlat_0018459, locale);
	btnLinesNew.translateCaption(Xlat_0018460, locale);
	btnLinesSave.translateBubbleHelp(Xlat_0018461, locale);
	btnLinesSave.translateCaption(Xlat_0018462, locale);
end;</source>
    </JadeMethod>
