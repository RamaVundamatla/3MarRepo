<Class name="CM_XmlHelperAgent" id="00631a62-8ed6-4bcf-8f47-70a4efb3d559">
    <superclass name="CM_Agent"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>XML helper class to provide methods that process XML messages and documents</text>
    <JadeMethod name="handleXMLException" id="745ec7b7-2882-4a5b-9602-ce0e6e1bfdee">
        <source>handleXMLException(_exc : JadeXMLException; _parsingError : Boolean io) : Integer protected;

/*

Purpose:			Handle any error during parsing of the incomingMessage

Parameters:			Exception object

Return Value:		_parsingError set to true when an exception occurs


Date		Who		Reason
18 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
					Refactor out from WS_WebServiceProvider

*/

vars

begin
	app.writeLog(method.qualifiedName &amp; 
							 " " &amp; _exc.class.name &amp; 
							 " " &amp; _exc.errorCode.String &amp; 
							 " " &amp; _exc.text &amp; 
							 " " &amp; _exc.extendedErrorText, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	_parsingError := true;
	
	return Ex_Resume_Next;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="JadeXMLException"/>
        <Parameter name="_parsingError" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hidePasswordFieldsForLogging" id="15646c1e-302d-4ea9-adb1-2993825704cb">
        <source>hidePasswordFieldsForLogging(_xmlMessage : String) : String;
/*

Purpose:			"Hide" any password-type fields in the passed in _xmlMessage, so that the
					information can be safely logged

Parameters:			XML message which may contain password fields

Return Value:		Revised document with password data removed

Date		Who		Reason
18 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration
					Refactor out from WS_WebServiceProvider
21 Jun 2018	jlgkpd1	TFS #37190 - change to remove outputDeclaration to enable this method to be used for Json 
					as well
*/

vars
	secureFields	: StringArray;
	xml 			: JadeXMLDocument;
	element 		: JadeXMLElement;
	fieldName,
	text 			: String;
	parseError		: Boolean;
	
begin
	// Handle any parser errors by just returning the input string
	on JadeXMLException do self.handleXMLException(exception, parseError);
	
	create xml transient;
	xml.parseString(_xmlMessage);
	
	if parseError then
		return _xmlMessage;
	endif;
	
	create secureFields transient;
	secureFields.add("password");
	secureFields.add("oldPass");
	secureFields.add("newPass");
	secureFields.add("newPass2");
	
	foreach fieldName in secureFields do

		element := xml.findElementByNameNS("*", fieldName);
		if element &lt;&gt; null then
			text := element.text;
			text.fillString("*");
			element.setText(text);
		endif;
	
	endforeach;

	xml.outputDeclaration := false;
	return xml.writeToString();
	
epilog
	delete secureFields;
	delete xml;
	
end;</source>
        <Parameter name="_xmlMessage" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="reparentElements" id="a48965df-a885-45f1-8d07-1f9fccc7c311">
        <source>reparentElements(_xml : JadeXMLDocument input;
					_childName,
					_newParentName : String;
					_documentChanged : Boolean io);
/*

Purpose:			Find any elements with the passed in _childName, and check they are children of a tag with the
					passed in _newParentName.  If they are not, then create a new parent node and "insert" it in the 
					XML tree above all the children.
					
Parameters:			XML document to alter
					Child element tage name to find
					Parent element name to check/create

Return Value:		

Date		Who		Reason
06 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	elements		: JadeXMLElementArray;
	element,
	oldParent,
	newParent		: JadeXMLElement;
		
begin
	create elements transient;
	_xml.findElementsByTagName(_childName, elements);

	// Assume all the children are at the same level, and will have the same parent
	foreach element in elements do
		// Get and check the parent of the first child found
		if oldParent = null then
			oldParent := element.parentElement;
			if oldParent.tagName = _newParentName then
				// Nothing to do, structure is already correct
				break;
			endif;
			// Need to create a new parent as a sibling of the child
			newParent := oldParent.addElement(_newParentName);
			_documentChanged := true;
		endif;
		
		// Move the child under the new parent node
		element.moveAsChildOf(newParent);
		
	endforeach;
	
epilog
	delete elements;
	
end;</source>
        <Parameter name="_xml" type="JadeXMLDocument" usage="input"/>
        <Parameter name="_childName" type="String"/>
        <Parameter name="_newParentName" type="String"/>
        <Parameter name="_documentChanged" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateElementNames" id="97efffdf-b1ac-4ae0-a5b0-af76f537fab3">
        <source>translateElementNames(_xml : JadeXMLDocument input;
							_namespace,
						 _inputName,
						 _outputName : String;
						 _documentChanged : Boolean io);
/*

Purpose:			Translate any element names in the passed in document that match the _inputName
					to the passed in _outputName

Parameters:			XML document to alter
					Tag name to find and change
					Tag name to change to

Return Value:		

Date		Who		Reason
05 Apr 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	elements		: JadeXMLElementArray;
	element			: JadeXMLElement;
		
begin
	create elements transient;
	
	//epr 30/7/18 inaportnet sending soap using namespace
	_xml.findElementsByNameNS(_namespace,_inputName, elements);
		
	foreach element in elements do
		element.tagName := _outputName;
		element.localName := _outputName;
		
		_documentChanged := true;
	endforeach;
	
epilog
	delete elements;
	
end;</source>
        <Parameter name="_xml" type="JadeXMLDocument" usage="input"/>
        <Parameter name="_namespace" type="String"/>
        <Parameter name="_inputName" type="String"/>
        <Parameter name="_outputName" type="String"/>
        <Parameter name="_documentChanged" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tryParseToXMLDocument" id="ef2e6f03-a2bc-40b9-9710-c087c6553364">
        <source>tryParseToXMLDocument(_xmlString : String;
					  _xmlDocument : JadeXMLDocument input) : Boolean;
/*

Purpose:			Try parsing the passed in String into the (empty) XML Document

Parameters:			

Return Value:		True if the parse was successful, false if not

Date		Who		Reason
13 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	parseError		: Boolean;
	
begin
	// Handle any parser errors 
	on JadeXMLException do self.handleXMLException(exception, parseError);
	
	_xmlDocument.parseString(_xmlString);
	
	return not parseError;
		
epilog

end;</source>
        <Parameter name="_xmlString" type="String"/>
        <Parameter name="_xmlDocument" type="JadeXMLDocument" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
