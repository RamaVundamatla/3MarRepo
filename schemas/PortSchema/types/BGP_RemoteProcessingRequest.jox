<Class name="BGP_RemoteProcessingRequest" id="66ddf785-9df5-4e17-a650-a54df49fa6eb">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Remote Processing(Logs Only)&lt;/display&gt;
&lt;displayShort&gt;Remote Processing&lt;/displayShort&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="remoteHeader" id="3fa764db-9df9-46fd-9b01-969afd135661">
        <embedded/>
        <type name="CM_RemoteDataHdr"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="68e97e68-9e0d-46f4-9329-763a3b73ccba">
        <updating/>
        <source>action(): Boolean updating;

vars

	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, self.remoteHeader, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	if global.isValidObject(self.remoteHeader) then
		self.remoteHeader.runBackGroundProcess(true);
	endif;

epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	inheritMethod();
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="fa9efdec-4c59-4473-87ae-dfafbc710c93">
        <source>getDisplay(): String;

// cnwdvb1 17 February 2003 

vars

	str, detail : String;

begin
	
	str := inheritMethod();
	if self.remoteHeader &lt;&gt; null then
		detail := self.remoteHeader.getDisplay();
	endif;
	return str &amp; Tab &amp; detail;
	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestLimit" id="32f4d745-586c-4021-9bce-e94773c4e160">
        <source>getRequestLimit(): Integer;
// -------------------------------------------
// Created 28 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	// No request limit.
	return 0;


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initRemoteProcessing" id="0c02a956-252e-47d9-ae70-9b6a74c4b437">
        <updating/>
        <source>initRemoteProcessing(_remoteHeader : CM_RemoteDataHdr) updating;

vars

begin

	self.remoteHeader := _remoteHeader;
	self.initRequestEvent(true, false, null);

end;</source>
        <Parameter name="_remoteHeader" type="CM_RemoteDataHdr"/>
    </JadeMethod>
</Class>
