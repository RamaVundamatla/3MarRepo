    <JadeMethod name="inspectObject" id="dac676ef-18e3-4180-bdff-22a08d325c34">
        <source>inspectObject();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 April 2019
TFS#		: 44287
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	obj 		: Object;
begin
	if self.tblDamage.row &gt; 1  then
		obj := self.tblDamage.allSelectedObjects.first;
		if obj &lt;&gt; null then
			obj.inspect;
		endif;
	else
		obj := self.tblDamage;
			if obj &lt;&gt; null then
			obj.inspect;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDamageItem" id="b97bb4e4-04ff-434e-932c-3b1f8cfb9a1b">
        <updating/>
        <source>loadDamageItem(damageInstance : CM_DamageInstance) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		12 October 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	pxyDam	: CM_DamageInstance;
	str		: String;
begin
	str := self.tblDataDisplayRow(self.tblDamage, damageInstance);
	
	pxyDam := damageInstance.pxyGetProxyObject();
	if pxyDam = null then
		pxyDam := app.createUpdateProxy(damageInstance).CM_DamageInstance;
	endif;
	
	self.allProxyDamageInstances.add(pxyDam);
	self.addPxyToParentForm(pxyDam);
	self.tblDamage.addItemObject(pxyDam, str);
epilog
end;</source>
        <Parameter name="damageInstance" type="CM_DamageInstance"/>
    </JadeMethod>
    <JadeMethod name="loadDamageItems" id="8b263195-61b1-4ce4-8902-7b7ce508e9b7">
        <updating/>
        <source>loadDamageItems() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		31 July 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 31/07/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 05 Feb 2025	navnk30		JIRA 33887: MTN | Road Gate In Checks throws error for damage check that is Inappropriate.
//----------------------------------------------------------------------
vars
	pxyDam, 
	damageInstance 	: CM_DamageInstance;
	str 			: String;
	object 			: CM_Object;
	table 			: CM_DataTable;
	idx 			: Integer;
	ti 				: CM_TrackedItem;
begin
	table := self.tblDamage;
	object := self.getItemForDisplay();
	// ## TRACKED ITEM
	if object.isKindOf(CM_TrackedItem) then
		if self.myProxyMasterItem = null then
			// 29944 don't create update proxy from cargo enquiry unless updating
			if not self.mode = Mode_View then
				ti := app.createUpdateProxy(object).CM_TrackedItem;
				self.myProxyMasterItem := ti;
			else
				ti := object.CM_TrackedItem;
			endif;
		else
			ti := self.myProxyMasterItem.CM_TrackedItem;
		endif;
		foreach damageInstance in ti.allDamageInstancesByPos do
			str := self.tblDataDisplayRow(self.tblDamage, damageInstance);
			table.addItemObject(damageInstance, str);
			if damageInstance.isTransient then	// 29944 in view mode these are persistent
				self.allProxyDamageInstances.add(damageInstance);
			endif;
		endforeach;
		self.setCaption(app.getErrorString(Damage) &amp; " " &amp; object.CM_TrackedItem.id);
	// ## WAGONS
	elseif object.isKindOf(CM_Wagon) then
		foreach damageInstance in object.CM_Wagon.allDamageInstanceByPos do
			self.loadDamageItem(damageInstance);
		endforeach;
		self.setCaption(app.getErrorString(Damage) &amp; " " &amp; object.CM_Wagon.id);
	// ## WAGON MASTERS
	elseif object.isKindOf(CM_WagonMaster) then
		foreach damageInstance in object.CM_WagonMaster.allDamageInstancesByPos do
			self.loadDamageItem(damageInstance);
		endforeach;
		self.setCaption(app.getErrorString(Damage) &amp; " " &amp; object.CM_WagonMaster.id); 
	elseif object.isKindOf(CM_TIMaster) then
		if (self.myParentForm.isKindOf(CMUI_MasterGeneratorMaintForm)and self.myParentForm.CMUI_MasterGeneratorMaintForm.isDamageFormInitialised) or
		   (self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm)and self.myParentForm.CMUI_MasterContainerMaintForm.isDamageFormInitialised) or
		   (self.myParentForm.isKindOf(CMUI_TIMasterMaintForm)and self.myParentForm.CMUI_TIMasterMaintForm.isDamageFormInitialised) then
			self.loadDamageProxyFromParentForm();
		else
			foreach damageInstance in object.CM_TIMaster.allDamageInstancesByPos do
				self.loadDamageItem(damageInstance);
			endforeach;
		endif;
		self.setCaption(app.getErrorString(Damage) &amp; " " &amp; object.CM_TIMaster.id); 
	elseif self.myParentForm.isKindOf(CMUI_CargoChecksForm) then								//05.02.2025 navnk30 JIRA 33887
		foreach damageInstance in self.myProxyMasterItem.CMGTE_Entity.allDamageInstancesByPos where global.isValidObject(damageInstance) do
			str := self.tblDataDisplayRow(self.tblDamage, damageInstance);
			table.addItemObject(damageInstance, str);
		endforeach;
	else
		 //epr par 31845 
		if self.myParentForm.class.implementsInterface(IF_DamageDetails) then
			foreach damageInstance in self.myParentForm.IF_DamageDetails.getDamageInstances do
				str := self.tblDataDisplayRow(self.tblDamage, damageInstance);
				table.addItemObject(damageInstance, str);
				if damageInstance.isTransient then	
					self.allProxyDamageInstances.add(damageInstance);
				endif;
			endforeach;
		endif;
	endif;
	
	if table.rows &gt; table.fixedRows then
		idx := table.fixedRows + 1;
		table.row := idx;
		self.setSelectedItem(table.accessRow(idx).itemObject.CM_DamageInstance);
		table.selectRow(idx, false);
		self.displaySelectedItem();
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDamageProxyFromParentForm" id="3ee1a0b7-c3ea-4295-b976-759dcfaeb111">
        <updating/>
        <source>loadDamageProxyFromParentForm()updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		12 October 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	damage 	: CM_DamageInstance;
	str 	: String;
	damageColl : CM_DamageInstanceByDmgePos;
begin
	if self.myParentForm.isKindOf(CMUI_MasterGeneratorMaintForm) then
		damageColl := self.myParentForm.CMUI_MasterGeneratorMaintForm.allDamageInstancesByPos;
	elseif self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm) then
		damageColl := self.myParentForm.CMUI_MasterContainerMaintForm.allDamageInstancesByPos;
	elseif self.myParentForm.isKindOf(CMUI_TIMasterMaintForm) then
		damageColl := self.myParentForm.CMUI_TIMasterMaintForm.allDamageInstancesByPos;
	endif;
	
	foreach damage in damageColl do
		str := self.tblDataDisplayRow(self.tblDamage, damage);
		self.allProxyDamageInstances.add(damage);
		self.tblDamage.addItemObject(damage, str);
	endforeach;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="mnuTblInspectObject_click" id="8c865a3c-4347-4b4e-821d-11f8b5f428e1">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuTblInspectObject_click(menuItem: MenuItem input) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 April 2019
TFS#		: 44287
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	self.inspectObject();
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeFromParentForm" id="9761630b-c0d2-442b-b182-aa848eb65d9b">
        <updating/>
        <source>removeFromParentForm() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		12 October 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars

begin
	if self.myParentForm.isKindOf(CMUI_MasterGeneratorMaintForm) then
		self.myParentForm.CMUI_MasterGeneratorMaintForm.allDamageInstancesByPos.removeIfPresent(self.mySelectedItem);
	elseif self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm) then
		self.myParentForm.CMUI_MasterContainerMaintForm.allDamageInstancesByPos.removeIfPresent(self.mySelectedItem);
	elseif self.myParentForm.isKindOf(CMUI_TIMasterMaintForm) then
		self.myParentForm.CMUI_TIMasterMaintForm.allDamageInstancesByPos.removeIfPresent(self.mySelectedItem);
	endif;
		
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="removeItem" id="22267a0b-a530-491e-b3af-c0502dcd190d">
        <updating/>
        <source>removeItem() updating, protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 13/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	idx : Integer;
begin
	if self.mySelectedItem = null then
		app.msgBox('Please select an Item to remove', 'Select Item', 0);
		return;
	endif;
	
	self.tblDamage.findObjectInRow(self.mySelectedItem, idx);
	
	if idx &gt; 0 then
		self.tblDamage.removeItem(idx);
		if self.allProxyDamageInstances.includes(self.mySelectedItem) then
			self.allProxyDamageInstances.remove(self.mySelectedItem);
		endif;
		self.removeFromParentForm();
		delete self.mySelectedItem;
		//epr tfs 1923 29/4/16
		self.clearItem();
	endif;
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCmifFromWagonPxy" id="6a39689a-bd43-4958-866a-cb96eb9b7a97">
        <updating/>
        <source>setCmifFromWagonPxy(_pxyWagon : CM_Wagon input; wagonUpdateCtrl : CMIF_WagonUpdateController input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	rake : CM_RailLine;
	wagonPos : Integer;
	realWagon : CM_Wagon;
begin

	realWagon := _pxyWagon.pxyGetRealObject.CM_Wagon;
	if realWagon &lt;&gt; null then
		rake := realWagon.myRailLine;
		if rake &lt;&gt; null then
			wagonPos := rake.allWagons.indexOf(realWagon);
		endif;
	endif;
	
	wagonUpdateCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
										rake,	//_rake : CM_RailLine;
										realWagon.myTrainInwards,	//_train : CM_Train;
										wagonPos,	//_wagonPosition : Integer;
										true	//_trainMode : Boolean
										);
										
	wagonUpdateCtrl.expectedEditionWagon := realWagon.edition;									
	wagonUpdateCtrl.myProxyWagon := _pxyWagon;
	
	if realWagon &lt;&gt; null then
		wagonUpdateCtrl.populateFromExistingWagonAddTi( realWagon, null, 0 );
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyWagon" type="CM_Wagon" usage="input"/>
        <Parameter name="wagonUpdateCtrl" type="CMIF_WagonUpdateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyMasterItems" id="08d9d8ab-5cdb-45a5-b5cd-2bf98fe59a6a">
        <updating/>
        <source>setMyMasterItems(_masterProxy, _masterReal : CM_Object) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		31 July 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 31/07/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars

begin
	self.myProxyMasterItem := _masterProxy;
	
	if _masterReal &lt;&gt; null then
		self.myRealMasterItem := _masterReal;
	endif;
epilog
end;</source>
        <Parameter name="_masterProxy" type="CM_Object"/>
        <Parameter name="_masterReal" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setOptIsNewDamage" id="5259cde3-2b49-4d85-819e-584275530c18">
        <source>setOptIsNewDamage(_damageInstance : CM_DamageInstance);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		04 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 04/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars

begin
	if _damageInstance &lt;&gt; null then
		self.optYes.value := _damageInstance.isNewDamage;
		self.optNo.value := not _damageInstance.isNewDamage;
	endif;
epilog
end;</source>
        <Parameter name="_damageInstance" type="CM_DamageInstance"/>
    </JadeMethod>
