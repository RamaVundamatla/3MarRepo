    <JadeMethod name="doNewPage" id="98151236-5c89-4b92-94de-dc163c2ed50e">
        <source>doNewPage() protected;

// cnwdvb1 19 November 2002 

vars

begin

	if self.isCSV then
		return;
	endif;
	app.printer.newPage();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrint" id="9c880366-8ef4-45af-a4c9-e65070ce1dd8">
