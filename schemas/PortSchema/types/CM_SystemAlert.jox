    <JadeMethod name="setRemarks" id="c1e7a113-d377-40ea-8b98-6ed0fbdfa04c">
        <updating/>
        <source>setRemarks(_remarks : String) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
09 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.remarks &lt;&gt; _remarks then
		self.remarks:=_remarks;
	endif;

epilog

end;</source>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="setReviewed" id="f2244bde-d658-4e5c-8d99-2802690a518a">
        <updating/>
        <source>setReviewed(_reviewed : Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 September 2006	cnwer1	Initial creation - PAR#xxxx
24 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	tmpTerminal 	: CM_Terminal;
	invalid 		: Boolean;
	ed				: Integer;
	
begin
	if self.reviewed &lt;&gt; _reviewed then
		self.reviewed:=_reviewed;
		self.reviewedBy:=app.myPassport.getUserCode;
		self.reviewedDateTime:=app.actualTimeServer();

//		if (not app.isValidObject(linkedTo)) then
		if self.linkedTo &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, self.linkedTo, invalid);
			// Dereference to check it is still valid
			ed := self.linkedTo.edition();
			if invalid then
				self.linkedTo := null;
			endif;
			on Exception do null;
		endif;
		
		if self.isType(EVENT_AT_FailedAutoPlan) then
			self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(EventTerminalAlertUpdate), false, self);
		endif;
		if self.linkedTo &lt;&gt; null and  self.linkedTo.respondsTo(IF_AlertAlarm) then
			tmpTerminal:=self.linkedTo.IF_AlertAlarm.getTerminalForAlert;
			if not self.isTransient and tmpTerminal &lt;&gt; null and self.mySystemAlertType &lt;&gt; null then
				 tmpTerminal.causeEvent( self.mySystemAlertType.type,false, self);	//25662 24/09/2010 set to false
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_reviewed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSeverity" id="89d1e995-cb41-4521-bbf0-3ce8065539d9">
        <updating/>
        <source>setSeverity(sevLevel : Integer ) updating;

begin
//	if sevLevel &lt; SEVERE_INFO or sevLevel &gt; SEVERE_REEFER then		//PAR 2984 // AKB 09Mar2001 PAR 3803 WAS
	if sevLevel &lt; SEVERE_INFO or sevLevel &gt; SEVERE_REEFER_MAX then		//PAR 2984  // AKB 09Mar2001 PAR 3803 NOW
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_SEVERITY, sevLevel.String, null, null);
		return;
	endif;
	severity := sevLevel;
end;</source>
        <Parameter name="sevLevel" type="Integer"/>
    </JadeMethod>
</Class>
