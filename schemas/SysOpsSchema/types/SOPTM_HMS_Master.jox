    <JadeMethod name="initShtTblInput4" id="5fa1855a-da42-481d-beb4-2042ff340384">
        <source>initShtTblInput4();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2012	cnwndl1	Initial creation	Par 29294

*/

vars

	theForm : SOP_HMS_TableMaintForm;
	sheet : Sheet;
	table	: CM_DataTable; 
	entTableDef	: EntTableDef;
	toolbar	: CMUI_Toolbar;
	btn : Button;
	prevBtn : Button;
	bLeft, bTop, bWidth, bHeight : Real;

begin

	theForm := self.myForm.SOP_HMS_TableMaintForm;
	sheet := theForm.shtTblInput4;
	sheet.caption := app.getString( Pilot_exemptions );
	sheet.visible := true;
	sheet.enabled := true;
	
	table := theForm.tblShtData4;
	
	table.visible := true;
	table.readOnly := true;
	
	toolbar := self.myForm.frmShtInput4Btns;
	toolbar.visible := true;
	
	btn := theForm.btnDeleteInput4;
	btn.caption := app.getErrorString(Delete_Caption);
	btn.bubbleHelp := null;
	btn := theForm.btnEditInput4;
	btn.caption := app.getErrorString(UpdateUpper);
	btn.bubbleHelp := null;
	btn := theForm.btnNewInput4;
	btn.caption := app.getErrorString(AddUpper);
	btn.bubbleHelp := null;
	
	table.clear;
	table.fixed3D 			:= false;
	table.optimiseRowHeight := true;
	table.stretchWidth 		:= true;	
	table.rows 				:= 1;
	table.fixedRows 		:= 1;
	table.fixedColumns 		:= 0;

	table.selectionType 	:= CM_DataTable.SelectionType_Row;
	table.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	table.multiSelect 		:= CM_DataTable.MultiSelect_Simple; 
	
	entTableDef := app.myController.getEntTableDef(ETDef_HMSPilotExempt);
	table.setTblDataEntRowsFromView(entTableDef, null);
							
	table.height := ( sheet.height - self.myForm.frmShtInput4Btns.height ) - 2;
							
epilog

end;</source>
    </JadeMethod>
