    <JadeMethod name="createEventTypeMap" id="1e2fc133-e20d-490c-9b45-9cfd6d648fa6">
        <updating/>
        <source>createEventTypeMap(_eventName : String; _eventMapObj : CM_TranMapEvent; _eventBrokerObj : CM_EventServiceBroker output) : Boolean updating, protected;

vars
	found		: Boolean;
	isDefault	: Boolean;
	isMove		: Boolean;
	className	: String;
	eventTypeObj : CM_EventType;
	serviceBrokerObj : CM_ServiceBroker;
	eventBrokerObj	 : CM_EventServiceBroker;
	proxyEventBroker	: CM_EventServiceBroker;
begin
	self.getEventDetails(_eventName, isDefault, eventTypeObj);

	if isDefault then
		foreach eventBrokerObj in _eventMapObj.allEventServiceBrokers do
			if eventBrokerObj.myEventType = null then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			eventBrokerObj := null;
		endif;
	else
		eventBrokerObj := _eventMapObj.allEventServiceBrokers[eventTypeObj]; // tfs42038 jlgzm1 09/05/2019
	endif;
	_eventBrokerObj := eventBrokerObj;

	if eventBrokerObj = null then
		create proxyEventBroker transient;
		
		proxyEventBroker.setProxyRSB(eventTypeObj, _eventMapObj);
		
		app.myTrxCA.trxCreateInvoiceTMTransaction(proxyEventBroker, serviceBrokerObj, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating event type map (' &amp; _eventName &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		_eventBrokerObj := serviceBrokerObj.CM_EventServiceBroker;
		createCount := createCount + 1;
	endif;
	
	return true;
epilog
	delete proxyEventBroker;
end;
</source>
        <access>protected</access>
        <Parameter name="_eventName" type="String"/>
        <Parameter name="_eventMapObj" type="CM_TranMapEvent"/>
        <Parameter name="_eventBrokerObj" type="CM_EventServiceBroker" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createImexMap" id="1c6407ef-a8e6-4264-8334-b552143cfe1d">
        <updating/>
        <source>createImexMap(_imex : String; _productMapObj : CM_ProductMap; _imexMapObj : CM_ImexServiceMap output) : Boolean updating, protected;

vars
	found		: Boolean;
	isDefault	: Boolean;
	imexObj	 : CM_CargoStatus;
	proxyImexMap,
	imexMapObj : CM_ImexServiceMap;
begin
	self.getImexDetails(_imex, isDefault, imexObj);

	if isDefault then
		foreach imexMapObj in _productMapObj.allImExMaps do
			if imexMapObj.imexStatus = 0 then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			imexMapObj := null;
		endif;
	else
		imexMapObj := _productMapObj.allImExMaps[imexObj.code];
	endif;
	
	if imexMapObj = null then
		create proxyImexMap transient;
		proxyImexMap.setProxy(_productMapObj, imexObj);
		app.myTrxCA.trxCreateInvoiceTMImex(proxyImexMap, imexMapObj, passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating imex map (' &amp; _imex &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		createCount := createCount + 1;
	endif;

	_imexMapObj := imexMapObj;
	return true;
epilog
	delete proxyImexMap;
end;
</source>
        <access>protected</access>
        <Parameter name="_imex" type="String"/>
        <Parameter name="_productMapObj" type="CM_ProductMap"/>
        <Parameter name="_imexMapObj" type="CM_ImexServiceMap" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceAllocation" id="47358c68-0215-4667-aa97-21245ca85950">
        <updating/>
        <source>createInvoiceAllocation(_broker : CM_SnapShotServiceBroker; _criteriaValues : HugeStringArray; _field : CM_XTABField; 
						_startRange : Integer; _endRange : Integer; _invLineDesc : CM_InvoiceLineDesc) : Boolean updating, protected;

vars
	terminalObj				: CM_Terminal;
	yardAllocationObj		: CM_InvoiceAllocation;
	proxyYAObj				: CM_InvoiceAllocation;
	proxyQM					: CM_QuantityMap;
	proxyQRM				: CM_QuantityRangeMap;
	isNew					: Boolean;
	fillOptionIn			: Integer;
	fillOptionOut			: Integer;
	yaCode					: String;
	yaDescription			: String;
	yaRemarks				: String;
	expiryType				: Integer;
	expiryDate				: Date;
	allowOthers				: Integer;
	noLocation				: Integer;
	priorityAdj				: Integer;
	isTestOverstowWeight	: Boolean;
	isDisabled				: Boolean;
	allTransientCriteriaObj	: CMIF_Array;
	yaColor					: Integer;
	overstowRule			: CM_YAOverstowRule;
	blockGroupsInColl		: CM_YABlockGroupArray;
	blockGroupsOutColl		: CM_YABlockGroupArray;
	displayHatched			: Boolean;
	pxyMapping : CM_TranMapInvoiceLineMapping;
	bank : CM_Bank;
	mapType :CM_TranMapInvoiceLineGroupType;
begin

	create proxyYAObj transient;
	create proxyQM transient;
	create proxyQRM transient;
	create proxyQRM.allRegisteredMethods transient;
		
	create allTransientCriteriaObj transient;
	yaCode := self.getCriteriaAllCMIF( _broker,  _criteriaValues, allTransientCriteriaObj );
	
	yaCode := yaCode &amp; " " &amp; _field.propertyName;
	yaDescription := yaCode;
	
	// Note: the null terminal parameter is deliberate, to keep these out of CM_Terminal.allYardAllocationsByCode as the 'code' value
	//	may not be unique here
	proxyYAObj.setProxy(yaCode,
						yaDescription,
						yaRemarks,
						fillOptionIn,
						fillOptionOut,
						expiryType,
						expiryDate,
						yaColor,
						displayHatched,
						allowOthers,
						noLocation,
						overstowRule,
						priorityAdj,
						isTestOverstowWeight,
						isDisabled,
						blockGroupsInColl,
						blockGroupsOutColl,
						false,
						terminalObj);
		
	proxyYAObj.setQuantityMap(proxyQM);
	proxyYAObj.setServiceBroker(_broker);
	proxyQM.setAllocationDetails(proxyYAObj, _field);

	proxyQRM.setProxy(proxyQM, _startRange, _endRange,0);
// TFS 40620	proxyQRM.allInvoiceLineMaps.add(_invLineDesc);
// TFS 40620	proxyQRM.allInvoiceLinesUsed.add(_invLineDesc);


	create pxyMapping transient; // TFS 40620
	bank := _invLineDesc.bank; // TFS 40620
	if bank &lt;&gt; null then // TFS 40620
		mapType := bank.getInvLineGroupAll(); // TFS 40620
	endif; // TFS 40620
	pxyMapping.update(CM_QuantityRangeMap.DEFAULT_INVOICELINE_KEY, _invLineDesc, proxyQRM, mapType, null, null, null, null, null); // TFS 40620

	app.myTrxUA.trxUpdateInvoiceAllocation(proxyYAObj, allTransientCriteriaObj, isNew, yardAllocationObj,  app.myPassport);
	
	if (not app.myPassport.trxCompletedOK) then
		self.setAllErrors('Creating invoice allocation, row ' &amp; rowCount.String);
		return false;
	endif;
	
	createCount := createCount + 1;
	
	return true;
	
epilog
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
	endif;
	delete allTransientCriteriaObj;
	delete proxyYAObj;
	if proxyQRM &lt;&gt; null then
		delete proxyQRM.allRegisteredMethods;
	endif;
	delete proxyQRM;
	delete proxyQM;
end;</source>
        <access>protected</access>
        <Parameter name="_broker" type="CM_SnapShotServiceBroker"/>
        <Parameter name="_criteriaValues" type="HugeStringArray"/>
        <Parameter name="_field" type="CM_XTABField"/>
        <Parameter name="_startRange" type="Integer"/>
        <Parameter name="_endRange" type="Integer"/>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceLineMapBOL" id="5bd433bc-dd6c-49ee-b90e-28e1383f9af1">
        <updating/>
        <source>createInvoiceLineMapBOL(	_invoiceLine : String;
							_quantityRangeMapObj : CM_QuantityRangeMap;
							_mapType : Integer;
							_isInContract : Boolean;
							_groupingType : String;
							_vesselCategory: HMS_VesselCategory;
							_transferType: CM_VoyageJobTransferType
							): Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	found	: Boolean;
	ls		: Boolean;
	lookForVoid	: Boolean;
	searchKey,
	key		: Integer;
	iter	: Iterator;
	ild,
	invLineDescObj,
	invoiceLineDescObj : CM_InvoiceLineDesc;
	pxyQR : CM_QuantityRangeMap;
	groupTypeObj		: CM_TranMapInvoiceLineGroupType;
	pxyMapping			: CM_TranMapInvoiceLineMapping;
	lineMapDict		: CM_TMInvLineMapByCargoAttrDict;
	groupType		: CM_TranMapInvoiceLineGroupType;
	lineMapping		: CM_TranMapInvoiceLineMapping;
	updateController :CMIF_TranMapLinesController;
	transferType	: CM_VoyageJobTransferType;
	vesselCategory	: HMS_VesselCategory;
	mapping : CM_TranMapInvoiceLineMapping;

begin
	// If we are creating a mapping we are doing that by updating the quantity range
	// The update of the QR purges all the existing mappings and re creates them
	// If we are updating the QR we make a proxy of the QR with all its current mappings and then add the new one
	
	
	
	self.getInvoiceLineDetails(_invoiceLine, invoiceLineDescObj);
	
	
	if self.baseColumnCount.isOneOf(15,17,18) then
		self.getGroupTypeDetails(_groupingType, groupTypeObj);	// 3/10/18 MAP TFS41202
	else
		groupTypeObj := self.myBank.getInvLineGroupAll();
	endif;
	

	iter := _quantityRangeMapObj.allTMInvoiceLineMappings.createIterator();
	while iter.next(mapping) do
		_quantityRangeMapObj.allTMInvoiceLineMappings.getIteratorKeys(key, iter);
		if mapping.myTMInvoiceLineDesc = invoiceLineDescObj 
		and mapping.myTMInvoiceLineGroupType = groupTypeObj then
				found := true;
				break;
		endif;
	endwhile;
	
	
	
	
	if not found then
		create updateController transient;
		app.cmsBeginLoad(ls);
		pxyQR := app.createUpdateProxy(_quantityRangeMapObj).CM_QuantityRangeMap;
		pxyQR.clear();
		app.cmsEndLoad(ls);

		if pxyQR.allRegisteredMethods = null then	
			create pxyQR.allRegisteredMethods transient;
		endif;
		_quantityRangeMapObj.allRegisteredMethods.copy(pxyQR.allRegisteredMethods);
		updateController.pxyQRMap := pxyQR;
		// copy the existing invoice line descriptions to the proxy, but not a VOID entry if there is no VOID in the load for this quantity range map
		// 32674 do this based on the voidList value only
		if self.voidList[self.rowCount] = false then
			lookForVoid := true;
		endif;

		lineMapDict := _quantityRangeMapObj.allTMInvoiceLineMappings;
		foreach lineMapping in lineMapDict do
			ild := lineMapping.myTMInvoiceLineDesc;
			key := lineMapping.mapValue;
			transferType := lineMapping.myTransferType;
			vesselCategory := lineMapping.myVesselCategory;
			
			groupType := lineMapping.myTMInvoiceLineGroupType;
			if lookForVoid then
				if ild.narration = self.voidInvoiceLineDesc then
					if searchKey = 0 then
						continue;
					elseif searchKey = key then
						continue;
					endif;
				endif;
			endif;
			create pxyMapping transient;
			pxyMapping.update(key, ild, pxyQR, groupType, transferType, vesselCategory,null,null,null);
		endforeach;
		
		key := 0;

		create pxyMapping transient;
		pxyMapping.update(key, invoiceLineDescObj, pxyQR, groupTypeObj, _transferType, _vesselCategory,null,null,null);

		app.myTrxUA.trxUpdateInvoiceTMTransaction(updateController, self.passport);
	endif;
	
	return true;
epilog
	app.cmsEndLoad(ls);				// 08/04/2011 cnwmh5 #27347
	delete updateController;
	delete pxyQR;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_invoiceLine" type="String"/>
        <Parameter name="_quantityRangeMapObj" type="CM_QuantityRangeMap"/>
        <Parameter name="_mapType" type="Integer"/>
        <Parameter name="_isInContract" type="Boolean"/>
        <Parameter name="_groupingType" type="String"/>
        <Parameter name="_vesselCategory" type="HMS_VesselCategory"/>
        <Parameter name="_transferType" type="CM_VoyageJobTransferType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceLineMapCargo" id="dff15f1b-7c53-4e58-b70d-7b14132457df">
        <updating/>
        <source>createInvoiceLineMapCargo(_invoiceLine : String; _quantityRangeMapObj : CM_QuantityRangeMap; 
								_mapType : Integer; _isInContract : Boolean; _groupingType : String; 
								_vesselCategory: HMS_VesselCategory; _transferType: CM_VoyageJobTransferType) : Boolean updating, protected;
/*
Purpose:	TFS 40620		
Date				Who			Reason
OCTOBER 2018		CNWAB1		Initial creation
*/

vars
	found	: Boolean;
	ls		: Boolean;
	lookForVoid	: Boolean;
	searchKey,
	key		: Integer;
	iter	: Iterator;
	ild,
	invLineDescObj,
	invoiceLineDescObj : CM_InvoiceLineDesc;
	pxyQR : CM_QuantityRangeMap;
	groupTypeObj		: CM_TranMapInvoiceLineGroupType;
	transferTypeObj	: CM_VoyageJobTransferType;
	pxyMapping			: CM_TranMapInvoiceLineMapping;
	lineMapDict		: CM_TMInvLineMapByCargoAttrDict;
	groupType		: CM_TranMapInvoiceLineGroupType;
	lineMapping		: CM_TranMapInvoiceLineMapping;
	updateController :CMIF_TranMapLinesController;
	transferType	: CM_VoyageJobTransferType;
	vesselCategory	: HMS_VesselCategory;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	// If we are creating a mapping we are doing that by updating the quantity range
	// The update of the QR purges all the existing mappings and re creates them
	// If we are updating the QR we make a proxy of the QR with all its current mappings and then add the new one
	
	
	
	self.getInvoiceLineDetails(_invoiceLine, invoiceLineDescObj);
	
	
	if self.baseColumnCount.isOneOf(15,17,18) then
		self.getGroupTypeDetails(_groupingType, groupTypeObj);	// 3/10/18 MAP TFS41202
	else
		groupTypeObj := self.myBank.getInvLineGroupAll();
	endif;
	
	
	// 34477 get the key to match on invoice line desc and methods together
	searchKey := self.findMethodKey(_quantityRangeMapObj);
	
	iter := _quantityRangeMapObj.allTMInvoiceLineMappings.createIterator();
	while iter.next(mapping) do
		_quantityRangeMapObj.allTMInvoiceLineMappings.getIteratorKeys(key, iter);

		if key = searchKey 
		and mapping.myTMInvoiceLineDesc = invoiceLineDescObj 
		and mapping.myTMInvoiceLineGroupType = groupTypeObj
		and mapping.myTransferType = _transferType then
			found := true;
			break;
		endif;
	endwhile;
	
	
	
	
	if not found then
		create updateController transient;
		app.cmsBeginLoad(ls);
		pxyQR := app.createUpdateProxy(_quantityRangeMapObj).CM_QuantityRangeMap;
		pxyQR.clear();
		app.cmsEndLoad(ls);

		if pxyQR.allRegisteredMethods = null then	//14 Jan 2011	NDL	Leaking transient in unit test
			create pxyQR.allRegisteredMethods transient;
		endif;
		_quantityRangeMapObj.allRegisteredMethods.copy(pxyQR.allRegisteredMethods);
		updateController.pxyQRMap := pxyQR;
		// copy the existing invoice line descriptions to the proxy, but not a VOID entry if there is no VOID in the load for this quantity range map
		// 32674 do this based on the voidList value only
		if self.voidList[self.rowCount] = false then
			lookForVoid := true;
		endif;
	
		lineMapDict := _quantityRangeMapObj.allTMInvoiceLineMappings;
		foreach lineMapping in lineMapDict do
			ild := lineMapping.myTMInvoiceLineDesc;
			key := lineMapping.mapValue;
			transferType := lineMapping.myTransferType;
			vesselCategory := lineMapping.myVesselCategory;
			groupType := lineMapping.myTMInvoiceLineGroupType;
			if lookForVoid then
				if ild.narration = self.voidInvoiceLineDesc then
					if searchKey = 0 then
						continue;
					elseif searchKey = key then
						continue;
					endif;
				endif;
			endif;
			create pxyMapping transient;
			pxyMapping.update(key, ild, pxyQR, groupType, transferType, vesselCategory, null, null, null);
		endforeach;
		
		// Add in the new one
		key := self.getMethodKey(pxyQR);
		create pxyMapping transient;
		pxyMapping.update(key, invoiceLineDescObj, pxyQR, groupTypeObj, _transferType, _vesselCategory, null, null, null);

		app.myTrxUA.trxUpdateInvoiceTMTransaction(updateController, self.passport);
	endif;
	
	return true;
epilog
	app.cmsEndLoad(ls);				// 08/04/2011 cnwmh5 #27347
	delete updateController;
	delete pxyQR;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_invoiceLine" type="String"/>
        <Parameter name="_quantityRangeMapObj" type="CM_QuantityRangeMap"/>
        <Parameter name="_mapType" type="Integer"/>
        <Parameter name="_isInContract" type="Boolean"/>
        <Parameter name="_groupingType" type="String"/>
        <Parameter name="_vesselCategory" type="HMS_VesselCategory"/>
        <Parameter name="_transferType" type="CM_VoyageJobTransferType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
