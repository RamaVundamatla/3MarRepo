        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="exitCode" id="7946228a-c292-4f81-90b7-95483a2926a6">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="logFile" id="81945da5-491f-4cf9-a3fc-c1fea48c827b">
        <embedded/>
        <type name="File"/>
    </ImplicitInverseRef>
