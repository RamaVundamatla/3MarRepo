    <JadeMethod name="cloneForTrackedItem" id="704d8c65-7dc8-46e1-81d3-9c914b1355c4">
        <source>cloneForTrackedItem(_ti : CM_TrackedItem input; _transient : Boolean);
/*

Date		Who		Reason
21 October 2013	cnwer1	Initial creation PAR 32838

*/

vars
	clone : CM_TranshipDetail;
begin
	clone := self.cloneSelf(_transient);
	clone.setForCreate(self.exportBookingReference,self.importBookingReference,
						self.exportBOL,self.importBOL,self.importOriginalLoadPort,self.myDischargePort,
						_ti,self.transhipToPorts);
	

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="0533354d-4446-405f-8430-ed11fe567c94">
        <updating/>
        <source>delete() updating;
//
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
vars
	port : CM_Port;
begin
	foreach port in self.transhipToPorts do
		if port.isTransient then
			delete port;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="dischargePort" id="27b74e23-4b64-4d27-9d37-ef21cbd00c90">
        <source>dischargePort() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/05/2010	cnwdap1	Initial creation - new for CCMS 1116 Tranship changes
*/
vars

begin
	if self.myDischargePort &lt;&gt; null then
		return self.myDischargePort.code;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getToPortsString" id="2faa1165-87c9-4546-bc24-3d93f4c0ec84">
        <source>getToPortsString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 November 2013	cnwndl1	Initial creation	Par 32706

*/

vars

	retStr : String;
	port : CM_Port;

begin

	if self.transhipToPorts = null 
	or self.transhipToPorts.isEmpty then
		retStr := null;
	else
		foreach port in self.transhipToPorts do
			if retStr = null then
				retStr := port.code;
			else
				retStr := retStr &amp; " " &amp; port.code;
			endif;
		endforeach;
	endif;

epilog

	return retStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="94b39c62-5b11-4507-b3b7-fafb83004f4d">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/06/2010	cnwdap1	Initial creation PAR #24516
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
*/
vars
	transhipDetail 	: CM_TranshipDetail;
	port, pxyPort	: CM_Port;
	completedOK		: Boolean;
	
begin
	transhipDetail := inheritMethod();
	
	foreach port in self.transhipToPorts do
	//	pxyPort := port.pxyCreateUpdateProxy();
	//	transhipDetail.transhipToPorts.add(pxyPort);
		transhipDetail.transhipToPorts.add(port);	//24 Mar 2020	NDL	TFS 48886
	endforeach;
	
	transhipDetail.myDischargePort := self.myDischargePort;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return transhipDetail;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete transhipDetail;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAltDischargePorts" id="fa42dc48-5446-4343-be36-7d88eb7ef9ca">
        <updating/>
        <source>setAltDischargePorts(_transhipPorts : CM_PortArray) updating;
//
//cnwrs1 CCMS 1137 18 July 2010
//
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal

vars

begin
	_transhipPorts.copy(self.transhipToPorts);
end;
</source>
        <Parameter name="_transhipPorts" type="CM_PortArray"/>
    </JadeMethod>
