    <JadeMethod name="getDisplayTextForTI" id="19b7a051-0108-42b0-a920-d74308fffcdf">
        <source>getDisplayTextForTI(_ti : CM_TrackedItem) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwjk3	Initial creation

*/
constants 
	Factor : Real = 0.001;
vars
	maxDisplay : Boolean;
	lc : CM_GridController;
	id,
	isoType,
	weight,
	text	: String;
begin
	lc := _ti.myPrimaryActualLocation.CM_GridController;
	if lc = null then
		return '';
	endif;
	
	maxDisplay := (self.isLandscape and self.scaleFactor &gt; 1.25) or
				  (not self.isLandscape and self.scaleFactor &gt; 1);
	
	
	// Id
	if maxDisplay then
		text := _ti.getSplitIdText();
	endif;

	if maxDisplay then
		// ISO Type
		if self.isLandscape and self.scaleFactor &gt;= 1.5 or
		   not self.isLandscape and self.scaleFactor &gt;= 1.75 then
			if _ti.isKindOf(CM_Container) then
				if self.isLandscape and self.scaleFactor &lt; 2.5 then
					text := text &amp; " ";
				else
					text := text &amp; Cr &amp; Cr;
				endif;
				text := text &amp; _ti.CM_Container.isoType;
			endif;
		endif;
		
		
		// Weight
		if self.isLandscape and self.scaleFactor &gt;= 1.5 or
		   not self.isLandscape and self.scaleFactor &gt;= 1.75 then
			if self.isLandscape and self.scaleFactor &lt; 4.75 then
				text := text &amp; " ";
			else
				text := text &amp; Cr &amp; Cr;
			endif;
			text := text &amp; (_ti.totalWeight * Factor).roundedTo(1).String &amp; "T";
		endif;
	endif;
	
	// Height
	if self.isLandscape then
		text := text &amp; " ";
	else
		text := text &amp; Cr &amp; Cr;
	endif;
	text := text &amp; "H:" &amp; lc.getActualStackPositionOfTI(_ti).String;

	
	return text;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
