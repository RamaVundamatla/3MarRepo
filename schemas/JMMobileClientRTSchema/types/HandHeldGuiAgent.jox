    <JadeMethod name="getRTDeviceForSelf" id="9d8cd544-d61b-4629-9961-bb1ed6051c51">
        <source>getRTDeviceForSelf(_computerName : String) : CM_RadioTelemetryDevice;
/*
----------   ----------  --------------------------------------------------
Created:	02 April 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myDevice &lt;&gt; null then
		return self.myDevice.CM_RadioTelemetryDevice;
	endif;
	return self.myHandHeldAgent.getRTDeviceForSelf(_computerName);

end;


</source>
        <Parameter name="_computerName" type="String"/>
        <ReturnType type="MobileHandHeldThin::CM_RadioTelemetryDevice"/>
    </JadeMethod>
