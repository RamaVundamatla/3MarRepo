    <JadeMethod name="setValues" id="324a68a0-ce4e-41ce-bb4f-8a3a93c7266c">
        <updating/>
        <source>setValues(_newInvoice, _differentCargo, _diffChargeDT : Boolean; _invoice : CM_Invoice; _tiArray : CM_TIArray; _chargeDT : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2023  navmv20 TFS 55304 Task 55542: Jade - Invoice Line Copy Jade Code

*/

vars

begin

	self.pxyInvoice := _invoice;
	if _differentCargo then
		_tiArray.copy(self.allTrackedItems);
	else
		self.allTrackedItems.clear();
	endif;
	self.chargeDT := _chargeDT;
	self.newInvoice := _newInvoice;
	self.differentCargos := _differentCargo;
	self.differentChargeDT := _diffChargeDT;
epilog

end;</source>
        <Parameter name="_newInvoice" type="Boolean"/>
        <Parameter name="_differentCargo" type="Boolean"/>
        <Parameter name="_diffChargeDT" type="Boolean"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_tiArray" type="CM_TIArray"/>
        <Parameter name="_chargeDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="6142d804-1fc5-4d8a-a837-679b73834685">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:	
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 12 April 2023  navmv20 TFS 55304 Task 55542: Jade - Invoice Line Copy Jade Code
vars
	invLine     : CM_InvoiceLine;
begin
	if  self.myInvoice = null then 
		app.raiseCMException(Invoic_null_must_provid_invoic,null,null);
	else
		if  self.myInvoice.isVoided then
			app.raiseCMException1(Invoice_void_cannot_invoice, self.myInvoice.sequenceNum.String,null,null);
		elseif self.myInvoice.isPostedOrReversal then
			app.raiseCMException1(Invoice_posted_cannot_invoice, self.myInvoice.sequenceNum.String,null,null);
		endif;
	endif;
	
	invLine := self.pxyInvLine;
	
	if invLine.invoiceLineDesc = null then
		app.raiseCMException(Invoi_line_type_null_must_prov,null,null);
		return;
	endif;
		
end;</source>
    </JadeMethod>
</Class>
