    <JadeMethod name="doKeyDown" id="c667c7be-1a26-47cd-9fc3-f27bea60bce9">
        <updating/>
        <source>doKeyDown(keyCode: Integer io; shift: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if keyCode = J_key_F1 then
		self.showHideHelp(not self.frmHelp.visible);
		
	elseif keyCode = J_key_F10 then
		app.msgBox(app.myHandHeldGuiAgent.getWhoAmIInfo(),"Who Am I?", MsgBox_Information_Icon);
	elseif 	keyCode = J_key_F11 then
		self.inspect;
	else
		inheritMethod(keyCode, shift);
	endif;
	

end;


</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
