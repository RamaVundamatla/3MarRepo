<Class name="CMIF_YardAllocationEnquiryObj" id="fac20008-a2c1-414f-8813-cd1a80d0dbcd">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>As some of the fields displayed for a CM_YardAllocation object
are derived we only want to search once and then return</text>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allYardAllocationsForTI" id="e25a98a0-9ed7-4d79-8101-84da769a1b19">
