    <JadeMethod name="translateForm" id="894bc6ab-e218-44ad-a71b-aefe5a3b6ace">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:44:38.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023332, locale);
	btnAddTime.translateCaption(Xlat_0023337, locale);
	btnClose1.translateCaption(Xlat_0023341, locale);
	btnDelTime.translateCaption(Xlat_0023335, locale);
	btnOK.translateCaption(Xlat_0023342, locale);
	btnUpdTime.translateCaption(Xlat_0023336, locale);
	chkIsDefault.translateCaption(Xlat_0023333, locale);
	lblCalendar.translateCaption(Xlat_0023339, locale);
	lblName.translateCaption(Xlat_0023334, locale);
	lblPriority.translateCaption(Xlat_0023340, locale);
	lblTerminal.translateCaption(Xlat_0023338, locale);
end;</source>
    </JadeMethod>
</GUIClass>
