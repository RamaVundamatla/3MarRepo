    <JadeMethod name="getOnsiteCargoFromColourCoding" id="eff6ed1a-a260-45f0-ba4d-a923201aecb8">
        <updating/>
        <source>getOnsiteCargoFromColourCoding(_tis: CM_TIArray input) updating;
// ---------------------------------------------------------------------------
// Created:		08 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		Get TIs from colour coding
//
// ---------------------------------------------------------------------------

vars
	anObj : Object;
	aTI : CM_TrackedItem;
	anLC : CM_SlotController;
	aFM : CM_FutureMovePlanned;
	slots : CM_SlotRequestSet;
	slot : CM_SlotRequest;
begin
	create slots transient;
	foreach anObj in self.allSelectedObjects do
		if anObj.isKindOf(CM_SlotController) then
			anLC := anObj.CM_SlotController;
			slot := null;
			if self.displayMode = ShpDisplayMode_ColCodeLoad then
				slot := anLC.mySlotRequestLoad;
			elseif self.displayMode = ShpDisplayMode_ColCodeDisch then
				slot := anLC.mySlotRequestDischarge;
			endif;
			if slot &lt;&gt; null then
				slots.add(slot);
			endif;
		endif;
	endforeach;

	self.myVoyage.getOnsiteCargoFromColourCoding(slots,_tis);
epilog
delete slots;
end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPositionForAttrbuteDefn" id="e3e7199e-5205-46a9-81a0-4b7e90802cbc">
        <source>getPositionForAttrbuteDefn(_theAttribute : String) : Integer protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		For displayMode = ShpDisplayMode_Defn the attributes are
//				shown in particular positions
// ---------------------------------------------------------------------------
vars
	theAttributePosition : Integer;

begin
	if _theAttribute = PicTI40FooterBackEnd then
		theAttributePosition := 5;
	elseif _theAttribute = PicTI40Footer then
		theAttributePosition := 5;
	
	// PAR 16415 CCMS 1029
	elseif _theAttribute = PicTI30Footer then
		theAttributePosition := 8;
	elseif _theAttribute = PicTI53Footer then
		theAttributePosition := 9;
	elseif _theAttribute = PicTI30FooterBE then
		theAttributePosition := 8;
	elseif _theAttribute = PicTI53FooterBE then
		theAttributePosition := 9;
		
	// PAR 18682
	elseif _theAttribute = PicTI45Footer then
		theAttributePosition := 9;
	elseif _theAttribute = PicTI45FooterBackEnd then
		theAttributePosition := 9;
	
	elseif _theAttribute = PicTIUnavail then
		theAttributePosition := 1;
	elseif _theAttribute = PicTIMotorFwd then // 20 MOTOR
		theAttributePosition := 1;
	elseif _theAttribute = PicTIMotorAft then // 20 MOTOR
		theAttributePosition := 1;
	elseif _theAttribute = PicTIDoorsAft then // 20 DOOR
		theAttributePosition := 3;
	elseif _theAttribute = PicTIDoorsFwd then // 20 DOOR
		theAttributePosition := 3;

	elseif _theAttribute = PicTIMotorFwd40 then // 40 MOTOR
		theAttributePosition := 2;
	elseif _theAttribute = PicTIMotorAft40 then // 40 MOTOR
		theAttributePosition := 2;
	elseif _theAttribute = PicTIDoorsAft40 then // 40 DOOR
		theAttributePosition := 4;
	elseif _theAttribute = PicTIDoorsFwd40 then // 40 DOOR
		theAttributePosition := 4;

	elseif _theAttribute = PicTIReefer then
		theAttributePosition := 6;
	elseif _theAttribute = PicTIWaterCooled then
		theAttributePosition := 6;
	elseif _theAttribute = PicTIMTOnly or _theAttribute = PicTIEmpty then
		theAttributePosition := 6;
	elseif _theAttribute = PicTIHeavy then
		theAttributePosition := 6;
	elseif _theAttribute = PicTIVoltageSingle or _theAttribute = PicTIVoltageDual then
		theAttributePosition := 9;
	elseif _theAttribute = PicTIConnected then
		theAttributePosition := 7;
	elseif _theAttribute = PicTIOversized then
		theAttributePosition := 8;
	elseif _theAttribute = PicTIHazard then
		theAttributePosition := 9;
	endif;

	return theAttributePosition;
	
end;</source>
        <access>protected</access>
        <Parameter name="_theAttribute" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedSlotControllers" id="5964513a-7a11-4eb9-a736-51b303a9f0dd">
        <source>getSelectedSlotControllers(_slots : CM_SlotControllerSet input);
// ---------------------------------------------------------------------------
// Created:     03 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj	: Object;
begin
	
	foreach tmpObj in self.allSelectedObjects do
		if (not CM_SlotController.hasInstance(tmpObj)) then
			continue;
		endif;
		
		_slots.add(tmpObj.CM_SlotController);
	endforeach;
	
end;</source>
        <Parameter name="_slots" type="CM_SlotControllerSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSequenceNumForRequest" id="7f8a6bf2-1a1a-4b26-894f-cd66964388f7">
        <source>getSequenceNumForRequest(_req : CM_SlotRequest) : String;
// ---------------------------------------------------------------------------
// Created:     17 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	seqObj	: CMIF_CustomSequenceObject;
	isTLSequenceView : Boolean;
begin

	if _req = null then
		return null;
	endif;

	if self.workingMode = SHP_VoyageAreaForm2.WorkMode_CustomSeq then
		if self.myVoyageAreaForm &lt;&gt; null then
			seqObj := self.myVoyageAreaForm.allCustomSeqObjsByReq[_req];
			if seqObj &lt;&gt; null then
				if self.zeroFilleSeqNum then
					if self.isTwinLiftSequenceView then
						return seqObj.seqNumTwin.stringWithLeadingZeros(3);
					else
						return seqObj.seqNum.stringWithLeadingZeros(3);
					endif;
				else
					if self.isTwinLiftSequenceView then
						return seqObj.seqNumTwin.asStringJMT;
					else
						return seqObj.seqNum.asStringJMT;
					endif;
				endif;
			endif;
		endif;
	endif;
	// PAR 14810  in Planning mode always show the seq by the job.
	if self.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan then
		isTLSequenceView := _req.myJob.CM_VoyageJob.isTwinLift; // PAR 14810 
		return _req.getSeqNumStringForXML(isTLSequenceView, self.isStarboardBerthed, false, self.zeroFilleSeqNum, self.amPrinting); // PAR 14810 
	else 
		return _req.getSeqNumStringForXML(self.isTwinLiftSequenceView, self.isStarboardBerthed, false, self.zeroFilleSeqNum, self.amPrinting);
	endif;
end;</source>
        <Parameter name="_req" type="CM_SlotRequest"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShipShowISOType" id="33b7aef8-0101-4675-b0c1-41acb3ee10c6">
        <source>getShipShowISOType(): Boolean;
/*

Purpose:			 // TFS 37556

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2018	jlgab1	Initial creation

*/

vars

begin
	return self.shipShowISOType;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSpecialStow" id="3dddbabe-19fd-40b4-b8cf-406ea6d97b2e">
        <source>getSpecialStow(_ti : CM_TrackedItem) : CM_SpecialStow;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/05/2015	cnwdap1		Initial creation PAR #36206 Graphical Representation of Hazard Class
//
vars
	ti : CM_TrackedItem;
	request : CM_SlotRequest;
	allocation : CM_YardAllocation;
	criteria : CM_YACriteria;
	specialStows : CM_ObjectSet;
	specialStow : CM_SpecialStow;

begin
	// do we have a TI? - get the hazard class from there
	if _ti &lt;&gt; null then
		ti := _ti;
	else
		ti := self.allTrackedItems.first;
	endif;
	if ti &lt;&gt; null then
		specialStow := app.myRoot.allSpecialStows[ti.specialStow];
		return specialStow;
	endif;
		
	// if no TI, do we have a slot request with a voyage allocation for special stow
	if self.myLocationsController &lt;&gt; null and not self.myLocationsController.CM_SlotController.allSlotRequestsLoad.isEmpty then
		request := self.myLocationsController.CM_SlotController.allSlotRequestsLoad.first;
		criteria := request.getAttrByType(YACriteriaType_SpecialStow);
		if criteria &lt;&gt; null then
			specialStows := criteria.myYAData.getDataValue.CM_ObjectSet;
			if not specialStows.isEmpty then
				return specialStows.first.CM_SpecialStow;
			endif;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_SpecialStow"/>
    </JadeMethod>
    <JadeMethod name="getTI" id="686fe40e-6fb2-42f0-993c-0798cc6c8605">
        <source>getTI(x: Real; y: Real): CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI, theLTI, theDTI	: CM_TrackedItem;
	rtnStr	: String;
	tmpYPos	: Real;
	numTIs,
	theReturn,idx		: Integer;
	lDisplayMode : Integer;
	tmpSlotController : CM_SlotController;
	theTIs: CM_TIArray;
begin

	lDisplayMode := self.displayMode;

	tmpSlotController := self.myLocationsController.CM_SlotController;

	// planning in load colour coding
	if (lDisplayMode = ShpDisplayMode_ColCodeLoad and 
	   self.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan) then

		// it is possible to have discharge CC for a SOB AND load CC for an export, in the same slot.
		// the user is allowed to drag drop either, so if we have both then ask which one to use
		if tmpSlotController.mySlotRequestLoad &lt;&gt; null and 
		   tmpSlotController.mySlotRequestLoad.moveType &lt;&gt; NULL_MOVETYPE then
			create theTIs transient;
			tmpSlotController.getAllPlannedTrackedItems(theTIs, true, false);
			if not theTIs.isEmpty then
				theLTI := theTIs.first;
			endif;
		endif;

		// only get the TI from the discharge CC if it is SOB and the job is incomplete, else get the ti for the load
		if tmpSlotController.mySlotRequestDischarge &lt;&gt; null then
			if tmpSlotController.mySlotRequestDischarge.moveType = SOB_MOVETYPE then
				if not tmpSlotController.allTrackedItems.isEmpty then
					theDTI := tmpSlotController.allTrackedItems[1];
				endif;
			endif;
		endif;


		if theLTI &lt;&gt; null and theDTI &lt;&gt; null then
			theReturn := app.msgBox("Do you want the SOB cargo (" &amp; theDTI.id &amp; ") for this move?","Confirm Drag Drop",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if theReturn = MsgBox_Return_Yes then
				theTI := theDTI;
			else
				theTI := theLTI;
			endif;
		elseif theDTI &lt;&gt; null then
			theTI := theDTI;
		else
			theTI := theLTI;
		endif;
		
		return theTI;		

	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		create theTIs transient;
		tmpSlotController.getAllPlannedTrackedItems(theTIs, true, false);
		if not theTIs.isEmpty then
			return null;
		endif;
		return theTIs[1];

	elseif lDisplayMode = DISPLAY_MODE_ACTUAL then
		if tmpSlotController.allTrackedItems.isEmpty then
			return null;
		endif;
		return tmpSlotController.allTrackedItems[1];
	
	endif;

epilog
	delete theTIs;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTextExtent999" id="820c7d6e-ae58-4eb5-aec9-1d2d40fc7468">
        <updating/>
        <source>getTextExtent999(_frame : Frame) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpNum	: Integer;
begin
	tmpNum := self.textExtent999;
	if tmpNum &lt;&gt; 0 then
		return tmpNum;
	endif;
	
	tmpNum := _frame.getTextExtent('999');
	self.textExtent999 := tmpNum;

	return tmpNum;

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getVoyageAllocCCAttributes" id="fb5b9f56-998d-449b-af93-4527b46f766b">
        <source>getVoyageAllocCCAttributes( _slotRequest : CM_SlotRequest) : CMIF_VoyageAllocCCAttributes protected;
/*

Date		Who		Reason
02 February 2017	cnwer1	Initial creation TFS 3284

*/

vars	
	
begin
	if _slotRequest = null then
		return null;
	endif;
	
	return _slotRequest.getVoyageAllocCCAttributes(self.allVoyageAllocCCAttributes);
	

epilog

