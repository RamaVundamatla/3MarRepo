    <JadeMethod name="setupVoyageCopyProxy" id="11e81189-eaa8-409b-965d-64c51d817b1a">
        <source>setupVoyageCopyProxy( pxyVoyage : CM_Voyage input; _newVoyageCode : String; _sourceVoyage : CM_Voyage ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
11/07/2013	cnwndl1	Par 31965		Initial creation	
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/
vars
	useHMSData				 : Boolean;
	vessel					 : CM_Vessel;
	pxyGeneralCargoStructure : CM_GeneralCargoVoyageStructure;
	now						 : TimeStamp;
	arrivalDate				 : TimeStamp;
	departureDate 			 : TimeStamp;
	pxyGlobalVoyage			 : CM_VoyageGlobal;
	trade					 : CM_Trade;
	berth					 : HMS_Berth;
	pxyHMSData				 : HMS_VoyageData;
	pxyVoyagePortRotation	 : CM_PortRotation;
	portRotation			 : CM_PortRotation;
	term					 : CM_Terminal;
begin
	term := self.getTerminal();

	vessel := _sourceVoyage.myVessel;
	trade := getTrade;						

	create pxyGeneralCargoStructure transient;
	pxyVoyage.setProxyVoyageGeneralCargo(pxyGeneralCargoStructure);
	
	
	pxyVoyage.setProxyForVoyageType(	false,
										false,
										true,
										vessel);
										
	////////////////////////////////////////////////////////////
	// this is the bit that makes it use the voyage gcs, instead of the vessel defs...
	pxyVoyage.myGeneralCargoVoyage.setDefaultLocationsFrom( _sourceVoyage.myGeneralCargoVoyage, true );
	////////////////////////////////////////////////////////////////////
	

	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(_newVoyageCode, vessel.code, null, null, null, null, null, 0, null, app.myRoot);
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(2);

	pxyVoyage.setProxyVoyage(	null,
								"",
								_newVoyageCode,
								"",
								"",
								vessel.code,
								vessel.name,
								"",
								true,
/*			PAR 33644					true,
								false, */
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null,
								null,
								_sourceVoyage.myOperator,
								trade,
								_sourceVoyage.myShippingLine,
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
								null,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		// 27/05/2009 cnwar2 CCMS1040
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								null,null,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null,			// TFS 4050
								pxyVoyage.paymentType,
								pxyVoyage.isBarge, 			//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,   //03/06/2020 cnwma1 Tfs #49400
								false	// 31.Aug.2023 navsp1 TFS 57809
								);					
								
	if self.opts.includesKey("useHMSData") then
		useHMSData := self.opts.bool("useHMSData");
	endif;
	if useHMSData then
		berth := self.opts.obj("berth").HMS_Berth;
		create pxyHMSData transient;
		pxyHMSData.setPxyFromVessel(vessel, term);
		pxyHMSData.setMyBerth(berth);
		pxyVoyage.setHMSVoyageData(pxyHMSData);
		pxyHMSData.setProxyDefaultVoyageMovements(berth, null, app.myPassport);
	endif;

	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
	endforeach;
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);
end;</source>
        <access>protected</access>
        <Parameter name="pxyVoyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_newVoyageCode" type="String"/>
        <Parameter name="_sourceVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="tAddVoyageCutOff" id="b38248f5-7216-4ef0-9425-e98f232fb2f1">
        <source>tAddVoyageCutOff();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2015	cnwmk3	Initial creation

*/
constants
	CutOffCode			: String = "PRENOTE2";
vars
	proxy, cutoff		:CM_ReceivalCutoffTermDef;
	sort				: Integer;
	cmif				: CMIF_Array;
begin
	self.deleteVoyageCutoff(CutOffCode);
	assertNull(self.getTerminal.allReceivalCutoffDefs[CutOffCode]);
	create proxy transient;
	proxy.setValues(CutOffCode, CutOffCode, 11, DefaultRelativeTo_Departure, 2, 0, true, CM_ReceivalCutoffTermDef.CriteriaType_CARGO, self.getTerminal, 
					2, 	//04/03/2025	navkc1 JIRA Story MTN-34227
					0); 	//04/03/2025	navkc1 JIRA Story MTN-34227
	
	create cmif transient;
	app.myTrxCA.trxCreateRecRestrictionDef(proxy, cmif, cutoff, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	self.assertNotNull(cutoff);
epilog
	delete cmif;
	delete proxy;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBasicGeneralCargoVoyage" id="1da897bf-ad30-4ccd-a35a-b871c877e98c">
        <source>tBasicGeneralCargoVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/07/2013	cnwndl1	Initial creation	Par 31965
27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
*/

constants
	
	VesselCodeString = "UT_GC1";
	Voyage1CodeString = "UT_GC1_01";
	Voyage2CodeString = "UT_GC1_02";
	
vars

	vessel : CM_Vessel;
	gcHoldLocnDefn : CM_GCHoldLocationDefn;
	proxyHoldLocnDefn : CM_GCHoldLocationDefn;
	loadState : Boolean;
	voyage1 : CM_Voyage;
	proxyGCCont : CM_GeneralCargoController;
	realGCCont : CM_VoyageController;
	proxyVoyage2 : CM_Voyage;
	voyage2 : CM_Voyage;
	
begin
	//Reset the Data
	self.deleteVessel(VesselCodeString);
	self.deleteVoyage(Voyage1CodeString);
	self.deleteVoyage(Voyage2CodeString);
	
	//Create a general cargo vessel
	vessel := self.addVesselGeneralCargo(VesselCodeString, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 0);
	self.assertNotNullMsg(vessel, "Add vessel failed");
	// add the gc locations
	self.addGCHoldDefn(	vessel.myGeneralCargoVesselStructure,	//_gcVesselStruct: CM_GeneralCargoVesselStructure;
						1,	//_holdNum: Integer;
						1,	//_placeNum: Integer;
						true,	//_isOnDeck : Boolean;			// PAR #36766
						null, 	// _maxWeight : Integer;		// PAR #36766
						null,	// _maxVolume: Decimal;			// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;		// TFS 1601
						"On Deck"	//_locName: String
						);
	self.addGCHoldDefn(	vessel.myGeneralCargoVesselStructure,	//_gcVesselStruct: CM_GeneralCargoVesselStructure;
						1,	//_holdNum: Integer;
						2,	//_placeNum: Integer;
						false,	//_isOnDeck : Boolean;			// PAR #36766
						null, 	// _maxWeight : Integer;		// PAR #36766
						null,	// _maxVolume: Decimal;			// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;		// TFS 1601
						"Under Deck"	//_locName: String
						);
	self.addGCHoldDefn(	vessel.myGeneralCargoVesselStructure,	//_gcVesselStruct: CM_GeneralCargoVesselStructure;
						1,	//_holdNum: Integer;
						3,	//_placeNum: Integer;
						false,	//_isOnDeck : Boolean;			// PAR #36766
						null, 	// _maxWeight : Integer;		// PAR #36766
						null,	// _maxVolume: Decimal;			// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;		// TFS 1601
						"Bilge"	//_locName: String
						);
	self.addGCHoldDefn(	vessel.myGeneralCargoVesselStructure,	//_gcVesselStruct: CM_GeneralCargoVesselStructure;
						3,	//_holdNum: Integer;
						1,	//_placeNum: Integer;
						true,	//_isOnDeck : Boolean;			// PAR #36766
						null, 	// _maxWeight : Integer;		// PAR #36766
						null,	// _maxVolume: Decimal;			// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;		// TFS 1601
						"On Deck"	//_locName: String
						);
	self.addGCHoldDefn(	vessel.myGeneralCargoVesselStructure,	//_gcVesselStruct: CM_GeneralCargoVesselStructure;
						3,	//_holdNum: Integer;
						2,	//_placeNum: Integer;
						false,	//_isOnDeck : Boolean;			// PAR #36766
						null, 	// _maxWeight : Integer;		// PAR #36766
						null,	// _maxVolume: Decimal;			// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;		// TFS 1601
						"Under Deck"	//_locName: String
						);
	self.addGCHoldDefn(	vessel.myGeneralCargoVesselStructure,	//_gcVesselStruct: CM_GeneralCargoVesselStructure;
						3,	//_holdNum: Integer;
						3,	//_placeNum: Integer;
						false,	//_isOnDeck : Boolean;			// PAR #36766
						null, 	// _maxWeight : Integer;		// PAR #36766
						null,	// _maxVolume: Decimal;			// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;		// TFS 1601
						"Bilge"	//_locName: String
						);
	gcHoldLocnDefn := self.addGCHoldDefn(	vessel.myGeneralCargoVesselStructure,	//_gcVesselStruct: CM_GeneralCargoVesselStructure;
						2,	//_holdNum: Integer;
						1,	//_placeNum: Integer;
						false,	//_isOnDeck : Boolean;			// PAR #36766
						null, 	// _maxWeight : Integer;		// PAR #36766
						null,	// _maxVolume: Decimal;			// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;		// TFS 1601
						"Bilge"	//_locName: String
						);
						
	//change the last gc location
	app.myPassport.setWarningsIgnored(true);
	app.cmsBeginLoad(loadState);
	proxyHoldLocnDefn := gcHoldLocnDefn.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadState);
	proxyHoldLocnDefn.setProxy(	5,	//_hatch : Integer;
								"Sub-bilge",	//_name : String;
								5,	//_place : Integer;
								false,	// _isOnDeck : Boolean;			// PAR #36766
								null,	// _maxWeight : Boolean;		// PAR #36766
								null,	// _maxVolume: Decimal;			// TFS 1601
								0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
								1,		// _onShipCrane: Integer;		// TFS 1601
								vessel.myGeneralCargoVesselStructure	//_myGCVesselStructure : CM_GeneralCargoVesselStructure
								);
	app.myTrxUA.trxUpdateGCHoldLocnDefn(proxyHoldLocnDefn, app.myPassport);
	delete proxyHoldLocnDefn;
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "GC Hold Defn update failed : " &amp; app.myPassport.getAllErrorsAndWarningsAsStr );
	app.myPassport.setWarningsIgnored(false);
	
	//create a voyage form this vessel.
	voyage1 := self.addVoyageWithGeneralCargoStruc(	Voyage1CodeString,
													vessel.name,
													vessel.myOperator.code,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(),
													0);
	self.assertTrueMsg( voyage1 &lt;&gt; null, "GC Voyage create failed : " &amp; app.myPassport.getAllErrorsAndWarningsAsStr );
	self.assertTrueMsg( voyage1.myGeneralCargoVoyage &lt;&gt; null, "GC Voyage has no GC Structure" );
	self.assertTrueMsg( not voyage1.myGeneralCargoVoyage.allLocationsByHatchPlace.isEmpty, "GC Voyage has no GC Hold Locations" );
	self.assertTrueMsg( voyage1.myGeneralCargoVoyage.allLocationsByHatchPlace.size = vessel.myGeneralCargoVesselStructure.allHoldLocnDefnByHatchPlace.size, "GC Voyage has wrong number of GC Location Controllers on first build" );
	
	//Add another location to the voyage.
	create proxyGCCont transient;
	proxyGCCont.setProxy(	voyage1.myGeneralCargoVoyage,	//_gcVoyage : CM_GeneralCargoVoyageStructure;
							6,	//_hatch : Integer;
							1,	//_place : Integer;
							"Up Top",	//_name : String;
							true,	// _isOnDeck : Boolean			// PAR #36766
							null,	// _maxWeight : Integetr		// PAR #36766
							null,	// _maxVolume: Decimal;			// TFS 1601
							0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
							1		// _onShipCrane: Integer;		// TFS 1601
							);
							
	app.myTrxCA.trxCreateVoyageController(proxyGCCont, realGCCont, app.myPassport);
	self.assertTrueMsg( realGCCont &lt;&gt; null, "Add GC Controller failed : " &amp; app.myPassport.getAllErrorsAndWarningsAsStr );
	self.assertTrueMsg( voyage1.myGeneralCargoVoyage.allLocationsByHatchPlace.size = vessel.myGeneralCargoVesselStructure.allHoldLocnDefnByHatchPlace.size + 1, "GC Voyage has wrong number of GC Location Controllers after add" );
	delete proxyGCCont;
	
	app.cmsBeginLoad(loadState);
	proxyGCCont := realGCCont.CM_GeneralCargoController.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadState);
	proxyGCCont.setProxy(	voyage1.myGeneralCargoVoyage,	//_gcVoyage : CM_GeneralCargoVoyageStructure;
							7,	//_hatch : Integer;
							2,	//_place : Integer;
							"Bilge",	//_name : String;
							false,	// _isOnDeck : Boolean			// PAR #36766
							null,	// _maxWeight : Integer			// PAR #36766
							null,	// _maxVolume: Decimal;			// TFS 1601
							0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
							1		// _onShipCrane: Integer;		// TFS 1601
							);
	
	app.myTrxUA.trxUpdateGenGCController(proxyGCCont, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "Update of GC Controller failed : " &amp; app.myPassport.getAllErrorsAndWarningsAsStr );
	self.assertTrueMsg( realGCCont.CM_GeneralCargoController.hatch = 7, "Update of GC Controller failed : hold s/be 7" );
	self.assertTrueMsg( realGCCont.CM_GeneralCargoController.place = 2, "Update of GC Controller failed : place s/be 2" );
	self.assertTrueMsg( realGCCont.CM_GeneralCargoController.name = "Bilge", "Update of GC Controller failed : name s/be Bilge" );
	delete proxyGCCont;
	
	//create a new voyage using this one as a template.
	create proxyVoyage2 transient;
	self.setupVoyageCopyProxy( proxyVoyage2, Voyage2CodeString, voyage1 );
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateVoyage(proxyVoyage2, voyage2, vessel, null, true, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "Copy of voyage 1 failed : " &amp; app.myPassport.getAllErrorsAndWarningsAsStr );
	self.assertTrueMsg( voyage1.myGeneralCargoVoyage.allLocationsByHatchPlace.size = voyage2.myGeneralCargoVoyage.allLocationsByHatchPlace.size, "GC Voyage2 (copied version) has wrong number of GC Location Controllers" );

		
epilog

	app.myPassport.setWarningsIgnored(false);

	// 24/02/2014 cnwmh5 - Transient Leaks
	if proxyVoyage2 &lt;&gt; null then
		delete proxyVoyage2.myGeneralCargoVoyage;
		if proxyVoyage2.allPortRotations &lt;&gt; null then
			proxyVoyage2.allPortRotations.purge();
		endif;
	endif;
	
	delete proxyHoldLocnDefn;
	delete proxyGCCont;
	delete proxyVoyage2;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoForecastChkAudit" id="5e891b91-9c3a-4692-b03b-92f9dcdd94e8">
        <source>tCargoForecastChkAudit();
/*

Purpose:			Tests the audits on an Cargo Forecast for creation, update and deletion

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
11 April 2022	navpw1	Initial creation TFS: 53132

*/

//Total of 3 Tests to run Audit Create, Audit Update. Each test has their own assert section

constants
	Ref						: String		= UT_DSL.TFS53132;
	TOTALQUANTITY 			: Integer 		= 12;
	TOTALWEIGHT				: Decimal[23,6] = 23.345;
	TOTALVOLUME				: Decimal[23,6] = 24.345;
	
	UPDTOTALQUANTITY 		: Integer 		= 15;
	UPDTOTALWEIGHT			: Decimal[23,6] = 26.345;
	UPDTOTALVOLUME			: Decimal[23,6] = 27.345;
	
	VESSELID				: String 		= "UTVES" &amp; Ref;
	VOYAGEID				: String 		= "UTVOY" &amp; Ref;
	
vars
	pxyCargoForecast,
	realCargoForecast		: CM_CargoForecast;
	cargoType				: CM_CargoType;
	commodity				: CM_Commodity;
	operator				: CM_Operator;
	vessel					: CM_Vessel;
	voyage					: CM_Voyage;
	
	error					: CM_Error;
	cargoTypeCommodityError, 
	imexStatusError,
	totalWeightError		: Boolean;
	auditObj 				: CM_AuditObject;
	createAuditExists,
	updateAuditExists,
	deleteAuditExists		: Boolean;
	mode					: String;
	
begin
	/*
	** Clean Up After Last test
	*/
	// delete voyage
	self.deleteVoyage(VOYAGEID);
	self.assertNoTrxErrorsOrWarnings();
	
	//Delete Vessel
	self.deleteVessel(VESSELID);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	**	Setup Test Create - Normal Happy Day Scenario
	*/
	operator 	:= app.myRoot.allOperators["****"];
	self.assertNotNullMsg(operator, "Operator is null");
	
	cargoType 	:= app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT");
	self.assertNotNullMsg(cargoType, "Cargo type is null");
	
	commodity 	:= app.myRoot.allCommodities["GENL"];
	self.assertNotNullMsg(commodity, "Commodity is null");
	
	mode 		:= CM_CargoForecast.Mode_Discharge;
	
	//Create Vessel
	vessel := self.addVesselCellular(VESSELID, operator);
	self.assertNotNull(vessel);
	
	//Create voyage
	voyage 		:= self.addVoyageWithContainerStructur(VOYAGEID, VESSELID, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, "Voyage is null");
	
	/*
	**	Run Test Create - Normal Happy Day Scenario
	*/
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, voyage);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	foreach auditObj in realCargoForecast.allAuditObjectsForClass do
		if auditObj.type = AuditCreated then
			createAuditExists := true;
			break;
		endif;
	endforeach;
	
	//Check the new reference are not null
	self.assertTrueMsg(createAuditExists, "Cargo Forecast: Could not find an audit of type Created");
	
	/*
	**	Setup Test Update - Normal Happy Day Scenario
	*/
	delete pxyCargoForecast;
	
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, voyage);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Run Test Update - Normal Happy Day Scenario
	*/
	delete pxyCargoForecast;
	
	pxyCargoForecast := app.createUpdateProxy(realCargoForecast).CM_CargoForecast;
	
	pxyCargoForecast.setProxyForUpdate(cargoType, commodity, mode, operator, UPDTOTALQUANTITY, UPDTOTALWEIGHT, UPDTOTALVOLUME, voyage);
	
	app.myTrxUA.trxUpdateCargoForecast(pxyCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Update - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	foreach auditObj in realCargoForecast.allAuditObjectsForClass do
		if auditObj.type = AuditUpdated then
			updateAuditExists := true;
			break;
		endif;
	endforeach;
	
	//Check the new reference are not null
	self.assertTrueMsg(updateAuditExists, "Cargo Forecast: Could not find an audit of type Updated");
	
	/*
	** Clean Up After test
	*/
	// delete voyage
	self.deleteVoyage(VOYAGEID);
	self.assertNoTrxErrorsOrWarnings();
	
	//Delete Vessel
	self.deleteVessel(VESSELID);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyCargoForecast;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoForecastCreate" id="2de42960-013c-48c9-b927-9f76a9344376">
        <source>tCargoForecastCreate();
/*

Purpose:			Tests that a Cargo Forecast can be created

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
07 April 2022	navpw1	Initial creation TFS: 53132

*/

constants
	Ref						: String		= UT_DSL.TFS53132;
	TOTALQUANTITY 			: Integer 		= 12;
	TOTALWEIGHT				: Decimal[23,6] = 23.345;
	TOTALVOLUME				: Decimal[23,6] = 24.345;
	
	VESSELID				: String 		= "UTVES" &amp; Ref;
	VOYAGEID				: String 		= "UTVOY" &amp; Ref;
	
vars
	pxyCargoForecast,
	realCargoForecast		: CM_CargoForecast;
	cargoType				: CM_CargoType;
	commodity				: CM_Commodity;
	operator				: CM_Operator;
	vessel					: CM_Vessel;
	voyage					: CM_Voyage;
	
	error					: CM_Error;
	cargoTypeCommodityError, 
	imexStatusError,
	totalWeightError		: Boolean;
	mode					: String;
	terminal				: CM_Terminal;
	requiredFields			: String;
	
begin
	terminal := self.getMyTerminal();
	requiredFields := self.setTerminalConfig(CargoForecastReqdFields, ETRow_Quantity &amp; "," &amp; ETRow_Volume &amp; "," &amp; ETRow_Weight).String;
	
	/*
	** Clean Up After Last test
	*/
	// delete voyage
	self.deleteVoyage(VOYAGEID);
	//self.assertNoTrxErrorsOrWarnings();
	
	//Delete Vessel
	self.deleteVessel(VESSELID);
	//self.assertNoTrxErrorsOrWarnings();
	
	/*
	**	Setup Test Create - Normal Happy Day Scenario
	*/
	operator 	:= app.myRoot.allOperators["****"];
	self.assertNotNullMsg(operator, "Operator is null");
	
	cargoType 	:= app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT");
	self.assertNotNullMsg(cargoType, "Cargo type is null");
	
	commodity 	:= app.myRoot.allCommodities["GENL"];
	self.assertNotNullMsg(commodity, "Commodity is null");
	
	mode 		:= CM_CargoForecast.Mode_Discharge;
	
	//Create Vessel
	vessel := self.addVesselCellular(VESSELID, operator);
	self.assertNotNull(vessel);
	
	//Create voyage
	voyage 		:= self.addVoyageWithContainerStructur(VOYAGEID, VESSELID, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, "Voyage is null");
	
	/*
	**	Run Test Create - Normal Happy Day Scenario
	*/
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, voyage);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCargoType &lt;&gt; null, "Cargo Forecast: Cargo Type Object is null");
	self.assertTrueMsg(realCargoForecast.myCommodity &lt;&gt; null, "Cargo Forecast: Commodity Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast: Mode is null");
	self.assertTrueMsg(realCargoForecast.myOperator &lt;&gt; null, "Cargo Forecast: Operator Object is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = voyage, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCargoType = cargoType, "Cargo Forecast: Cargo Type Object does not match expected cargo type");
	self.assertTrueMsg(realCargoForecast.myCommodity = commodity, "Cargo Forecast: Commodity Object does not match expected commodity");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	self.assertTrueMsg(realCargoForecast.myOperator = operator, "Cargo Forecast: Operator Object does not match expected operator");
	
	self.assertTrueMsg(realCargoForecast.totalQuantity = TOTALQUANTITY, "The total quantity on the Cargo Forecast does not match expected value: " &amp; TOTALQUANTITY.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalWeight = TOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; TOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = TOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; TOTALVOLUME.asStringJMT());
	
	/*
	**	Setup Test Create - Test Mandatory fields not specified gives errors
	*/
	delete pxyCargoForecast;
	
	/*
	**	Run Test Create - Test Mandatory fields not specified gives errors
	*/
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(null, null, null, null, null, null, null, null);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Test Mandatory fields not specified gives errors
	*/
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	foreach error in app.myPassport.allErrors do
		if error.text.cnContains("Cargo Type or Commodity") then
			self.assertTrueMsg(error.errorCode = Input_req_cargo_type_commodity, "Expected Error Code:" &amp; Input_req_cargo_type_commodity.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains("Cargo Type or Commodity"), "Expected: error message to contain 'Cargo Type or Commodity' | Actual: " &amp; error.text);	//Check Error Message Contains cargo-type or commodity
			cargoTypeCommodityError := true;
			
		elseif error.text.cnContains("mode") then
			self.assertTrueMsg(error.errorCode = REQUIRED_FIELD, "Expected Error Code:" &amp; REQUIRED_FIELD.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains("mode"), "Expected: error message to contain 'mode' | Actual: " &amp; error.text);											//Check Error Message Contains mode
			imexStatusError := true;
			
		endif;
		
	endforeach;
	
	if not cargoTypeCommodityError then
		self.assertTrueMsg(cargoTypeCommodityError, "Expected: error to be raised for required field (cargo-type or commodity) | Actual: No Error Raised"); 				//Check Error Code Matches Expected
		
	elseif not imexStatusError then
		self.assertTrueMsg(imexStatusError, "Expected: error to be raised for required field (imex-status) | Actual: No Error Raised"); 									//Check Error Code Matches Expected
		
	endif;
	
	//Check no new object has been set
	self.assertTrueMsg(realCargoForecast = null, "Cargo Forecast: Object should be null");
	
	
	/*
	**	Setup Test Create - Test Mandatory fields only specified
	*/
	delete pxyCargoForecast;
	
	/*
	**	Run Test Create - Test Mandatory fields only specified
	*/
	self.setTerminalConfig(CargoForecastReqdFields, ETRow_Volume &amp; "," &amp; ETRow_Weight);
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, null, mode, null, null, TOTALWEIGHT, TOTALVOLUME, voyage);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Test Mandatory fields only specified
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCargoType &lt;&gt; null, "Cargo Forecast: Cargo Type Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast: Mode is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = voyage, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCargoType = cargoType, "Cargo Forecast: Cargo Type Object does not match expected cargo type");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	
	self.assertTrueMsg(realCargoForecast.totalWeight = TOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; TOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = TOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; TOTALVOLUME.asStringJMT());
	
	/*
	**	Setup Test Create - Test Mandatory fields only specified 2
	*/
	delete pxyCargoForecast;
	
	/*
	**	Run Test Create - Test Mandatory fields only specified 2
	*/
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(null, commodity, mode, null, null, TOTALWEIGHT, TOTALVOLUME, voyage);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Test Mandatory fields only specified 2
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCommodity &lt;&gt; null, "Cargo Forecast: Commodity Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast: Mode is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = voyage, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCommodity = commodity, "Cargo Forecast: Commodity Object does not match expected commodity");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	
	self.assertTrueMsg(realCargoForecast.totalWeight = TOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; TOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = TOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; TOTALVOLUME.asStringJMT());
	
	/*
	** Clean Up After test
	*/
	// delete voyage
	self.deleteVoyage(VOYAGEID);
	//self.assertNoTrxErrorsOrWarnings();
	
	//Delete Vessel
	self.deleteVessel(VESSELID);
	//self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyCargoForecast;
	self.setTerminalConfig(CargoForecastReqdFields, requiredFields);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoForecastDelete" id="690c2cfd-2156-4046-8dd4-a68fc826e82b">
        <source>tCargoForecastDelete();
/*

Purpose:			Tests that a Cargo Forecast can be deleted

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
07 April 2022	navpw1	Initial creation TFS: 53132

*/

constants
	Ref						: String		= UT_DSL.TFS53132;
	TOTALQUANTITY 			: Integer 		= 12;
	TOTALWEIGHT				: Decimal[23,6] = 23.345;
	TOTALVOLUME				: Decimal[23,6] = 24.345;
	
	VESSELID				: String 		= "UTVES" &amp; Ref;
	VOYAGEID				: String 		= "UTVOY" &amp; Ref;
	
vars
	pxyCargoForecast,
	realCargoForecast		: CM_CargoForecast;
	cargoType				: CM_CargoType;
	commodity				: CM_Commodity;
	operator				: CM_Operator;
	vessel					: CM_Vessel;
	voyage					: CM_Voyage;
	
	error					: CM_Error;
	cargoTypeCommodityError, 
	imexStatusError,
	totalWeightError		: Boolean;
	mode					: String;
	
begin
/*
	** Clean Up After Last test
	*/
	// delete voyage
	self.deleteVoyage(VOYAGEID);
	self.assertNoTrxErrorsOrWarnings();
	
	//Delete Vessel
	self.deleteVessel(VESSELID);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	**	Setup Test Create - Normal Happy Day Scenario
	*/
	operator 	:= app.myRoot.allOperators["****"];
	self.assertNotNullMsg(operator, "Operator is null");
	
	cargoType 	:= app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT");
	self.assertNotNullMsg(cargoType, "Cargo type is null");
	
	commodity 	:= app.myRoot.allCommodities["GENL"];
	self.assertNotNullMsg(commodity, "Commodity is null");
	
	mode 	:= CM_CargoForecast.Mode_Discharge;
	
	//Create Vessel
	vessel := self.addVesselCellular(VESSELID, operator);
	self.assertNotNull(vessel);
	
	//Create voyage
	voyage 		:= self.addVoyageWithContainerStructur(VOYAGEID, VESSELID, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, "Voyage is null");
	
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, voyage);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	delete pxyCargoForecast;
	
	/*
	**	Run Test Create - Normal Happy Day Scenario
	*/
	app.myTrxDA.trxDeleteCargoForecast(realCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Clean Up After test
	*/
	// delete voyage
	self.deleteVoyage(VOYAGEID);
	self.assertNoTrxErrorsOrWarnings();
	
	//Delete Vessel
	self.deleteVessel(VESSELID);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyCargoForecast;
	
end;</source>
