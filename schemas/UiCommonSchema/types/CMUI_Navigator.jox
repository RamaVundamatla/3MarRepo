    <JadeMethod name="addDtlToToolBar" id="bc4da572-7859-4f5d-beb1-39858139015d">
        <source>addDtlToToolBar() protected;
// ---------------------------------------------------------------------------
// Created:     17 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	menuEntity			: CM_MenuEntity;
	loadStateSet 		: Boolean;
	pxyMenuDtl,
	menuDtl		 		: CM_MenuUserDtl;	
	theUserTerminal 	: CM_UserTerminal;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	//we can safely cast into menuDtl class as this enabling of menu items logic dictates
	menuDtl := self.lstTest.listObject.CM_MenuUserDtl;
	
	theUserTerminal := app.getMyUser.getUserTerminal(self.lstTest.getTeminalOfCurrentEntity);
	
	if theUserTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, ' userTerminal is null');
		return;
	endif;
	
	app.cmsBeginLoad(loadStateSet);
	pxyMenuDtl := menuDtl.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadStateSet);
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateMenuToolbarAdd(theUserTerminal, pxyMenuDtl, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Update Toolbar', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	if pxyMenuDtl &lt;&gt; null then
		delete pxyMenuDtl;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnCloseSearchTV_click" id="07af4f49-083e-4cb5-b90a-1f528ad57576">
        <controlMethod name="Button::click"/>
