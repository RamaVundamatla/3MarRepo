//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return CM_CodeGroup;
end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="af52fc36-6cbd-4ffb-ac4b-5de10bd3cd3b">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	jCell						:JadeTableCell;
	maxCodeLength		:Integer;
begin
	inheritMethod();
	maxCodeLength := self.myParent.SOPVM_CodeGroup.myObject.CM_CodeGroup.myCodeGroupType.codeLengthMax;
	self.myForm.tblInput1.accessCell(self.myForm.tblInput1.getRowByName(ETRow_Code), CM_EntryTable.ColumnValue).maxLength := maxCodeLength;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="43b80e71-518d-415d-806e-b42a5f6ae347">
        <source>setControlsForView();
// ---------------------------------------------------------------------------
// Created:     11 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.myForm.btnNewChildTV.enabled	:= self.canAddChild;
	self.myForm.btnNewTV.enabled 		:= self.canAddPeer;
	self.myForm.btnDeleteTV.enabled 	:= self.canDelete;
	self.myForm.btnEditTV.enabled 		:= self.canEdit;
end;</source>
    </JadeMethod>
