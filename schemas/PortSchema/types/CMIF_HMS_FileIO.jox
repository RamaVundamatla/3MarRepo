<Class name="CMIF_HMS_FileIO" id="80b0e843-4568-473d-bb9a-d3b492102549">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="defaultFileName" id="fa1f1fc1-9c68-43c8-88a9-eef94f29e501">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="defaultPath" id="7116cac1-76b3-4799-b497-723bb8c5fad0">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="closeFile" id="a6e5b2c0-f67e-48af-bad5-f0bb3857a044">
        <updating/>
        <source>closeFile(fileToClose: File) updating;

vars

begin
 	fileToClose.close;
end;</source>
        <Parameter name="fileToClose" type="File"/>
    </JadeMethod>
    <JadeMethod name="openFile" id="f5f6c3c1-7f75-4243-b229-53f3aec0bad4">
        <updating/>
        <source>openFile(f: File io):Boolean updating;

vars
	fileOpenDialog:	CMDFileOpen;
begin
	// Present open file dialog
	create fileOpenDialog;

	// Set the path back to its original position before the CMD was opened
	fileOpenDialog.resetCurrentPath:=true;

	// Set default path and filename
	// fileOpenDialog.initDir:=defaultPath;
	// fileOpenDialog.fileName:=defaultPath &amp; "\" &amp; defaultFileName &amp; ".csv";
	// fileOpenDialog.defaultExt:=".csv";

	// Set default filter types
	fileOpenDialog.filter:="Comma Separated Files (*.csv)|*.csv|All Files (*.*)|*.*";
	fileOpenDialog.filterIndex:=1;


	if fileOpenDialog.open = 0 then
		f.fileName := fileOpenDialog.fileName;	// get selected name (including path)
		f.mode := f.Mode_Input;
		//f.kind := f.Kind_ANSI;
		f.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
		//f.allowCreate := false;	// create if not there
		f.open;		
		return true; // File opened sucessfully
	else
		return false; // File opened failed
	endif;
epilog
	delete fileOpenDialog;
end;</source>
        <Parameter name="f" type="File" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="readTextFile" id="1dbdd150-2e55-4888-a120-c1373d89fa8a">
        <updating/>
        <source>readTextFile(textFileLines: HMS_TextFileLineArray io; delimiterType: Integer) updating;

vars
	f: 			File;
	lineNum:	Integer;
	fieldsRead:	StringArray;
begin
	// This is a generic File IO method that populates a collection of string arrays
	// Each entry in each array represents a field 
	// Each array in the collection represents a line in the input file

	// Create input file
	create f;
	f.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	// Open file for input
	if openFile(f)=true then
		// File opened sucessfully, continue
		// Read data from file
		while not f.endOfFile do
			create fieldsRead transient;
			readTextLine(f, fieldsRead, delimiterType);
			textFileLines.add(fieldsRead);
		endwhile;

		// Close file for output
		closeFile(f);
	endif;
epilog
	delete f;
end;</source>
        <Parameter name="textFileLines" type="HMS_TextFileLineArray" usage="io"/>
        <Parameter name="delimiterType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="readTextLine" id="a1989e7b-16e1-4840-b58d-295cee249d59">
        <updating/>
        <source>readTextLine(file: File; fieldsRead: StringArray io; delimiterType: Integer) updating;

vars
	fieldNum:		Integer;
	lineToRead:		String;
	delimiter:		String;
	field:			String;
	delimiterPosn:	Integer;
begin
	// This is a generic method that takes a string array and populates it 
	// using a single line from an input file that is separated by the delimiter eg comma, tab etc

	// Set delimiter
	if delimiterType=DelimiterType_Comma then
		delimiter:=",";
	elseif delimiterType=DelimiterType_Tab then
		delimiter:=Tab.String;
	else 
		delimiter:=" ";
	endif;

	// Read line from file
	lineToRead:=file.readLine;

	// Build fieldsRead array 
	// Locate posn of first delimiter;
	delimiterPosn:=lineToRead.pos(delimiter,1);
	// Get first field
	if delimiterPosn&gt;0 then
		field:=lineToRead[1:(delimiterPosn-1)];
		fieldsRead.add(field);
		if delimiterPosn+1&lt;lineToRead.length then 
			// More fields to read
			lineToRead:=lineToRead[(delimiterPosn+1):end];
			// Get next delimiter posn
			delimiterPosn:=lineToRead.pos(delimiter,1);
			// Get additional fields
			while delimiterPosn&lt;=lineToRead.length and delimiterPosn&gt;0 do
		    	field:=lineToRead[1:(delimiterPosn-1)];
				fieldsRead.add(field);
				if delimiterPosn+1&lt;lineToRead.length then 
					// More fields to read
					lineToRead:=lineToRead[delimiterPosn+1:end];
					// Get next delimiter posn
					delimiterPosn:=lineToRead.pos(delimiter,1);
				else
					// No more delimiters to find
					delimiterPosn:=-1;
					lineToRead:="";
				endif;
		    endwhile;
		    // Get last field (if there is any)
		    if lineToRead.length&gt;0 then
				field:=lineToRead;	
				fieldsRead.add(field);
			endif;
 		endif;
	else
		// No delimiter on this line - may only be a single field
		if lineToRead.length&gt;0 then
			field:=lineToRead;	
			fieldsRead.add(field);
		endif;
	endif;

end;</source>
        <Parameter name="file" type="File"/>
        <Parameter name="fieldsRead" type="StringArray" usage="io"/>
        <Parameter name="delimiterType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="saveFile" id="3351ace7-e017-403e-bf6b-ed376fffcda7">
        <updating/>
        <source>saveFile(f: File io):Boolean updating;

vars
	fileSaveDialog:	CMDFileSave;
begin
	// Present save file dialog
	create fileSaveDialog;

	// Set the path back to its original position before the CMD was opened
	fileSaveDialog.resetCurrentPath := true;

	// Set default path and filename
	fileSaveDialog.initDir := defaultPath;
	fileSaveDialog.fileName := defaultPath &amp; "\" &amp; defaultFileName &amp; ".csv";
	fileSaveDialog.defaultExt := ".csv";

	if fileSaveDialog.open = 0 then
		f.fileName := fileSaveDialog.fileName;	// get selected name (including path)
		f.mode := f.Mode_Output;
		//f.kind := f.Kind_ANSI;	// 29/2/16 cnwmp6 PAR 36286 unicode version
		f.allowCreate := true;	// create if not there
		f.open;		
		return true; // File opened sucessfully
	else
		return false; // File opened failed
	endif;
epilog
	delete fileSaveDialog;
end;</source>
        <Parameter name="f" type="File" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveHTMLFile" id="2476e285-903b-41cb-a651-18a0f9efded3">
        <updating/>
        <source>saveHTMLFile(f: File io):Boolean updating;

vars
	fileSaveDialog:	CMDFileSave;
begin
	// Present save file dialog
	create fileSaveDialog;

	// Set the path back to its original position before the CMD was opened
	fileSaveDialog.resetCurrentPath := true;

	// Set default path and filename
	fileSaveDialog.initDir := defaultPath;
	fileSaveDialog.fileName := defaultPath &amp; "\" &amp; defaultFileName &amp; ".htm";
	fileSaveDialog.defaultExt := ".htm";

	if fileSaveDialog.open = 0 then
		f.fileName := fileSaveDialog.fileName;	// get selected name (including path)
		f.mode := f.Mode_Output;
		//f.kind := f.Kind_ANSI;	// 29/2/16 cnwmp6 PAR 36286 unicode version
		f.allowCreate := true;	// create if not there
		f.open;		
		return true; // File opened sucessfully
	else
		return false; // File opened failed
	endif;
epilog
	delete fileSaveDialog;
end;</source>
        <Parameter name="f" type="File" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeHTMLFile" id="b08378c5-3c8d-40f5-bb5b-1f72b5ea20f0">
        <updating/>
        <source>writeHTMLFile(htmlText : String) : String updating;

vars
	f: 			File;
begin
	// This is a generic File IO method that takes a collection of string arrays
	// Each entry in each array represents a field 
	// Each array in the collection represents a new line in the output file

	// Create output file
	create f;
	f.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version

	// Open file for output
	if saveHTMLFile(f)=true then
		// File opened sucessfully, continue
		

		
		f.writeLine(htmlText);

		// Close file for output
		closeFile(f);
		return f.fileName;
	endif;
epilog
	delete f;
end;</source>
        <Parameter name="htmlText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="writeTextFile" id="191f46dc-5823-4726-a09c-71e64456d6ad">
        <updating/>
        <source>writeTextFile(textFileLines: HMS_TextFileLineArray; delimiterType: Integer) : String updating;

vars
	f: 			File;
	lineNum:	Integer;
begin
	// This is a generic File IO method that takes a collection of string arrays
	// Each entry in each array represents a field 
	// Each array in the collection represents a new line in the output file

	// Create output file
	create f;
	f.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version

	// Open file for output
	if saveFile(f)=true then
		// File opened sucessfully, continue
		
		lineNum:=1;
		while lineNum &lt;=textFileLines.size do
			writeTextLine(f,textFileLines[lineNum],delimiterType);
			lineNum:=lineNum+1;
		endwhile;

		// Close file for output
		closeFile(f);
		return f.fileName;
	endif;
epilog
	delete f;
end;</source>
        <Parameter name="textFileLines" type="HMS_TextFileLineArray"/>
        <Parameter name="delimiterType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="writeTextLine" id="3b98456a-b668-4677-ab44-a9b8f02d288b">
        <updating/>
        <source>writeTextLine(file: File;fieldsToWrite: StringArray; delimiterType: Integer) updating;

vars
	fieldNum:		Integer;
	lineToWrite:	String;
	delimiter:		String;
begin
	// This is a generic method that takes a string array and constructs a single
	// output string that is separated by the delimiter eg comma, tab etc

	// Set delimiter
	if delimiterType=DelimiterType_Comma then
		delimiter:=",";
	elseif delimiterType=DelimiterType_Tab then
		delimiter:=Tab.String;
	else 
		delimiter:=" ";
	endif;

	// Build Line to write
	fieldNum:=1;
	while fieldNum&lt;=fieldsToWrite.size do
		lineToWrite:=lineToWrite &amp; fieldsToWrite[fieldNum] &amp; delimiter;
		fieldNum:=fieldNum+1;
	endwhile;

	// Write line to file
	file.writeLine(lineToWrite);


end;</source>
        <Parameter name="file" type="File"/>
        <Parameter name="fieldsToWrite" type="StringArray"/>
        <Parameter name="delimiterType" type="Integer"/>
    </JadeMethod>
</Class>
