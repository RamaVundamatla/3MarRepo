        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBatNo_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2013	cnwndl1	Initial creation	Par 32849

*/

vars

begin

	if txtBatNo.text = lblBatNo.caption.toUpper then
		txtBatNo.selStart := 0;
		txtBatNo.selLength := lblBatNo.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
