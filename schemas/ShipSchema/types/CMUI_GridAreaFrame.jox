    <JadeMethod name="initForBayLayout" id="3cda36dc-a309-49e9-89d4-620b289014a4">
        <updating/>
        <source>initForBayLayout() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2009	cnwer1	Initial creation

*/

