    <JadeMethod name="doResizeControls" id="9b87786c-fa79-4bef-8cf9-5fc25f5cdddd">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	inheritMethod(_initialSetup);

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtRequestId.setAndIncrementTabIndex( tabIndex );
		self.txtRequestId.visible := true;
	endif;
	self.txtRequestId.move( 	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtRequestId.height + ( self.resizedMargin );
	if _initialSetup then
		self.lblRequest.setAndIncrementTabIndex( tabIndex );
		self.lblRequest.visible := true;
	endif;
	self.lblRequest.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
								
	cTop := cTop + self.lblRequest.height;
	cHeight := self.btnOne.top - cTop - ( self.resizedMargin * 3 );
	if _initialSetup then
		self.lstRelItems.setAndIncrementTabIndex( tabIndex );
		self.lstRelItems.visible := true;
		self.lstRelItems.enabled := false;
	endif;
	self.lstRelItems.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
	
								
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findRequest" id="54e3cd22-fe1a-4da0-8688-756b3528fda3">
        <updating/>
        <source>findRequest( _returning : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlgndl1	Initial creation	TFS 38083
*/

vars

	requestString : String;
	request : CM_Request;
	term : CM_Terminal;
	selectedRoadRelease : CM_BulkRelease;
	selectedPackRelease : CM_BulkRelease;
	selectedRailRelease : CM_BulkRelease;
	truckArray : CM_VehicleArray;
	truck : CM_Vehicle;
	newIndex : Integer;
	ti : CM_TrackedItem;
	
	allPreStaged : Boolean;
	tiSet : CM_TISet;
	firstStagingLC : CM_LocationsController;
	sourceIndex : Integer;
	outStandingItemCount : Integer;
	stagedItemCount : Integer;
	
	opt1Str :String;
	opt2Str :String;
	opt3Str : String;
	returnValue : Integer;

begin

	requestString := self.txtRequestId.text;
	if not _returning then
		self.setMyBulkRelease(null);
	else
		if self.myBulkRelease &lt;&gt; null and self.myBulkRelease.status &lt;&gt; BR_ACTIVE then
			//returning with a completed release
			self.setMyBulkRelease(null);
		endif;
	endif;
	self.requestedItemCount := 0;
	
	if requestString.trimBlanks = null or requestString = self.lblRequestId.caption.toUpper then
		if requestString = null then
			self.txtRequestId.text := self.lblRequestId.caption.toUpper;
		endif;
			
	else
		//find an active road release.
		term := self.myMobileDataAgent.myTerminal;
		selectedRoadRelease := self.getActiveBulkRelease( term, BR_TYPE_ROAD, true, requestString );	
		selectedPackRelease := self.getActiveBulkRelease( term, BR_TYPE_PACKING, true, requestString );	
		selectedRailRelease := self.getActiveBulkRelease( term, BR_TYPE_RAIL, true, requestString );	
		
		if selectedRailRelease &lt;&gt; null then	
			self.setMyBulkRelease(selectedRailRelease);
			return;
		
		elseif selectedPackRelease &lt;&gt; null and selectedRoadRelease &lt;&gt; null then
			if _returning and self.myBulkRelease &lt;&gt; null then
				//leave it alone.
			else
				self.lblRequest.caption := app.getErrorString(Pack_and_road_found_select);
				//One of each found,make them choose.
				opt1Str := app.getErrorString( Use_pack_request );
				opt2Str := app.getErrorString( Use_road_release_request );
				opt3Str := app.getErrorString(Neither_above_cancel);
				returnValue := self.optBox(opt1Str, opt2Str, opt3Str, null, 3, app.getErrorString(Select_option) );
				if returnValue = 1 then
					self.setMyBulkRelease(selectedPackRelease);
				elseif returnValue = 2 then
					self.setMyBulkRelease(selectedRoadRelease);
				else
					return;
				endif;
			endif;
			
		elseif selectedPackRelease &lt;&gt; null then
			self.setMyBulkRelease(selectedPackRelease);
			
		elseif selectedRoadRelease &lt;&gt; null then
			self.setMyBulkRelease(selectedRoadRelease);
			
		endif;
	
	endif;

	if self.myBulkRelease = null then
		self.lblRequest.caption := app.getErrorString(No_request_found);
	else
		if self.myBulkRelease.isPackingType then
			self.requestedItemCount := self.myBulkRelease.getTotalOutstanding;
			self.lblRequest.caption := app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " ["
			&amp; self.myBulkRelease.allReservePackingChildren.size.String &amp; " " &amp; app.getErrorString(INV_Items) &amp; "]";
		else
			self.requestedItemCount := self.myBulkRelease.allTrackedItemsAssigned.size;
			self.lblRequest.caption := app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " ["
			&amp; self.myBulkRelease.allReserveDetails.size.String &amp; " " &amp; app.getErrorString(INV_Items) &amp; "]";
		endif;
	endif;
	
	self.doResizeControls(false);
	
epilog

	delete tiSet;

end;</source>
        <Parameter name="_returning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="7660c093-1f3c-445e-a3e5-e1f87a8006bf">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	msg : String;

begin
		
	
	if self.myBulkRelease = null then
		return;
	endif;
	
	self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
	
	self.gotoForm( MOB_HHPackRequestSTW, false );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
