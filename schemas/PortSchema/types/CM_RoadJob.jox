    <JadeMethod name="addKioskAAAIDelRequest" id="1578a2f1-cb4b-4906-936d-22bf0c3ff490">
        <updating/>
        <source>addKioskAAAIDelRequest( _cmifReleaseById : CMIF_ReleaseById input; _passport : CM_Passport input) : CM_Request updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2020	jlgndl1	Initial creation	TFS 49167  AAAI = Any Amount Any Id

*/

vars

	release : CM_BulkRelease;
	gteRelease : CMGTE_Entity;
	pxyGteRelease : CMGTE_Release;
	request	: CM_DeliveryRequest;
	pxyTIs : CM_ObjectByStringDict;
begin

	release := _cmifReleaseById.myBulkRelease;
	
	create pxyGteRelease transient;
	pxyGteRelease.setForKioskAAAI( release, self.myVehicleVisit );
	
	//19/6/2025   jlier1MTN-34221 refactoring validation so is before trx 
	create pxyTIs transient;
	app.myValCA.valGateEntity(self.myVehicleVisit,pxyGteRelease,pxyTIs,_passport);
	
	if app.myPassport.hasErrorsIgnored then
		return null;
	endif;
	
	app.myUtilityCA.utlCreateInOutFlexiGateEntity( self.myVehicleVisit, pxyGteRelease, gteRelease, app.myPassport);	
	
	if gteRelease &lt;&gt; null then
		gteRelease.actionForCreate( self.myVehicleVisit, app.myPassport, null );
		request := gteRelease.myYardRequest.CM_DeliveryRequest;
	endif;
	
	return request;

epilog

	delete pxyGteRelease;
	if pxyTIs &lt;&gt; null then
		pxyTIs.purge;
		delete pxyTIs;
	endif;
end;</source>
        <Parameter name="_cmifReleaseById" type="CMIF_ReleaseById" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Request"/>
    </JadeMethod>
