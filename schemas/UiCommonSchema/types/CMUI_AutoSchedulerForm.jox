        <controlMethod name="CMUI_Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldSchedules_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;
// -------------------------------------------
// Created 29 August 2003 by cnwdvb1
// -------------------------------------------
// Date			Who		Reason
// 24/07/2025	jlizm1	MTN 35372 Add table filter to auto schedule form
vars

begin

/*	if folder.topSheet = self.shtSchedule then
	//	self.tblTaskDisplay.setFocus();
		// Back to front.
		self.typeOfSheet := self.Sheet_Task;
	else
	//	self.tblSchedules.setFocus();
		// Back to front.
		self.typeOfSheet := self.Sheet_Schedule;
	endif;*/
	
	if newSheet = self.shtTasks then
	//	self.tblTaskDisplay.setFocus();
		// Back to front.
		self.typeOfSheet := self.Sheet_Task;
		self.frmTableFilter.setupControl(self.tblTaskDisplay, null);
	else
	//	self.tblSchedules.setFocus();
		// Back to front.
		self.typeOfSheet := self.Sheet_Schedule;
		self.frmTableFilter.setupControl(self.tblSchedules, null);
	endif;
	
	self.frmTableFilter.doTableFilter();
	self.changeButtonStates();
	return true;
end;</source>
