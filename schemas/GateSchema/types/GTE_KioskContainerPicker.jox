    <JadeMethod name="doCancel" id="5b3f911d-44ad-4291-ac59-83e6fa3ff55d">
        <updating/>
        <source>doCancel() updating;
// --------------------------------------------------------------------------------
// Created:		23 February 2009 by cnwjo3
//
// Purpose:		Deal with using clicking Cancel
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	self.modalResult	:=	self.CNEC_MODAL_CANCEL;
	self.myReserveDetail := null;  //always good to clear this out
	self.unloadForm();
end;
</source>
    </JadeMethod>
    <JadeMethod name="doClick" id="f7f716b1-7aa8-4993-aef3-aa9cda87a496">
        <updating/>
        <source>doClick(table : Table input) updating;

// --------------------------------------------------------------------------------
// Created:		23 February 2009 by cnwjo3
//
// Purpose:		When ever table is clicked set itemObject for developer inspection
//				and set myReserveDetail so that it can be returned when form closes
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------

vars

begin

	self.tblContainerType.cnEcSetItemObject(table.row,table.column,self.tblContainerType.cnEcGetRowObject());
	self.setMyReserveDetail(self.tblContainerType.itemObject.CM_ReserveDetail);
	
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="6f8e1703-88cd-4925-8d7f-4e51d9502ef7">
        <updating/>
        <source>doOK() updating;

// --------------------------------------------------------------------------------
// Created:		23 February 2009 by cnwjo3
//
// Purpose:		User clicks OK
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------

vars

begin
	if self.getMyReserveDetail &lt;&gt; null then
		self.modalResult	:=	self.CNEC_MODAL_UPDATE;
		self.unloadForm();
	else
		return;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doUnload" id="d6a68157-e984-4534-89d3-c2449b97cd46">
