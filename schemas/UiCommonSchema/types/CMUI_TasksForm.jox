    <JadeMethod name="btnInstruction_click" id="6c70360a-07bd-444e-8a32-5162b5f13aa5">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnInstruction_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	row : Integer;
begin
	row := self.tblTasksAdd.accessedRow.row - 1;
	self.myAssistant.showInstructionEntryForm(self.myTrackedItem.allToDoTasksToDo[row],self);
	self.loadTasks(self.myTrackedItem);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSaveAndClose_click" id="96b9f62c-8538-4507-825a-7e2486adc294">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSaveAndClose_click(btn: Button input) updating;

vars

begin
	if self.doSave then
		// so we can unload without getting a confirmation dialog
		self.resetFirstChangeFlag;
		self.unloadForm;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSave_click" id="8ff78e89-fb74-474a-80c1-b728a09195bd">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSave_click(btn: Button input) updating;
/*
12/12/2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
*/
vars

begin
	if self.doSave then
		// so we can unload without getting a confirmation dialog
		if self.mode = self.TODO_TASK then 			// 12/12/2022	navcs2	ChangeRequest #56691:[56120]
			self.setToDoTasks(self.allToDoTasks);	// 12/12/2022	navcs2	ChangeRequest #56691:[56120]
			return;						   			// 12/12/2022	navcs2	ChangeRequest #56691:[56120]
		endif;							  			// 12/12/2022	navcs2	ChangeRequest #56691:[56120]
		
		self.resetFirstChangeFlag;
		self.loadTasks (self.getCurrentObject);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
