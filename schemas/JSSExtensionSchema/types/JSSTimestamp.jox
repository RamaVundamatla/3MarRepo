// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	gmtBias			: Integer;

begin
	self.timestampServer.cnGetGMTBias(gmtBias);
epilog
