    <JadeMethod name="getAuditText" id="82a6856b-d902-4f7a-bad6-2d64e4e52e6d">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     15 March 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt		: String;
	tmpStr	: String;
	commod  : CM_Commodity;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	return txt;
end;</source>
        <ReturnType type="String"/>
