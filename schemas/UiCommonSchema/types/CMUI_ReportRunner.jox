    <JadeMethod name="switchDateBoxComboBox" id="60a25e54-7bbc-4336-b32b-377ad8277900">
        <source>switchDateBoxComboBox(_isTemplate : Boolean; _name : String constant; _comboBox : ComboBox input) protected;
// ---------------------------------------------------------------------------
// Created:     07 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRow		: Integer;
	entRow		: EntTableRowTransient;
	filter		: CMQF_FilterReports;
	yesterday	: Date;
	bgpRequest  : BGP_ReportRequest;
begin
	
	tmpRow := self.tblParameter.getRowByName(_name);
//	entRow := self.tblParameter.getEntTableRowByConstName(_name);
	
	if tmpRow = 0 then
		return;
	endif;

	if _isTemplate then
		if tmpRow &lt;&gt; 0 then
			self.tblParameter.setControl(tmpRow, _comboBox);
			self.tblParameter.setValue(tmpRow, _comboBox.text);
			if self.myMenuEntity &lt;&gt; null and self.myMenuEntity.isKindOf(CM_MenuUserReport) then
				//PAR22361 - cnwsh3 - 18/02/2010 - Remove references to CM_MenuUserReport.myReportRequest 
				//mapped method.  Now using getBGPReportRequest method
				bgpRequest := self.myMenuEntity.CM_MenuUserReport.getBGPReportRequest();
				//if self.myMenuEntity.CM_MenuUserReport.myReportRequest &lt;&gt; null then
				if bgpRequest &lt;&gt; null then
					filter := bgpRequest.myFilter;
					self.tblParameter.setValueByNameTemplate(_name, filter.getDisplayStringForAttribute(_name, null));
				endif;
			endif;
		endif;
		
		tmpRow := self.tblParameter.getRowByControlName(_name); // check if any other controls by same name in table
		if tmpRow &lt;&gt; 0 then  // must be another cotrol with same name in table with still to change 
			self.switchDateBoxComboBox(_isTemplate, _name, _comboBox); // call this method again. 
		endif;
	else
		if tmpRow &lt;&gt; 0 then
			self.tblParameter.accessCell(tmpRow, CM_EntryTable.ColumnValue).cellControl := null;
			yesterday := self.systemToLocalTime(app.actualTimeServer()).date - 1;		// 27/4/16 cnwmp6 TFS 488 - Multi timezone support
			self.tblParameter.setValueByName(_name, yesterday);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_isTemplate" type="Boolean"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_comboBox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="switchQryParamsDateBoxToCmb" id="29d1b6f2-acb3-4e0c-ab8c-661c93a494d1">
        <updating/>
        <source>switchQryParamsDateBoxToCmb(_isTemplate : Boolean) protected, updating;
/*

Purpose:			switch all report params to Date box / combo box

Parameters:			_isTemplate: is to create report template

Return Value:		

Date			Who		Reason
27 October 2025	navec1	MTN-36160: NSWP | Implement Date String Parsing and Conversion Logic

*/

vars
    tbl                 : CM_EntryTable;
    qryReport           : CM_QryReport;
    row                 : Integer;
    obj                 : Object;
    entRowTrans         : EntTableRowTransient;
    qryParam            : CM_QueryReportParam;
    menuEntity          : CM_MenuEntity;
    menuUserReport      : CM_MenuUserReport;
    menuUserDtl         : CM_MenuUserDtl;
	newCmb  			: CMUI_ComboBox;
	currentCell			: JadeTableCell;			// ### JIRA: MTN-36160 04Nov2025 NAVPW1
	
begin
    tbl := self.tblParameter;
    if tbl = null then
        return;
    endif;
    
    menuEntity := self.myMenuEntity;
    if menuEntity = null then
        return;
    endif;
    
    // Extract CM_QryReport from menu entity
    if CM_MenuUserReport.hasInstance(menuEntity) then
        menuUserReport := menuEntity.CM_MenuUserReport;
        qryReport := menuUserReport.myQryReport;
    elseif CM_MenuUserDtl.hasInstance(menuEntity) then
        menuUserDtl := menuEntity.CM_MenuUserDtl;
        qryReport := menuUserDtl.myMenuItem.CM_QryReport;
    else
        return;
    endif;
    
    if qryReport = null or qryReport.allQueryReportParams.isEmpty() then
        return;
    endif;
    
    if _isTemplate then
        // Template mode: Set combo as cell control for date report params
        foreach row in tbl.fixedRows + 1 to tbl.rows do
            obj := tbl.accessRow(row).itemObject;
            if not EntTableRowTransient.hasInstance(obj) then
                continue;
            endif;
            
            entRowTrans := obj.EntTableRowTransient;			
            qryParam := qryReport.allQueryReportParams[entRowTrans.name];
            
            if qryParam &lt;&gt; null and qryParam.type = Date.number then	// is date type
				currentCell := tbl.accessCell(row, CM_EntryTable.ColumnValue);
				if not currentCell.cellControl.isKindOf(CMUI_ComboBox) then //cell control is not null and set to another control. We want to replace with a combo box
					newCmb := self.cmbQueryParamDate.loadControl(self.comboBoxIdx).CMUI_ComboBox;	//Used loadControl instead of transient as jade handles cleaning these up
					CMUI_ReportAgentStd@populateTemplateDateTypes(newCmb);
					newCmb.name := "cmb" &amp; qryParam.paramName;
					tbl.setControl(row, newCmb);
					newCmb.text := currentCell.text;		// ### JIRA: MTN-36160 03Nov2025 NAVPW1
					newCmb.automaticCellControl := true;	//Need this as the same in setupForm is somewhow overwritten for self.cmbQueryParamDate which should be copied when doing a loadControl
					self.comboBoxIdx += 1;
				endif;
            endif;
        endforeach;
    else
        // Non-template mode: Remove combo control
        foreach row in tbl.fixedRows + 1 to tbl.rows do
            obj := tbl.accessRow(row).itemObject;
            if not EntTableRowTransient.hasInstance(obj) then
                continue;
            endif;
            
            entRowTrans := obj.EntTableRowTransient;
            qryParam := qryReport.allQueryReportParams[entRowTrans.name];
            
            if qryParam &lt;&gt; null and qryParam.type = Date.number then
                tbl.accessCell(row, CM_EntryTable.ColumnValue).cellControl := null;
				tbl.setValue(row, null);
            endif;
        endforeach;
    endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_isTemplate" type="Boolean"/>
    </JadeMethod>
