    <DbClassMap file="edi"/>
    <JadeMethod name="setCurrentTag" id="ba99da12-d0c4-4811-bb2e-2d4f6d04f3c1">
        <updating/>
        <source>setCurrentTag() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 18 October 2007
//
//----------------------------------------------------------------------
//27 Jul 2015	cnwrs1	Par 32883 - EDI File Type sequence number

vars
	int	: Integer;
	msg	: String;
begin
	
	msg := self.currentMessage;
	int := msg.pos("*",1);
	if int &lt; 1 then
		int := 1;
	endif;
	if int &gt; 31 then
		int := 31;
	endif;
	self.currentTag := msg[1:int-1];

end;</source>
    </JadeMethod>
    <JadeMethod name="setFirstField" id="a9a5f537-9932-49d2-9a9f-7c8baa375897">
        <updating/>
        <source>setFirstField() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 19 October 2007
//
//----------------------------------------------------------------------
/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes

*/

vars
	msg,
	str				: String;
	pos				: Integer;
	
begin
	self.currentFieldNumber := 1;
	msg := self.currentMessage;
	
	if msg &lt;&gt; null then
		pos := 1;
		str := msg.scanUntil("*", pos);
	endif;
	
	self.currentField := str;
	
	self.setFirstSubItem;
	
end;

/* 	old code replaced

vars
	str: String;
	pos1,start,stop: Integer;
begin
	self.currentFieldNumber := 1;
	start := 1;
	pos1 := self.getCurrentMessage.pos("*",start);
	stop := pos1-start;
	if pos1 &lt; 1 then
		stop := self.getCurrentMessage.length - start;
	endif;
	if stop &lt; 1 then
		self.currentField := "";
	else
		self.currentField := self.getCurrentMessage[start:stop];
	endif;
	self.setFirstSubItem;

end;
*/</source>
    </JadeMethod>
    <JadeMethod name="setFirstSubItem" id="dce9cbc8-6d68-4334-8b07-8644ae02474b">
        <updating/>
        <source>setFirstSubItem() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 19 October 2007
//
//----------------------------------------------------------------------
/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes

*/

vars
	field		: String;
	pos			: Integer;
	
begin
	self.currentSubItemNumber := 1;
	
	field := self.currentField;
	
	if field = null then
		self.currentSubItem := null;
	else
		pos := 1;
		self.currentSubItem := field.scanUntil("*", pos);
	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="setNextField" id="bfc081d5-8810-4648-8d3f-5b67aeefb8c8">
        <updating/>
        <source>setNextField() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 18 October 2007
//
//----------------------------------------------------------------------
/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes
// 29 May 2018	jlgrs1	TFS 38918 only output the found data when matching index position
*/

vars
	str,
	msg				: String;
	msgLen,
	pos,
	index,
	currentIndex	: Integer;
	
begin
	currentIndex := self.currentFieldNumber + 1;
	self.currentFieldNumber := currentIndex;
	
	msg := self.currentMessage;
	msgLen := msg.length;
	
	pos := 1;
	index := 0;
	
	while index &lt; currentIndex do
		index := index + 1;
		
		if pos &gt; msgLen then
			str := null;
			break;
		endif;
		
		// Find field number "index"
		str := msg.scanUntil("*", pos);
		
		if pos = null then			// No more "*" delimiters, must be the end of the line
			break;
		endif;
		
		pos := pos + 1;				// Step over delimiter
	endwhile;
	
	if currentIndex = index then
		self.currentField := str;
	else
		self.currentField := null;
	endif;
	self.setFirstSubItem;
	
end;

/*	old code replaced

vars
	pos1,pos2,index,start,stop: Integer;
begin
	self.currentFieldNumber := self.currentFieldNumber + 1;
	index := 1;
	start := 1;
	while index &lt; self.currentFieldNumber do
		pos1 := self.getCurrentMessage.pos("*",start);
		if pos1 = 0 then // got all the fields
			start	:= 1;
			pos2	:= 1; // this ensures stop := 0 and currentField is set to blank
			break;
		endif;
		start :=  pos1 + 1; //skip the delimiter
		pos2 := self.getCurrentMessage.pos("*",start);
		index := index + 1;
	endwhile;
	stop := pos2-start;
	if pos2 &lt; 1 then
		stop := self.getCurrentMessage.length - start + 1; //cnwrs1 May 2008 + 1;
	endif;
	if stop &lt; 1 then
		self.currentField := "";
	else
		self.currentField := self.getCurrentMessage[start:stop];
	endif;
	self.setFirstSubItem;

end;
*/</source>
    </JadeMethod>
    <JadeMethod name="setNextSubItem" id="2cb5b6f5-7261-4c69-81cd-fe161e32a2a6">
        <updating/>
        <source>setNextSubItem() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 19 October 2007
//
//----------------------------------------------------------------------

/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes

*/

vars
	field,
	str				: String;
	fieldLen,
	pos,
	index,
	currentIndex	: Integer;
	
begin
	currentIndex := self.currentSubItemNumber + 1;
	self.currentSubItemNumber := currentIndex;
	
	field := self.currentField;
	fieldLen := field.length;
	
	pos := 1;
	index := 0;
	
	while index &lt; currentIndex do
		index := index + 1;
		
		if pos &gt; fieldLen then
			str := null;
			break;
		endif;
		
		// Find subfield number "index"
		str := field.scanUntil("*", pos);
		
		if pos = null then			// No more ":" delimiters, must be the end of the field
			if index &lt; currentIndex then
				str := null;
			endif;
			break;
		endif;
		
		pos := pos + 1;				// Step over delimiter
	endwhile;
	
	self.currentSubItem := str;
	
end;

/*	old code replaced 

vars
	str: String;
	pos1,pos2,pos3,i,start,stop: Integer;
begin
	self.currentSubItemNumber := self.currentSubItemNumber + 1;
	i := 1;
	start := 1;
	while i &lt; self.currentSubItemNumber do
		pos1 := self.currentField.pos("*",start);
		if pos1 = 0 then // got all the subItems
			start := 1;
			pos2 := 1; // this ensures stop := 0 and currentSubItem is set to blank
			break;
		endif;
		start :=  pos1+1; //skip the delimiter
		pos2 := self.currentField.pos("*",start);
		i := i + 1;
	endwhile;
	stop := pos2-start;
	if pos2 &lt; 1 then
		stop := self.currentField.length - start + 1;
	endif;
	if stop &lt; 1 then
		self.currentSubItem := "";
	else
		self.currentSubItem := self.currentField[start:stop];
	endif;
end;
*/</source>
    </JadeMethod>
    <JadeMethod name="setPreviousField" id="7a755194-eea5-41f7-94ca-6f5e77e02a7a">
        <updating/>
        <source>setPreviousField() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 18 October 2007
//
//----------------------------------------------------------------------

/*

Date		Who		Reason
03 Jun 2010	cnwkpd1	PAR #21998 - EDI File load performance changes

*/

vars

begin
	if self.currentFieldNumber &lt; 2 then
		return;
	endif;
	
	self.currentFieldNumber := self.currentFieldNumber - 2;
	self.setNextField();
	
end;

/*	old code replaced

vars
	str: String;
	pos1,pos2,pos3,i,start,stop: Integer;
begin
	if self.currentFieldNumber &lt; 1 then
		return;
	endif;
	self.currentFieldNumber := self.currentFieldNumber - 1;
	i := 1;
	start := 1;
	while i &lt; self.currentFieldNumber do
		pos1 := self.getCurrentMessage.pos("*",start);
		if pos1 = 0 then // got all the fields
			start := 1;
			pos2 := 1; // this ensures stop := 0 and currentField is set to blank
			break;
		endif;
		start :=  pos1+1; //skip the delimiter
		pos2 := self.getCurrentMessage.pos("*",start);
		i := i + 1;

	endwhile;
	stop := pos2-start;
	if pos2 &lt; 1 then
		stop := self.getCurrentMessage.length - start + 1;
	endif;
	if stop &lt; 1 then
		self.currentField := "";
	else
		self.currentField := self.getCurrentMessage[start:stop];
	endif;
	self.setFirstSubItem;


end;
*/</source>
    </JadeMethod>
</Class>
