    <JadeMethod name="isSubTerminal_Match" id="d0762ba2-fb4e-4fe5-812c-cf44a95b44d1">
        <source>isSubTerminal_Match(_yaData: CM_YADataObjects): Boolean;
// --------------------------------------------------------------------------------
// Created:		17 April 2009 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Return true because cargo type is not being used.
	if self.mySubTerminal = null then
		return true;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	// Do we have a match?
	return _yaData.matches(self.mySubTerminal);
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTAStorageGroup_Match" id="c9840019-e59a-4d1c-8496-20dc9d53fc18">
        <source>isTAStorageGroup_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 11/05/2023	navkc1	Bug 57912: EUP - YA Density Error

*/

vars
	yaData 		: CM_YAData;
	yaDataObjs 	: CM_YADataObjects;
	obj 		: Object;
	del 		: CM_DeliveryRequest;
	
begin

	yaData := self.getExtraCriteriaMatchData( YACriteriaType_TAStorageGroup );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataObjects) then
		yaDataObjs := yaData.CM_YADataObjects;
		if not yaDataObjs.isEmpty then
			obj := yaDataObjs.getFirstObject;
		endif;
		if obj &lt;&gt; null then
			return _yaData.includes(obj);
		endif;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isThirty_Match" id="0763c649-fb3b-4b3a-8d34-9217b7e91392">
        <source>isThirty_Match(_yaData: CM_YADataBoolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2015	cnwndl1	Initial creation	NDL	Par 35886

*/

vars

	isoType	: CM_ISOType;
	is30	: Boolean;
	yaData : CM_YAData;
	yaDataBoolean : CM_YADataBoolean;
	booleanValue : Boolean;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_IsThirty );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataBoolean) then
		yaDataBoolean := yaData.CM_YADataBoolean;
		if yaDataBoolean &lt;&gt; null then
			if yaDataBoolean.value =  CM_YADataBoolean.VALUE_EITHER then
				return true;
			endif;
			booleanValue := yaDataBoolean.getValueAsBoolean();
			return _yaData.doesValueMatch( booleanValue );
		endif;
	endif;
		
	isoType := self.getISOTypeFromRequest();
	
	if isoType = null then
		is30 := false;
	else
		is30 := (isoType.is30ftLong());
	endif;
	
	return _yaData.doesValueMatch(is30);


end;</source>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
