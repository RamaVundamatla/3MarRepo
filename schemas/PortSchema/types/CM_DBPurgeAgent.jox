    <JadeMethod name="doPurgeEventRequests" id="e57f0e96-7a5a-48a9-ac0f-e92b1d584784">
        <updating/>
        <source>doPurgeEventRequests() : Boolean protected, updating;
//
//23/05/2012	cnwrs1	Par 29613
//TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT
//
vars
//	allEventRequestsToPurge	: DynaDictionary;
//	deleteObj : Object;
	eventRequest : CM_EventRequest;
	errCode : Integer;
	errTxt : String;
	rtnCode : Boolean;
	count : Integer;
	theSize : Integer;
	iter : Iterator;
	idx : Integer;
	msg : String;
begin
	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	while idx &lt; 2 do
		idx := idx + 1;
		count := 0;
		if idx = 1 then
			msg := "Event Stop Request";
			self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;msg, false, false);
			iter := self.myTerminal.allEventRequestStopsByCargoID.createIterator();
			theSize := self.myTerminal.allEventRequestStopsByCargoID.size;
		else
			msg := "Event Notify Request";
			delete iter;
			self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;msg, false, false);
			iter := self.myTerminal.allEventRequestNotifyByCargoID.createIterator();
			theSize := self.myTerminal.allEventRequestNotifyByCargoID.size;
		endif;
		while iter.next(eventRequest) do
			app.myPassport.clearErrorsWarnings();	//Par 18316 Mar 2009
		
			if eventRequest.status = EventRequestPending then
				continue;
			endif;
			if eventRequest.createdTime.date &gt;= self.date then
				continue;
			endif;
			count := count + 1;
			errTxt := null;
			self.doInitiateProcess();
			
			if count mod Commit_Block_Size_Large = 0 then
				if self.abort() then
					return false;
				endif;
				
				if count mod Activity_Progress_Count_Large = 0 then
					self.createActivityHistory("Processed "&amp;count.String&amp;" of "&amp;theSize.String, false, true);
				endif;
			endif;
			
	//		app.myTrxDA.trxDeleteEventRequest(eventRequest, app.myPassport);
			// Will get here if trx has been unsuccessful due to abort.
			rtnCode := self.isToAbort or self.abort();
			
			if rtnCode then
				return false;
			endif;
			
			if errTxt &lt;&gt; null then
				self.allErrors.add(errTxt);
			endif;
			
			if app.myPassport.hasErrors() then	//validationForDelete didn't pass. Par 18316 Mar 2009
				theSize := theSize - 1;
				app.myPassport.clearErrorsWarnings();
			endif;
			
			self.createActivityHistory(null, false, false);
			self.doCheckForError();
		endwhile;
		self.createActivityHistory("Purged "&amp;count.String&amp;' '&amp;msg&amp;" records.", false, false);
	endwhile;
	return true;
epilog
	delete iter;
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeInformationTransactions" id="76886a79-3df7-4765-a5b8-64d52fd739bd">
        <updating/>
        <source>doPurgeInformationTransactions(_description : String) :Boolean updating, protected;
//
// par 16530 cnwrs1 May 2008
// this will remove CM_Information transaction with a description matching the paramater - ie 'Yard allocation logging'
//TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT
vars
	allTransactionToPurge: DynaDictionary;
	obj: Object;
	infoTransaction: CM_Information;
	errCode: Integer;
	errTxt: String;
	rtnCode: Boolean;
	count		: Integer;
	theSize		: Integer;
	purgeCount	: Integer;
	
begin
	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	create allTransactionToPurge transient;
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;"Information Transaction", false, false);
	allTransactionToPurge.setMembership(CM_Information);
	allTransactionToPurge.addMemberKey("createdTime", false, false);
	allTransactionToPurge.endKeys(true);
//	self.getInfoTransactionOldThanDate(allTransactionToPurge);	// cnwrl1 09/06/2009 PAR 19328 - what it was
	self.getInfoTransactionOldThanDate( allTransactionToPurge, _description );
	theSize := allTransactionToPurge.size;
	foreach obj in allTransactionToPurge do
		errTxt := null;
		self.doInitiateProcess();
		infoTransaction := obj.CM_Information;
		count := count + 1; //cnwrs1 par19275 Mar 2009
		if count mod Commit_Block_Size_Large = 0 then
			if self.abort() then
				return false;
			endif;
			if count mod self.Activity_Progress_Count_Large = 0 then
//				self.createActivityHistory("Processed "&amp;count.String&amp;" of "&amp;theSize.String, false, true);	// cnwrl1 08/06/2009 PAR 19328 - what it was
				self.createActivityHistory(	"Processed " &amp; count.display &amp; " of " &amp; theSize.display &amp;
											" purged " &amp; purgeCount.display, false, true );
			endif;
		endif;
//		if infoTransaction.description = _description then	// cnwrl1 09/06/2009 PAR 19328 - now done as part of getInfoTransactionOldThanDate
		app.myTrxDA.trxDeleteTITransaction(infoTransaction, null, app.myPassport);		// 12/10/18 MAP TFS41191
		// Will get here if trx has been unsuccessful due to abort.
		rtnCode := self.isToAbort or self.abort();
		if rtnCode then
			return false;
		endif;
		if errTxt &lt;&gt; null then
			self.allErrors.add(errTxt);
		endif;
		self.createActivityHistory(null, false, false);
		self.doCheckForError();
		// cnwrl1 08/06/2009 PAR 19328
		// Count the number of instances actually purged.
		purgeCount	:= purgeCount + 1;
//		endif;
	endforeach;
//	self.createActivityHistory("Purged "&amp;theSize.String&amp;" Information transactions.", false, false);	// cnwrl1 08/06/2009 PAR 19328 - what it was
	self.createActivityHistory(	"Purged " &amp; purgeCount.display &amp; " Information transactions.", false, false );
	
	return true;
	
epilog
	delete allTransactionToPurge;
end;
</source>
        <access>protected</access>
        <Parameter name="_description" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeInterTerminalRailBOLs" id="7e17dae2-0d11-46e4-8f47-d12bbbf3511f">
