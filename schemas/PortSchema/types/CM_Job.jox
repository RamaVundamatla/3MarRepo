    <JadeMethod name="updateStatus" id="4d04941c-4a66-4c0f-a68f-b226975574e6">
        <updating/>
        <source>updateStatus() updating;
//NEW Method, called from QEntry updateStatus method, makes the
//job update its status
// changed 2/5/3 by cnwgd1 now used by voyage and road jobs
// 31890 refactor out the getNewStatus for use in job print
vars
	newStatus	:	Integer;
begin

	exclusiveLock(self);
	newStatus := self.getNewStatus();

	if newStatus &lt;&gt; self.status then
		self.status := newStatus;
		self.causeTerminalEvent(self.Event_Mode_Update);
	endif;

epilog
	unlock(self);
end;</source>
    </JadeMethod>
