vars

begin
	inheritMethod(_colorControl);
	self.frmRateEntry.backColor := self.backColor;
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="da48cd53-4a42-4ac2-8c18-ba270495b65c">
        <source>setEnableObjects();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 28/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
	rateEntry : CM_RateEntry;
	rateTable : Table;
	bank : CM_Bank;
	rdg	: CM_RootDebtorGroup;

begin
	bank := self.myCurrentBank;
	rdg := bank.getRootDebtorGroup();
	rateTable := self.tblData;

	if self.myCurrentRate &lt;&gt; null then
		self.mnuInvUpdate.enabled := true;
		self.btnEditItem.enabled := true;
		if self.modeDisplay = self.Mode_Debtor then
			self.tblData.column := 1;
			rateEntry := self.tblData.accessRow(self.tblData.row).itemObject.CM_RateEntry;
			if rateEntry = null then
				self.mnuInvUpdate.enabled := false;
				self.btnEditItem.enabled := false;
				self.btnDelete.enabled := false;
				return;
			endif;

			if rateEntry.rate.CM_DebtorRate.debtorNode &lt;&gt; self.myCurrentDebtor then
				self.mnuInvUpdate.enabled := false;
				self.btnEditItem.enabled := false;
				self.btnDelete.enabled := false;
			else
				if self.myCurrentRate.CM_DebtorRate.debtorNode = rdg then
					if self.tblData.rows &gt; 2 then
						self.btnDelete.enabled := true;
					else
						self.btnDelete.enabled := false;
					endif;
				else
					self.mnuInvUpdate.enabled := true;
					self.btnEditItem.enabled := true;
					self.btnDelete.enabled := true;
				endif;
			endif;
		else
			self.btnDelete.enabled := true;
		endif;
	else
		self.mnuInvUpdate.enabled := false;
		self.btnEditItem.enabled := false;
		self.btnDelete.enabled := false;
	endif;

	if self.modeDisplay = self.Mode_Debtor then
		if self.myCurrentDebtor &lt;&gt; null and  self.myCurrentService &lt;&gt; null then
			self.btnNewItem.enabled := true;
			self.btnAudits.enabled := true;			
		else
			self.btnNewItem.enabled := false;
			self.btnAudits.enabled := false;			
		endif;
	elseif self.modeDisplay = self.Mode_Vessel then									// TFS 37794
		if self.myCurrentVessel &lt;&gt; null and self.myCurrentService &lt;&gt; null then		// TFS 37794
			self.btnNewItem.enabled := true;										// TFS 37794
			self.btnAudits.enabled := true;											// TFS 37794
		else																		// TFS 37794
			self.btnNewItem.enabled := false;										// TFS 37794
			self.btnAudits.enabled := false;										// TFS 37794
		endif;																		// TFS 37794
	elseif self.modeDisplay = self.Mode_VesselType then								//07.06.2018 cnwma1 ChangeRequest #38953
		if self.myCurrentVesselType &lt;&gt; null and self.myCurrentService &lt;&gt; null then	
			self.btnNewItem.enabled := true;										
			self.btnAudits.enabled := true;											
		else																		
			self.btnNewItem.enabled := false;										
			self.btnAudits.enabled := false;										
		endif;
	elseif self.modeDisplay = self.Mode_VisitType then								//07.06.2018 cnwma1 ChangeRequest #38953
		if self.myCurrentVisitType &lt;&gt; null and self.myCurrentService &lt;&gt; null then	
			self.btnNewItem.enabled := true;										
			self.btnAudits.enabled := true;											
		else																		
			self.btnNewItem.enabled := false;										
			self.btnAudits.enabled := false;										
		endif;
	elseif self.modeDisplay = self.Mode_Berth then									//07.06.2018 cnwma1 ChangeRequest #38953
		if self.myCurrentBerth &lt;&gt; null and self.myCurrentService &lt;&gt; null then	
			self.btnNewItem.enabled := true;										
			self.btnAudits.enabled := true;											
		else																		
			self.btnNewItem.enabled := false;										
			self.btnAudits.enabled := false;										
		endif;
	else
		if self.myCurrentLineGroupDebtor &lt;&gt; null and  self.myCurrentService &lt;&gt; null then
			self.btnNewItem.enabled := true;
			self.btnAudits.enabled := true;			
		else
			self.btnNewItem.enabled := false;
			self.btnAudits.enabled := false;			
		endif;
	endif;
// ###
	self.btnPrint.enabled := (self.cmbDebtor.listObject &lt;&gt; null or self.cmbTrade.listObject &lt;&gt; null
								or self.cmbVessel.listObject &lt;&gt; null);									// TFS 37794
	self.btnDelete.enabled := app.myPassport.myUser.canDo(self.myTerminal,PmAdmRatehistoryMaint);
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled := false;
		self.btnEditItem.enabled := false;
		self.btnNewItem.enabled := false;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setEntryFromService" id="0c80f7b6-22ab-491a-9e69-1445caece26b">
        <source>setEntryFromService(_service : CM_Service);
// ---------------------------------------------------------------------------
// Created:		18 January 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 28/03/2019	jlgdap1		TFS 43694 PEL1 Charging for Vessels that use a Ramp
vars
	aCT : CM_CalculationType;
	calcType : Integer;

begin
	self.tblCost.visible := false;
	self.txtCostPerUnit.visible := true;
	self.txtCostPerUnit.decimals := self.myTerminal.getConfig(FinancialRateDPlaces).Integer;
	self.txtCostPercent.decimals := self.myTerminal.getConfig(FinancialRateDPlaces).Integer;	//17 Sep 2012	NDL	Par 30375
	self.txtCostAdjust.decimals := self.myTerminal.getConfig(FinancialRateDPlaces).Integer;	//17 Sep 2012	NDL	Par 30375

	if _service &lt;&gt; null  then
		aCT := _service.myCalculationType;
		if aCT &lt;&gt; null then
			calcType := aCT.calculationType;
			if calcType = INV_CALC_TYPE_BUSINESS_HRS_QTY 
			or calcType = INV_CALC_TYPE_BUSHRSVESELVALUE // PAR 30681
			or calcType = INV_CALC_TYPE_BUSHRSCARGOVALUE  // PAR 30681
		//	or calcType = INV_CALC_TYPE_VESSEL_TON 	//25 Sep 2018	NDL	TFS 41015
			or calcType = INV_CALC_TYPE_VESSEL_TON_RANGE 
			or calcType = INV_CALC_TYPE_VESSEL_TON_QTY1
			or calcType = INV_CALC_TYPE_WO_PERMIT // TFS 39198
			or calcType = INV_CALC_TYPE_WO_EXTRA //27 Jun 2018	NDL	TFS 39246
			or calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM //28 Jun 2018	NDL	TFS 39338
			or calcType = INV_CALC_TYPE_TIDAL_CLASS then 	// 34489 CCMS 1327 Tidal CLass calc type
				self.tblCost.visible := true;
				self.txtCostPerUnit.visible := false;
			endif;
			//	CCMS SFW 1279 May 2012 Storage Escalating Charges
			if aCT.allQuantityRanges.size &gt; 0 then
				self.tblCost.visible := true;
				self.txtCostPerUnit.visible := false;
			endif;
			
			//22 Mar 2019	NDL	TFS 43687
			if aCT.rateType = CM_CalculationType.RateTypeHMSMovementType 
			or aCT.rateType = CM_CalculationType.RateTypeRamp then				// TFS 43694
				self.tblCost.visible := true;
				self.txtCostPerUnit.visible := false;
			endif;	
			
		endif;
	endif;
	
	self.clickRateOption();	//14 Sep 2012	NDL	Par 30375

end;</source>
        <Parameter name="_service" type="CM_Service"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentRateEntry" id="33b54cd8-812d-492c-ae4b-a00990397f00">
        <updating/>
        <source>setMyCurrentRateEntry( _rateEntry : CM_RateEntry ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

begin

	self.myCurrentRateEntry := _rateEntry;
	self.setBaseRateEntry();

epilog

end;</source>
        <Parameter name="_rateEntry" type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="setTableAlignment" id="5b9a0522-dacc-4ecd-8a9e-57c70026b808">
        <source>setTableAlignment();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	saveRow:    Integer;
	saveColumn: Integer;
	row:        Integer;
	rateTable : Table;
begin
	rateTable := self.tblData;

	saveRow := rateTable.row;
	saveColumn := rateTable.column;

	rateTable.accessMode := Table.AccessMode_Sheet;
	rateTable.alignment := Table.Alignment_Right;

	rateTable.accessMode := Table.AccessMode_Column;
	rateTable.column := 1;
	rateTable.alignment := Table.Alignment_Left;

	rateTable.accessMode := Table.AccessMode_Row;
	row := 1;
	while row &lt;= rateTable.fixedRows do
		rateTable.row := row;
		rateTable.alignment := Table.Alignment_Left;
		row := row + 1;
	endwhile;

	rateTable.accessMode := Table.AccessMode_Cell;
	rateTable.alignment := Table.Alignment_Right;

	rateTable.row := saveRow;
	rateTable.column := saveColumn;


end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f351b25f-bc9a-4947-b372-1d5b58e81cce">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 28/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
// 03 May 2020  cnwma1      Bug 49220: LNX - Error 1090 at Rate History Screen
vars
	
begin
	self.setNavigatorHeading(self.caption);
	self.initTableData(ETDef_InvMaintRateHistory);
	self.useTableSorting := true;
	self.useCtrlScroll   := false;
	self.modeDisplay 	 := self.Mode_Debtor;
	self.mode 			 := self.Mode_Add;		// 31732 so base rate is found for first entry
	self.toolbarStyle    := self.ToolbarStyle_ShowNoHide;
	self.showToolbar     := true;
	self.usesQueryFrame  := true;
	self.useTableInfo    := false;
	self.mnuContextColourLegend.visible := false;
	self.mnuColumnOrganiser.visible 	:= true;
	self.btnEditItem.enabled            := false; //03.05.2020 cnwma1 #38953
	self.initCostsTable(); 
	
	self.useTableInfo := true;	//19 Sep 2012	NDL	Par 30375
	self.doCmbBankBuild();
	// 35872 get business unit from user if more than one
	// may be called from INV_RateTable which sets the bank, so set it conditionally now
	if self.myCurrentBank = null then
		self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
	else
		self.cmbBank.listObject := self.myCurrentBank;
	endif;
		
	inheritMethod();
	self.fldQuery.topSheet := self.shtQuery1;
	self.doComboTradeBuild();
	self.doComboDebtorBuild();
	self.initDataTable();
	self.doComboServicesBuild();
	self.doComboVesselBuild();										// TFS 37794
	self.doComboVesselTypeBuild();									//07.06.2018 cnwma1 ChangeRequest #38953
	self.doComboVisitTypeBuild();									//07.06.2018 cnwma1 ChangeRequest #38953
	self.doComboBerthBuild();										//07.06.2018 cnwma1 ChangeRequest #38953
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_RATEENTRY_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_RATEENTRY_DELETE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_RATEENTRY_UPDATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_SERVICE_DELETE), Response_Continuous, null); // PAR 31657
	
	if self.myCurrentDebtor &lt;&gt; null then
		self.fldQuery.topSheet := self.shtQuery1;
		self.modeDisplay := self.Mode_Debtor;
		self.cmbDebtor.listObject := self.myCurrentDebtor;
		self.cmbDebtor.click(self.cmbDebtor);
		
		self.cmbDebtorService.listObject := self.myCurrentService;
		self.cmbDebtorService.click(self.cmbDebtorService);
		// July 2010 cnwjre1 24052 single-click 'New' from Rate Table
		if self.showNew then
			self.doQuery();
			self.frmQuery.visible := false;
			doNewItem();
			self.showNew := false;
		else
			self.doQuery();
		endif;
	elseif self.myCurrentLineGroupDebtor &lt;&gt; null then
		self.fldQuery.topSheet := self.shtQuery2;
		self.modeDisplay := self.Mode_Trade;
		self.cmbTrade.listObject := self.myCurrentLineGroupDebtor.shipPortGroup.shippingLine;
		self.cmbTrade.click(self.cmbTrade);
		
		self.cmbTradeGroup.listObject := self.myCurrentLineGroupDebtor.shipPortGroup;
		self.cmbTradeGroup.click(self.cmbTradeGroup);
		
		self.cmbTradeDebtor.listObject := self.myCurrentLineGroupDebtor;
		self.cmbTradeDebtor.click(self.cmbTradeDebtor);
		
		self.cmbTradeService.listObject := self.myCurrentService;
		self.cmbTradeService.click(self.cmbTradeService);
		// July 2010 cnwjre1 24052 single-click 'New' from Rate Table
		if self.showNew then
			self.frmQuery.visible := false;
			doNewItem();
			self.showNew := false;
		else
			self.doQuery();
		endif;
		
	// TFS 37794 Vessel Rate query
	elseif self.myCurrentVessel &lt;&gt; null then
		self.fldQuery.topSheet := self.shtQuery3;
		self.modeDisplay := self.Mode_Vessel;
		self.cmbVessel.listObject := self.myCurrentVessel;
		self.cmbVessel.click(self.cmbVessel);
		
		self.cmbVesselService.listObject := self.myCurrentService;
		self.cmbVesselService.click(self.cmbVesselService);
		
		if self.showNew then
			self.doQuery();
			self.frmQuery.visible := false;
			doNewItem();
			self.showNew := false;
		else
			self.doQuery();
		endif;
	// TFS 37794 end
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.myCurrentVesselType &lt;&gt; null then
		self.fldQuery.topSheet := self.shtQuery4;
		self.modeDisplay := self.Mode_VesselType;
		self.cmbVesselType.listObject := self.myCurrentVesselType;
		self.cmbVesselType.click(self.cmbVesselType);
		
		self.cmbVesselTypeService.listObject := self.myCurrentService;
		self.cmbVesselTypeService.click(self.cmbVesselTypeService);
		
		if self.showNew then
			self.doQuery();
			self.frmQuery.visible := false;
			doNewItem();
			self.showNew := false;
		else
			self.doQuery();
		endif;
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.myCurrentVisitType &lt;&gt; null then
		self.fldQuery.topSheet := self.shtQuery5;
		self.modeDisplay := self.Mode_VisitType;
		self.cmbVisitType.listObject := self.myCurrentVisitType;
		self.cmbVisitType.click(self.cmbVisitType);
		
		self.cmbVisitTypeService.listObject := self.myCurrentService;
		self.cmbVisitTypeService.click(self.cmbVisitTypeService);
		
		if self.showNew then
			self.doQuery();
			self.frmQuery.visible := false;
			doNewItem();
			self.showNew := false;
		else
			self.doQuery();
		endif;
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.myCurrentBerth &lt;&gt; null then
		self.fldQuery.topSheet := self.shtQuery6;
		self.modeDisplay := self.Mode_Berth;
		self.cmbBerth.listObject := self.myCurrentBerth;
		self.cmbBerth.click(self.cmbBerth);
		
		self.cmbBerthService.listObject := self.myCurrentService;
		self.cmbBerthService.click(self.cmbBerthService);
		
		if self.showNew then
			self.doQuery();
			self.frmQuery.visible := false;
			doNewItem();
			self.showNew := false;
		else
			self.doQuery();
		endif;
	endif;
	// Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
	if self.modeDisplay = self.Mode_Debtor then
		self.mnuSendReportMain.visible := true;
		self.mnuSendReportAll.visible := true;
		self.mnuSendReportSelected.visible := true;
		self.mnuSendReportSeparator.visible := true;
		self.mnuSendReportSelected.visible := true;
	else		
		self.mnuSendReportMain.visible := false;
	endif;
	
	self.setEntryFromService(self.myCurrentService); // PAR 13250
	//07.06.2018 cnwma1 ChangeRequest #38953
	self.frmQuery.height := 440;
	self.frmQuery.height := 300;
	self.lblBank.parent := frmQuery;
	self.cmbBank.parent := frmQuery;
	
	self.lblBank.top := 42; // ### TFS 50421 17SEP2021 NAVAB1
	self.lblBank.left := 20;
	self.lblBank.width := 80;
	
	self.cmbBank.top := 40; // ### TFS 50421 17SEP2021 NAVAB1
	self.cmbBank.left :=120;
	self.cmbBank.width := 160;
end;</source>
    </JadeMethod>
    <JadeMethod name="showAuditForm" id="8862374f-5ad6-48bf-b884-962e06dab7f1">
        <updating/>
        <source>showAuditForm() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	cma : INV_AuditsInvoices;

begin
	if self.myCurrentRate = null then
		if self.myCurrentDebtor &lt;&gt; null then // PAR 16503
			self.myCurrentRate := self.myCurrentDebtor.serviceRates.first;
			if self.myCurrentRate &lt;&gt; null then
				//self.myCurrentRateEntry := self.myCurrentRate.rateEntries.first.CM_RateEntry;
				self.setMyCurrentRateEntry( self.myCurrentRate.rateEntries.first.CM_RateEntry );	//17 Sep 2012	NDL	Par 30375
				if self.myCurrentRateEntry &lt;&gt; null then
					self.myCurrentRate := self.myCurrentRateEntry.rate;
				endif;
			endif;
		endif;
		if self.myCurrentRate = null then
			if self.tblData.rows &gt; 1 then
				//self.myCurrentRateEntry := self.tblData.accessRow(2).itemObject.CM_RateEntry;
				self.setMyCurrentRateEntry( self.tblData.accessRow(2).itemObject.CM_RateEntry );	//17 Sep 2012	NDL	Par 30375
				self.myCurrentRate := self.myCurrentRateEntry.rate;
			endif;
		endif;
	endif;
	if self.myCurrentRate = null then
		app.msgBox(app.getErrorString(INV_Please_Select_A_Rate),app.getErrorString(INV_Audit_Error), MsgBox_OK_Only);
		return;
	endif;
	app.mousePointer := MP_HOURGLASS;

	create cma;
	cma.myCurrentRate := self.myCurrentRate;
	cma.myTerminal := self.myTerminal;
	cma.createMyAssistant(INV_Assistant);
	cma.mode := cma.Mode_Qualified;	
	cma.openWithSavedSettings(); //cnwas3 PAR 21153
	cma.show;
epilog
	app.mousePointer := MP_DEFAULT;


end;</source>
    </JadeMethod>
    <JadeMethod name="showPrintFrame" id="70321b8b-602f-4811-8112-655deef6daba">
        <source>showPrintFrame();
// ---------------------------------------------------------------------------
// Created:		19 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	tmpDate : Date;
	tmpTime : Time;
	day,
	month,
	year	: Integer;
begin
	self.frmRatePrint.centreHorizontallyInParent();
	self.frmRatePrint.visible := true;
	self.frmRatePrint.zOrder(1);
	
	
	self.cmbDebtorPrt.listIndex := 1;
	self.cmbServicePrt.listIndex := 1;
	
	// 18/9/2006 (12290)
	
	tmpDate := self.systemToLocalTime(app.actualTimeServer).date();// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	day := 1; // start of the month
	month := tmpDate.month-1; // previous month
	
	// if the month is Jan we have to go back to Dec. last year.	
	if tmpDate.month() = 1 then
		year :=	tmpDate.year-1; // last year
	 else
		year :=	tmpDate.year; // this year
	endif;
	
	tmpDate.setDate(day,month,year);
	self.txtDateFrom.setDate(tmpDate);
	
	day :=tmpDate.daysInMonthJMT; // end of the month
	tmpDate.setDate(day,month,year);
	self.txtDateTo.setDate(tmpDate);
	
	tmpTime.setTime(0,0,0,0);
	self.txtTimeFrom.setTime(tmpTime);

	tmpTime.setTime(23,59,0,0);
	self.txtTimeTo.setTime(tmpTime);
	
	self.cmbDebtorPrt.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="showRateDetailsFrame" id="e1480776-3836-49be-b811-d4f7fd7563bc">
        <source>showRateDetailsFrame();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// Oct 2012	cnwjre1	30456 change the formatting to not have separators to avoid 14074 excp
// ---------------------------------------------------------------------------
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 11 Apr 2017	cnwma1	TFS 3852 ADP - Negative Invoice Rate Lines
// 20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table (Swap $CM_RateEntry.decimalPlaces for terminal config)
// 28 Mar 2018	jlgdap1	TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
	tsServer,
	tsLocal : TimeStamp;
	tseServer,
	tseLocal : TimeStamp;
	
	isVisible	: Boolean;
	now : Date;
	t : Time;
	idx, numDec, maxLen : Integer;
	row		: Integer;
	r : Real;
	cpu : Real;
	re : CM_RateEntry;
	theFrame : Frame;
	text	 : String;
	msg : String;
	zero : Real;
	bank : CM_Bank;
	rdgRe : CM_RateEntry;
	dpl : Integer;
	calcType : CM_CalculationType;
	subTerm : CM_SubTerminal;
	rowIndex : Integer;
	tidalClass : HMS_TidalClass;
begin
	theFrame := self.frmRateEntry;
	
	self.handleCalcTypeView();
	
	calcType := self.myCurrentService.myCalculationType;	//28 Jul 2018	NDL	TFS 39338

	self.frmToolbar.enabled := false;
	
	dpl := self.getRateEntryDecimalPlaces;	// TFS 36954 MPD 20 Feb 2018
	
	// PAR 14604 - default the format every time.
	// 35590 handle range calc type without the range entered - will show the screen but won't be anywhere to enter the rate
	if self.tblCost.rows &gt; 1 then
		self.tblCost.accessCell(2,2).text := null;// PAR 14604
		//self.tblCost.accessCell(2,2).decimals := $CM_RateEntry.decimalPlaces;// PAR 14604
		self.tblCost.accessCell(2,2).decimals := dpl; // TFS 36954 MPD 20 Feb 2018
		//th2 07/08/2007 for PAR 14632
		//self.tblCost.accessCell(2,2).text := r.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false); // default zero // PAR 14604
		self.tblCost.accessCell(2,2).text := r.asStringJMTWithPrecision(dpl, false);
	endif;
	
	self.txtCostPerUnit.text := null;// PAR 14604
	//self.txtCostPerUnit.decimals := $CM_RateEntry.decimalPlaces;// PAR 14604
	self.txtCostPerUnit.decimals := dpl; // TFS 36954 MPD 20 Feb 2018
	self.txtCostPerUnit.dataType := TextBox.DataType_SignedNumeric; //11/04/2017 cnwma1 TFS #3852	
	//17 Sep 2012	NDL	Par 30375
	self.txtCostPercent.text := null;
	//self.txtCostPercent.decimals := $CM_RateEntry.decimalPlaces;
	self.txtCostPercent.decimals := dpl; // TFS 36954 MPD 20 Feb 2018
	self.txtCostAdjust.text := null;
	//self.txtCostAdjust.decimals := $CM_RateEntry.decimalPlaces;
	self.txtCostAdjust.decimals := dpl; // TFS 36954 MPD 20 Feb 2018
	
	 // PAR 17537 should always allow upto 6 digits for the main number followed by the configured number of decimals.
	//numDec := $CM_RateEntry.decimalPlaces; // PAR 17537
	//maxLen := 7 + numDec; // PAR 17537
//	maxLen := 8 + dpl; // TFS 36954 MPD 20 Feb 2018
	maxLen := 12 + dpl;//10 May 2018	NDL	TFS 38528
	self.txtCostPerUnit.maxLength := maxLen; // PAR 17537
	
	//17 Sep 2012	NDL	Par 30375
	self.txtCostPercent.maxLength := maxLen;
	self.txtCostAdjust.maxLength := maxLen;
	
	//th2 07/08/2007 for PAR 14632
	//self.txtCostPerUnit.text := r.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false); // default zero // PAR 14604
	self.txtCostPerUnit.text := r.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
	//17 Sep 2012	NDL	Par 30375
	//self.txtCostPercent.text := r.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
	//self.txtCostAdjust.text := r.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
	// TFS 36954 MPD 20 Feb 2018
	self.txtCostPercent.text := r.asStringJMTWithPrecision(dpl, false);
	self.txtCostAdjust.text := r.asStringJMTWithPrecision(dpl, false);
	self.optRateCPU.value := true;
	self.optRateAdjust.value := false;
	self.optRatePercent.value := false;
	self.optRate.value := true;	// default
	
	if self.myCurrentRateEntry &lt;&gt; null then
		tsServer := self.myCurrentRateEntry.startTimestamp;
		tsLocal := self.systemToLocalTime(tsServer);
		self.txtRateDate.setDate(tsLocal.date);
		self.txtRateTime.setTime(tsLocal.time);
		
		tseServer := self.myCurrentRateEntry.expiryTimestamp;
		tseLocal := self.systemToLocalTime(tseServer);
		self.txtExpiryDate.setDate(tseLocal.date);
		self.txtExpiryTime.setTime(tseLocal.time);
		self.chkIgnoreEntry.value := self.myCurrentRateEntry.ignoreThisEntry;
		
		//17 Sep 2012	NDL	Par 30375
		if self.myCurrentRateEntry.isPercentBased then
			//self.txtCostPercent.text := (self.myCurrentRateEntry.percentageOfBase - 100).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
			self.txtCostPercent.text := (self.myCurrentRateEntry.percentageOfBase - 100).asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
			self.optRateCPU.value := false;
			self.optRatePercent.value := true;
		elseif self.myCurrentRateEntry.isAdjustmentBased then
			//self.txtCostAdjust.text := self.myCurrentRateEntry.adjustmentToBase.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
			self.txtCostAdjust.text := self.myCurrentRateEntry.adjustmentToBase.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
			self.optRateCPU.value := false;
			self.optRateAdjust.value := true;
		endif;
		
		//lblCurrRate.caption := "This rates' cost per unit is: " &amp; self.myCurrentRateEntry.getDerivedCostPerUnit(tsLocal).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true);
		lblCurrRate.caption := "This rates' cost per unit is: " &amp; self.myCurrentRateEntry.getDerivedCostPerUnit(tsLocal).asStringJMTWithPrecision(dpl, true); // TFS 36954 MPD 20 Feb 2018
		//17 Sep 2012	NDL	Par 30375
		if self.myBaseRateEntry &lt;&gt; null and self.myCurrentRateEntry &lt;&gt; self.myBaseRateEntry and
		   not self.tblCost.visible then
			//lblCurrRate.caption := lblCurrRate.caption &amp; " (" &amp; app.getErrorString(Default_rate) &amp; " = " &amp; self.myBaseRateEntry.getDerivedCostPerUnit(tsLocal).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true) &amp; ")";
			lblCurrRate.caption := lblCurrRate.caption &amp; " (" &amp; app.getErrorString(Default_rate) &amp; " = " &amp; self.myBaseRateEntry.getDerivedCostPerUnit(tsLocal).asStringJMTWithPrecision(dpl, true) &amp; ")"; // TFS 36954 MPD 20 Feb 2018
		endif;

		if calcType.calculationType = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//28 Jul 2018	NDL	TFS 39338
			self.optAmount.value := false;
			self.optRate.value := true;
			if self.tblCost.rows &gt;= 2 then
				foreach rowIndex in 2 to self.tblCost.rows do
					subTerm := self.tblCost.accessCell(rowIndex,1).itemObject.CM_SubTerminal;
					cpu := self.myCurrentRateEntry.getCPUforObject(subTerm);
					text := cpu.asStringJMTWithPrecision(dpl, false); 
					self.tblCost.accessCell(rowIndex, 2).text := text;
				endforeach;
			endif;
			
		elseif calcType.calculationType = INV_CALC_TYPE_TIDAL_CLASS then	//29 Jul 2018	NDL	TFS 39338
			self.optAmount.value := false;
			self.optRate.value := true;
			if self.tblCost.rows &gt;= 2 then
				foreach rowIndex in 2 to self.tblCost.rows do
					tidalClass := self.tblCost.accessCell(rowIndex,1).itemObject.HMS_TidalClass;
					cpu := self.myCurrentRateEntry.getCPUforObject(tidalClass);
					text := cpu.asStringJMTWithPrecision(dpl, false); 
					self.tblCost.accessCell(rowIndex, 2).text := text;
				endforeach;
			endif;
		
		elseif self.myCurrentRateEntry.allCostPerUnits.isEmpty then
			cpu := self.myCurrentRateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp);
			if self.tblCost.visible and // PAR 13250
			   self.tblCost.rows &gt; 1 then		// 35590 range handle calc type without the range
				//self.tblCost.accessCell(2,2).text := cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
				self.tblCost.accessCell(2,2).text := cpu.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
			else
				//self.txtCostPerUnit.text := cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false); // PAR 13250
				self.txtCostPerUnit.text := cpu.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
			endif;
			
		else
			if self.tblCost.visible then
				self.optAmount.value := self.myCurrentRateEntry.costIsAmount;
				self.optRate.value := not self.optAmount.value;
				if self.myCurrentRateEntry.costIsAmount then
					self.tblCost.columns:= 3;
					self.tblCost.setCellText(1,1, "Amount per range");
				endif;
				maxLen := self.myCurrentRateEntry.allCostPerUnits.size;
				row := 2;
				idx := 1;
				while true do
					cpu := self.myCurrentRateEntry.allCostPerUnits[idx];
					//self.tblCost.accessCell(row, 2).text := cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
					self.tblCost.accessCell(row, 2).text := cpu.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
					idx := idx + 1;
					if idx &gt; maxLen then
						break;
					endif;
					if self.tblCost.columns = 3 then
						if self.tblCost.accessCell(row, 3).enabled then
							cpu := self.myCurrentRateEntry.allCostPerUnits[idx];
							//text := cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
							text := cpu.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
							if self.myCurrentRateEntry.rateIsPercentage then
								text := text &amp; "%";
							endif;
							self.tblCost.accessCell(row, 3).text := text;
							idx := idx + 1;
						endif;
					endif;
					if idx &gt; maxLen then
						break;
					endif;
					
					row := row + 1;
					// number of rows has already been set.
					// Stop showing entries if max rows is met. The total costs per units can be larger if the user has changed the calc type on the service.
					if row &gt; self.tblCost.rows then
						break;
					endif;
				endwhile;
			else
				cpu := self.myCurrentRateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp);
				//self.txtCostPerUnit.text := cpu.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
				self.txtCostPerUnit.text := cpu.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
			endif;
		endif;
		
		if self.myCurrentRateEntry.rate.isKindOf(CM_DebtorRate) then
			self.lblRate.caption := 'To edit the rate for Debtor "' &amp; self.myCurrentRateEntry.rate.CM_DebtorRate.debtorNode.getListName() &amp; '" and Service "'   // so default debtor is not 'RDG'
						&amp; self.myCurrentRateEntry.rate.service.name &amp; ' " enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);
		elseif self.myCurrentRateEntry.rate.isKindOf(CM_VesselRate) then
			self.lblRate.caption := 'To edit the rate for Vessel "' &amp; self.myCurrentRateEntry.rate.CM_VesselRate.myVessel.code &amp; '" and Service "'		// TFS 37794
						&amp; self.myCurrentRateEntry.rate.service.name &amp; '" enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);		// TFS 37794
		elseif self.myCurrentRateEntry.rate.isKindOf(CM_BerthRate) then   //07.06.2018 cnwma1 ChangeRequest #38953
			self.lblRate.caption := 'To edit the rate for Berth "' &amp; self.myCurrentRateEntry.rate.CM_BerthRate.myBerth.code &amp; '" and Service "'		
						&amp; self.myCurrentRateEntry.rate.service.name &amp; '" enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);		
		elseif self.myCurrentRateEntry.rate.isKindOf(CM_VisitTypeRate) then //07.06.2018 cnwma1 ChangeRequest #38953
			self.lblRate.caption := 'To edit the rate for Visit Type "' &amp; self.myCurrentRateEntry.rate.CM_VisitTypeRate.myVisitType.code &amp; '" and Service "'		
						&amp; self.myCurrentRateEntry.rate.service.name &amp; '" enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);		
		elseif self.myCurrentRateEntry.rate.isKindOf(CM_VesselTypeRate) then //07.06.2018 cnwma1 ChangeRequest #38953
			self.lblRate.caption := 'To edit the rate for Vessel Type "' &amp; self.myCurrentRateEntry.rate.CM_VesselTypeRate.myVesselType.code &amp; '" and Service "'	
						&amp; self.myCurrentRateEntry.rate.service.name &amp; '" enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);	
		else
			self.lblRate.caption := 'To edit the rate for Line Group Debtor "' &amp; self.myCurrentRateEntry.rate.CM_LineGroupDebtorRate.lineGroupDebtor.code 
						&amp; '" and Service "' &amp; self.myCurrentRateEntry.rate.service.name &amp; '" enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);
		endif;
	else
		//if self.myCurrentLineGroupDebtor = null then			// TFS 37794
		if self.modeDisplay = self.Mode_Debtor then				// TFS 37794
			if  self.myCurrentDebtor = null then
				msg := "Debtor";
			endif;
		elseif self.modeDisplay = self.Mode_Vessel then			// TFS 37794
			if self.myCurrentVessel = null then					// TFS 37794
				msg := app.getErrorString(Vessel);				// TFS 37794
			endif;												// TFS 37794
		elseif self.modeDisplay = self.Mode_VesselType then			//07.06.2018 cnwma1 ChangeRequest #38953
			if self.myCurrentVesselType = null then					//07.06.2018 cnwma1 ChangeRequest #38953
				msg := app.getErrorString(VesselType);				//07.06.2018 cnwma1 ChangeRequest #38953
			endif;
		elseif self.modeDisplay = self.Mode_VisitType then			//07.06.2018 cnwma1 ChangeRequest #38953
			if self.myCurrentVisitType = null then					//07.06.2018 cnwma1 ChangeRequest #38953
				msg := app.getErrorString(VisitType);				//07.06.2018 cnwma1 ChangeRequest #38953
			endif;	
		elseif self.modeDisplay = self.Mode_Berth then				//07.06.2018 cnwma1 ChangeRequest #38953
			if self.myCurrentBerth = null then						//07.06.2018 cnwma1 ChangeRequest #38953
				msg := app.getErrorString(Berth);					//07.06.2018 cnwma1 ChangeRequest #38953
			endif;	
		else
			if  self.myCurrentLineGroupDebtor = null then
				if self.myCurrentService = null then
					msg := "Trade";
				endif;
			endif;
		
		endif;

		if self.myCurrentService = null then
			if msg &lt;&gt; null then
				msg := msg &amp; "/";
			endif;
			msg := msg &amp; "Service";
		endif;
		
		if msg &lt;&gt; null then
			app.msgBox("Please select a " &amp; msg,"Query Error", MsgBox_OK_Only);
			self.frmToolbar.enabled := true;
			return;
		endif;

//		t.setTime(0,0,0,0);
		now := self.systemToLocalTime(app.actualTimeServer).date();
		// 24052 default the date for a new entry to the effective date of the rate query unless this date is today
		//		when the last entered date (if any) is to be used - if neither date is set, use today's date.
		tsLocal.setDate(now);
		if self.effectiveDate &lt;&gt; null then
			if self.effectiveDate = now and
			   self.lastEnteredDate &lt;&gt; null then
				tsLocal.setDate(self.lastEnteredDate);
			else
				tsLocal.setDate(self.effectiveDate);
			endif;
		endif;
		tsLocal.setTime(TimeStartOfDay);
		tseLocal := null;				// no default expiry date, must be entered if required
		self.txtRateDate.setDate(tsLocal.date);
		self.txtRateTime.setTime(tsLocal.time);
		self.txtExpiryDate.setDate(tseLocal.date);
		self.txtExpiryTime.setTime(tseLocal.time);
		self.chkIgnoreEntry.value := false;
		tsServer := self.localToSystemTime(tsLocal);
		
		//if self.myCurrentLineGroupDebtor = null then			// TFS 37794
		if self.modeDisplay = self.Mode_Debtor then				// TFS 37794
			
			self.lblRate.caption := 'To enter a new rate for Debtor "' &amp; self.myCurrentDebtor.getListName() &amp; '" and Service "' 
						&amp; self.myCurrentService.name &amp; '" enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);
			re := self.myCurrentDebtor.getServiceTimeRate(self.myCurrentService, tsServer);
			if re &lt;&gt; null then
				//lblCurrRate.caption := "The current cost per unit is: " &amp; re.getDerivedCostPerUnit(tsServer).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true);
				lblCurrRate.caption := "The current cost per unit is: " &amp; re.getDerivedCostPerUnit(tsServer).asStringJMTWithPrecision(dpl, true); // TFS 36954 MPD 20 Feb 2018
			else
				lblCurrRate.caption := "The current cost per unit is: &lt;undefined&gt;.";
			endif;
			bank := self.myCurrentDebtor.bank;
		// TFS 37794 Vessel Rates
		elseif self.modeDisplay = self.Mode_Vessel then
			self.lblRate.caption := 'To enter a new rate for Vessel "' &amp; self.myCurrentVessel.name &amp; '" and Service "' 
						&amp; self.myCurrentService.name &amp; '" enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);
			re := self.myCurrentVessel.getVesselServiceTimeRate(self.myCurrentService, tsServer);
			if re &lt;&gt; null then
				lblCurrRate.caption := "The current cost per unit is: " &amp; re.getDerivedCostPerUnit(tsServer).asStringJMTWithPrecision(dpl, true);
			else
				lblCurrRate.caption := "The current cost per unit is: &lt;undefined&gt;.";
			endif;
			bank := self.cmbBank.listObject.CM_Bank;   //07.06.2018 cnwma1 ChangeRequest #38953
		// TFS 37794 end of this bit
		//07.06.2018 cnwma1 ChangeRequest #38953
		elseif self.modeDisplay = self.Mode_VesselType then
			self.lblRate.caption := 'To enter a new rate for Vessel Type "' &amp; self.myCurrentVesselType.description &amp; '" and Service "' 
						&amp; self.myCurrentService.name &amp; '" enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);
			re := self.myCurrentVesselType.getVesselTypeServiceTimeRate(self.myCurrentService, tsServer);
			if re &lt;&gt; null then
				lblCurrRate.caption := "The current cost per unit is: " &amp; re.getDerivedCostPerUnit(tsServer).asStringJMTWithPrecision(dpl, true);
			else
				lblCurrRate.caption := "The current cost per unit is: &lt;undefined&gt;.";
			endif;
			bank := self.cmbBank.listObject.CM_Bank;
		//07.06.2018 cnwma1 ChangeRequest #38953
		elseif self.modeDisplay = self.Mode_VisitType then
			self.lblRate.caption := 'To enter a new rate for Visit Type "' &amp; self.myCurrentVisitType.description &amp; '" and Service "' 
						&amp; self.myCurrentService.name &amp; '" enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);
			re := self.myCurrentVisitType.getVisitTypeServiceTimeRate(self.myCurrentService, tsServer);
			if re &lt;&gt; null then
				lblCurrRate.caption := "The current cost per unit is: " &amp; re.getDerivedCostPerUnit(tsServer).asStringJMTWithPrecision(dpl, true);
			else
				lblCurrRate.caption := "The current cost per unit is: &lt;undefined&gt;.";
			endif;
			bank := self.cmbBank.listObject.CM_Bank; //07.06.2018 cnwma1 ChangeRequest #38953
		//07.06.2018 cnwma1 ChangeRequest #38953
		elseif self.modeDisplay = self.Mode_Berth then
			self.lblRate.caption := 'To enter a new rate for Berth "' &amp; self.myCurrentBerth.description &amp; '" and Service "' 
						&amp; self.myCurrentService.name &amp; '" enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);
			re := self.myCurrentBerth.getBerthServiceTimeRate(self.myCurrentService, tsServer);
			if re &lt;&gt; null then
				lblCurrRate.caption := "The current cost per unit is: " &amp; re.getDerivedCostPerUnit(tsServer).asStringJMTWithPrecision(dpl, true);
			else
				lblCurrRate.caption := "The current cost per unit is: &lt;undefined&gt;.";
			endif;
			bank := self.cmbBank.listObject.CM_Bank;
		else
			self.lblRate.caption := 'To enter a new rate for Line Group Debtor "' &amp; self.myCurrentLineGroupDebtor.code 
						&amp; '" and Service "' &amp; self.myCurrentService.name &amp; '" enter a new rate, ' &amp; app.getErrorString(INV_Set_The_Time_And_Click_The);
			re := self.myCurrentLineGroupDebtor.getServiceTimeRate(self.myCurrentBank, self.myCurrentService, tsServer);
			if re &lt;&gt; null then
				//lblCurrRate.caption := "The current cost per unit is: " &amp; re.getDerivedCostPerUnit(tsServer).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true);
				lblCurrRate.caption := "The current cost per unit is: " &amp; re.getDerivedCostPerUnit(tsServer).asStringJMTWithPrecision(dpl, true); // TFS 36954 MPD 20 Feb 2018
			else
				lblCurrRate.caption := "The current cost per unit is: &lt;undefined&gt;.";
			endif;
			if self.myCurrentLineGroupDebtor.debtor &lt;&gt; null then
				bank := self.myCurrentLineGroupDebtor.debtor.bank;
			endif;
		endif;
		
		//18 Sep 2012	NDL	Par 30375
		if re &lt;&gt; null and not re.isRootDebtorGroupRateEntry then
			if re.isPercentBased then
				//self.txtCostPercent.text := (re.percentageOfBase - 100).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
				self.txtCostPercent.text := (re.percentageOfBase - 100).asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
				self.optRateCPU.value := false;
				self.optRatePercent.value := true;
			elseif re.isAdjustmentBased then
				//self.txtCostAdjust.text := re.adjustmentToBase.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
				self.txtCostAdjust.text := re.adjustmentToBase.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
				self.optRateCPU.value := false;
				self.optRateAdjust.value := true;
			endif;
			if bank &lt;&gt; null then
				rdgRe := bank.getRootDebtorGroup.getServiceTimeRate(self.myCurrentService, tsServer);
				if rdgRe &lt;&gt; null then
					//lblCurrRate.caption := lblCurrRate.caption &amp; " (" &amp; app.getErrorString(Default_rate) &amp; " = " &amp; rdgRe.getDerivedCostPerUnit(tsServer).asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true) &amp; ")";
					lblCurrRate.caption := lblCurrRate.caption &amp; " (" &amp; app.getErrorString(Default_rate) &amp; " = " &amp; rdgRe.getDerivedCostPerUnit(tsServer).asStringJMTWithPrecision(dpl, true) &amp; ")"; // TFS 36954 MPD 20 Feb 2018
				endif;
			endif;
		else
			if self.optRateCPU.visible then
				self.optRateCPU.value := true;		// default
			endif;
		endif;
	endif;

	theFrame.zOrder(1);
	theFrame.centreWindow();
	self.frmRateToolbar.positionToolbarControls();
		
	theFrame.visible := true;
	if self.mode = self.Mode_Update then
		if self.tblCost.visible then // PAR 13250
			self.tblCost.moveFirst();
			self.tblCost.setFocus();
		else
			self.txtCostPerUnit.setFocus(); // PAR 13250
		endif;
	else	
		self.txtRateDate.setFocus();	
	endif;
	
	//18 Sep 2012	NDL	Par 30375
	if ( re = null and self.myCurrentDebtor = null )
	or ( re &lt;&gt; null and re.isRootDebtorGroupRateEntry and self.mode = self.Mode_Update )	// 30456 added the mode test
	or ( self.myCurrentDebtor &lt;&gt; null and self.myCurrentDebtor = self.myCurrentDebtor.bank.getRootDebtorGroup )
	then
		self.txtCostPercent.enabled := false;
		self.txtCostAdjust.enabled := false;
		//self.txtCostPercent.text := zero.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
		//self.txtCostAdjust.text := zero.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false);
		// TFS 36954 MPD 20 Feb 2018
		self.txtCostPercent.text := zero.asStringJMTWithPrecision(dpl, false);
		self.txtCostAdjust.text := zero.asStringJMTWithPrecision(dpl, false);
		self.optRateCPU.value := true;
		self.optRatePercent.value := false;
		self.optRateAdjust.value := false;
		self.optRatePercent.enabled := false;
		self.lblOptRatePercnt.enabled := false;
		self.optRateAdjust.enabled := false;
		self.lblOptRateAdjust.enabled := false;
	else
		// enabling from 31732 testing
		self.optRatePercent.enabled := true;
		self.lblOptRatePercnt.enabled := true;
		self.optRateAdjust.enabled := true;
		self.lblOptRateAdjust.enabled := true;
		self.clickRateOption();
	endif;
	
	if self.tblCost.visible and
	   not self.txtCostPerUnit.visible then
		isVisible := false;
		self.tblCost.top := self.frmOptions.top + 30;
	else
		isVisible := true;
		self.tblCost.top := self.optRateAdjust.top + 46;
	endif;
	self.txtCostPercent.visible := isVisible;
	self.txtCostAdjust.visible := isVisible;
	self.optRateCPU.visible := isVisible;
	self.optRatePercent.visible := isVisible;
	self.optRateAdjust.visible := isVisible;
	self.lblOptRateCPU.visible := isVisible;
	self.lblOptRatePercnt.visible := isVisible;
	self.lblOptRateAdjust.visible := isVisible;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5236ac03-8fd5-4ba6-9caf-cd129589b0e1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:47:52.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006213, locale);
	btnAudits.translateBubbleHelp(Xlat_0002202, locale);
	btnAudits.translateCaption(Xlat_0002208, locale);
	btnCancelRate.translateBubbleHelp(Xlat_0002203, locale);
	btnCancelRate.translateCaption(Xlat_0002209, locale);
	btnDoCancel.translateCaption(Xlat_0002210, locale);
	btnDoPrint.translateBubbleHelp(Xlat_0023401, locale);
	btnDoPrint.translateCaption(Xlat_0002211, locale);
	btnFilePicker.translateCaption(Xlat_0015142, locale);
	btnNewItem.translateCaption(Xlat_0002212, locale);
	btnQueryDebtor.translateBubbleHelp(Xlat_0002204, locale);
	btnQueryDebtor.translateCaption(Xlat_0002213, locale);
	btnQueryShip.translateBubbleHelp(Xlat_0002205, locale);
	btnQueryShip.translateCaption(Xlat_0002214, locale);
	btnRefresh.translateBubbleHelp(Xlat_0002206, locale);
	btnRefresh.translateCaption(Xlat_0002215, locale);
	btnSaveRate.translateBubbleHelp(Xlat_0002207, locale);
	btnSaveRate.translateCaption(Xlat_0002216, locale);
