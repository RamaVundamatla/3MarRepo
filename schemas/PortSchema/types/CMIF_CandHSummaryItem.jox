<Class name="CMIF_CandHSummaryItem" id="32d6f3e1-c6d6-41f9-b61f-673b7a3a9663">
    <superclass name="CMIF_CandHSummary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This represents a cell in the C &amp; H Summary Report</text>
    <DbClassMap file="misc"/>
    <ImplicitInverseRef name="allSnapShots" id="8ce41503-a6ba-4a91-a8fd-551363ff1765">
        <memberTypeInverse/>
        <type name="CM_SnapShotSet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allTrackedItems" id="34ed449a-c0c8-4f6a-ae6d-6bc044fcbd2e">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="category" id="de7197f9-1c2d-4e32-98ae-b252520d6630">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>
Order printed on report
IMPORTANT - This is also the number exported to SQL so do not change</text>
    </PrimAttribute>
    <PrimAttribute name="itemCode" id="3f97ec34-4ea8-4af5-9338-4d12b6951255">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>
E.g.  	Import Dry
		Import Reefer
		Import MT
		...</text>
    </PrimAttribute>
    <ExplicitInverseRef name="myCMIFTradeLineGeo" id="1e6007c3-9795-4cc6-aa4f-fd8cd6a79e98">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMIF_CandHTradeLineGeo"/>
        <access>readonly</access>
        <Inverse name="CMIF_CandHTradeLineGeo::allSummaryItemsByCode"/>
        <Inverse name="CMIF_CandHTradeLineGeo::allSummaryItemsByPrintOrder"/>
    </ExplicitInverseRef>
    <PrimAttribute name="numTIs" id="37f04fbb-2cbf-4636-9317-79a06b411511">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="size" id="41eba063-ef35-44c6-af06-fffbfbc28fd6">
        <length>4</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>
20' or 40'</text>
    </PrimAttribute>
    <JadeMethod name="addSnapShot" id="c2517f52-3963-450e-a14e-95efb34ea5c4">
        <updating/>
        <source>addSnapShot(_snapShot: CM_TISnapShot) updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.allSnapShots.add(_snapShot);
	
	self.redoNumTIs();	

end;</source>
        <Parameter name="_snapShot" type="CM_TISnapShot"/>
    </JadeMethod>
    <JadeMethod name="getCount" id="4d64104a-d2ec-4b45-9c3c-6888f454558a">
        <source>getCount(_originalValue: Boolean): Integer;
//----------------------------------------------------------------
//	Created:	08 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	cnt		: Integer;
	snpSht	: CM_SnapShot;
begin

	if _originalValue then
		foreach snpSht in self.allSnapShots do
			if snpSht.isUserGenerated then
				continue;	//don't count it
			endif;
			cnt := cnt + 1;
		endforeach;
		return cnt;
	else
		return self.numTIs;
	endif;

end;</source>
        <Parameter name="_originalValue" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyLGD" id="db133034-c2a5-4603-a42a-db197f4d6301">
        <source>getMyLGD(): CM_LineGroupDebtor;
//----------------------------------------------------------------
//	Created:	12 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.myCMIFTradeLineGeo &lt;&gt; null then
		return self.myCMIFTradeLineGeo.myLineGroupDebtor;
	endif;

	return null;

end;</source>
        <ReturnType type="CM_LineGroupDebtor"/>
    </JadeMethod>
    <JadeMethod name="hasEdits" id="78015917-8ddf-4950-9895-c1199a1cc5ae">
        <source>hasEdits(): Boolean;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ss	: CM_SnapShot;
begin
	
	foreach ss in self.allSnapShots do
		if ss.CM_TISnapShot.myUserTISnapShot &lt;&gt; null then
			return true;	
		endif;
	endforeach;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="redoNumTIs" id="f34fcc34-9587-4c1a-a8b9-2e6237e0d5ec">
        <updating/>
        <source>redoNumTIs() updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	snapShot	: CM_SnapShot;
begin

	self.numTIs := 0;
	foreach snapShot in self.allSnapShots do
		if not snapShot.CM_TISnapShot.ignoreMe then
			self.numTIs := self.numTIs + 1; 
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="removeSnapShot" id="ec89411a-bfe3-434d-860f-f792b95d068e">
        <updating/>
        <source>removeSnapShot(_snapShot: CM_TISnapShot) updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.allSnapShots.remove(_snapShot);
	self.redoNumTIs();	
end;</source>
        <Parameter name="_snapShot" type="CM_TISnapShot"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="19bd278b-3991-4ed0-a6cc-e0ef4ea6eed8">
        <updating/>
        <source>setForCreate(_itemCode, _size: String; _printOrder: Integer; _tradeLineGeo: CMIF_CandHTradeLineGeo) updating;
//----------------------------------------------------------------
//	Created:	05 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.itemCode := _itemCode;
	self.category := _printOrder;
	self.size := _size;
	
	self.myCMIFTradeLineGeo := _tradeLineGeo;
	
end;</source>
        <Parameter name="_itemCode" type="String"/>
        <Parameter name="_size" type="String"/>
        <Parameter name="_printOrder" type="Integer"/>
        <Parameter name="_tradeLineGeo" type="CMIF_CandHTradeLineGeo"/>
    </JadeMethod>
</Class>
