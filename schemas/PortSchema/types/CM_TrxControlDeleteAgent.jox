    <JadeMethod name="trxDeleteVoyageBookingRefs" id="ef9dbf92-abee-4074-8854-f05e32c0998d">
        <updating/>
        <source>trxDeleteVoyageBookingRefs(_voyage:CM_Voyage; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBookingRef : CM_BookingRef;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if _voyage = null then
		app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Voyage), null, null);
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _voyage.allBookingRefs.isEmpty then
		// so that finaliseActivityWithPassport will work correctly
		beginTransaction;
		return;
	endif;

	foreach tmpBookingRef in _voyage.allBookingRefs do
		beginTransaction;
		app.myUtilityDA.utlDeleteBookingRef(tmpBookingRef, null, _passport);
		if _passport.hasErrors then
			break;
		endif;
		app.cmsCommitTransaction(_passport);
	endforeach;
	
	if (not process.isInTransactionState) then
		// so that finaliseActivityWithPassport will work correctly
		beginTransaction;
	endif;

epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
