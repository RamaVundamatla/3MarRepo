    <JadeMethod name="getWorkOrderTaskIdByClass" id="e7d1d551-3201-4e16-aff8-d4fb8afae979">
        <source>getWorkOrderTaskIdByClass(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/12/2022 navcs2 	ChangeRequest 54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen

*/

vars
	wodTaskId : Integer;
begin
	
	if self.isKindOf(CM_WodToDoNonOperational) then
		wodTaskId := WO_TASK_ToDo_NONOPS;
	elseif  self.isKindOf(CM_WodToDoTrain) then
		wodTaskId := WO_TASK_ToDo_TRAIN;
	elseif  self.isKindOf(CM_WodToDoVehicleVisit) then
		wodTaskId := WO_TASK_ToDo_TRUCK;
	elseif  self.isKindOf(CM_WodToDoVBS) then
		wodTaskId := WO_TASK_ToDo_VBS;
	elseif  self.isKindOf(CM_WodToDoVoyage) then
		wodTaskId := WO_TASK_ToDo_VOYAGE;	
	elseif  self.isKindOf(CM_WodToDoWagon) then
		wodTaskId := WO_TASK_ToDo_WAGON;	
	endif;
	
	return wodTaskId;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
