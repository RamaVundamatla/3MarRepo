    <JadeMethod name="cmbLocale_click" id="ae79659d-abb9-4c67-acbc-b47db6112ba3">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLocale_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions

*/

vars
	locale : CM_Locale;
	localeId : String;
	
begin
	if self.cmbLocale.listObject &lt;&gt; null then
		locale := self.cmbLocale.listObject.CM_Locale;
	endif;
	
	if locale = self.selectedLocale then
		return;
	endif;
	
	if self.xlatHasChanges() then
		if app.msgBox(app.getErrorString(UnsavedChangesInView), app.getErrorString(ConfirmCancelHeading), MsgBox_Yes_No) = MsgBox_Return_No then
			self.cmbLocale.listIndex := self.cmbLocale.findObject(self.selectedLocale);
			return;
		endif;
	endif;
	
	self.selectedLocale := locale;
		
	self.loadTranslationFields();
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbLocale_displayEntry" id="364b2a03-4021-4dd7-a7d3-2fa7b468bd15">
