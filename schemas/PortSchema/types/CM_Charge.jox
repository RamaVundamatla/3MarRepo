    <JadeMethod name="getQuantity" id="eb5e8d93-0950-4d20-a0a5-d9b29a2418e6">
        <source>getQuantity() : Real;
/*
Purpose:			

Date		Who		Reason
21 November 2023	navab1	BUG 61269
*/

vars

begin	
	if self.isVolumeBased() then
		return self.total / self.rate;
	else
		return self.invoiceLine.quantity;
	endif;

epilog

end;</source>
