    <JadeMethod name="validateLanes" id="a4691314-1ca1-45e0-a63f-8c858c98597d">
        <source>validateLanes() protected;
// ---------------------------------------------------------------------------
// Created:     21 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.laneCount &gt; 0 then
		if self.numberOfRows &lt;&gt; self.laneCount then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Expecting ' &amp; self.laneCount.String &amp;
										' lane proxies. Only ' &amp; self.allGridRows.size.String &amp; ' defined');
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
