		self.mySource.erase(1);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doActionTaskKnown" id="5af977c1-0253-4cbe-982b-5cd5825bc5ca">
        <updating/>
        <source>doActionTaskKnown(_woActionIF: CMIF_WorkOrderAction; _realJob: CM_Job io; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
18 Apr 2023 navma1  ChangeRequest 55442:[54989] EUP - Pack Cargo Work Order - Enhancement
10 Jul 2023	navma1	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
17 Jul 2023	navma1	Bug 59158: MTN - Actioning ToDo work orders doesn't create Update Transaction
*/

vars
	bulkRelease	    : CM_BulkRelease;
begin
	
	inheritMethod(_woActionIF, _realJob, _passport);
	
	if self.myReleaseRequest = null then							//17.04.2023 navma1 #55442:[54989]
		bulkRelease := self.createBulkRelease(BR_TYPE_PACKING);	
		if bulkRelease &lt;&gt; null then
			self.myReleaseRequest := bulkRelease;					//10.07.2023 navma1 #54550
		endif;
	endif;	
epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doActionTaskUnKnown" id="7365d753-28bb-49ff-bc5a-31b89d0a2c5e">
        <updating/>
        <source>doActionTaskUnKnown(_woActionIF: CMIF_WorkOrderAction; _realJob: CM_Job io; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2023 navma1  ChangeRequest 55442:[54989] EUP - Pack Cargo Work Order - Enhancement
19 Apr 2023 navma1  ChangeRequest 57326:[57327] EUP - VAS Task linked with Pack or Unpack Work Order
17 Jul 2023	navma1	Bug 59158: MTN - Actioning ToDo work orders doesn't create Update Transaction
*/

vars
	jobParams 		: CMIF_WorkOrderJobParams;
	woTrans     	: CM_WOTransaction;
	wodToDo			: CM_WodToDo;
	toDoJobParm     : CMIF_WorkOrderJobParams;
	toDoJob			: CM_Job;
	reserveDetail   : CM_ReserveDetail;
begin
	
	create jobParams transient;
	
	if _woActionIF.useYardJobs then
		self.createWOJobs(_woActionIF,jobParams,_realJob,_passport);
		

		/*
		17.04.2023 navma1 #57326:[57327]
		Create ToDo Task Jobs and Wles for Release by Type and Assign the first reserve detail to 
		Match cargo type and use total requested
		*/
		if not self.allToDoRequests.isEmpty then
			wodToDo := self.allToDoRequests.first;
			create toDoJobParm transient;
			
			if self.myReleaseRequest &lt;&gt; null then
				reserveDetail := self.myReleaseRequest.allReserveDetails.first;
			endif;
			if reserveDetail.isPackingParent then
				toDoJobParm.setReserveDetail(reserveDetail);
			endif;
			
			wodToDo.createWOJobs(_woActionIF,toDoJobParm,toDoJob,_passport);
			
		endif;
	endif;

epilog
	delete jobParams;
	delete toDoJobParm;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="erase" id="1c935706-6e9c-455e-940c-7b2bc314c8f6">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Aug 2009	cnwmd1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars

begin
	if self.mySource &lt;&gt; null then
		self.mySource.erase(_eraseLevel);
	endif;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAdvWOTransactionType" id="67958d02-7fb1-42b0-aaa4-14bcbd079a76">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TIPACK_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TIPACK_UPDATED;
	else
		return TRANS_TYPE_WO_TIPACK_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getBulkReleaseFromTask" id="4d36a214-af86-464e-bb7c-599631d32cbf">
        <source>getBulkReleaseFromTask(): CM_BulkRelease;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Mar 2023 navma1	ChangeRequest 55442:[54989] EUP - Pack Cargo Work Order - Enhancement
10 Jul 2023	navma1	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
*/

vars
	ti 				: CM_TrackedItem;
	bulkRelease		: CM_BulkRelease;
	term			: CM_Terminal;
begin
	term := self.getMyTerminal();
	
	if self.myReleaseRequest &lt;&gt; null then				//17.04.2023 navma1 #55442:[54989]
		bulkRelease := self.myReleaseRequest;
	else
		/*
		/10.07.2023 navma1 #54550
		if term.isUseYardJobsForCargoWo then
			bulkRelease := term.allBulkReleaseByTypeByStByCd.getAtKeyGeq(BR_TYPE_PACKING,BR_ACTIVE,self.taskID, null );
		else
			bulkRelease := term.allBulkReleaseByTypeByStByCd.getAtKeyGeq(BR_TYPE_PACKING,BR_ACTIVE,self.myParent.id, null );
		endif;
		*/
	endif;
	
	return bulkRelease;
epilog

end;</source>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="ecac8bab-f194-442e-a4ca-51b15c76ee72">
        <source>getDisplayString(_useShortDesc : Boolean) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Aug 2009	cnwmd1	Initial creation
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars
	displayStr : String;
	typeDesc   : String;
begin
	typeDesc := self.getTypeDescription();											//29.09.2021 navma1 #51925
	
	if _useShortDesc then
		displayStr := typeDesc;													
		displayStr := typeDesc &amp;" Task #" &amp; self.getTaskSequenceNumber().String;	//06.03.2023 navma1 #56457:[56458]	
	else
		displayStr :=  self.getLongDescription(typeDesc,null);						//29.09.2021 navma1 #51925
	endif;
epilog
	return displayStr;
end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
