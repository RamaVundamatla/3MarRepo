    <JadeMethod name="getDisplayStrForDefName" id="453a43be-5108-4b78-97ac-1dbef91045ab">
        <source>getDisplayStrForDefName(_name: String): String;
// ---------------------------------------------------------------------------
// Created:     12 October 2011 cnwgb1 
// Purpose:     CCMS 1009 RORO Stowage Advice
//  
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if _name = ETDef_EDITIVoyageHeader then
		return app.getErrorString(Voyage);
	elseif _name = ETDef_EDITILayout then
		return app.getErrorString(Layout);
	elseif _name = ETDef_EDITILayoutPoint then
		return app.getErrorString(Layout_Point);
	elseif _name = ETDef_EDITIStowAdvice then
		return app.getErrorString(Stowage_advice);
	endif;
end;
</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
