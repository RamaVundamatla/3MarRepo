    <JadeMethod name="updateOwnershipChange" id="a7a73528-0024-45d1-a883-5d5cb2e2b971">
        <updating/>
        <source>updateOwnershipChange()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 July 2023 	navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
07 August 2023 	navmv20 CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
30/11/2023		navkc1 ChangeRequest 58254 Task 58255: UI - New Permission
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	pxyCOO, realCOO 		: CM_OwnershipChange;
	theReturn : Integer;
	terminal				: CM_Terminal;
	newOperator,storageCgargeOpe,currentOperator : CM_Operator;
	incoterm : CM_InvoiceINCOTerm;
	frightForward	: CM_ConsigneeConsignor;
	refNumber,remarks,condition : String;
	addFreeDays,ownershipFreeDays : Integer;
	scheduleTSstart, freeStorageExpNewTS 		: TimeStamp;
	detail, pxyDetail : CM_OwnershipChangeDetail ; //07/08/2023 navmv20 CR 59440 Task 59441
	freeStorageExpNew : Date;
	invoiceContract : CM_InvoiceContract;					//navra1 - TFS 64874 - 14th Aug 2024	
	invoiceContractExists : Boolean;										//navra1 - TFS 64874 - 14th Aug 2024
	debtorInvoiceContracts : CM_InvContractByBankIdDict;					//navra1 - TFS 64874 - 14th Aug 2024
	incoChanged, contractChanged : Boolean;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	//  ### JIRA 19351 30SEP2024 NAVAB1
	if self.myOwnershipChange.isApproved() then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("COO - " &amp; self.myOwnershipChange.refNumber &amp; " - Update after APPROVAL", LogTRACE.String);
		endif;
	endif;

	pxyCOO := app.createUpdateProxy(self.myOwnershipChange).CM_OwnershipChange;	
	
	//07/08/2023 navmv20 CR 59440 Task 59441 - start
	foreach detail in self.myOwnershipChange.allDetails do
		pxyDetail := app.createUpdateProxy(detail).CM_OwnershipChangeDetail;
		pxyDetail.setOwnershipChange(pxyCOO);
	endforeach;
	//07/08/2023 navmv20 CR 59440 Task 59441-end

	if self.cmbNewOperator.listIndex &lt;&gt; -1 then
		newOperator := self.cmbNewOperator.itemObject[self.cmbNewOperator.listIndex].CM_Operator;
		/* ### JIRA 19351 30SEP2024 NAVAB1
		debtorInvoiceContracts  := newOperator.debtor.allInvoiceContracts;
		foreach invoiceContract in debtorInvoiceContracts where invoiceContract.myTerminal.code = self.myTerminal.code do				//navra1 - DEFECT 65798 - 29th Aug 2024
			if invoiceContract.active = true then
				self.cmbInvoiceContract.addItemObject(invoiceContract.contractId, invoiceContract);
				invoiceContractExists := true;
			endif;
		endforeach;
		*/
	endif;
	
	/* ### JIRA 19351 30SEP2024 NAVAB1
	if invoiceContractExists &lt;&gt; true then
		app.myPassport.addWarningFull(Cargo_item_todo_tasks_pendin, null, null, null, null);
		//app.raiseCMWarning1(Cargo_item_todo_tasks_pendin, null, null, null, null);
	endif;	
	*/
	
	if self.cmbCurrentOperator.listIndex &lt;&gt; -1 then
		currentOperator := self.cmbCurrentOperator.itemObject[self.cmbCurrentOperator.listIndex].CM_Operator;
	endif;
	
	if self.cmbIncoTerm.listIndex &lt;&gt; -1 then
		incoterm := self.cmbIncoTerm.itemObject[self.cmbIncoTerm.listIndex].CM_InvoiceINCOTerm;
	endif;
	
	if self.cmbFrightForwarder.listIndex &lt;&gt; -1 then
		frightForward := self.cmbFrightForwarder.itemObject[self.cmbFrightForwarder.listIndex].CM_ConsigneeConsignor;
	endif;
	
	if self.cmbStorageOperator.listIndex &lt;&gt; -1 then
		storageCgargeOpe := self.cmbStorageOperator.itemObject[self.cmbStorageOperator.listIndex].CM_Operator;
	endif;
	
	scheduleTSstart.setDate(self.mskCOOFromStart.text.asDateJMT());
	scheduleTSstart.setTime(self.mskCOOFromStartTime.text.asTimeJMT());
	if self.txtAddFreeDaysNew &lt;&gt; null then
		addFreeDays := self.txtAddFreeDaysNew.text.Integer;
	endif;
	
	
	if self.txtRemarks &lt;&gt; null then
		remarks := self.txtRemarks.text.String;
	endif;
	
	if self.txtCondition &lt;&gt; null then
		condition := self.txtCondition.text.String;
	endif;
	if self.txtRefNumber &lt;&gt; null then
		refNumber := self.txtRefNumber.text.String;
	endif;
	terminal := self.getMyTerminal;
	
	if self.cmbInvoiceContract.listIndex &lt;&gt; -1 then																			//navra1 - TFS 64874 - 14th Aug 2024
		invoiceContract := self.cmbInvoiceContract.itemObject[self.cmbInvoiceContract.listIndex].CM_InvoiceContract;		//navra1 - TFS 64874 - 14th Aug 2024
	endif;
	
	// ### TFS BUG 64680 17JUNE024 NAVAB1 - set the free storage exp for new Op on COO
	freeStorageExpNew := self.displayFreeStorageExpiry.caption.asDateJMT();
	freeStorageExpNewTS.setDate(freeStorageExpNew);
	
	//  ### JIRA 19351 30SEP2024 NAVAB1
	if incoterm &lt;&gt; self.myOwnershipChange.myIncoterm then
		incoChanged := true;
	endif;
	if invoiceContract &lt;&gt; self.myOwnershipChange.myInvoiceContract then
		contractChanged := true;
	endif;
	
	pxyCOO.setProxy(refNumber, null,condition,app.getMyUserCode(),self.localToSystemTime(scheduleTSstart),self.myOwnershipChange.dateTimeApproved, // ### JIRA 19351 30SEP2024 NAVAB1

									freeStorageExpNewTS,null,addFreeDays,pxyCOO.freeDaysOperatorOld, // ### TFS CR 58263 TASK 58264 30JAN2024 NAVAB1 // ### TFS CR 58263 TASK 58264 30JAN2024 NAVAB1 // ### TFS BUG 64126 16MAY2024 NAVAB1
											null,null,null,remarks,frightForward,incoterm,newOperator,currentOperator,null,storageCgargeOpe,null,terminal, invoiceContract);	//navra1 - TFS 64874 - 14th Aug 2024
	while true do
		app.myTrxUA.trxUpdateOwnershipChange(pxyCOO, app.myPassport); 
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Ownersh_change_update_sucessf), app.getErrorString(Message),MsgBox_OK_Only);
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Ownersh_change_updated), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	
	//  ### JIRA 19351 30SEP2024 NAVAB1
	if self.myOwnershipChange.isApproved() 
	and (incoChanged or contractChanged) then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("COO - " &amp; self.myOwnershipChange.refNumber &amp; " - Update after APPROVAL. INCO Changed: " &amp; incoChanged.String &amp; " CONTRACT Changed: " &amp; contractChanged.String, LogTRACE.String);
		endif;
		self.doApprove(true); // ### JIRA 33015 04OCT2024 NAVAB1 reapproval
	endif;
	
	
epilog
	self.mousePointer := Window.MousePointer_Default;
	delete pxyCOO;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateOwnershipChangeDetails" id="c09a1f2d-3705-4bad-beab-2f420ef273b4">
        <source>updateOwnershipChangeDetails();
/*
Purpose:			

Date		Who		Reason
27 May 2024	navab1	CR 64164 TASK 64179
*/

vars
	cmifOwnershipChangeDtl : CMIF_OwnershipChangeDetail;
	theReturn, option, timeRemaining : Integer;
begin

	create cmifOwnershipChangeDtl transient;
	// put all the sub items in, whether 'included' or not.
	self.allProxyDetailsForInclude.copy(cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails);
	
	while true do
		app.myTrxUA.trxUpdateOwnershipChangeDtls(cmifOwnershipChangeDtl,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			self.showMessage(app.getErrorString(Details_auto_saved), 1500, self.Position_TopCentered);
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Ownership_change_details), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  // there must have just been warnings that the user has acknoledged so ..
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
			
		break;
	endwhile;
	

epilog
	self.allProxyDetailsForInclude.purge();
	delete cmifOwnershipChangeDtl;


end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="a9b5bb99-7780-45b6-b8b4-2e23bf2ad10b">
