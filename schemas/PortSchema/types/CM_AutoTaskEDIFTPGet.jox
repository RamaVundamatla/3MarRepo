    <JadeMethod name="getValueForRow" id="027a43f0-9c59-4111-a37c-3fdde1b0bd19">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;
//
// 03 Mar 2014	cmwrs1 par 33631 SFW 1373
//
vars

begin
	if _rowName = ETRow_BgpAutoEDIFTP then
		if global.isValidObject(self.myFTPEntity) then
			return self.myFTPEntity.id;
		endif;
	endif;
	
	return inheritMethod(_rowName, _obj);
end;
</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1cd32544-f917-4593-b3c5-f55448391c0d">
        <source>pxyCreateUpdateProxy() : SelfType;
//
// 03 Mar 2014	cmwrs1 par 33631 SFW 1373
//
vars
	task : CM_AutoTaskEDIFTPGet;
	completedOK		: Boolean;
begin
	task := inheritMethod();
	task.myFTPEntity := self.myFTPEntity;
	completedOK := true;
	return task;
epilog
	if not completedOK then	
		delete task;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e6e6b7e8-c170-486c-bb56-7fd2390bdd47">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskEDIFTPGet) updating;
//
// 03 Mar 2014	cmwrs1 par 33631 SFW 1373
//
vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName := BGP_EdiFTPGet.name;
	self.myFTPEntity := _pxyAutoTask.myFTPEntity;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskEDIFTPGet"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4634115c-e07c-44cb-839c-e1535b71534f">
