    <JadeMethod name="doTblDataDBClick" id="2651d366-9cfd-4884-bffb-57ebadcb3481">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;

vars

begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if table.column &lt;= table.fixedColumns then
		return;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	self.showPropertyFrame();

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="07143b64-74a5-41cc-bdf8-34ae2eaa98cf">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;

vars
	theRow, theCol : Integer;
begin
	self.myCurrentDebtor := null;
	self.myCurrentInvType := null;
	self.myCurrentMapping := null;
	self.myCurrentFinPeriod := null;
	
	inheritMethod(table);
	theRow := table.row;
	theCol := table.column;
	
	if theRow &gt; table.fixedRows then
		self.myCurrentInvType := table.accessRow(theRow).itemObject.CM_InvoiceDesc;
		if theCol &gt; table.fixedColumns then
			self.myCurrentDebtor := table.accessColumn(theCol).itemObject.CM_Debtor;
			self.myCurrentMapping := table.accessCell(theRow,theCol).itemObject.CM_DebtorBankInvTypeDtl;
			if self.myCurrentMapping &lt;&gt; null then
				self.myCurrentFinPeriod := self.myCurrentMapping.myFinancialPeriodEnd;
			endif;
		endif;
	endif;
	
	self.cmbDebtors.listObject := self.myCurrentDebtor;
	self.cmbInvoiceTypes.listObject := self.myCurrentInvType;
	self.cmbPeriods.listObject := self.myCurrentFinPeriod;
	self.setEnableObjects();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="haltProgress" id="a0c1b4a6-1068-4c93-90f8-c93b077b6f18">
        <source>haltProgress(pe : CM_ProgressException; ls : Boolean io) : Integer;

vars
	wasSet : Boolean;
begin
	wasSet := ls;
	app.cmsEndLoad(ls);		// from 35872 testing, to avoid an error with msg box in load state

	if app.msgBox(self.myCurrentBank.getMsgString(WARN_CANCEL_PROGRESS ,
										"",
										"",""),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then

		cmbDebtor.listIndex := 1;
		self.tblData.columns := 1;
		return Ex_Abort_Action;
	else
		if wasSet then
			app.cmsBeginLoad(ls);
		endif;
		return Ex_Continue;
	endif;

end;</source>
        <Parameter name="pe" type="CM_ProgressException"/>
        <Parameter name="ls" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
