    <JadeMethod name="tSubDeck" id="8581d98b-362b-4bc2-93b4-79e887596a86">
        <updating/>
        <source>tSubDeck() updating;
// cnwmp6
// CNWMC5
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2012		NAVAB1		Initial creation
*/

vars
	gcDefn : CM_ROROGCDefnVoyage;
	altRoroLCs, roroLCs : CM_LCArray;
	voyage : CM_Voyage;
	realAlloc : CM_VoyageAllocation;
	ct : CM_CargoType;
	product: CM_Product;
	theEditions : CM_ObjectByOidEditionDict;
	lc : CM_LocationsController;
	theTI : CM_TrackedItem;
	voyageDeck : CM_DeckVoyage;
	lcSet		: CM_LCSet;
begin
	ct	:= self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := ct.allProducts.first;

	voyage := self.createVesselVoyage("UTBISH_SUB1", "UTBISH_SUB", null);
	
	//12 Nov 2020	NDL	TFS 50311 - investigation
	beginTransaction;
	voyage.setPropertyValue( CM_Voyage::myVoyageProcess.name, self.getTerminal.getDefaultVoyageProcess );
	commitTransaction;
	
	self.createCargoOnship(voyage);
	
	create lcSet transient;
	
	if voyage.myROROStructure &lt;&gt; null then
		voyageDeck:= voyage.myROROStructure.allDecksByCode[DECK1];
		if voyageDeck &lt;&gt; null then
			voyageDeck:= voyageDeck.allSubDecks[1];
			if voyageDeck &lt;&gt; null then
				create roroLCs transient;
						
				// ### GC ALLOCATION
				realAlloc := self.addVoyageAllocation(voyage, "AUMEL", "", "", ct.id, false, false); // Cannon Balls
				// ### GC POSITIONS
				roroLCs.clear();
				gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 50, 10, voyageDeck, app.myPassport);
				roroLCs.add(gcDefn.myGCController);
				lcSet.clear();
				roroLCs.copyNoDups(lcSet);
			
				gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null,null, null, 50, -5, voyageDeck, app.myPassport);
				roroLCs.add(gcDefn.myGCController);
				roroLCs.copyNoDups(lcSet);
			
				gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 75, -5, voyageDeck, app.myPassport);
				roroLCs.add(gcDefn.myGCController);
				roroLCs.copyNoDups(lcSet);
				self.updateTIRemarksFromLCSet(lcSet);
			
				self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
				
				
				roroLCs.clear();
				self.getJobROROControllerByID("UTBISH_SUB1",DECK1,DECK1 &amp; "S", "AUTOLOCN701", roroLCs, true, 1); 
				self.getJobROROControllerByID("UTBISH_SUB1",DECK1,DECK1 &amp; "S", "AUTOLOCN702", roroLCs, true, 1); 
				self.getJobROROControllerByID("UTBISH_SUB1",DECK1,DECK1 &amp; "S", "AUTOLOCN703", roroLCs, true, 1); 
				
				realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "20BX", "", TI_CargoType_Container, false, false);
				self.addLCsToROROAllocation(true, realAlloc, roroLCs, null,1);
				
				
			endif;
		endif;
	endif;

epilog
	delete roroLCs;
	delete lcSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVoyageGetNextNumWorkPoint" id="986545d3-6d37-466d-8dac-ecba8680ad64">
        <source>tVoyageGetNextNumWorkPoint();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	voyage : CM_Voyage;
	workPoint : CM_WorkPoint;
	nextNum : String;
	jobSheet : CM_VoyageDeckJobSheet;
begin

	
	jobSheet:=self.xCreateDeckJobSheet("UT_ROROOP","UT_ROROOP1","UT_WP");
	voyage:= jobSheet.myVoyage;
	workPoint:=jobSheet.myWorkPoint;
	
	//add a job sheet
	//no work point should return 200 still as looks at it from the job sheet
	nextNum:=voyage.getNextJobNumber(jobSheet,null);
	
	self.assertEqualMsg(nextNum,"200","job next num != 200");
	
	nextNum:=voyage.getNextJobNumber(jobSheet,workPoint);
	
	self.assertEqualMsg(nextNum,"200","job next num != 200");
	
epilog

end;</source>
