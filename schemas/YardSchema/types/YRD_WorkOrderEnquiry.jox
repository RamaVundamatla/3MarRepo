    <JadeMethod name="refreshSelectedStatus" id="2ab7b8cd-2a0b-4eae-b5a0-ee8ef22b3fa7">
        <source>refreshSelectedStatus();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2009	cnwrd1	Initial creation

*/

vars
	objArr : ObjectArray;
	obj : Object;
	assoc : CM_Association;
begin
	// update status filter 
	
	self.allSelectedStatus.clear();
	create objArr transient;
	self.mltWOStatus.getSelected(objArr);
	
	foreach obj in objArr do
		assoc := obj.CM_Association;
		self.allSelectedStatus.add( assoc.getValue().Integer );
	endforeach;
	

epilog
	delete objArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeFromTable" id="2ca0d594-09f3-4089-b8c3-f0890a973ea6">
        <source>removeFromTable( _obj : CM_Object);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Aug 2009	cnwrd1	Initial creation
16 Dec 2022 navma1	Bug 54234: MTN - Work Order Maintenance - Work Order tasks are duplicated when adding a todo task to the Receive Cargo
22/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
*/

vars
	workOrderDtl : CM_WorkOrderDtl;
	workOrder	 : CM_WorkOrder;
	theRow 		 : Integer;
	isInvalid 	 : Boolean;
begin
	// somethings been deleted we need to find if we have it in the table and remove.
	
	if _obj.isKindOf(CM_WorkOrder) then
		workOrder := _obj.CM_WorkOrder;
	elseif _obj.isKindOf(CM_WorkOrderDtl) then
		workOrderDtl := _obj.CM_WorkOrderDtl;
		on Exception do app.handleDeletedObject(exception, workOrderDtl, isInvalid);
		workOrder := workOrderDtl.myParent;
	endif;

	
	if self.isEnqType_WorkOrder and workOrderDtl = null then
		// in work order mode with a work order so check and remove if we are displaying
		self.tblData.removeItemObject(workOrder); //23/06/2025	navkc1 JIRA MTN 34973

	elseif self.isEnqType_Task then
	
		//if we have been sent a work order (i.e. no work order dtl)  then we want to remove all of its details if they are in the list
		if workOrderDtl = null and  workOrder &lt;&gt; null then
			foreach workOrderDtl in workOrder.allWoDtls do	
				self.tblData.removeItemObject(workOrderDtl); //23/06/2025	navkc1 JIRA MTN 34973
			endforeach;		
		endif;
		self.tblData.removeItemObject(workOrderDtl); //23/06/2025	navkc1 JIRA MTN 3497
	endif;
	
	self.updateStatusBarCount();			// 22/11/2023	navcs2	ChangeRequest 60866

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="rowPostprocess" id="66a024c3-0cbe-47e5-a911-5a6298c43c57">
        <updating/>
        <source>rowPostprocess(_dataTable: CM_DataTable io; _idx: Integer; _obj: Object): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jun 2024 navlc30 ChangeRequest 64360: MTN - Multithreading For Work Order Enquiry Screen 
*/

vars
	workOrder : CM_WorkOrder;
	workOrderDetail : CM_WorkOrderDtl;
begin

	if self.isEnqType_WorkOrder then
		workOrder := _obj.CM_WorkOrder;
		self.doNotableAdd(workOrder);
	elseif self.isEnqType_Task then
		workOrderDetail := _obj.CM_WorkOrderDtl;
		self.doNotableAdd(workOrderDetail);
	endif;		
	
	return true;
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="io"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rowPreprocess" id="55f5e045-a21e-4afb-8df6-9f812960bf1b">
        <updating/>
        <source>rowPreprocess(_dataTable: CM_DataTable; _obj: Object): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jun 2024 navlc30 ChangeRequest 64360: MTN - Multithreading For Work Order Enquiry Screen
*/

vars
	workOrderDetail : CM_WorkOrderDtl;
	tbl : CM_DataTable;
begin
	if self.isEnqType_Task then
		workOrderDetail := _obj.CM_WorkOrderDtl;
		tbl := _dataTable;
		tbl.removeItemObject(workOrderDetail);													//16.12.2022 navma1 #54234
	endif;	
	
	return true;
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveXMLStrForTblColumns" id="0144a8c6-527f-4b10-a944-6fa0acfc9827">
        <updating/>
        <source>saveXMLStrForTblColumns(_theTable: CM_DataTable input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwmd1	Initial creation

*/

vars
	xmlStr : String;
begin

	xmlStr := self.tblData.getXmlStrForColumns(true);
	
	if self.isEnqType_WorkOrder then
		self.enquiryTypeDef_WorkOrder := xmlStr;	
	elseif self.isEnqType_Task then
		self.enquiryTypeDef_Task := xmlStr;	
	endif;
epilog

end;</source>
