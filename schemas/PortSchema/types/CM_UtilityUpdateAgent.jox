vars

begin

	self.initialiseActivity();

	app.myValUA.valTerminalStateObject(pTerminal, pGroup, pProxyStateObject);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	pTerminal.setStateObject(pGroup, pProxyStateObject, _passport);

epilog
	// Always return the error code to the caller (which will be zero if no errors)
	
end;</source>
        <Parameter name="pTerminal" type="CM_Terminal"/>
