    <JadeMethod name="getDisplayString" id="1008840c-f3db-4bcc-96d8-06e5f355770f">
        <source>getDisplayString(_useShortDesc: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2021		navma1	Initial creation

*/

vars
	displayString 	: String;
	desc			: String;
	woTaskType	 	: CM_WorkOrderDetailType;
begin
	
	desc := app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Voyage,self.detailType);
	
	if desc = null then
		return null;
		
	endif;
	if _useShortDesc then
		displayString :=  desc;
	else
		displayString := "(" &amp; self.taskID.String &amp; ") " &amp; desc;
		
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHarbour" id="0e0919a0-4eb0-4af7-8d7b-d9390120ae4c">
        <source>getHarbour() : HMS_Harbour;
/*

Purpose:			 // TFS 38524

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgab1	Initial creation

*/

vars

	voyage : CM_Voyage;
	movement : HMS_VoyageMovement;
	hmsBerth : HMS_Berth;
	fromTS, toTS : TimeStamp;
	harbour : HMS_Harbour;
	wod : CM_WorkOrderDtl;
	
begin
	voyage := self.getMyVoyageObject();
	
	if voyage = null then
		return null;
	endif;
	
	movement := voyage.getMovementArrival();
	if movement = null then
		return null;
	endif;
	
	harbour := movement.myHarbour;


	return harbour;
epilog

end;</source>
        <ReturnType type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="getInaportnetPPKB" id="01ef827f-ef73-45a2-95bc-f1badf0f7486">
        <source>getInaportnetPPKB() : String;
/*

Purpose:			Generate a unique PPKB reference number from the receiver for the INAPORTNET interface

Parameters:			None

Return Value:		PPKB number

Date		Who		Reason
19 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

	port : CM_Port;
begin
	port:=self.getMyTerminal.getDefaultPort();
	
	if port &lt;&gt; null then
		return  port.code &amp; "-PPKB-" &amp; self.getOidString;
	endif;
	return "PPKB." &amp; self.getOidString;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
