<Class name="WS_SourceLocation" id="95af2181-390a-4d36-944a-ec543f8fcc13">
    <superclass name="WS_Code"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Log Source location codes, system definable values</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allSourceSubLocations" id="c51dc9d6-6782-46ed-b33c-8e85cdd4168d">
        <memberTypeInverse/>
        <type name="WS_SourceSubLocationArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="isFSC" id="26ddb6d2-a71d-4a4d-99a2-c63d08e1a23d">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="delete" id="d2a89314-bdba-4861-b5ac-f3951dec0adb">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2014	cnwmc5	Initial creation

*/

vars

begin
	if self.allSourceSubLocations &lt;&gt; null and not self.allSourceSubLocations.isEmpty() then
		self.allSourceSubLocations.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="d3d03d97-6a01-49d8-8421-ef5808d8a7b6">
        <updating/>
        <source>setProxyFromObject(_object: CM_SourceLocation) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2014	cnwmc5	Initial creation

*/

vars
	wsSourceSubLocation : WS_SourceSubLocation;
	sourceSubLocation	: CM_SourceSubLocation;
	code				: CM_Code;
	
begin
	inheritMethod(_object);
	
	foreach code in _object.allSubLocations do
		if not code.isKindOf(CM_SourceSubLocation) then
			continue;
		endif;
		
		sourceSubLocation := code.CM_SourceSubLocation;
		
		create wsSourceSubLocation transient;
		wsSourceSubLocation.setProxyFromObject(sourceSubLocation);
		self.allSourceSubLocations.add(wsSourceSubLocation);
	endforeach;
	
	self.isFSC := _object.isFSC;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_SourceLocation"/>
    </JadeMethod>
</Class>
