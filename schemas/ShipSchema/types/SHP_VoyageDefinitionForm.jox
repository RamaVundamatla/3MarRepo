/*
Date		Who		Reason
26 May 2009	cnwar2	Initial creation

*/
vars

begin
	// ### JIRA 34233 06MAR 2025 NAVAB1
	self.btnCutoffEdit.enabled := self.ckbOverrideDef.value;

	self.frmCutoffDataEntry.enabled := self.ckbOverrideDef.value;
	self.tblVoyageCutoffs.userInputEnabled 	:= self.ckbOverrideDef.value;
	self.btnAddOperator.enabled 			:= self.ckbOverrideDef.value and (self.myTerminal.allReceivalCutoffDefs.size &gt; 0);
	
	if not self.ckbOverrideDef.value then
		self.hasOperatorColumn := false;
		self.initRecCutoffsTbl();
