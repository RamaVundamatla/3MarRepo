    <JadeMethod name="setProxyDocketNumberWeigh" id="ff9607e0-a422-4f5b-b892-5f4a3e516a58">
        <updating/>
        <source>setProxyDocketNumberWeigh(_docketNumberWeigh : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2014	cnwmc5	Initial creation

