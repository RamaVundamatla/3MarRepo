    <JadeMethod name="getXMLInvoice" id="97851a87-263d-471c-840e-4494a5ed0501">
        <source>getXMLInvoice() : String;
// 28218 CCMS 2120 Oct 2011 electronic invoicing, method used in report writer
vars
	result	: String;
begin
	result := '&lt;invoice&gt;' &amp; CrLf &amp;
			  '&lt;invoicenumber&gt;' &amp; self.sequenceNum.asStringJMT() &amp; '&lt;/invoicenumber&gt;' &amp; CrLf;
	if self.purchaseOrderNumber &lt;&gt; null then
		result := result &amp; '&lt;purchaseordernumber&gt;' &amp; self.purchaseOrderNumber.xmlReplaceReservedChars(true) &amp; '&lt;/purchaseordernumber&gt;' &amp; CrLf;
	endif;
	result := result &amp; '&lt;invoiceissuedate&gt;' &amp; self.toDT.date.userFormat($ODBC_Date) &amp; '&lt;/invoiceissuedate&gt;' &amp; CrLf &amp;
			  '&lt;/invoice&gt;';
	result.encodeUTF8();
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLInvoiceSummary" id="3e2d8ff9-a55a-4fff-a13b-bf3229dcc0cd">
        <source>getXMLInvoiceSummary() : String;
// 28218 CCMS 2120 Oct 2011 electronic invoicing, method used in report writer
vars
	result	: String;
	totalQty	: Real;
//	totalNet,
//	totalGst,
//	total		: Decimal[10,2];
	idx	: Integer;
//	invTotalNoTax :   Decimal[12,2];
	taxTotal	: Real;
	codes : StringArray; 
	rates  : RealArray; 
	amounts : RealArray;
	multiTax : Boolean;
	invline : CM_InvoiceLine;															//+TFS2893
	
	
	summDict	: CM_GLSummaryByGLCodeRateDict;
	repSumm	: CM_ReportInvoiceSummary;
	glSumm		: CM_GLSummary;
	count1 			: Integer;
	totalNet, totalGst, total		: Decimal[14,2];	//11 May 2018	NDL	TFS 38528
	invTotalNoTax :   Decimal[16,2];	//11 May 2018	NDL	TFS 38528
	
begin
	create codes transient;
	create rates transient;
	create amounts transient;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;

	totalNet := self.getTotalAmount();
	totalQty := self.getTotalQuantity();
	
	self.getTaxForInvoice(multiTax, invTotalNoTax, codes, rates, amounts); 
	
	if self.isZeroRatedTax then
		taxTotal := 0;
	else
		foreach idx in 1 to codes.size do
			taxTotal := taxTotal + (amounts[idx] * (rates[idx] / 100));
		endforeach;
	endif;
	totalGst := taxTotal.jMTRoundedTo($CM_ChargeQuantity.decimalPlaces);
	total := totalNet + totalGst;
	
	result := '&lt;invoicesummary&gt;' &amp; CrLf &amp;
			  '&lt;invoiceqty&gt;' &amp; totalQty.rounded.String &amp; '&lt;/invoiceqty&gt;' &amp; CrLf &amp;
			  '&lt;invoicecost&gt;' &amp; CrLf &amp;
			  '&lt;currency&gt;NZD&lt;/currency&gt;' &amp; CrLf &amp;
			  '&lt;netamount&gt;' &amp; totalNet.String &amp; '&lt;/netamount&gt;' &amp; CrLf &amp;
			  '&lt;gst&gt;' &amp; totalGst.String &amp; '&lt;/gst&gt;' &amp; CrLf &amp;
			  '&lt;totalamount&gt;' &amp; total.String &amp; '&lt;/totalamount&gt;' &amp; CrLf &amp;
			  '&lt;/invoicecost&gt;' &amp; CrLf &amp;
			  '&lt;/invoicesummary&gt;';
	result.encodeUTF8();
	return result;
epilog
	delete codes;
	delete rates;
	delete amounts;
	
	//delete summDict;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLTransport" id="eb3c90f5-aed3-42dc-9103-93ebe2a7a88e">
        <source>getXMLTransport() : String;
// 28218 CCMS 2120 Oct 2011 electronic invoicing, method used in report writer
vars
	result	: String;
	
begin
	if self.invoiceType.isVoyageSpecific() and
	   self.myVoyage &lt;&gt; null then
		result := '&lt;transport&gt;' &amp; CrLf &amp;
				  '&lt;lloydsnumber&gt;' &amp; self.myVoyage.lloydsNumber[1:8].xmlReplaceReservedChars(true) &amp; '&lt;/lloydsnumber&gt;' &amp; CrLf &amp;
				  '&lt;vesselname&gt;' &amp; self.myVoyage.vesselName.xmlReplaceReservedChars(true) &amp; '&lt;/vesselname&gt;' &amp; CrLf &amp;
				  '&lt;voyagenumber&gt;' &amp; self.debtorReference[1:10].xmlReplaceReservedChars(true) &amp; '&lt;/voyagenumber&gt;' &amp; CrLf &amp;
				  '&lt;/transport&gt;';
		result.encodeUTF8();
	// ### TFS 51219 25MAY2021 NAVAB1
	elseif self.invoiceType.isVoyageGroupSpecific() 
	and self.myVoyage &lt;&gt; null then
		result := '&lt;transport&gt;' &amp; CrLf &amp;
				  '&lt;lloydsnumber&gt;' &amp; self.myVoyage.lloydsNumber[1:8].xmlReplaceReservedChars(true) &amp; '&lt;/lloydsnumber&gt;' &amp; CrLf &amp;
				  '&lt;vesselname&gt;' &amp; self.myVoyage.vesselName.xmlReplaceReservedChars(true) &amp; '&lt;/vesselname&gt;' &amp; CrLf &amp;
				  '&lt;voyagenumber&gt;' &amp; self.debtorReference[1:10].xmlReplaceReservedChars(true) &amp; '&lt;/voyagenumber&gt;' &amp; CrLf &amp;
				  '&lt;voyagegroupcode&gt;' &amp; self.myVoyage.voyageGroupCode.xmlReplaceReservedChars(true) &amp; '&lt;/voyagegroupcode&gt;' &amp; CrLf &amp;
				  '&lt;/transport&gt;';
		result.encodeUTF8();
	endif;
	
	return result;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
