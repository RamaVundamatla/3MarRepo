    <JadeMethod name="getRowColour" id="ebd838c2-becd-49e0-b862-6fc471dbb436">
        <source>getRowColour(_foreColour: Integer output; _backColour: Integer output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2023 navma1 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order

*/

vars

begin
	inheritMethod(_foreColour, _backColour);
	
	if self.status = WLE_COMPLETED then
		_foreColour := White;					
		_backColour := CM_Job.Colour_ReceiptComplete;
	endif;

epilog

end;</source>
        <Parameter name="_foreColour" type="Integer" usage="output"/>
        <Parameter name="_backColour" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTi" id="f444589f-8f9d-4894-8c5b-c0eaa6c9fab8">
        <source>getTi(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023	navhl20	ChangeRequest 57762: EUP - Delivery Dispatch – Pack/UnPack
03 Jul 2023 navma1  ChangeRequest 58849: EUP | Delivery Dispatch Screen - Unpack Operation
29 Apr 2024 navma1	Bug 63868: MTN - 1081 from performance test QA-PerformanceTest-Dumps_20240424
*/

vars
	operWle : CM_WorkListEntry;
	ti		: CM_TrackedItem;
begin
	
	ti := self.myTrackedItem;
	
	if ti &lt;&gt; null then
		return ti;
	endif;
	
	operWle := self.myOperationalWLE;
	
	if operWle &lt;&gt; null  then
		return operWle.myTrackedItem;
	endif;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
