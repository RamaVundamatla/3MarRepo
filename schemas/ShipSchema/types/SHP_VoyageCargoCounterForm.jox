	self.chkQty.value			:= true;
	self.chkWeight.value		:= true;
	self.chkLM.value			:= true;
	self.chkArea.value			:= true;
	self.chkVolume.value		:= true;
	
	self.mulCargoTypes.clearSelected;
epilog

end;</source>
