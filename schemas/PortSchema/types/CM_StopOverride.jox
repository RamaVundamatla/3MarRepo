    <JadeMethod name="getStopOverriddenReason" id="7da663ea-6a1d-4691-b8f1-a265c962903a">
        <source>getStopOverriddenReason() : String;

/*
Purpose:	This method is available for use in JRW so do not delete.
			Reimplemented method for JRW.

Date				Who		Reason
03 September 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	if self.myStopOverrideReason = null then
		// should never happen but...
		return app.getString( Unknown );
	else
		return self.myStopOverrideReason.description;
	endif;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="f330cc6a-7e58-42f4-80ee-6f3fc0eb5da4">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl( _tiTransCntrl : CMIF_TITransactionController; _passport : CM_Passport input ) updating;

/*
Date			Who		Reason
24 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	tiTransCntrl	: CMIF_TITransactionController;
	
begin
	tiTransCntrl			:= _tiTransCntrl;
	
	self.remarks			:= tiTransCntrl.remarks;
	self.systemGenerated	:= tiTransCntrl.systemGenerated;
	self.setStop( tiTransCntrl );
	
	inheritMethod( tiTransCntrl, _passport );
	
epilog
	
end;
</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
