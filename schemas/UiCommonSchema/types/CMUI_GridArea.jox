    <JadeMethod name="drawSelf" id="94d2f23d-e342-4cc4-b72b-aadb0c84e957">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>drawSelf() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.setGridRowColPositions();
	// sgp 22 July 2003 : totalPointWidth and height already include the scaleFactor
	self.myGridAreaFrame.width	:= self.totalPointWidth;// * scaleYFactor;
	self.myGridAreaFrame.height	:= self.totalPointHeight;// * scaleXFactor;

	if self.mySDF &lt;&gt; null then
		self.drawGridArea();
		self.drawVLabels();
		self.drawHLabels();
		
		self.myHLabelsFrame.width := self.myGridAreaFrame.width; //epr par 19063 2/4/09 
		self.mySDF.backColor := self.myHLabelsFrame.backColor;
		self.mySDF.myDrawingFrame.backColor := self.myHLabelsFrame.backColor;
	endif;
epilog
		
end;</source>
    </JadeMethod>
