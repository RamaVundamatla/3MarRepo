    <JadeMethod name="kaTruckLoaderUnloader" id="210aa2ed-08e1-4b44-a685-7578fcf20a27">
        <source>kaTruckLoaderUnloader();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 31 May 2023
TFS#		: 56398
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/


vars
	response : WS_Response;
	request : WS_CargoItemUpdateRequest;	
	webServiceService : JMTUserInterfaceService;
	
begin

	app.initialize();
	
	create webServiceService transient;
	
	app.myPassport.setMyUserFromCode("jlika1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["JBL"]);
	//app.setPropertyValue("downloadFileDirectoryPath","C:\Temp/");
	app.setPropertyValue("isWebApp",true);
	//app.setPropertyValue("myPDFPrinter","3377.74".asOid.CM_PrinterDef);	

	create request transient;
	create response transient;
			
	request.setPropertyValue("cargoGroupId","KA3009211");
	request.setPropertyValue("cargoType","1");
	request.setPropertyValue("commodityCode","GENL");
	request.setPropertyValue("dischargePort", "AUBNE");
	request.setPropertyValue("isoType", "2200");
	request.setPropertyValue("id", "CR31052023B");
	request.setPropertyValue("imexStatus", 2);
	request.setPropertyValue("isOverlanded", true);
	request.setPropertyValue("operatorCode","DOUG");
	request.setPropertyValue("weightTotal","2000");
	request.setPropertyValue("truckIdForLoad", "HL017");
	request.setPropertyValue("voyageCode", "02160761");
	
	webServiceService.createNewCargo(request);
	


epilog

	delete response;
	delete request;
	delete webServiceService;

end;</source>
    </JadeMethod>
