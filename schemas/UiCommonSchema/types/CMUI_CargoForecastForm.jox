    <JadeMethod name="setupForm" id="145cd4c7-692d-487d-9b7a-b187e47dcba6">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2022	navak20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars

begin
	inheritMethod();
	self.isNewBtnClicked := false;
	self.btnRemove.enabled := false;
	self.btnSave.enabled := false;
	self.btnNew.enabled := false;
	self.btnAudits.enabled := false;
	self.doPermissionCheck();
	self.populateCmbData();
	self.disableCmbControls();
	self.cmbMode.listIndex := self.cmbMode.findString(1, app.getErrorString(Discharge));
	
	if self.myObject = null then
		self.setCaption(app.getErrorString1(Cargo_Forecast_For,null));
	elseif self.myObject.isKindOf(CM_Voyage) then
		self.setCaption(app.getErrorString1(Cargo_Forecast_For,self.myObject.CM_Voyage.code));
	else 
		self.setCaption(app.getErrorString1(Cargo_Forecast_For,self.myObject.CM_Train.code));
	endif;
	self.initTblCargoForecast(ETDef_CargoForecast);
	self.loadCargoForecastTable();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblCargoForecast_click" id="f19e802d-337c-48e2-b492-5c4d807bad09">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargoForecast_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2022	navtnr20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars

begin
	self.isNewBtnClicked := false;
	self.btnAudits.enabled := true;
	if self.tblCargoForecast.row &gt; 1 then	//20.05.2022 navsrk20 TFS 53142
		self.myTblItem := self.tblCargoForecast.accessRow(self.tblCargoForecast.row).itemObject.CM_Object;
		self.tblCargoForecast.selectMode := Table.SelectMode_CurrentRow;
		if self.myTblItem &lt;&gt; null then
			if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
				self.btnSave.enabled := true;
				self.btnRemove.enabled := true;
			else
				self.btnRemove.enabled := false;
		endif;
		self.displayCargoForecast(self.myTblItem);
	endif;
	else							//20.05.2022 navsrk20 TFS 53142
		self.clearCmbData();		//20.05.2022 navsrk20 TFS 53142
		self.disableCmbControls();	//20.05.2022 navsrk20 TFS 53142
	endif;
epilog

end;</source>
