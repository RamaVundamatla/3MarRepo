<CollClass name="ObjectArray">
    <JadeMethod name="findWSProxyObjectWithOid" id="6e8feaff-1853-4df9-bc91-76291b7f6ae3">
        <source>findWSProxyObjectWithOid(_oid : String) : WS_ProxyObject;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2018	jlger1	Initial creation tfs 37383

*/

vars
	obj : Object;
begin
	if _oid = null then
		return null;
	endif;
	foreach obj in self do
		if obj.isKindOf(WS_ProxyObject) and obj.WS_ProxyObject.cmObjectId =_oid then
			return obj.WS_ProxyObject;
		endif;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_oid" type="String"/>
        <ReturnType type="WS_ProxyObject"/>
    </JadeMethod>
</CollClass>
