    <JadeMethod name="doLogOn" id="4230c19d-929a-440d-8940-e22200f5573f">
        <updating/>
        <source>doLogOn() updating;
/*
	Created on 01 April 2008
	
	by Debby Hutchison
	
	Purpose:

Date		Who		Reason
20 Oct 2011	cnwkpd1	PAR #28510 - Problems logging on in Windows Mobile 6.5 device
	
*/

vars
	errorStr 	: String;
	menuForm	: MOB_MainMenuForm;
	userObj		: CM_User;
	
begin
	if self.myMobileDataAgent.doLogOnMobile(self.txtUserName.text.toUpper(),
											self.txtPassword.getPasswordText(), errorStr) then		// PAR #28510
		userObj	:=	app.getMyUser();
		//  Get Locale here
		app.setLocale(app.getMyUser().getLocale());

		app.setApplicationColors(userObj.colorBackgroundRT, userObj.colorForegroundRT, userObj.colorTableBackRT, userObj.colorTableForeRT);
		create menuForm transient;
		menuForm.show();
		unloadForm;
	else
		self.checkAndShowErrors;
	endif;
end;</source>
    </JadeMethod>
