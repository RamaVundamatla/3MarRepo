/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2024	jlier1	Initial creation 63834

*/

vars

begin
	_types.add(YACriteriaType_TransactionType);

epilog

end;</source>
        <Parameter name="_types" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="581cff59-ffa8-4e49-a8b2-aac7997610a5">
        <source>getDisplay(dataObj: Object): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2024	jlier1	Initial creation 63834

*/

vars

begin
	return dataObj.CM_ResourceType.code; // ### JIRA 12618 29NOV2024 NAVAB1 - this value is used in the extract and load of invoice transaction maps

epilog

end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="56cc13ba-2b76-498f-99d0-8ef043fd6a95">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2024	jlier1	Initial creation

*/

vars
	resourceType : CM_ResourceType;
begin

	foreach resourceType in app.myRoot.allTaskResourceTypes do
		objects[resourceType.getYAIdentifier()] := resourceType;
	endforeach;
epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
