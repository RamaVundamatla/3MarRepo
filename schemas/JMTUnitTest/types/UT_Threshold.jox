	isoType := "2200";
	
	//1 with pretrip task in pretrip task area
	self.addCargo(	"THRS1110101",	//_id : String;
					isoType,	///_isoType: String;
					_mTGrade,	//_mtGrade : CM_MTGrade;
					_operator,	//_operator : CM_Operator;
