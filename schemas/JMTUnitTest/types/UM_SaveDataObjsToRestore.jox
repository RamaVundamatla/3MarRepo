    <JadeMethod name="outputChangedValueDetails" id="b2752d3a-8c71-4b8f-acff-3cc012a1bde5">
        <source>outputChangedValueDetails(_terminal : CM_Terminal);

/*

Purpose:		TESTING ONLY

Date			Who		Reason
11/11/2014		cnwmh5	Initial creation

*/

vars

	str					: String;

begin

	foreach str in self.allStateDataChangedNames do
		self.changedValueDetails(str, _terminal, true);
	endforeach;
	
	self.allStateDataChangedNames.clear();

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="outputStoredData" id="fe2156c8-eb22-488b-a6d6-f2e94b2b2c53">
        <source>outputStoredData();

/*

Purpose:		

Date			Who		Reason
12 December 2014	cnwmh5	Initial creation

*/

vars

	obj								: Object;
	
	iter							: Iterator;
		
	className 						: String;
	methodName						: String;
	terminalOrSystem				: String;
	code							: String;
	testName						: String;

begin

	/////write 'Stored:';
	iter := app.mySaveDataObjsToRestore.allChangedStateDataDict.createIterator;
	while iter.next(obj) do
		app.mySaveDataObjsToRestore.allChangedStateDataDict.getIteratorKeys(className, methodName, testName, code, terminalOrSystem, iter);
		/////write className &amp; Tab &amp; methodName &amp; Tab &amp; testName &amp; Tab &amp; code.String &amp; Tab &amp; terminalOrSystem.String &amp; Tab &amp;
		/////	obj.String &amp; Tab &amp; obj.CM_Terminal.code;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="restoreAllStateData" id="98335f41-7f5c-4a95-8688-fe35c74e7fa0">
        <source>restoreAllStateData(_terminal : CM_Terminal);

/*

Purpose:		Restore the all state data back to it's previous value.
				Have to do this by reading through the current state data
				and going off to the saved data and getting it's value as 
				found if state data doesn't exist when you save the original
				then it doesn't get reset when this method is called.
				Also found that if not set by unit test it doesn't get 
				caught and if doesn't exist in original save it doesn't
				get reset either

Date			Who		Reason
10/12/2014		cnwmh5	Initial creation

*/

vars
	
	terminal						: CM_Terminal;
	stateData						: CM_StateData;
	stateObjectSaved				: CM_StateObject;
	stateDataSaved					: CM_StateData;
	
	stateObjectArray				: CM_StateObjectArray;
	
	startTS							: TimeStamp;
	index							: Integer;
	value							: Any;
	
begin

	///write method.qualifiedName();

	startTS := app.actualTimeServer();
	app.currentMethodBeingRun := "unitTestAfterClass|restoreAllStateData";
	
	terminal := _terminal;
	if terminal = null then
		terminal := app.myRoot.allTerminals["UT"];
	endif;
	
	// restore all the terminal data
	stateObjectArray := terminal.getAllStateData();
	
	beginTransaction;
	foreach index in 1 to stateObjectArray.size step 1 do
		stateObjectSaved := self.allTerminalStateData[index];
		foreach stateData in stateObjectArray[index].allStateData do
			stateDataSaved := stateObjectSaved.allStateData[stateData.key];
			
			// get the value 
			value := self.setNullValue(stateDataSaved);
			if stateDataSaved &lt;&gt; null then
				value := stateDataSaved.getValue();
			endif;
			
			// reset the data
			terminal.setConfig(stateData.key, value);
		endforeach;
	endforeach;
	commitTransaction;
	
	// restore all the system data
	stateObjectArray := app.myRoot.getAllStateData();
	
	beginTransaction;
	foreach index in 1 to stateObjectArray.size step 1 do
		stateObjectSaved := self.allSystemStateData[index];
		foreach stateData in stateObjectArray[index].allStateData do
			stateDataSaved := stateObjectSaved.allStateData[stateData.key];
			
			// get the value 
			value := self.setNullValue(stateDataSaved);
			if stateDataSaved &lt;&gt; null then
				value := stateDataSaved.getValue();
			endif;
			
			// reset the data
			app.myRoot.setConfig(stateData.key, value, true);
		endforeach;
	endforeach;
	commitTransaction;
	
	/////write method.qualifiedName() &amp; Tab &amp; 'elapsed: ' &amp; (app.actualTimeServer.getDifferenceInMinutes(startTS)).String;
	app.currentMethodBeingRun := null;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="restoreSelectedStateData" id="25c0267c-431e-435c-a78b-466eaedcc333">
        <source>restoreSelectedStateData(_code : String; _method, _test : Method; _self : UT_UnitTest; _obj : Any);

/*

Purpose:		Restore the State Data back to it's orginal value

Date			Who		Reason
12/12/2014		cnwmh5	Initial creation

*/

vars

	obj							: Object;
	stateData					: CM_StateData;
	terminal					: CM_Terminal;
	stateObjectSaved			: CM_StateObject;
	stateDataSaved				: CM_StateData;
	
	stateObjectArray			: CM_StateObjectArray;
	
	iter						: Iterator;
	
	className					: String;
	methodName					: String;
	testName					: String;
	code						: String;
	terminalOrSystem			: String;
	afterClass					: Boolean;
	configFound					: Boolean;
	index						: Integer;
	value						: Any;

begin

	if _obj &lt;&gt; null and _obj.isKindOf(CM_Terminal) then
		if app.currentMethodBeingRun = null then
			app.currentMethodBeingRun := "unitTestAfter|restoreSelectedStateData";
		endif;
		stateObjectArray := _obj.CM_Terminal.getAllStateData();
		
		beginTransaction;
		foreach index in 1 to stateObjectArray.size step 1 do
			stateObjectSaved := self.allTerminalStateData[index];
			stateDataSaved := stateObjectSaved.allStateData[_code];
			
			// get the value 
			value := self.setNullValue(stateDataSaved);
			if stateDataSaved &lt;&gt; null then
				value := stateDataSaved.getValue();
				configFound := true;
			endif;
			
			// reset the data
			_obj.CM_Terminal.setConfig(_code, value);
			/*
			if stateDataSaved &lt;&gt; null then
				write "Restored: " &amp; _method.name &amp; Tab &amp; _test.name &amp; Tab &amp; _self.String &amp; Tab &amp; 
					_code &amp; Tab &amp; ' restored to: ' &amp; _obj.CM_Terminal.getConfig(_code).String;
			else
				write "Restored (Not Found): " &amp; _method.name &amp; Tab &amp; _test.name &amp; Tab &amp; _self.String &amp; Tab &amp; 
					_code &amp; Tab &amp; ' restored to: ' &amp; _obj.CM_Terminal.getConfig(_code).String;
			endif;
			*/
			break;
		
		endforeach;
		commitTransaction;
		
		terminalOrSystem := "Terminal";
		if app.currentMethodBeingRun = "unitTestAfter|restoreSelectedStateData" then
			app.currentMethodBeingRun := null;
		endif;
	else

		stateObjectArray := app.myRoot.getAllStateData();
		
		beginTransaction;
		foreach index in 1 to stateObjectArray.size do
			stateObjectSaved := self.allSystemStateData[index];
			stateDataSaved := stateObjectSaved.allStateData[_code];
			
			// get the value
			value := stateDataSaved.getValue();
			if stateDataSaved &lt;&gt; null then
				value := stateDataSaved.getValue();
				configFound := true;
			endif;
			
			// reset the data
			app.myRoot.setConfig(stateData.key, value, true);
			/*
			if stateDataSaved &lt;&gt; null then
				app.writeLog("Restored: " &amp; _method.name &amp; Tab &amp; _test.name &amp; Tab &amp; _self.String &amp; Tab &amp; 
					_code  &amp; Tab &amp; ' restored to: ' &amp; app.myRoot.getConfig(_code).String, LogAlways);
			else
				app.writeLog("Restored (Not Found): " &amp; _method.name &amp; Tab &amp; _test.name &amp; Tab &amp; _self.String &amp; Tab &amp; 
					_code &amp; Tab &amp; ' restored to: ' &amp; _obj.CM_Terminal.getConfig(_code).String, LogAlways);
			endif;
			*/
			break;
			
		endforeach;
		commitTransaction;
		
		terminalOrSystem := "System";
	endif;	
	
	delete iter;
	iter := self.allChangedStateDataDict.createIterator;
	while iter.next(obj) do
		self.allChangedStateDataDict.getIteratorKeys(className, methodName, testName, code, terminalOrSystem, iter);
		if className = _self.getName() and testName = _test.name and code = _code then
			self.allChangedStateDataDict.removeKey(className, methodName, testName, code, terminalOrSystem);
		endif;
	endwhile;
	
epilog

	delete iter;


end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_test" type="Method"/>
        <Parameter name="_self" type="UT_UnitTest"/>
        <Parameter name="_obj" type="Any"/>
    </JadeMethod>
    <JadeMethod name="restoreStateData" id="dfd00d9c-9ed0-43fc-955b-c76bdaaf07c3">
        <source>restoreStateData(_method, _test : Method; _self : UT_UnitTest);

/*

Purpose:		Restore the State Data back to it's orginal value

Date			Who		Reason
12/12/2014		cnwmh5	Initial creation

*/

vars

	obj							: Object;
	terminal					: CM_Terminal;
	stateDataSaved				: CM_StateData;
	
	dict						: DynaDictionary;
	stateObjectArray			: CM_StateObjectArray;
	
	iter						: Iterator;
	
	className					: String;
	methodName					: String;
	testName					: String;
	code						: String;
	terminalOrSystem			: String;
	afterClass					: Boolean;
	configFound					: Boolean;
	index						: Integer;
	value						: Any;
	
begin

	abortTransaction;

	iter := self.allChangedStateDataDict.createIterator;
	while iter.next(obj) do
		self.allChangedStateDataDict.getIteratorKeys(className, methodName, testName, code, terminalOrSystem, iter);
		
		if className &lt;&gt; _self.getName() then
			continue;
		endif;
		
		if _method.name = "unitTestAfter" then
			if methodName = "unitTestBeforeClass" then
				continue;
			endif;
		elseif _method.name = "unitTestAfterClass" then
			afterClass := true;
		else
			continue;
		endif;
		
		self.restoreSelectedStateData(code, _method, _test, _self, obj);

	endwhile;
	
	// empty and after class method then reset all values
	if app.mySaveDataObjsToRestore.allChangedStateDataDict.isEmpty() and  _method.name = "unitTestAfterClass" then
		app.mySaveDataObjsToRestore.restoreAllStateData(terminal);
	endif;
	
epilog

	delete iter;
	delete dict;

end;</source>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_test" type="Method"/>
        <Parameter name="_self" type="UT_UnitTest"/>
    </JadeMethod>
    <JadeMethod name="saveAllStateData" id="eeef3dce-d590-40b7-abdc-fee39a02bce4">
        <updating/>
        <source>saveAllStateData(_terminal : CM_Terminal; _calledFrom : Any; _stateObjectArray : CM_StateObjectArray io) updating;

/*

Purpose:		Save the state data
				if _stateObjectArray passed then local save of the data

Date			Who		Reason
10/12/2014		cnwmh5	Initial creation

*/

vars

	terminal						: CM_Terminal;
	root							: CM_Root;
	stateObject						: CM_StateObject;
	stateObjectTemp					: CM_StateObject;
	stateData						: CM_StateData;
	pxyStateData					: CM_StateData;

	stateObjectArray				: CM_StateObjectArray;
	
	isSystemSave					: Boolean;
	startTS							: TimeStamp;

begin

	/////write method.qualifiedName();

	startTS := app.actualTimeServer();

	terminal := _terminal;
	
	if _calledFrom.isKindOf(JMTUnitTest) or _calledFrom.isKindOf(JUnitForm) or _calledFrom.isKindOf(JadeScript) then
		// save off the system state data
		foreach stateObject in app.myRoot.getAllStateData() do
			create stateObjectTemp transient;
			self.allSystemStateData.add(stateObjectTemp);
			foreach stateData in stateObject.allStateData do
				stateObjectTemp.setStateData(stateData.key, stateData.getValue(), true);
			endforeach;
		endforeach;
		
		// get the terminal
		if terminal = null then
			terminal := app.myRoot.allTerminals["UT"];
		endif;
		
		isSystemSave := true;
	else
		// not stateObjectArray passed so can't do anything
		if _stateObjectArray = null then
			return;
		endif;
	endif;
	
	// terminal null so don't save anything
	if terminal = null then
		return;
	endif;
	
	if isSystemSave then
		foreach stateObject in terminal.getAllStateData() do
			create stateObjectTemp transient;
			self.allTerminalStateData.add(stateObjectTemp);
			foreach stateData in stateObject.allStateData do
				stateObjectTemp.setStateData(stateData.key, stateData.getValue(), true);
			endforeach;
		endforeach;
	else
		foreach stateObject in terminal.getAllStateData() do
			create stateObjectTemp transient;
			_stateObjectArray.add(stateObjectTemp);
			foreach stateData in stateObject.allStateData do
				stateObjectTemp.setStateData(stateData.key, stateData.getValue(), true);
			endforeach;
		endforeach;
	endif;
	
	/////write method.qualifiedName() &amp; Tab &amp; 'elapsed: ' &amp; (app.actualTimeServer.getDifferenceInMinutes(startTS)).String;
	
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_calledFrom" type="Any"/>
        <Parameter name="_stateObjectArray" type="CM_StateObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="saveStateData" id="5260b106-e17a-47ef-a569-095fe2390def">
        <source>saveStateData(_code : String; _method, _test : Method; _self : UT_UnitTest; _terminal : CM_Terminal);

/*

Purpose:		Save the changed state data to the association

Date			Who		Reason
11/12/2014		cnwmh5	Initial creation

*/

vars

	terminal						: CM_Terminal;
	obj								: Object;
	
	iter							: Iterator;
	
	className						: String;
	methodName						: String;
	testName						: String;
	code							: String;
	terminalOrSystem				: String;	
	terminalOrSystemStr				: String;
	savedItemFound					: Boolean;
	
begin

	terminal := _terminal;
	if terminal = null then
		terminal := app.myRoot.allTerminals["UT"];
	endif;	
	
	if _method.name = "setTerminalConfig" then
		terminalOrSystemStr := "Terminal";
	elseif _method.name = "setSystemConfig" then
		terminalOrSystemStr := "System";
	endif;
	
	iter := self.allChangedStateDataDict.createIterator;
	while iter.next(obj) do
		self.allChangedStateDataDict.getIteratorKeys(className, methodName, testName, code, terminalOrSystem, iter);
		if _self.getName() = className and _method.name = methodName and _test.name = testName and _code = code then
			savedItemFound := true;
			break;
		endif;	
	endwhile;
	
	if not savedItemFound then
		///app.writeLog('Save: ' &amp; _self.getName() &amp; Tab &amp; _method.name &amp; Tab &amp; _test.name &amp; Tab &amp; _code &amp; Tab &amp; terminalOrSystemStr &amp; Tab &amp; 
		///	terminal.String &amp; Tab &amp; terminal.code, LogAlways);
		allChangedStateDataDict.putAtKey(_self.getName(), _method.name, _test.name, _code, terminalOrSystemStr, terminal);
	endif;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_test" type="Method"/>
        <Parameter name="_self" type="UT_UnitTest"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setNullValue" id="393d69fc-c63f-41f5-8093-cda1c116ef70">
        <source>setNullValue(_stateData : CM_StateData) : Any;

/*

Purpose:		Set the null value for the respective CM_StateData object

Date			Who		Reason
19/12/2014		cnwmh5	Initial creation

*/

vars

	value 					: Any;

begin


	if _stateData.isKindOf(CM_StateBinary) then
		value := null.Binary;
	elseif _stateData.isKindOf(CM_StateCollection) then
		value := null.Collection;
	elseif _stateData.isKindOf(CM_StateInteger) then
		value := null.Integer;
	elseif _stateData.isKindOf(CM_StateIntegerArray) then
		value := null.IntegerArray;
	elseif _stateData.isKindOf(CM_StateDateArray) then	//19 Jun 2020	NDL	tFS 49569
		value := null.DateArray;
	elseif  _stateData.isKindOf(CM_StateDecimal) or _stateData.isKindOf(CM_StateReal) then
		value := null.Real;
	elseif _stateData.isKindOf(CM_StateReference) then
		value := null.CM_Object;
	elseif _stateData.isKindOf(CM_StateSound) then
		value := null.Sound;
	elseif _stateData.isKindOf(CM_StateStringArray) then
		value := null.StringArray;
	else
		value := null.String;
	endif;
	
	return value;

epilog

end;</source>
        <Parameter name="_stateData" type="CM_StateData"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
