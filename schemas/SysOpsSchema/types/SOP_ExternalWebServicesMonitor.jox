    <JadeMethod name="selectedView" id="1b5ca66f-10de-48be-85e8-74dba3169c5e">
        <source>selectedView() : String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 04 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

