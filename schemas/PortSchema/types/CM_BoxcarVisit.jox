    <JadeMethod name="autoAllocationMatch" id="3a9b6dca-c666-4dea-ac0d-a2f60769f460">
        <source>autoAllocationMatch(_ti: CM_TrackedItem; _noMatchReason: String output; _yaAgent : CM_YAAutoplanAgent input; _cmifAutoPlan: CMIF_YAAutoPlan): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2013	cnwndl1	Initial creation	Par 31278
11 June 2013	NDL rework for Auto planning Par 31692

*/

vars

	boxcarCont : CM_BoxcarWagonController;
	iter : Iterator;
	ti : CM_TrackedItem;
	currentWeight : Decimal [16,4];
	fMove : CM_FutureMove;
	maxTiDimension : Decimal [16,4];
	alloc : CM_RailAllocation;
	weightAdding : Decimal [16,4];

begin

	//pass in null to yaAgent we want to do the logging here in this method
	if not inheritMethod(_ti, _noMatchReason, null, _cmifAutoPlan) then
		return false;
	endif;

	if _ti.isContainer then
		_noMatchReason := app.getErrorString(Boxcar_not_design_take_contai);
		return false;
	endif;
	
	//13 Sep 2013	NDL Par 34279
	weightAdding := _cmifAutoPlan.getWeightForValidation(); // caters for partial move of break bulk item
	
	if weightAdding &gt; 0 then
		
		currentWeight := self.getWagonTareWeight();
		currentWeight := currentWeight + weightAdding;
	
		//boxcarCont := self.allLocationsControllers.first.CM_BoxcarWagonController;
		boxcarCont := self.allLocationsControllersArray[1].CM_BoxcarWagonController;	//04 Dec 2014	NDL	Par 35345
		iter := boxcarCont.allTrackedItems.createIterator; 
		while iter.next( ti ) do
			if not ti.isPlanned(PLANNING_MODE) and not ti.isQueued then
				// this cargo is staying here
				currentWeight := currentWeight + ti.totalWeight;
			endif;
		endwhile;
		delete iter;
		iter := boxcarCont.allQueuedFutureMoves.createIterator; 
		while iter.next( fMove ) do
			ti := fMove.CM_FutureMoveQueued.myTrackedItem;
			if ti &lt;&gt; _ti then
				// this cargo is moving here
				//currentWeight := currentWeight + ti.totalWeight;
				currentWeight := currentWeight + fMove.getWeightForValidation;	//13 Sep 2013	NDL Par 34279
			endif;
		endwhile;
		delete iter;
		iter := boxcarCont.allPlannedFutureMoves.createIterator; 
		while iter.next( fMove ) do
			ti := fMove.CM_FutureMovePlanned.myTrackedItem;
			if ti &lt;&gt; _ti then
				// this cargo is moving here
				//currentWeight := currentWeight + ti.totalWeight;
				currentWeight := currentWeight + fMove.getWeightForValidation;	//13 Sep 2013	NDL Par 34279
			endif;
		endwhile;
		delete iter;
		
		if currentWeight &gt; self.myWagonClass.maxLoadWeight then
			_noMatchReason := app.getErrorString(Maximum_weight_would_exceede);
			return false;
		endif;
		
	endif;
	
	if _ti.totalVolume &gt; 0 then	
		if _ti.totalVolume &gt; self.getMaxVolume() then
			_noMatchReason := app.getErrorString2(Volume_exceeds_volume,_ti.id,self.id);
			return false;
		endif;
		
	endif;
	
	maxTiDimension := _ti.length;
	maxTiDimension := maxTiDimension.max(_ti.getActualHeightRaw);
	maxTiDimension := maxTiDimension.max(_ti.getActualWidthRaw);
	
	if maxTiDimension &gt; self.myWagonClass.getMaxBoxcarInternalDimension then
		_noMatchReason := app.getErrorString2(Maxim_dimen_excee_maxim_inter_,_ti.id,self.id);
		return false;
	endif;
	
	if _yaAgent &lt;&gt; null then
		_yaAgent.addLogEntry(AP_Log_YA_Match,app.getErrorString1(Item_matched_criteria, self.id), false);
	endif;
	
	return true;
	
epilog

	if _yaAgent &lt;&gt; null and _noMatchReason &lt;&gt; null then
		_yaAgent.addLogEntry(AP_Log_YA_No_Match, app.getErrorString2(WagonAutoPlanError, self.id, _noMatchReason), false);
	endif;

	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_noMatchReason" type="String" usage="output"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="7debdc82-76b6-4803-945c-0b3a24dabb61">
        <source>findLocation(_strs: StringArray; _noException: Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

begin

	if _strs.size = 0 then
		_foundLC := self.allLocationsControllersArray.first();
		return;
	endif;
	
	if _strs[1].trimBlanks = "1" or _strs[1].trimBlanks = self.id then
		_foundLC := self.allLocationsControllersArray.first();
		return;
	endif;

epilog

end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getActualWidthAndHeight" id="b2870c86-5a87-4ac4-87c4-28af276a90ea">
        <source>getActualWidthAndHeight(_moveController: CMIF_MoveController; _moveMode: Integer; maxWidth: Decimal output; maxHeight: Decimal output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

begin

	if self.myWagonClass &lt;&gt; null then
		maxWidth := self.myWagonClass.overallWidth;
		if maxWidth = 0 then
			maxWidth := self.myWagonClass.internalWidth;
		endif;
		maxHeight := self.myWagonClass.overallHeight;
		if maxHeight = 0 then
			maxHeight := self.myWagonClass.internalHeight;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="maxWidth" type="Decimal" usage="output"/>
        <Parameter name="maxHeight" type="Decimal" usage="output"/>
    </JadeMethod>
