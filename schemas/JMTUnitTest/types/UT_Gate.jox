    <JadeMethod name="tReceiveMTToTruckWhenInYard" id="5a2b8b03-743c-4ed4-b4de-d6f9116ffbba">
        <source>tReceiveMTToTruckWhenInYard();

/*

Purpose:		 gate In container thru to the yard, then add another MT Receival request to the truck once in the yard

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2011	cnwndl1	Initial creation

*/

vars

	truck: CM_Vehicle;
	ti1: CM_TrackedItem;
	ti2: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	id: String;
	
	gteClass : Class;
	gteEntity : CMGTE_Entity;
	realEntity : CMGTE_Entity;
	realEntities,
	entityArray : CMGTE_EntityArray;
	load : Boolean;
	pxyVVR : CM_VehicleVisitRecord;
	index : Integer;
	
	controller : CMIF_FlexiGateController;
		
begin

	id := "ZZZZ1234561";
	deleteContainer(id);
	deleteVehicle("UTTRUCK");

	vvr := gateInContainer("UTTRUCK", id, "2200", operator.code, "MT", dualGate);
		ti1 := self.getTrackedItem(id);
		assertNotNull(ti1);
		assertNotNull(ti1.getPrimaryLocation(QUEUE_MODE));
		assertEqual(pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);

	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	app.cmsBeginLoad(load);
	pxyVVR := vvr.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	id := "ZZZZ1234562";
	self.deleteContainer(id);
	
	////////////////
	create controller transient;
	create gteEntity as CMGTE_Container transient;
	controller.myTerminal := self.getTerminal();
	controller.jobType := CMGTE_Entity.JobType_EmptyIN;   // MT
	controller.id := id;
	controller.regNo := pxyVVR.regNumber;
	controller.isoTypeCode := "2200";
	controller.operatorCode := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code;
	controller.commodity := "MT";
	controller.weightTotal := 2000;
	controller.carriageTempC := NULL_TEMPERATURE;
	controller.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	controller.setOxygen( NULL_OXYGEN );
	controller.voyageCode := null;
	controller.yardLocationTxt := null;
	controller.imexStatus := TI_IMEX_STATUS_STORAGE;
	controller.destinationPort := null;
	controller.dischargePort := null;
	controller.myBookingRefItem := null;
	controller.myVehicleVisitRecord := pxyVVR;
	gteEntity.setPXYFromController(controller); 
	
	create entityArray transient;
	entityArray.add(gteEntity);
	
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	
	app.myTrxCA.trxCreateInOutFlexiGateEntitys(vvr, entityArray, realEntities,true, app.myPassport);
	assertTrueMsg( app.myPassport.noErrors = true, app.myPassport.getErrorsAsString);
	
	ti2 := self.getTrackedItemByCargoType(id, 1);
	assertNotNull(ti2);
	assertNotNull(ti2.getPrimaryLocation(QUEUE_MODE));
	
	self.workVehicle(vvr);
		assertNotNull(ti1.getPrimaryLocation(REAL_MODE));
		assertTrue(ti1.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
		assertNotNull(ti2.getPrimaryLocation(REAL_MODE));
		assertTrue(ti2.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
		assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	self.moveVehicleToLane(vvr.vehicle, pout, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pout, 1));
		
	self.roadExit(vvr);
		assertNull(vvr.myRoadJob);
		assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
		assertNull(vvr.vehicle.myPrimaryActualLocation);
epilog
	delete entityArray;
	delete gteEntity;
	delete pxyVVR;
	delete controller;
	delete realEntities;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveMTWithAPFailure" id="92dfaefe-10b4-41c0-ba8e-80b7ab25133e">
        <source>tReceiveMTWithAPFailure();
// cnwdap1
// Date: 07 October 2008	
// Author: cnwdw1	
// Description: Receive an MT that failes to autoplan.
