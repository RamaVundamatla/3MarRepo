	endforeach;
		

end;</source>
        <access>protected</access>
        <Parameter name="_realAllocation" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="compareCriteriaToCMIF" id="5cd32149-0467-4d6a-8b61-a355979bde88">
        <source>compareCriteriaToCMIF(_yaAgent : CM_YAAutoplanAgent input; _cmifAutoPlan : CMIF_YAAutoPlan) : Boolean;
// -------------------------------------------
// Created 17 March 2005 by cnwdvb1
// -------------------------------------------
vars
	criteria			: CM_YACriteria;
	str					: String;
	rtnValue			: Boolean;
	tmpCMIF_YAAutoPlan	: CMIF_YAAutoPlan;
	theYAAallocation	: CM_YardAllocation;
	aTempAllocation		: CM_VoyageAllocation;
begin

	rtnValue := true;

	tmpCMIF_YAAutoPlan := _cmifAutoPlan;
	tmpCMIF_YAAutoPlan.setMyTerminal(self.myTerminal);
	
	if tmpCMIF_YAAutoPlan.hasAllocation then //cnwrd1 ccms 1303 14.11.2012
	// self is a yard allocation we are testing
	// against the tmpCMIF_YAAutoPlan.myAllocation
	// we want to make sure a box matching us would be ok for tmpCMIF_YAAutoPlan.mYallocation also (which can be more specific)
	
		theYAAallocation := tmpCMIF_YAAutoPlan.getMyAllocation();
		if theYAAallocation.isKindOf(CM_VoyageAllocation) then
			create aTempAllocation transient;
			aTempAllocation.cloneCriteriaTransient(theYAAallocation);
			aTempAllocation.CM_VoyageAllocation.addVoyageCriteria(theYAAallocation.CM_VoyageAllocation.myVoyage);
			return self.isSameCriteriaSubset(aTempAllocation , _yaAgent , _cmifAutoPlan);
		else
			return self.isSameCriteriaSubset(theYAAallocation , _yaAgent , _cmifAutoPlan);
		endif;
		
	endif;
	
	foreach criteria in self.allCriteria discreteLock do
		if not criteria.isCMIFAutoPlanDataMatch(_cmifAutoPlan) then
			//if self.allowOthersOption = YAOverlap_LastResort then
				if _yaAgent &lt;&gt; null then
					_yaAgent.addLogEntry(AP_Log_YA_No_Match,app.getErrorString1(Item_failed_match_criteri,criteria.getDescription()) , false);
				endif;
				if _cmifAutoPlan.raiseWarning then
					app.raiseCMWarning1(Item_failed_match_criteri, criteria.getDescription(), null, null, criteria);
					rtnValue := false;
					continue;
				endif;
				return false;
			//endif;
		else
			if _yaAgent &lt;&gt; null then
				_yaAgent.addLogEntry(AP_Log_YA_Match,app.getErrorString1(Item_matched_criteria,criteria.getDescription()), false);
			endif;
		endif;
	endforeach;

	return rtnValue;
epilog 
	delete aTempAllocation;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="9665b50b-6115-40b3-8349-b665578ac834">
        <updating/>
        <source>create() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.expiryType	:=	YAExpiryType_Never;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createCriteriaFromXTABProperty" id="4f0e267f-378a-40ea-bb9c-d32788241387">
        <source>createCriteriaFromXTABProperty(_propertyType, _propertyValue : String; _imexStatus : Integer);
// ---------------------------------------------------------------------------
// Created:     18 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 15/01/2015       cnwma1 		    PAR #37387 Hazardous Summarize Cargo On Site
// 01/06/2022 		navsrk20 			ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
// 25Oct2022		navhl20				TFS 53862 EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------

vars
	weightRn : CM_WeightRange;
	criteria : CM_YACriteria;
	port : CM_Port;
	commGrp : CM_CommodityGroup;
	isoGroup : CM_ISOTypeGroup;
	isoType : CM_ISOType;
	cargoTy : CM_CargoType;
	aPortCode : String;
	tmpBoolean : Boolean;
	objSet : ObjectSet;
	imex : CM_IMEXStatus;
	specialSt : CM_SpecialStow;
	prod : CM_Product;
	theRoot : CM_Root;
	shippingLine : CM_ShippingLine;		// 01/06/2022 navsrk20 53195
	damageParty	: CM_DamageParty;	// 25/10/2022 navhl20 TFS 53862
begin
	if _propertyType = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_propertyType', null, null);
		return;
	endif;
	
	theRoot := app.myRoot;

	create objSet transient;

	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ' &amp; _propertyType.String &amp; " " &amp; _propertyValue.String);


	// ### CARGO TYPE
	if _propertyType = CM_BookingRefItem::cargoTypeDescr.name 
	or _propertyType = CM_TrackedItem::cargoType.name then
		// Only create the criteria that is configured
		
		objSet.clear;
		foreach cargoTy in theRoot.allCargoTypesById  discreteLock do
			if cargoTy.description = _propertyValue then
				objSet.add(cargoTy);
			endif;
		endforeach;
		if objSet.isEmpty() then
			return;
		endif;
		criteria := self.createCriteria(objSet, YACriteriaType_CargoType);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		
		return;
	// ### CARGO SUBTYPE
	elseif _propertyType = CM_BookingRefItem::getProductCode.name 
	or _propertyType = CM_TrackedItem::myProduct.name then
		// ### MUST have the cargo type, so see if we have already done that bit
//		In the XML we are not sure of the order of the property types and values. IF the XML includes cargo sub type we must have the cargo type.
//		So if the cargo subtype is in the XML before the cargo sub type then after we have created everything see if we can get the cargo type from the YA.
		criteria := self.getCriteriaOfType(theRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
		if criteria = null then
			return;
		endif;
		if not criteria.myYAData.isKindOf(CM_YADataObjects) then
			return;
		endif;
		cargoTy := criteria.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType;
		if cargoTy = null then
			return;
		endif;

		// Got the cargo type setup the sub cargo type
		prod := cargoTy.getProductFromCode(_propertyValue);
		if prod &lt;&gt; null then
			objSet.clear;
			objSet.add(prod );
			criteria := self.createCriteria(objSet, YACriteriaType_Product);
			if criteria &lt;&gt; null then
				criteria.setYardAllocation(self);
			endif;
		endif;
		
		return;
	// ### DISCHARGE PORT
	elseif _propertyType = CM_BookingRefItem::getDischargePort.name 
	or  _propertyType =  CM_TrackedItem::dischargePort.name
	or _propertyType = CM_BookingRef::getDischargePort.name then
		aPortCode := _propertyValue;
		port := theRoot.allPorts[aPortCode];
		if port &lt;&gt; null then
			objSet.clear;
			objSet.add(port);
			criteria := self.createCriteria(objSet, YACriteriaType_DischargePort);
			if criteria &lt;&gt; null then
				criteria.setYardAllocation(self);
			endif;
		endif;
		return;
	
	// ### ISO GROUP
	elseif _propertyType = CM_BookingRefItem::isoTypeGroup.name 
	or  _propertyType =  CM_BookingRefItem::getISOTypeGroupForISOType.name // PAR 26322
	or  _propertyType =  CM_Container::isoGroup.name then
		isoGroup := theRoot.allISOTypeGroups[_propertyValue];
		if isoGroup = null then
			return;
		endif;
		
		objSet.clear;
		objSet.add(isoGroup);
		criteria := self.createCriteria(objSet, YACriteriaType_ISOGroup);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		return;
	// ### COMMODITY GROUP
	elseif _propertyType = CM_BookingRefItem::getCommodityGroupDesc.name 
	or  _propertyType =  CM_TrackedItem::commodityGroup.name
	or _propertyType = CM_BookingRef::getCommodityGroupDesc.name then
		commGrp := theRoot.allCommodityGroups[_propertyValue];
		if commGrp &lt;&gt; null then
			objSet.clear;
			objSet.add(commGrp);
			criteria := self.createCriteria(objSet, YACriteriaType_CommodityGroup);
			if criteria &lt;&gt; null then
				criteria.setYardAllocation(self);
			endif;
		endif;
		return;
	// ### OVER DIMENSION
	elseif _propertyType = CM_BookingRefItem::getIsOverDimension.name 
	or _propertyType = CM_TrackedItem::isOverDimensions.name
	or _propertyType = CM_BookingRef::getIsOverDimension.name then
		tmpBoolean := (_propertyValue.pos("true", 1) &gt; 0);
		
		if tmpBoolean then
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsOverDimension);
		else
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_FALSE, YACriteriaType_IsOverDimension);
		endif;
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		return;
	// ### HAZARDOUS
	elseif _propertyType = CM_BookingRefItem::getIsHazardous.name 
	or _propertyType = CM_TrackedItem::isHazardous.name
	or _propertyType = CM_BookingRef::getIsHazardous.name 
	or _propertyType = CM_TrackedItem::isHazardousOrLimited.name then  // 15/01/2015 cnwma1 PAR #37387 
		tmpBoolean := (_propertyValue.pos("true", 1) &gt; 0);
		
		if tmpBoolean then
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsHazardous);
		else
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_FALSE, YACriteriaType_IsHazardous);
		endif;
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		return;
	// ### ISO TYPE
	elseif _propertyType = CM_BookingRefItem::isoType.name 
	or  _propertyType =  CM_Container::isoType.name then
	
		isoType := theRoot.allISOTypes[_propertyValue];
		if isoType = null then
			return;
		endif;
		
		objSet.clear;
		objSet.add(isoType);
		criteria := self.createCriteria(objSet, YACriteriaType_ISO);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		return;
	// ### SPECIAL STOW - getSpecialStowDesc
	elseif _propertyType = CM_BookingRefItem::getSpecialStowDesc.name 
	or _propertyType = CM_TrackedItem::specialStow.name
	or _propertyType = CM_BookingRef::getSpecialStowDesc.name then
		foreach specialSt in theRoot.allSpecialStows  discreteLock do
			if specialSt.description = _propertyValue 
			or (_propertyType = CM_TrackedItem::specialStow.name and specialSt.code = _propertyValue) then
				objSet.clear;
				objSet.add(specialSt);
				criteria := self.createCriteria(objSet, YACriteriaType_SpecialStow);
				if criteria &lt;&gt; null then
					criteria.setYardAllocation(self);
				endif;
				break;
			endif;
		endforeach;
		return;
	// ### IS FORTY
	elseif _propertyType = CM_Container::is40.name then
		tmpBoolean := (_propertyValue.pos("true", 1) &gt; 0);
		
		if tmpBoolean then
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsForty);
		else
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_FALSE, YACriteriaType_IsForty);
		endif;
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	// ### IS FORTY FIVE
	elseif _propertyType = CM_Container::is45.name then
		tmpBoolean := (_propertyValue.pos("true", 1) &gt; 0);
		
		if tmpBoolean then
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsFortyFive);
		else
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_FALSE, YACriteriaType_IsFortyFive);
		endif;
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	// ### IS THIRTY
	elseif _propertyType = CM_Container::is30.name then
		tmpBoolean := (_propertyValue.pos("true", 1) &gt; 0);
		
		if tmpBoolean then
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsThirty);
		else
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_FALSE, YACriteriaType_IsThirty);
		endif;
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	// ### IS FIFTY THREE
	elseif _propertyType = CM_Container::is53.name then
		tmpBoolean := (_propertyValue.pos("true", 1) &gt; 0);
		
		if tmpBoolean then
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsFiftyThree);
		else
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_FALSE, YACriteriaType_IsFiftyThree);
		endif;
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	// ### WEIGHT
	elseif _propertyType = CM_BookingRefItem::weight.name 
	or _propertyType = CM_TrackedItem::totalWeight.name then
		if _propertyValue.isDecimal() then
			weightRn := theRoot.getColourFromWeightRange(_propertyValue.Integer);
		endif;
		if weightRn &lt;&gt; null then
			objSet.clear;
			objSet.add(weightRn);
			criteria := self.createCriteria(objSet, YACriteriaType_Weight);
			if criteria &lt;&gt; null then
				criteria.setYardAllocation(self);
			endif;
		endif;
		return;
	// ### BOOKING
	elseif _propertyType =  CM_BookingRefItem::getBookingRefString.name 
	or _propertyType = CM_TrackedItem::bookingReference.name
	or _propertyType =   CM_BookingRef::getBookingRefString.name  then
		if self.myTerminal.allBookingRefsByRef[_propertyValue] = null then
			return;
		endif;
		criteria := self.createCriteria(_propertyValue, YACriteriaType_BookingRef);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		return;
	// ### TRANS SHIP TO PORT
	elseif _propertyType = CM_BookingRefItem::getMyTranshipToPort.name 
	or _propertyType = CM_TrackedItem::getMyTranshipToPort.name 
	or _propertyType = CM_BookingRef::getMyTranshipToPort.name then
		aPortCode := _propertyValue;
		port := theRoot.allPorts[aPortCode];
		if port &lt;&gt; null then
			objSet.clear;
			objSet.add(port);
			criteria := self.createCriteria(objSet, YACriteriaType_TranshipToPort);
			if criteria &lt;&gt; null then
				criteria.setYardAllocation(self);
			endif;
		endif;
		return;
	// ### DESTINATION PORT
	elseif _propertyType = CM_BookingRefItem::getDischargePort.name 
	or _propertyType =CM_TrackedItem::destinationPort.name 
	or _propertyType =CM_BookingRef::getDestinationPort.name then
		aPortCode := _propertyValue;
		port := theRoot.allPorts[aPortCode];
		if port &lt;&gt; null then
			objSet.clear;
			objSet.add(port);
			criteria := self.createCriteria(objSet, YACriteriaType_DestinationPort);
			if criteria &lt;&gt; null then
				criteria.setYardAllocation(self);
			endif;
		endif;
		return;
	// ### HAZARDOUS DETAILS
	elseif _propertyType =CM_TrackedItem::getHazardsAsString.name then // PAR 35325
	
		if _propertyValue = "-" then // Blank
			return;
		endif;

		criteria := self.createCriteria(_propertyValue, YACriteriaType_Hazardous);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		return;
	// IS EMPTY
	elseif  _propertyType = CM_TrackedItem::isEmpty.name then // PAR 35325
		tmpBoolean := (_propertyValue.pos("true", 1) &gt; 0);
		
		if tmpBoolean then
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsEmpty);
		else
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_FALSE, YACriteriaType_IsEmpty);
		endif;
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		return;
	// WATER COOLED  		
	elseif  _propertyType = CM_TrackedItem::getCoolingType.name then // PAR 35325
		tmpBoolean := (_propertyValue.pos(ContainerWaterCooledStr, 1) &gt; 0);
		
		if tmpBoolean then
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_WaterCooled);
		else
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_FALSE, YACriteriaType_WaterCooled);
		endif;
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		return;
	// REQUIRES POWER
	elseif  _propertyType = CM_TrackedItem::requiresPower.name then // PAR 35325
		tmpBoolean := (_propertyValue.pos("true", 1) &gt; 0);
		
		if tmpBoolean then
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_RequiresPower);
		else
			criteria := self.createCriteria(CM_YADataBoolean.VALUE_FALSE, YACriteriaType_RequiresPower);
		endif;
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		return;
	//Start 01/06/2022 navsrk20 53195
	// ### Shipping Line - getShippingLine					
	elseif  _propertyType = CM_TrackedItem::getShippingLineCode.name then
		foreach shippingLine in theRoot.allShippingLines  discreteLock do
			if shippingLine.code = _propertyValue  then
				objSet.clear;
				objSet.add(shippingLine);
				criteria := self.createCriteria(objSet, YACriteriaType_ShippingLine);
				if criteria &lt;&gt; null then
					criteria.setYardAllocation(self);
				endif;
				break;
			endif;
		endforeach;
		return;
	//End 01/06/2022 navsrk20 53195
	endif;
	
	// TRANSHIP DISCHARGE PORT is not possible in a SUMMARY
	// WEIGHT FLEXI 
	// IS TWENTY is not possible in a SUMMARY
	

epilog
	delete objSet;

end;</source>
        <Parameter name="_propertyType" type="String"/>
        <Parameter name="_propertyValue" type="String"/>
        <Parameter name="_imexStatus" type="Integer"/>
    </JadeMethod>
