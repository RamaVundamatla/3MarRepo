    <JadeMethod name="removeFromAlerts" id="762713c8-2067-4d56-a194-00d51f1bf0e8">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::removeFromAlerts"/>
        </interfaceImplements>
        <source>removeFromAlerts(_alert : CM_SystemAlert);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 November 2011	cnwndl1	Initial creation

*/

vars
	
begin

	if not self.alerts.includes(_alert) then
		return;
	endif;
	alerts.remove(_alert);

	if self.myTerminal &lt;&gt; null and _alert.mySystemAlertType &lt;&gt; null and not _alert.reviewed then
		self.myTerminal.causeEvent( _alert.mySystemAlertType.type, false, _alert );
	endif;
	
epilog

end;</source>
        <Parameter name="_alert" type="CM_SystemAlert"/>
    </JadeMethod>
