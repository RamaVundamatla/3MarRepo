    <JadeMethod name="qlbClassData_click" id="8d2cb2e8-364c-419c-9dac-2cfddf66911b">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>qlbClassData_click(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	schemaObjectEntity : DEV_SchemaObjectEntity;
	
begin
	if listbox.text = null then
		return;
	endif;
	
	schemaObjectEntity := listbox.itemObject[listbox.listIndex].DEV_SchemaObjectEntity;
	
	if schemaObjectEntity = null then
		return;
		
	endif;
	
	if schemaObjectEntity.resolvedBy &lt;&gt; null then
		self.slStatus.caption := "Source Comparison: Item - Resolved by: " &amp; schemaObjectEntity.resolvedBy &amp; "@" &amp; schemaObjectEntity.resolvedAt.String;
		listbox.setFocus();
	endif;
	
	self.compareClassDetail(listbox, schemaObjectEntity);
	listbox.setFocus();
	
	self.btnOpenInWinMerge.enabled := false;
	self.btnOpenInNpp.enabled := false;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="qlbClassData_contextMenu" id="9b500763-9479-4ac0-b574-6952c2a8a33c">
