<Application name="JMTITSWorker" id="eb8fb73b-1e3c-4eb0-bee6-3196e2aafdf5">
    <applicationType>S</applicationType>
    <controlSpacing>4</controlSpacing>
    <finalizeMethod name="MobileServerSchema::finITSApplication"/>
    <fontName>MS Sans Serif</fontName>
    <fontSize>8.25</fontSize>
    <formMargin>7</formMargin>
