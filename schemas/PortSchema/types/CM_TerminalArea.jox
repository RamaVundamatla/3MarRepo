    <JadeMethod name="hasAccessLeft" id="447056c5-057c-4832-a95e-3f15a11f2596">
        <source>hasAccessLeft() : Boolean;
// ---------------------------------------------------------------------------
// Created:		19 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
