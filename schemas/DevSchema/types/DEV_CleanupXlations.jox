    <JadeMethod name="doChangeSourceCode" id="487f7b3c-1395-4211-ba6a-e7c5352d2f01">
        <updating/>
        <source>doChangeSourceCode() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2017	cnwns1	Initial creation

*/


constants
	CONSTANTS 	= "constants" &amp; CrLf;
	VARS 		= "vars";

vars

	
	constOb 		: Constant; 
	meth			: Method;	
	constantCategory : ConstantCategory;
	portSchema 		: Schema;
	meths 			: MethodSet;
	xmlDoc			: JadeXMLDocument;
	xmlElement		: JadeXMLElement;
	textElement		: JadeXMLElement;
	xmlAttribute	: JadeXMLAttribute;
	transMeth 		: Method;
	codeSchema 		: Schema;
	codeClass 		: Class;
	source			: String;
	newName 		: String;
	oldName 		: String;
	text 			: String;
	formClass 		: String;
	formSchema 		: String;
	lMyLsSchema 	: LSschema;
  	lmyLsClass 		: LSclass;
	lMyLsMethodSource : LSmethodSource;
	lMyLsMethod 	: LSmethod;
	today			: TimeStamp;
	commentString 	: String;
	progress 		: Integer;
	totalCount 		: Integer;
	dowrite 		: Boolean;
	methsToDo 		: Integer;
	foundIt 		: Boolean;
	codeMeth 		: Method;
	problems 		: HugeStringArray;
	folderServer	: FileFolder;
begin
	
	app.writeLog(method.name,1);
	write method.name;
	
	dowrite := false;
		
	create problems transient;
		
	portSchema:=rootSchema.getSchema(PortSchemaName);
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);
			
	today := app.actualTimeServer;
	
	commentString := Tab &amp; "//" &amp; today.date.shortFormat()&amp; Tab &amp; "jlgns1" &amp; Tab &amp; "TFS 3827 XLAT_FormCaptions need to be sorted out" &amp; CrLf;
		
	getSpecialMethods();
	
	totalCount := constantCategory.cnEcGetConstants().size;
	
	foreach constOb in constantCategory.cnEcGetConstants() do
	
		oldName := constOb.name;		
		progress := progress + 1;	
			
		newName := self.myAgent.makeConstantNameString(constOb.getSource.Integer);		
			
		if progress mod 10 = 0 then
			self.caption := (progress / totalCount * 100).Real.roundedTo(1).String &amp; "% " &amp; progress.String &amp; " of " &amp; totalCount.String &amp; " " &amp; oldName &amp; " " &amp; newName ;
			app.doWindowEvents(0);
		endif;
				
		if oldName = newName then
			continue;
		endif;
				
		delete meths;
		create meths transient;
		
		constOb.getMethodRefs(meths);
			
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(constOb.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
				
			// Get the text
		textElement := xmlElement.findElement(XMLTag_Msg, null);
		if textElement &lt;&gt; null then
			text := textElement.text;
		endif;
		
				// get the form class
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
		if xmlAttribute &lt;&gt; null then
			formClass := xmlAttribute.value;
		endif;
		// get the form Schema
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_SchemaName);
		if xmlAttribute &lt;&gt; null then
			formSchema := xmlAttribute.value;
		endif;
		
		codeSchema := rootSchema.getSchema(formSchema);
		if codeSchema = null then 
			write "codeSchema is null"; 
		else			
			codeClass := codeSchema.getClass(formClass);
			if codeClass = null then

			else
				transMeth := codeClass.getMethod("translateForm");			
				if transMeth &lt;&gt; null  then
					lmyLsClass := getLSFromClass(codeClass,self.allLsSchemas);
					lMyLsMethodSource := getLsMethod(transMeth,lmyLsClass,false);
					xScanSource(lMyLsMethodSource, oldName, newName,false);	
					if meths.includes(transMeth) then
						meths.remove(transMeth);
					endif;
				endif;
			endif;
		endif;	

		if meths.size &gt; 0 then			
			foreach meth in meths do
				foundIt := false;
				if codeClass &lt;&gt; null then
					lmyLsClass := getLSFromClass(codeClass,self.allLsSchemas);
					foreach lMyLsMethod in lmyLsClass.allMethods do
						if lMyLsMethod.myMethod = meth then
							lMyLsMethodSource := lMyLsMethod.LSmethodSource;
							xScanSource(lMyLsMethodSource, oldName, newName,false);
							foundIt := true;
						endif;
					endforeach;
				endif;
					
				if not foundIt then
					if codeClass &lt;&gt; null then
						codeMeth := codeClass.getMethod(meth.name);	
					else
						codeMeth := null;
					endif;
					
					if codeMeth &lt;&gt; null and codeClass &lt;&gt; null then
						lmyLsClass := getLSFromClass(codeClass,self.allLsSchemas);
						lMyLsMethodSource := getLsMethod(codeMeth,lmyLsClass,false);
						if xScanSource(lMyLsMethodSource, oldName, newName,false) then
							foundIt := true;
							continue;
						endif;
							
					elseif codeSchema &lt;&gt; null then
						foreach codeClass in codeSchema.allClasses do
							if not foundIt then
								codeMeth := codeClass.getMethod(meth.name);	
								if codeMeth &lt;&gt; null then
									lmyLsClass := getLSFromClass(codeClass,self.allLsSchemas);
									lMyLsMethodSource := getLsMethod(codeMeth,lmyLsClass,false);
									if	xScanSource(lMyLsMethodSource, oldName, newName,false) then
										foundIt := true;
										continue;
									endif;
								endif;
							endif;
						endforeach;
					
					endif;
				endif;
			endforeach;	
		endif;
					 
		
		foreach meth in meths do	
			foundIt := false;
			foreach lMyLsSchema in self.allLsSchemas do
				foreach lmyLsClass in lMyLsSchema.allClasses do
					foreach lMyLsMethod in lmyLsClass.allMethods do
						if lMyLsMethod .myMethod = meth then
							foundIt := true;
						endif;
					endforeach;
				endforeach;
			endforeach;	
			if not foundIt then
				problems.add(oldName &amp; Tab &amp; meth.name &amp; Tab &amp; meth.getOidAsString);
				methsToDo := methsToDo + 1;
			endif;			
		endforeach;		
		foreach lMyLsSchema in self.allLsSchemas do
			foreach lmyLsClass in lMyLsSchema.allClasses do
				foreach lMyLsMethod in lmyLsClass.allMethods do
					lMyLsMethodSource := lMyLsMethod.LSmethodSource;
					if lMyLsMethodSource.isSpecial then
						xScanSource(lMyLsMethodSource, oldName, newName,false);	
					endif;
				endforeach;
			endforeach;	
		endforeach;			
	endforeach;
		
	foreach lMyLsSchema in self.allLsSchemas do
		foreach lmyLsClass in lMyLsSchema.allClasses do
			foreach lMyLsMethod in lmyLsClass.allMethods do
				lMyLsMethodSource := lMyLsMethod.LSmethodSource;
				if lMyLsMethodSource.sourceHasChanged then
					source := lMyLsMethodSource.source;
					if not source.cnContains(commentString) then
						if self.xStringContains(source,CONSTANTS) then
							lMyLsMethodSource.setSource(source.replace(CONSTANTS,commentString  &amp; CONSTANTS ));
						else
							lMyLsMethodSource.setSource(source.replace(VARS ,commentString &amp; VARS ));
						endif;
					endif;
				endif;
			endforeach;
		endforeach;	
	endforeach;	
	
	if methsToDo &gt; 0 then
		write "methsToDo " &amp; methsToDo.String;
	//	problems.inspectModal;
	//	return;////////////////////////////
	endif;
	
	
	folderServer := self.zFileCreateFolder(Path_SourceCodeChanges,false);
	//Create scm for all those methods....
		
	self.zFileCreateMethodExtract(folderServer,self.allLsSchemas);
	
	write "done";
	app.writeLog(method.name &amp; "_End",1);
	write method.name &amp; "_End";
	
epilog
	delete problems;
	delete xmlDoc;
	delete meths;
//	delete releaseMeths;
//	delete classColl;

end;
</source>
    </JadeMethod>
    <JadeMethod name="doChangeXlatObjects" id="e81bc384-52a2-4177-b103-0504002fc257">
        <updating/>
        <source>doChangeXlatObjects(_cleanup : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2017	cnwns1	Initial creation

*/

constants
	XLAT = "Xlat_";
vars
	xLat 			:	XLAT_TranslatableText;
	newGlobalConst 	: GlobalConstant;
	const	 		: Constant;
	portSchema 		: Schema;
	constantCategory : ConstantCategory;
	constDict 		: ConstantNDict;
	totalCount 		: Integer;
	progress 		: Integer;
	index 			: Integer;
	allXlats 		: ObjectArray;
	invCount 		: Integer;
	xlatDict 		: DynaDictionary;
	formCaption 	: XLAT_FormCaption;
	xlatCategory 	: XLAT_Category;
	agent 			: CM_TranslationAgent;
	newName 		: String;
begin
//app.initialize;

	app.writeLog(method.name,1);
	write method.name;

	portSchema:=rootSchema.getSchema("PortSchema");
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);

	xlatCategory := app.myRoot.allXLAT_Categories[XLAT_FormCaptions];
	
	create constDict transient;
	
	constantCategory.cnEcGetConstants.copy(constDict);
	
	write constDict.size;
	
	create allXlats transient;
	
	XLAT_FormCaption.instances.copy(allXlats);
		
	totalCount := allXlats.size;
	
	foreach index in allXlats.size to 1 step -1 do	
		xLat := allXlats[index].XLAT_FormCaption;	
			
		progress := progress + 1;	
		
		
		
		if progress mod 10 = 0 then
			self.caption := (progress / totalCount * 100).Real.roundedTo(1).String &amp; "% " &amp; progress.String &amp; " of " &amp; totalCount.String &amp; " " &amp; xLat.number.String;
			app.doWindowEvents(0);
		endif;
				
		if not app.isValidObject(xLat.myGlobalConstant) then
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; "Xlat Obj " &amp; xLat.number.String &amp; Tab &amp; "Invalid Constant" , LogINFO);
			if _cleanup then
				beginTransaction;
					delete xLat;
				commitTransaction;
			endif;
			invCount := invCount + 1;		
			continue;
		endif;
	
		//This does not happen
		if 	xLat.myGlobalConstant = null then
		//	write "Existing is Null";
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; "Xlat Obj " &amp; xLat.number.String &amp; Tab &amp; "Null Constant" , LogINFO);
			if _cleanup then
				beginTransaction;
					delete xLat;
				commitTransaction;
			endif;
			continue;
		endif;
		
		if xLat.myGlobalConstant.name.cnContains(XLAT) then 
			if self.allConstantsToDelete.includes(xLat.myGlobalConstant) then
				app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; "Xlat Obj " &amp; xLat.number.String &amp; Tab &amp; "xlat in Delete List 'allConstantsToDelete'" , LogINFO);
				if _cleanup then
					beginTransaction;
						delete xLat;
					commitTransaction;
				endif;
			endif;
			
			continue;
		endif;		
			
		newName := self.myAgent.makeConstantNameString(xLat.myGlobalConstant.getSource.Integer);
						
		newGlobalConst := constDict[newName].GlobalConstant;  
		
		if newGlobalConst = null then 
			if self.allConstantsToDelete.includes(xLat.myGlobalConstant) then
				app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; "Xlat Obj " &amp; xLat.number.String &amp; Tab &amp; "New Global Constant is null" , LogINFO);
				if _cleanup then
					beginTransaction;
						delete xLat;
					commitTransaction;
				endif;
			else
		
			//	write "new Const is null " &amp; newName;
				continue;
			endif;
		endif;	
		
		if self.allConstantsToDelete.includes(newGlobalConst) then
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; "Xlat Obj " &amp; xLat.number.String &amp; Tab &amp; "xlat in Delete List 'allConstantsToDelete'" , LogINFO);
			if _cleanup then
				beginTransaction;
					delete xLat;
				commitTransaction;
			endif;	
			continue;
		endif;		
		
		if	xLat = null then		
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; "Xlat Obj  is null " , LogINFO);
			if _cleanup then
				beginTransaction;
					delete xLat;
				commitTransaction;
			endif;
		//	write "xLat null";
			continue;
		endif;
		
		if	xLat.myCategory = null then		
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; "Xlat Obj " &amp; xLat.number.String &amp; Tab &amp; "category is null " , LogINFO);
			if _cleanup then
				beginTransaction;
					delete xLat;
				commitTransaction;
			endif;
		//	write "category null";
			continue;
		endif;
		
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; "Redirecting Xlat Obj " &amp; xLat.number.String &amp; Tab &amp; 
				"from " &amp; xLat.myGlobalConstant.name &amp; Tab &amp;  "to " &amp; newGlobalConst.name , LogINFO);
			if _cleanup then
				beginTransaction;	
					xLat.initialise(xLat.myCategory,newGlobalConst,xLat.myConstantCategoryName,null,null);
				//	write "changed";
				commitTransaction;
			endif;
		
	endforeach;
	
	create xlatDict transient;
	xlatDict.setMembership(XLAT_FormCaption);
	xlatDict.addExternalKey(String,64,true, false);
	xlatDict.endKeys(true);
	
	foreach formCaption in  XLAT_FormCaption.instances discreteLock do
		xlatDict.putAtKey(formCaption.vConstantName,formCaption);
	endforeach;
	
	
	create agent transient;
	
	foreach const in constDict do
		if const.name.cnContains(XLAT) and not self.allConstantsToDelete.includes(const) then
			newGlobalConst := const.GlobalConstant;
			formCaption := xlatDict.getAtKey(newGlobalConst.name).XLAT_FormCaption;
			if formCaption = null then
				app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; "Creating Xlat Obj " &amp; newGlobalConst.name , LogINFO);
				if _cleanup then
					beginTransaction;
						formCaption := agent.subTrxLoadFromGlobalConstant(xlatCategory,newGlobalConst).XLAT_FormCaption;
					commitTransaction;
				endif;	
			endif;
		endif;
	endforeach;
	
	write allXlats.size;
	app.writeLog(method.name &amp; "_End",1);
	write method.name &amp; "_End";
	
epilog
	delete agent;
	delete xlatDict;
	delete allXlats;
	delete constDict;
end;</source>
        <Parameter name="_cleanup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCloneConstants" id="6ba012e4-959c-4749-9c57-260ba89a7e82">
        <updating/>
        <source>doCloneConstants() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2017	cnwns1	Initial creation

*/
constants
	XLAT = "Xlat_";
	TranslateFormName = "translateForm";
vars
	portSchema 		: Schema;
	constantCategory: ConstantCategory;
	constantObj  	: Constant;
	newConstantObj  : Constant;
	lsConstant 		: LSconstant;
	newName 		: String;
	oldName 		: String;
	schemaName		: String;
	controlName		: String;
	constantName 	: String;
	constantNumber	: Integer;
	formClass		: String;
	text			: String;
	controlProperty	: String;
	xmlDoc			: JadeXMLDocument;
	xmlElement		: JadeXMLElement;
	textElement		: JadeXMLElement;
	xmlAttribute	: JadeXMLAttribute;
//	constantArr 	: ObjectArray;
	lsSchema		: LSschema;
	
	
	lMyLsSchema : LSschema;
	lMyLsClass : LSclass;
	constCount : Integer;
	forceCreateArr : StringArray; 
	remapArr : StringArray; 
	progress : Integer;
	totalCount : Integer;
	
	
	fileFolder		: FileFolder;
begin

	app.writeLog(method.name,1);
	write method.name;


	create forceCreateArr transient;

	forceCreateArr.add("Xlat_0021299");
	forceCreateArr.add("Xlat_0020711");
	forceCreateArr.add("Xlat_0017611");
	forceCreateArr.add("Xlat_0008354");
	forceCreateArr.add("Xlat_0009090");
	forceCreateArr.add("Xlat_0008336");
	forceCreateArr.add("Xlat_0015554");
	forceCreateArr.add("Xlat_0015555");
	forceCreateArr.add("Xlat_0015557");
	forceCreateArr.add("Xlat_0015558");
	forceCreateArr.add("Xlat_0015559");
	forceCreateArr.add("Xlat_0015560");
	forceCreateArr.add("Xlat_0018599");
	forceCreateArr.add("Xlat_0008776");
	forceCreateArr.add("Xlat_0020668");
	forceCreateArr.add("Xlat_0020761");	
	forceCreateArr.add("Xlat_0004109");	
	forceCreateArr.add("Xlat_0004081");	
	forceCreateArr.add("Xlat_0004082");	
	forceCreateArr.add("Xlat_0004077");	
	forceCreateArr.add("Xlat_0000292");	
	forceCreateArr.add("Xlat_0000294");	
	forceCreateArr.add("Xlat_0000295");	
	forceCreateArr.add("Xlat_0013603");
	forceCreateArr.add("Xlat_0020950");
	forceCreateArr.add("Xlat_0020928");
	forceCreateArr.add("Xlat_0020929");
	forceCreateArr.add("Xlat_0020936");
	forceCreateArr.add("Xlat_0018027");
	forceCreateArr.add("Xlat_0020968");
	forceCreateArr.add("Xlat_0009621");
	forceCreateArr.add("Xlat_0017652");
	
	
	forceCreateArr.add("Xlat_0021689");
	
	create remapArr transient;
	
	remapArr.add("MOB_HHBre_CMOB_HHBreakBulkDisc");
	remapArr.add("MOB_HHBrea_CMOB_HHBreakBulkMer");
	remapArr.add("MOB_HHBrea_CMOB_HHBreakBulkSpl");
	remapArr.add("MOB_HandH_CMOB_HandHeldReeferE");
	remapArr.add("MOB_HandH_CMOB_HandHeldCargoEn");
		

	portSchema:=rootSchema.getSchema("PortSchema");
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);
	
   // getMethodSource();
	
	create self.allLsSchemas transient;
		 
	lsSchema := getLsSchema(portSchema,self.allLsSchemas);
	
	lMyLsClass := getLsClass(portSchema.getClass(JadeScript.name),lsSchema);	
		
		
//	create lsConstant transient;
	totalCount := constantCategory.cnEcGetConstants().size;
	
	foreach constantObj in constantCategory.cnEcGetConstants() do	
		
		if self.allConstantsToDelete.includes(constantObj) then
			continue;
		endif;
		
		oldName := constantObj.name;
		
		newName := self.myAgent.makeConstantNameString(constantObj.getSource.Integer);		
				
			progress := progress + 1;	
	
		if progress mod 10 = 0 then
			self.caption := (progress / totalCount * 100).Real.roundedTo(1).String &amp; "% " &amp; progress.String &amp; " of " &amp; totalCount.String &amp; " " &amp; oldName &amp; " " &amp; newName ;
			app.doWindowEvents(0);
		endif;
		
		if oldName = newName then
			continue;
		endif;
		
		newConstantObj := portSchema.getGlobalConstant(newName);
		if newConstantObj &lt;&gt; null then
			continue;
		endif;
				
		schemaName := null;
		formClass  := null;
		controlName:= null;
		controlProperty := null;
		constantNumber := null;
		text := null;
	
		constantName := newName;
		// no xml then error as should have xml
		if constantObj.text = null then
			app.writeStatement("*** Error - No XML Text (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ")");
		//	write "*** Error - No XML Text (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ")";
			continue;
		endif;
		
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(constantObj.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
		
		
		// Get the controlName
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_SchemaName);
		if xmlAttribute &lt;&gt; null then
			schemaName := xmlAttribute.value;
			
		else
			continue;
		endif;
		// get the form class
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
		if xmlAttribute &lt;&gt; null then
			formClass := xmlAttribute.value;
			
		else
			continue;
		endif;
		
		if remapArr.includes(oldName) then
			if oldName 	   = "MOB_HHBre_CMOB_HHBreakBulkDisc" then
				formClass := "MOB_HHCargoDiscrepancy";
			elseif oldName = "MOB_HHBrea_CMOB_HHBreakBulkMer" then
				formClass := "MOB_HHCargoMerge";
			elseif oldName = "MOB_HHBrea_CMOB_HHBreakBulkSpl" then
				formClass := "MOB_HHCargoSplit";
			elseif oldName = "MOB_HandH_CMOB_HandHeldReeferE" then
				formClass := "MOB_HHReeferEnquiryForm";
			elseif oldName = "MOB_HandH_CMOB_HandHeldCargoEn" then
				formClass := "MOB_HHCargoEnquiryForm";	
			endif;	
		endif;
		
		
		// Get the text
		textElement := xmlElement.findElement(XMLTag_Msg, null);
		if textElement &lt;&gt; null then
			text := textElement.text;
		else
			continue;
		endif;
				
		// Get the controlName
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlName);
		if xmlAttribute &lt;&gt; null then
			controlName := xmlAttribute.value;
		endif;
		
		// Get the controlName
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlProperty);
		if xmlAttribute &lt;&gt; null then
			controlProperty := xmlAttribute.value;
		endif;
	
		constantNumber := constantObj.getSource().Integer;
		
		if schemaName &lt;&gt; null and formClass &lt;&gt; null and controlName &lt;&gt; null and controlProperty &lt;&gt; null 
		and constantObj.name &lt;&gt; null and constantNumber &lt;&gt; null and text &lt;&gt; null or forceCreateArr.includes(newName) then
	
			create lsConstant transient;
			lsConstant.schemaName 	:= schemaName;
			lsConstant.formName 	:= formClass;
			lsConstant.controlName 	:= controlName;
			lsConstant.controlProperty := controlProperty;
			lsConstant.name 		:=  newName;
			lsConstant.number 		:= constantNumber;
			lsConstant.text 		:= text;	
			
			
			if not lMyLsClass.allConstants.includesKey(schemaName, formClass, controlName, controlProperty) then
				lMyLsClass.allConstants.add(lsConstant);
			elseif forceCreateArr.includes(newName) then
				lMyLsClass.allConstants.add(lsConstant);
			endif;
			
			constCount := constCount + 1;
		endif;
	
	endforeach;
				
		if constCount = 0 then
			return;
		endif;
				
	
		fileFolder := zFileCreateFolder(Path_NewConstants,false);
		
		
	foreach lsSchema in self.allLsSchemas do
		if lsSchema.name = PortSchemaName then
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; lsSchema.name &amp; Tab &amp; lsSchema.allConstants.size.String &amp; Tab &amp; Tab &amp; 
			self.allLsSchemas.size.String , LogINFO);
		
			 
			zFileMakeScm_FormXlatGC(fileFolder ,  lsSchema);
		endif;
	endforeach;	
			
	write "clone scms created";
	app.writeLog(method.name &amp; "_End",1);
	write method.name &amp; "_End";
			
epilog
//	delete lMySchmas;
	delete lMyLsSchema;
	delete forceCreateArr;
	delete remapArr;
	//delete lMyLsClass;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateJCFToDeleteConstants" id="f462126a-a084-4634-bf4b-a4d6cd609844">
        <source>doCreateJCFToDeleteConstants();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2017	cnwns1	Initial creation

*/

vars
	fileDetailsDelete: File;
	jcfFile			 : File;
	globalConstant 	 : GlobalConstant;
	glCoObject 		 : Object;
	fileFolder 		 : FileFolder;
begin
	app.writeLog(method.name,1);
	write method.name;


	if self.allConstantsToDelete = null or self.allConstantsToDelete.size = 0 then
		return;
	endif;
	
	fileFolder := zFileCreateFolder(Path_Delete_Constants,false);
	
	create fileDetailsDelete transient;
	fileDetailsDelete.mode := File.Mode_Append;
	//fileDetailsDelete.fileName := "c:\temp\XLATFormToDelete.csv";
	fileDetailsDelete.fileName := fileFolder.fileName &amp;  "\XLATOrphansToDelete.csv";
	fileDetailsDelete.usePresentationFileSystem := fileFolder.usePresentationFileSystem;
	if fileDetailsDelete.isAvailable() then
		fileDetailsDelete.purge();
	endif;
	fileDetailsDelete.writeLine("Oid,Date,Time,Number,Name");
	
	
	create jcfFile transient;
	jcfFile.mode := File.Mode_Append;
	//fileDetailsDelete.fileName := "c:\temp\XLATFormToDelete.csv";
	jcfFile.fileName := fileFolder.fileName &amp; "\XLATOrphansToDelete.jcf";
	jcfFile.usePresentationFileSystem := false;
	if jcfFile.isAvailable() then
		jcfFile.purge();
	endif;
	jcfFile.writeLine('JadeCommandFile');
	jcfFile.writeLine('JadeVersionNumber 7.0.11');
	jcfFile.writeLine('Commands');
	jcfFile.writeLine('AbortOnError True');
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp;  "allConstantsToDelete Size: "	&amp; allConstantsToDelete.size.String	, LogINFO);	
	
	foreach glCoObject  in self.allConstantsToDelete do
		globalConstant := glCoObject.GlobalConstant;
		//const := obj.Constant;
		fileDetailsDelete.writeLine(globalConstant.getOidAsString &amp; ","&amp; globalConstant.cnEcGetModifyTimeStamp.Date.String &amp; "," &amp;globalConstant.cnEcGetModifyTimeStamp.Time.String &amp; "," &amp; globalConstant.getSource &amp; "," &amp; globalConstant.name);
		app.writeLog( Tab &amp;  "Delete GlobalConstant PortSchema::" &amp; globalConstant.name	, LogINFO);	
		
		jcfFile.writeLine ("Delete GlobalConstant PortSchema::" &amp; globalConstant.name);
	endforeach;
	
	self.allConstantsToDelete.clear;
	app.writeLog(method.name &amp; "_End",1);
	write method.name &amp; "_End";
	
epilog
delete jcfFile;
	delete fileDetailsDelete;
end;</source>
    </JadeMethod>
    <JadeMethod name="doExtractCSVforConstants" id="8c379e83-5bac-49f0-bb3f-3d40893396f1">
        <updating/>
        <source>doExtractCSVforConstants() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2017	cnwns1	Initial creation

*/

vars

	
	fileConstantDetails	: File;
	fileMethodDetails	: File;
	//folderServer		: FileFolder;
	today				: TimeStamp;
	//systemName 			: String;
	specialArray 		: IntegerArray;
	constantArray 		: HugeStringArray;
	methodArray 		: HugeStringArray;
	line 				: String;
	folderNonServer						: FileFolder;
	
	
begin

	app.writeLog(method.name,1);
	write method.name;

	today := app.actualTimeServer;

	create constantArray transient;
	create methodArray transient;
	
	xGetConstantsIntoArray(constantArray,methodArray);
		
	
	if constantArray.size + methodArray.size &gt; 0 then
	
		// Create the folder (NON Server) for the constants to retrieve
	//	today := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	//	create folderNonServer transient;
	//	folderNonServer.fileName := "c:\temp" &amp; Path_CSV_extract  &amp; app.computerName &amp; "\Transfer" &amp;
	///		today.date.year.String &amp; today.date.month.padLeadingWith("0", 2) &amp; today.date.day.padLeadingWith("0", 2);
	///	folderNonServer.usePresentationFileSystem := true;
	//	if not folderNonServer.isAvailable then
	//		folderNonServer.make();
	//	endif;
	
	
		folderNonServer := zFileCreateFolder(Path_CSV_extract,true);
				
	//	systemName := app.cnGetServerMiscPath;
	//	systemName := systemName[2:End].replace(":\","").replace("\server\c_misc","");
			
		if constantArray.size &gt; 0 then
		
			create fileConstantDetails transient;	
			fileConstantDetails.usePresentationFileSystem := folderNonServer.usePresentationFileSystem;
			fileConstantDetails.openOutput(folderNonServer.fileName &amp; "\tmp_constantsExtract" &amp; systemName &amp; ".csv" );
		//	fileConstantDetails.usePresentationFileSystem := folderServer.usePresentationFileSystem;
		//	fileConstantDetails.openOutput(folderServer.fileName &amp; "\constantsExtract" &amp; systemName &amp; ".csv" );
		//	fileConstantDetails.writeLine("Schema,Class,Control,Property,Name,Number,Caption,Combined");
				
			foreach line in constantArray do
				fileConstantDetails.writeLine(line);
			endforeach;
					
			fileConstantDetails.close();
		endif;	
			
	
		
		if methodArray.size &gt; 0 then
		
			create fileMethodDetails transient;	
			fileMethodDetails.usePresentationFileSystem := folderNonServer.usePresentationFileSystem;
			fileMethodDetails.openOutput(folderNonServer.fileName &amp; "\methodsExtract" &amp; systemName &amp; ".csv" );
		//fileMethodDetails.usePresentationFileSystem := folderServer.usePresentationFileSystem;
		//	fileMethodDetails.openOutput(folderServer.fileName &amp; "\methodsExtract" &amp; systemName &amp; ".csv" );	
		//	fileMethodDetails.writeLine("Schema,Class,Method,ConstantName,ConstantNumber,Caption,PropertyCombined");
		
			foreach line in methodArray do
				fileMethodDetails.writeLine(line);
			endforeach;
			
			if	fileMethodDetails &lt;&gt; null then
				fileMethodDetails.close;
			endif;
		endif;
	endif;
	
	write "done";
	app.writeLog(method.name &amp; "_End",1);
	write method.name &amp; "_End";
	
epilog
	delete constantArray;
	delete methodArray;

delete fileConstantDetails;
delete specialArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFindUnusedConstants" id="b7a0b976-862b-452c-af29-afac9f402c9c">
        <updating/>
        <source>doFindUnusedConstants() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2017	cnwns1	Initial creation

*/

constants
    TranslateFormName = "translateForm";
vars

	category			: XLAT_Category;
	
	startTime 			: TimeStamp;
	constArr 			: ObjectArray;
	const  				: Constant;
	constantCategory 	: ConstantCategory;
	portSchema 			: Schema;
	codeSchema 			: Schema;
	codeClass 			: Class;
	codeMeth 			: Method;
	index				: Integer;
	methSet				: MethodSet;
	subSchemas 			: SchemaColl;
	classColl 			: ClassColl;	
	outputString 		: String;
	obj 				: Object;	
	schemaNames 		: StringArray;
	meths 				: MethodSet;
	xmlDoc 				: JadeXMLDocument;
	xmlElement 			: JadeXMLElement;
	textElement 		: JadeXMLElement;
	tempClass 			: Class;
	xmlAttribute 		: JadeXMLAttribute;
	found 				: Boolean;
	constName 			: String;
	lsSchema 			: LSschema;
	lsClass 			: LSclass;
	lsMethod 			: LSmethod;
	totalCount 			: Integer;
	progress 			: Integer;
	schemaName 			: String;
	className 			: String;
	controlName 		: String;
	mySchema 			: Schema;
	myClass 			: Class;
	
	namesToSpare 		: StringArray;
	namesToChange 		: StringArray;
	secondPass 			: Boolean;
	newNameCount	: Integer;
begin

	create namesToSpare transient;
	create namesToChange transient;
	startTime := app.actualTimeServer;
	
	app.writeLog(method.name,1);
	write method.name;
	
	category := app.myRoot.allXLAT_Categories[XLAT_FormCaptions];
	
	namesToSpare.add("CMUI_ConnectAt_CchkIgnoreWarnL");
	namesToSpare.add("CMUI_ConnectAttachOld_CbtnCanc");
	namesToSpare.add("CMUI_ConnectAttachOld_CbtnOK");
	
	namesToSpare.add("MOB_HHBre_CMOB_HHBreakBulkDisc");
	namesToSpare.add("MOB_HHBrea_CMOB_HHBreakBulkMer");
	namesToSpare.add("MOB_HHBrea_CMOB_HHBreakBulkSpl");
	namesToSpare.add("MOB_HandH_CMOB_HandHeldReeferE");
	namesToSpare.add("MOB_HandH_CMOB_HandHeldCargoEn");
	

	
	portSchema:=rootSchema.getSchema("PortSchema");
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);
		
	getSpecialMethods();
		
	create constArr transient;
	
	
	
	
	foreach const in constantCategory.cnEcGetConstants() do	
		
		if self.allConstantsToDelete.includes(const) then
			continue;
		endif;
				
		if const.name.cnContains("Xlat_") then
			newNameCount := newNameCount + 1;
		endif;
		
		create meths transient;
		const.getMethodRefs(meths);
		if meths.size = 0 then
			constArr.add(const);
		endif;
		delete meths;
	endforeach;	
	
	if  newNameCount &gt; 10000 then
		secondPass := true;
	endif;
	
	
		
	write "Finnished adding " &amp; constArr.size.String &amp; Tab &amp; (app.actualTimeServer - startTime).String;
	
	create	methSet transient;
	create	subSchemas transient;
	
	totalCount :=	constArr.size;
	
	foreach index in constArr.size to 1 step -1 do
		found := false;
		const := constArr[index].Constant;
			
		constName := const.name;
		
		progress := progress + 1;	
				
		if progress mod 10 = 1 then
		
			self.caption := "Orphans " &amp; progress.String &amp; " of " &amp; totalCount.String &amp; " " &amp; constName ;
			
			app.doWindowEvents(0);
		endif;	
			
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(const.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
				
		
		// get the form schema
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_SchemaName);
		if xmlAttribute &lt;&gt; null then
			codeSchema := rootSchema.getSchema(xmlAttribute.value);
		else
			write "codeSchema is null " &amp; constName &amp; Tab &amp; const.getSource;
			continue;
		endif;
		
		delete classColl;		
		classColl := codeSchema.allClasses();
		
		
		// get the form class
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
		if xmlAttribute &lt;&gt; null then
	//	codeClass := codeSchema.getClass(xmlAttribute.value);
			foreach tempClass in classColl do
				if tempClass.name =   xmlAttribute.value then
					codeClass := tempClass;
				endif;
			endforeach;	
		else
			write 	"atrib is null " &amp; constName &amp; Tab &amp; const.getSource;
			continue;
		endif;
		
		if codeClass = null then
			write 	"codeClass is null " &amp; constName &amp; Tab &amp; const.getSource;
			continue;
		endif;
		codeMeth := codeClass.getMethod(TranslateFormName);
		
		
		
		if codeMeth &lt;&gt; null and self.xStringContains(codeMeth.getSource,constName) then
			constArr.remove(const);
			continue;
		endif;	
		
		
		
		methSet.clear;
		codeClass.allMethods(methSet);
		
		foreach codeMeth in methSet do
			if self.xStringContains(codeMeth.getSource,constName) then
				constArr.remove(const);
				found := true;
				break;
			endif;
		endforeach;	
		
		if found then
			continue;
		endif;
		
		
		foreach lsSchema in allLsSchemas do
			if not found then
				foreach lsClass in lsSchema.allClasses do
					if not found then
						foreach lsMethod in lsClass.allMethods do
							if not found then
								if xStringContains(lsMethod.LSmethodSource.source,constName) then
									constArr.remove(const);
									found := true;
									break;
								endif;	
							endif;
						endforeach;
					endif;	
				endforeach;
			endif;
		endforeach;
		
		
	//	if found then
	//		found := false;
	//		continue;
	//	endif;
		
	endforeach;	
		
	write "Finnished scan 1 " &amp; constArr.size.String &amp; Tab &amp; (app.actualTimeServer - startTime).String;
		
	// Remove anything with broken XML references	
		
	foreach const in constantCategory.cnEcGetConstants() do
	
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(const.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
				
				// get the form Schema
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_SchemaName);
		if xmlAttribute &lt;&gt; null then
			schemaName :=  xmlAttribute.value;
		endif;
			
		// get the form class
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
		if xmlAttribute &lt;&gt; null then
			className :=  xmlAttribute.value;
		endif;
		
		// get the form class
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlName);
		if xmlAttribute &lt;&gt; null then
			controlName :=  xmlAttribute.value;
		endif;
			
		mySchema :=  rootSchema.getSchema(schemaName);
		if mySchema = null then
			if not constArr.includes(const) then
				constArr.add(const);
			endif;
		else
			myClass := mySchema.getClass(className);
			if myClass = null then
				if not constArr.includes(const) then
					constArr.add(const);
				endif;
			endif;
		endif;	
	endforeach;
		
		
	//we want to keep the 3 consts the first time around	
	if not secondPass then
		foreach index in constArr.size to 1 step -1 do
			const := constArr[index].Constant;			
			if namesToSpare.includes(const.name) then
				constArr.remove(const);
			endif;
		endforeach;	
	endif;	
		
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp;  "allConstantsToDelete Size: "	&amp; self.allConstantsToDelete.size.String	, LogINFO);	
		
	foreach obj in constArr do
		const := obj.Constant;
		if not self.allConstantsToDelete.includes(const) then
			self.allConstantsToDelete.add(const);
		endif;
	//	outputString := outputString &amp; const.name &amp; CrLf;
	endforeach;
		
	
	write "done";
	app.writeLog(method.name &amp; "_End",1);
	write method.name &amp; "_End";
	
epilog

	delete xmlDoc ;
	delete textElement ;
	
	delete schemaNames;

	delete constArr;
	delete methSet;
	delete subSchemas;
	delete classColl;
	delete namesToSpare;
	delete namesToChange;
//	delete releaseMeths;
//	delete releaseMeths	;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doGetMethodRefsNotInFile" id="c7641187-c474-401b-8a7a-3bd70d2e17c3">
        <updating/>
        <source>doGetMethodRefsNotInFile(_checkMethods : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2017	cnwns1	Initial creation

*/
vars
	inputFile : File;

	
	inputArray 			: HugeStringArray;
	constantName 		: String;
	
	line 				: String;
	localConstantArray 	: HugeStringArray;
	localMethodArray 	: HugeStringArray;
	forignConstantArray : HugeStringArray;
	forignMethodArray 	: HugeStringArray;
	badConstantArray 	: HugeStringArray;
	badMethodArray 		: HugeStringArray;
	totalCount 			: Integer;
	progress 			: Integer;
	deleteArray 		: StringArray;

	folderNonServer 	: FileFolder;
	inputFileNode 		: FileNode;
	fileName 			: String;
	portSchema 			: Schema;
	constantCategory 	: ConstantCategory;
	constantObj 		: Constant;
	meths 				: MethodSet;
	codeMeth 			: Method;
	lsMethod 			: LSmethodSource;
	folderServer		: FileFolder;
begin
	
	app.writeLog(method.name,1);
	write method.name;


	create forignConstantArray transient;
	create forignMethodArray transient;
	
	create inputFile transient;
	
	folderNonServer := zFileCreateFolder(Path_CSV_extract,true);
	
	//Show a dialog box to halt the process and give Dmast a chance to catch up if it is behind
	while true do 
		if	folderNonServer.files.size &lt;&gt; 2 then
			if  app.msgBox("No File Found, Try again?","No File Found",MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
				write "folderNonServer.files.size is " &amp; folderNonServer.files.size.String; 
				return;
			else
				write "folderNonServer.files.size is " &amp; folderNonServer.files.size.String;
			endif;
		else
			break;
		endif;
	endwhile;
	
	
	
	
	
	if _checkMethods then
		fileName := "methodsExtract";
	else
		fileName := "constantsExtract";
	endif;
	
	foreach inputFileNode in folderNonServer.files do
		if inputFileNode.isKindOf(File) then
			inputFile := inputFileNode.File;
		else	
			continue;
		endif;
		
		self.caption := inputFile.name &amp; " - Loading File";
		app.doWindowEvents(0);
		
		
		if inputFile.fileName.cnContains(fileName) then
			inputFile.openInput(inputFile.fileName);
		//	create forignConstantArray transient;
			while not inputFile.endOfFile do
			//	delete inputArray;
			//	create inputArray transient;
				line := inputFile.readLine.removeCrLfs;
				forignConstantArray.add(line);
			endwhile;		
			
			if _checkMethods then
				create localMethodArray transient;
			else
				create localConstantArray transient;
			endif;
		endif;
	endforeach;
	
	
	
	xGetConstantsIntoArray(localConstantArray,localMethodArray);
		
	if localMethodArray&lt;&gt; null then
		totalCount := localMethodArray.size;
	else
		totalCount := localConstantArray.size;
	endif;
	
	//if localConstantArray.size + localMethodArray.size &gt; 0 then
	
	
	create badConstantArray transient;
	create badMethodArray transient;
	create deleteArray transient;
	
	
	if not _checkMethods then
		foreach line in localConstantArray do
			progress := progress + 1;
			if progress mod 13 = 0 then
				self.caption := (progress / totalCount * 100).Real.roundedTo(1).String &amp; "% " &amp; progress.String &amp; " of " &amp; totalCount.String &amp; " localConstantArray";
				app.doWindowEvents(0);
			endif;
			
			create inputArray transient;
			line.getHugeTokensForDelimiter(",",inputArray);
			constantName := 	inputArray[5];
			delete inputArray;
			if deleteArray.includes(constantName) then
				continue;
			endif;
		
			if not forignConstantArray.includes(line) then
				badConstantArray.add(line);
				deleteArray.add(constantName);
			endif;
		endforeach;
	else
		foreach line in localMethodArray do
			progress := progress + 1;
			if progress mod 15 = 0 then
				self.caption := (progress / totalCount * 100).Real.roundedTo(1).String &amp; "% " &amp; progress.String &amp; " of " &amp; totalCount.String &amp; " localMethodArray";
				app.doWindowEvents(0);
			endif;
		
			create inputArray transient;
			line.getHugeTokensForDelimiter(",",inputArray);
			constantName := 	inputArray[4];
			delete inputArray;
			if deleteArray.includes(constantName) then
				continue;
			endif;
		
			if not forignMethodArray.includes(line) then
				badMethodArray.add(line);
				deleteArray.add(constantName);
			endif;
		endforeach;
	endif;

	
	if badConstantArray.size + badMethodArray.size = 0 then
		return;
	endif;
	
	
	portSchema:=rootSchema.getSchema(PortSchemaName);
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);
	
	progress := 0;
	totalCount := constantCategory.cnEcGetConstants.size;
	foreach constantObj in	constantCategory.cnEcGetConstants do
		//add to allDelete
		
		progress := progress + 1;
		
		if self.allConstantsToDelete.includes(constantObj) then
			continue;
		endif;
		
		if progress mod 12 = 0 then
			self.caption := (progress / totalCount * 100).Real.roundedTo(1).String &amp; "% " &amp; constantObj.name &amp; " - Scanning Source";
			doWindowEvents(0);
		endif;
		
		
		if   badConstantArray.includes(constantObj.name) or badMethodArray.includes(constantObj.name) then
			self.allConstantsToDelete.add(constantObj);
			delete meths;
			create meths transient;
			constantObj.getMethodRefs(meths);
			
			foreach codeMeth in meths do
				if 	codeMeth.schemaType.name = JadeScript.name or  codeMeth.name = "translateForm"  then
				
				lsMethod :=	self.getLSFromMeth(codeMeth,false,self.allDeleteLSSchemas).LSmethodSource;
				
				xScanSource(lsMethod,constantObj.name,null,true);
				
				endif;
			endforeach;
			
		endif;
		
	endforeach;
	
		folderServer := self.zFileCreateFolder(Path_CSV_extract &amp; fileName &amp; "\" ,false);
	//Create scm for all those methods....
		
		
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp;  "allDeleteLSSchemas Size: "	&amp; self.xGetChangedMethodCount(self.allDeleteLSSchemas,"Method").String	, LogINFO);	
		
	self.zFileCreateMethodExtract(folderServer,self.allDeleteLSSchemas);

	write "done";

	app.writeLog(method.name &amp; "_End",1);
	write method.name &amp; "_End";	


epilog
	delete folderNonServer;
	
	if localConstantArray &lt;&gt; null then
		delete localConstantArray;
	endif;
	if localMethodArray &lt;&gt; null then
		delete localMethodArray;
	endif;
	
	
	delete forignConstantArray;
	delete forignMethodArray; 
	delete badConstantArray;
	delete badMethodArray;
	delete deleteArray;

//	delete specialArray;
end;</source>
        <Parameter name="_checkMethods" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doHuntForLostConstants" id="6e467230-019c-451a-9301-037454806df7">
        <updating/>
        <source>doHuntForLostConstants() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2017	cnwns1	Initial creation

*/

constants
    TranslateFormName = "translateForm";
	XLAT = "Xlat_";
vars

	category			: XLAT_Category;
	
	startTime 			: TimeStamp;
	constArr 			: ObjectArray;
	const  				: Constant;
	constantCategory 	: ConstantCategory;
	portSchema 			: Schema;
	codeSchema 			: Schema;
	codeClass 			: Class;
	codeMeth 			: Method;
	index				: Integer;
	methSet				: MethodSet;
	subSchemas 			: SchemaColl;
	classColl 			: ClassColl;	
	outputString 		: String;
	obj 				: Object;	
	schemaNames 		: StringArray;
	meths 				: MethodSet;
	xmlDoc 				: JadeXMLDocument;
	xmlElement 			: JadeXMLElement;
	textElement 		: JadeXMLElement;
	tempClass 			: Class;
	xmlAttribute 		: JadeXMLAttribute;
	found 				: Boolean;
	constName 			: String;
	lsSchema 			: LSschema;
	lsClass 			: LSclass;
	lsMethod 			: LSmethodSource;
	totalCount 			: Integer;
	progress 			: Integer;
	schemaName 			: String;
	className 			: String;
	controlName 		: String;
	mySchema 			: Schema;
	myClass 			: Class;
	namesToSpare 		: StringArray;
	namesToChange 		: StringArray;
	arrRefsNames 		: HugeStringArray;
	xmlRefName	 		: String;
	secondPass 			: Boolean;
	nameString 			: String;
	folderServer		: FileFolder;
begin

	app.writeLog(method.name,1);
	write method.name;

	create namesToSpare transient;
//	create namesToChange transient;
	startTime := app.actualTimeServer;
	
	category := app.myRoot.allXLAT_Categories[XLAT_FormCaptions];
	
	namesToSpare.add("CM_BaseForm");

	
	
	
	create arrRefsNames transient;
	
	portSchema:=rootSchema.getSchema("PortSchema");
	constantCategory:=portSchema.getConstantCategory(XLAT_FormCaptions);
		
	totalCount := constantCategory.cnEcGetConstants().size;
	
	foreach const in constantCategory.cnEcGetConstants() do	
	
		//Go throught all XLAT constants			
		constName := const.name;
		
		if self.allConstantsToDelete.includes(const) then
			continue;
		endif;
		
		//Show Progress
		progress := progress + 1;	
		if progress mod 11 = 0 then
			self.caption := (progress / totalCount * 100).Real.roundedTo(1).String &amp; "% " &amp; "Lost " &amp;  progress.String &amp; " of " &amp; totalCount.String &amp; " " &amp; constName ;
			app.doWindowEvents(0);
		endif;	
		
		if const.name.cnContains(XLAT) then	
			continue;
		endif;
		
		delete meths;
		create meths transient;
		const.getMethodRefs(meths);
		
		
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(const.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
				
		
		// get the form schema
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_SchemaName);
		if xmlAttribute &lt;&gt; null then
			codeSchema := rootSchema.getSchema(xmlAttribute.value);
		else
			write "codeSchema is null " &amp; constName &amp; Tab &amp; const.getSource;
			continue;
		endif;
		
		delete classColl;		
		classColl := codeSchema.allClasses();
		
		
		
		// get the form class
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
		if xmlAttribute &lt;&gt; null then
	//	codeClass := codeSchema.getClass(xmlAttribute.value);
			foreach tempClass in classColl do
				if tempClass.name =   xmlAttribute.value then
					codeClass := tempClass;
				endif;
			endforeach;	
		else
			write 	"atrib is null " &amp; constName &amp; Tab &amp; const.getSource;
			continue;
		endif;
		
		if meths.size = 1 and codeClass = meths.first.schemaType then
			continue;
		endif;
		
		if codeClass = null then
			write 	"codeClass is null " &amp; constName &amp; Tab &amp; const.getSource;
			continue;
		endif;
	
			
		foreach codeMeth in meths do
			if	codeMeth.schemaType.name &lt;&gt; JadeScript.name 
			and codeMeth.name = TranslateFormName 
			and codeMeth.schemaType &lt;&gt; codeClass 
			and not namesToSpare.includes(codeMeth.schemaType.name)	then
			
			lsMethod :=	self.getLSFromMeth(codeMeth,false,self.allDeleteLSSchemas).LSmethodSource;
			
			xScanSource(lsMethod,constName,null,true);
			
		//		self.addConstantToDeleteDict(const);
				
//				nameString := codeMeth.schemaType.schema.name &amp; "::" &amp; codeMeth.schemaType.name &amp; "::" &amp; codeMeth.name;	
//				if not arrRefsNames.includes(nameString) then
//					arrRefsNames.add(nameString);
//				endif;
	
			//	write nameString  &amp; "," &amp; const.name;//);
			endif;
		endforeach;
	endforeach;	
		
//	if arrRefsNames.size = 0 then
//		write "None Found";
//	else
//		createJCFToDeleteMethods(arrRefsNames);	
//	endif;		
				
	folderServer := self.zFileCreateFolder(Path_LostConstantChanges,false);
	//Create scm for all those methods....
		
		
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp;  "allDeleteLSSchemas Size: "	&amp; self.xGetChangedMethodCount(self.allDeleteLSSchemas,"Method").String	, LogINFO);	
		
	self.zFileCreateMethodExtract(folderServer,self.allDeleteLSSchemas);
				
				
	
	write "done";
	app.writeLog(method.name &amp; "_End",1);
	write method.name &amp; "_End";	

epilog

	delete xmlDoc ;
	delete textElement;
	delete schemaNames;
	delete constArr;
	delete methSet;
	delete subSchemas;
	delete classColl;
	delete namesToSpare;
	delete namesToChange;
	delete arrRefsNames;
end;</source>
    </JadeMethod>
    <JadeMethod name="getConstantRefs" id="e354100b-04e9-4836-b238-a539c5108fbb">
        <updating/>
        <source>getConstantRefs(_constant : Constant ;_lsSchemas : LSschemaByName io ; _getUsage : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2017	cnwns1	Initial creation

*/
 
vars
	meths : MethodSet;
	codeMeth : Method;
	lsMeth	: LSmethodSource;
	lsConstant : LSconstant;
	xmlDoc : JadeXMLDocument;
	xmlElement : JadeXMLElement;
	textElement :JadeXMLElement;
	controlCaption : String;
	source : String;
	linePos : Integer;
	line : String;
	charPos : Integer;
	controlProperty : String;
	controlName : String;
begin
	create meths transient;
	_constant.getMethodRefs(meths);
	
	create xmlDoc transient;
	xmlDoc.parseString(_constant.text);
	xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
		
	// Get the text
	textElement := xmlElement.findElement(XMLTag_Msg, null);
	if textElement &lt;&gt; null then
		controlCaption :=  textElement.text.removeCrLfs.removeCommas;
	endif;	
	
	foreach codeMeth in meths do
		
		if codeMeth.getSchemaType.Class.name = JadeScript.name then
			continue;
		endif;
		
		
		lsMeth := self.getLSFromMeth(codeMeth,false,_lsSchemas);
		create lsConstant transient;
		lsConstant.name 		:=  _constant.name;
		lsConstant.number 		:= _constant.getSource.Integer;
		lsConstant.text 		:= controlCaption;
		
		if _getUsage then
				
			source := lsMeth.source;
									
			linePos := 1;
		
			while true do
				// get the line to check
				line := source.cnEcGetNextLine(linePos);
				if linePos = 0 then 
					break;
				endif;
				
				if not self.xStringContains(line,lsConstant.name) then
					continue;
				endif;
				charPos := 1;
				line := line.removeTabCrLfs.scanUntil("(",charPos);
				if charPos = 0 then 
					continue;
				endif;
				charPos := 1;
				
				controlName := line.scanUntil(".",charPos).trimBlanks;
				
				if charPos = 0 then 
					continue;
				endif;
				
				if controlName.cnContains(":") then
					charPos := 1;
					controlProperty := controlName.scanUntil(":",charPos);
				endif;
				
				
				if controlName.length &gt; lsConstant.controlName.maxLength then
					lsConstant.controlName :=controlName[1:lsConstant.controlName.maxLength];
				else
					lsConstant.controlName :=controlName;
				endif;
				
				controlProperty :=	line[charPos:End].replace(".translate","").trimBlanks;
				
				if controlProperty.cnContains(":") then
					charPos := 1;
					controlProperty := controlProperty.scanUntil(":",charPos);
				endif;
				if controlProperty.cnContains(".") then
					
					controlProperty := controlProperty.replace(".","");
				endif;
				
				if controlProperty.length &gt; lsConstant.controlProperty.maxLength then
					lsConstant.controlProperty :=  controlProperty[1: lsConstant.controlProperty.maxLength];
				else
					lsConstant.controlProperty := controlProperty;
				endif;
				break;
			endwhile;	
				
		endif;
	//	lsConstant.schemaName 	:= schemaName;
	//	lsConstant.formName 	:= formClass;
		
		lsMeth.allConstants.add(lsConstant);
	endforeach;
epilog
	delete meths;
			delete xmlDoc;
end;</source>
        <Parameter name="_constant" type="Constant"/>
        <Parameter name="_lsSchemas" type="LSschemaByName" usage="io"/>
        <Parameter name="_getUsage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLSFromClass" id="8f7ec7e2-4b5e-4286-a085-fe401479c3bc">
        <updating/>
        <source>getLSFromClass(_codeClass : Class;  _schemaDict : LSschemaByName io) : LSclass updating ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2017	cnwns1	Initial creation

*/

vars
	lsSchema : LSschema;
	lsClass : LSclass;
begin
	lsSchema := self.getLsSchema(_codeClass.schema, _schemaDict);
	
	lsClass := self.getLsClass(_codeClass,lsSchema);
		
	return lsClass;
epilog

end;</source>
        <Parameter name="_codeClass" type="Class"/>
        <Parameter name="_schemaDict" type="LSschemaByName" usage="io"/>
        <ReturnType type="LSclass"/>
    </JadeMethod>
    <JadeMethod name="getLSFromMeth" id="cd0095c0-4dc2-4430-9b91-03d4289d3523">
        <updating/>
        <source>getLSFromMeth(_codeMethod : Method;_isSpecial : Boolean ;_schemaDict : LSschemaByName io) : LSmethodSource  updating ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2017	cnwns1	Initial creation

*/

vars
	lsClass : LSclass;
	lsMethod : LSmethodSource;
begin
	lsClass := self.getLSFromClass(_codeMethod.getSchemaType.Class,_schemaDict);
		
	lsMethod := self.getLsMethod(_codeMethod,	lsClass,_isSpecial );
		
	return lsMethod;
epilog

end;</source>
        <Parameter name="_codeMethod" type="Method"/>
        <Parameter name="_isSpecial" type="Boolean"/>
        <Parameter name="_schemaDict" type="LSschemaByName" usage="io"/>
        <ReturnType type="LSmethodSource"/>
    </JadeMethod>
    <JadeMethod name="getLsClass" id="f559ce74-c085-4867-8b5a-b1e9f5318850">
        <source>getLsClass(_class : Class; _lMyLsSchema : LSschema io) : LSclass  ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2017	cnwns1	Initial creation

*/

vars
	lsClass : LSclass;
begin

	if _lMyLsSchema.allClasses.includesKey(_class.name) then
		lsClass := _lMyLsSchema.allClasses.getAtKey(_class.name);
	else
		create lsClass transient;
		lsClass.myClass := _class;
		lsClass.name := lsClass.myClass.name;
		_lMyLsSchema.allClasses.add(lsClass);
	endif;


	return lsClass;
epilog

end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_lMyLsSchema" type="LSschema" usage="io"/>
        <ReturnType type="LSclass"/>
    </JadeMethod>
    <JadeMethod name="getLsMethod" id="685142a9-fb29-4fb4-ba6d-709e4c772209">
        <source>getLsMethod(_method : Method ; _lsClass : LSclass input; _isSpecialMethod : Boolean ) : LSmethodSource ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2017	cnwns1	Initial creation

*/

vars
	lMyLsMeth : LSmethodSource;
	methodName : String;
begin


		methodName := _method.name;
	
	
		if _lsClass.allMethods.includesKey(methodName) then
			lMyLsMeth := _lsClass.allMethods.getAtKey(methodName).LSmethodSource;
			if lMyLsMeth.myMethod &lt;&gt; _method then
				return null;
			endif;
		else
			create lMyLsMeth transient;
			lMyLsMeth.myMethod := _method;
		//	lMyLsMeth.myClass := _lsClass	;
			lMyLsMeth.setSource(_method.getSource);
			lMyLsMeth.name := methodName;	// this way round gets 1090 if name is mis-spelled	
			lMyLsMeth.setSpecial(_isSpecialMethod);
			create lMyLsMeth.allConstants transient;
			_lsClass.allMethods.add(lMyLsMeth);
		endif;
		
		return lMyLsMeth;
epilog

end;</source>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_lsClass" type="LSclass" usage="input"/>
        <Parameter name="_isSpecialMethod" type="Boolean"/>
        <ReturnType type="LSmethodSource"/>
    </JadeMethod>
    <JadeMethod name="getLsSchema" id="742ac991-0332-4d75-9ff1-968909d24c92">
        <updating/>
        <source>getLsSchema(_schema : Schema; _schemaDict : LSschemaByName io  ) : LSschema updating ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2017	cnwns1	Initial creation

*/
constants


vars
lMyLsSchema : LSschema;
schemaName : String; 

begin

	
	
	
	schemaName := _schema.name;

	if _schemaDict.includesKey(schemaName) then
		lMyLsSchema := _schemaDict.getAtKey(schemaName);
	else	
		 create lMyLsSchema transient;
		lMyLsSchema.mySchema := _schema;
		lMyLsSchema.name := schemaName;
		_schemaDict.add(lMyLsSchema);
	endif;
	
	return lMyLsSchema;
epilog

end;</source>
        <Parameter name="_schema" type="Schema"/>
        <Parameter name="_schemaDict" type="LSschemaByName" usage="io"/>
        <ReturnType type="LSschema"/>
    </JadeMethod>
    <JadeMethod name="getSpecialMethods" id="c8ea82a3-8150-49bc-ac7a-889943d737b3">
        <updating/>
        <source>getSpecialMethods() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2017	cnwns1	Initial creation

*/
constants
	TranslateFormName = "translateForm";
vars
codeSchema : Schema; 
classColl : ClassColl; 
codeClass : Class; 
codeMeth : Method;

 lMyLsSchema : LSschema;
 lMyLsClass : LSclass ;
 lMyLsMeth : LSmethodSource ;
begin
	if self.allLsSchemas &lt;&gt; null then
//		if self.allLsSchemas.size &gt; 1 then
//			write "not regenerated";
//			return;
//		else
			self.allLsSchemas.purge;
//		endif;
	endif;

    create self.allLsSchemas transient;
	

	codeSchema  :=rootSchema.getSchema(UiCommonSchemaName);
	xAddTransMethod(codeSchema,"CM_ContainerEnqForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_Selector",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_CargoPhotosFormModal",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_EDITranshipSummary",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_QueryAccessSetsForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_SelectorColOrganiserForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_TILCTypeForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_CalendarDateBulkAddForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_EventTransactions","cmbEventType_lostFocus",true);
	xAddTransMethod(codeSchema,"CMUI_EventTransactions","doSelectEvent",true);
	xAddTransMethod(codeSchema,"CMUI_ReleaseCargoForm","onReleaseRefChanged",true);
	xAddTransMethod(codeSchema,"CMUI_TestAutoPlanFormTest2",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_VehicleBookDayTemplate",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_ReceiveCargoForm","onContainerIdChange",true);
	xAddTransMethod(codeSchema,"CMUI_AdditionalReleaseTypes","setupForm",true);
	xAddTransMethod(codeSchema,"CMUI_VehicleBookTermTemplate",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_CargoEnqConfigEditTab",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_MoveAmountForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_ObjectCriteriaListForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_TrackedItemPicker",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_CargoEnqConfigEditTab",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_CargoEnqConfigCopyFrom",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CM_ContainerEnqForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_EmailSetupForm","zTranslateDONOTEDIT",true);
	xAddTransMethod(codeSchema,"CMUI_RequestEditForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_StopsForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CMUI_ShipFullyPlanForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CM_BaseForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"CM_ContainerEnqForm",TranslateFormName,true);
	
	
	
	codeSchema  :=rootSchema.getSchema(MobileUISchemaName);	
	xAddTransMethod(codeSchema,"MOB_HHTruckAllCargo",TranslateFormName,true);
	xAddTransMethod(codeSchema,"MOB_HandHeldMenuForm","getTranslationOfMenu",true);
	xAddTransMethod(codeSchema,"MOB_HandHeldMenuForm","displayCurrentLocation",true);
	xAddTransMethod(codeSchema,"MOB_HHVehicleMove","displayCurrentLocation",true);
	xAddTransMethod(codeSchema,"MOB_HHCargoSplit",TranslateFormName,true);
	xAddTransMethod(codeSchema,"MOB_HHReeferEnquiryForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"MOB_HHCargoDiscrepancy",TranslateFormName,true);
	xAddTransMethod(codeSchema,"MOB_HHCargoMerge",TranslateFormName,true);
	xAddTransMethod(codeSchema,"MOB_HHVehicleLanderVoyForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"MOB_HHTruckReleaseCargoSelect",TranslateFormName,true);
	xAddTransMethod(codeSchema,"MOB_HHTruckReleaseEntry",TranslateFormName,true);
	xAddTransMethod(codeSchema,"MOB_HHTruckReleaseSelect",TranslateFormName,true);
	xAddTransMethod(codeSchema,"MOB_HHStagingCargo",TranslateFormName,true);
	

	

	codeSchema  :=rootSchema.getSchema(ShipSchemaName);	
	xAddTransMethod(codeSchema,"SHP_BayDefinitionVoyageForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"SHP_OrderOfWorkForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"SHP_GeneralCargoVoyageForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"SHP_LoadList",TranslateFormName,true);
	xAddTransMethod(codeSchema,"SHP_LoadListComparison",TranslateFormName,true);
	xAddTransMethod(codeSchema,"SHP_NonPlannedNonWorkedForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"SHP_VoyageAreaForm2",TranslateFormName,true);
	xAddTransMethod(codeSchema,"SHP_VoyageEventCheckList","doSelectEvent",true);
	xAddTransMethod(codeSchema,"SHP_VoyageEventCheckList","doUnselectEvent",true);
	xAddTransMethod(codeSchema,"SHP_ROROPrint",TranslateFormName,true);
	xAddTransMethod(codeSchema,"SHP_GCHoldLocationVessDefnForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"SHP_BayDefinitionForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"SHP_VoyageAreaForm2","zTranslateDONOTEDIT",true);
	
		
	codeSchema  :=rootSchema.getSchema(YardSchemaName);
	xAddTransMethod(codeSchema,"YRD_GridAreaEnquiryForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"YRD_TrainPlanningForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"YRD_GridAreasForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"YRD_GridAreasOverviewForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"YRD_GCAreaEnquiryForm",TranslateFormName,true);
	
	codeSchema  :=rootSchema.getSchema(HmsSchemaName);
	xAddTransMethod(codeSchema,"HMS_TidalModelForm","zTranslateDONOTEDIT",true);
	
	codeSchema  :=rootSchema.getSchema(LogSchemaName);
	xAddTransMethod(codeSchema,"LOG_LoadOutForm","zTranslateDONOTEDIT",true);
	xAddTransMethod(codeSchema,"LOG_VoyageOpsFormOLD",TranslateFormName,true);
	
	
	codeSchema  :=rootSchema.getSchema(GateSchemaName);
	xAddTransMethod(codeSchema,"GTE_PreNoteForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"GTE_BulkGateForm_In","doCargoTypesClick",true);
	xAddTransMethod(codeSchema,"GTE_BulkGateForm_In","onPINChange",true);
	xAddTransMethod(codeSchema,"GTE_BulkGateForm_In","openFormFromPinNo",true);
	xAddTransMethod(codeSchema,"GTE_FlexiGateForm","onPINChange",true);
	xAddTransMethod(codeSchema,"GTE_FlexiGateForm","openFormFromPinNo",true);
	xAddTransMethod(codeSchema,"GTE_FlexiGateForm",TranslateFormName,true);
	xAddTransMethod(codeSchema,"GTE_KioskPinEntryForm","doEnter",true);
	xAddTransMethod(codeSchema,"GTE_TrackedItems",TranslateFormName,true);
	xAddTransMethod(codeSchema,"GTE_SecurityGateVisitEntry",TranslateFormName,true);
	xAddTransMethod(codeSchema,"GTE_FlexiGateOutForm",TranslateFormName,true);
	
	
	
	codeSchema  :=rootSchema.getSchema(InvoiceSchemaName);		
	xAddTransMethod(codeSchema,"INV_CashReceiptMulti",TranslateFormName,true);
	xAddTransMethod(codeSchema,"INV_ListLines","loadDataForFirstTime",true);
	xAddTransMethod(codeSchema,"INV_InvoiceCargoAllocMapping",TranslateFormName,true);
	
	codeSchema  :=rootSchema.getSchema(DevSchema.name);		
	xAddTransMethod(codeSchema,"JadeScript","mdhFixupMain",true);
	xAddTransMethod(codeSchema,"JadeScript","mdhCorrectFormNames",true);
	
	codeSchema  :=rootSchema.getSchema(PortSchemaName);		
	xAddTransMethod(codeSchema,"CM_Voyage","validateDates",true);	
	xAddTransMethod(codeSchema,"CM_ValidationUpdateAgent","valTerminalConfig",true);
	xAddTransMethod(codeSchema,"CM_DebtorBankInvTypeDtl","auditIdDisplay",true);
	xAddTransMethod(codeSchema,"CM_DebtorBankInvTypeDtl","getAuditText",true);
	xAddTransMethod(codeSchema,"CM_AuditConfig","getDescription",true);
	xAddTransMethod(codeSchema,"CM_QuantityMap","getAuditText",true);
	xAddTransMethod(codeSchema,"CM_Bank","getAuditText",true);
	xAddTransMethod(codeSchema,"CM_DebtorInvoiceLineDesc","auditIdDisplay",true);
	
	codeClass := codeSchema.getClass(JadeScript.name);
	foreach codeMeth in codeClass.cnGetMethods() do
		if self.xIsReleaseMeth(codeMeth) then
			xAddTransMethod(codeSchema,codeClass.name,codeMeth.name,true);
		endif;	
	endforeach;
		
		
end;
</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="fcbe2409-4104-45cf-b66b-c6fbf3325711">
