    <JadeMethod name="validateForApproval" id="7561b91b-8084-40ab-9d5d-643ddefa924d">
        <source>validateForApproval();
/*
Purpose:	

Date		Who		Reason
14 January 2025	navab1	JIRA 33801
*/

vars
	detail,
	subDetail	: CM_OwnershipChangeDetail; 
begin
			
	foreach detail in self.allDetails do
		detail.validateForApproval();
		foreach subDetail in detail.allSubDetails do
			subDetail.validateForApproval();
		endforeach;
	endforeach;

epilog

end;</source>
