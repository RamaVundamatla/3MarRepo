    <JadeMethod name="openFile" id="13d8249a-f5a1-4833-991f-a32b742bf2e6">
        <source>openFile( detailLevel : Integer ) : File;

//	opens text file for output

vars
	myDlg	: CMDFileSave;
	f		: File;

begin
	create myDlg;

	myDlg.initDir := "c:\temp";
	myDlg.defaultExt := "*.txt";

	if detailLevel = self.LIST_ONLY then	
		myDlg.fileName := "forms.txt";
	elseif detailLevel = self.STATS_ONLY then
		myDlg.fileName := "stats.txt";
	elseif detailLevel = self.ALL_DETAILS then
		myDlg.fileName := "helpsrce.txt";
	endif;

	if myDlg.open = 0 then	// user clicked OK
		create f;
		f.fileName := myDlg.fileName;	// get selected name
		if f.isAvailable() then 
			f.purge;
		endif;
		f.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
		f.mode := 0;
		f.allowCreate := true;	// create if not there
		f.open;					// not mandatory
		return f;
	else
		return null;
	endif;

epilog
	delete myDlg;
end;</source>
        <Parameter name="detailLevel" type="Integer"/>
        <ReturnType type="File"/>
    </JadeMethod>
    <JadeMethod name="populateForms" id="dec309b2-366d-4e78-bf48-0fdc6ae657db">
        <updating/>
        <source>populateForms() updating;

//	fills the table tblSelectedForms based on the selected schema (and "Include subschemas" chekcbox)

vars
	formDate	: Date;
	theClass	: Class;
	rowPointer	: Integer;
	theSchema	: Schema;
	allSchemas	: SchemaColl;
	
begin
	create allSchemas transient;
	self.setStatusLine("Working...", true);
	btnGetForms.enabled := false;

	progressBar.partsInJob := 0;
	progressBar.partsDone := 0;

	tblSelectedForms.clear;
	tblSelectedForms.rows := 0;
	tblSelectedForms.columns := 2;
	self.aEarliestDate := txtStartDate.text.Date;

	theSchema := lstSchema.listObject.Schema;
	
	if theSchema = null then
		self.setStatusLine("No schema selected", false);
		return;
	endif;

	self.aAllValidFormsAsClasses.clear();
	self.getValidForms(aEarliestDate, theSchema, self.aAllValidFormsAsClasses);

	if chkSubschemas.value then
		theSchema.allSubschemas(allSchemas);
		
		if allSchemas &lt;&gt; null then
			foreach theSchema in allSchemas do
//				write( "getting forms for subschema" &amp; schema.getName );
				self.getValidForms(self.aEarliestDate, theSchema, self.aAllValidFormsAsClasses);
			endforeach;
		endif;
	endif;

	if self.aAllValidFormsAsClasses &lt;&gt; null then 
		rowPointer := 1;
		
		foreach theClass in aAllValidFormsAsClasses do
			formDate := theClass.cnEcGetModifyTimeStamp().Date;
			tblSelectedForms.addItemAt(theClass.name &amp; Tab &amp; formDate.format(self.DATE_FORMAT), rowPointer);
			tblSelectedForms.row := rowPointer;		// set row
			tblSelectedForms.column := 1;	
			tblSelectedForms.itemObject := theClass;	// associate class with row

//	write ("CnEcHelpForm::populateForms table add " &amp; myRow.String &amp; " (" &amp; tblSelectedForms.rows.String &amp; ")" &amp; Tab &amp; cls.getName );
			rowPointer := rowPointer + 1;
		endforeach;
	endif;

	self.setStatusLine((rowPointer - 1).String &amp; " forms listed", false);
epilog
	delete allSchemas;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateSchemas" id="be007f70-26f3-48ff-baf4-354b62daa7bf">
        <source>populateSchemas();

//	populates lbSchema list box
//	calls populateSubschemas (if there are any) to get a nice display...

vars
	allSchemas	: SchemaColl;
	listPointer	: Integer;
	theSchema	: Schema;
	
begin
	lstSchema.clear();
	create allSchemas transient;

	foreach theSchema in Schema.instances do // schemaColl do
		if theSchema.getName = "CardSchema" then
			break;
		endif;
	endforeach;

	if theSchema.getName &lt;&gt; "CardSchema" then
		theSchema := currentSchema;
	endif;

	listPointer := lstSchema.addItem(theSchema.getName);
	lstSchema.itemObject[listPointer] := theSchema;
	lstSchema.itemLevel[listPointer] := 1;
	lstSchema.itemExpanded[listPointer] := true;
//	write( myIndex.String &amp; Tab &amp; "1" &amp; Tab &amp; schema.getName );

	theSchema.allSubschemas(allSchemas);
	
	if allSchemas &lt;&gt; null then
		self.populateSubschemas(theSchema, 2, allSchemas);
	endif;

	// select current schema 

	listPointer := 1;

	while listPointer &lt;= lstSchema.listCount do
		theSchema := lstSchema.itemObject[listPointer].Schema;
		
		if theSchema = currentSchema then
			lstSchema.listObject := theSchema;
			lstSchema.topIndex := lstSchema.listIndex;
			break;
		endif;
		
		listPointer := listPointer + 1;
	endwhile;
epilog
	delete allSchemas;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateSubschemas" id="5834d20b-dce0-4519-9000-53d4bfe19643">
        <source>populateSubschemas(pSourceSchema : Schema; pLevel : Integer; pAllSchemas : SchemaColl);

//	populates lbSchemas with subschemas of sourceSchema
//	recurses (gasp!) as required

vars
	theSchema		: Schema;
	allLocalSchemas	: SchemaColl;
	listPointer		: Integer;
	
begin
	create allLocalSchemas transient;

	foreach theSchema in pAllSchemas do 
		if theSchema.superschema = pSourceSchema then 
			listPointer := lstSchema.addItem( theSchema.getName );
			lstSchema.itemObject[listPointer] := theSchema;
			lstSchema.itemLevel[listPointer] := pLevel;
			lstSchema.itemExpanded[listPointer] := true;
//			write( myIndex.String &amp; Tab &amp; myLevel.String &amp; Tab &amp; schema.getName );

			theSchema.allSubschemas(allLocalSchemas);
			
			if pAllSchemas &lt;&gt; null then
				self.populateSubschemas(theSchema, pLevel + 1, allLocalSchemas);
			endif;
		endif;
	endforeach;
epilog
	delete allLocalSchemas;
end;</source>
        <Parameter name="pSourceSchema" type="Schema"/>
        <Parameter name="pLevel" type="Integer"/>
        <Parameter name="pAllSchemas" type="SchemaColl"/>
    </JadeMethod>
    <JadeMethod name="selectAllItems" id="f070c1a0-4b24-427e-930a-aad5fa422cac">
        <updating/>
        <source>selectAllItems(pIsSelected : Boolean) updating;

//	selects or deselects all forms in lbSelectedForms according to myBoolean
//	also resets some check boxes according to the setting

vars
	rowPointer	: Integer;

begin
	rowPointer := 1;
	
	while rowPointer &lt;= tblSelectedForms.rows do
		tblSelectedForms.row := rowPointer;
		tblSelectedForms.selected := pIsSelected;
		rowPointer := rowPointer + 1;
	endwhile;

	if pIsSelected then
		optSelectedForms.value := true;
	else
		optAllForms.value := true;
	endif;

	chkSelectAll.value := false;
	chkDeselectAll.value := false;
end;</source>
        <Parameter name="pIsSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setOptionButtons" id="d7b4072c-8415-419a-a107-c5e91bf138e8">
        <source>setOptionButtons(optionValue : Integer);

//	sets listing options according to the value passed

begin
	if optionValue = self.LIST_ONLY then
		optList.value := true;
	elseif optionValue = self.STATS_ONLY then
		optStatistics.value := true;
	elseif optionValue = self.ALL_DETAILS then
		optAllDetails.value := true;
	else	// unknown goto LIST
		optList.value := true;
	endif;
end;</source>
        <Parameter name="optionValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStatusLine" id="25e2dc8f-f336-4db1-b38b-ac1f31617e47">
        <source>setStatusLine(str : String; updateNow : Boolean);

//	displays text in the status line

begin
	statusLine.caption := str;
	
	if updateNow then
		statusLine.refreshNow();
	endif;
end;</source>
        <Parameter name="str" type="String"/>
        <Parameter name="updateNow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblSelectedForms_click" id="733ec699-ac10-413d-8086-f050d442faf7">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSelectedForms_click(table: Table input) updating;

vars
	theClass	: Class;
	theForm		: Form;
	
begin
	optSelectedForms.value := true;

	tblSelectedForms.column := 1;	
	theClass	:= tblSelectedForms.itemObject.Class;
	tblSelectedForms.selected := true;
	tblSelectedForms.column := 2;
	tblSelectedForms.selected := true;

	if theClass = null then
		self.setStatusLine("*** null ***", false);
	else
		theForm := self.getForm(theClass.name);
		
		if theForm = null then
			self.setStatusLine(theClass.name &amp; " (NOFORM)", false);
		else
			self.setStatusLine(theClass.name &amp; " (" &amp; theForm.helpKeyword &amp; ")", false);
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
