    <JadeMethod name="documentForDeveloper" id="562ab27e-0aae-4c2d-8b82-d54c7c9412cf">
        <source>documentForDeveloper(_includeSuper : Boolean);

/*

Purpose:			Document all the available features of the receiver for a developer

Parameters:			_include the features of the superclasses of the receiver

Return Value:		None, but details output to interpreter window


Date		Who		Reason
27 Aug 2008	cnwkpd1	Internal documentation

*/

vars

begin
	zDocumentFeatures(_includeSuper);
	
	if self.hasSubclasses then
		write "==&gt; Subclasses of " &amp; self.name;
		self.zDocumentSubclasses(0);
	endif;

	
epilog

end;</source>
