//----------------------------------------------------------------
//	Created:	13 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//24/10/2019	JLGNS1	Bug 47151: JMT - Seals not being editable in General tab of Cargo Enquiry screen
vars
	editTable	: CM_EntryTable;
begin
	//epr par 32630 27/1/15 removed redundant code
	if table.parent &lt;&gt; null and table.parent.isKindOf(CM_EntryTable) then
		editTable := table.parent.CM_EntryTable;			
		editTable.cnEcResizeContents();
		editTable.accessRow(editTable.row).height := 120;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblSeals_lostFocus" id="78e1e381-1845-4054-bcc1-ec6f1d7f726d">
