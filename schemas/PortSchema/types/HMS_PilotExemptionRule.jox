        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="4ac617ca-63ff-4966-9b6d-125c4ec1cd05">
        <source>validateMe(_passport: CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2012	cnwndl1	Initial creation		Par 29496

*/

vars

	existingRule : HMS_PilotExemptionRule;

begin

	inheritMethod(_passport);
	
	if self.ruleName.trimBlanks = null then
//		app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Rule_name), null, null );
		app.raiseCMException1( Input_required_field_Required, app.getErrorString(Rule_name), null, null ); // cnwdb2	PAR 35364
	endif;
	
	if self.criteria &lt; 1 or self.criteria &gt; 3 then
//		app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Criteria), null, null );
		app.raiseCMException1( Input_required_field_Required, app.getErrorString(Criteria), null, null ); // cnwdb2	PAR 35364
	endif;
	
	if self.operator &lt; 1 or self.operator &gt; 5 then
//		app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Operator), null, null );
		app.raiseCMException1( Input_required_field_Required, app.getErrorString(Operator), null, null ); // cnwdb2	PAR 35364
	endif;
	
	if self.value &lt; 0 then
//		app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Value), null, null );
		app.raiseCMException1( Input_required_field_Required, app.getErrorString(Value), null, null ); // cnwdb2	PAR 35364
	endif;
	
	if self.myHarbour = null then
//		app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Harbour), null, null );
		app.raiseCMException1( Input_required_field_Required, app.getErrorString(Harbour), null, null ); // cnwdb2	PAR 35364
	else
		if not self.isTransient then
			existingRule := self.myHarbour.allPilotExemptionRules.getAtKey(self.myHarbour,self.ruleName);
			if existingRule &lt;&gt; null and existingRule &lt;&gt; self then
				app.raiseCMException2( Already_exists_valid, self.ruleName, app.getErrorString(Pilot_exemption_rule), null, null );
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="1483dba7-0d28-4d46-a244-c6c1c25e4a5d">
