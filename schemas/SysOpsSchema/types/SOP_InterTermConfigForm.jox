/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2010	conkc1	Initial creation

*/

vars

begin

	btnSave.enabled          := true;
	grpSource.enabled        := true;
	grpReleaseDetail.enabled := true;
	grpDestination.enabled   := true;
	cmbDefaultLane.enabled   := true;
	cmbDefaultGate.enabled   := true;
	cmbSubTerminal.enabled   := true;
	
	lblDefaultLane.enabled   := true;
	lblDefaultGate.enabled   := true;
	lblSubTerminal.enabled   := true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getGateInformation" id="18d24725-84a7-4358-838d-6b9ebe54c3d9">
        <updating/>
        <source>getGateInformation(gate : CM_Gate) updating;
/*
Purpose:			Get lane for this gate

Parameters:			Gate

Return Value:		

Date				Who		Reason
02 February 2010	conkc1	Initial creation

*/
vars

	gateArea 		: CM_GateArea;
	laneNumber		: Integer;
	lc				: CM_LaneController;
begin
	// Assuming one A-gate per terminal 
	self.cmbDefaultLane.clear();
	
	if gate &lt;&gt; null then
		gateArea := gate.getFirstAGate_IN();
		if gateArea &lt;&gt; null then
			if gateArea.laneCount &gt; 0 then
				self.cmbDefaultLane.enabled := self.cmbDefaultGate.enabled;
				foreach laneNumber  in 1 to gateArea.laneCount	do
					lc := gateArea.getLaneByNumber(laneNumber);
					
					if lc.isUnavailable or 										
						lc.laneDirection &lt;&gt; CM_LaneController.Is_In_Lane then	
						continue;												
					endif;														
					
					self.cmbDefaultLane.addItemObject(laneNumber.String, lc);
				endforeach;
			else
				self.cmbDefaultLane.enabled := false;
			endif;
		endif;

		self.cmbDefaultLane.setIndex(1);
	
	endif;

epilog

end;</source>
        <Parameter name="gate" type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTerminalAreas" id="fdf63b09-10ac-41b3-9426-5e917af82542">
        <updating/>
        <source>getSelectedTerminalAreas() : CM_TerminalAreaSet updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2010	conkc1	Initial creation

*/

vars
	size      : Integer;
	index     : Integer;
	objectSet : CM_TerminalAreaSet;
begin
	create objectSet transient;

	size := self.grpMultiSelect.mySelectedListBox.listCount;
	foreach index in 1 to size do
		objectSet.add (self.grpMultiSelect.mySelectedListBox.itemObject[index].CM_TerminalArea);
	endforeach;
	
	return objectSet;
epilog

end;</source>
        <ReturnType type="CM_TerminalAreaSet"/>
    </JadeMethod>
