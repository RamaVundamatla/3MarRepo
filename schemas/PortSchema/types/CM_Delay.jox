    <JadeMethod name="getVoyageJSLoLo" id="8115e40d-4944-4620-b477-00e1fbf23e48">
        <source>getVoyageJSLoLo() : CM_VoyageJobSheet;
//getVoyageJobSheet Renamed 11/04/2017
// ---------------------------------------------------------------------------
// Created:		03 January 2008 By Andrew Bishop cnwab1
//
// Purpose:	
//11/04/2017	cnwma1	TFS #4027:MSL - Voyage Side Profile - delay not showed	
// ---------------------------------------------------------------------------
vars
	tmpJS, vjs : CM_VoyageJobSheet;
begin
	if self.myVoyage = null then
		return null;
	endif;
	
	if self.myMachine = null then  
		return null;
	endif;
	

	if not self.myMachine.isCrane() then
		return null;
	endif;

	
	foreach tmpJS in self.myVoyage.allJobSheets discreteLock do
		
		if tmpJS.crane = self.myMachine.code then
			vjs := tmpJS;
		endif;
	endforeach;
	
	return vjs;
end;</source>
        <ReturnType type="CM_VoyageJobSheet"/>
    </JadeMethod>
    <JadeMethod name="getVoyageJSRoRoHold" id="e5102d96-5fb9-4da2-9f66-876813fa3a2e">
        <source>getVoyageJSRoRoHold(): CM_VoyageJobSheet;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2017	cnwma1	Initial creation

*/
vars
	tmpJS, vjs : CM_VoyageJobSheet;
begin
	if self.myVoyage = null then
		return null;
	endif;
	
	if self.myWorkPoint = null then  
		return null;
	endif;
	
	foreach tmpJS in self.myVoyage.allJobSheets discreteLock do
		
		if tmpJS.myWorkPoint = self.myWorkPoint then
			vjs := tmpJS;
		endif;
	endforeach;
	
	return vjs;
end;</source>
        <ReturnType type="CM_VoyageJobSheet"/>
    </JadeMethod>
