    <JadeMethod name="buildBackground" id="cc741f92-5cb9-4eed-90f2-5e37ca7d85cf">
        <updating/>
        <source>buildBackground() updating;

vars
	startDT	: TimeStamp;
	finishDT: TimeStamp;
begin
	// this method will rebuild the time and meter scales
	app.mousePointer := MousePointer_HourGlass;

	// get the parameters
	startDT	:= self.myViewController.viewStartDT;
	finishDT := self.myViewController.viewFinishDT;

	// rebuild the time scale	
	self.rebuildScaleTime(startDT, finishDT, false);

	// rebuild wharf scale
	self.rebuildScaleWharf();
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildEntireForeground" id="3be7b513-3538-457a-9587-bb444f876b5a">
        <updating/>
        <source>buildEntireForeground(_selectedMovement : CMIF_HMS_WorkingMovement; _scrollToSelected : Boolean) updating;
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 16/05/2012	cnwdap1		PAR #29427 New parameter for buildEntireForegroundForXViews method to prevent tidal summary form from being updated twice
vars

begin
	// clear the form and rebuild the ships
	app.mousePointer := MousePointer_HourGlass;

	// clear the form of all ships
	self.setMyCurrentWorkingMovement(_selectedMovement);

	// rebuild the view Draw drag pictures	
	self.rebuildShips();
	
	//self.buildEntireForegroundForXViews();							// PAR #29427
	self.buildEntireForegroundForXViews(_selectedMovement = null);		// PAR #29427

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_selectedMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_scrollToSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildEntireForegroundForXViews" id="3b4bff50-3a1e-487e-8244-31327cecbc6e">
        <updating/>
        <source>buildEntireForegroundForXViews(_updateTidalSummaryForm : Boolean) updating;
//-----------------------------------------
// Created: November 2004 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 16/05/2012	cnwdap1		PAR #29427 New parameter for this method to prevent tidal summary form from being updated twice
// 10/02/2012	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
vars

begin

	if self.mySeaViewForm &lt;&gt; null then
		self.mySeaViewForm.buildEntireForeground();
	endif;
	
	if self.myVoyageList &lt;&gt; null then
		self.myVoyageList.buildEntireForeground();
	endif;
	
	if self.myMovementsTableForm &lt;&gt; null then
		self.myMovementsTableForm.buildEntireForeground();
	endif;	

	//if self.myTidalSummaryForm &lt;&gt; null then								// PAR #29427
	if self.myTidalSummaryForm &lt;&gt; null and _updateTidalSummaryForm then		// PAR #29427
		self.myTidalSummaryForm.drawMe();
	endif;				
	
	if self.myTidalModelForm &lt;&gt; null and _updateTidalSummaryForm then											// PAR #33337
		self.myTidalModelForm.handleNotificationRefreshView(null, self.myCurrentWorkingMovement, null, null);	// PAR #33337
	endif;																										// PAR #33337

	if self.myVoyageMaintForm &lt;&gt; null then
		if self.myCurrentWorkingMovement &lt;&gt; null then
			self.myVoyageMaintForm.buildEntireForeground(self.myCurrentWorkingMovement.myWorkingVoyage);
		else
			self.myVoyageMaintForm.buildEntireForeground(null);
		endif;
	endif;
end;</source>
        <Parameter name="_updateTidalSummaryForm" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildMap" id="c7628739-f331-435f-9cfb-6b172458c6a6">
        <updating/>
        <source>buildMap() updating, protected;
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
vars
	progressTotalParts	: Integer;
	
begin
	self.endNotificationForSubscriber(self);
		
	// Setup progress bar info
	progressTotalParts := 4;
	self.progressStart(progressTotalParts, null, null, null,'Loading data into view');	
	self.modalDialogUpdateInfo('Loading Step 1 of ' &amp; progressTotalParts.String);				
	
	// Set user defined  colours
	self.setSystemDefinedColours();
	
	// Set terminals available for view within this Harbour
	self.setTerminalListForHarbour();
	
	// build the time scale
	self.myDrawTimeLabel.setSystemColours(self.myHarbour);	
	self.rebuildScaleTime(self.myViewController.viewStartDT, self.myViewController.viewFinishDT, true);

	// Update progress bar
	self.progressUpdate();
	self.modalDialogUpdateInfo('Loading Step 2 of ' &amp; progressTotalParts.String);				
	// Setup the view controls
	self.setupWharfControls();
	self.initSnapBerthSubMenus();	
	self.rebuildScaleWharf();
	
	// Update progress bar
	self.progressUpdate();
	self.modalDialogUpdateInfo('Loading Step 3 of ' &amp; progressTotalParts.String);				
	// Build default collections
	self.setMyCurrentWorkingMovement(null);
	self.myViewController.buildView_WorkingVoyageAndMove();		

	// Update progress bar
	self.progressUpdate();
	self.modalDialogUpdateInfo('Loading Step 4 of ' &amp; progressTotalParts.String);						
	// build all the ship sprites
	self.rebuildShips();

// cnwdad1 06/07/2007 - PAR #14399 - Notifications of changes are sometimes not being processed.
// Since we can't determine the cause, I moved this call to the epilog in case an exception is causing
// this method to bail out early for some reason.
//	self.registerNotifications();

	self.setCaption(self.getViewCaption());
	self.setNavigatorHeading(self.caption);		
epilog
// cnwdad1 06/07/2007 - PAR #14399 - Notifications of changes are sometimes not being processed.
// Since we can't determine the cause, I moved this call here in case an exception is causing
// this method to bail out early for some reason.
	self.registerNotifications();
	
	self.doResize();
	self.progressFinish();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildResourceButtons" id="d3cc8875-ebf5-4b5e-8bc7-72e8c4fa8f87">
        <updating/>
        <source>buildResourceButtons()updating, protected;

vars
	btn : CMUI_ButtonForToolbar;
	rd  : HMS_ResourceType;
	int : Integer;
	iter : Iterator;
	toolbar : CMUI_Toolbar;
	firstTime : Boolean;
begin
	// this method builds the resource icon indicator floating pallet

	if self.myHarbour = null
	or app.myRoot.allResourceTypes.isEmpty() then
		return;
	endif;

	iter := app.myRoot.allResourceTypes.createIterator;
	
	toolbar := self.frmToolbar;
	firstTime := true;
	
	while iter.next(rd) do
		if (not rd.iconVisibleOnView) 
		or rd.isNotAvailableForEntry then // CCMS 1350
			continue;
		endif;
		
		
		int := int + 1;
		btn := self.btnResource.loadControl(int).CMUI_ButtonForToolbar;
		btn.picture 	:= rd.iconUpState;
		btn.pictureDown := rd.iconDownState;
		btn.userObject 	:= rd;
		btn.enabled		:= false;
		btn.value		:= true;
		btn.visible 	:= true;
		btn.caption		:= rd.description;
		btn.bubbleHelp	:= rd.description;
		self.allResourceIdArray.add(int);
		
		if firstTime then
			toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);												
			firstTime := false;
		endif;
		toolbar.addButton(btn, CMUI_Toolbar.Control_Alignment_Left);

	endwhile;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);											

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calculateSpriteTopHeight" id="34697403-09b7-464a-869a-39722d8f4139">
        <updating/>
        <source>calculateSpriteTopHeight(	_movementObj : CMIF_HMS_WorkingMovement;
							_nextMoveObj : CMIF_HMS_WorkingMovement;
							_yTop : Real output;
							_yHeight : Real output) updating;
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning						
vars
	diff			: Real;
	minsInViewArea	: Real;
	
begin
	if global.isValidObject(_nextMoveObj) then
		_yHeight	:=	(_movementObj.occursOnDT.minutesDiff(_nextMoveObj.occursOnDT)) / self.minutesPerPixel;
	else
		_yHeight	:=	10;
	endif;
	
	// get the time position for the ship
	minsInViewArea := _movementObj.occursOnDT.minutesDiff(self.myViewController.viewFinishDT);
	
	_yTop	:=	((minsInViewArea / self.minutesPerPixel) - _yHeight).rounded; // set top to position needed to put pic in right place.
	//_yTop	:=	_yTop + 1;/////////// reposition for scale offset

	//Par 11056 HG
	// Windows limits forms and controls to a maximum height of 32,767 pixels. if the picture's calculated height is larger
	// than this (voyage movement over long period) then when height value is set it will only get set to 32,767.
	// This would leave the voyage movement picture short, which would mean the bottom of the pic would line up with wrong date.
	
	// As the Frame the pics are on, can also only have a max height of 32,767, we just need to work out if there is going to be a problem and recalculate.
	// We just need to make sure if it is truncated then lines up the appropriate end correctly. (other end will always be off screen so doesnt matter if short).
	
	// if required height for voyage movement means the pic will be truncated then do something.
	if _yHeight &gt; 32767 then
		if _movementObj.occursOnDT &lt; self.myViewController.viewStartDT
		and _nextMoveObj.occursOnDT &gt; self.myViewController.viewFinishDT // means that pic should cover whole of area.
		then
			// if voyage movement is over long period then height will be truncated consderabilly.
			// move top to just above viewable screen so it covers whole of screen.
			_yTop	:=	-20;
		else
			// means one end of pic needs to be shown on the screen. need to work out which.
			if  _yTop &lt; 0 then 	// Start of pic is off the top of the frame.
				//	As bottom will be truncated to 32767 need to bring top of picture down so bottom will line up with arrival date.
				diff	:=	_yHeight - 32767;  // Work out what the difference is between windows max and the height we have calculated.
				_yTop	:=	_yTop + diff; 	// this difference can be added to the top to push the picture down.
			else
				// if not above top of screen then dont worry as will be in correct position, the truncated end is the end not visible.
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_movementObj" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_nextMoveObj" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_yTop" type="Real" usage="output"/>
        <Parameter name="_yHeight" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="canDateRangeFitToScreen" id="5fc1d31e-b668-4dad-b685-17525965d513">
        <source>canDateRangeFitToScreen(_newStartDT: TimeStamp; _newEndDT: TimeStamp; _timeZoom : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     30 November 2005	cnwhjg1
//
// Purpose:     Par 11056 HG

// Windows limits forms and controls to a maximum height of 32,767 pixels. We need to check if time scale combined
// with date range is going to need a frame that is bigger than can be displayed. If it is then the appropriate 
//	message should be returned to user and action should not be allowed. 
// ----------   ----------  --------------------------------------------------
vars
	timeLabel	: HMS_DrawTimeLabelNEW;
	startDT		: TimeStamp;
	finishDT	: TimeStamp;
	newHeight	: Real;
	
begin
	timeLabel	:=	self.myDrawTimeLabel;
	startDT		:=	_newStartDT;
	finishDT	:=	_newEndDT;
	newHeight	:=	(finishDT.date - startDT.date) * 24 * 10 / (_timeZoom);
	
	// max height allowed is 32,767. so check for 32500 to leave some leeway for other
	// pictures to hang off end if needed.
	if newHeight &gt; 32500 then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_newStartDT" type="TimeStamp"/>
        <Parameter name="_newEndDT" type="TimeStamp"/>
        <Parameter name="_timeZoom" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearDragPictures" id="87a6a734-b8f2-4dad-80b5-449de76e1990">
        <updating/>
        <source>clearDragPictures() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.allDragPictures.purge();
	self.nextPicDragIndex := 0;
	
	//Null the reference so that it's not left invalid
	self.myCurrentDragPicture := null;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearVoyageFromView" id="9b605215-634a-4593-9168-d7f4ca0ddc7b">
        <source>clearVoyageFromView(_workingVoyage : CMIF_HMS_WorkingVoyage) protected;
// ---------------------------------------------------------------------------
// Created:     02 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	dragPict 	: HMS_GraphicalDragPicture;
	iter		: Iterator;
begin

	if _workingVoyage = null then
		return;
	endif;
	if self.allDragPictures.isEmpty then
		return;
	endif;	
	
	iter := self.allDragPictures.createIterator();
	self.allDragPictures.startKeyGeq(_workingVoyage, iter);
	
	while iter.next(dragPict) do
		if dragPict.myWorkingVoyage &lt;&gt; _workingVoyage then
			break;
		endif;
		delete dragPict;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="clearWharfControls" id="ee161cab-41bb-41f9-8c4c-fc5a79fc0620">
        <updating/>
        <source>clearWharfControls() updating;
//-----------------------------------------
// Created: August 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpWharfCntrl : HMS_WharfDrawControl;
begin
	foreach tmpWharfCntrl in self.allWharfDrawControls do
		tmpWharfCntrl.clearWharfControl();
	endforeach;	
	
end;</source>
    </JadeMethod>
