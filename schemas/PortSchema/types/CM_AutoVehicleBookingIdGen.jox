    <JadeMethod name="newExternalRefIdNotAlreadyUsed" id="350c4d3e-a0d5-436c-b3b7-ef6a046882f2">
        <source>newExternalRefIdNotAlreadyUsed(_newId : String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2023	navpw1	Initial creation TFS: 53898 (53961)

*/

vars
	vehicleBookingTimeslot : CM_VehicleBookingTimeSlot;

begin
	vehicleBookingTimeslot := self.myTerminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef.getAtKeyGeq(_newId);
	if vehicleBookingTimeslot = null or vehicleBookingTimeslot.externalReference &lt;&gt; _newId then
		// no existing onsite cargo with the same id.
		return true;
	endif;

	return false;
epilog

end;</source>
        <Parameter name="_newId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="newIdNotAlreadyUsed" id="1a39c6a1-5624-4af5-8f16-fc0a1e1c9399">
        <source>newIdNotAlreadyUsed(_newId: String): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 May 2023 navma1	Bug 58195: FR - EUP 53429 - BR - VBS changes MTN - null object reference.

*/

vars
	existingVbsSlot : CM_VehicleBookingTimeSlot;
	vbsTem			: CM_VehicleBookingTerminal;
begin
	
	vbsTem := self.myTerminal.myVehicleBookingTerminal;
	
	existingVbsSlot := vbsTem.allVBTimeslotsById[_newId];
	
	if existingVbsSlot = null then
		return true;
	endif;

	return false;
epilog

end;</source>
        <Parameter name="_newId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="fe16649d-dd84-422b-b575-9fd2c8379355">
        <updating/>
        <source>setForUpdate(_proxy: CM_AutoVehicleBookingIdGen) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2022	navsrk20	ChangeRequest 53898: EUP - VBS MTN - [2] - External Reference Code Generation

*/

vars

begin
	self.externalRefLength := _proxy.externalRefLength;
	self.externalRefPrefix := _proxy.externalRefPrefix;
	self.isExternalRefEnabled := _proxy.isExternalRefEnabled;
	inheritMethod(_proxy);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoVehicleBookingIdGen"/>
    </JadeMethod>
    <JadeMethod name="setPxyOtherAttributes" id="013d3fdc-bcbd-414c-a5cb-7ad7fb17f7c9">
        <updating/>
        <source>setPxyOtherAttributes(_externalRefLength : String; _externalRefPrefix : String; _isExternalRefEnabled : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2022	navsrk20	ChangeRequest 53898: EUP - VBS MTN - [2] - External Reference Code Generation

*/

vars

begin
	if _externalRefLength &lt;&gt; null then
		self.externalRefLength := _externalRefLength.Integer;
	endif;
	self.externalRefPrefix := _externalRefPrefix;
	self.isExternalRefEnabled := _isExternalRefEnabled;
	
epilog

end;</source>
        <Parameter name="_externalRefLength" type="String"/>
        <Parameter name="_externalRefPrefix" type="String"/>
        <Parameter name="_isExternalRefEnabled" type="Boolean"/>
    </JadeMethod>
</Class>
