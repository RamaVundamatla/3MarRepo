    <JadeMethod name="myTerminal" id="1fe40ff4-2ead-4d2c-9750-00a9855247e4">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
//--------------------------------------------------------------
//Created: 14 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := null;
	
	if self.myTerminal = null and self.myVoyage &lt;&gt; null then
		_value := self.myVoyage.myTerminal;
	endif;

end;</source>
