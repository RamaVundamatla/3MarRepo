    <JadeMethod name="adjustControlsForBulkEdit" id="28f5138f-37bd-4ac0-9a70-aa4671e49c90">
        <updating/>
        <source>adjustControlsForBulkEdit(_isBulkEdit : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 December 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot (Task 55831)
24 Apr 2023 		navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
24 Apr 2023 		navhl20	ChangeRequest 57733:[57734] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 02]
*/

vars

begin
	// Hide usnused Controls
	self.txtExternalReference.visible  := _isBulkEdit;
	self.lblExternalReference.visible  := _isBulkEdit;
	self.txtId.visible 				   := _isBulkEdit;
	self.idLabel.visible 			   := _isBulkEdit;
	//self.vbsSlotItems.visible 	   := _isBulkEdit;				//24.4.2023 navhl20 #57733[57734]
	self.lblCopySlots.visible 		   := _isBulkEdit;				//24.4.2023 navhl20 #57716[57718]
	self.txtCopySlots.visible 		   := _isBulkEdit;				//24.4.2023 navhl20 #57716[57718]
	
	// Move controls
	if not _isBulkEdit then
		self.lblStartDT.top  := 68;
		self.startDT.top 	 := 68;
		self.startTM.top	 := 68;
		
		self.lblEndDT.top 	 := 107;
		self.endDT.top 		 := 107;
		self.endTM.top 		 := 107;
		
		self.cmbCarrier.top  := 146;
		self.lblCarrier.top  := 146;
		
		self.cmbDriver.top 	 := 185;
		self.lblDriver.top 	 := 185;
		
		self.txtRemarks.top   := 224;
		self.lblRemarks.top   := 224;
		
		self.vbsSlotHeader.height := 283;
		self.height := 600;									//24.4.2023 navhl20 #57733[57734]
		self.minimumHeight := 600;							//24.4.2023 navhl20 #57733[57734]
		self.borderStyle := 1;
		
		self.lblVbsSlotType.top := 29;						//24.4.2023 navhl20 #57716[57718]
		self.cmbVbsSlotType.top	:= 29;						//24.4.2023 navhl20 #57716[57718]
		self.chkPreGateIn.top 	:= 29;						//24.4.2023 navhl20 #57716[57718]
		self.chkPreGateOut.top 	:= 68;						//24.4.2023 navhl20 #57716[57718]
		self.chkKiosk.top 		:= 107;						//24.4.2023 navhl20 #57716[57718]
		self.lblSubCarrier.top	:= 146;						//24.4.2023 navhl20 #57716[57718]
		self.cmbSubCarrier.top	:= 146;						//24.4.2023 navhl20 #57716[57718]
		self.lblVehicle.top  	:= 185;						//24.4.2023 navhl20 #57716[57718]
		self.cmbVehicle.top		:= 185;						//24.4.2023 navhl20 #57716[57718]
		self.vbsSlotItems.top	:= 310;						//24.4.2023 navhl20 #57733[57734]
		self.vbsSlotItems.height:= 200;						//24.4.2023 navhl20 #57733[57734]
	endif;
epilog
	
end;</source>
        <Parameter name="_isBulkEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="adjustControlsForEdit" id="eac7e6fd-bb73-4095-9390-02442d4df85a">
        <source>adjustControlsForEdit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2023	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]

*/

vars

begin
	self.txtCopySlots.visible 		:= false;
	self.lblCopySlots.visible 		:= false;
	self.lblVbsSlotType.top 		:= self.lblCopySlots.top;
	self.cmbVbsSlotType.top 		:= self.txtCopySlots.top;
	self.chkPreGateIn.top 			:= self.txtCopySlots.top;
	self.idLabel.top 				:= self.lblVbsSlotType.top + 25;
	self.txtId.top 					:= self.lblVbsSlotType.top + 25;
	self.chkPreGateOut.top 			:= self.lblVbsSlotType.top + 25;
	self.lblExternalReference.top 	:= self.idLabel.top + 25;
	self.txtExternalReference.top 	:= self.idLabel.top + 25;
	self.chkKiosk.top 				:= self.idLabel.top + 25;
	self.lblStartDT.top 			:= self.lblExternalReference.top + 25;
	self.startDT.top 				:= self.lblExternalReference.top + 25;
	self.startTM.top 				:= self.lblExternalReference.top + 25;
	self.lblEndDT.top 				:= self.lblStartDT.top + 25;
	self.endDT.top 					:= self.lblStartDT.top + 25;
	self.endTM.top 					:= self.lblStartDT.top + 25;
	self.lblCarrier.top 			:= self.lblEndDT.top + 25;
	self.cmbCarrier.top 			:= self.lblEndDT.top + 25;
	self.lblSubCarrier.top 			:= self.lblEndDT.top + 25;
	self.cmbSubCarrier.top 			:= self.lblEndDT.top + 25;
	self.lblDriver.top 				:= self.lblCarrier.top + 25;
	self.cmbDriver.top 				:= self.lblCarrier.top + 25;
	self.lblVehicle.top 			:= self.lblCarrier.top + 25;
	self.cmbVehicle.top 			:= self.lblCarrier.top + 25;
	self.lblRemarks.top 			:= self.lblDriver.top + 25;
	self.txtRemarks.top 			:= self.lblDriver.top + 25;
	self.vbsSlotHeader.height		:= self.vbsSlotHeader.height - 25;
	self.vbsSlotItems.top 			:= self.vbsSlotItems.top - 25;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="adjustTxtCopySlotsControl" id="f42f3b80-1bd7-4f68-9d5d-313c9df51a37">
        <source>adjustTxtCopySlotsControl();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jul 2024 navbs1 	Bug 64332: FR | 53729 - Delivery Dispatch screen - 1239 error

*/

vars
	bookingItem: CM_VehicleBookingTimeSlotItem;
	vbsItemSet : CM_VehicleBookingTSItemSet;

begin
	if self.vehicleBookingMode &lt;&gt; self.MODE_ADD then 
		return;
	endif;
	if self.txtCopySlots.text.Integer &gt; 1 then 
		return;
	endif;
	vbsItemSet :=self.myProxyVehicleBookingTimeSlot.allVehicleBookingItems;
	if vbsItemSet.size = 0 then 
		self.txtCopySlots.enabled := true;
	else
		foreach bookingItem in vbsItemSet do 
			if bookingItem.myTrackedItem &lt;&gt; null then
				self.txtCopySlots.enabled := false;
				break;
			else
				self.txtCopySlots.enabled := true;
			endif;
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
