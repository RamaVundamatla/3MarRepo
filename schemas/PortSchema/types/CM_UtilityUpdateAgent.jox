        <source>utlUpdateAuditQualify(pProxyAudit:CM_Audit; _financialObject : CM_FinancialObject;_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realAudit:CM_Audit;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyAudit.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyAudit.pxyGetRealObjectAndEdition(realAudit, expectedEdition);
	
	if realAudit = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Audit.name, null, null);
		return;
	endif;

	app.myValUA.valAuditQualify(realAudit, pProxyAudit);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realAudit);

	if _passport.noErrors and realAudit.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Audit', null, null);
		return;
