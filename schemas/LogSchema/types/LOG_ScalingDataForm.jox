    <JadeMethod name="addItem" id="a9632511-5d3c-426d-af11-e50fb7945a52">
        <updating/>
        <source>addItem() updating;
//--------------------------------------------------------------
//Created: April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	scalingDtl	: CM_LogScalingDtl;
	theRow,
	roundMin, roundMax : Integer;	
begin
	self.setFieldSEDs(roundMin, roundMax);
	create scalingDtl transient;
	scalingDtl.setForUpdateProxy(tblItem.getValueByName(ETRow_LogId).String,
						tblItem.getValueByName(ETRow_LogCondition).String,
						roundMin, roundMax,tblItem.getValueByName(ETRow_ScalerCode).String);
	
	// check all fields have been entered

	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();

	scalingDtl.checkFieldsNotNull();
	self.checkForDuplicateScalingDtl(scalingDtl,tblItem.getValueByName(ETRow_LogId).String);
	
	if app.myPassport.hasErrors then
		app.showErrorWarningDialog('Scaling Data', app.myPassport, ErrWarnMode_Add);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		delete scalingDtl;			
		return;
	endif;

	scalingDtl.setHdrForProxy(self.myCurrentTicket);
	self.allScalingDtls.add(scalingDtl);
	
	self.calcRemaining(false);

	if (not app.myPassport.noErrors) then
		app.showErrorWarningDialog('Loadout', app.myPassport, ErrWarnMode_Add);
		self.allScalingDtls.remove(scalingDtl);
		delete scalingDtl;
		return;
	endif;
	on CM_Exception do null;	// disarm the validation ex handler

	self.tblAll_ShowScalingDtl(scalingDtl, 0);
	self.setFieldLogId();
	self.setEnableObjects();
	tblItem.setFocus();
epilog
	self.tblItem.goToRowByName(ETRow_SedMin);
	self.tblItem.setFocus;
end;</source>
    </JadeMethod>
    <JadeMethod name="calcRemaining" id="99302872-92e3-405d-ade2-45abda06bbef">
        <source>calcRemaining(_pieceCntChanged : Boolean);
// ---------------------------------------------------------------------------
// Created:     03 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	required : Integer;
begin

	required := (self.totalRequired - self.allScalingDtls.size);

	if required &lt; 0 and not _pieceCntChanged then
		app.raiseCMException1(NUM_TICKETS_EXCEEDED, txtRemaining.text, null, null);	
		return;	
	endif;
	
	if not _pieceCntChanged then
		txtRemaining.text := required.String;
	endif;
	
end;</source>
        <Parameter name="_pieceCntChanged" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForDuplicateScalingDtl" id="1bca19a8-d353-41e9-b59a-67e5085f9149">
        <source>checkForDuplicateScalingDtl(_scalingDtl : CM_LogScalingDtl; _newID : String)protected;
//--------------------------------------------------------------
//Created: 12 April 2002 By: cnwgd1
//--------------------------------------------------------------
// cnwrd1 3.11.08  par  17456 updated to include _newID parameter for testing before setting the proxy
vars
	obj : CM_LogScalingDtl;
begin

	if not self.allScalingDtls.isEmpty then
		foreach obj in self.allScalingDtls do
			if obj &lt;&gt; _scalingDtl then
				if obj.logID = _scalingDtl.logID then
					app.raiseCMException1(VB_DUPLICATED_ITEM, 'Log ID ' &amp; _scalingDtl.logID, 'id', null);
					break;
				endif;
				if obj.logID = _newID then
					app.raiseCMException1(VB_DUPLICATED_ITEM, 'Log ID ' &amp; _newID, 'id', null);
					break;
				endif;
			endif;
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_scalingDtl" type="CM_LogScalingDtl"/>
        <Parameter name="_newID" type="String"/>
    </JadeMethod>
