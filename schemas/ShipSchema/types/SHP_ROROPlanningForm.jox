    <JadeMethod name="timerEvent" id="2db8497a-a722-4685-b960-26dac1af873e">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*
Purpose:	// PAR 28544 noticed that 40 footers were drawing wrong on note		
Date		Who		Reason
05 December 2011	cnwab1	Initial creation
28 dec 2012	cnwrs1	try and stop crashes if voyage deleted while window open
*/
vars	
	anLC : CM_LocationsController;
	defn : CM_DeckItem;
	job	 : CM_Job;
	now	: TimeStamp;
	timeDiff	: Time;
	posNeg,
	numDays : Integer;
	str : String;
	isInvalid : Boolean;
begin
	now := app.actualTimeServer();	// 9/5/16 cnwmp6 TFS 488 - Multi timezone support
	app.mousePointer	:=	Busy;
	on Exception do app.handleDeletedObject(exception, self.myCurrentVoyage, isInvalid);
	on Exception do app.handleDeletedObject(exception, self.myROROPlanDrawController, isInvalid); //cnwrd1 par 32400 moved here.
	
	str := self.myCurrentVoyage.code;
	if isInvalid then
		self.myCurrentRORO := null;
		self.myCurrentVoyage := null;
		self.myAssistant.comboBoxROROVoyageStructure(self.cmbVoyage,null,self.myTerminal);
		return;
	endif;
	if eventTag = 1 then
		
		foreach defn in self.allLocnsForNotes discreteLock do
			anLC := defn.getFirstLC();
			// 28878 Dec 2011 on creation of a GC colour coding area call the doUserNotifyLayers (as is done from a move)
			// 			to draw the cargo layer and show/hide covered container positions
			//	the timeDiff code is an attempt to limit this to a create
			
			if anLC.isKindOf(CM_ROROGCController) then 
				timeDiff := anLC.createdTime.differenceAsTime(now, posNeg, numDays);
				if numDays = 0 and timeDiff.hour = 0 and timeDiff.minute = 0 then
					 //epr par 29608 26/6/12
					//	self.doFrameDrawDetectOtherGraphic(anLC.CM_ROROGCController.myGCDefn.myLayout);
					self.doUserNotifyLayers(EVENT_RORO_ITEM_UPDATE, defn.myLayout, 0, null);
				endif;
			else
			//epr 29079 3/2/2011
				if defn.isOOTL then
					timeDiff := anLC.createdTime.differenceAsTime(now, posNeg, numDays);
					if numDays = 0 and timeDiff.hour = 0 and timeDiff.minute = 0 then
						//epr par 29608 26/6/12
						//	self.doFrameDrawDetectOtherGraphic(defn.myLayout);
						self.doUserNotifyLayers(EVENT_RORO_ITEM_UPDATE, defn.myLayout, 0, null);
					endif;
					
					// PAR 29807 when the first LOAD OOTL is moved to the deck, the OOTL layer is created, if this is the case then show it
					timeDiff := defn.myLayout.myDeckLayer.createdTime.differenceAsTime(now, posNeg, numDays);
					if numDays = 0 and timeDiff.hour = 0 and timeDiff.minute = 0 then
						self.doUserNotifyLayers(EVENT_RORO_LAYER_UPDATE, defn.myLayout.myDeckLayer, 0, null);
					endif;
				endif;
			endif;
			
			str := self.myROROPlanDrawController.modeWork.String;
			if isInvalid then
				self.myROROPlanDrawController := null;
				return;
			endif;
			self.myROROPlanDrawController.doDrawObject(anLC);
		endforeach;
		
		// 28750 Dec 2011 refresh Deck Job table
		foreach job in self.allJobsForNotes discreteLock do
			self.doJobNotificationUpdate(EVENT_UPDATE_VOYAGE_AREA, null, job);
		endforeach;
	endif;
	
epilog
	endLoad;
	self.startedTimer := false;
	self.allLocnsForNotes.clear();
	self.allJobsForNotes.clear();
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toggleCCButtons" id="73f03566-8f4a-4ee6-a52f-dd851543ef06">
