    <JadeMethod name="getDisplayStringForAttribute" id="fd0c5fd1-0743-4237-93e7-b3c72710d53c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     20 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_LotId then
		return self.id;
	elseif _attrName = ETRow_MyManifest then
		if self.myManifest &lt;&gt; null then 
			return self.myManifest.id;
		else
			return null;
		endif;
//	elseif _attrName = ETRow_CalendarCode then
//		return self.code;
//	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="0daf63b0-14dc-427f-8ff3-231ae119072c">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     01 February 2006 by cnwhg1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyLot : CM_Lot;	
	completedOK		: Boolean;
	
begin

	proxyLot := inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyLot;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyLot;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="925b6f73-8828-4a8c-a1c0-c2db5caf965b">
        <updating/>
        <source>setForCreate(_pxyLot : CM_Lot) updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     create proxy 
// ----------   ----------  --------------------------------------------------
vars

begin	
	self.setForUpdate(_pxyLot);

epilog

end;</source>
        <Parameter name="_pxyLot" type="CM_Lot"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="25bc8b55-2ca7-4d3e-bf53-f206216562c2">
        <updating/>
        <source>setForUpdate(_pxyLot : CM_Lot) updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	self.id 					:= _pxyLot.id.trimBlanks;
	self.myManifest 			:= _pxyLot.myManifest;
end;</source>
        <Parameter name="_pxyLot" type="CM_Lot"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2bffcb6d-5bd2-4b5f-b6fc-2a6b36803c61">
        <updating/>
        <source>setProxy(_id : String; _manifest : CM_Manifest) updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	calendar : CM_Calendar;
begin

		self.raiseExceptionIfNotTransient(method);
		self.id 			:= _id[1:30];
		self.myManifest		:= _manifest;

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_manifest" type="CM_Manifest"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="402fe6ed-7761-4a91-9a73-897cdc19421d">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     02 February 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Id', null, null);
		app.raiseCMException(Input_required_field_Id, null, null); // cnwdb2	PAR 35364


	endif;
	if self.myManifest = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Manifest', null, null);
		app.raiseCMException(Input_required_field_manifest, null, null);
	endif;	
end;</source>
    </JadeMethod>
</Class>
