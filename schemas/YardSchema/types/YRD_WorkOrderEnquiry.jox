    <JadeMethod name="buildActionTasksMenu" id="9d74e96e-81dc-44bb-be10-090fcf0227eb">
        <source>buildActionTasksMenu( _wo : CM_WorkOrder);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06/01/2010	cnwrd1	Initial creation
24/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders - change signature, other changes
16 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
27 Sep 2023	navma1  ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
*/

vars
	mnuChild,
	mnuMaster	: MenuItem;
	mnuIndex 	: Integer;	
	task 		: CM_WorkOrderDtl;
	showMenu 	: Boolean;
	ignoreAction : Boolean;
begin

	showMenu 		  			   := false;
	mnuMaster 		  			   := self.mnuActionTasks;
	mnuMaster.visible 			   := true;
	mnuMaster.enabled 			   := true;
	self.mnuActionTaskStub.visible := false;
	
	ignoreAction := _wo.ignoreAutoTaskAction();					//27.09.2023 navma1 #59638
	foreach task in _wo.allWoDtls do
		if /*ignoreAction or*/ task.canActionTask then			//16.03.2023 navma1 #56457:[56458]	
			showMenu := true;
			mnuIndex := mnuIndex + 1;
			mnuChild := mnuMaster.getMenuItem(mnuIndex); 		// check if the menu is already cloned
			if mnuChild = null then
				mnuChild := mnuMaster.loadSubMenu(mnuIndex); 	// clone menu
			endif;
			
			mnuChild.caption 	:= task.getDisplayString(true);
			mnuChild.visible 	:= true;
			mnuChild.enabled 	:= true;
			mnuChild.userObject := task;
		endif;
	endforeach;
	
	
	while true do
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex);
		if mnuChild = null then
			break;
		endif;
		mnuChild.visible := false;
	endwhile;
	
	self.mnuActionTasks.visible := showMenu;
epilog

end;</source>
        <Parameter name="_wo" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="buildCashReceiptCancelMenu" id="6d836947-23b4-4655-a89f-a5089213e970">
        <source>buildCashReceiptCancelMenu( _wo : CM_WorkOrder);
/*
Purpose:	TFS 42401		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/


	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	mnuChild, mnuMaster	: MenuItem;
	mnuIndex : Integer;	
	showMenu : Boolean;
	
	receipt : CM_CashReceipt;
begin
	self.mnuCRPaymentStatusCancel.visible := false;

	if _wo.allCashReceipts.isEmpty() then
		return;
	endif;

	showMenu := false;
	
	mnuMaster := self.mnuCRPaymentStatusCancel;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	self.mnuCRPaymentStatusCancelSub.visible := false;

	self.mnuCRPaymentStatusCancel.translateCaption(Xlat_0023124, null);// JLGAB1 08MAR19
	
	
	if not app.isSpecial() then // MARCH19 if special can change to any payment status
		foreach receipt in _wo.allCashReceipts do
			if receipt.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED then //Needs to only approved cash Receipts
				continue;
			endif;
	
			showMenu := true;
			mnuIndex := mnuIndex + 1;
			mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
			if mnuChild = null then
				mnuChild := mnuMaster.loadSubMenu(mnuIndex); // clone menu
			endif;
			mnuChild.caption := receipt.externalInvoiceNumber &amp; " - " &amp;  receipt.getPaymentStatusStr(receipt.paymentStatus); // getDescription();
			mnuChild.visible := true;
			mnuChild.enabled := true;
			mnuChild.userObject := receipt;
			
				
		endforeach;
	endif;
	
	
	while true do
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex);
		if mnuChild = null then
			break;
		endif;
		mnuChild.visible := false;
	endwhile;
	
	// JLGAB1 08MAR19 update  payment status
	if app.isSpecial() and not showMenu then
			self.showPaymentStatusMenu(_wo, mnuMaster);
			showMenu := true;
	endif;

	self.mnuCRPaymentStatusCancel.visible := showMenu;
epilog

end;</source>
        <Parameter name="_wo" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="buildCompleteTaskMenu" id="37f29315-6dfa-4444-81a4-942e3fd814b1">
        <source>buildCompleteTaskMenu( _wo : CM_WorkOrder);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
*/

vars
	mnuChild,
	mnuMaster	: MenuItem;
	mnuIndex 	: Integer;	
	task		: CM_WorkOrderDtl;
	showMenu 	: Boolean;
begin

	showMenu				 := false;
	mnuMaster 				 := self.mnuCompleteTask;
	mnuMaster.visible		 := true;
	mnuMaster.enabled		 := true;
	self.mnuToDoTask.visible := false;
	
	
	foreach task in _wo.allWoDtls do
		if task.canCompleteToDoTask then
			showMenu := true;
			mnuIndex := mnuIndex + 1;
			mnuChild := mnuMaster.getMenuItem(mnuIndex); // check if the menu is already cloned
			
			if mnuChild = null then
				mnuChild := mnuMaster.loadSubMenu(mnuIndex); // clone menu
			endif;
			
			mnuChild.caption     := task.getDisplayString(true);
			mnuChild.visible     := true;
			mnuChild.enabled     := true;
			mnuChild.userObject  := task;
			mnuChild.helpKeyword := CMUI_TasksForm.name &amp; ":" &amp; TASK_MODE_COMPLETE.String;
		endif;			
	endforeach;
	
	
	while true do
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex);
		if mnuChild = null then
			break;
		endif;
		mnuChild.visible := false;
	endwhile;
	
	self.mnuCompleteTask.visible := showMenu;
epilog

end;</source>
        <Parameter name="_wo" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="buildUsersCombo" id="d6d436df-e4dc-4945-bb58-d68bdf27b36f">
        <source>buildUsersCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	user			: CM_User;
begin
	self.cmbUsers.addItem("");
	
	foreach user in app.myRoot.allUsers where not user.isNotAvailableForEntry do
		if user.isSuperUser  then
			continue;
		endif;
		self.cmbUsers.itemObject[self.cmbUsers.addItem(user.userName &amp; ' (' &amp; user.code &amp; ')')] := user;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="canCompleteToDoWLE" id="40fbffe8-af3a-4e1c-a3b5-77654a2e4826">
        <source>canCompleteToDoWLE(_wle: CM_WOToDoWLE) : Boolean;
/*
Purpose - 	
Who - NAVAB1
Date - 27SEP2023
ADO - CR 60699 TASK 60700
Functionality Moved From WO Opeartion to WO Enquiry
23 Aug 2024 navlc30 Bug 65665: EUP | Complete Job button should not be available on the Unallocated tab for the VAS work orders
*/

vars
	toDoTask : CM_ToDoTask;
	toDoTaskDesc : CM_ToDoTaskDesc;
	trxType : CM_TransactionType; 
begin
	toDoTaskDesc := _wle.job.CM_WOToDoTaskJob.myToDoTaskDesc;
	trxType := app.myRoot.allTransactionTypes[toDoTaskDesc.trxTypeOnCompletion]; 
	if trxType &lt;&gt; null and trxType.trxGroup &lt;&gt;  TRANS_TYPE_GROUP_WO then 
		if _wle.myTrackedItem = null then
			return false;
		endif;
	endif;

	toDoTask := self.getToDoTask(_wle);

	if toDoTask = null or toDoTask.status = STATUS_COMPLETE then
		return false;
	endif;
	
	return app.myPassport.myUser.canCompleteTodoTask(toDoTask.myTerminal, toDoTask.toDoTaskDesc);

epilog

end;</source>
        <Parameter name="_wle" type="CM_WOToDoWLE"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
