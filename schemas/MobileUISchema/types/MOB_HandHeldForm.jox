    <JadeMethod name="handleCmdButtons" id="41083362-0ab7-47a9-b335-3514cfec9068">
        <updating/>
        <source>handleCmdButtons(_buttonNo : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:	31 December 2008 By Graeme Black cnwgb1
// Purpose: One of our soft command buttons was clicked. 
//          Send this fact to the form
//			PNL CCMS 1794  PAR 18797
// ---------------------------------------------------------------------------
vars
begin
	if     _buttonNo = 1 then
		self.handleBtnOne();
	elseif _buttonNo = 2 then
		self.handleBtnTwo();
	elseif _buttonNo = 3 then
		self.handleBtnThree();
	elseif _buttonNo = 4 then
		self.handleBtnFour();
	elseif _buttonNo = 5 then
		self.handleBtnFive();
	endif;
		
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_buttonNo" type="Integer"/>
