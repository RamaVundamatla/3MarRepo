    <JadeMethod name="xlatHasChanges" id="c1531c2d-1e57-414e-bfb2-ff800981d5b0">
        <source>xlatHasChanges() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions
28 August 2023		jlizm1	TFS 59551 Kiosk Additional Question

*/

vars
	pxyQuestion : CM_KioskTranslation;
	pxyErrorMsg	: CM_KioskTranslation;
	
begin

	if self.selectedLocale = null then
		return false;
	endif;

	if self.myProxyKioskObject = null then
		if self.txtQuestion.text &lt;&gt; "" or self.txtErrorMessage.text &lt;&gt; "" then
			return true;
		endif;
		return false;
	endif;
	
	if self.myProxyKioskObject.isKindOf(CM_KioskAdditionalQuestion) then
		pxyQuestion := self.myProxyKioskObject.CM_KioskAdditionalQuestion.allQuestions[self.selectedLocale.localeId];
	else
		pxyQuestion := self.myProxyKioskObject.CM_KioskPPEQuestion.allQuestions[self.selectedLocale.localeId];
	endif;	
	
	if pxyQuestion &lt;&gt; null then
		if pxyQuestion.text &lt;&gt; self.txtQuestion.text then
			return true;
		endif;
	else
		if self.txtQuestion.text &lt;&gt; "" then
			return true;
		endif;
	endif;
	
	
	if self.myProxyKioskObject.isKindOf(CM_KioskAdditionalQuestion) then
		pxyErrorMsg := self.myProxyKioskObject.CM_KioskAdditionalQuestion.allErrorMessages[self.selectedLocale.localeId];
	else
		pxyErrorMsg := self.myProxyKioskObject.CM_KioskPPEQuestion.allErrorMessages[self.selectedLocale.localeId];
	endif;	

	if pxyErrorMsg &lt;&gt; null then
		if pxyErrorMsg.text &lt;&gt; self.txtErrorMessage.text then
			return true;
		endif;
	else
		if self.txtErrorMessage.text &lt;&gt; "" then
			return true;
		endif;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
