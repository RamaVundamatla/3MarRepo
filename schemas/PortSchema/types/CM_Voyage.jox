    <JadeMethod name="addDefCutoffsForOperator" id="f0a2f913-82a8-411f-971e-f9f63fda87f6">
        <updating/>
        <source>addDefCutoffsForOperator(_cutoffOperator : CM_Operator) updating;
// ---------------------------------------------------------------------------
// Created:	26 March 2010 By Graeme Black cnwgb1 PAR 23207
// Purpose:	Add a set of Receival Cutoffs for a voyage for a terminal (and for an operator, if specified)
// --------------------------------------------------------------------------- 
// 06/03/2012	cnwcs5	par 29158 - EDI Booking cutoff
vars
	defaultsList 	: CM_RecCutoffDefsBySortKey;
	cutoff			: CM_ReceivalCutoffDef;	// par 29158
	recCutoffDef 	: CM_ReceivalCutoffTermDef;
	operatorDefList : CM_RecCutoffOpTermByDefDict;
	operatorTermDef : CM_ReceivalCutoffOpTerm;
	voyageCutoff 	: CM_ReceivalCutoffVoyage;
	earlyTSPN, cutoffTSPN, //04/03/2025	navkc1 JIRA Story MTN-34227
	earlyTS, cutoffTS		: TimeStamp;
begin
	// Get the Terminal Defaults
	create defaultsList transient;
	
	foreach recCutoffDef in self.myTerminal.allReceivalCutoffDefs where recCutoffDef.isAvailableForEntry do
		defaultsList.add(recCutoffDef);
	endforeach;
	
	// Get any Operator Defaults for this terminal
	if _cutoffOperator &lt;&gt; null then
		operatorDefList := _cutoffOperator.getConfigForTerminal(AllReceivalRestrictions, app.myPassport.myTerminal).CM_RecCutoffOpTermByDefDict;
	endif;	

	foreach recCutoffDef in defaultsList do
		
		cutoff := recCutoffDef;
		
		// Check there are no overrides for this code for this operator on this terminal.
		if operatorDefList &lt;&gt; null then
			foreach operatorTermDef in operatorDefList do
				if operatorTermDef.myReceivalCutoffTermDef.code = recCutoffDef.code then

					cutoff := operatorTermDef;
					break;
				endif;
			endforeach;
		endif;
		
		// translate into actual date/times
		//cutoff.getCutoffsForVoyage (self, earlyTS, cutoffTS);	// par 29158 - March 2012
		
		cutoff.getCutoffsForVoyage (self, earlyTS, cutoffTS);
		cutoff.getCutoffsPNForVoyage(self, earlyTSPN, cutoffTSPN);//04/03/2025	navkc1 JIRA Story MTN-34227 
		
		create voyageCutoff transient;
		
		voyageCutoff.setProxy(recCutoffDef.code, cutoffTS, earlyTS, self, _cutoffOperator, 
							cutoffTSPN, //04/03/2025	navkc1 JIRA Story MTN-34227
							earlyTSPN, //04/03/2025	navkc1 JIRA Story MTN-34227
							null,null,null,null,null);
				
	endforeach;
	
epilog
	delete defaultsList;
end;</source>
        <Parameter name="_cutoffOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="addPortToAllPorts" id="6c92f6c7-a588-4bf2-9759-1027c45d8a82">
        <updating/>
        <source>addPortToAllPorts(_port : CM_Port input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Apr 2009	cnwer1	Initial creation
25 May 2009	cnwkpd1	PAR #19764 - Tidy up proxy in epilog
//16 Apr 2018	jlgrs1	TFS 38147 fixup PortRotation addition (make the proxy transient)
21 Febuary 2023 jlier1 TFS 56686 - also make the port active
*/

vars

	pxyRotation,
	portRotation : CM_PortRotation;
begin
	if _port = null then
		return;
	endif;
	
	if not _port.isActive then
		_port.setIsActive(true);
	endif;
	
	if not self.includesPort(_port) then
		create pxyRotation transient;
		pxyRotation.setProxy(_port, self);
		
		if not self.isTransient then
			create portRotation persistent;
			portRotation.setForCreate(pxyRotation, self);
		endif;
		self.allPorts.add(_port);
		
	endif;

	
epilog
	delete pxyRotation;			// KPD 25/05/2009
	
end;</source>
        <Parameter name="_port" type="CM_Port" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addToGlobalAllVoyages" id="4343383e-3c75-46ec-93c4-458bec3305fd">
        <source>addToGlobalAllVoyages() protected;

/*

Purpose:			Add the receiver to the manual collections of all voyages on its
					parent Global Voyages


Return Value:		None


Date		Who		Reason
10 Apr 2008	cnwkpd1	PAR #16378 - Initial creation

*/

vars
	arrivalGlbVoy,
	departGlbVoy	: CM_VoyageGlobal;
	
begin
	arrivalGlbVoy := self.myVoyageGlobalArrival;
	
	if arrivalGlbVoy &lt;&gt; null and self.isTransient = arrivalGlbVoy.isTransient then
		arrivalGlbVoy.allVoyages.add(self);
	endif;
	
	departGlbVoy := self.myVoyageGlobalDeparture;
	if departGlbVoy &lt;&gt; null and departGlbVoy &lt;&gt; arrivalGlbVoy and self.isTransient = departGlbVoy.isTransient then
		departGlbVoy.allVoyages.add(self);
	endif;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addVoyAllocationTotals" id="244520d8-1ac3-4d55-b459-5cdabeb00bf9">
        <source>addVoyAllocationTotals( _voyAlloc : CM_VoyageAllocation;
						_voyageAllocations : ObjectArray input; 
						_totals : IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2011	cnwer1	Initial creation

*/

vars
	idx , oldValue: Integer;
begin	
	if _voyAlloc = null then
		return;
	endif;
		
	idx:=_voyageAllocations.indexOf(_voyAlloc);
	
	oldValue:=_totals[idx];
	_totals[idx]:=oldValue+1;
			
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <Parameter name="_voyageAllocations" type="ObjectArray" usage="input"/>
        <Parameter name="_totals" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="applySurchargesForMovements" id="cb24f8c9-fdcd-426e-8729-699e34f5ad34">
        <source>applySurchargesForMovements();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/06/2018	jlgdap1		Initial creation TFS 39355 PEL1 Pilot Surcharges
//
vars
	invoice, marineInvoice : CM_Invoice;
	iter : Iterator;
	invoiceType : CM_InvoiceDesc;
	surcharges : CM_InvoiceTypeSurchargeExempt;
	pilotSurcharge : CM_InvTypePilotSurcharge;
	movement : HMS_VoyageMovement;
	timings : HMS_MarineServicesTimings;
	invoiceLine : CM_InvoiceLine;
	seqNum : Integer;
	resUsed, pilotResUsed : HMS_ResourceUsed;

begin
	// get the first marine services invoice for this voyage
	iter := self.allInvoices.createIterator();
	while iter.next(invoice) do
		if invoice.isMarineServiceInvoice then
			marineInvoice := invoice;
			break;
		endif;
	endwhile;
	if marineInvoice = null then
		return;
	endif;
	
	// get the invoice type from the marine services invoice, and see if it has any surcharges
	invoiceType := marineInvoice.invoiceType;
	surcharges := invoiceType.mySurchargeAndExemptions;
	if surcharges = null then
		return;
	endif;
	
	// does the surcharge include any pilot surcharges?
	if surcharges.allInvTypePilotSurcharges.isEmpty then
		return;
	endif;
	
	// check whether any of the mvoements for this voyage need a pilot surcharge create

	foreach movement in self.myHMSVoyageData.allVoyageMovements discreteLock do
		timings := movement.myMarineServiceTimings;
		if timings = null then
			continue;
		endif;
		if not timings.pilotSurchargeInvLIneTypeRTS and not timings.pilotSurchargeInvLIneTypeVNR then
			continue;
		endif;
		
		
		// TFS 39355 get the resource used for the pilot
		foreach resUsed in movement.allResourceUsed do
			if resUsed.myResource.isResourceForClass(HMS_ResourceForPilot) then
				pilotResUsed := resUsed;
				break;
			endif;
		endforeach;
			
		// create an invoice line if required for each invoice line type in the surcharges.allInvTypePilotSurcharges set
		foreach pilotSurcharge in surcharges.allInvTypePilotSurcharges do
			if timings.pilotSurchargeInvLIneTypeVNR and pilotSurcharge.getNotReadyInvLineType &lt;&gt; null then
			
				// TFS 39355
				self.applySurchargesForPilot(pilotSurcharge.getNotReadyInvLineType, marineInvoice, pilotResUsed); // TFS 39355
				
			endif;
			
			if timings.pilotSurchargeInvLIneTypeRTS and pilotSurcharge.getTooSoonInvLineType &lt;&gt; null then
			
				// TFS 39355
				self.applySurchargesForPilot(pilotSurcharge.getTooSoonInvLineType, marineInvoice, pilotResUsed); // TFS 39355
				
			endif;
		endforeach;
	endforeach;
	
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="applySurchargesForPilot" id="b0c6b755-f305-4671-a5c8-c5106abfea38">
        <source>applySurchargesForPilot(_pilotSurchargeInvLine : CM_InvoiceLineDesc input; _marineInvoice : CM_Invoice; _pilotResUsed : HMS_ResourceUsed);
/*

Purpose:			TFS 39355

Parameters:			

Return Value:		

Date			Who		Reason
31 July 2018	jlgab1	Initial creation
23 Oct 2024  	navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	invoice, marineInvoice : CM_Invoice;
	iter : Iterator;
	invoiceType : CM_InvoiceDesc;
	surcharges : CM_InvoiceTypeSurchargeExempt;
	pilotSurcharge : CM_InvTypePilotSurcharge;
	movement : HMS_VoyageMovement;
	timings : HMS_MarineServicesTimings;
	invoiceLine : CM_InvoiceLine;
	seqNum : Integer;

	charge : CM_Charge;
	resUsed, pilotResUsed : HMS_ResourceUsed;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
	
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	marineInvoice := _marineInvoice;
	pilotResUsed := _pilotResUsed;
	
	create invoiceLine persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
	invoiceLine.setForCreate(seqNum, false, null, _pilotSurchargeInvLine,  marineInvoice, marineInvoice.debtor, marineInvoice.bank, 0, app.actualTimeServer);
	if pilotResUsed&lt;&gt; null then
		invoiceLine.setMyTransactionHMS(pilotResUsed.myVTMISTransaction); // AB
	endif;
	invoiceLine.createCharges();
	
	invoiceLine.calculateQuantity();
	foreach charge in invoiceLine.charges do
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
		endif;
		charge.evaluateRate();
	endforeach;
	
	invoiceLine.setTotalAmount(); //29/09/2025	navkc1 JIRA 35917
	
epilog
	
end;</source>
        <Parameter name="_pilotSurchargeInvLine" type="CM_InvoiceLineDesc" usage="input"/>
        <Parameter name="_marineInvoice" type="CM_Invoice"/>
        <Parameter name="_pilotResUsed" type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="archive" id="491ad809-4900-4193-94a6-0e7d0d463b52">
        <updating/>
        <source>archive(_cmifArchiveVoy : CMIF_ArchiveVoyage; _passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			20 February 2003 by cnwdwq1
Purpose:			Implemented in CM_CellularVoyage for now.

Changed On		Changed By		Reason
------------	------------	-----------------------------------------
06/09/2006		cnwdad1			CCMS #1039.
13/08/2008		concms1			par 17592 - update CM_KPIVoyage before archiving
11 Jan 2011		cnwkpd1			PAR #26678 - Tidy up transient leaks
25 Mar 2013		cnwcs5			CCMS POL 2097 / par 31259
11 Apr 2018		jlgdap1			TFS 37966 PEL1 Archve Status
12 Mar 2020     cnwma1			Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue
11 Oct 2021 	jlier1			TFS 51963 removed inaportnet
19 Aug 2022		jlizm1			TFS 54298 EUP - Simplified Voyage Work Order Process
16 Feb 2023		navsks20 		TFS  56480: EUP Testing | Voyage Ops screen opens Archived Voyages
------------------------------------------------------------------------
*/
vars
	ti 				: CM_TrackedItem;
	bookingRef  	: CM_BookingRef;
	jobIter,
	tiIter,
	iter 			: Iterator;
	job 		    : CM_VoyageJob;
	voyageJobSheet  : CM_VoyageJobSheet;
	theMonitor  	: CMIF_Monitor;
	allBookingRefs  : CM_BookingRefSet;
	tmpVoyageInland : CM_VoyageInlandTerminal;
	term 			: CM_Terminal;
	onShipRob       : CM_TISet;
begin
	exclusiveLock(self);
	
	if self.isNullVoyage then
		app.raiseCMException1(ERR_NULL_OBJ, 'CM_NullVoyage', null, null);
		return;
	endif;
	
	if _cmifArchiveVoy = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_cmifArchiveVoy', null, null);
		return;
	endif;
	
	if _passport = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'passport', null, null);
		return;
	endif;
	
	if self.archived then
		app.raiseCMException1(Voyage_already_archived, self.code, null, null);
		return;
	endif;
	
	//12.03.2020 cnwma1 #48863
	if not self.checkAllResourcesAreCharged then
			app.setContinueCMExceptions(false);
			app.raiseCMException1(	Canno_archi_voyag_outst_resou_,	self.code,null,	null);
			return;
	else
		if _cmifArchiveVoy.isNoDatesAllowed  and 
			self.arrivedDT  = null           and 
			self.departedDT = null           then
			
				// Do nothing.
			else
				if self.arrivedDT = null then
					app.setContinueCMExceptions(false);
					app.raiseCMException1(ERR_NOT_ARRIVED, self.getDisplayDetails(false), null, null);
					return;
					
				elseif self.departedDT = null then
					app.setContinueCMExceptions(false);
					app.raiseCMException1(ERR_NOT_DEPARTED, self.getDisplayDetails(false), null, null);
					return;
					
				endif;
			endif;
	endif;
	
	/*12.03.2020 cnwma1 #48863
	if (not self.archived) then
		if (not self.checkAllResourcesAreCharged) then
			app.setContinueCMExceptions(false);
			app.raiseCMException1(	Canno_archi_voyag_outst_resou_,
									self.code,
									null,
									null);
			return;
		else

			if _cmifArchiveVoy.isNoDatesAllowed
			and self.arrivedDT = null
			and self.departedDT = null
			then
				// Do nothing.
			else
				if self.arrivedDT = null then
					app.setContinueCMExceptions(false);
					app.raiseCMException1(ERR_NOT_ARRIVED, self.getDisplayDetails(false), null, null);
					return;
					
				elseif self.departedDT = null then
					app.setContinueCMExceptions(false);
					app.raiseCMException1(ERR_NOT_DEPARTED, self.getDisplayDetails(false), null, null);
					return;
					
				endif;
			endif;
		endif;
	endif;
	*/
	
	
	// KPI STUFF. generate kpi stats. Must be before the deletion of the slot requests and wles
	self.setKPIVoyageShiftMoves(true);
	self.setKPIVoyageBayMoves(true);
	self.setKPIVoyageMoves;					
	
	if self.myCellularVoyageStructure &lt;&gt; null then
		self.myCellularVoyageStructure.archive(_cmifArchiveVoy, _passport);
	endif;
	
	
	if self.myROROStructure &lt;&gt; null then
		self.myROROStructure.archive(_cmifArchiveVoy, _passport);
	endif;
	
	if self.myGeneralCargoVoyage &lt;&gt; null then
		self.myGeneralCargoVoyage.archive(_cmifArchiveVoy, _passport);
	endif;
	
	if _cmifArchiveVoy.myMonitor &lt;&gt; null then
		theMonitor := _cmifArchiveVoy.myMonitor;
	endif;
	
	//13/03/2020 cnwma1 Bug #48863
	//----------------------
	//Unworked ROB Trackeditems on the ship
	//------------------------
	
	if _cmifArchiveVoy.removeNonWorkedTrackedItems then
		
		create onShipRob transient;
		self.getNonWorkedROB(onShipRob);
		
		if not onShipRob.isEmpty then
			while true do
				ti := onShipRob.first;
				if ti = null then
					break;
				endif;
								
				exclusiveLock(ti);
				onShipRob.remove(ti);
				
				ti.erase(NORMAL_ERASE);
			endwhile;
		endif;
	endif;

	//----------------------
	//Remove EDI Tracked Items
	//----------------------
	if _cmifArchiveVoy.removeEDITrackedItems then
		if theMonitor &lt;&gt; null then
			theMonitor.updateProgress(app.getErrorString(RemovingEDITrackedItems) &amp; '...', null, null);
		endif;
		
		self.eraseAllEDIBayPlans();
	endif;

	//----------------------
	//Jobs
	//----------------------
	if theMonitor &lt;&gt; null then
		theMonitor.updateProgress(app.getErrorString(ArchivingJobs) &amp; '...', null, null);
	endif;
	
	foreach voyageJobSheet in self.allJobSheets do
		jobIter	:=	voyageJobSheet.allJobsByJobNum.createIterator();
		
		while jobIter.next(job) do
			job.archive();
		endwhile;
		
		delete jobIter;
	endforeach;
	
	//---------------------
	//Process pre-notes
	//---------------------
	if _cmifArchiveVoy.removePreNotifiedTrackedItems then
		if theMonitor &lt;&gt; null then
			theMonitor.updateProgress(app.getErrorString(RemovingPreNotifiedTIs)&amp; '...', null, null);
		endif;

		tiIter := self.allNotifiedTIsByCargoTypeId.createIterator();
		
		while tiIter.next(ti) do
			exclusiveLock(ti);
			
			if ti.isChild then
				continue;
			endif;
			
			ti.erase(NORMAL_ERASE);
		endwhile;
		
		delete tiIter;
	endif;

	//---------------------
	//Process TBA's
	//---------------------
	if _cmifArchiveVoy.removeTBATrackedItems then
		if theMonitor &lt;&gt; null then
			theMonitor.updateProgress(app.getErrorString(RemovingTBATrackedItems) &amp; '...', null, null);
		endif;

		tiIter	:=	self.allTbaTIsByCargoTypeId.createIterator();
		
		while tiIter.next(ti) do
			exclusiveLock(ti);
			
			if ti.isChild then
				continue;
			endif;
			
			ti.breakTBAMatch();
			ti.erase(NORMAL_ERASE);
		endwhile;
		
		//16 Mar 2020	NDL	TFS 47004
		delete tiIter;
		tiIter	:=	self.allRRPTIsByCargoTypeId.createIterator();
		
		while tiIter.next(ti) do
			exclusiveLock(ti);
			
			if ti.isChild then
				continue;
			endif;
			
			ti.erase(NORMAL_ERASE);
		endwhile;
	endif;

	//---------------------
	//Process Booking References
	//---------------------
	if _cmifArchiveVoy.removeBookingRefs then
		if theMonitor &lt;&gt; null then
			theMonitor.updateProgress(app.getErrorString(RemovingBookingRefs) &amp; '...', null, null);
		endif;
		iter := self.allBookingRefs.createIterator();
		while iter.next(bookingRef) do
			exclusiveLock(bookingRef);
			bookingRef.erase(NORMAL_ERASE);
		endwhile;
		
	elseif _cmifArchiveVoy.archiveBookingRef then	//10 Sep 2009	NDL	Par 10413
		if theMonitor &lt;&gt; null then
			theMonitor.updateProgress(app.getErrorString(Archiving_booking_references) &amp; '...', null, null);
		endif;
		create allBookingRefs transient;
		if not self.allBookingRefs.isEmpty then
			self.allBookingRefs.copy(allBookingRefs);
			app.myUtilityUA.utlSetBookRefsStatus(BOOKING_REF_ARCHIVED, allBookingRefs, _passport);
		endif;
	
	endif;

	if self.myTerminal.myEdiConfig &lt;&gt; null then
		//probably already done - but do it anyway in case terminal doesn't run BGPs
		self.myTerminal.myEdiConfig.removeVoyageFromProcessing(self);
	endif;
	if not self.archivedDT.isValid then
		self.archivedDT := app.serverTimestampAtTrxStart;
	endif;
	
	if self.isMTNWOVoyageProcess then						// TFS 37966
		self.status := Voyage_Status_VesselArchived;		// TFS 37966
	elseif self.isEUPDefaultVoyageProcess then				// TFS 54298
		self.status := Voyage_Status_EUP_Archived;			// TFS 54298
	else
		self.status	:=	Voyage_Status_Archived;
	endif;													// TFS 37966
	
	self.archived	:=	true;
	
	// The following must be called AFTER the archived flag has been set
	self.setMyTerminal(self.myTerminal);
	
	//24 Jan 2011	NDL	Par 26676
	foreach tmpVoyageInland in self.allVoyageInlandTerminals do
		term := tmpVoyageInland.getMyTerminal();
		if term &lt;&gt; null then
			_passport.setMyTerminal(term);	// set passports terminal relative to each term being processed.
			tmpVoyageInland.archive( _cmifArchiveVoy, _passport );
		endif;
	endforeach;
	_passport.setMyTerminal(self.myTerminal);	// reset passports terminal for next bit.
	
	
	
	// The following must be called AFTER the archived flag has been set
	if self.myHMSVoyageData &lt;&gt; null then
		self.myHMSVoyageData.setAllMovementsArchived(_passport);
	endif;
	
	//Par19349 cnwrs1 Mar 2009
	self.eraseXlations(self.allXlations, NORMAL_ERASE);
	
	//Starting 17 Feb 2023 NAVSKS20 TFS 56480
	if app.getMyCurrentVoyage() = self then
		app.setMyCurrentVoyage(null);
	endif;
	//End 17 Feb 2023 NAVSKS20 TFS 56480

epilog 
	_passport.setMyTerminal(self.myTerminal);//24 Jan 2011	NDL	Par 26676
	delete jobIter;
	delete tiIter;
	delete allBookingRefs;
	delete iter;		
	delete onShipRob;
end;</source>
        <Parameter name="_cmifArchiveVoy" type="CMIF_ArchiveVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="arrMoveCountGtrThanIMSR" id="1e8fae64-7b54-48e9-949d-9cbf93d6f01c">
        <source>arrMoveCountGtrThanIMSR():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

	arrMovement : HMS_VoyageMovement;
	arrCount : Integer;
	imsr : CM_WodMarineServicesInitial;
	imsrCount : Integer;
	iter : Iterator;
	wo : CM_WorkOrder;

begin

	iter := self.allWorkOrders.createIterator;
	while iter.next( wo ) do
		if wo.isWorkOrderForIMSR then
			imsrCount := imsrCount + 1;
		endif;
	endwhile;

	arrMovement := self.getMovementArrival();
	if arrMovement &lt;&gt; null then
		arrCount := arrMovement.countDeleted() + 1;
	else
		arrCount:= 0;
	endif;
	
	return arrCount &gt; imsrCount;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="auditClass" id="c5596ca4-ccc0-454a-9756-666ece036941">
        <options>4</options>
