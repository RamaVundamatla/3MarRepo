    <JadeMethod name="btnLinesDelete_click" id="f17e434a-2a3f-4e4e-9e0f-612fc6b94425">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnLinesDelete_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2012	cnwjre1	Initial creation

*/

vars

begin
	if self.tblLines.rows &gt; 2 then
		// ### TFS BUG 66001 19SEP2024 NAVAB1
		delete self.cmbCargoType.getControl(self.currentLineRow);
		delete self.cmbCommodity.getControl(self.currentLineRow);
		delete self.cmbSubType.getControl(self.currentLineRow);
	
	
	
		self.tblLines.removeItem(self.currentLineRow);
		if self.currentLineRow &gt; self.tblLines.rows then
			self.currentLineRow := self.tblLines.rows;
		endif;
	endif;
	self.doSBMapSetEnableObjects();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
