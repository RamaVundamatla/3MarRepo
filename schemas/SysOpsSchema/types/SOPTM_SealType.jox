	self.setupMultiSelect1(app.getString(CargoTypes), app.myRoot.allCargoTypesById, SOP_TableMaintForm::displayEntryCargoType.name);	

	create coll transient;
	foreach wagonClass in app.myRoot.allWagonClasses where not wagonClass.isNotAvailableForEntry do
		coll.add(wagonClass);
	endforeach;
	
	self.setupMultiSelect2(app.getErrorString(Wagon_class), coll, SOP_TableMaintForm::displayEntryWagonClass.name);

epilog
	delete coll;
	
end;</source>
