    <JadeMethod name="setupThumbnailDetails" id="b1fd8a3e-6dba-4056-b7b3-8689cd344a3e">
        <updating/>
        <source>setupThumbnailDetails() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars
	theForm					: SOP_TableMaintForm;
	comboExtra,
	comboResourceGroup		: ComboBox;						// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	resourceTypeGroup		: CM_ResourceTypeGroup;			// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	allResourceTypeGroups	: CM_ResourceTypeGroupByCode;	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	
begin

	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ToDoTaskResourceTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Description, false);
	
	comboExtra := theForm.cmbExtraInfo;
	
	comboExtra.clear();
	comboExtra.addItem("");
	comboExtra.addItem(EXTRA_INFO_PALLET);
	
	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	comboResourceGroup := theForm.cmbResourceGroup;
	comboResourceGroup.clear();
	allResourceTypeGroups := app.myRoot.allResourceTypeGroups;
	foreach resourceTypeGroup in allResourceTypeGroups do
		comboResourceGroup.addItem(resourceTypeGroup.code);
	endforeach;
	
	self.filterAutoApplyList(theForm, null);
	
	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_ToDoTaskEntryTbl);
	
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideAdditionalInfo" id="e0a32718-b12e-4ed0-99ec-4c97025aa8f1">
        <source>showHideAdditionalInfo(_type : Integer);

/*

Purpose:	// ### TFS #56635[54261] 28NOV2022 NAVAB1		

Parameters:			

Return Value:		


Date		Who		Reason
28 November 2022	navab1	Initial creation

*/

vars
	theForm			: SOP_TableMaintForm;

begin
	theForm	:=	self.myForm;

	if _type = TODO_TYPE_GROUP_TI  
	or _type = TODO_TYPE_GROUP_CARGOGROUP then 
		theForm.tblInput1.showRowByName(ETRow_AdditionalInfo,false); 
	else
		theForm.tblInput1.hideRowByName(ETRow_AdditionalInfo,false); 
	endif;

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="d0545e5e-519c-4fc2-b5bf-9b91a4c752ca">
        <updating/>
        <source>showThumbnail(pResourceType : CM_ResourceType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			  Who		Reason
18 Dec 2009		  cnwndl1	 Initial creation	CCMS MES 1006
11 Jan 2011		  cnwkpd1	 PAR #26678 - Tidy up transient leaks
19 Sept 2022  	  navds21    Bug 54861: Place holder text missing and mismatch 
02 Nov 2022       navds20 	 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
23 December 2022  navds21    ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/

vars

	theForm					: SOP_TableMaintForm;
	iter 					: Iterator;
	obj 					: Object;
	toDoColl 				: CM_ToDoTaskDescBySortKey;
	additionalInfo,
	resourceTypeGroupCode,				// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	resourceTypeCode		: String;	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	theRow 		    		: Integer;	// 19/09/2022 navds21 TFS 54861
	
begin

	theForm	:=	self.myForm;
	theForm.tblInput1.clearValues();
	theForm.tblInput1.setValueByName(ETRow_Code, pResourceType.code);
	theForm.tblInput1.setValueByName(ETRow_Description, pResourceType.description);
	theForm.tblInput1.setValueByName(ETRow_UnitDescription, pResourceType.unitDescription);
	theForm.tblInput1.setValueByName(ETRow_NumDecimals, pResourceType.decimalPlaces);		
	theForm.tblInput1.setValueByName(ETRow_IsAvailable, pResourceType.isAvailable);
	theForm.tblInput1.setValueByName(ETRow_HasBeenUsed, pResourceType.hasBeenUsed);
	theForm.tblInput1.setValueByName(ETRow_IsFromToDateTimeRequired, pResourceType.isFromToDateTimeRequired);		
	theForm.tblInput1.setValueByName(ETRow_IsMandatory, pResourceType.mandatory);		//23.12.2022 navds21 TFS #54349[54262])
	if pResourceType.type = TODO_TYPE_GROUP_TI											// ### TFS #56635[54261] 28NOV2022 NAVAB1
	or pResourceType.type = TODO_TYPE_GROUP_CARGOGROUP then								// ### TFS #56635[54261] 28NOV2022 NAVAB1
		theForm.tblInput1.showRowByName(ETRow_AdditionalInfo,false);					// ### TFS #56635[54261] 28NOV2022 NAVAB1
		additionalInfo := pResourceType.getDisplayStringForAttribute(ETRow_AdditionalInfo,false);
		theForm.cmbExtraInfo.listIndex := theForm.cmbExtraInfo.findStringExact(1, additionalInfo);
		theForm.tblInput1.setValueByName(ETRow_AdditionalInfo,additionalInfo);
	else
		theForm.tblInput1.hideRowByName(ETRow_AdditionalInfo,false); 					// ### TFS #56635[54261] 28NOV2022 NAVAB1
	endif;
	
	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	if app.myPassport.isVASEnabled then
		resourceTypeGroupCode := theForm.displayEntryResourceTypeGroup(pResourceType.myResourceTypeGroup);
		theForm.tblInput1.setValueByName(ETRow_ResourceGroup, resourceTypeGroupCode);
		theForm.cmbResourceGroup.listIndex := theForm.cmbResourceGroup.findStringExact(1, resourceTypeGroupCode);
		
		self.filterAutoApplyList(theForm, pResourceType);
		
		resourceTypeCode := theForm.displayEntryResourceType(pResourceType.myAutoApplyResourceType);
		theForm.tblInput1.setValueByName(ETRow_AutoApply,resourceTypeCode);
		theForm.cmbAutoApply.listIndex := theForm.cmbAutoApply.findStringExact(1, resourceTypeCode);
	else
		theForm.tblInput1.hideRowByName(ETRow_ResourceGroup, false);
		theForm.tblInput1.hideRowByName(ETRow_AutoApply, false);
	endif;
	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	
	theForm.tblInput1.setValueByName(ETRow_Type,app.getToDoTaskIntToString(pResourceType.type)); // ### TFS #56635[54261] 28NOV2022 NAVAB1
	theForm.loadCmbType(app.getToDoTaskIntToString(pResourceType.type), false);					 //02/11/2022 navds20 TFS #56635[54261] // ### TFS #56635[54261] 21NOV2022 NAVAB1 added class
	
	theRow := theForm.tblInput1.showRowByName(ETRow_HookCode, false); // 19/09/2022 navds21 TFS 54861
	self.jadeCode := pResourceType.getJadeCode();
	if theForm.mode = theForm.Mode_View then																		//cnwmc5 - 22 Sep 2015 - PAR 36920
		//theForm.tblInput1.setValueByName(ETRow_HookCode, app.getErrorString(Doubleclick_view));					//cnwmc5 - 22 Sep 2015 - PAR 36920	//19/09/2022 navds21 TFS 54861
		theForm.tblInput1.setValue(theRow,'Dbl-Click to view'); //  19/09/2022 navds21 TFS 54861
	else																											//cnwmc5 - 22 Sep 2015 - PAR 36920
		//theForm.tblInput1.setValueByName(ETRow_HookCode, app.getErrorString(Doubleclick_edit));					//cnwmc5 - 22 Sep 2015 - PAR 36920	//19/09/2022 navds21 TFS 54861
		theForm.tblInput1.setValue(theRow,'Dbl-Click to edit'); //  19/09/2022 navds21 TFS 54861
	endif;																											//cnwmc5 - 22 Sep 2015 - PAR 36920
	
	create toDoColl transient;
	iter := pResourceType.allUsageContexts.createIterator;

	while iter.next( obj ) do
		if obj.isKindOf(CM_ToDoTaskDesc) then
			toDoColl.add( obj.CM_ToDoTaskDesc );
		endif;
	endwhile;
		
	theForm.mulSelect1.setSorted(true);
	theForm.mulSelect1.setSelected(toDoColl);
	self.disableMulSelect1Contents();
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="pResourceType" type="CM_ResourceType"/>
    </JadeMethod>
</Class>
