    <JadeMethod name="getBooleanFromKeyValue" id="114d0c1e-3d51-4779-8316-91616f369cb5">
        <source>getBooleanFromKeyValue(_value :String):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     22 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _value.startsWith (self.True_Property_Key_Value) then
		return true;
	elseif _value.startsWith (self.False_Property_Key_Value) then
		return false;
	else
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Unexpected parameter value (' &amp; _value &amp; ')');
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChangedColumnLevel" id="edcac0d3-7c82-4c0c-b230-01bd61cf9038">
        <source>getChangedColumnLevel(_lastArray, _array :StringArray; _numCols :Integer):Integer protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int :Integer;
begin
	if _lastArray.size = 0 then
		return 1;				// starting displaying column headings at row 1
	endif;
	
	foreach int in  1 to _numCols do
		if _array [int] &lt;&gt; _lastArray[int] then
			return int;		// row at which to start displaying new values
		endif;
	endforeach;
	
	// not sure we will ever get to here - we expect a change of key values for each
	// entry in our  array - if we return 1 then we wil just display all headings from
	// the higest v]level column grouping
	return 1;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lastArray" type="StringArray"/>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_numCols" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getChangedGroupingLevel" id="ab56e251-5e84-4b5a-98ec-fbd9a6b1f454">
        <source>getChangedGroupingLevel(_array, _lastArray :StringArray):Integer protected;
// ---------------------------------------------------------------------------
// Created:     07 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int, size :Integer;
begin
	size := _array.size;
	
	foreach int in  1 to size do
		if _array [int] &lt;&gt; _lastArray[int] then
			return int;		
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_lastArray" type="StringArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getChangedRowLevel" id="b9b4a46f-3890-41e6-ab3e-0678a5331732">
        <source>getChangedRowLevel(_lastArray, _array :StringArray; _numRows :Integer):Integer protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int, rows :Integer;
begin
	rows := _numRows;
	
	if rows = 0 then
		rows := 1;		// dummy row key
	endif;
	
	foreach int in 1 to rows do // just looking at row heading _array
		if _array [int] &lt;&gt; _lastArray[int] then
			return int;	
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lastArray" type="StringArray"/>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_numRows" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getChangedTabLevel" id="6889b801-f1e6-49d6-ba37-6056ce8b1ab8">
        <source>getChangedTabLevel(_lastArray, _array :StringArray; _numTabs :Integer):Integer protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int :Integer;
begin
	foreach int in  1 to _numTabs do
		if _array [int] &lt;&gt; _lastArray[int] then
