    <JadeMethod name="doMnuWorkEDIDeleteBuild" id="42288e3c-8681-415c-b23f-773f9f801601">
        <source>doMnuWorkEDIDeleteBuild();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	idx : Integer;
	voyage : CM_Voyage;
	ediController : CM_VoyageEDIBayPlanController;
	subMenu : MenuItem;

begin
	voyage := self.myCurrentVoyage;
	
	self.doPurgeSubMenus(self.mnuWorkEDIDelete);

	foreach ediController in voyage.allEDIBayPlans do
		idx := idx + 1;
		subMenu := self.mnuWorkEDIDelete.getMenuItem(idx);
		if subMenu = null then
			subMenu := self.mnuWorkEDIDelete.loadSubMenu(idx);
		endif;

		subMenu.caption := ediController.shortDescription;
		subMenu.userObject := ediController;

	endforeach;

	if idx = 0 then
		self.mnuWorkEDI.visible := false;
	else
		self.mnuWorkEDI.visible := true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuWorkEDIFilesBuild" id="ac354183-e97e-4847-8fe9-1e1e886f7db5">
        <source>doMnuWorkEDIFilesBuild();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	idx : Integer;
	voyage : CM_Voyage;
	ediController : CM_VoyageEDIBayPlanController;
	subMenu : MenuItem;

begin
	voyage := self.myCurrentVoyage;
	
	self.doPurgeSubMenus(self.mnuWorkEDIFiles);
	
	foreach ediController in voyage.allEDIBayPlans do
		idx := idx + 1;
		subMenu := self.mnuWorkEDIFiles.getMenuItem(idx);
		if subMenu = null then
			subMenu := self.mnuWorkEDIFiles.loadSubMenu(idx);
		endif;

		subMenu.caption := ediController.shortDescription &amp; ", " &amp; ediController.allPlannedFutureMoveEDIs.size.String &amp; " items.";
		if ediController.lastLoadToActualBayPlansDT.isValid() then
			subMenu.caption := subMenu.caption &amp; " (Loaded " &amp; ediController.lastLoadToActualBayPlansDT.String &amp; ")";
		endif;
		subMenu.userObject := ediController;
	endforeach;

	self.mnuWorkEDIActual.enabled := false;
	self.mnuWorkEDILoad.enabled := false;
	self.mnuWorkEDIDisch.enabled := true;
	
	if idx = 0  then
		self.mnuWorkEDI.visible := false;
	else
		self.mnuWorkEDI.visible := true;
	endif;
epilog

end;</source>
    </JadeMethod>
