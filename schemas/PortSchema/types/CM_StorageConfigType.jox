    <JadeMethod name="addWorkAndCompChargeDaysTo" id="e85cf542-842b-4108-8e7a-596bde901ac1">
        <source>addWorkAndCompChargeDaysTo( _ti : CM_TrackedItem; _storageConfig : CM_StorageConfig; _expiryDate : Date; _days : Integer ) : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 November 2017	jlgndl1	Initial creation	TFS 7032

*/

vars
	workCal : CM_Calendar;
	compCal : CM_Calendar;
	count	: Integer;
	result	: Date;
	date	: Date;
	calendarDate : CM_CalendarDate;
	eofWeekDt : Date;
begin

	result := _expiryDate;
	if not _expiryDate.isValid then
		return null;
	endif;

	if _storageConfig &lt;&gt; null then
		workCal := _storageConfig.myWorkingDaysCalendar;
		compCal := _storageConfig.getMyCompulsoryCalendar;
	endif;

	if workCal = null or compCal= null then
		return null;
	endif;
	if workCal.allCalendarDates.isEmpty and compCal.allCalendarDates.isEmpty
	or _days &lt;= 0 then
		return null;
	endif;
	
	//This is the bit that re-adjusts for when the cargo actually arrives in the weekend.
	if workCal.getFirstCalendarDateForDay(_expiryDate) &lt;&gt; null then
		eofWeekDt := _expiryDate + 2;
	else
		eofWeekDt := _expiryDate + 7;
	endif;
	
	date := _expiryDate;
	while true do
		date := date + 1; 
		calendarDate := null;
		if date &lt;= eofWeekDt then	// check for a weekend date in the first week (mon-sunday week)
			calendarDate := workCal.getFirstCalendarDateForDay(date);
		endif;
		if calendarDate = null then	// not a weekend/holiday
			calendarDate := compCal.getFirstCalendarDateForDay(date);
		endif;
		if calendarDate = null then	// not a weekend/holiday or Compulsory day
			count := count + 1;
		endif;
		if count &gt;= _days then
			if compCal.getFirstCalendarDateForDay(date + 1) &lt;&gt; null then
				//while the next day is a holiday we will want to count that too, so carry on.
				continue;
			endif;
			break;
		endif;
	endwhile;

	result := date;
	return result;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
        <Parameter name="_expiryDate" type="Date"/>
        <Parameter name="_days" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
