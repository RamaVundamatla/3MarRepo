    <JadeMethod name="validateDelete" id="b2efbf4c-553b-4159-a5f7-b312f62ef9c9">
        <source>validateDelete(_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		par 23859 - prevent dangling references
// ---------------------------------------------------------------------------
vars

begin
	if not self.allLaneDevices.isEmpty then
		app.raiseCMException2(Lane_Device_Delete_Error, self.code, self.allLaneDevices.first.getLaneDescription, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
