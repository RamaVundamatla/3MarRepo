    <JadeMethod name="setAttributes" id="0eca9503-43ca-4009-9362-10d2185dc15c">
        <updating/>
        <source>setAttributes( _tiMaster : CM_TIMasterContainer io; _isEdit : Boolean; _multiLastTi : CM_TIMasterContainer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2008	cnwrd1	Initial creation

*/

vars

begin

	self.isEdit				:= _isEdit;
	
	self.chkRange.visible := false;
	self.lCreateRange.visible := false;
	
	if self.isEdit then
		self.myTiMaster		:= _tiMaster;
		if _multiLastTi &lt;&gt; null then
			// editing range
		//	chkRange.value := true;
		//	chkRange_change(chkRange);
		//	txtIDend.text := _multiLastTi.id;
		endif;
	else
		self.myTiMaster 	:= null;
	endif;
	
	


end;</source>
