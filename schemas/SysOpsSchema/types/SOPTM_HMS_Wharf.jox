    <JadeMethod name="initShtDataTable1" id="6ae67340-9b9d-48c5-9f2e-e117e93b763a">
        <updating/>
        <source>initShtDataTable1() updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
sht							: CMUI_Sheet;
	tbl							: CM_DataTable;
begin
//	inheritMethod();
	sht := self.myForm.shtDataTable1;
	tbl := self.myForm.tblData1;

	sht.caption := 'Wharf Resources';
	sht.visible := true;
	
	tbl.rows := 1;
	tbl.columns := 4;
	
	tbl.accessCell(1,1).text := 'Order' &amp; Tab &amp; 
								'Arrival Resource' &amp; Tab &amp; 
								'Departure Resource' &amp; Tab &amp; 
								'Shift Resource';
	
//	self.myForm.cmbResourceArr.automaticCellControl := true;
//	self.myForm.cmbSystemRole.automaticCellControl := true;
//	self.myForm.cmbCargoBOLType.automaticCellControl := true;

	// this should really be done by calling the superclass method !!!
	self.myForm.frmTBDataTable1.visible	:= false;	// par 19830 concms1 june2009

end;</source>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="5f8e03ca-0289-443b-9a30-e8c85e3b86d8">
        <source>initShtMultiSelect();
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod;
	
	self.setupMultiSelect2('Terminals',app.myRoot.allTerminals,SOP_HMS_TableMaintForm::displayEntryAllTerminals.name);	
	//self.setupMultiSelect1('Berths',null,SOP_HMS_TableMaintForm::displayEntryBerth.name);	
