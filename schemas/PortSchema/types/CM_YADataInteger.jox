    <JadeMethod name="doDataComparison" id="a3762ce7-9251-4c17-b551-bc8243d75fb7">
        <source>doDataComparison(_yaData: SelfType): Boolean;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
vars

	i	 : Integer;

begin

	if self.allValues.isEmpty() then
		return true;
	endif;
	
	foreach i in _yaData.allValues do
		if self.allValues.includes(i) then
			return true;
		endif;
	endforeach;

	return false;

end;</source>
        <Parameter name="_yaData" type="SelfType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDataComparisonWithResolution" id="d8edaf3e-edad-4ab8-9af1-b2c2e50d06f9">
        <source>doDataComparisonWithResolution(_yaData: CM_YAData): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
15 August 2008	consw1	Initial creation

*/

vars
	i	 		: Integer;
	iArray		: IntegerArray;
	yaPattern	: CM_YADataPattern;

begin

	if self.allValues.isEmpty() then
		return true;
	endif;

	if _yaData.isKindOf(CM_YADataPattern) then
		yaPattern := _yaData.CM_YADataPattern;
		create iArray transient;
		yaPattern.myCriteriaType.resolveTransportModePattern(yaPattern.pattern, iArray);
		foreach i in iArray do
			if self.allValues.includes(i) then
				return true;
			endif;
		endforeach;
		return false;
	endif;
	
	foreach i in _yaData.CM_YADataInteger.allValues do
		if self.allValues.includes(i) then
			return true;
		endif;
	endforeach;

	return false;
	
epilog
	delete iArray;
end;</source>
        <Parameter name="_yaData" type="CM_YAData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="b25e20b5-e87a-493b-b615-afa85532f92f">
        <source>getDataDisplay(_criteriaType: CM_YACriteriaType) : String;
//30 July 2008	cnwdw1	
//
vars
	value: Integer;
	displayString: String;
begin
	foreach value in self.allValues do
		displayString := displayString &amp; _criteriaType.getIntegerDisplay(value) &amp; ", ";
	endforeach;
	displayString := displayString[1:displayString.length-2];
	return displayString;
end;</source>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <ReturnType type="String"/>
    </JadeMethod>
