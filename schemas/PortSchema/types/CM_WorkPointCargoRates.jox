    <JadeMethod name="validateUpdate" id="be498bf5-ca81-41f5-9a04-6bd207d4e8a8">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

	realForDupCheck : CM_WorkPointCargoRates;
	realSameKeys : CM_WorkPointCargoRates;

begin

	if self.myWorkPoint = null then
		app.raiseCMException(Input_required_field_workPoint, null, null ); 
		return;
	endif;
	
	if self.myCargoType = null then
		app.raiseCMException(Unspecified_Cargo_Type, null, null ); 
		return;
	endif;
	
	if self.transferType &lt; 0 then
		app.raiseCMException(Transfer_type_required, null, null ); 
		return;
	endif;
	
	if self.dailyHoursWorkable &gt; 24 then
		app.raiseCMException2(ERR_LOWER_GT_UPPER, ETRow_DailyHoursWorkable, "24", null, null);
	endif;
	
	if self.targetRatePHQuantity &lt;= 0 and self.targetRatePHVolume &lt;= 0 and self.targetRatePHWeight &lt;= 0 then
		app.raiseCMException(Hourly_target_rate_require, null, null );
	endif;
	
	if self.isTransient then
		realForDupCheck := self.pxyGetRealObject;
	else
		realForDupCheck := self;
	endif;
	
	realSameKeys := self.myCargoType.allWorkPointRates.getAtKey( self.myCargoType, self.myProduct, self.myWorkPoint, self.jobType, self.transferType );
	if realSameKeys &lt;&gt; null and realSameKeys &lt;&gt; realForDupCheck then
		app.raiseCMException(EDIData_AlreadyExists, null, null );
		return;
	endif;
	
	if self.myProduct &lt;&gt; null then
		realSameKeys := self.myProduct.allWorkPointRates.getAtKey( self.myCargoType, self.myProduct, self.myWorkPoint, self.jobType, self.transferType );
		if realSameKeys &lt;&gt; null and realSameKeys &lt;&gt; realForDupCheck then
			app.raiseCMException(EDIData_AlreadyExists, null, null );
			return;
		endif;
	endif;
	
	realSameKeys := self.myWorkPoint.allWorkPointRates.getAtKey( self.myCargoType, self.myProduct, self.myWorkPoint, self.jobType, self.transferType );
	if realSameKeys &lt;&gt; null and realSameKeys &lt;&gt; realForDupCheck then
		app.raiseCMException(EDIData_AlreadyExists, null, null );
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
