    <JadeMethod name="doMnuCargoEraseClick" id="ab5ba9b7-bcbf-4628-9ef5-8b0200bc3794">
        <updating/>
        <source>doMnuCargoEraseClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
vars
	theTI : CM_TrackedItem;
	theReturn : Integer;
begin
	if menuItem.userObject &lt;&gt; null then
		if menuItem.userObject.isKindOf(CM_TrackedItem) then
			theTI := menuItem.userObject.CM_TrackedItem;
			while true do // PAR 8920 added a TRX LOOP
				app.myTrxDA.trxDeleteTI(theTI, true, app.myPassport);
				if app.myPassport.trxCompletedOK then
					global.beep;
					break;
				else
					theReturn := app.showErrorWarningDialog("Delete Cargo", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   theReturn = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					return;
				endif;
				break;
			endwhile;
		endif;
	endif;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuEDIEnable" id="c24557cf-450c-4792-a77e-8934a7469b0c">
        <updating/>
        <source>doMnuEDIEnable(_enable : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.mnuWorkEDIActual.enabled := _enable;
	self.mnuWorkEDILoad.visible := false;// not required yet, possibly later if we get the EDI side going
	self.mnuWorkEDILoad.enabled   := (not self.myCurrentVoyage.allOnshipTIsByCargoTypeId.isEmpty());
	self.mnuWorkEDIDisch.enabled  := (not self.myCurrentVoyage.allOnshipTIsByCargoTypeId.isEmpty());
	self.mnuWorkEDIDelete.enabled := _enable;

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuEditTranshipExports" id="07484c74-2fe8-4d72-a6b3-3012e019d35d">
        <source>doMnuEditTranshipExports();
// ---------------------------------------------------------------------------
// Created:     20 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tiArray :CM_TIArray;
begin
	create tiArray transient;
		if self.myBayDrawingController &lt;&gt; null then
			self.myBayDrawingController.getAllSelectedTIs(tiArray);	
			self.doShowTranshipExportTis(tiArray);
	endif;
epilog
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuGlobalVoyMakeActual" id="f9a99644-786b-4518-8dcc-40262b62753c">
        <updating/>
        <source>doMnuGlobalVoyMakeActual(menuItem: MenuItem input) updating;
//----------------------------------------------------------------
//	Created:	05 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theReturn,
	theIndex	: Integer;
	strMode		: String;
	isMerge,
	isProposed	: Boolean;
	mon			: CMIF_Monitor;
begin

	if self.myCurrentVoyageInterTerm = null then
		app.msgBox('You must select a voyage from the Global Voyage menu.', "Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if not self.myCurrentVoyage.allVoyageJobs.isEmpty  then
		//if self.myCurrentVoyage.hasVoyageWorkStarted() then
		app.msgBox("The current bay plan view cannot be made actual because the current voyage" &amp; CrLf &amp; 
				   "has jobs that may have been worked.  You will need to either delete all" &amp; CrLf &amp; 
				   "jobs or create a new voyage.", "EDI Update", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;	
	endif;

	if self.displayMode = ShpDisplayMode_VoyGlobProposed then
		isProposed := true;
		strMode := "Proposed";
	elseif self.displayMode = ShpDisplayMode_VoyGlobActual then
		strMode := "Actual";
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'invalid mode for bay plan make actual');
		return;
	endif;
	
	if self.myCurrentVoyage.allOnshipTIsByCargoTypeId.isEmpty then
		theReturn := app.msgBox("Make " &amp; strMode &amp; " bay plan for " &amp; self.myCurrentVoyageInterTerm.code &amp; " from " &amp; self.myCurrentVoyageInterTerm.myTerminal.name &amp; " Actual?", self.caption, MsgBox_Yes_No);
	
	else
		theReturn := app.msgBox("Merge " &amp; strMode &amp; " bay plan for " &amp; self.myCurrentVoyageInterTerm.code &amp; " from " &amp; self.myCurrentVoyageInterTerm.myTerminal.name &amp; " into Actual?", self.caption, MsgBox_Yes_No);
		isMerge := true;
	endif;
	
	if theReturn &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;

	if app.myPassport.myCMIFMonitor = null then
		create mon transient;
		mon.myParent := self;
		app.myPassport.setMyCMIFMonitor(mon);
	endif;

	if self.myTerminalTransferController = null then	//should be null
		create self.myTerminalTransferController transient;
	endif;
	
	self.myTerminalTransferController.setForCreate(self.myCurrentVoyage, self.myCurrentVoyageInterTerm, isProposed, isMerge, self.myTerminal);
	
	app.mousePointer := Window.MousePointer_HourGlass;
	self.showMessageForBigUpdate(true, "Making Actual For ");

	//set this now - painful to do twice just for warnings - inline with EDI stuff
	app.myPassport.warningsAcknowledged	:= true;

	while true do
		app.myTrxUA.trxSetActualBayPlanFromVoyage(self.myTerminalTransferController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.switchDisplayMode(ShpDisplayMode_Actual, true);
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog('Set To Actual', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;


epilog
	delete mon;
	delete self.myTerminalTransferController;
	self.showMessageForBigUpdate(false, null); // hide frame
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
