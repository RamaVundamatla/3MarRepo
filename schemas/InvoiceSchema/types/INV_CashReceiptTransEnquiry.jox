    <JadeMethod name="tblCash_dblClick" id="1a4761ff-4ceb-4c6a-9848-37766c7122a5">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCash_dblClick(table: Table input) updating;
/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Dec 2019	NDL		TFS 47284

*/
vars
	row	: Integer;
	lineObj : CMIF_CashReceiptEnquiryLine;
	cash : CM_Cash;
begin
	row := self.tblCash.row;
	
	if row &gt; self.tblCash.fixedRows and row &lt;= self.tblCash.rows then
		lineObj :=  table.accessRow(table.row).itemObject.CMIF_CashReceiptEnquiryLine;
		if lineObj &lt;&gt; null then
			cash := lineObj.myCashObject;
		endif;
		if cash &lt;&gt; null and
		   cash.isKindOf(CM_CashReceipt) then
			self.showCashReceipt(cash.CM_CashReceipt);
			return;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="408e6367-1119-4771-a005-594f7065b0aa">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 June 2025 09:47:49.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023855, locale);
	btnClose.translateCaption(Xlat_0023856, locale);
	btnSearch.translateBubbleHelp(Xlat_0023857, locale);
	btnSearch.translateCaption(Xlat_0023858, locale);
	btnSearchCancel.translateBubbleHelp(Xlat_0023859, locale);
	btnSearchCancel.translateCaption(Xlat_0023860, locale);
	btnSearcher.translateBubbleHelp(Xlat_0023861, locale);
	btnSearcher.translateCaption(Xlat_0023862, locale);
	lblBank.translateCaption(Xlat_0023863, locale);
	lblCashDebtor.translateCaption(Xlat_0023864, locale);
	lblFromDate.translateCaption(Xlat_0023865, locale);
	lblSearch.translateCaption(Xlat_0023866, locale);
	lblSearchCrit.translateCaption(Xlat_0023867, locale);
	lblTerminal.translateCaption(Xlat_0023868, locale);
	lblToDate.translateCaption(Xlat_0023869, locale);
	mnuAudits.translateCaption(Xlat_0023870, locale);
	mnuCashReceipt.translateCaption(Xlat_0023871, locale);
	mnuChangeStatus.translateCaption(Xlat_0027089, locale);
	mnuColOrg.translateCaption(Xlat_0023872, locale);
	mnuContext.translateCaption(Xlat_0023873, locale);
	mnuInspect.translateCaption(Xlat_0023874, locale);
	mnuInvoice.translateCaption(Xlat_0023875, locale);
	mnuPrintCashRec.translateCaption(Xlat_0023876, locale);
	mnuPrintPayRec.translateCaption(Xlat_0023877, locale);
	mnuShowCargo.translateCaption(Xlat_0023878, locale);
end;</source>
    </JadeMethod>
