    <JadeMethod name="buildQueryToMatchDetails" id="adfafa3a-8c69-4a5e-9650-63394f11cbc5">
        <source>buildQueryToMatchDetails(	_userQuery : CM_MenuUserQuery io; _criteriaLineHolder : CM_QueryCriteriaLineHolder io ):String;
/*
Date			Who		Reason
10 January 2012	cnwndl1	Initial creation	Par 28953
25/09/2012		cnwcs5	par 30390 - remove voyageCode property
17/07/2023		navkc1	CR 58406 Task 58964: Jade - Road Gate Release Use Rel Req Cargo Group Items
15/09/2023		navkc1	CR 60429 Task 60448: UI - Cargo Review UI Changes - VBS Slot Selector Query
12/10/2023		navdap1	TFS 58928 EUP | Calloff Zimmer DB Load - imex status Export and Import for Unknown release type
*/

vars
	transQueryLine 	: CM_SelectorCriteriaLine;
	transProperty 	: CM_QueryProperty;
	transOperator 	: CM_QueryOperator;
	objSet 			: ObjectSet;
	className, 
	voyage			: String;			// par 30390 sept 2012
	term 			: CM_Terminal;
	subTerminal 	: CM_SubTerminal;
	imexs 			: IntegerArray;
	criteria : CM_YACriteria;
	yaType : Integer;
	returnMsg : String;
	msg : String;
	hasImex	: Boolean; //15/09/2023	navkc1	CR 60429 Task 60448
begin

	create objSet transient;

	if self.myCargoType &lt;&gt; null then
		if self.myCargoType.id = 1 then
			className := "CM_Container";
			_userQuery.setPropertyValue( "queryMode", 1);
		endif;
	endif;
	if className = null then
		className := "CM_TrackedItem";
		_userQuery.setPropertyValue( "queryMode", 0);
	endif;

	//	Add Site criteria line
	create transQueryLine transient; 
	transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
	
	create transProperty as CM_QTiSiteLookupProperty transient;
	transProperty.set(	"Site",						//_niceName : String
						CM_TrackedItem::site.name,	//_propName : String
						className					//_className : String
						);
	transProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
	
	create transOperator as CM_QIntegerLookupEqual transient;
	transOperator.setSearchValue( TI_SITE_ONSITE );
	
	transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
										transProperty,	//_myQueryProperty : CM_QueryProperty;
										transOperator,	//_myQueryOperator : CM_QueryOperator;
										transProperty.propertyName,	//_propName : String;
										transProperty.propertyClassName	//_propClassName : String
										);
											
	
	//	Add Terminal criteria line
	term := self.getMyTerminal;
	if term &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QRefTerminalProperty transient;
		transProperty.set(	"Terminal",	//_niceName : String
							"myTerminal",	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QReferenceLookup transient;
		transOperator.setSearchValue( term );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.myReserveHeader &lt;&gt; null and self.myReserveHeader.mySubTerminal &lt;&gt; null then
	
		subTerminal := self.myReserveHeader.mySubTerminal;
		
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QRefSubTerminalProperty transient;
		transProperty.set(	"Sub-Terminal",	//_niceName : String
							CM_TrackedItem::mySubTerminal.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QReferenceLookup transient;
		transOperator.setSearchValue( subTerminal );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
										
	if not self.allTerminalAreas.isEmpty then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QRefTerminalAreaProperty transient;
		transProperty.set(	"Terminal Area",	//_niceName : String
							CM_TrackedItem::myTerminalArea.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		objSet.clear();
		self.allTerminalAreas.copyNoDuplicates( objSet, false );
		create transOperator as CM_QReferenceIsOneOf transient;
		transOperator.setSearchValue( objSet );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.myCargoType &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QCargoTypeLookupProperty transient;
		transProperty.set(	"Cargo Type",	//_niceName : String
							CM_TrackedItem::cargoType.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QIntegerLookupEqual transient;
		transOperator.setSearchValue( self.myCargoType.id );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.myISOGroup &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrISOGroupProperty transient;
		transProperty.set(	"ISO Type Group",	//_niceName : String
							CM_Container::isoGroup.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( self.myISOGroup.code );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.myISOType &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrISOTypeProperty transient;
		transProperty.set(	"ISO Type",	//_niceName : String
							CM_Container::isoType.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( self.myISOType.code );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.myProduct &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QRefProductProperty transient;
		transProperty.set(	"Cargo Subtype",	//_niceName : String
							CM_TrackedItem::myProduct.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QReferenceIsOneOf transient;
		transOperator.setSearchValue( self.myProduct );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	
	if not self.allAvailabilityGrades.isEmpty then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QAvailabilityGradeProperty transient;
		transProperty.set(	"Availability Grade",	//_niceName : String
							CM_Container::availabilityGrade.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QIntegerIsOneOf transient;
		transOperator.setSearchValue( self.allAvailabilityGrades );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.clean then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QBooleanProperty transient;
		transProperty.set(	"Is Clean",	//_niceName : String
							CM_Container::isClean.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QueryBooleanOperator transient;
		transOperator.setSearchValue( true );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.heavyRated then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QBooleanProperty transient;
		transProperty.set(	"Is Heavy Duty",	//_niceName : String
							CM_Container::isHeavyDuty.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QueryBooleanOperator transient;
		transOperator.setSearchValue( true );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.getBOLNumber.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStringProperty transient;
		transProperty.set(	"Bill Of Lading",	//_niceName : String
							CM_TrackedItem::billOfLading.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringEquals transient;
		transOperator.setSearchValue( self.getBOLNumber );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	voyage := self.getVoyageCode.trimBlanks;		// patr 30390 sept 2012
	
	if voyage &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrVoyageProperty transient;
		transProperty.set(	"Voyage",							//_niceName : String
							CM_TrackedItem::voyageCode.name,	//_propName : String
							className							//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( voyage );					// par 30390 sept 2012
		
		transQueryLine.setDetailsOnClone(	false,							//_isUnavailableAtRunTime : Boolean;
											transProperty,					//_myQueryProperty : CM_QueryProperty;
											transOperator,					//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,		//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.getOperator &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrOperatorProperty transient;
		transProperty.set(	"Operator",	//_niceName : String
							CM_TrackedItem::operatorCode.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( self.getOperator.code );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif; 
	
	if self.getConsigneeCode.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrConsignProperty transient;
		transProperty.CM_QStrConsignProperty.type := CONSIGNEE;
		transProperty.set(	"Consignee",	//_niceName : String
							CM_TrackedItem::consignee.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( self.getConsigneeCode );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	if self.getFreightForwarderCode.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStrConsignProperty transient;
		transProperty.CM_QStrConsignProperty.type := FREIGHT_FORWARDER;
		transProperty.set(	"Freight Forwarder",	//_niceName : String
							CM_TrackedItem::freightForwarderCode.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringLookup transient;
		transOperator.setSearchValue( self.getFreightForwarderCode );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	//12 Sep 2019	NDL	TFS 46561
	if self.colour.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStringMethod transient;
		transProperty.set(	"Colour",	//_niceName : String
							CM_TrackedItem::getColour.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringEquals transient;
		transOperator.setSearchValue( self.colour.trimBlanks );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	//12 Sep 2019	NDL	TFS 46561
	if self.markSelection.trimBlanks &lt;&gt; null then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStringProperty transient;
		transProperty.set(	"Mark",	//_niceName : String
							CM_TrackedItem::mark.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringEquals transient;
		transOperator.setSearchValue( self.markSelection.trimBlanks );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	//21 Mar 2016	NDL	TFS 1691 - Implied attribute for all releases...
	create transQueryLine transient; 
	transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
	
	create transProperty as CM_QBooleanProperty transient;
	transProperty.set(	"Is Available",	//_niceName : String
						CM_Container::isAvailable.name,	//_propName : String
						className	//_className : String
						);
	transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
	
	create transOperator as CM_QueryBooleanOperator transient;
	transOperator.setSearchValue( true );
	
	transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
										transProperty,	//_myQueryProperty : CM_QueryProperty;
										transOperator,	//_myQueryOperator : CM_QueryOperator;
										transProperty.propertyName,	//_propName : String;
										transProperty.propertyClassName	//_propClassName : String
										);
	
	//17/07/2023	navkc1	CR 58406 Task 58964 - Cargo Group
	if self.myCargoGroup &lt;&gt; null then
		create transQueryLine transient;
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QStringMethod transient;
		transProperty.set("Cargo Group Id",	//_niceName : String
							CM_TrackedItem::getMyCargoGroupId.name,	//_propName : String
							className	//_className : String
							);
		
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create transOperator as CM_QStringEquals transient;
		transOperator.setSearchValue(self.myCargoGroup.id);
		
		transQueryLine.setDetailsOnClone(false,
										transProperty,	//_isUnavailableAtRunTime : Boolean;
										transOperator,	//_myQueryProperty : CM_QueryProperty; 
										transProperty.propertyName,	//_propName : String;
										transProperty.propertyClassName	//_propClassName : String
										);
	endif;
	
	//12 Jun 2015	NDL	Par 36338
	if self.myReleaseCriteria &lt;&gt; null then
		foreach criteria in self.myReleaseCriteria.allCriteria do
			msg := null;
			yaType := 0;
			if criteria.myYACriteriaType &lt;&gt; null then
				yaType := criteria.myYACriteriaType.type;
			endif;
			if yaType &gt; 0 then
				transQueryLine := _criteriaLineHolder.getLineWithAllocationAttr( yaType );
				if transQueryLine &lt;&gt; null then
					msg := "'" &amp; criteria.myYACriteriaType.description &amp; "' already set.";
					if returnMsg = null then
						returnMsg := msg;
					else
						returnMsg := returnMsg &amp; CrLf &amp; msg;
					endif;
					continue;
				endif;
				//15/09/2023	navkc1	CR 60429 Task 60448
				if yaType = YACriteriaType_ImexStatus then
					hasImex := true;
				endif;
				//need one, add a line.
				msg := _criteriaLineHolder.addEquivalentLineFromYACrit( criteria, className );
			endif;
			if msg &lt;&gt; null then
				if returnMsg = null then
					returnMsg := msg;
				else
					returnMsg := returnMsg &amp; CrLf &amp; msg;
				endif;
			endif;
		endforeach; 
		
		//return returnMsg; //20/09/2023	navkc1	Bug 60595
		
	endif;
	
	//15/09/2023	navkc1	CR 60429 Task 60448 - If Release Request, Extra Criteria does not have IMEX status, then we build a default one.
	if not hasImex then
		create transQueryLine transient; 
		transQueryLine.setMyCriteriaLineHolder(_criteriaLineHolder);
		
		create transProperty as CM_QImExStatusProperty transient;
		transProperty.set(	"Import/Export Status",	//_niceName : String
							CM_TrackedItem::imexStatus.name,	//_propName : String
							className	//_className : String
							);
		transProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create imexs transient;
		imexs.add( TI_IMEX_STATUS_STORAGE );
		if myReserveHeader &lt;&gt; null then
			if self.myReserveHeader.type = BR_TYPE_ROAD or self.myReserveHeader.type = BR_TYPE_RAIL then
				imexs.add( TI_IMEX_STATUS_IMPORT );	
			elseif self.myReserveHeader.type = BR_TYPE_SHIP then
				imexs.add( TI_IMEX_STATUS_EXPORT ); 	
			elseif self.myReserveHeader.type = BR_TYPE_UNKNOWN then		// TFS 58928
				imexs.add( TI_IMEX_STATUS_EXPORT );						// TFS 58928
				imexs.add( TI_IMEX_STATUS_IMPORT );						// TFS 58928
			endif;
		endif;
		
		create transOperator as CM_QIntegerIsOneOf transient;
		transOperator.setSearchValue( imexs );
		
		transQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											transProperty,	//_myQueryProperty : CM_QueryProperty;
											transOperator,	//_myQueryOperator : CM_QueryOperator;
											transProperty.propertyName,	//_propName : String;
											transProperty.propertyClassName	//_propClassName : String
											);
	endif;
	
	return returnMsg; //20/09/2023	navkc1	Bug 60595

epilog

	delete imexs;
	delete objSet;
	
end;</source>
        <Parameter name="_userQuery" type="CM_MenuUserQuery" usage="io"/>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkAvailQuantityAndWeight" id="3ae32d34-4e49-4af3-9781-f7cdfd028310">
        <source>checkAvailQuantityAndWeight(_totalQtyRequested : Integer; _totalWeightRequested : Decimal);
/*

Purpose:			This is currently used for EUP to check whether there is enough Quantity/Weight available

Parameters:			

Return Value:		

Date		Who		Reason
17/07/2023	navkc1	CR 58406 Task 58964: Jade - Road Gate Release Use Rel Req Cargo Group Items
*/

vars
	allTis			: CM_TISet;
	ti				: CM_TrackedItem;
	reason			: String;
	bulkRel			: CM_BulkRelease;
	availQuantity 	: Integer;
	availWeight 	: Decimal [23,4];
begin
	bulkRel := self.myReserveHeader;
	if bulkRel = null  then
		return;
	endif;
	//jlier1 TFS 59732 let methods that call this whether the context needs 
	create allTis transient;
	
	self.getAllItemsForRelUseSelector(allTis);
	
	foreach ti in allTis do		
		if ti.isOnSite() then
			if ti.testAgainstReserveSelection(self, reason, false, null) then
				if ti.allReserveDetails.isEmpty() or ti.allReserveDetails.includes(self) then
					availQuantity := availQuantity + ti.totalQuantity;
					availWeight := availWeight + ti.totalWeight;
				endif;
			endif;
		endif;
	endforeach;
	
	if availQuantity &lt; _totalQtyRequested then
		app.raiseCMException4(Relea_reque_does_not_have_quan, bulkRel.code, _totalQtyRequested.asStringJMT(), availQuantity.asStringJMT(), self.getDescription,null,null);
	endif;
	
	if availWeight &lt; _totalWeightRequested then
		app.raiseCMException4(Relea_reque_does_not_have_weig, bulkRel.code, _totalWeightRequested.asStringJMT(), availWeight.asStringJMT(), self.getDescription,null,null);
	endif;
	
epilog
	delete allTis;
end;</source>
        <Parameter name="_totalQtyRequested" type="Integer"/>
        <Parameter name="_totalWeightRequested" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="checkAvailableReleaseWeight" id="9668b8bb-0527-4520-9a31-83689cd34a7e">
        <source>checkAvailableReleaseWeight();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2024	navsp1	Initial creation TFS 61548

*/

vars
	allTis			: CM_TISet;
	ti				: CM_TrackedItem;
	availWeight 	: Decimal [23,4];
begin
	
	create allTis transient;
	
	self.getAllItemsForRelUseSelector(allTis);
	
	foreach ti in allTis do		
		if ti.isOnSite() then
			if ti.allReserveDetails.isEmpty() or ti.allReserveDetails.includes(self) then
				availWeight := availWeight + ti.totalWeight;
			endif;
		endif;
	endforeach;

	if self.weightRequested &gt; availWeight then
		app.raiseCMException4(Relea_req_does_not_have_rel_wt, self.myReserveHeader.code, self.weightRequested.asStringJMT(), availWeight.asStringJMT(), self.getDescription,null,null);
	endif;
	
epilog
	delete allTis;
end;</source>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="2e656354-9727-4636-aea0-09cd3d8e38c3">
        <updating/>
        <source>cloneReferences(_clone : SelfType input; bTransient : Boolean) updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	_clone.allAvailabilityGrades.clear();
	self.allAvailabilityGrades.copy(_clone.allAvailabilityGrades);
	_clone.myCargoType := self.myCargoType;
	//clonedSelf.myISOGroup := self.myISOGroup; virtual
	_clone.myISOType := self.myISOType;
	_clone.myProduct := self.myProduct;
	_clone.myISOGroup := self.myISOGroup; //cnwrd1 par 20810 9/10/9
	

end;


</source>
        <Parameter name="_clone" type="SelfType" usage="input"/>
        <Parameter name="bTransient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createPlanningTrackedItem" id="a3cfed68-43b7-4358-a38c-cb0d7bcd682c">
        <source>createPlanningTrackedItem(slotPosition : String; _slotController : CM_VoyageController; _transient : Boolean) : CM_TrackedItem;
// Return a transient tracked item that can be used by voyage planning. 
// Don't forget to call deletePlanningTrackedItem when done with it
// 01/04/2010	cnwcs5	par 23383 - pass context info (self) to updateTICollections via new parameter (_extra)
// 10/11/2010	cnwdap1	PAR #23794 CCMS MES 1102 changes for rail cargo
// 30/11/2010	cnwdap1	PAR #26426 CCMS MES 1102 changes for ship release requests
// 07/12/2010	cnwdap1	PAR #26478 Rail release TBA TIs should be created with imex status of Storage
// 20/10/2015   cnwma1  PAR #36146 Provisional Baplie File for Vessel\
// 30/01/2017	cnwma1	TFs # 3224:PAR38565 MSL - ERROR 86321 - planning MT on bay 45/47 voy WAS02S17
// 11/10/2019	jlgdap1	TFS 47001 PRP Auto-plan Errors
// 19/07/2023	jlizm1	TFS 58461 Change release mark number to string
// 06/11/2025	jlizm1	MTN 36255 Rotabox Assign Release To Vessel
vars
	container 		: CM_Container;
	cargo 			: CM_TrackedItem;
	plannedMove 	: CM_FutureMovePlanned;
	voyageJob 		: CM_VoyageJob;
	isoType			: CM_ISOType;
	terminal		: CM_Terminal;
	slotPos			: String;
	controller		: CMIF_TIUpdateController;
	passport 		: CM_Passport;
	loadRequest		: CM_Request;
	newID			: String;	
	reserveHeader	: CM_BulkRelease;
	cargoType		: CM_CargoType;
	isoGroup		: CM_ISOTypeGroup;
begin
	
	reserveHeader := self.myReserveHeader;
	cargoType	  := self.myCargoType;
	terminal 	  := self.getMyTerminal;
	
	if cargoType.id = TI_CargoType_Container then
		// PAR #23794 for rail jobs, create persistent TIs
		// PAR #26426 if _transient parameter says so, create transient otherwise create persistent
		if _transient then
			create container transient;
			container.zSetPxyTerminal(terminal);
			controller := null;
			passport   := null;
		else
			create container persistent;
			container.setTerminalForRailReleaseWLE(terminal);
			controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
			passport   := app.myPassport;
			container.changeState(TI_STATE_PLACEHOLDER, passport);	//13 Mar 2020	NDL	TFS 47004	
			self.allRRPs.add( container );	//24 Mar 2020	NDL	TFS 47004
		endif;
		
		// 04/06/2010 cnwmh5 #20661 - Start
		container.setCommodity(terminal.getDefaultEmptyCommodity());
		
		isoType := self.myISOType;	
		if isoType = null then								//30/01/2017 cnwma1  TFS #3224
			isoGroup := self.getISOGroup();
			if isoGroup &lt;&gt; null then
				container.setSizeAndTypeAttibutesYA(isoGroup.allISOTypes.first.CM_ISOType);
			endif;
		endif;
		
		if isoType &lt;&gt; null then
			container.changeISOType(isoType.code, controller, passport);		
		endif;
		// PAR #23794 For rail jobs, no future move is created
		// PAR #26426 change this to only create future moves for transient tis
		if _transient then											// PAR #26426
			create plannedMove transient;
			container.setPlannedFutureMove(1, plannedMove);
		endif;
		if _slotController &lt;&gt; null then
			slotPos := _slotController.getStowageId(container);
		else
			slotPos := slotPosition;
		endif;
		container.setMyOperator(reserveHeader.myOperator);		// PAR #23794 moved up here so stops processing has an operator
		container.updateContentsStatus();
		// PAR #26478 Rail release TBA Tis should be imex status Storage
		if _slotController = null and slotPosition = null then	// PAR #26478 
			container.setImExStatus(TI_IMEX_STATUS_STORAGE);	// PAR #26478 
		else													// PAR #26478 
			container.setImExStatus(TI_IMEX_STATUS_EXPORT);	
		endif;													// PAR #26478 
		
		container.setPlannedLocnId(slotPos);										
		// 04/06/2010 cnmwh5 #20661 - End
		// PAR #23794 for rail creation, where slot controller is null, get id from next available TBA id
		if _slotController = null then
			newID := terminal.tbaNextSeqNumber;	
			//16 Mar 2020	NDL	TFS 47004
			if container.isRRP then
				newID := "RRP" &amp; newID[4:end];
			endif;
			container.changeId(newID, controller, passport);
		else
			if slotPos.length &gt; 17 then
				// truncate id to maximum length, keep the last characters for better differentiation
				container.changeId("RRP" &amp; slotPos[slotPos.length-16:end], controller, passport);
			else
				container.changeId("RRP" &amp; slotPos, controller, passport);
			endif;
		endif;
		
		if reserveHeader.myVoyage &lt;&gt; null then
			container.setMyVoyage(reserveHeader.myVoyage, passport);
		else
			container.setMyVoyage(terminal.getNullVoyage, passport);
		endif;
		
		//06 Apr 2020	NDL	TFS 47004
		if reserveHeader.isShipType &lt;&gt; null then
			container.setMyRRPTrain( null );
			container.setMyTrainAssigned( null, passport );
		elseif reserveHeader.isRailType &lt;&gt; null then
			container.setMyRRPTrain( reserveHeader.myAssignedTrain );
			container.setMyTrainAssigned( reserveHeader.myAssignedTrain, passport );
		endif;	
		
		if reserveHeader.myDischargePort &lt;&gt; null then
			container.setDischargePort(reserveHeader.myDischargePort.code);
		endif;
		if reserveHeader.myLoadPort &lt;&gt; null then
			container.setLoadPort(reserveHeader.myLoadPort.code);
		endif;
		// PAR #23794 Rail release specific attributes
		if _slotController = null then
			if reserveHeader &lt;&gt; null and reserveHeader.myDestinationPort &lt;&gt; null then
				container.setDestinationPort(reserveHeader.myDestinationPort.code);
			endif;
			container.setIntendedReleaseModeFromStr(TI_TRANSMODE_RAIL_STR);
		endif;
		container.setTotalWeight(self.getAverageWeight(), controller, passport);			// PAR #23794
		// PAR #23794 only create voyage job for slot controllers
		// PAR #26426 if creating a persistent voyage wle TI, find the right voyage job
		if _transient then											// PAR #26426
			create voyageJob transient;
		else
			// PAR #26426 find the (persistent) voyage job
			if _slotController &lt;&gt; null  then
				loadRequest:=_slotController.getRequest(true);
				if loadRequest &lt;&gt; null then	
					if not loadRequest.allWorkListEntries.isEmpty then
						voyageJob := loadRequest.allWorkListEntries.first.job.CM_VoyageJob;
					endif;
				endif;
			endif;
		endif;
		if voyageJob &lt;&gt; null then
			voyageJob.updateTICollections(container, self);	// 01/04/2010 cnwcs5 par 23383
		endif;
		
		container.setMark(self.markSelection);					// TFS 47001
		container.setMarkNumber(self.markNumber);				// TFS 47001
		
		return container;
	else // TFS 3190
		
		cargo := terminal.createTI(cargoType,false);
		
		self.allRRPs.add( cargo );	//24 Mar 2020	NDL	TFS 47004
		
		cargo.setTerminalForRailReleaseWLE(terminal);
		controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
		passport   := app.myPassport;
		newID 	   := terminal.tbaNextSeqNumber;	//16 Mar 2020	NDL	TFS 47004
		newID 	   := "RRP" &amp; newID[4:end];
		
		cargo.changeId(newID, controller, passport);	//21 Mar 2019	NDL	TSF 37550 - Moved up for performance
		
		cargo.changeState(TI_STATE_PLACEHOLDER, passport);	//13 Mar 2020	NDL	TFS 47004
		
		cargo.setMyOperator(reserveHeader.myOperator);
		cargo.setImExStatus(TI_IMEX_STATUS_EXPORT);	
		cargo.setPlannedLocnId(slotPosition);										
		
		if reserveHeader.myVoyage &lt;&gt; null then
			cargo.setMyVoyage(reserveHeader.myVoyage, passport);
		else
			cargo.setMyVoyage(terminal.getNullVoyage, passport);
		endif;
		if reserveHeader.myDischargePort &lt;&gt; null then
			cargo.setDischargePort(reserveHeader.myDischargePort.code);
		endif;
		if reserveHeader.myLoadPort &lt;&gt; null then
			cargo.setLoadPort(reserveHeader.myLoadPort.code);
		endif;	
		cargo.setTotalWeight(self.getAverageWeight(), controller, passport);
		
		cargo.setMark(self.markSelection);						// TFS 47001
		cargo.setMarkNumber(self.markNumber);					// TFS 47001
		if cargo.isBreakBulkGeneric then						// TFS 47001
			cargo.CM_BreakBulkGeneric.setColour(self.colour);	// TFS 47001
		endif;													// TFS 47001
		
		return cargo;
	endif;
	
epilog
	delete controller;
end;</source>
        <Parameter name="slotPosition" type="String"/>
        <Parameter name="_slotController" type="CM_VoyageController"/>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="delete" id="ada75a46-eb64-4c7c-ba5b-5daff0f00a40">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		08 October 2010
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
// 06 Jul 2015	cnwkpd1		PAR #36578 - Tidy up leaked CM_Strings objects
// --------------------------------------------------------------------------------
vars
	
begin
	delete self.maskIds;
	
	//24 Mar 2020	NDL	TFS 47004
	if not self.allRRPs.isEmpty then
		self.allRRPs.purge();	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="deletePlanningTrackedItem" id="9b088a23-e4df-45ac-b5b0-59c1a795b34d">
        <updating/>
        <source>deletePlanningTrackedItem(trackedItem : CM_TrackedItem io) updating;
// Return a tracked item that can be used by voyage planning. A transient TI is created
// based on the info in the release
vars
	container : CM_Container;
	plannedMove : CM_FutureMovePlanned;
	voyageJob : CM_VoyageJob;
begin
	voyageJob := trackedItem.allJobsShipRelease.first;
	voyageJob.updateTICollectionsUnassign(trackedItem);
	
	trackedItem.cleanupQueuedAndPlanned();
	
	delete trackedItem;
end;
</source>
        <Parameter name="trackedItem" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doesTIMatchForRelease" id="03c96b11-da98-469a-95c7-5335b5680478">
        <source>doesTIMatchForRelease(_ti : CM_TrackedItem; _isExact : Boolean output) : Boolean;
// ---------------------------------------------------------------------------
// Created:		26 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	exact : Boolean;
begin
	
	// 35137 match on ISO Group as well as ISO type
	if not self.isMatchForISOTypeProduct(_ti, false) then
		return false;
	endif;
	/* pre-35137
	if _ti.getISOTypeObject &lt;&gt; self.myISOType then
		return false;
	endif;
	
	if _ti.myCargoType &lt;&gt; self.myCargoType then
		return false;
	endif;
	*/
	if self.myReserveHeader &lt;&gt; null and _ti.myOperator &lt;&gt; self.myReserveHeader.myOperator then
		return false;
	endif;
	//epr TFS 40128 31/8/18 try to match on av grades, and the rest
	exact:=true;
	if self.myBOLIn &lt;&gt; null and _ti.billOfLading &lt;&gt; null then
		if self.myBOLIn.number &lt;&gt; _ti.billOfLading then
			exact:=false;
		endif;
	endif;
	
	if _ti.isKindOf(CM_Container) then
		if self.clean and not _ti.CM_Container.isClean then
			exact:=false;
		endif;
		
		if self.heavyRated and not _ti.CM_Container.isHeavyDuty then
			exact:=false;
		endif;
		if not self.allAvailabilityGrades.isEmpty and not self.allAvailabilityGrades.includes(_ti.CM_Container.availabilityGrade) then
			exact:=false;
		endif;
	endif;
	_isExact:=exact;
	return true;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_isExact" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
