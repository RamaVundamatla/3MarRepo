    <JadeMethod name="unload" id="5b9a02d1-4609-47a6-b634-0f81711cb7c1">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Apr 2022 navma1 	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
*/

vars
	invalid,close : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myPxyTask, invalid);
	on Exception do app.handleDeletedObject(exception, self.myPxyWorkOrder, invalid);
	
	if self.myPxyTask &lt;&gt; null then
		self.myPxyTask.edition;
		
		if not invalid then		
			if self.myPxyTask.pxyGetRealObject = null then
				delete self.myPxyTask;
			endif;
		endif;
		
		delete self.myPxyTask;
	endif;
	
	invalid := false;
	
	if self.myPxyWorkOrder &lt;&gt; null then
		self.myPxyWorkOrder.edition;
		if not invalid then
			delete self.myPxyWorkOrder;
		endif;
	endif;
	
	delete self.myEmailController;
	
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateCargoTabNumber" id="22a104c3-c1d9-4151-be8d-d0ba8251634a">
        <source>updateCargoTabNumber();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
23 Aug 2022 navma1	Bug 54297: MTN - Pack Work Order issues
08 Feb 2023 navma1 ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
30/03/2023	navcs2	ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement
06 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
23 May 2024 navhl20 Bug 64258: MTN - Cargo work order takes significant time to click between tasks
*/

vars
	cargoCount	: Integer;
	workOrder	: CM_WorkOrder;
	tiSet		: CM_TISet;
	isShip		: Boolean;
begin

	workOrder := self.myPxyWorkOrder ;
	
	if workOrder = null then
		return;
	endif;
	
	if not workOrder.isKindOf(CM_WorkOrderTI) then
		return;
	endif;
	
	//cargoCount 						:= self.myPxyWorkOrder.CM_WorkOrderTI.allTIs.size;			//08.02.2023 navma1 #56457 Task#56458
	if self.myPxyTask &lt;&gt; null then																	//30.03.2023	navcs2  #55440:[54990]
		cargoCount 						:= self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.size;   	//08.02.2023 navma1 #56457 Task#56458
	endif;																							//30.03.2023	navcs2  #55440:[54990]
	
	/*
	//23.05.2024 navhl20 #64258
	if self.myPxyTask &lt;&gt; null and self.myPxyTask.status &lt;&gt; WO_STATUS_COMPLETE and self.myPxyTask.isKindOf(CM_WorkOrderTIDtl) 
	and self.myPxyTask.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP then					//06.12.2023 navhl20 #58400[61617]
		cargoCount 	:= self.tblSelectedCargo.rows - 1;
	endif;*/
	
	//Start 23.05.2024 navhl20 #64258
	create tiSet transient;	
	isShip := false;
	if self.myPxyTask.isKindOf(CM_WorkOrderTIDtl) and self.myPxyTask.CM_WorkOrderTIDtl.getTransport() = TI_TRANSMODE_SHIP then
		isShip := true;
	endif;
	if isShip then
		if self.myPxyTask.status &lt;&gt; WO_STATUS_COMPLETE then
			self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.copyNoDuplicates(tiSet,false);
			self.myPxyTask.CM_WorkOrderTIDtl.allCompleteTIs.copyNoDuplicates(tiSet,false);
		else
			self.myPxyTask.CM_WorkOrderTIDtl.allCompleteTIs.copyNoDuplicates(tiSet,false);
		endif;
		cargoCount := tiSet.size;
	endif;
	//End 23.05.2024 navhl20 #64258
	
	self.lblTotalRequested.caption	:= "Total Requested:";
	self.txtTotalRequested.text	    := cargoCount.String;
	
	//23.08.2022 navma1 #54297
	self.txtTotalRequired.text	    := cargoCount.String;
	
	self.shtSelectedTis.caption := "Selected Cargo Items [" &amp; cargoCount.String &amp; "]";

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateDebtorSelectionBox" id="b1afbde7-b965-4058-9187-8b34a528b50e">
        <source>updateDebtorSelectionBox();
/*

Purpose:

Parameters:

Return Value:

Date			Who		Reason
13 Jan 2023 	navcs2	ChangeRequest 56632:[56057] EUP - VAS Non Operational Work Order
14 April 2023	navcs2	Defect 57574: MTN - WO - The filter text is not getting cleared when selecting a new work order task

*/

vars
	operator 			: CM_Operator;
	operatorSet 		: CM_OperatorSet;
	debtorPreSelected,
	debtorPreAvail,
	debtorSet			: CM_DebtorSet;
	theBank 			: CM_Bank;
	rdg					: CM_RootDebtorGroup;
begin

	create operatorSet transient;
	create debtorSet transient;
	
	// Get the currently selected operators, selected debtors and available debtors
	self.mulToDoSecondaryEntites.getSelected(operatorSet);
	
	// Get the debtors from the selected operators
	foreach operator in operatorSet do
		debtorSet.addNoDuplicates(operator.debtor, false);
	endforeach;
	
	// Reset the control with the filtered debtor set
	self.mulToDoEntity.setAvailable(debtorSet, false);				// 14.04.2023 navcs2 Defect 57574
	self.mulToDoEntity.setParentCollection(debtorSet);				// 14.04.2023 navcs2 Defect 57574
epilog
	delete operatorSet;
	delete debtorSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateEntitesRequestedRequired" id="f7bcdd5e-2ce1-42a9-b2c5-201f315b9115">
        <source>updateEntitesRequestedRequired();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jan 2023	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen


*/

vars

begin
	if self.myPxyTask &lt;&gt; null then
		if self.myPxyTask.detailType = WO_TASK_ToDo_NONOPS then
			self.txtTotalRequested.text  := self.myPxyTask.CM_WodToDoNonOperational.allDebtors.size.String;
			self.txtTotalRequired.text   := self.txtTotalRequested.text;
		elseif self.myPxyTask.detailType = WO_TASK_ToDo_TRAIN then
			self.txtTotalRequested.text  := self.myPxyTask.CM_WodToDoTrain.allTrains.size.String;
			self.txtTotalRequired.text   := self.txtTotalRequested.text;
		elseif self.myPxyTask.detailType = WO_TASK_ToDo_TRUCK then
			self.txtTotalRequested.text  := self.myPxyTask.CM_WodToDoVehicleVisit.allVehicleVisits.size.String;
			self.txtTotalRequired.text   := self.txtTotalRequested.text;
		elseif self.myPxyTask.detailType = WO_TASK_ToDo_WAGON then
			self.txtTotalRequested.text  := self.myPxyTask.CM_WodToDoWagon.allWagons.size.String;
			self.txtTotalRequired.text   := self.txtTotalRequested.text;
		elseif self.myPxyTask.detailType = WO_TASK_ToDo_VBS then
			self.txtTotalRequested.text  := self.myPxyTask.CM_WodToDoVBS.allVBSSlots.size.String;
			self.txtTotalRequired.text   := self.txtTotalRequested.text;
		elseif self.myPxyTask.detailType = WO_TASK_ToDo_VOYAGE then
			self.txtTotalRequested.text  := self.myPxyTask.CM_WodToDoVoyage.allVoyages.size.String;
			self.txtTotalRequired.text   := self.txtTotalRequested.text;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateTaskId" id="fa7117bb-6ef3-495a-9bdf-42607a5ba8bc">
        <source>updateTaskId(_wodSet : CM_WorkOrderDtlArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2023 navma1  ChangeRequest 56842:[56843] EUP - VAS Task Priority

*/

vars
	term	  	 : CM_Terminal;
	wod		  	 : CM_WorkOrderDtl;
	idx		  	 : Integer;
	uniquePrefix,
	uniqueSuffix : String;
begin
	term         := self.myTerminal;
	uniquePrefix := self.myPxyWorkOrder.id &amp; "-";
	
	idx := 1;
	foreach wod in _wodSet do
		if term &lt;&gt; null then
			uniqueSuffix := term.getNextSuffix(idx);
			wod.setTaskID(uniquePrefix &amp; uniqueSuffix);
			idx := idx + 1;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_wodSet" type="CM_WorkOrderDtlArray" usage="io"/>
    </JadeMethod>
