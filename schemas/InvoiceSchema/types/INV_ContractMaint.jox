    <JadeMethod name="tblData_dblClick" id="e87a1d57-04c1-470e-bfd9-b007c4128dbb">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Feb 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint
15 Mar 2023 navmk20		Bug 57096: MTN - Minor UX issue when using contract maintenance
*/

vars

begin
	if table.row &gt; table.fixedRows then
		self.doBtnUpdateClick();			// 15.3.2023 navmk20 TFS 57096
		return;
	endif;

	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.CM_DataTable.resortTableByColumn(table.column);

	table.accessCell(1,table.column).fontBold := true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_rowColumnChg" id="5812d3f7-e80c-4255-ae08-ecdfeda2602f">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_rowColumnChg(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations
21 Aug 2024	navnk30	Bug 65602: FR - 54089 - Invoice Contract - permissions

*/

vars
	contract : CM_InvoiceContractDetails;
begin
	contract := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContractDetails;
	
	if contract = null then
		self.btnAccumulate.enabled := false;
		return;
	endif;
	
	//if contract.isVolumeBased() then		//21.08.2024 navnk30 #65602
	if contract.isVolumeBased() and
			app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then //21.08.2024 navnk30 #65602
		self.btnAccumulate.enabled := true;
	else
		self.btnAccumulate.enabled := false;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDisplayRow" id="d4735635-eb85-4ac0-b9fe-6f678b2004ca">
        <source>tblDisplayRow();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint

*/

vars
	tbl					: CM_DataTable;
	idx					: Integer;
	str 				: String;
	detail : CM_InvoiceContractDetails;
begin
	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	foreach detail in self.myInvoiceContract.allInvoiceContractDetails do
		str := detail.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		idx := tbl.addItem(str);
		tbl.accessRow(idx).itemObject := detail;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b20b298a-a10a-4406-8d5c-cd45cc55ee69">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 December 2023 09:36:39.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025590, locale);
	btnAccumulate.translateBubbleHelp(Xlat_0026154, locale);
	btnAccumulate.translateCaption(Xlat_0026155, locale);
	btnAdd.translateBubbleHelp(Xlat_0025710, locale);
	btnAdd.translateCaption(Xlat_0025591, locale);
	btnAttachments.translateCaption(Xlat_0025592, locale);
	btnAudit.translateBubbleHelp(Xlat_0026555, locale);
	btnAudit.translateCaption(Xlat_0026556, locale);
	//btnClearFilter.translateBubbleHelp(Xlat_0026580, locale);
	btnClose.translateCaption(Xlat_0025593, locale);
	btnCopy.translateBubbleHelp(Xlat_0025711, locale);
	btnCopy.translateCaption(Xlat_0025594, locale);
	btnRemove.translateBubbleHelp(Xlat_0025712, locale);
	btnRemove.translateCaption(Xlat_0025595, locale);
	btnSave.translateBubbleHelp(Xlat_0025713, locale);
	btnSave.translateCaption(Xlat_0025596, locale);
	btnUpdate.translateBubbleHelp(Xlat_0025714, locale);
	btnUpdate.translateCaption(Xlat_0025597, locale);
	chkActive.translateCaption(Xlat_0025598, locale);
	chkPrimary.translateBubbleHelp(Xlat_0025734, locale);
	chkPrimary.translateCaption(Xlat_0025599, locale);
	lblContractId.translateCaption(Xlat_0025600, locale);
	lblDebtor.translateCaption(Xlat_0025601, locale);
	lblDescription.translateCaption(Xlat_0025602, locale);
	lblEnd.translateCaption(Xlat_0025603, locale);
	lblStart.translateCaption(Xlat_0025604, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0025605, locale);
	mnuContextMenu.translateCaption(Xlat_0025606, locale);
	mnuInspectObject.translateCaption(Xlat_0025715, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="133ec96f-740b-46f1-9271-82f26861877b">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose:			

Date		Who		Reason
20 February 2023	navab1	TFS CR 56446 TASK 56447
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
*/

vars

begin
	//16/10/2023	navmv20	Bug 60893 - start
	if self.myContractRateMaint &lt;&gt; null then
		self.myContractRateMaint.unloadForm();
	endif;
	
	if self.myParentForm &lt;&gt; null then
		self.myParentForm.INV_ContractEnquiry.myContractMaintForm := null;
	endif;
	//16/10/2023	navmv20	Bug 60893 - end
	inheritMethod(); // ### TFS 57311 24MAR2023 NAVAB1
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateContract" id="564f76d0-9dea-488e-a216-cb48dbe4fdb6">
        <updating/>
        <source>updateContract()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jan 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint

*/

vars
	pxyCon, realCon 		: CM_InvoiceContract;
	bank 					: CM_Bank;
	debtor 					: CM_Debtor;
	desc,contractID			: String;
	scheduleTSstart 		: TimeStamp;
	scheduleTSend 			: TimeStamp;
	primarycheck,
	activeCheck				: Boolean;
	terminal				: CM_Terminal;
	theReturn : Integer;
	autoChangeEndDate : Boolean;
begin

	if self.cmbDebtor.listIndex &lt;&gt; -1 then
		debtor := self.cmbDebtor.itemObject[self.cmbDebtor.listIndex].CM_Debtor;
	endif;
	if self.txtContractID &lt;&gt; null then
		contractID := self.txtContractID.text.String;
	endif;
	if self.txtDescription &lt;&gt; null then
		desc := self.txtDescription.text.String;
	endif;
	terminal := app.myPassport.myTerminal;

	scheduleTSstart.setDate(self.mskContractFromStart.text.asDateJMT());
	scheduleTSstart.setTime(self.mskContractFromStartTime.text.asTimeJMT());
	scheduleTSend.setDate(self.mskContractFromEnd.text.asDateJMT());
	scheduleTSend.setTime(self.mskContractFromEndTime.text.asTimeJMT());
	primarycheck := self.chkPrimary.value;
	activeCheck :=  self.chkActive.value;
	/* // ### TFS BUG 60627 15NOV2023 NAVAB1
	if self.chkPrimary.value then
		self.chkActive.value := true;
	endif;
	*/

	// ### TFS CR 55646 TASK 56413 21FEB2023 NAVAB1
	if self.myInvoiceContract.toTS.date &lt;&gt; scheduleTSend.date then
		autoChangeEndDate :=  app.msgBox(app.getErrorString(Date_chang_want_this_updat_ont),app.getErrorString(Confirmation),MsgBox_Yes_No) = MsgBox_Return_Yes;
	endif;

	self.mousePointer := Window.MousePointer_HourGlass;
	
	if autoChangeEndDate then // ### BUG 56908 21MAR2023 NAVAB1
		pxyCon := self.myInvoiceContract.cloneForCopy(true,false,scheduleTSend.date, false); // ### BUG 56908 21MAR2023 NAVAB1
	else
		pxyCon := app.createUpdateProxy(self.myInvoiceContract).CM_InvoiceContract;
	endif;
	
	pxyCon.setProxy(activeCheck,contractID, self.localToSystemTime(scheduleTSstart), self.localToSystemTime(scheduleTSend), primarycheck, pxyCon.myBusinessUnit, pxyCon.myTerminal, debtor,desc); // ### BUG 58796 26JUN2023 NAVAB1 'localToSystemTime'
	
	
	while true do
		app.myTrxUA.trxUpdateInvContract(pxyCon, app.myPassport, autoChangeEndDate); // ### TFS CR 55646 TASK 56413 21FEB2023 NAVAB1
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Invoice_contrac_update_sucess), app.getErrorString(Message),MsgBox_OK_Only);
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contract_update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
	self.mousePointer := Window.MousePointer_Default;
	delete pxyCon;
	
end;</source>
    </JadeMethod>
