    <JadeMethod name="create" id="59bf4259-8102-4893-9733-f2c48919d42a">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	self.name := SOP_TableMaintForm.Table_EmailGroup;
	self.permissionView	 := PmAdmEmailaddressView;
	self.permissionMaint := PmAdmEmailaddressMaint;
	self.myDataClass := CM_EmailGroup;


end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="ae3eb4cc-6fad-4dae-a0ff-1119507139d2">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	app.myTrxDA.trxDeleteEmailGroup(pObj.CM_EmailGroup, app.myPassport);

end;</source>
        <Parameter name="pObj" type="CM_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="ac00cc38-3049-4c40-8833-46e007757465">
        <updating/>
        <source>doSave(): Boolean updating;
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
vars

	theForm			: SOP_TableMaintForm;
	title			: String;
	proxyGroup		: CM_EmailGroup;
	allSelected		: CM_EmailAddress2ByNameDict;

begin

	theForm := self.myForm; 
	title := theForm.tblInput1.getValueByName(ETRow_Title).String;
 	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_EmailGroup transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	create allSelected transient;
	theForm.mulSelect1.getSelected(allSelected);
	proxyGroup := theForm.myProxyObject.CM_EmailGroup;
	proxyGroup.setProxyForEmailGroup(title, allSelected);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateEmailGroup(proxyGroup, theForm.myCurrentObject.CM_EmailGroup, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateEmailGroup(proxyGroup, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;

epilog
	delete allSelected;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="a74686cf-0aff-4463-b676-b635455b5801">
        <source>getCollection(): Collection;
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
begin

	self.resetGroupColl();	
	return self.allEmailGroups;


end;</source>
