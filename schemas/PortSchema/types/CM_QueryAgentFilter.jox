    <JadeMethod name="qryLogLocationReports" id="d4606364-1a61-4cba-8534-3574ee0fd0b8">
        <updating/>
        <source>qryLogLocationReports(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// -----------------------------------------------------------------------------
// Created:		12 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 29/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object-based
// -----------------------------------------------------------------------------
vars
	startPos,
	numSelected 	: Integer;
	sohLocation		: CM_SOHLocation;
	iter,
	locIter  		: Iterator;
	location 		: CM_LocationsController;
	termArea		: CM_TerminalArea;
	jrwTrans		: CM_JRWOld;
	terminal		: CM_Terminal;
	cmifMonitor		: CMIF_Monitor;
	checkTypes,
	updateProgress	: Boolean;
	intTA,
	numItems		: Integer;
	failedDAC  :CM_DataAccessController;
	lastUpdated		: Decimal [20];						// PAR #35843
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);

	cmifMonitor := _passport.myCMIFMonitor;
	updateProgress := (cmifMonitor &lt;&gt; null);
	checkTypes := (not _filter.terminalAreaTypes.isEmpty);
	
	self.myRWLogDocket := self.createJRWTransient(CM_JRWOld).CM_JRWOld;
	jrwTrans := self.myRWLogDocket.CM_JRWOld;
	jrwTrans.allLocations.clear();
	jrwTrans.blockLength 	:= _filter.blockLength;
	jrwTrans.baseDate		:= _filter.baseDate;
	jrwTrans.ageType		:= _filter.ageType;

	foreach terminal in _filter.allTerminals do
		delete iter;
		iter := terminal.allTerminalAreas.createIterator();
		if _filter.getMyTerminalArea &lt;&gt; null then
			iter.startAtObject(_filter.getMyTerminalArea);
		endif;
		
		numItems := terminal.allTerminalAreas.size;
		
		while iter.next(termArea) do
			if _filter.getMyTerminalArea &lt;&gt; null and termArea &lt;&gt; _filter.getMyTerminalArea then
				break;
			endif;
			
			if checkTypes
			and (not _filter.terminalAreaTypes.includes(termArea.type)) then
				continue;
			endif;
			
			intTA := intTA + 1;
			
			if updateProgress then
				if cmifMonitor.partsInJob &lt; numItems then
					cmifMonitor.partsInJob := numItems;
				endif;
				cmifMonitor.partsDone := intTA;
				if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
					cmifMonitor.updateProgress(null, cmifMonitor.partsInJob, cmifMonitor.partsDone);
					lastUpdated := app.relativeMachineTime;													// PAR #35843
				endif;																						// PAR #35843
				//if cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel then
				//return;
				//endif;
				
				if ((cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) or
			   	(cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel))  then
					CM_BreakOutException.raise_(cmifMonitor.monitorReturnValue, 'Breaking Out');
					return jrwTrans.allLocations.size;
				endif;
			endif;
			
			delete locIter;		// PAR #26678
			locIter := termArea.allLocationsControllers.createIterator();
			while locIter.next(location) do : locationWhile

				foreach sohLocation in location.allProductLocations do
					if (not sohLocation.canUserAccessSelf(null, failedDAC, _passport)) then
						continue locationWhile;
					endif;
				endforeach; 
				if (_filter.getMyLocationsController &lt;&gt; null and _filter.getMyLocationsController &lt;&gt; location) then
					continue;
				endif;
				startPos := 1;
				if (location.isKindOf(CM_YardController)) and (_filter.locationComment &lt;&gt; null and (location.CM_YardController.remarks.toUpper.pos(_filter.locationComment.toUpper, startPos)) = 0) then
					continue;
				endif;
				
				// 28/09/2009 cnwar2 CCMS1107/#20638
				if location.isKindOf(CM_LogController) then
					if (_filter.isLocationInspected = LOG_ROW_INSPECTED and not location.CM_LogController.isInspected)
					or (_filter.isLocationInspected = LOG_ROW_NOTINSPECTED and location.CM_LogController.isInspected)
					or (_filter.isLocationFumigated = LOG_ROW_FUMIGATED and not location.CM_LogController.isFumigated)
					or (_filter.isLocationFumigated = LOG_ROW_NOTFUMIGATED and location.CM_LogController.isFumigated) then
						continue;
					endif;
				endif;
				
				jrwTrans.allLocations.add(location);
			endwhile;
		endwhile;
	endforeach;
	
	numSelected := jrwTrans.allLocations.size;

epilog
	delete iter;
	delete locIter;
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryLogSummary" id="2908bd41-d899-41e1-9cc2-ecd0ec3d84a3">
        <updating/>
        <source>qryLogSummary(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     1 Feb 2010 by cnwdz2 CCMS 1108 par22177 
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	numSelected		: Integer;
	jrwTrans		: CM_JRWLog;
	logFilter			: CMQF_Log;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	logFilter := _filter.CMQF_Log;
	jrwTrans := self.createJRWTransient(CM_JRWLog).CM_JRWLog;
	//populate the filter object's collections, references, and attributes
	jrwTrans.allTrackedItems.clear();
	_filter.filterObjects(jrwTrans.allLogSummaryData, _passport);
	
	jrwTrans.setAllTerminals(logFilter.allTerminals);
	
	jrwTrans.myVoyageGlobalActual	:= logFilter.getMyVoyageGlobalActual;
	jrwTrans.myVoyageGlobalAllocated:= logFilter.getMyVoyageGlobalAllocated;
	jrwTrans.myLogLot				:= logFilter.getMyLogLot;
	jrwTrans.logHatch				:= logFilter.logHatch;
	jrwTrans.logPlace				:= logFilter.logPlace;
	
	jrwTrans.myOperator 			:= logFilter.myOperator;
	jrwTrans.myTerminalArea 		:= logFilter.getMyTerminalArea;
	jrwTrans.myLocationsController 	:= logFilter.getMyLocationsController;
	jrwTrans.qryStartDate 			:= logFilter.startDate;
	jrwTrans.qryEndDate 			:= logFilter.endDate;

	jrwTrans.carrierCode			:= logFilter.carrierCode;
	jrwTrans.loggingOrganisation 	:= logFilter.loggingOrganisation;
	jrwTrans.gangNumber 			:= logFilter.gangNumber;

	jrwTrans.mySourceLocation 		:= logFilter.getMyQrySourceLocation;
	jrwTrans.mySourceSubLocation 	:= logFilter.getMyQrySourceSubLocation;
	jrwTrans.mySourceSubSubLocation := logFilter.getMyQrySourceSubSubLocation;
	jrwTrans.myLogSpecies 			:= logFilter.getMyLogSpecies;
	jrwTrans.myLogGrade 			:= logFilter.getMyLogGrade;
	jrwTrans.myLogType 				:= logFilter.getMyLogType;
	jrwTrans.myLogTreatment 		:= logFilter.getMyLogTreatment;
	jrwTrans.myLogLength 			:= logFilter.getMyLogLength;
	
	numSelected := jrwTrans.allLogSummaryData.size;
	
epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryLogWharfStorage" id="22adde1a-4660-413f-8ec2-db0d2d8df84c">
        <updating/>
        <source>qryLogWharfStorage(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	numSelected 	: Integer;
	docket 			: CM_BOLIn;
	jrwTrans		: CM_JRWOld;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);

	self.myRWLogDocket := self.createJRWTransient(CM_JRWOld).CM_JRWOld;
	jrwTrans := self.myRWLogDocket.CM_JRWOld;
	jrwTrans.allLocations.clear();
	_filter.filterObjects(jrwTrans.allLocations, _passport);
	
	jrwTrans.blockLength 	:= _filter.blockLength;
	jrwTrans.baseDate		:= _filter.baseDate;
	jrwTrans.ageType		:= _filter.ageType;
	
	numSelected := jrwTrans.allLocations.size;

epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryMTReport" id="dfda33f5-d68f-4b9b-a88f-8f53640d44df">
        <updating/>
        <source>qryMTReport(_filter : CMQF_FilterReports input; _passport : CM_Passport input) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		25 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWEmpty;
	tiFilter			: CMQF_EmptySpecial;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_EmptySpecial;
	
	jrwTrans := self.createJRWTransient(CM_JRWEmpty).CM_JRWEmpty;
	jrwTrans.allTrackedItems.clear();
	jrwTrans.allActiveReleases.clear();
	jrwTrans.allSummaryTIs.clear();
	jrwTrans.allRecTrans.clear();
	jrwTrans.allRelTrans.clear();
	jrwTrans.allToDoTrans.clear();
	tiFilter.filterEmptySpecial(jrwTrans, _passport);

//	tiFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	jrwTrans.qryStartDate 	:= tiFilter.startDate;
	jrwTrans.qryEndDate 	:= tiFilter.endDate;

	jrwTrans.myPort 			:= tiFilter.getMyPort;
	jrwTrans.myLoadPort 		:= tiFilter.getMyLoadPort;
	jrwTrans.myVoyage 			:= tiFilter.getMyVoyage;
	jrwTrans.myTerminalArea 	:= tiFilter.getMyTerminalArea;
	jrwTrans.myOperator 		:= tiFilter.myOperator;
	jrwTrans.myOperatorGroup 	:= tiFilter.getMyOperatorGroup;
	jrwTrans.myISOTypeGroup 	:= tiFilter.getMyISOTypeGroup;

	jrwTrans.sumRail 	:= tiFilter.sumRail;
	jrwTrans.sumRoad 	:= tiFilter.sumRoad;
	jrwTrans.sumWeight 	:= tiFilter.sumWeight;

	numSelected := jrwTrans.numItems();
	
epilog

	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryMTRequestsAvailabilitySum" id="fbdf085c-b608-4fd0-a678-062d270950e1">
        <updating/>
        <source>qryMTRequestsAvailabilitySum(_filter : CMQF_FilterReports input; _passport : CM_Passport input) : Integer updating;
//----------------------------------------------------------------
//	Created:	08 November 2004	by Jason Chapman  (cnwjc2)
//
//				16/08/2010	cnwdad1	PAR 25218.
//----------------------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWEmpty;
	tiFilter			: CMQF_Container;
	
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_Container;
	
	jrwTrans := self.createJRWTransient(CM_JRWEmpty).CM_JRWEmpty;
	jrwTrans.allTrackedItems.clear();
	jrwTrans.allActiveReleases.clear();
	jrwTrans.allSummaryTIs.clear();
	jrwTrans.allRecTrans.clear();
	jrwTrans.allRelTrans.clear();
	jrwTrans.allToDoTrans.clear();
	tiFilter.filterObjects(jrwTrans.allMTSummaryObjects, _passport);
//	tiFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	jrwTrans.qryStartDate 	:= tiFilter.startDate;
	jrwTrans.qryEndDate 	:= tiFilter.endDate;

	jrwTrans.myPort 			:= tiFilter.getMyPort;
	jrwTrans.myLoadPort 		:= tiFilter.getMyLoadPort;
	jrwTrans.myVoyage 			:= tiFilter.getMyVoyage;
	jrwTrans.myTerminalArea 	:= tiFilter.getMyTerminalArea;
	jrwTrans.myOperator 		:= tiFilter.myOperator;
	jrwTrans.myOperatorGroup 	:= tiFilter.getMyOperatorGroup;
	jrwTrans.myISOTypeGroup 	:= tiFilter.getMyISOTypeGroup;
	jrwTrans.qryAvaGradesStr	:= tiFilter.getQryAvaGradesStr;
	jrwTrans.qryPackAreasStr	:= tiFilter.getQryPackAreasStr;
	jrwTrans.packByDate			:= tiFilter.packByDate;
// cnwdad1 16/08/2010 - PAR #25218.
	jrwTrans.fromPackByDate		:= tiFilter.fromPackByDate;
	jrwTrans.toPackByDate		:= tiFilter.toPackByDate;
	
	jrwTrans.sumRail 	:= tiFilter.sumRail;
	jrwTrans.sumRoad 	:= tiFilter.sumRoad;
	jrwTrans.sumWeight 	:= tiFilter.sumWeight;

	numSelected := jrwTrans.allMTSummaryObjects.size();
epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryMachineHistory" id="4ba53cd6-a152-4dba-85d6-aea30aa49a4f">
        <updating/>
        <source>qryMachineHistory(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     01 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	count	 	: Integer;
	jrwTrans	: CM_JRWMachineHistory;
	filter		: CMQF_MachineHistory;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	filter 		:= _filter.CMQF_MachineHistory;
	jrwTrans	:= self.createJRWTransient(CM_JRWMachineHistory).CM_JRWMachineHistory;

	jrwTrans.baseDate			:= filter.baseDate;
	jrwTrans.dateFrom			:= filter.startDate;
	jrwTrans.timeFrom			:= filter.startTime;
	jrwTrans.dateTo 			:= filter.endDate;
	jrwTrans.timeTo				:= filter.endTime;
	
	filter.allDelayTypes.copy (jrwTrans.allDelayTypes);
	filter.allDelayTypeGroups.copy (jrwTrans.allDelayTypeGroups);
	
	jrwTrans.allDelayTypes.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	jrwTrans.allDelayTypeGroups.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	
	jrwTrans.myMachine 			:= filter.getMyMachine;
	jrwTrans.myMachineType		:= filter.getMyMachineType;
	jrwTrans.myUser 			:= filter.myUser;
	
	jrwTrans.setAllTerminals(filter.allTerminals);
	
	filter.filterObjects_AllColls(jrwTrans.allMachineHistory, jrwTrans.allKPIMachineByDateUser, 
			jrwTrans.allKPIMachineByShiftUser, jrwTrans.allTransientsToDelete, _passport);
	
	count := jrwTrans.allMachineHistory.size;
epilog
	return count;
end;
</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
