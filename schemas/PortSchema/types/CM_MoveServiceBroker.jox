    <JadeMethod name="auditId" id="6e616a08-35ce-4267-8971-8427d76c5413">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2017	cnwma1	Initial creation

*/

vars

begin
	return self.getTranMapBreadCrumb;

