    <JadeMethod name="doResize" id="14d845ac-3eb3-4854-b08c-f730c6ef0cb8">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
10 September 2008	consw1	Initial creation

*/

vars

begin
	inheritMethod();

	
	if self.isSearcherVisible then
		if btnSearchCollaps.enabled then
			self.showSearchParameters();
		else
			self.doCollapseSearchParameters();
		endif;
	endif;
epilog

end;</source>
