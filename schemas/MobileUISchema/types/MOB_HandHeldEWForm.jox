    <JadeMethod name="canAckWarningsSkipErrors" id="464b8f91-10d1-48fc-bd8a-58f640ef2766">
        <source>canAckWarningsSkipErrors() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:	15 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	return self.mode.bitAnd(ErrWarnMode_CanAckWarnSkipErr).Boolean;
epilog
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
