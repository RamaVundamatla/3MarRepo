    <JadeMethod name="exportMe" id="723dd8d9-de29-44d5-8da5-40dcc75d27ab">
        <source>exportMe(_file:File; _objArray:ObjectArray io);
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs1
//
// Purpose:     To allow serialisation of properties of each class     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	property:Property;
	popColl:PropertyNDict;
	object: Object;
	str,message: String;
begin
	// check if we have already been called. if so bugger off. 
	if _objArray.includes(self) then
		return;
	else
		_objArray.add(self);
	endif;
	popColl := self.class.getProperties;
	_file.writeLine("&lt;"&amp;self.class.name&amp;"&gt;");

	foreach property in popColl do
		if property.isKindOf(Attribute) then
			if property.type = StringArray then
				foreach str in self.getPropertyValue(property.getName).StringArray do //this dosnt work
					message := message &amp; "," &amp; str;
				endforeach;
				_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;message&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
			else
				_file.writeLine("&lt;"&amp;property.getName&amp;"&gt;"&amp;self.getPropertyValue(property.getName).String.trimBlanks&amp;"&lt;/"&amp;property.getName&amp;"&gt;");
				app.writeStatement(("&lt;"&amp;property.getName&amp;"&gt;"&amp;self.getPropertyValue(property.getName).String.trimBlanks&amp;"&lt;/"&amp;property.getName&amp;"&gt;"));
			endif;
		else
			object := self.getPropertyValue(property.getName).Object;
			if object &lt;&gt; null then
				if object.isKindOf(CM_Object) then
					self.exportMyReferences(_file, _objArray, property);
				elseif object.isKindOf(Collection) then
					self.exportMyCollections(_file, _objArray, property);
				endif;
			endif;
		endif;	
	endforeach;
	_file.writeLine("&lt;/"&amp;self.class.name&amp;"&gt;");

end;</source>
        <text>ExportMe will export an object out to an open output file.
You shouldnt need to override this method just call it.
I calls exportMyCollections which you will need to override 
if you want sub object to to unloaded.
Override exportMyReferences to export a reference.</text>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="exportMeAttrIgnoreXML" id="a55b8919-f2aa-40e7-b70d-4efa4bf785bb">
