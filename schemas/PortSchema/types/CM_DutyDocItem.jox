    <JadeMethod name="pxyCreateUpdateProxy" id="0af0006c-d457-4041-bdc7-75155aeb92f3">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2013	cnwer1	Initial creation HAT 2189

*/

vars
	pxyDutyDocItem : CM_DutyDocItem;
		completedOK		: Boolean;
begin
	pxyDutyDocItem:= inheritMethod();
	pxyDutyDocItem.myTrackedItem:=self.myTrackedItem;
	pxyDutyDocItem.myDutyDoc:=self.myDutyDoc;
	pxyDutyDocItem.myDutyDocTerminalRoot:=self.myDutyDocTerminalRoot;
	
	completedOK:=true;
	return pxyDutyDocItem;
epilog
	if not completedOK then
		delete pxyDutyDocItem;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
