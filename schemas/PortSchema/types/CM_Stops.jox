    <JadeMethod name="canBeViewed" id="f32465a5-a514-4e7a-b118-4751fb067b7f">
        <source>canBeViewed(_passport: CM_Passport): Boolean;
//----------------------------------------------------------------
//	Created:	01 December 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	term		: CM_Terminal;
begin

	if _passport = null
	or _passport.myUser = null then
		return true;
	endif;
	
	term := _passport.myTerminal;
	
	if _passport.myUser.canViewStop(term, self.myStopsTable) then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkStopTableRelationship" id="e521ab71-f5c2-4adf-b418-82a91d913021">
        <updating/>
        <source>checkStopTableRelationship(_stopTable : CM_StopsTable) updating;
// ---------------------------------------------------------------------------
// Created:		11 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars

begin
	if _stopTable = null then
		return;
	endif;
	if _stopTable.id &lt;&gt; self.id then
		return;
	endif;
	if self.myTrackedItem = null then		// or not global.isValidObject(self.myTrackedItem) then - inversed, so can't be invalid
		return;
	endif;
	
	if self.myStopsTable &lt;&gt; _stopTable then
		self.myStopsTable := _stopTable;	//inversed
	endif;
	
end;</source>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="delete" id="aac1e487-d379-4c6b-9d9f-74fa70df58da">
        <updating/>
        <source>delete() updating;

/*
Date			Who		Reason
24 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	// delete any transient myStopOverrideTxn here if and only if both the stop and transaction are transient.
	if self.isTransient and
	   self.myStopOverrideTxn &lt;&gt; null and
	   self.myStopOverrideTxn.isTransient then
		delete self.myStopOverrideTxn;
	endif;
	
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="deleteTransaction" id="f1a930d4-aa23-4cf1-a1ac-77d2440f5e30">
        <updating/>
        <source>deleteTransaction(_ti: CM_TrackedItem) updating;
//----------------------------------------------------------------
//	Created:	28 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	trans	: CM_TITransaction;
begin

	trans := self.myTransaction;
	if trans &lt;&gt; null
	and trans.myTrackedItem = _ti then
		//incorrect association
		trans.eraseForTrackedItem(0);
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getMyStopTablDesc" id="02fd56a1-934b-4fb1-a71c-e49e97c65917">
