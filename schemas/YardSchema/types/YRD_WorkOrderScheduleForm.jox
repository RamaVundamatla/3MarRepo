    <JadeMethod name="selectInputCell" id="e9c4eeef-4425-4ff3-a37e-ade55c8c64de">
        <updating/>
        <source>selectInputCell(_loop : Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		Position to next input cell.
//
// Parameters:	None
//
// Returns:		Sets inputRow and inputColumn.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	col, row : Integer;
	looping : Boolean;
	tbl : CM_BaseTable;
	
begin
	tbl := self.tblSchedule;
	
	self.inputRow := 0;
	self.inputColumn := 0;

	tbl.clearAllSelected();
	
	if tbl.rows &lt;= tbl.fixedRows then
		return;
	endif;

	row := tbl.row;
	col := tbl.column;
	
	while true do
		if tbl.inputType = Table.InputType_TextNumeric then
			tbl.selected := true;
			self.inputRow := tbl.row;
			self.inputColumn := tbl.column;
			if tbl.topRow &gt; self.inputRow or tbl.positionTop() &lt; 0 then
				tbl.topRow := self.inputRow;
			endif;	
			if tbl.leftColumn &gt; self.inputColumn or tbl.positionLeft() &lt; 0 then
				tbl.leftColumn := self.inputColumn;
			endif;
			return;
		endif;

		tbl.selected := false;

		if tbl.column &lt; tbl.columns then
			tbl.column := tbl.column + 1;
		else
			if looping and tbl.row &gt;= row then
				break;
			elseif tbl.row = tbl.rows then
				if _loop then
					looping := true;
					tbl.row := tbl.fixedRows;
				else
					break;
				endif;
			endif;
			tbl.row := tbl.row + 1;
			tbl.column := tbl.fixedColumns + 1;
		endif;
	endwhile;
	
	tbl.row := row;
	tbl.column := col;
				
epilog

end;</source>
        <Parameter name="_loop" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="set" id="1ba039bf-d090-4914-bf73-a73b04b90e12">
        <updating/>
        <source>set(_workOrder : CM_WorkOrder) updating;
// -----------------------------------------------------------------------------
// Created:		13 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	self.myWorkOrder := _workOrder;
epilog

end;</source>
