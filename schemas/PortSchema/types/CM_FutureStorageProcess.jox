    <JadeMethod name="getCargoTypeId" id="e306b55e-cf2a-4703-91ab-18918c0c32f8">
        <source>getCargoTypeId() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/

vars

begin
