    <JadeMethod name="mdhCheckFormCaptBubbDtls" id="1c5a88b9-5b94-4408-a551-90ecfdd08946">
        <source>mdhCheckFormCaptBubbDtls();

/*

Purpose:			

Date			Who		Reason
09/11/2016		cnwmh5	Initial creation

*/

vars

	form					: Form;
	form1					: Form;
	cntrl					: Control;
	tmpMenu					: MenuItem;
	prop					: Property;
	xlatCaption				: XLAT_FormCaption;
	klass					: Class;
	schema					: Schema;
	
	xlatDict				: DynaDictionary;
	propsToGet				: StringArray;
	schemaArray				: SchemaColl;
	classesArray			: ClassColl;
	allowableSchemasArray	: StringArray;
	
	numControls				: Integer;
	index					: Integer;
	controlName				: String;
	doBreak					: Boolean;
	schemaName				: String;
	index1					: Integer;
	xlatString				: String;
	

begin

	create xlatDict transient;
	xlatDict.setMembership(XLAT_FormCaption);
	xlatDict.addMemberKey("vSchemaName", true, false);
	xlatDict.addMemberKey("vFormClass", true, false);
	xlatDict.addMemberKey("vControlName", true, false);
	xlatDict.addMemberKey("vControlProperty", true, false);
	xlatDict.endKeys(true);
	XLAT_FormCaption.instances.copy(xlatDict);	
	
	create propsToGet transient;
	propsToGet.add("caption");
	propsToGet.add("bubbleHelp");
	
	create allowableSchemasArray transient;									
	allowableSchemasArray.add("PortSchema");
	allowableSchemasArray.add("MobileServerSchema");
	allowableSchemasArray.add("MobileUISchema");
	allowableSchemasArray.add("UiCommonSchema");
	allowableSchemasArray.add("GateSchema851");
	allowableSchemasArray.add("GeneralCargoSchema");
	allowableSchemasArray.add("HmsSchema");
	allowableSchemasArray.add("InvoiceSchema");
	allowableSchemasArray.add("LogSchema851");
	allowableSchemasArray.add("LOGAS400LoadSchema");
	allowableSchemasArray.add("ShipSchema");
	allowableSchemasArray.add("SysOpsSchema");
	allowableSchemasArray.add("WebSchema851");
	allowableSchemasArray.add("WebExampleSchema");
	allowableSchemasArray.add("WebServicesSchema");
	allowableSchemasArray.add("XMLSchema851");
	allowableSchemasArray.add("YardSchema");

	create schemaArray transient;
	schemaArray.add(rootSchema.getSchema(UiCommonSchemaName));
	schemaArray.add(rootSchema.getSchema(MobileUISchemaName));
	
	create classesArray transient;
	
	foreach schema in schemaArray do
		if schema.name &lt;&gt; MobileUISchemaName then
			schema.getClass(CM_BaseForm.name).allSubclasses(classesArray);
			schema.getClass(CM_BaseForm.name).allSubclassesInSubschemas(classesArray);
		else
			schema.getClass('MOB_BaseForm').allSubclasses(classesArray);
			schema.getClass('MOB_BaseForm').allSubclassesInSubschemas(classesArray);
		endif;
	endforeach;
	
	foreach klass in classesArray do
		if not allowableSchemasArray.includes(klass.schema.name) then						
			continue;
		endif;	
		schemaName := klass.schema.name;
		foreach form in Form.instances do
			if form.name = klass.name then
				write schemaName &amp; Tab &amp; form.name;
				numControls := form.controlCount;
				foreach index in 1 to numControls do
					cntrl := form.controls(index);
					
					controlName := cntrl.getPropertyValue('name').String;
					
					foreach index1 in 1 to propsToGet.size do
						prop := cntrl.class.getPropertyInHTree(propsToGet[index1]);
						if prop &lt;&gt; null then
							xlatCaption := xlatDict.getAtKey(schemaName, form.name, cntrl.name, propsToGet[index1]).XLAT_FormCaption;
							xlatString := null;
							if xlatCaption &lt;&gt; null then
								xlatString := xlatCaption.vConstantName;
							endif;
							if cntrl.getPropertyValue(propsToGet[index1]).String.cnContains("_") then
								write Tab &amp; controlName &amp; Tab &amp; prop.name &amp; Tab &amp; cntrl.getPropertyValue(propsToGet[index1]).String &amp; Tab &amp; 
									xlatString &amp; Tab &amp; (cntrl.getPropertyValue(propsToGet[index1]).String = xlatString).String;
							endif;
						endif;
					
					endforeach;
					
				endforeach;
			endif;
		endforeach;
	endforeach;
	
epilog

	delete xlatDict;
	delete propsToGet;
	delete schemaArray;
	delete classesArray;
	delete allowableSchemasArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhCheckFormCaptions" id="a2390565-cd94-4424-803a-436dd6804dfd">
        <source>mdhCheckFormCaptions();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
07 May 2012	cnwmh5	Initial creation

*/

vars

	meth					: Method;
	lsConstant				: LSconstant;
	form					: Form;
	cntrl					: Control;
	tmpMenu					: MenuItem;
	//captionsAgent			: FormCaptionsAgent;
		
	methSource				: String;
	attribute				: String;
	constant				: String;
	sourceLine				: String;
	str						: String;
	controlName				: String;
	constantProperty		: String;
	commentedOutStartOfLine	: String;
	commentedOutEndOfLine	: String;
	logMsg					: String;
	
	posCrLf					: Integer;
	length					: Integer;
	pos1					: Integer;
	pos2					: Integer;
	isCommentedOut			: Boolean;
	numControls				: Integer;
	index					: Integer;
	numMenus				: Integer;
	multiCommentOut			: Boolean;


begin

	
	foreach form in Form.instances do
		if form.name = "SOP_TableMaintForm" then
			break;
		endif;
	endforeach;
	
	write form.name &amp; Tab &amp; form.getPropertyValue('name').String;
	
	numControls := form.controlCount;
	foreach index in 1 to numControls do
		cntrl := form.controls(index);
		
		if cntrl.isKindOf(Button)
				or cntrl.isKindOf(Label)
				or cntrl.isKindOf(JadeDockBase)
				or cntrl.isKindOf(StatusLine)
				or cntrl.isKindOf(GroupBox)
				or cntrl.isKindOf(Frame)
				or cntrl.isKindOf(CheckBox)
				or cntrl.isKindOf(OptionButton) then
			
			controlName := cntrl.getPropertyValue('name').String;
			
			
			write Tab &amp; controlName &amp; Tab &amp; cntrl.getPropertyValue('caption').String;
			
		endif;
		
	endforeach;
	
	/*
	numMenus := form.menuItemCount;
	foreach index in 1 to numMenus do
		tmpMenu := form.menuItems(index);
		
		if tmpMenu.isSeparatorJMT() then
			//self.log(class.name &amp; '::' &amp; method.name &amp; ' SEPARATOR ' &amp; tmpMenu.name, true);
			continue;
		endif;
		
		if tmpMenu.name = null then
			//self.log(class.name &amp; '::' &amp; method.name &amp; ' NULL MENU NAME ', true);//&amp; tmpMenu.name;
			continue;
		endif;
		
		controlName := tmpMenu.getPropertyValue('name').String;
		
		lsConstant := _lsClass.allConstants[_lsSchema.name, form.name, tmpMenu.name, 'caption'];
		if lsConstant = null then
			self.handleFormTranslation2(_lsSchema, _lsClass, self.makeConstantName(_lsClass.name, tmpMenu.getPropertyValue('name').String, 'caption'), 
					tmpMenu.getPropertyValue('name').String, 'caption', tmpMenu.getPropertyValue('caption').String, null, null, false, true);
		else
		if lsConstant.text &lt;&gt; tmpMenu.getPropertyValue('caption').String then
			logMsg	:=	'*** WARNING - Existing constant has different value ' &amp; lsConstant.name &amp; Tab &amp; lsConstant.formName &amp; Tab &amp; 
					lsConstant.controlName &amp; Tab &amp; lsConstant.controlProperty &amp; Tab &amp; lsConstant.text &amp; Tab &amp; tmpMenu.getPropertyValue('caption').String;
			self.log(logMsg, true);
		endif;
	endif;
	endforeach;
	*/

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhCheckVoyageMyVessel" id="a5942235-94e8-49f6-9808-797c4d39f598">
        <source>mdhCheckVoyageMyVessel();

/*

Purpose:		Check voyages myVessel is set correctly	

Parameters:			

Return Value:		


Date			Who		Reason
19 June 2013	cnwmh5	Initial creation

*/

vars

	terminal					: CM_Terminal;
	voyage						: CM_Voyage;
	vessel						: CM_Vessel;

begin

	app.initialize();
	
	write "term" &amp; Tab &amp; 'term name' &amp; Tab &amp; 'voy oid' &amp; Tab &amp; 'voy created date' &amp; Tab &amp; 'voy created time' &amp; Tab &amp; 
		'voy code' &amp; Tab &amp; 'voy ves code' &amp; Tab &amp; 'voy ves name' &amp; Tab &amp; 'voy myves code' &amp; Tab &amp; 'voy myves name' &amp; Tab &amp; 
		'ves oid';
	
	foreach terminal in app.myRoot.allTerminals do
	
		foreach voyage in terminal.allVoyagesByCode do
		
			vessel := app.myRoot.allVessels[voyage.vesselCode];
		
			if voyage.myVessel = null then
				write terminal.code &amp; Tab &amp; terminal.name &amp; Tab &amp; voyage.String &amp; Tab &amp; voyage.creationTime.date.String &amp; Tab &amp; voyage.creationTime.time.String &amp; Tab &amp; 
					voyage.code &amp; Tab &amp; voyage.vesselCode &amp; Tab &amp; voyage.vesselName &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; vessel.String;
				continue;
			endif;
		
			
					
			write terminal.code &amp; Tab &amp; terminal.name &amp; Tab &amp; voyage.String &amp; Tab &amp; voyage.creationTime.date.String &amp; Tab &amp; voyage.creationTime.time.String &amp; Tab &amp;
				voyage.code &amp; Tab &amp; voyage.vesselCode &amp; Tab &amp; voyage.vesselName &amp; Tab &amp; voyage.myVessel.code &amp; Tab &amp; voyage.myVessel.name &amp; Tab &amp; vessel.String;
		
		
		endforeach;
	
	
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhCheckWhenLastRun" id="6c0c0d9e-4eb6-461f-bbb6-96f6cd00b751">
        <source>mdhCheckWhenLastRun();

/*

Purpose:		From the CSV dump from TestLink check to see what version the test was last run in

Date			Who		Reason
23/09/2013		cnwmh5	Initial creation

*/

vars

	xmlDoc						: JadeXMLDocument;
	elementTestCase				: JadeXMLElement;
	xmlAttribute				: JadeXMLAttribute;
	xmlElement					: JadeXMLElement;
	xmlCDATA					: JadeXMLCDATA;
	fileFolder					: FileFolder;
	fileNode					: FileNode;
	file						: File;
	obj							: Object;
	outputFile					: File;

	allFiles					: FileNodeArray;
	testCaseDict				: DynaDictionary;
	
	testCaseXMLArray			: JadeXMLElementArray;
	
	lineArray					: StringArray;
	resultArray					: HugeStringArray;
	systemIdArray				: StringArray;
		
	iter						: Iterator;
		
	externalId					: String;
	testSuite					: String;
	testCaseName				: String;
	directoryName				: String;	
	systemId					: String;
	line						: String;
	testName					: String;
	lastExecution				: String;
	index 						: Integer;
	testName2					: String;
	systemId2					: String;
	currentTestCaseName 		: String;
	firstTime					: Boolean;
	results						: String;
	posCount					: Integer;
	lastRun						: String;
	needsAttention				: String;
	recordCount					: Integer;
	tempStr						: String;
	
begin

	directoryName := "c:\testlink\results";
	
	create lineArray transient;
	create systemIdArray transient;
	
	delete testCaseDict;
	create testCaseDict transient;
	testCaseDict.setMembership(HugeStringArray);
	testCaseDict.addExternalKey(String, 350, false, false);			// Full Test Name
	testCaseDict.addExternalKey(String, 15, false, false);			// System name
	testCaseDict.endKeys(false);
	
	// create and load the test project xml docuemnt
	create xmlDoc transient;
	xmlDoc.parseFile(directoryName &amp; "\Master Terminal.xml");
	
	// get the test suite elements
	create testCaseXMLArray transient;
	xmlDoc.getElementsByTagName('testcase', testCaseXMLArray);
	
	///write "testCaseXMLArray size: " &amp; testCaseXMLArray.size.String;
	
	foreach elementTestCase in testCaseXMLArray do
		testCaseName := null;
		xmlAttribute := elementTestCase.getAttributeByName("name");
		if xmlAttribute.value = null then
			continue;
		endif;
		testCaseName := xmlAttribute.value.String;
		
		// get the test case id
		xmlElement := elementTestCase.getElementByTagName("externalid");
		externalId := null;
		if xmlElement &lt;&gt; null then
			xmlCDATA := xmlElement.childNodes.first.JadeXMLCDATA;
			externalId := xmlCDATA.data.String;
		endif;
		
		// get the test suite details for the test
		testSuite := null;
		while true do
			xmlElement := xmlElement.parentElement;
			if xmlElement = null then
				break;
			endif;
			xmlAttribute := xmlElement.getAttributeByName("name");
			if xmlAttribute &lt;&gt; null and xmlAttribute.value &lt;&gt; null then
				if xmlAttribute.value &lt;&gt; testCaseName then
					testSuite := xmlAttribute.value.String &amp; "/" &amp; testSuite.trimBlanks();
				endif;
			endif;
		endwhile;
		testSuite := testSuite[1:testSuite.length-1];
		
		systemId := null;
		testCaseName := testCaseName.replaceString(",", " ");
		create resultArray transient;
		testCaseDict.putAtKey(testSuite &amp; "    " &amp; "01-" &amp; externalId &amp; ":" &amp; testCaseName, systemId,  resultArray);
		////write testSuite &amp; Tab &amp; "01-" &amp; externalId &amp; ":" &amp; testCaseName &amp; Tab &amp; systemId;
	endforeach;
	testCaseXMLArray.clear();
	delete xmlDoc;
	
	// read through the csv files
	create fileFolder transient;
	fileFolder.fileName := directoryName;
	if not fileFolder.isValidPathName(fileFolder.fileName) or not fileFolder.isAvailable() then
		write "Unable to find directory (" &amp; fileFolder.fileName &amp; ")";
		return;
	endif;

	// get the files in the directory
	allFiles := fileFolder.files();

	//iter := testCaseDict.createIterator;
	
	foreach fileNode in allFiles do
	
		// don't care about directory's
		if not fileNode.isKindOf(File) then
			continue;
		endif;
		
		// don't want anything that doesn't have an exension of eml.
		if fileNode.fileName[fileNode.fileName.length - 3: end] &lt;&gt; ".csv" then
			continue;
		endif;
	
		// don't want the output file to be created
		if fileNode.fileName.toUpper().cnContains("TESTCASEDETAILS") then
			continue;
		endif;
	
		// get the system name
		systemId := fileNode.fileName[fileNode.fileName.length - 14:11];
		////write fileNode.fileName &amp; Tab &amp; Tab &amp; systemId;
		
		// save systemIds
		if not systemIdArray.includes(systemId) then
			systemIdArray.add(systemId);		
		endif;
		
		// get the file details
		delete file;
		create file transient;
		file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
		file.fileName := fileNode.fileName;
		
		line := null;
		while not file.endOfFile do
		
			// don't want the header line
			if line = null then
				file.readLine();
			endif;
		
			line := file.readLine;
			lineArray.clear();
			lineArray := line.cnGetTokens(",");
			
			testName := lineArray[1] &amp; "    " &amp; lineArray[2];
			testName := testName.replaceString(",", "");
			lastExecution := lineArray[lineArray.size];
			index := 1;
			lastExecution := lastExecution.scanUntil("[", index).trimBlanks();
			
			delete iter;
			iter := testCaseDict.createIterator;
			testCaseDict.startKeyLeq(testName, null, iter);
			while iter.next(obj) do
				testCaseDict.getIteratorKeys(testName2, systemId2, iter);
				///write testName &amp; Tab &amp; testName2;
				if testName = testName2 then
					create resultArray transient;
					resultArray.add(lastExecution);
					testCaseDict.putAtKey(testName, systemId, resultArray);
					if systemId2 = null then
						testCaseDict.removeKey(testName, null);
					endif;
					break;
				endif;
			endwhile;
					
		endwhile;
		
	endforeach;
		
	create outputFile transient;
	outputFile.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	outputFile.fileName := directoryName &amp; "\TestCaseDetails.csv";
	if outputFile.isAvailable() then
		outputFile.close();
		outputFile.purge();
	endif;
	
	systemId := null;
	foreach index in 1 to systemIdArray.size do	
		if systemId &lt;&gt; null then
			systemId := systemId &amp; ",";
		endif;
		systemId := systemId &amp; systemIdArray[index];
	endforeach;
	outputFile.writeLine("Test Case," &amp; systemId &amp; ",Last Run,Needs Attention");
	
	delete iter;
	iter := testCaseDict.createIterator;
	posCount := 1;
	recordCount := 0;
	currentTestCaseName := null;
	firstTime := true;
	while iter.next(obj) do
	
		resultArray := obj.HugeStringArray;
		testCaseDict.getIteratorKeys(testName, systemId, iter);
		
		///tempStr := null;
		///if not resultArray.isEmpty() then
		///	tempStr := resultArray[1];
		///endif;
		
		// first time so set the currentTestCaseName
		if firstTime then 
			currentTestCaseName := testName;
			firstTime := false;
		endif;
		
		if testName &lt;&gt; currentTestCaseName then
			
			results := results[1: results.length - 1];
			
			// pad out results
			lineArray.clear();
			results.getTokensForDelimiter(",", lineArray);
			if lineArray.size &gt; 0 then
				if lineArray.size &lt; systemIdArray.size then
					index := lineArray.size + 1;
					foreach index in index to systemIdArray.size do
						results := results &amp; ",";
					endforeach;
				endif;
			else
				index := systemIdArray.size - 2;
				foreach index in index to 0 step -1 do
					results := results &amp; ",";
				endforeach;
			endif;
			
			// work out when last run
			lineArray.clear();
			results.getTokensForDelimiter(",", lineArray);
			lastRun := null;
			foreach index in 1 to lineArray.size do
				if lineArray[index].trimBlanks() = "Passed" or lineArray[index].trimBlanks() = "Failed" or 
						lineArray[index].trimBlanks() = "Blocked" then
					lastRun := systemIdArray[index];
				endif;
			endforeach;
			
			// work out whether need to check
			needsAttention := null;
			tempStr := null;
			if lineArray.size = 0 then
				needsAttention := "Y";
			elseif lastRun.trimBlanks().length = 0 then
				index := systemIdArray.size - 1;
				foreach index in index to 1 step - 1 do
					tempStr := tempStr.trimBlanks() &amp; lineArray[index];
				endforeach;
				if tempStr.trimBlanks().length &lt;&gt; 0 or 
						(tempStr.trimBlanks().length = 0 and lineArray[lineArray.size].trimBlanks().length = 0) then
					needsAttention := "Y";
				endif;
			else
				index := systemIdArray.indexOf(lastRun);
				if index &lt;= (systemIdArray.size - 3) then
					needsAttention := "Y";
				endif;
			endif;
			
			outputFile.writeLine(currentTestCaseName &amp; "," &amp; results &amp; "," &amp; lastRun &amp; "," &amp; needsAttention);
			///write currentTestCaseName &amp; "," &amp; results &amp; "," &amp; lastRun &amp; "," &amp; needsAttention;
			
			currentTestCaseName := testName;
			results := null;
			posCount := 1;
			recordCount := 0;
			
		endif;
		
		recordCount := recordCount + 1;
		index := systemIdArray.indexOf(systemId);
		if index &gt; 0 then
			if posCount &lt;&gt; index then
				index := index - 1;
				foreach posCount in posCount to index do
					results := results &amp; ",";
				endforeach;
			endif;
			if resultArray.isEmpty() then
				results := results &amp; ",";
			else
				results := results &amp; resultArray[1] &amp; ",";
			endif;
			posCount := posCount + 1;
		endif;
		
	endwhile;
	
epilog

	file.close();
	outputFile.close();

	delete iter;

	delete testCaseXMLArray;
	delete resultArray;	
	delete systemIdArray;
	
	delete file;
	delete outputFile;
	
	delete lineArray;
	
	delete xmlDoc;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhChkTranslFormCommentDoWork" id="7ee0d739-191b-44ed-9a45-081b881f4885">
        <source>mdhChkTranslFormCommentDoWork(_method : Method);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2011	cnwmh5	Initial creation

*/
constants
	CAPTION				: String = ".translateCaption";
	BUBBLE				: String = ".translateBubbleHelp";
	COMMENT				: String = "//";
vars

	commentedAttribs	: StringArray;

	methodSource		: String;
	
	pos					: Integer;
	pos1				: Integer;
	posComment			: Integer;
	
	attrib				: String;
	line				: String;
	
begin

	create commentedAttribs transient;

	methodSource := _method.getSource();
	
	pos := 1;
	while true do
	
		line := methodSource.cnGetToken(pos, CrLf);
		if line = null then
			continue;
		endif;
		if line = 'end;' then
			break;
		endif;
		
		pos1 := 0;
		if line.cnContains(CAPTION) then
			pos1 := line.pos(CAPTION, 1);
		elseif line.cnContains(BUBBLE) then
			pos1 := line.pos(BUBBLE, 1);
		endif;
		
		if pos1 = 0 then
			continue;
		endif;
		
		posComment := line.pos(COMMENT, 1);
		if posComment &gt; pos1 then
			continue;
		elseif posComment = 0 then
			// need to check to see if attribute is in collection of commented attributes
			attrib := line[1:pos1-1].trimBlanks();
			attrib.cnReplaceString(Tab, "");
			if commentedAttribs.includes(attrib) then
				write _method.getSchemaType().schema.name &amp; Tab &amp; _method.getSchemaType().name &amp; Tab &amp; _method.name &amp; Tab &amp; 
					attrib &amp; Tab &amp; _method.cnGetModifierName() &amp; Tab &amp; _method.cnGetModifiedTimeStamp().String;
			endif;
		else
			// need to add to collection of commented attributes 
			attrib := line[posComment+2:pos1-posComment-2].trimBlanks();
			attrib.cnReplaceString(Tab, "");
			if not commentedAttribs.includes(attrib) then
				commentedAttribs.add(attrib);
			endif;
		endif;
	
	
	endwhile;

epilog

	delete commentedAttribs;

end;</source>
        <Parameter name="_method" type="Method"/>
    </JadeMethod>
    <JadeMethod name="mdhChkTranslateFormComments" id="52ab2c62-c5a2-43fa-90e0-3a77a78f7e02">
        <source>mdhChkTranslateFormComments();


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwmh5	Initial creation

*/

vars

	schema				: Schema;
	class				: Class;
	meth				: Method;

	classesArray		: ClassColl;
	schemaArray			: SchemaColl;

begin
	
	create schemaArray transient;
	schemaArray.add(rootSchema.getSchema(UiCommonSchemaName));
	schemaArray.add(rootSchema.getSchema(MobileUISchemaName));
	
	create classesArray transient;

	foreach schema in schemaArray do
		if schema.name &lt;&gt; MobileUISchemaName then
			schema.getClass(CM_BaseForm.name).allSubclasses(classesArray);
			schema.getClass(CM_BaseForm.name).allSubclassesInSubschemas(classesArray);
		else
			schema.getClass('MOB_BaseForm').allSubclasses(classesArray);
			schema.getClass('MOB_BaseForm').allSubclassesInSubschemas(classesArray);
		endif;
	endforeach;
	
	// process the classes that have a translateForm method
	foreach class in classesArray do
	
		// check to see if the class has a translateForm method
		meth := class.getMethod("translateForm");
		if meth = null then
			continue;
		endif;

		// process the method to see if commented and uncommented details
		self.mdhChkTranslFormCommentDoWork(meth);	
		
	endforeach;
	
	
epilog

	delete classesArray;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhCompareNewOldCode" id="9c615b20-c0c0-4e72-bd62-18861623f1f5">
        <source>mdhCompareNewOldCode();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
20 January 2012	cnwmh5	Initial creation

*/

vars


	file						: File;
	obj							: Object;
	newFile						: File;
	diffFile					: File;
	fileNodeObj					: FileNode;
	fileFolder1					: FileFolder;
	fileFolder2					: FileFolder;
	
	jdo							: JadeDynamicObject;
	jdoTest						: JadeDynamicObject;
	
	dictOld  					: DynaDictionary;
	dictNew  					: DynaDictionary;
	
	allFilesOld					: FileNodeArray;
	allFilesNew					: FileNodeArray;
	
	currentClassName			: String;
	currentMethodName			: String;
	attribute					: String;
	text						: String;
	propertyType				: String;
	
	isCommentedOut				: Boolean;
	diffFound					: Boolean;
	newFieldsFound				: Boolean;

begin
	app.initialize();
	
	// get the files in the specified directory
	create allFilesOld transient;
	create allFilesNew transient;
		
	// load the details from *Schema-NEW.txt
	delete fileFolder1;
	create fileFolder1 transient;
	fileFolder1.fileName := "c:\translate";
	fileFolder1.mask := "*Schema-NEW.txt";
	//fileFolder1.mask := "ShipSchema-NEW.txt";
	if not fileFolder1.isValidPathName(fileFolder1.fileName) or not fileFolder1.isAvailable() then
		write 'fileFolder (' &amp; fileFolder1.fileName &amp; ') not found.  Exiting.';
		return;
	endif;
	allFilesOld := fileFolder1.files();

	foreach fileNodeObj in allFilesOld do
	
		if dictOld &lt;&gt; null then
			dictOld.purge;
		endif;
		delete dictOld;
		create dictOld transient;
		dictOld.setMembership(JadeDynamicObject);
		dictOld.addExternalKey(String, 35, false, true);					// class name
		dictOld.addExternalKey(String, 35, false, true);					// method name
		dictOld.addExternalKey(String, 35, false, false);					// attribute
		dictOld.addExternalKey(String, 35, false, true);					// type   e.g. caption or bubbleHelp
		dictOld.endKeys(false);
		
		self.mdhCreateJDOForComparison(fileNodeObj.File, dictOld);
		
		// load the details from *-FormCaptions-partial-NEW.txt
		allFilesNew.clear();
		delete file;
		create file transient;
		//file.fileName := "C:\translate\GateSchema-FormCaptions-partial-NEW.txt";
		file.fileName := fileNodeObj.fileName[1:fileNodeObj.fileName.length - 8] &amp; "-FormCaptions-partial-NEW.txt";
		if not file.isAvailable then
			return;
		endif;
		allFilesNew.add(file);
		
		if dictNew &lt;&gt; null then
			dictNew.purge;
		endif;
		delete dictNew;
		create dictNew transient;
		dictNew.setMembership(JadeDynamicObject);
		dictNew.addExternalKey(String, 35, false, true);					// class name
		dictNew.addExternalKey(String, 35, false, true);					// method name
		dictNew.addExternalKey(String, 35, false, false);					// attribute
		dictNew.addExternalKey(String, 35, false, true);					// type   e.g. caption or bubbleHelp
		dictNew.endKeys(false);
		
		self.mdhCreateJDOForComparison(file, dictNew);
	
		// Create the *-FIELDS-NEW file
		create newFile transient;
		newFile.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version
		newFile.fileName := fileNodeObj.fileName[1:fileNodeObj.fileName.length - 8] &amp; "-FormCaptions-partial-FIELDS-NEW.txt";
		if newFile.isAvailable then
			newFile.purge;
		endif;
		newFile.writeLine("class" &amp; Tab &amp; "method" &amp; Tab &amp; "commented" &amp; Tab &amp; "attribute" &amp; Tab &amp; "text");
		
		// Create the *-DIFF-NEW file
		create diffFile transient;
		diffFile.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version
		diffFile.fileName := fileNodeObj.fileName[1:fileNodeObj.fileName.length - 8] &amp; "-FormCaptions-partial-DIFF-NEW.txt";
		if diffFile.isAvailable then
			diffFile.purge;
		endif;
		diffFile.writeLine("class" &amp; Tab &amp; "method" &amp; Tab &amp; "commented" &amp; Tab &amp; "attribute" &amp; Tab &amp; "old text" &amp; Tab &amp; "new text");
	
		diffFound := false;
		
		foreach obj in dictOld do
			jdo := obj.JadeDynamicObject;
			currentClassName := jdo.getPropertyValue("className").String;
			currentMethodName := jdo.getPropertyValue("methodName").String;
			attribute := jdo.getPropertyValue("attribute").String; 
			propertyType := jdo.getPropertyValue("propertyType").String;
			text := jdo.getPropertyValue("text").String;
			
			jdoTest := dictNew[currentClassName, currentMethodName, attribute, propertyType].JadeDynamicObject;
			if jdoTest = null then
				newFile.writeLine(currentClassName &amp; Tab &amp; currentMethodName &amp; Tab &amp; isCommentedOut.String &amp; Tab &amp; 
					propertyType &amp; Tab &amp; attribute &amp; Tab &amp; text);
				newFieldsFound := true;
			else
				///write jdoTest.getPropertyValue("text").String.length.String &amp; Tab &amp; jdoTest.getPropertyValue("text").String &amp; CrLf &amp;
				///	text.length.String &amp; Tab &amp; text;
				if jdoTest.getPropertyValue("text").String.trimBlanks() &lt;&gt; text.trimBlanks() then
					diffFile.writeLine(currentClassName &amp; Tab &amp; currentMethodName &amp; Tab &amp; isCommentedOut.String &amp; Tab &amp; 
						propertyType &amp; Tab &amp; attribute &amp; Tab &amp; text &amp; Tab &amp; jdoTest.getPropertyValue("text").String);
					diffFound := true;
				endif;
			endif;
						
		endforeach;
		
		if not newFieldsFound then
			newFile.purge;
		endif;
		
		if not diffFound then
			diffFile.purge;
		endif;
		
	endforeach;
	
epilog

	if dictOld &lt;&gt; null then
		dictOld.purge;
	endif;
	delete dictOld;
	
	if dictNew &lt;&gt; null then
		dictNew.purge;
	endif;
	delete dictNew;

	delete file;
	delete newFile;
	delete diffFile;
	delete fileFolder1;
	delete fileFolder2;

end;
</source>
    </JadeMethod>
    <JadeMethod name="mdhConvertFilesSoCanCompare" id="c038720b-6732-4718-974d-54954f46ee5f">
        <source>mdhConvertFilesSoCanCompare();

/*

Purpose:		Remove stuff that isn't source, create xml.  Reload new xml file and create one from partial to 
				compare with newly created one.

Parameters:			

Return Value:		


Date			Who		Reason
19 January 2012	cnwmh5	Initial creation

*/

vars
	
	
	schema					: Schema;
	klass					: Class;
	obj						: Object;
	
	file					: File;
	outputFile				: File;
	
	fileFolder1				: FileFolder;
	fileFolder2				: FileFolder;
	fileNodeObj				: FileNode;
	
	allFiles				: FileNodeArray;
	filesPartial			: FileNodeArray;
	filesSource				: FileNodeArray;
	
begin
	
	
	schema := rootSchema.getSchema("SchemaComparisonUtility");
	if schema = null then
		write "Unable to find SchemaComparisonUtility.  Exiting JadeScript.";
		return;
	endif;
	
	klass := schema.getClass("SchemaComparisonUtility");
	if klass = null then
		write "Unable to find JadeScript.  Exiting JadeScript.";
		return;
	endif;
	
	create obj as klass transient;
	
	
	// get the files in the specified directory
	create allFiles transient;
	
	delete fileFolder1;
	create fileFolder1 transient;
	fileFolder1.fileName := "c:\translate";
	if not fileFolder1.isValidPathName(fileFolder1.fileName) or not fileFolder1.isAvailable() then
		write 'fileFolder (' &amp; fileFolder1.fileName &amp; ') not found.  Exiting.';
		return;
	endif;
	
	create filesSource transient;
	fileFolder1.mask := "*Schema.scm";
	filesSource := fileFolder1.files();
	filesSource.copy(allFiles);
	
	delete fileFolder2;
	create fileFolder2 transient;
	fileFolder2.fileName := "c:\translate";
	if not fileFolder2.isValidPathName(fileFolder2.fileName) or not fileFolder2.isAvailable() then
		write 'fileFolder (' &amp; fileFolder2.fileName &amp; ') not found.  Exiting.';
		return;
	endif;
	
	create filesPartial transient;
	fileFolder2.mask := "*-FormCaptions-partial.scm";
	filesPartial := fileFolder2.files();
	filesPartial.copy(allFiles);	
	
	foreach fileNodeObj in allFiles do
	
		delete file;
		create file transient;
		file.fileName := fileNodeObj.fileName;
		
		delete outputFile;
		create outputFile transient;
		outputFile.fileName := file.fileName[1:file.fileName.length - 4] &amp; "-NEW" &amp; ".txt";
		if outputFile.isAvailable then
			outputFile.purge;
		endif;
	
		//write file.fileName &amp; Tab &amp; outputFile.fileName;
	
		obj.sendMsgWithIOParams('sortSCMByClassMethodWithParams', file, outputFile);
	
	endforeach;
	
epilog
	
	delete file;
	delete outputFile;
	
	delete obj;
	
	delete allFiles;
		
end;
</source>
    </JadeMethod>
