    <JadeMethod name="startListenerApp" id="9938fe55-628a-44c2-bbd3-1e8151192754">
        <source>startListenerApp();

vars

begin
	app.setProfileString(app.getIniFileName(), 'WebOptions', 'JMMobileListener_WebServicesURL', 'tcp, ' &amp; app.myRoot.getClientConnectionFormatted());
	self.startApplication('JMMobileBase', 'JMMobileListener');
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="0f8bef6b-87fa-4a48-bebe-fa1e2abd19d0">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars

begin
//	write class.name &amp; '::' &amp; method.name &amp; ' received event ' &amp; eventType.String;
	if eventType = Event_TerminateListenerApp then
		terminate;
	endif;
	
	inheritMethod(eventType, theObject, eventTag, userInfo);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeStatement" id="4c49b26a-34dc-49c0-83be-0c40cfb0c002">
        <source>writeStatement(_str : String) ;//serverExecution; 
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
// 03 Mar 2008	conks1a		PAR #16047 - remove unnecessary serverExecution for performance
//--------------------------------------------------------------------------
*/
vars
	ab : JadeLog;
	
begin
	create ab;
	ab.fileName := "GDANSKTEST.txt";
	
	ab.log(_str);
	
	delete ab;
end;


</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
