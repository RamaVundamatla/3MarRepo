    <JadeMethod name="getDisplayStringForAttribute" id="59781fb5-3e5e-4258-b1de-b5388057322d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 23 January 2007
// 22/03/2022  navsrk20   #52821 - EUP - Documents Linked to Cargo Types
// 26/11/2022  navvt20	  Task 55527: UI - Invoice List Attachments
// 5/12/2022   navvt20    TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
// 18/01/2022  navtnr20	  Defect 56219: File Attachment - After upload showing error
// 25/01/2023  navvt20 	  TFS CR 56204 Task 56207: UI - File Attachment List new column
// 22 June 2023 navtnr20	TFS CR 58224	Task 58228: UI - COO Attachments
//----------------------------------------------------------------------

vars

begin
	
	
	if _attrName = ETRow_User then
		return self.userCode;
	elseif	_attrName = ETRow_Category then // 5 Dec 2022 navvt20 TFS 55520
		if self.myCategory &lt;&gt; null then
			return self.myCategory.description; // 5 Dec 2022 navvt20 TFS 55520
		endif;
		return null;
	elseif _attrName = ETRow_Source then
		// 09/03/2022 jlizm1 TFS 52834 
		if self.myParent &lt;&gt; null then
			return self.myParent.getFileCategoryStr();// ### TFS CR 56094 TASK 59618 08AUG2023 NAVAB1
		endif;
	elseif _attrName = ETRow_Remarks then // ### TFS CR 55299 TASK 55520 15DEC2022 NAVAB1
		if self.remarks.length &gt; 100 then // ### TFS CR 55299 TASK 55520 15DEC2022 NAVAB1
			return self.remarks[1:100] &amp; "..."; // ### TFS CR 55299 TASK 55520 15DEC2022 NAVAB1
		else // ### TFS CR 55299 TASK 55520 15DEC2022 NAVAB1
			return self.remarks;
		endif;
	elseif _attrName = ETRow_External then		//25 Jan 2023 navvt20 TFS 56207
		return self.getInvoiceExternalOnly.asStringJMT;	//25 Jan 2023 navvt20 TFS 56207
	endif;
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceExternalOnly" id="accda76a-e09d-4d1e-9d79-5b7599f6325d">
        <source>getInvoiceExternalOnly() : Boolean;
/*

Purpose:			Gets Whether an Invoice Note is marked as internal only

Parameters:			NONE

Return Value:		Boolean	Representing whether or not the invoice note is internal only

Date				Who		Reason
25 Jan 2023			navvt20 TFS CR 56204 Task 56207: UI - File Attachment List new column

*/

begin
	if  self.myCategory&lt;&gt;null and self.myCategory.external then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="54e80190-b05b-4358-9974-9d6074074486">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 August 2022		jlizm1	Initial creation TFS 54298 EUP - Simplified Voyage Work Order Process
05 Dec    2022		navvt20 TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
15 Feb 2023			navds21 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
*/

vars
	proxy : CM_FileData;
begin
	proxy := inheritMethod();
	
	//proxy.myParent	 := self.myParent;
	proxy.myCategory 	 := self.myCategory;  			 // 1 Dec 2022 navvt20 TFS 55520
	proxy.remarks 		 := self.remarks;        		 // 5 Dec 2022 navvt20 TFS 55520
	proxy.actionContext  := self.actionContext; 		 //22.2.2023 navhl20	#56625[56517]
	return proxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a28d1fa6-8fcf-479b-af78-2a2b02f26fa4">
        <updating/>
        <source>setForCreate(_parent 			: CM_Object; 
			 _userCode 			: String; 
			 _myCategory 		: CM_FileDataCategory; 
			 _remarks 			: String;
			 _file 				: File;
			 _description		: String; 
			 _heading			: String; 
			 _context 			: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 1 Dec 2022  navvt20 TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
// 15 Feb 2023 navds21 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
vars

begin


	self.myParent	:= _parent;
	self.userCode	:= _userCode;
	self.myCategory := _myCategory; 									// 1 Dec 2022 navvt20 TFS 55520
	self.remarks    := _remarks;   	 									// 5 Dec 2022 navvt20 TFS 55520
	//self.setDetailsFromFile(_file,_description, _heading); 			//22.2.2023 navhl20	#56625[56517]
	self.setDetailsFromFile(_file,_description, _heading,_context);		//22.2.2023 navhl20	#56625[56517]


end;</source>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_myCategory" type="CM_FileDataCategory"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_file" type="File"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateProxy" id="f57feff7-d52b-4beb-bde4-a1dabc32f3ee">
        <updating/>
        <source>setForCreateProxy( _parent 		 : CM_Object;
					_userCode 	 : String;
					_pxyFileData : CM_FileData input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Mar 2018	jlger1	Initial creation
01 Dec 2022 navvt20 TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
15/02/2023	navcs2	Bug 56586: EUP - Voyage Work orders documents are not linked correctly
15 Feb 2023 navma1 	ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
15 Feb 2023 navds21 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
*/

vars
	storageDetail,
	pxyStorageDetail : CM_FileDataStorageDetail;
	fileData		 : Binary;
begin
	self.myParent		:= _parent;						// 15/02/2023 navcs2 Bug 56586
	self.userCode		:= _userCode;
	self.description	:= _pxyFileData.description;
	self.dateTime		:= _pxyFileData.dateTime;
	self.fileName		:= _pxyFileData.fileName;
	self.heading		:= _pxyFileData.heading[1:50];	// 15.02.2023 navma1 #56561
	self.myCategory 	:= _pxyFileData.myCategory; 	// 1 Dec 2022 navvt20 TFS 55520
	self.remarks 		:= _pxyFileData.remarks;		// 5 Dec 2022 navvt20 TFS 55520
	self.actionContext 	:= _pxyFileData.actionContext;  //22.2.2023 navhl20	#56625[56517]
	
	foreach pxyStorageDetail in _pxyFileData.allFileDataStorageDetail do
		create storageDetail persistent;		
		storageDetail.set(pxyStorageDetail.fileName, pxyStorageDetail.csvBlob,null,self);
	endforeach;
epilog

end;</source>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_pxyFileData" type="CM_FileData" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="02b8025e-4d79-4122-9457-483c7b34b721">
        <updating/>
        <source>setForUpdate(_pxyFile : CM_FileData) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 August 2022		jlizm1	Initial creation TFS 54298 EUP - Simplified Voyage Work Order Process
1 Dec 2022 			navvt20 TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
15 Feb 2023 		navds21 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
*/

vars

begin
	inheritMethod(_pxyFile);
	//self.userCode := _pxyFile.userCode;
	self.myCategory := _pxyFile.myCategory;			 // 1 Dec 2022 navvt20 TFS 55520
	self.remarks    := _pxyFile.remarks;   			 // 5 Dec 2022 navvt20 TFS 55520
	self.actionContext := _pxyFile.actionContext; 	 //22.2.2023 navhl20	#56625[56517]
epilog

end;</source>
        <Parameter name="_pxyFile" type="CM_FileData"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b85857f8-8362-4928-9d16-dd184674bbda">
        <updating/>
        <source>setProxy( _description		: String; 
			_heading		: String;
			_remarks 		: String;
			_parent			: CM_Object;
			_myCategory 	: CM_FileDataCategory;
			_context		: Integer		//22.2.2023 navhl20	#56625[56517]
		) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Dec 2022	navvt20	TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
15 Feb 2023 navds21 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
*/

vars

begin
	self.myParent	   := _parent;
	self.myCategory    := _myCategory; 
	self.description   := _description;
	self.heading 	   := _heading[1:50];		//15.02.2023 navma1 #56561
	self.remarks 	   := _remarks;
	self.actionContext := _context;				//22.2.2023 navhl20	#56625[56517]
epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_myCategory" type="CM_FileDataCategory"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="f59425b8-330e-44d9-99b3-84421954f886">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navmk20	Bug 58087: FR | EUP 54086 - Invoicing - Maintenance Enhancements 090.h

*/

vars

begin
	if _property = null then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
