    <JadeMethod name="setComboValues" id="6e6f07a7-d451-4840-9ef5-2fc4b329ec7c">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #32215 CCMS DPH 2290 New Car Attributes
//
vars
	carModel		: CM_VehicleModel;
	carModelDict	: CM_VehicleModelByModel;
	
begin
	_combo.clear();
	carModelDict := app.myDutyDocRoot.allVehicleModels;
	
	foreach carModel in carModelDict do
		_combo.itemObject[_combo.addItem(carModel.model)] := carModel;
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := carModelDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := carModelDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="2df442d8-ca46-4213-b802-381f2bbcdf01">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #322156 CCMS DPH 2290 New Car Attributes
//
vars
	carModel 		: CM_VehicleModel;
	carModelDict 	: CM_VehicleModelByModel;
	selectionValue,
	idx				: Integer;
	array			: ObjectArray;
	
begin
	carModelDict := app.myDutyDocRoot.allVehicleModels;
	
	_tbl.rows := _tbl.fixedRows;
	
	//doesn't know about CMUI_ListTable - so have to do this:
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach carModel in carModelDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and  _operator.CM_QStringIsOneOf.allSelectionValues.includes(carModel.model) then
			selectionValue := 1;
			array.add(carModel);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab  &amp; carModel.model);
		_tbl.accessRow(idx).itemObject := carModel;
	endforeach;
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="004630df-9ae4-49ec-81cf-bbb2e944f38c">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #33215 CCMS DPH 2290 New Car Attributes
//
vars
	carModel	: CM_VehicleModel;
	str			: String;
	numRows,
	idx			: Integer;
	sa			: StringArray;

begin
	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			carModel := _tbl.accessRow(idx).itemObject.CM_VehicleModel;
			sa.add(carModel.model);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="56ba64c2-ffaf-4e65-993d-4068a123339e">
        <source>translateToDisplayValue(_value: Any): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #33215 CCMS DPH 2290 New Car Attributes
//
vars

begin
	if _value.isKindOf(CM_VehicleModel) then
		if _value &lt;&gt; null then
			return _value.CM_VehicleModel.model;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="2f0612bb-f8db-4630-aedc-cb5992202618">
        <source>translateToSearchValue(_value: Any): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #32215 CCMS DPH 2290 New Car Attributes
//
vars
	invalidObj 		: Boolean;
	object			: CM_VehicleModel;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_VehicleModel) then
			object := _value.CM_VehicleModel;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		returnVal := object.model;
	endif;
	
	return returnVal;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="b65a72f2-1cf4-48f7-88ab-138f1e344c81">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(String) then	
		return _value.String;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
