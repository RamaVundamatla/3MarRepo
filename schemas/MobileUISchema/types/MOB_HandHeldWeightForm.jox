    <JadeMethod name="setupControls" id="eb23ed7d-1e32-4e68-aba8-471719aeb80a">
        <updating/>
        <source>setupControls() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/03/2010	cnwdap1	Initial creation PAR #23369
26/03/2010	cnwdap1	PAR #23064 Don't show "Is Certifiable" if cargo type is not weighable
31/03/2010	cnwdap1	PAR #22741 Centralise context checking
31/03/2010	cnwdap1	PAR #23064 Incorrectly checking cargoType.isWeighable, should be cargoType.canWeightBeCertified
*/
vars
	state		: Integer;
	context		: Integer;
	cargoCheck	: CM_CargoCheck;
	item 		: CM_CargoCheckItem;
	toDo		: CM_ToDoTask;
	
begin
	
	// PAR #22741
	cargoCheck := self.myMobileGenericAgent.getEquipCheckContextFromState();
	if cargoCheck &lt;&gt; null then
		foreach item in cargoCheck.allCargoCheckItems discreteLock where item.requiredExtraInfo = EXTRA_INFO_WEIGHT do	//31 May 2012	NDL Par 29038
			if item.myToDoTaskDesc &lt;&gt; null then
				self.myCargoCheckItem := item;
				self.chkToDo.visible := true;
				self.chkToDo.caption := item.myToDoTaskDesc.description;//cnwas3 par 24175 change the caption so it reflects what the todo task is
				if self.myTrackedItem &lt;&gt; null then
					foreach toDo in self.myTrackedItem.allToDoTasksToDo where toDo.toDoTaskDescCode = item.myToDoTaskDesc.code do
						self.chkToDo.value := true;
					endforeach;
				endif;
			endif;
		endforeach;
	endif;
	
	self.doResizeControls(true);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="72e672ec-3b8d-4ebd-a36c-014b5146eb0f">
        <updating/>
        <source>setupForm() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 March 2010	cnwdap1	Initial creation PAR #23369
*/
vars

	prod : CM_Product;

begin

	if self.baseCaption = null then
		self.baseCaption := self.caption;
	endif;

	self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;
	app.myMobileAgent.setMyProxy( self.myTrackedItem );
	app.myMobileAgent.setMySelectedTI(self.myTrackedItem);
	
	self.caption := self.baseCaption &amp; "  " &amp; myTrackedItem.cargoTypeDescr;

	inheritMethod();
	
	if self.myTrackedItem &lt;&gt; null then
		prod := self.myTrackedItem.getProductForMeasurementConv();
	endif;
	
//	self.lblWeight.caption := self.lblWeight.caption &amp; self.myMobileDataAgent.getMeasureLabelUnit(prod,Type_Weight);
	
	self.setupCmdButtons( 2, app.getErrorString(Save), BACK_BUTTON, null, null, null );
	self.setupControls();
	self.displayWeight();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
