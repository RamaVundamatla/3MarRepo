    <JadeMethod name="getPropertyFromColumnName" id="f270820e-9bd5-460f-b6d5-e8fe6e9626cd">
        <source>getPropertyFromColumnName(_columnName: String): Property;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2025	jlier1	Initial creation
12 Nov 2025 navlc30 JIRA 36357 - LINX - Enable importing debtor addresses via EDI

*/

vars

begin
	if _columnName = ETRow_DeliveryPartyCode then
		return CM_EDIAddressTI::id;
	elseif _columnName = ETRow_AddressLine1 then
		return CM_EDIAddressTI::address1;
	
	elseif _columnName = ETRow_AddressLine2 then
		return CM_EDIAddressTI::address2;
		
	elseif _columnName = ETRow_AddressLine3 then
		return CM_EDIAddressTI::address3;
	
	elseif _columnName =ETRow_AddressPostCode then
		return CM_EDIAddressTI::postCode;
		
	elseif _columnName = ETRow_AddressRegion then
		return CM_EDIAddressTI::region;
		
	elseif _columnName = ETRow_AddressCountry then

		return	CM_EDIAddressTI::countryCode;
		
	elseif _columnName = ETRow_AddressCity then
		return CM_EDIAddressTI::city;
		
	elseif _columnName = ETRow_EmailAddress then				//12.11.2025 navlc30 #36357
		return CM_EDIAddressTI::emailAddress;
	else

		return inheritMethod(_columnName);
	endif;

	

epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0819ac8a-bfdc-4807-9e2a-1f79a0fb08a1">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2025	jlier1	Initial creation 33694
12 Nov 2025 navlc30 JIRA 36357 - LINX - Enable importing debtor addresses via EDI

*/

vars

begin
	inheritMethod(_proxyEDITI);
	self.address1:=_proxyEDITI.address1;
	self.address2:=_proxyEDITI.address2;
	self.address3:=_proxyEDITI.address3;
	self.city:=_proxyEDITI.city;
	self.code :=_proxyEDITI.code;
	self.countryCode:=_proxyEDITI.countryCode.trimBlanks;
	self.deliveryInstructions:=_proxyEDITI.deliveryInstructions;
	self.isDefault:=_proxyEDITI.isDefault;
	self.postCode:=_proxyEDITI.postCode;
	self.region:=_proxyEDITI.region;
	self.emailAddress:= _proxyEDITI.emailAddress;				//12.11.2025 navlc30 #36357
	self.isAlternate := _proxyEDITI.isAlternate; 				//12.11.2025 navlc30 #36357
	
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="4940c68c-93f6-4d8c-aa22-7f48b60d26cd">
        <updating/>
        <source>verifySelf() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2025	jlier1	Initial creation 33694

*/

vars

begin
	if self.countryCode &lt;&gt; null and app.getMyRoot.allCountries[self.countryCode] = null then
		app.raiseCMException1(Invalid_country_specified,self.countryCode,null,null);
		
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
