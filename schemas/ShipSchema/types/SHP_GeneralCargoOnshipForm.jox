        <source>searchSelectAll() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2010	cnwmd1	Initial creation

*/

vars

begin
	if self.lstCargoTypes.areAllRowsSelected(true) then
		self.lstCargoTypes.clearSelected;
	else
		self.lstCargoTypes.selectAll();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="813af3d4-7bd8-4129-9a8d-631f15ce9e8c">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;

vars

begin
	if _theTable = self.tblBOL then
		//epr par 31274 12/3/13 col organiser didn't remember when switching type of table
		_theTable.setXMLStrForTblColumns(false, self.xmlStrBOL);		

		self.showBOLsForVoyage();
	elseif _theTable = self.tblBOLItems then
		self.showBOLCargo();
	elseif _theTable = self.tblCargo then
		self.showCargoOnBoard();
	endif;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableHeadings" id="b914f49d-1aed-47d0-8a0e-d1e2baba7853">
        <updating/>
        <source>setTableHeadings(_table : CM_DataTable input; _type : String) updating, protected;

vars
	theDef 	: EntTableDef;
begin
	if _table = null then
		return;
	endif;
	
	theDef := app.myController.getEntTableDef(_type);
	
	_table.setTblDataEntRowsFromDef(theDef);
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="setToolbarSearch" id="6e36052b-9f97-4adc-a858-ea9940d31b02">
        <source>setToolbarSearch() protected;
//7 July 2022 navukv20 ChangeRequest 53915: MTN - BOL Maintenance Toolbars
vars
	toolbar : CMUI_Toolbar; //7 July 2022 navukv20  53915 MTN - BOL Maintenance Toolbars
begin
	//7 July 2022 navukv20  53915 MTN - BOL Maintenance Toolbars
	//Start
	toolbar := self.frmQueryToolbar;
	toolbar.showCaptions := frmToolbar.showCaptions;
	self.positionQueryFrame();
	//End
	
	self.frmSelectToolbar.showCaptions := self.frmToolbar.showCaptions;
	self.frmSearchToolbar.showCaptions := self.frmToolbar.showCaptions;
	
	self.frmSelector.height := self.frmSelectToolbar.height + self.tblFilter.height + 10;
	self.tblFilter.top := self.frmSelectToolbar.height;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupContextMenu" id="028671ab-5bec-4387-90c4-431cfca24b22">
        <updating/>
        <source>setupContextMenu(_table : Table input) updating, protected;
// enable right-click menus selectively based on table and current selection
vars
	ti  : CM_TrackedItem;
	obj : CM_Object;
begin
	
	self.mnuTransactions.visible:=false;
	self.mnuSendToReport.visible := false;
	
	if _table = self.tblBOL then
		self.mnuTableSearch.visible := self.btnBOLSearch.enabled;
		self.mnuTableEditStops.visible := true;					//cnwmc5 - 28 April 2014 - CCMS 2352
		self.mnuCustomsStatus.visible := (self.myCurrentBOL.isKindOf(CM_BOLIn) and self.myCurrentBOL.CM_BOLIn.hasCustomsStatusMessages());		//cnwmc5 - 3 July 2014 - CCMS 2353
	
		self.mnuTransactions.visible:=true;
		self.mnuSendToReport.visible := true;
		
		//24 Oct 2017	NDL	TFS 6940
		self.mnuOutTurnBOL.visible := true;
		self.mnuOutTurnVoy.visible := true;
		
	elseif _table = self.tblBOLItems then
		self.mnuTableSearch.visible := self.btnBOLItemSearch.enabled;
		self.mnuTableEditStops.visible := false;				//cnwmc5 - 28 April 2014 - CCMS 2352
	
	//	if self.tblBOLItems.allSelectedObjects.includesBulkOrBreakBulk() then
	//		self.mnuOutTurnBOL.visible := true;
	//		self.mnuOutTurnBOL.userObject := _table;
	//	endif;
	
	elseif _table.name = self.tblStowagePlan.name then
		self.mnuTableSearch.visible := self.btnStowageSearch.enabled;
		self.mnuTableEditStops.visible := false;				//cnwmc5 - 28 April 2014 - CCMS 2352
	elseif _table = self.tblStowageItems then
		self.mnuTableSearch.visible := self.btnStowItmSearch.enabled;
		self.mnuTableEditStops.visible := false;				//cnwmc5 - 28 April 2014 - CCMS 2352
	elseif _table = self.tblCargo then
		if self.myCurrentBOLDetail &lt;&gt; null then
			self.mnuTableLink.visible := true;
		endif;
		self.mnuTableSearch.visible := self.btnCOBSearch.enabled;
		self.mnuTableEditStops.visible := false;				//cnwmc5 - 28 April 2014 - CCMS 2352
	endif;

	obj := _table.accessRow(_table.row).itemObject.CM_Object;
	if not global.isValidObject(obj) then
		return;
	endif;
	// show search, edit &amp; delete menu items
	self.mnuTableEdit.visible := true;
	if _table &lt;&gt; self.tblBOL then
		self.mnuTableDelete.visible := true;
	endif;
	if _table = self.tblBOLItems then
		//self.mnuTableRelink.visible := true;	// not until implemented
		self.mnuTableUnlink.visible := true;
		self.mnuTransfer.visible := obj &lt;&gt; null;
	endif;
	if obj.isKindOf(CM_TrackedItem) then
		ti := obj.CM_TrackedItem;
		self.buildCargoMenu(ti);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c67d7412-04de-4e56-b842-ce3231a10aba">
        <updating/>
        <source>setupForm() updating;


// 5/12/12 	PJS		PAR #30787
//28 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
vars

begin
	self.baseCaption := self.caption;
	inheritMethod();
	
	//+ cnwmd1 Par 22846
	self.frmQuery.zOrder(1);
	self.positionQueryFrame();
	self.fldQuery.useSheetBackColors := true;
	self.fldQuery.setDefaultSheetBackColors();
	self.fldQuery.initSheetBackColors();
	self.initQueryFrame();
	
	self.createMyAssistant(CMUI_Assistant);
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.addSearchToolbarControls;
	
	self.btnInstruction.enabled := false;//28.10.2022 navtnr20 TFS 54967
	self.initBOLTable();	//epr par 31274 12/3/13 col organiser didn't remember when switching type of table

	self.initTable(self.tblCargo, ETDef_GCVoyageData);
	tblCargo.removeColumnByEntRowName(ETRow_BillOfLading);	//30787
	self.initTable(self.tblBOLItems, ETDef_GCVoyageData);
	tblBOLItems.removeColumnByEntRowName(ETRow_BillOfLading);  //30787
	
	self.initTable(self.tblStowageItems, ETDef_GCOnship);
	
	self.moveModeForm := REAL_MODE;
	

	self.lblBOLSearch.width := self.lblBOLSearch.parent.Control.clientWidth - self.btnBOLSReset.width - 2;
	self.lblBOLItemSearch.width := self.lblBOLItemSearch.parent.Control.clientWidth- self.btnBISReset.width - 2;
	self.lblCOBSearch.width := self.lblCOBSearch.parent.Control.clientWidth- self.btnCOBSReset.width - 2;
	
	self.doComboCargoBuild(); //+ cnwmd1 Par 22846
	self.doComboReconciledBuild();	//30787
	
	self.btnBOLAdd.enabled := app.myPassport.myUser.canDo(self.myTerminal, PmAdmBOLMaint); // 27/04/2010 cnwmh5 PAR23943
	self.btnBOLDelete.enabled := app.myPassport.myUser.canDo(self.myTerminal, PmAdmBOLMaint); 		//cnwmc5 - 1 May 2014 - PAR 34074

	//** probably only one set of these notification registrations on Event_BOLAdd, Event_BOLUpdate is actually needed
	self.beginClassNotification(CM_BOL, false, self.myTerminal.getTerminalEvent(Event_BOLAdd), Response_Continuous, 0);
	self.beginClassNotification(CM_BOL, false, self.myTerminal.getTerminalEvent(Event_BOLUpdate), Response_Continuous, 0);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Event_BOLAdd), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Event_BOLUpdate), Response_Continuous, null);
	self.beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Add), Response_Continuous, 0);
	
	
	/*
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Voyage_Create_Event), Response_Continuous, null);  //cnwrd1 par 23145 12.3.2010 - monitor voyage adds/deletes for search combo
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Voyage_Delete_Event), Response_Continuous, null); //cnwrd1 par 23145 12.3.2010 - monitor voyage adds/deletes for search combo
	*/	
	self.beginClassNotification(CM_Voyage, false, Object_Create_Event, Response_Continuous, 0); //cnwrd1 par 23145 12.3.2010 - do user notes not work for voyages?? Should be above but didnt work.
	self.beginClassNotification(CM_Voyage, false, Object_Delete_Event, Response_Continuous, 0);	

	self.doResize();
	
	// TFS 2198
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnCOBAdd.enabled:= false;
		self.btnCOBDelete.enabled:= false;
		self.btnBOLAdd.enabled:= false;
		self.btnBOLDelete.enabled:= false;
		self.btnBOLItemAdd.enabled:= false;
		self.btnBOLItemDelete.enabled:= false;
		self.btnStowItmEdit.enabled:= false;
		self.btnStowItmDelete.enabled:= false;
		self.btnTransfer.enabled:= false;
		self.mnuTableEdit.enabled:= false;
		self.mnuTableEditStops.enabled:= false;
		self.mnuTransfer.enabled:= false;
		self.mnuTableAdd.enabled:= false;
		self.mnuTableDelete.enabled:= false;
		self.mnuTableUnlink.enabled:= false;
		self.mnuCargo.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showBOLCargo" id="2b636d97-7a26-4a3c-b676-4fe1f8873558">
        <source>showBOLCargo() protected;
// 23144 handle cargo linked to BOL but not BOL detail
vars

begin
	if self.isBOLDetailMode() then
		self.showBOLDetailCargo();
	else
		self.showBOLCargoItems();
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showBOLCargoItems" id="1bd3739b-cb3b-4e90-a2ae-52e0b018a888">
        <source>showBOLCargoItems() protected;
// par 23144 show tracked items attached to the BOL but not to any BOL detail
// 01/02/2017 cnwma1 TFS #3269:PAR38601 STWO - Duplicate cargo lines being created in Voyage BOL maintenance screen
// 28 Aug 2024 navah1	Bug 64204: MTN - Table row limit reached on Voyage BOL maintenance cannot be closed 

vars
	count	: Integer;
	obj : CM_Object;
	ti	: CM_TrackedItem;
begin
	if self.myCurrentBOL = null then
		return;
	endif;
	
	self.tblBOLItems.rows := self.tblBOLItems.fixedRows;
	self.tblBOLItems.clearAllSelected();
	self.myCurrentBOL.fetchLatest();
	//foreach ti in self.myCurrentBOL.allTrackedItems where ti.myBOLDtl = null do		    // cnwmc5 - 14 April 2014 - CCMS 2352
	//foreach ti in self.myCurrentBOL.allTrackedItems  do									// cnwmc5 - 14 April 2014 - CCMS 2352 //01/02/2017 cnwma1 TFS #3269
	foreach ti in self.myCurrentBOL.allTrackedItems where ti.state &lt;&gt; TI_STATE_MERGED do    // 01/02/2017 cnwma1 TFS #3269
		count := count + 1;
		if self.includeBOLItems(ti) then
			obj := ti;
			self.addItemObjectToTable(obj, self.tblBOLItems);
		endif;
		if self.tblBOLItems.rows = JadeTableRowLimit then									// 28.08.2024 navah1 #64204	
			app.msgBox('Maximum number of entries in table reached.  Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;
	endforeach;

	btnBOLItemSearch.enabled := (count &gt; 0);
	btnBOLItemEdit.enabled := false;
	btnBOLItemDelete.enabled := false;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showBOLDetailCargo" id="70d1b53f-a45d-411e-b15e-57f08a3a1853">
        <source>showBOLDetailCargo() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Aug 2024 navah1	Bug 64204: MTN - Table row limit reached on Voyage BOL maintenance cannot be closed 

*/
vars
	count : Integer;
	obj : CM_Object;
	ti	: CM_TrackedItem;
begin
	if self.myCurrentBOLDetail = null then
		return;
	endif;
	
	self.tblBOLItems.rows := self.tblBOLItems.fixedRows;
	self.tblBOLItems.clearAllSelected();
	self.myCurrentBOLDetail.fetchLatest();
	foreach ti in self.myCurrentBOLDetail.allTrackedItems do
		count := count + 1;
		if self.includeBOLItems(ti) then
			obj := ti;
			self.addItemObjectToTable(obj, self.tblBOLItems);
		endif;
		
		if self.tblBOLItems.rows = JadeTableRowLimit then	// 28.08.2024 navah1 #64204	
			app.msgBox('Maximum number of entries in table reached.  Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;
	endforeach;

	btnBOLItemSearch.enabled := (count &gt; 0);
	btnBOLItemEdit.enabled := false;
	btnBOLItemDelete.enabled := false;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showBOLsForVoyage" id="90180891-4f3b-4bda-a3bb-9c8c3fbf4a54">
        <updating/>
        <source>showBOLsForVoyage() updating, protected;
// 28 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
vars
	bolDetailMode : Boolean;
	bolCount	: Integer;
	bol : CM_BOL;
	bolDetail	: CM_BOLDtl;
	obj	: CM_Object;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	//epr par 31274 12/3/13 col organiser didn't remember when switching type of table

	self.tblBOL.rows := self.tblBOL.fixedRows;
	self.tblBOLItems.rows := self.tblBOLItems.fixedRows;
	self.btnBOLEdit.enabled := false;
	self.btnInstruction.enabled := false;	//28.10.2022 navtnr20 TFS 54967
	self.btnBOLDelete.enabled := false;		//cnwmc5 - 1 May 2014 - PAR 34074
	//self.btnBOLSearch.enabled := false;
	self.btnBOLItemSearch.enabled := false;
	self.btnBOLItemEdit.enabled := false;
	self.btnBOLItemDelete.enabled := false;
	self.hasBOLs := false;
	// only CM_BOLIn required, not BOLOut
	foreach bol in self.myCurrentVoyage.allBOLInByTypeStatusNumDT do
		if self.isBOLDetailMode() then
			foreach bolDetail in bol.allBOLDtls do
				bolCount := bolCount + 1;
				if self.includeBOLDetails(bolDetail) then
					obj := bolDetail;
					self.addItemObjectToTable(obj, self.tblBOL);
				endif;
			endforeach;
		else
			// 23144 handle cargo linked to BOL but not BOL detail
			if self.includeBOL(bol) then
				bolCount := bolCount + 1;
				obj := bol;
				self.myCurrentBOL :=bol;
				self.addItemObjectToTable(obj, self.tblBOL);
			endif;
		endif;
	endforeach;
	// if only one BOL, show its cargo automatically
	if bolCount = 1 then
		//epr 34278 9/6/14
		self.myCurrentBOLDetail := bolDetail;
		if self.myCurrentBOLDetail &lt;&gt; null then
			self.myCurrentBOL:=self.myCurrentBOLDetail.myBOL;
		endif;
		self.showBOLCargo();
	endif;
	self.hasBOLs := (bolCount &gt; 0);
//	self.btnBOLSearch.enabled := self.hasBOLs; // no need  PAr #30787
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showCargoOnBoard" id="5ee7751a-92aa-4d36-8130-971d2af79f95">
        <updating/>
        <source>showCargoOnBoard() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Aug 2024 navah1	Bug 64204: MTN - Table row limit reached on Voyage BOL maintenance cannot be closed 

*/
vars
	rowIdx : Integer;
	obj : CM_Object;
	ti : CM_TrackedItem;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	self.btnCOBEdit.enabled := false;
	self.btnCOBDelete.enabled := false;
	self.tblCargo.rows := self.tblCargo.fixedRows;
	self.hasCOB := false;

	foreach ti in self.myCurrentVoyage.allOnshipTIsByIdCargoType do
		// don't show items already assigned to a BOL detail for this voyage
		if ti.myBOLDtl &lt;&gt; null then
			continue;
		endif;
		
		// cnwmc5 - 16 April 2014 - CCMS 2352
		if not self.isBOLDetailMode() and ti.myReceivalBOL &lt;&gt; null then
			continue;
		endif;
		
		// cnwmc5 - 16 April 2014 - CCMS 2352
		if ti.getImExStatus() = TI_IMEX_STATUS_REMAINONBOARD
		and ti.dischargePort &lt;&gt; self.myTerminal.getDefaultPort().code then
			continue;
		endif;
		
		self.hasCOB := true;
		if self.includeCOBItems(ti) then
			obj := ti;
			self.addItemObjectToTable(obj, tblCargo);
		endif;
		
		// 21.08.2024 navah1 #64204	
		if self.tblCargo.rows = JadeTableRowLimit then
			app.msgBox('Maximum number of entries in table reached.  Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;
		
	endforeach;
	self.btnCOBSearch.enabled := self.hasCOB;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showHideSearch" id="40c3708a-4a5b-43f2-95fe-509b7beff556">
        <updating/>
        <source>showHideSearch() updating, protected;
// various Search button/menu selection
//
//  4/12/12	PJS 	PAR #30787
//	12 April 2022	navds20  TFS 53359
//

constants	
	//TOP_Y = 65;		//TFS 53359
	TOP_Y = 105;		//TFS 53359
vars

begin

	// clear stuff first from all controls - otherwise they are carrieid through from diffeent searches
	resetSearch;	
	
	//08 Mar 2018	NDL	TFS 37401 - Only Steve would do this.  And he did!
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage), app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;

	if self.frmSearch.visible then
		self.frmSearch.visible := false;
	else
		self.frmSearch.cnEcResizeContents();
		self.frmSearch.centreWindow();
		self.lblSearchType.caption := getSearchType();
		if self.searchType = Search_BOL then
			lblSearchId.visible := false;
			txtSearchId.visible := false;
			lblSearchLocatn.visible := false;
			txtSearchLocn.visible := false;
			lblSearchOper.visible := false;
			cmbSearchOper.visible := false;
			
			lblSearchBOL.top := TOP_Y;
			lblSearchBOL.visible := true;
			cmbSearchBOL.top := TOP_Y;
			cmbSearchBOL.visible := true;
			lblSearchCType.top := TOP_Y + 25;
			lblSearchCType.visible := true;
			cmbSearchCType.top := TOP_Y + 25;
			cmbSearchCType.visible := true;
			lblSearchMarks.top := TOP_Y + 50;
			lblSearchMarks.visible := true;
			txtSearchMarks.top := TOP_Y + 50;
			txtSearchMarks.visible := true;
			lblSearchCommod.top := TOP_Y + 75;
			lblSearchCommod.visible := true;
			cmbSearchCommod.top := TOP_Y + 75;
			cmbSearchCommod.visible := true;
			
			lblReconciled.visible := true;
			lblReconciled.top := TOP_Y + 100;
			cmbReconciled.visible := true;
			cmbReconciled.top := TOP_Y + 100;
						
			lblSearchOper.visible := true;
			lblSearchOper.top := TOP_Y + 125;
			cmbSearchOper.visible := true;
			cmbSearchOper.top := TOP_Y + 125;
							
									
			frmSearch.height := lblSearchOper.top + 45;
			
			// 27/04/2010 cnwmh5 PAR23943
			self.cmbSearchCType.clear;
			self.cmbSearchCType.listCollection(self.allCargoTypes, false, 0);	
			
			self.cmbSearchBOL.clear;
			self.cmbSearchBOL.listCollection(self.myCurrentVoyage.allBOLInByTypeStatusNumDT, false, 0);	
			cmbSearchBOL.listObject := self.filterBOL;
			
			cmbSearchCType.listObject := self.filterBOLCargoType;
			txtSearchMarks.text := self.filterBOLMarks;
			cmbSearchCommod.setObject(self.filterBOLCommodity);
			cmbSearchOper.setObject(self.filterBOLOperator);
			
		//30787 - Voyage rationalisation	
		elseif self.searchType = Search_BOL_Detail then
			lblSearchId.visible := false;
			txtSearchId.visible := false;
			lblSearchLocatn.visible := false;
			txtSearchLocn.visible := false;
			lblSearchOper.visible := false;
			cmbSearchOper.visible := false;
			
			lblReconciled.visible := false;
			cmbReconciled.visible := false;
			
			lblSearchBOL.top := TOP_Y;
			lblSearchBOL.visible := true;
			cmbSearchBOL.top := TOP_Y;
			cmbSearchBOL.visible := true;
	
	
			lblSearchCType.top := TOP_Y + 25;
			lblSearchCType.visible := true;
			cmbSearchCType.top := TOP_Y + 25;
			cmbSearchCType.visible := true;
			lblSearchMarks.top := TOP_Y + 50;
			lblSearchMarks.visible := true;
			txtSearchMarks.top := TOP_Y + 50;
			txtSearchMarks.visible := true;
			lblSearchCommod.top := TOP_Y + 75;
			lblSearchCommod.visible := true;
			cmbSearchCommod.top := TOP_Y + 75;
			cmbSearchCommod.visible := true;
			
			frmSearch.height := lblSearchCommod.top + 45;
			
			// 27/04/2010 cnwmh5 PAR23943
			self.cmbSearchCType.clear;
			self.cmbSearchCType.listCollection(self.allCargoTypes, false, 0);	
			
			self.cmbSearchBOL.clear;
			self.cmbSearchBOL.listCollection(self.myCurrentVoyage.allBOLInByTypeStatusNumDT, false, 0);	
			cmbSearchBOL.listObject := self.filterBOL;		
			
			
	
			cmbSearchCType.listObject := self.filterBOLCargoType;
			txtSearchMarks.text := self.filterBOLMarks;
			cmbSearchCommod.setObject(self.filterBOLCommodity);
		elseif self.searchType = Search_Stowage then
			lblSearchId.visible := false;
			txtSearchId.visible := false;
			lblSearchBOL.visible := false;
			cmbSearchBOL.visible := false;
			lblSearchOper.visible := false;
			cmbSearchOper.visible := false;
			lblReconciled.visible := false;
			cmbReconciled.visible := false;
						
			lblSearchLocatn.top := TOP_Y;
			lblSearchLocatn.visible := true;
			txtSearchLocn.top := TOP_Y;
			txtSearchLocn.visible := true;
			lblSearchCType.top := TOP_Y + 25;
			lblSearchCType.visible := true;
			cmbSearchCType.top := TOP_Y + 25;
			cmbSearchCType.visible := true;
			lblSearchMarks.top := TOP_Y + 50;
			lblSearchMarks.visible := true;
			txtSearchMarks.top := TOP_Y + 50;
			txtSearchMarks.visible := true;
			lblSearchCommod.top := TOP_Y + 75;
			lblSearchCommod.visible := true;
			cmbSearchCommod.top := TOP_Y + 75;
			cmbSearchCommod.visible := true;
			
			frmSearch.height := lblSearchCommod.top + 45;

			txtSearchLocn.text := self.filterStowageLocation;
			cmbSearchCType.listObject := self.filterStowageCargoType;
			txtSearchMarks.text := self.filterStowageMarks;
			cmbSearchCommod.setObject(self.filterStowageCommodity);
		elseif self.searchType = Search_BOL_Item or
		   self.searchType = Search_COB or
		   self.searchType = Search_Stowage_Item then
			self.filterCargoTypes(); //+ cnwmd1 Par 22846
			
			lblReconciled.visible := false;
			cmbReconciled.visible := false;
			lblSearchBOL.visible := false;
			cmbSearchBOL.visible := false;
			
			
			lblSearchId.top := TOP_Y;
			lblSearchId.visible := true;
			txtSearchId.top := TOP_Y;
			txtSearchId.visible := true;
			lblSearchLocatn.top := TOP_Y + 25;
			lblSearchLocatn.visible := true;
			txtSearchLocn.top := TOP_Y + 25;
			txtSearchLocn.visible := true;
			lblSearchCType.top := TOP_Y + 50;
			lblSearchCType.visible := true;
			cmbSearchCType.top := TOP_Y + 50;
			cmbSearchCType.visible := true;
			lblSearchMarks.top := TOP_Y + 75;
			lblSearchMarks.visible := true;
			txtSearchMarks.top := TOP_Y + 75;
			txtSearchMarks.visible := true;
			lblSearchCommod.top := TOP_Y + 100;
			lblSearchCommod.visible := true;
			cmbSearchCommod.top := TOP_Y + 100;
			cmbSearchCommod.visible := true;
			lblSearchOper.top := TOP_Y + 125;
			lblSearchOper.visible := true;
			cmbSearchOper.top := TOP_Y + 125;
			cmbSearchOper.visible := true;
			
			frmSearch.height := lblSearchOper.top + 45;
			
			//30787
			 if self.searchType = Search_BOL_Item   then
				txtSearchId.text := self.filterBOLItemId;
				txtSearchLocn.text := self.filterBOLItemLocation;
				cmbSearchCType.listObject := self.filterBOLItemCargoType;
				txtSearchMarks.text := self.filterBOLItemMarks;
				cmbSearchCommod.setObject(self.filterBOLItemCommodity);
				cmbSearchOper.setObject(self.filterBOLItemOperator);
		    elseif self.searchType = Search_COB then
				txtSearchId.text := self.filterCOBItemId;
				txtSearchLocn.text := self.filterCOBLocation;
				cmbSearchCType.listObject := self.filterCOBCargoType;
				txtSearchMarks.text := self.filterCOBMarks;
				cmbSearchCommod.setObject(self.filterCOBCommodity);
				cmbSearchOper.setObject(self.filterCOBOperator);
		    elseif self.searchType = Search_Stowage_Item then
				txtSearchId.text := self.filterStowItemId;
				txtSearchLocn.text := self.filterStowItemLocation;
				cmbSearchCType.listObject := self.filterStowItemCargoType;
				txtSearchMarks.text := self.filterStowItemMarks;
				cmbSearchCommod.setObject(self.filterStowItemCommodity);
				cmbSearchOper.setObject(self.filterStowItemOperator);
			endif;
			
			
		endif;
		
		self.frmSearch.visible := true;
		// setFocus to the top control
		if self.searchType = Search_BOL  or self.searchType = Search_BOL_Detail then
			lblSearchBOL.setFocus();
		elseif self.searchType = Search_Stowage then
			lblSearchLocatn.setFocus();
		elseif self.searchType = Search_BOL_Item or
		   self.searchType = Search_COB or
		   self.searchType = Search_Stowage_Item then
			lblSearchId.setFocus();
		endif;
		self.frmSearch.zOrder(1);
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
