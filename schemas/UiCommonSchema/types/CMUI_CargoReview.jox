    <JadeMethod name="addCriteriaLine" id="db6a43ac-058b-457e-8b4b-2b5cf8e3dfde">
        <updating/>
        <source>addCriteriaLine() : Boolean protected, updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	idx 						: Integer;
	criteriaLine				: CM_SelectorCriteriaLine;
begin

	self.queryLineChanged := false;
	criteriaLine := self.setPropertyValueAndOperator(null);
	
	if criteriaLine = null then//creation was not sucessful
		return false;
	endif;
	criteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
	
	idx := self.tblCriteria.addItemObject(criteriaLine, criteriaLine.getDescriptionString);
	self.tblCriteria.accessRow(idx).backColor := criteriaLine.getPerformanceColour;	//02 Sep 2019	NDL	TFS 45891
	self.setCriteriaLabel(); //02/10/2023	navkc1	CR 60423 Task 60763
	
	return true;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addMeasurementRow" id="ba25c27e-5865-4575-afe7-e4c0805a1559">
        <source>addMeasurementRow(_row 	: EntTableRow; _entTableRows : EntTableRowArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2022	jlier1	Initial creation

*/

vars
	measure		: CM_MeasurementType;
	prefix		: String;
	rowHeading	: String;
	rowName		: String;
	proxyRow	: EntTableRowProxy;
	isPerformance : Boolean;
begin	
	foreach measure in app.myRoot.allMeasurementTypesByShortName discreteLock where measure.measurementType = _row.measurementType do
		if not measure.isDisplay or not measure.isAvailableForEntry then
			continue;
		endif;
		
		app.getRowHeadingFromMeasure(_row, measure, prefix, rowHeading, rowName);
		// 35440 use the cargo type attribute headings if set, for the cargo enquiry screen

		create proxyRow transient;
		//proxyRow.setBasicDetails(rowName, rowHeading, Table.InputType_None, true);  // 20/03/2015 cnwma1  PAR #35887
		proxyRow.setBasicDetails(rowName, rowHeading, _row.inputType, true);		   // 20/03/2015 cnwma1  PAR #35887
		_entTableRows.add(proxyRow);
	
		if _row.name.startsWith("pre") or _row.name.startsWith("release") then
			self.allPerformanceRows.add(proxyRow);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="EntTableRow"/>
        <Parameter name="_entTableRows" type="EntTableRowArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="5bd0bb69-63ae-4a20-aa5f-a91404b6a126">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars
	toolbar	: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveSelector, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//---------------------------------------------------------------------------------------------
	toolbar.addButton(self.btnGrid, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnVertical, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHorizontal, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//---------------------------------------------------------------------------------------------	
	toolbar.addButton(self.btnShowSelector, CMUI_Toolbar.Control_Alignment_Left);	
	if app.myCurrentUserCan(self.myTerminal, PmCargoReviewCustDocSummary) then
		toolbar.addButton(self.btnShowTblSummary, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnCustDocSummary, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	if app.myCurrentUserCan(self.myTerminal,PmYardMoveMaint) then
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	//---------------------------------------------------------------------------------------------	
		toolbar.addButton(self.btnGroupMove, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//---------------------------------------------------------------------------------------------	
	toolbar.addButton(self.btnGrouping, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmGroupBy, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//---------------------------------------------------------------------------------------------	
	toolbar.addButton(self.btnAddtionalCols, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmAdditionalCol, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//---------------------------------------------------------------------------------------------	
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="autoDoCustDocFromParent" id="7a833cf3-8520-4d40-b713-01af95e3cd27">
        <updating/>
        <source>autoDoCustDocFromParent() updating;
/*

Purpose:			This method can be called if we are opening the form from transport ui screens. 
					EUP wants the screen to automatically do the custom document summary

Parameters:			

Return Value:		

Date		Who		Reason
23/02/2023	navkc1 CR 62580 Task 62581: UI - Road Exit Custom Document Details

*/

vars
	table		: CM_DataTable;
	tiSet		: CM_TISet;
	cargoDict	: CM_TIByCargoTypeIdDict;
begin
	create tiSet transient;
	create cargoDict transient;
	
	table := self.tblCargoGrouped;
	
	if table.hasNoData() then
		return;
	endif;
	
	// Select all item in the Group table
	table.selectAll();
	
	// Get selected TI from Group Table
	self.getAllTisForCustDocSummary(true, tiSet);
	
	// Populate the Cargo table
	tiSet.copy(cargoDict);
	self.displayCargoResults(cargoDict);
	
	// Do the Custom Summary and display
	self.doCustDocSummary(tiSet);
	
epilog
	delete tiSet;
	delete cargoDict;
end;</source>
    </JadeMethod>
