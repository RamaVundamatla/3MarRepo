    <JadeMethod name="removeObject" id="2739874e-e8f4-4830-bb42-b3a274341859">
        <updating/>
        <source>removeObject(_obj : CM_Object) protected, updating;

vars
	idx : Integer;
begin

	if (not self.allNotableObjects.includes(_obj)) then
		return;
	endif;
	
//	if self.tblNNCargo.findObjectInRow(_obj, idx) then
//		if idx = self.tblNNCargo.row then
//			self.tblNNCargoInfo.rows := self.tblNNCargoInfo.fixedRows;
//		endif;
//		self.tblNNCargo.removeItem(idx);
//	endif;
	if self.tblCargo.findObjectInRow(_obj, idx) then
		self.tblCargo.removeItem(idx);
	endif;
	if self.tblBOL.findObjectInRow(_obj, idx) then
		self.tblBOL.removeItem(idx);
	endif;
	if self.tblBOLItems.findObjectInRow(_obj, idx) then
		self.tblBOLItems.removeItem(idx);
		// refresh the BOL Detail table entry as well, to get the TI total and qty differences current
		self.refreshBOLDetailEntry(null);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
