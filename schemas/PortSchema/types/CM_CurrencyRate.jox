    <JadeMethod name="validateUpdate" id="0b3e37b6-7aaa-4c6f-a110-9995aff0da46">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 3755
23/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
*/

vars

	tmpCurrencyRate : CM_CurrencyRate;
	realCurrencyRate : CM_CurrencyRate;
	
begin

	if self.myCurrencyType = null then
		app.raiseCMException(Currency_type, null, null);


	elseif (not self.effectiveDT.isValid) then
		app.raiseCMException(Input_required_field_effctDate, null, null); 

	else
		tmpCurrencyRate := self.myCurrencyType.allCurrencyRates.getAtKey(self.effectiveDT);
		if self.isTransient() then
			realCurrencyRate := self.pxyGetRealObject();
		else
			realCurrencyRate := self;
		endif;
		if tmpCurrencyRate &lt;&gt; null
		and realCurrencyRate &lt;&gt; tmpCurrencyRate then
			//app.raiseCMException2(DuplicateItem, app.getErrorString(Currency_rate), self.effectiveDT.shortCurrentLocaleFormat, null, null);	//23/06/2022 NAVDS20 TFS 53760
			//Currency Rate already exists for %1 : Currenc_rate_already_exists
			app.raiseCMException1(Currenc_rate_already_exists, self.effectiveDT.shortCurrentLocaleFormat, null, null);	//23/06/2022 NAVDS20 TFS 53760
		endif;
		
	endif;
	
	if self.rate &lt; 0 then
		app.raiseCMException1(REQUIRED_FIELD, 'Rate', null, null);
		app.raiseCMException(Input_required_field_rate, null, null);
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
