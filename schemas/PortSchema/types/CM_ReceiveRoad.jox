/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN

*/

vars
	subCarrier : CM_Carrier;
begin
	subCarrier := self.getVehicleVisitSubCarrier;
	if subCarrier &lt;&gt; null then
		return subCarrier.code &amp; " - " &amp; subCarrier.description;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
