    <JadeMethod name="populateTables" id="9ee6fb5f-288d-46e8-9e98-ab459a89ff99">
        <source>populateTables();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2018	jlgndl1	Initial creation	TFS 39186
*/

vars

	heading : String;
	detail : String;
	
	term : CM_Terminal;
//	cgn : CM_NotifiedCargoGroup;
	cg : CM_CargoGroup;
	
	notifiedGroupId : String;
	completed : Boolean;
	plannedTo : String;
	lcs : CM_LCSet;
	actualLocations : String;
	totalWeight : String;
	scanned : Integer;
	toScan : Integer;
	
	notYetScannedArray : StringArray;
	cargoId : String;
	
	allCargoGroupsByIdDict : CM_TIByIdCargoTypeDict;	//02 Oct 2018	NDL	TFS 39186
	ti : CM_TrackedItem;

begin

	self.tblNotGrps.clear();
	self.tblNotGrps.fixedColumns := 0;
	self.tblNotGrps.rows := 1;
	self.tblNotGrps.fixedRows := 1;
	self.tblNotGrps.columns := 7;
	
	heading := 	"Notified Group Id" &amp; Tab &amp;
				"Completed" &amp; Tab &amp;
				"Planned To" &amp; Tab &amp;
				"Actual Locations" &amp; Tab &amp;
				"Total Weight" &amp; Tab &amp;
				"Scanned" &amp; Tab &amp;
				"To Scan";
	self.tblNotGrps.setCellText( 1, 1, heading );
	
	
	self.tblNotScanned.clear();
	self.tblNotScanned.fixedColumns := 0;
	self.tblNotScanned.rows := 1;
	self.tblNotScanned.columns := 1;
	
	heading := 	"Cargo Ids";
	self.tblNotScanned.setCellText( 1, 1, heading );
	

	
	
	if self.myCargoGroupAssignment &lt;&gt; null then
		term := self.myTerminal;
		create lcs transient;
		
		//02 Oct 2018	NDL	TFS 39186
		create allCargoGroupsByIdDict transient;
		self.myCargoGroupAssignment.getAllCargoGroupsByIdDict( allCargoGroupsByIdDict );
		
		foreach ti in allCargoGroupsByIdDict do
		
			cg := ti.CM_CargoGroup;
			
			notifiedGroupId := cg.id;
			completed := cg.isComplete;
			//plannedTo := cg.defaultLocation;
			plannedTo := cg.getDefaultLocation;	//13 Nov 2019	NDL	TFS 47298
			actualLocations := null;
			totalWeight := "0";
			scanned := 0;
			toScan := cg.getPreAssignedToScan( null );
			
		//	cg := cgn.getMatchingCargoGroup;
		//	if cg &lt;&gt; null then
				lcs.clear();
				actualLocations := cg.getAllLocations( lcs );
				totalWeight := cg.getMeasureTotalWeightUnit;
				scanned := cg.getScannedCount();
		//	endif;
			detail := 	notifiedGroupId &amp; Tab &amp;
						completed.getYesNo &amp; Tab &amp;
						plannedTo &amp; Tab &amp;
						actualLocations &amp; Tab &amp;
						totalWeight &amp; Tab &amp;
						scanned.asStringJMT &amp; Tab &amp;
						toScan.asStringJMT;
						
			self.tblNotGrps.rows := self.tblNotGrps.rows + 1;
			self.tblNotGrps.setCellText( self.tblNotGrps.rows, 1, detail );
		
		endforeach;
		
		self.tblNotGrps.leftColumn := 1;
		
		create notYetScannedArray transient;
		self.myCargoGroupAssignment.getNotYetScanned( notYetScannedArray, true );
		
		foreach cargoId in notYetScannedArray do
		
			detail := cargoId;
		
			self.tblNotScanned.rows := self.tblNotScanned.rows + 1;
			self.tblNotScanned.setCellText( self.tblNotScanned.rows, 1, detail );
			
		endforeach;
		
		self.tblNotScanned.leftColumn := 1;
		
	endif;

epilog

	delete lcs;
	delete notYetScannedArray;
	delete allCargoGroupsByIdDict;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCargoGroupAssignmentObj" id="7cb96302-3bfb-46bf-83cc-612f21b3aecb">
        <updating/>
        <source>setMyCargoGroupAssignmentObj( cgAssign : CM_CargoGroupAssignment ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

begin

	self.myCargoGroupAssignment := cgAssign;
	
	if self.myCargoGroupAssignment = null then
		self.caption := app.getErrorString( Cargo_group_assignm_overvie );
	else
		self.caption := self.myCargoGroupAssignment.id &amp; " " &amp; app.getErrorString( Overview );
	endif;

epilog

end;</source>
        <Parameter name="cgAssign" type="CM_CargoGroupAssignment"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="fb126c05-bb61-4fe4-99fb-6fdbbfb9d741">
        <updating/>
        <source>setupControls()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	cga : CM_CargoGroupAssignment;

begin

	self.doResizeControls(true);
	
	cga := self.myMobileGenericAgent.myCargoGroupAssignment;
	
	self.setMyCargoGroupAssignmentObj( cga );
	
	self.populateTables();

epilog

end;</source>
    </JadeMethod>
