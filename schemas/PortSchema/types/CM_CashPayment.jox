    <JadeMethod name="getStatusDescription" id="1c64583a-e5c0-4851-8257-0da04b589ee4">
        <source>getStatusDescription(_status : Integer): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Feb 2020 cnwma1  Bug 48513: GUQ - Invoice with blank status after container has been released/ Cash transactions
*/
vars
	str:   String;
begin
	// ### JIRA 35178 23JUN2025 NAVAB1 - created by API
	str := self.myCashReceipt.getPaymentStatusStr(self.myCashReceipt.paymentStatus);
	
	if str = app.getErrorString(Credit_Check_Paid) then
		if self.voided then
			str := app.getErrorString(PaymentStatus_Void);
		elseif _status = CM_CashPayment.Status_Normal then
			str := app.getErrorString(PaymentStatus_Normal);
		elseif _status = CM_CashPayment.Status_NormalOffsite then
			str := app.getErrorString(PaymentStatus_NormalOffsite);
		endif;
	else
		return str;
	endif;

	return str;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusFromInvoiceStatus" id="caf25aa5-7d0c-456d-95c4-719f4e1218bd">
        <source>getStatusFromInvoiceStatus(_invoiceStatus : Integer) : Integer;
/*
Purpose: This method will get and return the corresponding Cash Payment Status type based on the existing Invoice Status type.
         TFS# 45301 introduces 3 new constants in CM_CashPayment class {Status_Normal, Status_Void, Status_Merged}. It is a good 
		 practice to use the CashPayment constant when setting the CashPayment.Status attribute instead of the constant under 
		 CM_InvoiceLine.

Parameters:	

Return Value:		

Date		Who		TFS		Reason
====================================================================================
22 Jul 2019	jlgdi1	45301	Initial creation
====================================================================================
*/

begin
	if _invoiceStatus = CM_InvoiceLine.STATUS_VOIDED then 
		return self.Status_Void;
	endif;
	
	return self.Status_Normal;
end;</source>
        <Parameter name="_invoiceStatus" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTaxAmountForPayment" id="465c7c49-c738-4590-badb-8a443af466a8">
        <source>getTaxAmountForPayment(): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2017	jlgmp6	Initial creation

*/

vars
	taxrate : Real;

begin
	
	if self.myInvoiceLine &lt;&gt; null then
		return self.myInvoiceLine.getTaxAmountForLine();
	elseif self.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357
		self.myCashPaymentForInvoice.getTaxAmountForPayment(); // TFS 7357
	elseif self.myProformaDetail &lt;&gt; null then // TFS 8307
		if self.myProformaDetail.myInvoiceLineType &lt;&gt; null then // TFS 8307
			taxrate := self.myProformaDetail.myInvoiceLineType.getTaxRateForLine(self.myDebtorTerminal.myDebtor, self.dateTime); // TFS 8307
			return self.cashValue * (taxrate / 100); // TFS 8307
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTaxCode" id="254f58d3-6e01-4587-a52e-2c167c287dbc">
