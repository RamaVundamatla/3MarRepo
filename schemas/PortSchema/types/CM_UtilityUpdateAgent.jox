    <JadeMethod name="utlUpdateWodVoyageDtl" id="fbf006a3-83c1-4db5-babb-c0488e265456">
        <updating/>
        <source>utlUpdateWodVoyageDtl(	_proxy : CM_WorkOrderVoyageDtl input;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

	real : CM_WorkOrderVoyageDtl;
	expectedEdition : Integer;

begin

	self.initialiseActivity();

	_proxy.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxy.pxyGetRealObjectAndEdition( real, expectedEdition);
	
	if real = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, 'Voyage Work Order Detail', null, null);
		return;
	endif;

	app.myValUA.valWodVoyageDtl( _proxy );
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, true);
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(real);

	if _passport.noErrors and real.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage Work Order Detail', null, null);
		return;
	endif;

	real.setForUpdate(_proxy);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, false);
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_WorkOrderVoyageDtl" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkOrder" id="e6e37591-b294-45d5-9945-4cb97defed15">
        <source>utlUpdateWorkOrder(_pxyWorkOrder : CM_WorkOrder input;
					_updateTasks : Boolean;
					_passport    : CM_Passport input) ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Aug 2009	cnwmd1	Initial creation
14 Jun 2018	jlger1	tfs 39166
18 Oct 2021	jlier1	TFS 52195
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
12 Mar 2024	navsaa30 Bug 62841: EUP | Error 4 in Proforma Processing [PERFORMANCE]
*/

vars
	realWorkOrder 			: CM_WorkOrder;
	expectedEdition 		: Integer;
	voyageProformaTrxAction : CMIF_TrxActionWOProforma;
	voyageProcess			: CM_VoyageProcess;
begin
	self.initialiseActivity();

	_pxyWorkOrder.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyWorkOrder.pxyGetRealObjectAndEdition(realWorkOrder, expectedEdition);
	
	if realWorkOrder = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkOrder.name, null, null);
		return;
	endif;

	app.myValUA.valWorkOrder(_pxyWorkOrder);
	
	if _pxyWorkOrder.taskStatus &lt;&gt; realWorkOrder.taskStatus 
		and _pxyWorkOrder.taskStatus = WO_STATUS_APPROVED  
		and not realWorkOrder.hasBeenApproved() then
		_pxyWorkOrder.validateForApproval();
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWorkOrder, true);
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realWorkOrder);

	if _passport.noErrors and realWorkOrder.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Work Order', null, null);
		return;
	endif;

	realWorkOrder.setForUpdate(_pxyWorkOrder,_updateTasks);
	
	if _passport.noErrors then
		if not app.isInProformaMode then
			//epr 20/6/18 TFS 39166
			voyageProcess := _passport.myTerminal.getDefaultVoyageProcess();		// 12/03/24 navsaa30 #62841	
			if voyageProcess = null or not voyageProcess.isEUPDefaultProcess then		
				create voyageProformaTrxAction transient;
				voyageProformaTrxAction.setMyWorkOrder(realWorkOrder,CM_TrxControlAgent.Trx_Update);
				_passport.addTrxPostAction(voyageProformaTrxAction);
			endif;
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realWorkOrder, false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_updateTasks" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkOrderCargoRequest" id="0f9f5d9c-0d56-456e-aee7-419c2dcca562">
        <source>utlUpdateWorkOrderCargoRequest(	_voyageJob : CM_VoyageJob input;
								_passport  : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/06/2018	jlger1	Initial creation 39166
01/08/2018	jlgdap1	TFS 39964 PEL1 Hold Job Ops Loading Changes
14 Aug 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
25 Jan 2022 navma1	Bug 52657: SAL - Cargo request auto creation on Permit request complete (Critical)
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	voyage 				: CM_Voyage;
	workOrderDtl,
	permitRequest		: CM_WorkOrderDtl;
	pxyWorkOrderDtl 	: CM_WodVoyageCargoRequest;
	pxyWodCargoRequest  : CM_WodCargoRequest;
	wle					: CM_WorkListEntry;
	realWorkOrder  		: CM_WorkOrder; 
	pxyWorkOrder 		: CM_WorkOrderVoyage;
	ti 					: CM_TrackedItem;
	tiset 				: CM_TISet;
	berth 				: HMS_Berth;
	hmsVoyageData       : HMS_VoyageData;
begin
	self.initialiseActivity();
	
	voyage		  := _voyageJob.myVoyage;
	hmsVoyageData := voyage.myHMSVoyageData ;
	
	workOrderDtl	:= voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL);
	
	//25.01.22 navma1 #52657
	if workOrderDtl = null  then
		permitRequest := voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_PERMIT);
		if permitRequest &lt;&gt; null then
			return;
		endif;
	endif;
	//25.01.22 navma1 #52657
	
	
	if hmsVoyageData &lt;&gt; null then															// TFS 39964
		if _voyageJob.myShift &lt;&gt; null then 													//14.8.2018 cnwma1 TFS #39698
			berth := hmsVoyageData.getBerthForDateTime(_voyageJob.myShift.startDateTime);	// TFS 39964
		endif;
		if berth= null then // TFS 39349
			berth := hmsVoyageData.getBerthForDateTime(voyage.arrivedDT);					// TFS 39349 use arrival
		endif;
	endif;																					// TFS 39964
	
	if workOrderDtl &lt;&gt; null then
		realWorkOrder := workOrderDtl.myParent;
	endif;
	
	if realWorkOrder &lt;&gt; null then	
		if realWorkOrder.taskStatus &gt; WO_STATUS_PENDING then
			return;
		endif;
		
		pxyWorkOrder := realWorkOrder.pxyCreateUpdateProxy.CM_WorkOrderVoyage;
		pxyWorkOrderDtl:=workOrderDtl.pxyGetProxyObject.CM_WodVoyageCargoRequest;
	else
		create pxyWorkOrder transient;
		pxyWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,app.myPassport.myUser,null,null,voyage.myTerminal,null,null,null, WO_STATUS_PENDING);
		pxyWorkOrder.setMyVoyage(voyage);
		
		create pxyWorkOrderDtl transient;
		pxyWorkOrderDtl.setParent(pxyWorkOrder);
		pxyWorkOrderDtl.setMyBerth(berth);															// TFS 39964
		
		// TFS 41538 -  OccursOnDT not necessary any more on an initial cargo request
		// TFS 41538 pxyWorkOrderDtl.setRequiredByDT(_voyageJob.myShift.startDateTime);							// TFS 39964
	endif;
	
	// TFS 39507 add TI to the work order for estimation
	create tiset transient; // TFS 39507
	foreach wle in _voyageJob.workListEntries discreteLock do
		
		create pxyWodCargoRequest transient;
		pxyWodCargoRequest.setProxyFromWLE(wle.CM_VoyageWLE);
		pxyWorkOrderDtl.allCargoDetails.add(pxyWodCargoRequest);
		
		ti := wle.myTrackedItem; // TFS 39507
		if ti &lt;&gt; null then // TFS 39507
			tiset.add(ti); // TFS 39507
		endif; // TFS 39507
	endforeach;
	
	if realWorkOrder = null then
	
		app.myUtilityCA.utlCreateWorkOrder(pxyWorkOrder, realWorkOrder, app.myPassport);
	else
		self.utlUpdateWorkOrder(pxyWorkOrder,true,app.myPassport);
	endif;
	
	if realWorkOrder &lt;&gt; null then																	// TFS 39964
		foreach ti in tiset do // TFS 39507
			realWorkOrder.addTrackedItem(ti,realWorkOrder.allWoDtls.first); 						// TFS 39507		//08.02.2023 navma1 #56457 Task#56458
		endforeach; // TFS 39507
	endif;																							// TFS 39964
epilog
	delete pxyWorkOrder;
	delete tiset;

end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkOrderDetailType" id="d7c154fd-29e5-4680-9e27-5e66ca9ff703">
        <source>utlUpdateWorkOrderDetailType(_pxyWorkOrderTaskType : CM_WorkOrderDetailType; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	expectedEdition			: Integer;
	realWorkOrderTaskType   : CM_WorkOrderDetailType;
	
begin
	
	self.initialiseActivity();

	_pxyWorkOrderTaskType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyWorkOrderTaskType.pxyGetRealObjectAndEdition(realWorkOrderTaskType, expectedEdition);
	
	if _pxyWorkOrderTaskType = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkOrderDetailType.name, null, null);
		return;
	endif;
	
	app.myValUA.valWorkOrderDetailType(_pxyWorkOrderTaskType, realWorkOrderTaskType);
	
	if not self.checkValidationWithPassport(_passport)then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realWorkOrderTaskType);
	
	if _passport.noErrors and realWorkOrderTaskType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Work Order Detail Type', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realWorkOrderTaskType.setForUpdate(_pxyWorkOrderTaskType);
	endif;

epilog

end;</source>
        <Parameter name="_pxyWorkOrderTaskType" type="CM_WorkOrderDetailType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkOrderMani" id="65a960b2-8840-477e-b014-67264cf4d923">
        <source>utlUpdateWorkOrderMani(_pxyWorkOrder : CM_WorkOrder input;
					_updateTasks : Boolean;
					_passport    : CM_Passport input) ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
12/03/24 	navsaa30 Bug 62841: EUP | Error 4 in Proforma Processing [PERFORMANCE]
*/

vars
	realWorkOrder 			: CM_WorkOrder;
	expectedEdition 		: Integer;
	voyageProformaTrxAction : CMIF_TrxActionWOProforma;
	voyageProcess			: CM_VoyageProcess;
begin
	self.initialiseActivity();

	_pxyWorkOrder.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyWorkOrder.pxyGetRealObjectAndEdition(realWorkOrder, expectedEdition);
	
	if realWorkOrder = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkOrder.name, null, null);
		return;
	endif;

	app.myValUA.valWorkOrder(_pxyWorkOrder);
	
	if _pxyWorkOrder.taskStatus &lt;&gt; realWorkOrder.taskStatus 
		and _pxyWorkOrder.taskStatus = WO_STATUS_APPROVED  
		and not realWorkOrder.hasBeenApproved() then
		_pxyWorkOrder.validateForApproval();
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWorkOrder, true);
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realWorkOrder);

	if _passport.noErrors and realWorkOrder.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Work Order', null, null);
		return;
	endif;

	realWorkOrder.setForUpdateShipMani(_pxyWorkOrder,_updateTasks);
	
	if _passport.noErrors then
		if not app.isInProformaMode then
			//epr 20/6/18 TFS 39166
			voyageProcess := _passport.myTerminal.getDefaultVoyageProcess();		// 12/03/24 navsaa30 #62841	
			if voyageProcess = null or not voyageProcess.isEUPDefaultProcess then
				create voyageProformaTrxAction transient;
				voyageProformaTrxAction.setMyWorkOrder(realWorkOrder,CM_TrxControlAgent.Trx_Update);
				_passport.addTrxPostAction(voyageProformaTrxAction);
			endif;
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realWorkOrder, false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_updateTasks" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkOrderMarine" id="34072645-f346-43e7-b99a-b6da7478f852">
        <source>utlUpdateWorkOrderMarine( 	_voyage : CM_Voyage input;
							_voyageExternalCode : String;
							 _isArrival : Boolean;
							_hmsResourceUsed : HMS_ResourceUsed ;
							_realWorkOrderDtl : CM_WorkOrderDtl;
							_occursOnDT : TimeStamp;
							_towingVoyage : CM_Voyage;
							_berth : HMS_Berth input;
							_bowMarkTo : Decimal;
							_draftAft : Decimal;
							_draftFwd : Decimal;
							_hasRamp : Boolean;
							_starboardberthed : Boolean;
							_passport : CM_Passport input) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlger1	Initial creation
10 Sep	2018 	jlger1	 ttfs 40629 inaportrest api
11 Oct 2021	jlier1		TFS 51963
24 Mar 2023 	navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars
	voyageStatus : CM_VoyageStatus;
	realWorkOrderDtl : CM_WorkOrderDtl;
	realWorkOrder  : CM_WorkOrder; 
	pxyWorkOrder : CM_WorkOrderVoyage;
	pxyWorkOrderVoyageDtl : CM_WorkOrderVoyageDtl;
	pxyMarineInital : CM_WodMarineServicesInitial;
	pxyMarineDepart : CM_WodMarineServicesDepart;
	pxyMarineService,
	marineService : CM_WodMarineServiceDetail;
	terminal : CM_Terminal;
begin
	self.initialiseActivity();
	
	realWorkOrderDtl:=_realWorkOrderDtl;
	if realWorkOrderDtl = null and _voyage &lt;&gt; null then
		if _isArrival then
			realWorkOrderDtl := _voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL);	
		else
			realWorkOrderDtl := _voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEDEPART);	
		endif;
	endif;
	
	if realWorkOrderDtl &lt;&gt; null then
		realWorkOrder := realWorkOrderDtl.myParent;
	endif;
	
	if _voyage &lt;&gt; null then
		terminal:=_voyage.myTerminal;
	else
		terminal:=_passport.myTerminal;
	endif;
	
	if realWorkOrder &lt;&gt; null then
		if realWorkOrder.taskStatus &lt;&gt; WO_STATUS_PENDING and
			realWorkOrder.taskStatus &lt;&gt; WO_STATUS_NOTAPPROVED and
			realWorkOrder.taskStatus &lt;&gt; WO_STATUS_USERENTRY and
			realWorkOrder.taskStatus &lt;&gt; WO_STATUS_REJECTED_FIN then
			
			//if realWorkOrder.taskStatus &lt;&gt; WO_STATUS_APPROVED then
			//	app.raiseCMException2(Not_updat_work_order_with_stat,realWorkOrderDtl.getDisplayString(false),realWorkOrder.getStatusString,null,null);
			//endif;
			return ;
		endif;
		pxyWorkOrder := realWorkOrder.pxyCreateUpdateProxy.CM_WorkOrderVoyage;
		if _occursOnDT &lt;&gt; null and _occursOnDT.isValid then
			pxyWorkOrder.setRequiredByDT(_occursOnDT);
		endif;
		
		//epr TFS 41539 31/10/18
		if realWorkOrder.taskStatus = WO_STATUS_NOTAPPROVED then
			//set it back to pending 
			pxyWorkOrder.setTaskStatus(WO_STATUS_PENDING);
		endif;
		
		pxyWorkOrderVoyageDtl:=realWorkOrderDtl.pxyGetProxyObject.CM_WorkOrderVoyageDtl;
		
	else
		create pxyWorkOrder transient;
		pxyWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,app.myPassport.myUser,null,null,terminal,null,null,null, WO_STATUS_PENDING);
		pxyWorkOrder.setMyVoyage(_voyage);
		if _voyage = null and _voyageExternalCode &lt;&gt; null then
			pxyWorkOrder.CM_WorkOrderVoyage.setVoyageExternalCode(_voyageExternalCode);		
		endif;
		
		if _isArrival then
			create pxyWorkOrderVoyageDtl  as CM_WodMarineServicesInitial transient;
		else
			create pxyWorkOrderVoyageDtl  as CM_WodMarineServicesDepart transient;
		endif;
		pxyWorkOrderVoyageDtl.setParent(pxyWorkOrder);
	endif;
	
	if realWorkOrderDtl &lt;&gt; null then
		marineService:=realWorkOrderDtl.CM_WorkOrderVoyageDtl.getMarineServiceDtlForResource(_hmsResourceUsed.myResource);
		if marineService &lt;&gt; null then
			pxyMarineService:=marineService.pxyGetProxyObject;
			if pxyMarineService = null then
				pxyMarineService:=marineService.pxyCreateUpdateProxy;
			endif;
		endif;
	endif;
	
	if pxyMarineService = null then
		create pxyMarineService transient;
	endif;
	
	if pxyWorkOrderVoyageDtl.isKindOf(CM_WodMarineServicesInitial) then
		pxyWorkOrderVoyageDtl.setTowingVoyage(_towingVoyage);
		// TFS 40236 pxyWorkOrderVoyageDtl.CM_WodMarineServicesInitial.setMyBerth(_berth);
		
		// TFS 40236 NEED TO POPULATE PARAMS FROM WEB SERVICE
		pxyWorkOrderVoyageDtl.CM_WodMarineServicesInitial.setPxyMarineDetails(_berth,_draftAft,_draftFwd, _bowMarkTo,_hasRamp,_starboardberthed ); // TFS 40236 

		//pxyWorkOrderVoyageDtl.setProxy(pxyWorkOrderVoyageDtl.requiredByDT,_occursOnDT,false);
		//pxyWorkOrderVoyageDtl.setProxy( _occursOnDT, pxyWorkOrderVoyageDtl.requiredByDT, false );	//24 Sep 2018	NDL	TFS 40810			//24.3.2023 navhl20	#57301[57303]
		pxyWorkOrderVoyageDtl.setProxyReqByDT(_occursOnDT);																					//24.3.2023 navhl20	#57301[57303]
		
	// 19 Sep 2018	NDL TFS 40810 
	elseif pxyWorkOrderVoyageDtl.isKindOf(CM_WodMarineServicesDepart) then	
		pxyWorkOrderVoyageDtl.CM_WodMarineServicesDepart.setPxyMarineDetails( _draftAft, _draftFwd, _bowMarkTo );
		//pxyWorkOrderVoyageDtl.setProxy(pxyWorkOrderVoyageDtl.requiredByDT,_occursOnDT,false);
		//pxyWorkOrderVoyageDtl.setProxy( _occursOnDT, pxyWorkOrderVoyageDtl.requiredByDT, false );	//24 Sep 2018	NDL	TFS 40810			//24.3.2023 navhl20	#57301[57303]
		pxyWorkOrderVoyageDtl.setProxyReqByDT(_occursOnDT);																					//24.3.2023 navhl20	#57301[57303]
		pxyWorkOrderVoyageDtl.setTowingVoyage(_towingVoyage);
		
	endif;
	
	pxyMarineService.setProxyFromResourceUsed(_hmsResourceUsed);
	pxyWorkOrderVoyageDtl.addMarineServiceDetail(pxyMarineService);
	
	
		
	if realWorkOrder = null then
		app.myUtilityCA.utlCreateWorkOrder(pxyWorkOrder,realWorkOrder,_passport);
	else
		self.utlUpdateWorkOrder(pxyWorkOrder,true,_passport);
	endif;
epilog
	
	delete pxyWorkOrder;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_voyageExternalCode" type="String"/>
        <Parameter name="_isArrival" type="Boolean"/>
        <Parameter name="_hmsResourceUsed" type="HMS_ResourceUsed"/>
        <Parameter name="_realWorkOrderDtl" type="CM_WorkOrderDtl"/>
        <Parameter name="_occursOnDT" type="TimeStamp"/>
        <Parameter name="_towingVoyage" type="CM_Voyage"/>
        <Parameter name="_berth" type="HMS_Berth" usage="input"/>
        <Parameter name="_bowMarkTo" type="Decimal"/>
        <Parameter name="_draftAft" type="Decimal"/>
        <Parameter name="_draftFwd" type="Decimal"/>
        <Parameter name="_hasRamp" type="Boolean"/>
        <Parameter name="_starboardberthed" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkOrderSchedule" id="f11f59e6-f201-41d3-8d64-bab313ba0fe4">
        <source>utlUpdateWorkOrderSchedule(_pxySchedule : CM_WorkOrderSchedule; _realSchedule : CM_WorkOrderSchedule io; _passport : CM_Passport input);
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 31 Mar 2025 	navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// -----------------------------------------------------------------------------

vars

begin
	// Always initialize the activity first
	self.initialiseActivity();

	_pxySchedule.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	app.myValUA.valWorkOrderSchedule(_realSchedule, _pxySchedule);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_realSchedule);
	exclusiveLock(_realSchedule.myParent);

	// ====================================================
	// now do the update
	app.setContinueCMExceptions(false);

	if _passport.noErrors() then
		_realSchedule.setForUpdate(_pxySchedule);
	endif;

	if _passport.noErrors() then
		_realSchedule.myParent.causeEvent(_passport.myTerminal.getTerminalEvent(Event_WorkOrderSchedule_Update), false, _realSchedule);
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_WorkOrderSchedule_Update), false, _realSchedule);
	endif;

epilog

end;</source>
        <Parameter name="_pxySchedule" type="CM_WorkOrderSchedule"/>
        <Parameter name="_realSchedule" type="CM_WorkOrderSchedule" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkOrderTISource" id="3dfa7a0e-554b-46b1-9d54-33c3cf486fd0">
        <updating/>
        <source>utlUpdateWorkOrderTISource(_pxySource : CM_WorkOrderTISource; _realSource : CM_WorkOrderTISource io; _passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 31 Mar 2025  navma1  	MTN-34387 MTN - Removing Unnecessary Audits
// -----------------------------------------------------------------------------

vars

begin
	// Always initialize the activity first
	self.initialiseActivity();

	_pxySource.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	app.myValUA.valWorkOrderTISource(_realSource, _pxySource);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_realSource);

	// ====================================================
	// now do the update
	app.setContinueCMExceptions(false);

	if _passport.noErrors() then
		_realSource.setForUpdate(_pxySource);
		updateObjectEdition(_realSource);
	endif;
epilog

end;</source>
        <Parameter name="_pxySource" type="CM_WorkOrderTISource"/>
        <Parameter name="_realSource" type="CM_WorkOrderTISource" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
