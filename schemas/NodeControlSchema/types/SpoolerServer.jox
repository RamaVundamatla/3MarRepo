    <JadeMethod name="ftpFileException" id="d0438981-656d-477b-be79-3d2c53853407">
        <source>ftpFileException(e:Exception;s:String output;errorcode:Integer output):Integer;
// Added to capture exceptions, eg if output file is in use during get
begin
	s:="FileException "&amp;e.errorCode.String&amp;": "&amp;e.text;
	errorcode:=e.errorCode;
	return Ex_Resume_Next;
end;</source>
        <Parameter name="e" type="Exception"/>
        <Parameter name="s" type="String" usage="output"/>
        <Parameter name="errorcode" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDateTime" id="175e5886-f776-494b-8ab7-d52cd5f9bb07">
        <updating/>
        <source>getDateTime(dateTime:String io) updating;

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	ts:TimeStamp;
begin
	ts:=app.actualTimeServer;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	dateTime:=ts.date.format("yyMMdd")&amp;ts.time.format("HHmmss");
end;</source>
        <Parameter name="dateTime" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="make" id="cd28d1e7-5973-4792-8204-a225d441cd4d">
        <updating/>
        <source>make(fileName:String) updating;
// full path name required
begin
	bFile.fileName:=fileName.toLower;
	if not bFile.isAvailable then
		app.makePathIfPossible(bFile.fileName,false);
		bFile.open;
		bFile.close;
	endif;
	app.logMessage("Made file "&amp;bFile.fileName&amp;".");
end;</source>
        <Parameter name="fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="purge" id="ee177221-a874-43c4-b483-c187e777c7e0">
        <updating/>
        <source>purge(fileName:String):Boolean updating;
// full path name required
begin
	bFile.fileName:=fileName.toLower;
	if bFile.isAvailable then
		bFile.shareMode:=File.Share_Exclusive;
		if bFile.tryOpen then
			bFile.close;
			bFile.purge;
			app.logMessage("Purged file "&amp;fileName&amp;".");
			return true;
		else
			app.logMessage("Could not purge file "&amp;fileName&amp;".");
			return false;
		endif;
	endif;
end;</source>
        <Parameter name="fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="redirectPermitted" id="adb12d84-0f13-4e1b-b62a-bdbc6ff4a46c">
        <source>redirectPermitted():Boolean;
// reimplement in subschema
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rename" id="aaa69a69-0805-4bc9-9f8b-fdf72d343e24">
        <updating/>
        <source>rename(inFileName, newName:String):Boolean updating;
// Full path names required
begin
	aFile.fileName:=inFileName.toLower;
	bFile.fileName:=newName.toLower;
	aFile.shareMode:=File.Share_Exclusive;
	if aFile.isAvailable and aFile.tryOpen then
		aFile.close;
	else
		app.logMessage("Could not access file to be renamed: "&amp;aFile.fileName&amp;" to "&amp;bFile.fileName&amp;".");
		return false;
	endif;

	if bFile.isAvailable then
		bFile.shareMode:=File.Share_Exclusive;
		if bFile.tryOpen then
			bFile.close;
			bFile.purge;
		else
			app.logMessage("Could not rename file "&amp;aFile.fileName&amp;" to "&amp;bFile.fileName&amp;" - output file in use.");
			return false;
		endif;
	endif;
	app.makePathIfPossible(bFile.fileName,false);
	app.logMessage("Renamed file "&amp;aFile.fileName&amp;" to "&amp;bFile.fileName&amp;".");
	fileRename(aFile,bFile.fileName);
	return true;
end;</source>
        <Parameter name="inFileName" type="String"/>
        <Parameter name="newName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
