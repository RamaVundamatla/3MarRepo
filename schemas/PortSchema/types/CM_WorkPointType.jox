    <JadeMethod name="getAuditText" id="9cf8d6c9-4b8e-4be5-bc2f-2ee5ad8dbf3f">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	txt,
	tmpStr: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();

	tmpStr := null;
	tmpStr := app.getWorkPointTypeString(self.type);
	txt := txt &amp; 'Type' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6e543dbb-f139-4200-9cca-b5466a76995d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars

begin
	if _attrName = ETRow_Type then
		return app.getWorkPointTypeString(self.type);
	elseif _attrName = ETRow_NotAvailForEntry then
		return self.notAvailableForEntry.String;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstUnallocatedWorkPoint" id="fd551fbb-4644-4c75-96df-effa015b47fa">
        <source>getFirstUnallocatedWorkPoint(): CM_WorkPoint;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2023	navnk30	Bug 61097: EUP | LMS Interface - POST with no Work Point ID

*/

vars
	workPoint: CM_WorkPoint;
begin
	foreach workPoint in self.allWorkPoints do 
		if workPoint.allJobSheets.isEmpty then
			return workPoint;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <ReturnType type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="getNextWorkPointCode" id="755280a0-6a3b-42c1-b26a-992d4e0a1d76">
        <source>getNextWorkPointCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2023	navnk30	Bug 61097: EUP | LMS Interface - POST with no Work Point ID

*/

vars
	nextCode, 
	prefix			: String;
	suffix			: Integer;
	terminal		: CM_Terminal;
begin
	prefix := self.code;
	suffix := 1;
	
	nextCode := prefix &amp; '0' &amp; suffix.String;
	terminal := app.myPassport.myTerminal;
	
	while terminal.allWorkPointsByCode.includesKey(nextCode) do
		suffix := suffix + 1;
		if suffix &lt; 10 then
			nextCode := prefix &amp; '0' &amp; suffix.String;
		else
			nextCode := prefix &amp; suffix.String;
		endif;
	endwhile;
	
	return nextCode;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
