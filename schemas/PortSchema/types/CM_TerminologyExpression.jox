    <JadeMethod name="validateForUpdate" id="cc317b21-8e0f-4147-b6aa-adabf2d010ba">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     12 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if self.userExpression = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'expressionTypeDescr', 'expressionTypeDescr', null); 
		app.raiseCMException(Input_required_field_exprsTypD, 'expressionTypeDescr', null); // cnwdb2	PAR 35364
	endif;

	if self.myTerminologyDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminology Definition object is null');
	endif;
	
	if self.myTermTypeExpression = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminology Type Expression object is null');	
	endif;
	
end;</source>
    </JadeMethod>
</Class>
