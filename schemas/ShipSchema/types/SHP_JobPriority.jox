    <JadeMethod name="doNewPriority" id="ac466d6c-a8ad-4578-9529-d029e6023c27">
        <source>doNewPriority();
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	list : CMUI_ListBox;
	 idx, priority : Integer;
begin

	list := self.lstJobPriority;
	
	if list.listIndex &lt; 1 then
		return;
	endif;

	self.getNextPriority(list.itemData[list.listIndex], idx, priority);

	list.addItemAt(self.getPriorityDesc(priority),idx);
	list.itemLevel[idx] := self.LevelPriority;
	list.itemData[idx] := priority;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="8c8da762-8da2-41f8-872c-847a524fa524">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod();

	self.populateControllerForDisplay();
	
	self.initListBox();
	
	if app.isSpecial() then
		self.writeListBoxDetails("");
	endif;
	self.caption :=app.getErrorString(JOBPriorities) &amp; " " &amp; self.priorityObject.getNiceName() &amp; " " &amp; self.myController.tempLabel;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doReset" id="1496f434-c8eb-4828-b468-e1a29e5531a3">
        <updating/>
        <source>doReset() updating;
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	jpController : CMIF_JobPriorityController;
	theReturn : Integer;
begin
	create jpController transient;
	jpController.init(true,self.priorityObject,self.priorityClass);
	jpController.populateDefaults();
	
	while true do
		app.myTrxCA.trxCreateVoyageJobPriority(jpController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Priorities_reset), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings); // PAR 34655
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog
	if jpController &lt;&gt; null then
		jpController.allJobPriorities.purge; // proxies
		delete jpController;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="15a208bb-71e3-4a4e-88d3-cf238d3ff1f3">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	top : Integer;
begin
	inheritMethod();
	
	
	top := self.frmToolbar.clientHeight + 1;
	self.lstJobPriority.move(1,top,self.clientWidth, self.clientHeight);
end;</source>
    </JadeMethod>
    <JadeMethod name="getIndexForObject" id="f8ccd39e-9a67-4c6a-b08b-23ba51f3e8ad">
        <source>getIndexForObject(_obj : Object; _fromTop : Boolean) : Integer;
/*
Purpose:			
Date				Who			Reason
NOVEMBER 2014		CNWAB1		Initial creation
*/

vars
	fromIDX, toIDX, idx : Integer;
	priority : Integer;
	list : CMUI_ListBox;
begin

	list := self.lstJobPriority;
		fromIDX := 1;
		toIDX := list.listCount();

	if _fromTop then
	foreach idx in fromIDX to toIDX do
		if list.itemObject[idx] = _obj then
			return idx;

		endif;
	endforeach;
	else
	foreach idx in fromIDX to toIDX reversed do 
		if list.itemObject[idx] = _obj then
			return idx;

		endif;
	endforeach;
	endif;
	

	
	return 1;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_fromTop" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getIndexForPriority" id="f9ab1c1a-8bda-4277-b8eb-23826486302a">
        <source>getIndexForPriority(_priority : Integer; _craneType : Integer) : Integer;
/*
Purpose:			
Date				Who			Reason
NOVEMBER 2014		CNWAB1		Initial creation
*/

vars
	fromIDX, toIDX, idx : Integer;
	priority : Integer;
	list : CMUI_ListBox;
	ajp : CM_JobPriority;
begin

	list := self.lstJobPriority;

	fromIDX := 1;
	toIDX := list.listCount();

	foreach idx in fromIDX to toIDX do
		if list.itemLevel[idx] = self.LevelPriority then
			ajp := list.itemObject[idx].CM_JobPriority;		
			
			if ajp &lt;&gt; null and ajp.craneType = _craneType then
				if list.itemData[idx] = _priority then
					return idx;
				endif;
			endif;
		endif;
	endforeach;

	
	return 1;
end;</source>
        <Parameter name="_priority" type="Integer"/>
        <Parameter name="_craneType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextPriority" id="080a930d-0646-46ce-89f2-bf1fd9a079c0">
        <source>getNextPriority(_priType : Integer; _index : Integer io; _priority : Integer io) ;
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	fromIDX, toIDX, idx : Integer;
	list : CMUI_ListBox;
begin

	list := self.lstJobPriority;

	fromIDX := 1;
	toIDX := list.listCount();



	if _priType = 21 then
		foreach idx in fromIDX to toIDX do
			if list.itemLevel[idx] = self.LevelPriority then
				_priority := list.itemData[idx] + 1;
			endif;
			if list.itemData[idx] = 22 then
				_index := idx;
				return;
			endif;
		endforeach;
	else
		_index := toIDX + 1;
		foreach idx in fromIDX to toIDX do
			if list.itemLevel[idx] = self.LevelPriority then
				_priority := list.itemData[idx] + 1;
			endif;
		endforeach;
		return;
	endif;
end;</source>
        <Parameter name="_priType" type="Integer"/>
        <Parameter name="_index" type="Integer" usage="io"/>
        <Parameter name="_priority" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getPriorityDesc" id="8fdd545c-9158-4017-8e7d-73896a95aa34">
        <source>getPriorityDesc(priority : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return app.getErrorString1(Priority_group, priority.String);  // PAR 34655 "Priority " &amp; priority.String &amp; " Grouping";
end;</source>
        <Parameter name="priority" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initListBox" id="acd99bcd-a42c-4505-b82d-ed57eb2554b2">
        <source>initListBox();
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	list 		: CM_QueueListBox;
	craneType, 
	priority,
	jobType,
	count 		: Integer;
	aJP 		: CM_JobPriority;
begin
	list := self.lstJobPriority;
	self.lstJobPriority.enableEvent("mouseMove",false);
	
	list.clear;
	
	
	foreach aJP in self.myController.allJobPriorities do
		if craneType &lt;&gt; aJP.craneType then
			craneType := aJP.craneType;
			priority := aJP.priority;
			jobType := aJP.jobType;
			self.initListBoxAddCrane(aJP);
			self.initListBoxAddPriority(aJP);
			self.initListBoxAddJob(aJP);
			continue;
		endif;
		if priority &lt;&gt; aJP.priority then
			priority := aJP.priority;
			jobType := aJP.jobType;
			self.initListBoxAddPriority(aJP);
			self.initListBoxAddJob(aJP);
			continue;
		endif;
		if jobType &lt;&gt; aJP.jobType then
			jobType := aJP.jobType;
			self.initListBoxAddJob(aJP);
			continue;
		endif;


	endforeach;
	//added by cnwyl1 for par 12216
	foreach count in 1 to list.listCount() do
		list.itemExpanded[count] := true;
	endforeach;
	//add end	
	if list.listCount &gt; 0 then
		list.listIndex := 1;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="initListBoxAddCrane" id="fb62a61c-b4ac-4863-9d2b-62b3742e7443">
        <source>initListBoxAddCrane(_jp : CM_JobPriority);
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	list : CMUI_ListBox;
