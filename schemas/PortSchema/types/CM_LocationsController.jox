    <JadeMethod name="testControllerLocnRestriction" id="8568c516-e3b7-4af4-aee2-547d1c77fa5f">
        <source>testControllerLocnRestriction(restrict : CM_LocationRestriction; obj: CMIF_AutoMovePlan input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     27 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not obj.myTrackedItem.isCompatibleWithRestriction(restrict, obj)) then
		return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="restrict" type="CM_LocationRestriction"/>
