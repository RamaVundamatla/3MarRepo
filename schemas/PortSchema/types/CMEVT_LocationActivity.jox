    <JadeMethod name="getAmountString" id="5c919e39-c095-4fea-92a0-18a6e61b1137">
        <source>getAmountString( _includeCargoType : Boolean; _weightMeasurementType : CM_MeasurementType ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2021	navndl1	Initial creation	TFS 50906
11 Jun 2021	NDL	TFS 51321

*/

vars

	cargoType : CM_CargoType;
	returnVal : String;
	measureType : CM_MeasurementType;
	type : String;
	zero : Decimal[14,4];

begin

	cargoType := self.getCargoType;
	
	if cargoType = null then
		if self.volume &lt;&gt; 0 then
			returnVal := volume.asStringWeightJMT &amp; " m3";
		elseif self.weight &lt;&gt; 0 then
			returnVal := weight.asStringWeightJMT &amp; " kg";
		elseif self.quantity &lt;&gt; 0 then
			returnVal := "x" &amp; quantity.asStringJMT;
		else
			returnVal := "0";
		endif;
	
	else
		if cargoType.isTrackByVolume then
			measureType := cargoType.getDefaultMeasurementForType(Type_Volume);
			type := measureType.shortName;
			if self.volume &lt;&gt; 0 then
				returnVal := app.convertMeasurementForDisplay(type, self.volume ) &amp; " " &amp; type;
			else
				returnVal := zero.asStringJMTWithPrecision(measureType.getDecimalPrecision, false) &amp; " " &amp; type;
			endif;
		elseif cargoType.isTrackByWeight then
			if _weightMeasurementType &lt;&gt; null then // ### TFS 51515 15JUL2021 NAVAB1
				measureType := _weightMeasurementType; // ### TFS 51515 15JUL2021 NAVAB1
			else
				measureType := cargoType.getDefaultMeasurementForType(Type_Weight);
			endif;
			
			type := measureType.shortName;
			if self.weight &lt;&gt; 0 then
				returnVal := app.convertMeasurementForDisplay(type, self.weight ) &amp; " " &amp; type;
			else
				returnVal := zero.asStringJMTWithPrecision(measureType.getDecimalPrecision, false) &amp; " " &amp; type;
			endif;
		else
		//	if self.quantity &lt;&gt; 0 then
				returnVal := "x" &amp; self.quantity.asStringJMT;
		//	endif;
		endif;
		if _includeCargoType then
			returnVal := cargoType.description &amp; " " &amp; returnVal;
		endif;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_includeCargoType" type="Boolean"/>
        <Parameter name="_weightMeasurementType" type="CM_MeasurementType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="efbef31a-b53d-4771-b8b2-8bca03e8c50c">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	txt		: String;
	tmpStr	: String;
	ti : CM_TrackedItem;

begin

	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	ti := self.getTrackedItem;
	if ti &lt;&gt; null then
		tmpStr := ti.id;
		txt := txt &amp; 'Cargo' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := getSourceDisplay();
	txt := txt &amp; 'Source Display' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := getTargetDisplay();
	txt := txt &amp; 'Target Display' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="7bef06cc-a3b7-46e7-ad2f-8e9bfc48d8ff">
        <source>getBank(): CM_Bank;
/*
Purpose:			

Date		Who		Reason
31MAY2021	NAVAB1	TFS 51219
*/

vars

begin
	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.companyOid;
	endif;
	
	if mySourceVoyage &lt;&gt; null then
		return self.mySourceVoyage.myDischargeCompany;
	endif;
	
	if myTargetVoyage &lt;&gt; null then
		return self.mySourceVoyage.myDischargeCompany;
	endif;
		
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
