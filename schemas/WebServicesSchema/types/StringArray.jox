<CollClass name="StringArray">
    <JadeMethod name="getDescription" id="b6004c9c-d707-400c-9030-10e54fda149b">
        <source>getDescription() : String;

vars
	s,
	str:	String;
begin
	foreach str in self do
		s := s &amp; str &amp; ",";
	endforeach;
	
	return s;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
