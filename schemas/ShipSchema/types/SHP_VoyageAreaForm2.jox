    <JadeMethod name="mnuCreateQuickTIClick" id="4e530895-2a1d-4dc1-98bf-6500cb42873e">
        <updating/>
        <source>mnuCreateQuickTIClick() updating;
// ---------------------------------------------------------------------------
// Created:     05 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	slot : CM_SlotController;
	slots : CM_LCSet;
	is40 : Boolean;
theReturn : Integer;
begin
	if self.myCurrentDrawingController &lt;&gt; null then
		if not self.myCurrentDrawingController.allSelectedObjects.isEmpty() then
			slot := self.myCurrentDrawingController.allSelectedObjects.first.CM_SlotController;
			if app.msgBox("Create Quick Cargo in " &amp; slot.getFullId &amp;"?", "Quick Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes then
				is40 := app.msgBox("Create 40 foot?", "Quick Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes;

				create slots transient;
				self.myCurrentDrawingController.allSelectedObjects.copy(slots);
				self.myCurrentVoyage.createQuickCargo(slots,is40 );
				
				if app.myPassport.allErrorWarnings.size &gt; 0 then
					app.myPassport.allErrorWarnings.inspectModal;
				endif;

				return;
			endif;
		endif;
	endif;
epilog
	delete slots;
end;</source>
    </JadeMethod>
