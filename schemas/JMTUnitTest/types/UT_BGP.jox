    <JadeMethod name="backupFileExists" id="0a806f70-25d0-4356-a074-4db1c3dcdb52">
        <source>backupFileExists():Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 January 2016	cnwndl1	Initial creation	Par 37296

*/

vars

	miscPath : String;
	ourBackupFile:File;

begin

	miscPath := app.cnGetServerMiscPath;
	
	create ourBackupFile transient;
	ourBackupFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	ourBackupFile.usePresentationFileSystem := false;
	ourBackupFile.fileName := miscPath &amp; "\" &amp; CM_BackupAgentDB.BackupInProgress;
	ourBackupFile.mode := File.Mode_Input;
	
	return ourBackupFile.isAvailable;
	

epilog

	delete ourBackupFile;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCargoOnSite" id="12dd298c-000e-4c6f-a470-42ed949c113e">
        <source>createCargoOnSite();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2012	cnwrd1	Initial creation

*/

vars
	bs: CM_StraddleStack;
	bs2 : CM_BlockStack;
	container1: CM_TrackedItem;
	cargo,
	packitem1,
	packitem2 : CM_TrackedItem;
	strs : StringArray;
	idx : Integer;	
	aPort : CM_Port;
	voy : CM_Voyage;
	op : CM_Operator;
	ct : CM_CargoType;
	product: CM_Product;
	startLC : CM_GridController;
	packTIs: CM_TIArray;
	locCon : CM_BlockController;
begin
	ct	:= self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := ct.allProducts.first;

	voy := self.getVoyage("UTGARBAGE1");

	aPort := app.myRoot.allPorts["NZAKL"];
	op := app.myRoot.allOperators["MSC"];
	create strs transient;
	
	
	deleteTerminalArea("UTRJD1");
	bs := self.addStraddleStack("UTRJD1", 5,5,1);
	deleteTerminalArea("UTRJD2");
	bs2 := self.addBlockStack("UTRJD2",10,null);

	
	
	startLC := bs.allGridControllersByRowColumn.first();
	// ### 20 GENERALS
	cargo := self.addContainerAtLocnDisch("RAJD2077441", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	startLC := bs.getNextAvailableLocation(startLC);
	cargo := self.addContainerAtLocnDisch("RAJD2077442", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	startLC := bs.getNextAvailableLocation(startLC);
	cargo := self.addContainerAtLocnDisch("RAJD2077443", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	startLC := bs.getNextAvailableLocation(startLC);
	cargo := self.addContainerAtLocnDisch("RAJD2077444", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	startLC := bs.getNextAvailableLocation(startLC);
	cargo := self.addContainerAtLocnDisch("RAJD2077445", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	startLC := bs.getNextAvailableLocation(startLC);
	cargo := self.addContainerAtLocnDisch("RAJD2077446", "U20G", "GENL", TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	
	self.deleteContainer("RJDPACK2");
	packitem1 := self.addContainerAtLocation("RJDPACK2", null, "U20G", "GENL", 1, bs2.myLocationsController);
	
	//packitem2 := self.addContainerAtLocation("RJDPACK1", null, "U20G", "GENL", 1, bs2.myLocationsController);
	
	
	create packTIs transient;
	packTIs.add(packitem1);
	packContainer(cargo.CM_Container, packTIs);
	deleteTerminalArea("UTRJD2");
	
epilog
	delete strs;
	delete packTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage" id="b8b6efc0-1cc4-4ed6-b878-b01fa69ef99e">
        <updating/>
        <source>createVesselVoyage(_voyage : String; _vessel : String; _operator :CM_Operator) : CM_Voyage updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2012	cnwrd1	Initial creation

*/

vars

	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
	
begin
	voyage1 := self.getVoyage("UTGARBAGE1");
	if voyage1 &lt;&gt; null then
		self.loadAllJobsToOps(voyage1, false);
	endif;
	deleteVoyage("UTGARBAGE1");
	deleteVessel("UTGARBAGE");
	
	vessel := self.addVesselLOLOholdsRORO("UTGARBAGE", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	self.addVesselDefnReefer40(vessel);

	voyage1:=self.addVoyageWithConRORO("UTGARBAGE1", "UTGARBAGE", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	
	return voyage1;
epilog

end;</source>
        <Parameter name="_voyage" type="String"/>
        <Parameter name="_vessel" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVoyageLoadJobsVA" id="f554e9bd-d5f6-4e6d-a6b7-e409c2c94dd4">
        <updating/>
        <source>createVoyageLoadJobsVA() : CM_VoyageJob updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2012	cnwrd1	Initial creation

*/


vars
	altRoroLCs, roroLCs : CM_VoyageROROControllerArray;
	realAlloc 				: CM_VoyageAllocation;
	voyage : CM_Voyage;
	altSlots, slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	theLCs: CM_LCArray;
	ct : CM_CargoType;
	product: CM_Product;
	theEditions : CM_ObjectByOidEditionDict;
	voyageJob : CM_VoyageJob;
begin
	ct	:= self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := ct.allProducts.first;

	//create a voyage job for bay 
	
	voyage := self.getVoyage("UTGARBAGE1");
	create theLCs transient;
	create slots transient;
	create altSlots transient;
	create theEditions transient;

	// ### GET SLOTS. NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 20 GENL PRENOTES
	self.getJobSlotControllers("UTGARBAGE1","05",DeckOnDeck,1,1,6,slots);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);

	
	/// ## MAKE SLOT JOB
	voyageJob:=self.addVoyageJob(voyage,"CRN1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	slots.clear;
	
	return voyageJob;

epilog
	delete slots;
	delete theLCs;
	delete altRoroLCs;
	delete roroLCs;
	delete tmpLoadCC;
	delete altSlots;
	delete theEditions;

end;</source>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="iDevGarbageCollection" id="cb61f449-47e4-496d-9a7d-633f7c11cce6">
        <source>iDevGarbageCollection();
//
//26 June 2018	jlgrs1	Initial creation
//
vars

begin
	self.opts.purge;
	self.opts.addAssoc('DevActivityHistory', true);
	self.opts.addAssoc('DevAllEDI', true);
	self.opts.addAssoc('DevArchiveVoyages', true);
	self.opts.addAssoc('DevAuditObjects', true);
	self.opts.addAssoc('DevBookingRef', true);
	self.opts.addAssoc('DevBulkRelease', true);
	self.opts.addAssoc('DevCamTaskHistory', true);
	self.opts.addAssoc('DevDataDumpExtractHistory', true);
	self.opts.addAssoc('DevDeleteArchivedVoyages', true);
	self.opts.addAssoc('DevDiscrepancies', true);
	self.opts.addAssoc('DevEDISenderRecipFileTypeHist', true);
	self.opts.addAssoc('DevEventTransactions', true);
	self.opts.addAssoc('DevGarbageTIs', true);
	self.opts.addAssoc('DevInfoEDISent', true);
	self.opts.addAssoc('DevInformation', true);
	self.opts.addAssoc('DevInvoiceItems', true);
	self.opts.addAssoc('DevJMTV6Objects', true);
	self.opts.addAssoc('DevMachineHistory', true);
	self.opts.addAssoc('DevOffsiteItems', true);
	self.opts.addAssoc('DevOldSlotControllers', true);
	self.opts.addAssoc('DevOldSlotRequests', true);
	self.opts.addAssoc('DevOverriddenWarning', true);
	self.opts.addAssoc('DevPrenoteItems', true);
	self.opts.addAssoc('DevTISnapShots', true);
	self.opts.addAssoc('DevTempReadings', true);
	self.opts.addAssoc('DevTemperatureReadings', true);
	self.opts.addAssoc('DevTowerTransactions', true);
	self.opts.addAssoc('DevUnusedVessels', true);
	self.opts.addAssoc('DevUserWindow', true);
	self.opts.addAssoc('DevVehicleVisitRecord', true);
	self.opts.addAssoc('DevVoyageJobs', true);
	self.runDevGarbageCollection(app.actualTimeServer.date.addYears(-10));
	self.assertNoTrxErrorsOrWarnings();
epilog
	self.opts.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="iGarbageCollection" id="dbc4ef44-ddb6-4483-bbe4-8ff3fc837954">
        <source>iGarbageCollection();
//
//26 June 2018	jlgrs1	Initial creation
//20 September 2022 navmv20 ChangeRequest 53403: MTN - Garbage Collection of Release Request
vars
	terminal : CM_Terminal;
	purgeBeforeDays : Integer;
begin
	self.opts.purge;
	self.opts.addAssoc('VOYAGE', true);
	self.opts.addAssoc('CARGOPHOTO', true);
	self.opts.addAssoc('VEHICLEVISIT', true);
	self.opts.addAssoc('LOGCHECKSCALEHDR', true);
	self.opts.addAssoc('JMTREPORTS', true);
	self.opts.addAssoc('YARDALLOCATIONLOGS', true);
	self.opts.addAssoc('EDIDATA', true);
	self.opts.addAssoc('LOCKTRANSACTIONS', true);
	self.opts.addAssoc('XLATION', true);
	self.opts.addAssoc('SUNDRY', true);
	self.opts.addAssoc('MACHINE', true);
	self.opts.addAssoc('DISCREP', true);
	self.opts.addAssoc('LOCATION', true);
	self.opts.addAssoc('DOCKET', true);
	self.opts.addAssoc('OFFSITE', true);
	self.opts.addAssoc('PRENOTE', true);
	self.opts.addAssoc('BOOKINGREF', true);
	self.opts.addAssoc('DUTYDOCS', true);
//	self.opts.addAssoc('VEHICLESCHED', true);
	self.opts.addAssoc('CARGOGROUPS', true);
	self.opts.addAssoc('TRUNCATEEDIINFO', true);	//14 Sep 2021	NDl	TSF 51718
	self.opts.addAssoc('RELEASEREQUESTS', true);    //16/09/2022 navmv20 TFS 53403
	foreach terminal in app.myRoot.allTerminals do
		purgeBeforeDays := terminal.getConfig(VsPurgeSlotsOlderThan).Integer;
		if purgeBeforeDays &lt; 1 then
			self.opts.addAssoc('VEHICLESCHED', false);
		else
			self.opts.addAssoc('VEHICLESCHED', true);
		endif;
		self.runGarbageCollection((app.actualTimeServer.date.addYears(-10)), terminal);
	endforeach;
	self.assertNoTrxErrorsOrWarnings();
epilog
	self.opts.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="planLoadItems" id="d921bcc3-0314-417c-85f7-645509a884c1">
        <updating/>
        <source>planLoadItems() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2012	cnwrd1	Initial creation

*/


vars
tmpOptionsUsed 	: IntegerArray;
 slots : CM_SlotControllerArray;
 allJobs 		: CM_JobArray;
	jobSheet		: CM_VoyageJobSheet;
	job				: CM_Job;
	allJobSet				: CM_VoyageJobSet;
	controller		: CMIF_ShipPlanningController;
	mode, idx 			: Integer;
	voyage 			: CM_Voyage;
	planIfStops,
	planFromRowEnds,
	useWeights,
	planAccrossTermArea,
	planAccrossTermAreaCol,
	ignoreWarnings,
	planTwinLift	: Boolean;
	
	height,
	numRowSep,
	weightAve,
	weightPC	: Integer;
	gridControler : CM_GridController;
	trackedItem 	: CM_TrackedItem;
	wle : CM_WorkListEntry;
	slot : CM_SlotController;
	theTIs: CM_TIArray;
	moveController : CMIF_MoveController;
	lcs : CM_LCArray;
	wles,wlesWithWarnings : CM_WLEArray;
begin
	
	//need to delete all containers and recreate
	
	self.removeAllStops();
	self.removeAllRTS();
	
	create tmpOptionsUsed transient;
	create allJobs transient;
	create controller transient;
	mode:=3; //this is job mode voyage is 1 crane is 2
	voyage := self.getVoyage("UTGARBAGE1");
	jobSheet:=voyage.allJobSheets["CRN1"];
	
	/*
		//result of trying to rerun this test
		//really should create the voyage and jobs before hand
		won't work if that one job has been completed need to create the job and delete it everytime
		job was marked up as 20 tl for discharge port BNE
	
	*/
	//there's only one job
	foreach job in voyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isDischarge then
			continue;
		endif;
		allJobs.add(job);
	endforeach;

	
	//not sure why this sets the config when the chk box changes value?
	app.myTrxUA.trxUpdateTerminalConfig(self.getTerminal, AutoLoadPlanAt3Height,false, app.myPassport );
	planAccrossTermArea:=true;
	ignoreWarnings := true;
	
	//self.setYardAreaFlipped();
	controller.init(self.getTerminal,
					mode, 
					allJobs, 
					jobSheet,
					voyage,
					planIfStops,
					tmpOptionsUsed, 
					height, 
					planFromRowEnds,
					numRowSep,
					null,
					useWeights,
					weightAve,
					weightPC,
					planAccrossTermArea,
					planAccrossTermAreaCol,
					ignoreWarnings,
					planTwinLift);
					
	controller.initQuery();
	controller.doQuery(null); // DO THE LOAD PLAN

	
epilog
	delete wles;
	delete wlesWithWarnings;
	delete lcs;
	delete theTIs;
	delete slots;
	delete allJobs;
	delete tmpOptionsUsed;
	delete controller;
	delete allJobSet;
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeAllRTS" id="c8a5cc46-16bb-44be-8dd7-599f37866e76">
        <updating/>
        <source>removeAllRTS() updating;
// ---------------------------------------------------------------------------
// Created:     January 2009 NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voy : CM_Voyage;
	theTIs: CM_TIArray;
begin
	create theTIs transient;
	
	voy := self.getVoyage("UTGARBAGE1");
	
	voy.allOnsiteTIsByCargoTypeId.copy(theTIs);
	app.myTrxUA.trxUpdateTIsReadyToShip(theTIs, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete theTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeAllStops" id="4f89c9d0-0b54-4d65-a3c1-d8420cffc399">
        <updating/>
        <source>removeAllStops() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2009	cnwer1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	voy : CM_Voyage;
begin
	voy := self.getVoyage("UTGARBAGE1");
	self.opts.purge;
	self.opts.addAssoc("CENum", "144");

	foreach ti in voy.allOnsiteTIsByCargoTypeId discreteLock do
			self.deleteStops(ti);
	endforeach;

	foreach ti in voy.allOnshipTIsByCargoTypeId discreteLock do
			self.deleteStops(ti);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="runDevGarbageCollection" id="c2fd9375-65ed-433f-b419-756b490b6f96">
        <source>runDevGarbageCollection(_date : Date);
//
//26 June 2018	jlgrs1	Initial creation
//
vars
	activityHistory : Boolean;
	allEDI : Boolean;
	archiveVoyages : Boolean;
	auditObjects : Boolean;
	bookingRef : Boolean;
	bulkRelease : Boolean;
	camTaskHistory : Boolean;
	dataDumpExtractHistory : Boolean;
	deleteArchivedVoyages : Boolean;
	discrepancies : Boolean;
	ediSenderRecipFileTypeHist : Boolean;
	eventTransactions : Boolean;
	garbageTIs : Boolean;
	infoEDISent : Boolean;
	information : Boolean;
	invoiceItems : Boolean;
	jMTV6Objects : Boolean;
	machineHistory : Boolean;
	offsiteItems : Boolean;
	oldSlotControllers : Boolean;
	oldSlotRequests : Boolean;
	overriddenWarning : Boolean;
	prenoteItems : Boolean;
	tiSnapShots : Boolean;
	tempReadings : Boolean;
	temperatureReadings : Boolean;
	towerTransactions : Boolean;
	userWindow : Boolean;
	unusedVessels : Boolean;
	vehicleVisitRecord : Boolean;
	voyageJobs : Boolean;
	agent : CM_DBPurgeAgent;
begin
	app.isGarbageCollectionProcess := true;
	if self.opts.includesKey("DevActivityHistory") then
		activityHistory := self.opts.bool("DevActivityHistory");
	endif;	
	if self.opts.includesKey("DevAllEDI") then
		allEDI := self.opts.bool("DevAllEDI");
	endif;	
	if self.opts.includesKey("DevArchiveVoyages") then
		archiveVoyages := self.opts.bool("DevArchiveVoyages");
	endif;	
	if self.opts.includesKey("DevAuditObjects") then
		auditObjects := self.opts.bool("DevAuditObjects");
	endif;	
	if self.opts.includesKey("DevBookingRef") then
		bookingRef := self.opts.bool("DevBookingRef");
	endif;	
	if self.opts.includesKey("DevBulkRelease") then
		bulkRelease := self.opts.bool("DevBulkRelease");
	endif;	
	if self.opts.includesKey("DevCamTaskHistory") then
		camTaskHistory := self.opts.bool("DevCamTaskHistory");
	endif;	
	if self.opts.includesKey("DevDataDumpExtractHistory") then
		dataDumpExtractHistory := self.opts.bool("DevDataDumpExtractHistory");
	endif;	
	if self.opts.includesKey("DevDeleteArchivedVoyages") then
		deleteArchivedVoyages := self.opts.bool("DevDeleteArchivedVoyages");
	endif;	
	if self.opts.includesKey("DevDiscrepancies") then
		discrepancies := self.opts.bool("DevDiscrepancies");
	endif;	
	if self.opts.includesKey("DevEDISenderRecipFileTypeHist") then
		ediSenderRecipFileTypeHist := self.opts.bool("DevEDISenderRecipFileTypeHist");
	endif;	
	if self.opts.includesKey("DevEventTransactions") then
		eventTransactions := self.opts.bool("DevEventTransactions");
	endif;	
	if self.opts.includesKey("DevGarbageTIs") then
		garbageTIs := self.opts.bool("DevGarbageTIs");
	endif;	
	if self.opts.includesKey("DevInfoEDISent") then
		infoEDISent := self.opts.bool("DevInfoEDISent");
	endif;	
	if self.opts.includesKey("DevInformation") then
		information := self.opts.bool("DevInformation");
	endif;	
	if self.opts.includesKey("DevInvoiceItems") then
		invoiceItems := self.opts.bool("DevInvoiceItems");
	endif;	
	if self.opts.includesKey("DevJMTV6Objects") then
		jMTV6Objects := self.opts.bool("DevJMTV6Objects");
	endif;	
	if self.opts.includesKey("DevMachineHistory") then
		machineHistory := self.opts.bool("DevMachineHistory");
	endif;	
	if self.opts.includesKey("DevOffsiteItems") then
		offsiteItems := self.opts.bool("DevOffsiteItems");
	endif;	
	if self.opts.includesKey("DevOldSlotControllers") then
		oldSlotControllers := self.opts.bool("DevOldSlotControllers");
	endif;	
	if self.opts.includesKey("DevOldSlotRequests") then
		oldSlotRequests := self.opts.bool("DevOldSlotRequests");
	endif;	
	if self.opts.includesKey("DevOverriddenWarning") then
		overriddenWarning := self.opts.bool("DevOverriddenWarning");
	endif;	
	if self.opts.includesKey("DevPrenoteItems") then
		prenoteItems := self.opts.bool("DevPrenoteItems");
	endif;	
	if self.opts.includesKey("DevTISnapShots") then
		tiSnapShots := self.opts.bool("DevTISnapShots");
	endif;	
	if self.opts.includesKey("DevTempReadings") then
		tempReadings := self.opts.bool("DevTempReadings");
	endif;	
	if self.opts.includesKey("DevTemperatureReadings") then
		temperatureReadings := self.opts.bool("DevTemperatureReadings");
	endif;	
	if self.opts.includesKey("DevTowerTransactions") then
		towerTransactions := self.opts.bool("DevTowerTransactions");
	endif;	
	if self.opts.includesKey("DevUserWindow") then
		userWindow := self.opts.bool("DevUserWindow");
	endif;	
	if self.opts.includesKey("DevUnusedVessels") then
		unusedVessels := self.opts.bool("DevUnusedVessels");
	endif;	
	if self.opts.includesKey("DevVehicleVisitRecord") then
		vehicleVisitRecord := self.opts.bool("DevVehicleVisitRecord");
	endif;	
	if self.opts.includesKey("DevVoyageJobs") then
		voyageJobs := self.opts.bool("DevVoyageJobs");
	endif;	
	create agent transient;
	agent.setPropertyValue(CM_DBPurgeAgent::date.name, _date);
	
	if activityHistory then
		agent.doDevActivityHistory;
	endif;
	if allEDI then
		agent.doDevAllEDI;
	endif;
	if archiveVoyages then
		agent.doDevArchiveVoyages;
	endif;
	if auditObjects then
		agent.doDevAuditObjects;
	endif;
	if bookingRef then
		agent.doDevBookingRef;
	endif;
	if bulkRelease then
		agent.doDevBulkRelease;
	endif;
	if camTaskHistory then
		agent.doDevCamTaskHistory;
	endif;
	if dataDumpExtractHistory then
		agent.doDevDataDumpExtractHistory;
	endif;
	if deleteArchivedVoyages then
		agent.doDevDeleteArchivedVoyages;
	endif;
	if ediSenderRecipFileTypeHist then
		agent.doDevEDISndrRecipFileTypeHist;
	endif;
	if eventTransactions then
		agent.doDevEventTransactions;
	endif;
	if eventTransactions then
		agent.doDevEventTransactions;
	endif;
	if garbageTIs then
		agent.doDevGarbageTIs(1);
		agent.doDevGarbageTIs(2);
		agent.doDevGarbageTIs(3);
	endif;
	if infoEDISent then
		agent.doDevInfoEDISent;
	endif;
	if information then
		agent.doDevInformation;
	endif;
	if invoiceItems then
		agent.doDevInvoiceItems;
	endif;
	if jMTV6Objects then
		agent.doDevJMTV6Objects;
	endif;
	if machineHistory then
		agent.doDevMachineHistory;
	endif;
	if offsiteItems then
		agent.doDevOffsiteItems;
	endif;
	if oldSlotControllers then
		agent.doDevOldSlotControllers;
	endif;
	if oldSlotRequests then
		agent.doDevOldSlotRequests;
	endif;
	if overriddenWarning then
		agent.doDevOverriddenWarning;
	endif;
	if prenoteItems then
		agent.doDevPrenoteItems;
	endif;
	if tiSnapShots then
		agent.doDevTISnapShots;
	endif;
	if tempReadings then
		agent.doDevTempReadings;
	endif;
	if temperatureReadings then
		agent.doDevTemperatureReadings;
	endif;
	if towerTransactions then
		agent.doDevTowerTransactions;
	endif;
	if userWindow then
		agent.doDevUserWindow;
	endif;
	if unusedVessels then
		agent.doDevUnusedVessels;
	endif;
	if vehicleVisitRecord then
		agent.doDevVehicleVisitRecord;
	endif;
	if voyageJobs then
		agent.doDevVoyageJobs;
	endif;
epilog
	app.isGarbageCollectionProcess := false;
	delete agent;
end;</source>
