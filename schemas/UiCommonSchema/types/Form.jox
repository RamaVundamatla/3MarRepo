    <JadeMethod name="enableAllControls" id="d6a30c63-8a18-4dd0-8e46-15ae12e06c88">
        <source>enableAllControls(_enable : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2009	cnwer1	Initial creation

*/

vars

	numControls,
	int:	Integer;
	ctl:	Control;
begin
	
	numControls := self.controlCount;
	int := 1;
	while int &lt;= numControls do
		ctl := self.controls(int);
		if ctl.isKindOf(Label)
		or ctl.isKindOf(CMUI_ButtonForToolbar) then
			int := int+1;
			continue;
		elseif ctl.isKindOf(CheckBox) then
			ctl.CheckBox.readOnly := (not _enable);			
		elseif ctl.isKindOf(TextBox) then
			ctl.TextBox.readOnly := (not _enable);
			ctl.enabled:=_enable;
		elseif ctl.isKindOf(Table) then
			//ctl.Table.readOnly := (not _enable);
			ctl.Table.userInputEnabled :=  _enable;
		elseif ctl.isKindOf(JadeEditMask) then
			ctl.JadeEditMask.readOnly := (not _enable);
		elseif ctl.isKindOf(Button)
		or ctl.isKindOf(ComboBox)
		or ctl.isKindOf(OptionButton) then
			ctl.enabled := _enable;
		elseif ctl.isKindOf(ListBox) then
			// do not disable ListBoxes as then users cannot scroll down
			// if required to see what is there
			//ctl.enabled := _enable;
		elseif ctl.isKindOf(CMUI_MultiSelectGroupBox) then
			ctl.CMUI_MultiSelectGroupBox.readOnly:=(not _enable);
		// sfw1035
		elseif ctl.isKindOf(CMUI_FieldFrame) then
			ctl.enabled := _enable;
		endif;
		int := int+1;
	endwhile;


epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
