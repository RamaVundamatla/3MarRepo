	endif;
	
	terminal := self.terminal;
	
	if terminal &lt;&gt; null then
		terminalCode := terminal.code;
	endif;
	
	invExtNumber := invExtNumGenerator.getNextId(null, terminalCode);
	
	return invExtNumber;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="86ec2c9a-862f-4790-a849-e34415521403">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Dec 2016	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up

*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	txt,
	tmpStr,str	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr := null;
	str    :=null;
	if self.code &lt;&gt; null then
		tmpStr:=self.code;
		txt := txt &amp; app.getErrorString(Code) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str    :=null;
	if self.mailingName &lt;&gt; null then
		tmpStr:=self.mailingName;
		txt := txt &amp; app.getErrorString(Name) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str    :=null;
	if self.mailingAddress.size &gt; 0 then
		foreach str in self.mailingAddress do
			tmpStr :=tmpStr&amp; " " &amp;str ;
		endforeach;
		tmpStr := tmpStr.trimLeft;
		txt := txt &amp; app.getFormCaptionsString(Xlat_0017114) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;

	tmpStr := null;
	str    :=null;
	if self.onsiteStorageChargeTime &lt;&gt; NULL_TIME then
		tmpStr := self.onsiteStorageChargeTime.format("HH:mm");
		txt := txt &amp;'Cut-Off Time'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str    :=null;
	if self.allBankDetails.size &gt; 0 then
		foreach str in self.allBankDetails do
			if str = null then
				break;
			endif;
			tmpStr :=tmpStr&amp; " " &amp;str ;
		endforeach;
		tmpStr := tmpStr.trimLeft;
		txt := txt &amp;'Bank Details' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str := null;
	if self.physicalAddress.size &gt; 0 then
		foreach str in self.physicalAddress do
			if str = null then
				break;
			endif;
			tmpStr :=tmpStr&amp; " " &amp;str ;
		endforeach;
		tmpStr := tmpStr.trimLeft;
		txt := txt &amp;'Remittance Address' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str := null;
	if self.currentTransactionMap &lt;&gt; null then
		tmpStr := self.currentTransactionMap.description;
		txt := txt &amp;'Current Cargo Transaction Map' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str := null;
	if self.myCurrentTranMapVoyage &lt;&gt; null then
		tmpStr := self.myCurrentTranMapVoyage.description;
		txt := txt &amp;'Current Voyage Transaction Map' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str := null;
	if self.myCurrentTranMapEvent &lt;&gt; null then
		tmpStr := self.myCurrentTranMapEvent.description;
		txt := txt &amp;'Current Event Transaction Map' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myCurrentTranMapCargoAlloc &lt;&gt; null then
		tmpStr := self.myCurrentTranMapCargoAlloc.description;
		txt := txt &amp;'Current Cargo Allocation Transaction Map' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	
	tmpStr := null;
	if self.taxPercentageRate &lt;&gt; 0 then
		tmpStr := self.taxPercentageRate.asStringJMT;
		txt := txt &amp;'Tax Percentage Rate' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.mailingName &lt;&gt; null then
		tmpStr := self.mailingName;
		txt := txt &amp;'Name' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAutoInvoice" id="1162f0aa-288f-41e7-8383-17aeb4e046dc">
        <updating/>
        <source>getAutoInvoice(_invoiceType 	 : CM_InvoiceDesc;
			   _invLineType 	 : CM_InvoiceLineDesc; 
			   _tran			 : CM_TITransaction; 
			   _debtor		 	 : CM_Debtor; 
			   _forcedStatusOpen : Boolean ): CM_Invoice updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2005 cnwab1	Initial creation	TFS 47100
16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link
*/
vars
	obj			: CM_Object;
	retInvoice	: CM_Invoice;
	paymentType : Integer;			
	woSet		: CM_WorkOrderSet;
begin

	//10 Oct 2018	NDL	TFS 41281
	if _invLineType &lt;&gt; null then
		paymentType := _invLineType.getPaymentType( _debtor );
	endif;

	// 31263 Mar 2013 if proforma save an invoice per invoice type in app.allReportObjectSet
	if app.isInProformaMode then
		
		foreach obj in app.allReportObjectSet do
			if obj.isKindOf(CM_Invoice) then
				if obj.CM_Invoice.invoiceType = _invoiceType
				and obj.CM_Invoice.paymentType = paymentType //10 Oct 2018	NDL	TFS 41281
				then
					retInvoice := obj.CM_Invoice;
					break;
				endif;
			endif;
		endforeach;
		
		if retInvoice = null then
			create retInvoice;
			retInvoice.initialise(self, _invoiceType, _debtor, _tran, _forcedStatusOpen, paymentType);
			app.allReportObjectSet.add(retInvoice);
			
			// TFS 39803 moved this call to myCreateAuditAgentso that it is just for actual creates
			app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(retInvoice);		// 9/5/18 MAP TFS37718
		endif;
		
		return retInvoice;
	endif;
	
	// 31890 performance - remove the loop and tryLocks
	self.reserveLock(self.allInvoices);

	retInvoice := self.getMatchingInvoice(_invoiceType, _invLineType, _tran, _debtor, _forcedStatusOpen );
	
	//16.12.2021 navma1 #52580
	if _tran &lt;&gt; null then
		create woSet transient;
		self.findMatchedWorkOrders(_tran,_debtor,woSet);
	endif;
	
	if retInvoice = null then
		create retInvoice;
		retInvoice.initialise(self, _invoiceType, _debtor, _tran, _forcedStatusOpen, paymentType);
		
		/*
		16.12.2021 navma1 #52580
		// ### TFS 39349 Voyage Work Orders are only seen if the terminal's voyage process is PEL1 or IPN SO only these termianls will find a voyage work order
		wo := tran.getWorkOrderForInvoice(); // TFS 39349
		retInvoice.setMyWorkOrder(wo); 		 // TFS 39349
		*/
		
		//16.12.2021 navma1 #52580
		if not woSet.isEmpty then
			woSet.copyNoDuplicates(retInvoice.allWorkOrders,false);
		endif;
		
		// TFS 39803 moved this call to myCreateAuditAgentso that it is just for actual creates
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(retInvoice);						// 9/5/18 MAP TFS37718
	else
		// make sure we have the latest version of the invoice and that nobody can change it
		self.reserveLock(retInvoice);
		
		//16.12.2021 navma1 #52580
		if not woSet.isEmpty then
			woSet.copyNoDuplicates(retInvoice.allWorkOrders,false);
		endif;
	endif;

	if retInvoice = null then // ## PAR 10155 AKB2005JUNE
		app.raiseCMException1(ERROR_NULL_INVOICE," the '" &amp; _tran.class.getNiceName() &amp; "' transaction ",null,null);
	endif;
	

	return retInvoice;

epilog
	delete woSet;
end;</source>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_forcedStatusOpen" type="Boolean"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getAutoInvoiceBOL" id="c640c2e2-3a53-415d-b569-5b83f70198a3">
        <updating/>
        <source>getAutoInvoiceBOL(	invoiceType: CM_InvoiceDesc;
					_invLineType : CM_InvoiceLineDesc;
					tran: CM_BOLTransaction;
					debtor: CM_Debtor
					): CM_Invoice updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	retInvoice : CM_Invoice;
	paymentType : Integer;	
	
begin

	if debtor &lt;&gt; null then
		paymentType := debtor.getDefaultPaymentType( self.terminal );
	else
		paymentType := 0;
	endif;
	if _invLineType &lt;&gt; null and debtor &lt;&gt; null then
		paymentType := _invLineType.getPaymentType(debtor);
	endif;
	

	self.reserveLock(self.allInvoices);
	retInvoice := self.getMatchingInvoiceBOL(invoiceType, _invLineType, tran, debtor);
	if retInvoice = null then
		create retInvoice;
		retInvoice.initialiseBOL(self, invoiceType, debtor, tran, paymentType); 
		
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(retInvoice);		// 9/5/18 MAP TFS37718
	else
		// make sure we have the latest version of the invoice and that nobody can change it
		self.reserveLock(retInvoice);
	endif;


	return retInvoice;

epilog
end;</source>
        <Parameter name="invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="tran" type="CM_BOLTransaction"/>
        <Parameter name="debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getAutoInvoiceEvent" id="d7d363eb-50fe-4deb-9018-db5e8cbc4e71">
        <updating/>
        <source>getAutoInvoiceEvent(invoiceType: CM_InvoiceDesc; _invLineType : CM_InvoiceLineDesc; tran: CM_EventTransaction; debtor: CM_Debtor): CM_Invoice updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Dec 2024 navma1  MTN-33567 MTN - Charges Are Not Created When adding Events

*/

vars
	retInvoice		: CM_Invoice;
	paymentType 	: Integer;	
	voyage			: CM_Voyage;
begin

	if tran.isVoyageEvent then 
		voyage := tran.CMEVT_VoyageEvent.getVoyage();					//05.12.2024 navma1 #MTN-33567
		if voyage &lt;&gt; null then
			paymentType := voyage.paymentType;
		endif;
	else
		if debtor &lt;&gt; null then
			paymentType := debtor.getDefaultPaymentType( self.terminal );
		else
			paymentType := 0;
		endif;
		if _invLineType &lt;&gt; null and debtor &lt;&gt; null then
			paymentType := _invLineType.getPaymentType(debtor);
		endif;
	endif;

	// 31890 performance - get rid of the loop and tryLocks
	self.reserveLock(self.allInvoices);
	retInvoice := self.getMatchingInvoiceEvent(invoiceType, _invLineType, tran, debtor);
	if retInvoice = null then
		create retInvoice;
		retInvoice.initialiseEvent(self, invoiceType, debtor, tran, paymentType);

		// TFS 39803 moved this call to myCreateAuditAgentso that it is just for actual creates
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(retInvoice);		// 9/5/18 MAP TFS37718
	else
		// make sure we have the latest version of the invoice and that nobody can change it
		self.reserveLock(retInvoice);
	endif;

	return retInvoice;

epilog
end;</source>
        <Parameter name="invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="tran" type="CM_EventTransaction"/>
        <Parameter name="debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getAutoInvoiceSnapshot" id="aa0c6451-6043-4bbc-a2b1-d88e9f16fe47">
        <updating/>
        <source>getAutoInvoiceSnapshot(	_invoiceType: CM_InvoiceDesc;
						_debtor: CM_Debtor;
						_dateTime : TimeStamp;
						_forcedStatusOpen : Boolean;
						_invLineType : CM_InvoiceLineDesc
						): CM_Invoice updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars
	retInvoice:      CM_Invoice;
	paymentType : Integer;	//10 Oct 2018	NDL	TFS 41281
begin

	//10 Oct 2018	NDL	TFS 41281
	if _invLineType &lt;&gt; null then
		paymentType := _invLineType.getPaymentType( _debtor );
	endif;
	
	// 31890 performance get rid of the loop and tryLock
	retInvoice := self.getMatchingInvoiceSnapshot(_invoiceType, _invLineType, _dateTime, _debtor, _forcedStatusOpen );
	if retInvoice = null then
		create retInvoice;

		// TFS 39803 moved this call to myCreateAuditAgentso that it is just for actual creates
		retInvoice.initialise(self, _invoiceType, _debtor, null, _forcedStatusOpen, paymentType);
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(retInvoice);		// 9/5/18 MAP TFS37718
	else
		// make sure we have the latest version of the invoice and that nobody can change it
		self.reserveLock(retInvoice);
	endif;

	if retInvoice = null then
		app.raiseCMException1(ERROR_NULL_INVOICE," snap shot ",null,null);
	endif;
	

	return retInvoice;

epilog
end;</source>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_forcedStatusOpen" type="Boolean"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getAutoInvoiceVTMIS" id="6529f254-f8f1-4f8d-9a4b-6626222ae43f">
        <updating/>
        <source>getAutoInvoiceVTMIS(_invoiceType : CM_InvoiceDesc; 
					_invLineType : CM_InvoiceLineDesc; 
					_tran		 : HMS_VTMISTransaction; 
					_debtor		 : CM_Debtor): CM_Invoice updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link
*/
vars
	retInvoice	: CM_Invoice;
	paymentType : Integer;
	woSet		: CM_WorkOrderSet;
begin
	
	//10 Oct 2018	NDL	TFS 41281
	if _invLineType &lt;&gt; null then
		paymentType := _tran.myVoyage.paymentType;	//17 Oct 2018	NDL	TFS 41446
	endif;

	// 31890 performance get rid of the loopp and tryLocks
	retInvoice := self.getMatchingInvoiceVTMIS(_invoiceType, _invLineType, _tran, _debtor);
	
	//10.02.2022 navma1 #52580
	if _tran &lt;&gt; null then
		create woSet transient;
		self.findMatchedVoyageWorkOrders(_tran,woSet);
	endif;
	
	if retInvoice = null then
		create retInvoice;
		retInvoice.initialiseVTMIS(self, _invoiceType, _debtor, _tran, paymentType);
		
		//10.02.2022 navma1 #52580
		if not woSet.isEmpty then
			woSet.copyNoDuplicates(retInvoice.allWorkOrders,false);
		endif;
		
		// TFS 39803 moved this call to myCreateAuditAgentso that it is just for actual creates
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(retInvoice);		// 9/5/18 MAP TFS37718
	else
		// make sure we have the latest version of the invoice and that nobody can change it
		self.reserveLock(retInvoice);
		
		//10.02.2022 navma1 #52580
		if not woSet.isEmpty then
			woSet.copyNoDuplicates(retInvoice.allWorkOrders,false);
		endif;
	endif;

	return retInvoice;

epilog
	delete woSet;
end;</source>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_tran" type="HMS_VTMISTransaction"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getAutoInvoiceWO" id="caae3c95-839a-4c0b-8d93-f730798b025c">
        <updating/>
        <source>getAutoInvoiceWO(_invoiceType	: CM_InvoiceDesc;
				 _invLineType	: CM_InvoiceLineDesc; 
				 _tran			: CM_WOTransaction;
				 _debtor		: CM_Debtor): CM_Invoice updating;
/*

Purpose:			
	TFS 39237
Parameters:			

Return Value:		

Date		Who		Reason
JUNE 2018	CNWAB1	Initial creation
16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
*/

vars
	retInvoice		: CM_Invoice;
	paymentType 	: Integer;			//10 Oct 2018	NDL	TFS 41281
	wo				: CM_WorkOrder;		//17 Oct 2018	NDL	TFS 41446
	voyage			: CM_Voyage;
begin

	//17 Oct 2018	NDL	TFS 41446
	wo		 := _tran.myWorkOrder;
	//voyage	 := wo.CM_WorkOrderVoyage.getMyVoyageObject;
	// 15/05/2023	navkc1	CR 57927 Task 54268
	voyage	 := wo.CM_WorkOrder.getMyVoyageObject;
	
	if wo &lt;&gt; null and wo.isVoyageWorkOrder and voyage  &lt;&gt; null then
		paymentType := voyage.paymentType;
	else
		if _debtor &lt;&gt; null then
			paymentType := _debtor.getDefaultPaymentType( self.terminal );
		else
			paymentType := 0;
		endif;
		if _invLineType &lt;&gt; null and _debtor &lt;&gt; null then
			paymentType := _invLineType.getPaymentType(_debtor);
		endif;
	endif;

	// 31890 performance - get rid of the loop and tryLocks
	self.reserveLock(self.allInvoices);
	
	retInvoice := self.getMatchingInvoiceWO(_invoiceType, _invLineType, _tran, _debtor);
	
	if retInvoice = null then
		create retInvoice;
		retInvoice.initialiseWorkOrder(self, _invoiceType, _debtor, _tran.myWorkOrder, paymentType); // TFS 37964 pass in WO
		
		//10.02.2022 navma1 #52580
		if wo &lt;&gt; null then
			retInvoice.allWorkOrders.addNoDuplicates(wo,false);
		endif;
		
		// TFS 39803 moved this call to myCreateAuditAgentso that it is just for actual creates
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(retInvoice);		// 9/5/18 MAP TFS37718
	else
		// make sure we have the latest version of the invoice and that nobody can change it
		self.reserveLock(retInvoice);
		
		//10.02.2022 navma1 #52580
		if wo &lt;&gt; null then
			retInvoice.allWorkOrders.addNoDuplicates(wo,false);
		endif;
	endif;


	return retInvoice;

epilog
end;</source>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_tran" type="CM_WOTransaction"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getAutoInvoiceX" id="4c309448-da54-4e49-8e43-d847281edde7">
        <updating/>
        <source>getAutoInvoiceX(invoiceType: CM_InvoiceDesc; tran: CM_TITransaction; debtor: CM_Debtor; _forcedStatusOpen : Boolean; _isNew : Boolean output ): CM_Invoice updating;
// TEST (31890) copy of getAutoInvoice without any creation, for the existing code
vars
	obj:			 CM_Object;
	retInvoice:      CM_Invoice;
	invoicesLocked:  Boolean;
	tryCount:        Integer;
	
	tmpStatus : Integer;
begin
	_isNew := false;
	tmpStatus := invoiceType.getStatusForNewInvoice(_forcedStatusOpen); // PAR 17895
	
	while tryCount &lt; 5 do
		retInvoice := self.getMatchingInvoiceX(invoiceType, tran, debtor, _forcedStatusOpen );
		if retInvoice = null then
			// probably need to create a new invoice.  Lock allInvoices to see if we
			// are the only one doing it.
			if not invoicesLocked then
				invoicesLocked := tryLock(self.allInvoices, Exclusive_Lock, Transaction_Duration, 1000);
				// now make doubly sure that we have the latest invoice
				// go around again
			else
				// we have locked allInvoices and tryed again to find a suitable invoice
				// to no avail so we need to create a new invoice.
				////create retInvoice;
				////retInvoice.initialise(self, invoiceType, debtor, tran, _forcedStatusOpen);
				_isNew := true;
				break;
			endif;
		else
			// make sure we have the latest version of the invoice and that nobody can change it
			if tryLock(retInvoice, Exclusive_Lock, Transaction_Duration, 1000) then
//				if (retInvoice.status = CM_Invoice.INVOICE_OPEN)
				if (retInvoice.status = tmpStatus) then // PAR 17895
					// all systems are GO!
					break;
				else
					unlock(retInvoice);
				endif;
			endif;
		endif;
		tryCount := tryCount + 1;
	endwhile;

	return retInvoice;

epilog
	if invoicesLocked then
		unlock(self.allInvoices);
	endif;
end;</source>
        <Parameter name="invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="tran" type="CM_TITransaction"/>
        <Parameter name="debtor" type="CM_Debtor"/>
        <Parameter name="_forcedStatusOpen" type="Boolean"/>
        <Parameter name="_isNew" type="Boolean" usage="output"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getAutoInvoiceY" id="fcfcd915-61da-4653-9aee-8bd94886e877">
        <updating/>
        <source>getAutoInvoiceY(invoiceType: CM_InvoiceDesc; tran: CM_TITransaction; debtor: CM_Debtor; _forcedStatusOpen : Boolean; _isNew : Boolean output ): CM_Invoice updating;
// TEST (31890) new version of getAutoInvoice without any creation, for the new code
vars
	retInvoice:      CM_Invoice;
	invoicesLocked:  Boolean;
	
	tmpStatus : Integer;
begin
	_isNew := false;
	tmpStatus := invoiceType.getStatusForNewInvoice(_forcedStatusOpen);
	
	self.reserveLock(self.allInvoices);
	invoicesLocked := true;
	retInvoice := self.getMatchingInvoiceX(invoiceType, tran, debtor, _forcedStatusOpen );
	if retInvoice = null then
		////create retInvoice;
		////retInvoice.initialise(self, invoiceType, debtor, tran, _forcedStatusOpen);
		_isNew := true;
	else
		// make sure we have the latest version of the invoice and that nobody can change it
		self.reserveLock(retInvoice);
	endif;

	return retInvoice;

epilog
	if invoicesLocked then
		unlock(self.allInvoices);
	endif;
end;</source>
        <Parameter name="invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="tran" type="CM_TITransaction"/>
        <Parameter name="debtor" type="CM_Debtor"/>
        <Parameter name="_forcedStatusOpen" type="Boolean"/>
        <Parameter name="_isNew" type="Boolean" usage="output"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getBankDetailsString" id="646e7ec5-53bd-4b5c-8499-03f6133f1580">
        <source>getBankDetailsString() : String;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aStr : String;
	idx, endIdx : Integer;
begin
	if self.allBankDetails = null then
		return null;
	endif;
	
	if self.allBankDetails.isEmpty then
		return null;
	endif;
	
	endIdx := self.allBankDetails.size;
	foreach idx in 1 to endIdx do
		aStr := aStr &amp; self.allBankDetails[idx] &amp; CrLf;		// from TFS 2062 was just Cr
	endforeach;
	
	return aStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBusinessUnits" id="5c0a9746-55f5-4c43-9bd7-b8c6b4821336">
        <source>getBusinessUnits(_terminal : CM_Terminal; businessUnits: CM_CompanyByCodeDict input);

vars
	company:  CM_Bank;
	iter	: Iterator;

begin
	if (not self.isRootCompany) then
		self.parentCompany.getBusinessUnits(_terminal, businessUnits);
		return;
	endif;

	iter := self.subCompanies.createIterator;
	self.subCompanies.startKeyGeq(_terminal, null, iter);
	while iter.next(company) do
		if company.terminal &lt;&gt; _terminal then
			break;
		endif;
		company.subCompanies.copy(businessUnits);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="businessUnits" type="CM_CompanyByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCalcTypeForTransaction" id="6947119e-67e5-4e79-b691-2286c815fd57">
        <source>getCalcTypeForTransaction(_transaction : CM_TITransaction) : CM_CalculationType;
// ---------------------------------------------------------------------------
// Created:     15 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------


vars
	invLineDesc:  CM_InvoiceLineDesc;
	aSBController : CMIF_ServiceBroker;
	idx : Integer;
	aServ : CM_Service;
begin
	if _transaction = null then
		return null;
	endif;

	create aSBController transient;
	aSBController.myTransaction := _transaction;
	
	self.getInvoiceLineDescForXaction(aSBController);

	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		aServ := invLineDesc.services.first;
		if aServ &lt;&gt; null and aServ.myCalculationType &lt;&gt; null then
			return aServ.myCalculationType;
		endif;
	endforeach;
	return null;
	
epilog
	delete aSBController;



end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <ReturnType type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="getChargeTypeFromMapping" id="26cdfaff-b45b-42c9-b24a-6fbda3114c6d">
        <source>getChargeTypeFromMapping(_invLine : CM_InvoiceLineDesc; _parentObj : CM_Object; _combinationObj : CM_Object) : Integer;
// ---------------------------------------------------------------------------
// Created:		20 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aMap : CM_InvoiceLineChargeMapping;
begin
	// no mappings do not check
	if self.allInvLineChargeMappings.isEmpty() then
		return self.No_Charge_Mapping;
	endif;
	if _combinationObj = null then
		return self.No_Charge_Mapping;
	endif;
		
	aMap := self.allInvLineChargeMappings[_invLine, _parentObj, _combinationObj];
	if aMap = null then
		return self.No_Charge_Mapping;
	else
		return aMap.chargeByOpCon;
	endif;
end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLineDesc"/>
        <Parameter name="_parentObj" type="CM_Object"/>
        <Parameter name="_combinationObj" type="CM_Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCompanyByCode" id="9c49f125-752c-43da-871e-b8df1b6e3e99">
        <source>getCompanyByCode(_term : CM_Terminal; _code : String) : CM_Bank;
// ---------------------------------------------------------------------------
// Created:		19 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	sub, subSub : CM_Bank;
begin
	foreach sub in self.subCompanies discreteLock do
		if sub.code = _code then
			return sub;
		endif;
		
		if sub.terminal &lt;&gt; _term then
			continue;
		endif;
		
		
		subSub := sub.getCompanyByCode(_term, _code);
		if subSub &lt;&gt; null then
			return subSub;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getConfig" id="c2ebdb7d-c6b8-49d5-825c-f45e29429eaf">
        <source>getConfig( pCode : String ) : Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

begin

	return self.getStateData( pCode );

epilog

end;</source>
        <Parameter name="pCode" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getDebtorTypeFromMapInventory" id="ba4a07f0-6f00-482f-89c2-26520572b095">
        <source>getDebtorTypeFromMapInventory(_invLine : CM_InvoiceLineDesc; _parentObj : CM_Object; _tran : CMEVT_LocationActivity) : CM_DebtorType;
/*
Purpose:			

Date		Who		Reason
31MAY2021	NAVAB1	TFS 51219
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	aMap 		   : CM_InvoiceLineChargeMapping;
	combinationObj : CM_Object;
	tmpVoyage	   : CM_Voyage;
	lMessage	   : String;
begin
	// no mappings do not check
	if self.allInvLineChargeMappings.isEmpty() then
		return null;
	endif;
	
	if _tran = null then
		return null;
	endif;
		
	aMap := self.allInvLineChargeMappings.getAtKeyGeq(_invLine, _parentObj, null);
	
	if aMap &lt;&gt; null then
		if aMap.myInvoiceLineDesc = _invLine
		and aMap.myParentMappingObject = _parentObj then
			// Get the Debtor Type
			if aMap.myCombinationMappingObject.isKindOf(CM_ConsigneeConsignor) then
				if aMap.chargeTypeCode = CM_DebtorType.DT_CONSIGNEE then
					lMessage	   := "Invoice Line Charge Mapping, Consignee "&amp;_tran.consignee;
					combinationObj := app.myRoot.allConsigneeConsignors[_tran.consignee];
				elseif aMap.chargeTypeCode = CM_DebtorType.DT_CONSIGNOR then
					lMessage	   := "Invoice Line Charge Mapping, Consignor "&amp;_tran.consignor;
					combinationObj := app.myRoot.allConsigneeConsignors[_tran.consignor];
				endif;
			elseif aMap.myCombinationMappingObject.isKindOf(CM_Operator) then
				if aMap.chargeTypeCode = CM_DebtorType.DT_CARGO_OPERATOR then
					lMessage 	   := "Invoice Line Charge Mapping, Cargo Operator "&amp;_tran.operatorCode;
					if _tran.operatorCode &lt;&gt; null then
						combinationObj := app.myRoot.allOperators[_tran.operatorCode];
					endif;
				elseif aMap.chargeTypeCode = CM_DebtorType.DT_SHIP_OPERATOR then
					lMessage 	   := "Invoice Line Charge Mapping, Ship Operator ";
					tmpVoyage 	   := _tran.getVoyage();
					if tmpVoyage &lt;&gt; null then
						combinationObj := tmpVoyage.myOperator;
						if tmpVoyage.myOperator &lt;&gt; null then
							lMessage := lMessage &amp; " " &amp; tmpVoyage.myOperator.code;
						endif;
					endif;
				endif;
			elseif aMap.myCombinationMappingObject.isKindOf(CM_Carrier) then
				lMessage := "Invoice Line Charge Mapping, Carrier ";
					if _tran.carrierCode &lt;&gt; null then
						combinationObj := app.myRoot.allCarriers[_tran.carrierCode];
					endif;
			elseif aMap.myCombinationMappingObject.isKindOf(CM_Stevedore) then
				lMessage := "Invoice Line Charge Mapping, Stevedore " &amp; _tran.stevedoreCode;
				if _tran.stevedoreCode &lt;&gt; null then
					combinationObj := app.myRoot.allStevedores[_tran.stevedoreCode];
				endif;
			endif;
		endif;
	endif;
	
	if app.canLogExtraDetail then							//05.10.2022 navma1 #52967
		if combinationObj &lt;&gt; null then
			app.invLog(lMessage, LogINFO.String);
		endif;
	endif;
	
	return self.getDebtorTypeFromMapping(_invLine, _parentObj,combinationObj);
end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLineDesc"/>
        <Parameter name="_parentObj" type="CM_Object"/>
        <Parameter name="_tran" type="CMEVT_LocationActivity"/>
        <ReturnType type="CM_DebtorType"/>
    </JadeMethod>
    <JadeMethod name="getDebtorTypeFromMapTI" id="889d89d1-56ce-4e5a-9bae-821fc54c37ca">
        <source>getDebtorTypeFromMapTI(_invLine : CM_InvoiceLineDesc; _parentObj : CM_Object; _ti : CM_TrackedItem) : CM_DebtorType;
// ---------------------------------------------------------------------------
// Created:	22 October 2008 By Graeme Black cnwgb1
// Purpose:	Get the debtor type for an inv line/ parent object using the charge mappings
// Added for PAR 18186
// Based on getDebtorTypeFromMapTrans()
// 05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 18 Oct 2024  navlw1		JIRA-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------

vars
	aMap 			: CM_InvoiceLineChargeMapping;
	combinationObj  : CM_Object;
	dt 				: CM_Debtor;
	tmpVoyage 		: CM_Voyage;
	tmpCustomsAgent : CM_CustomsAgent;
	lMessage		: String;
begin
	// no mappings do not check
	if self.allInvLineChargeMappings.isEmpty() then
		return null;
	endif;
	
	if _ti = null then
		return null;
	endif;
		
	aMap := self.allInvLineChargeMappings.getAtKeyGeq(_invLine, _parentObj, null);
	if aMap &lt;&gt; null then
		if aMap.myInvoiceLineDesc = _invLine and aMap.myParentMappingObject = _parentObj then
			// Get the Debtor Type
			if aMap.myCombinationMappingObject.isKindOf(CM_ConsigneeConsignor) then
				if aMap.chargeTypeCode = CM_DebtorType.DT_FREIGHT_FORWARDER then
					lMessage := "Invoice Line Charge Mapping, Freight Forwarder "&amp;_ti.freightForwarderCode;
					combinationObj := app.myRoot.allConsigneeConsignors[_ti.freightForwarderCode];
				elseif aMap.chargeTypeCode = CM_DebtorType.DT_CONSIGNEE then
					lMessage := "Invoice Line Charge Mapping, Consignee "&amp;_ti.consignee;
					combinationObj := app.myRoot.allConsigneeConsignors[_ti.consignee];
				elseif aMap.chargeTypeCode = CM_DebtorType.DT_CONSIGNOR then
					lMessage := "Invoice Line Charge Mapping, Consignor "&amp;_ti.consignor;
					combinationObj := app.myRoot.allConsigneeConsignors[_ti.consignor];
				endif;
			
			elseif aMap.myCombinationMappingObject.isKindOf(CM_Operator) then
				if aMap.chargeTypeCode = CM_DebtorType.DT_CARGO_OPERATOR then
					lMessage := "Invoice Line Charge Mapping, Cargo Operator "&amp;_ti.operatorCode;
					if _ti.operatorCode &lt;&gt; null then
						combinationObj := app.myRoot.allOperators[_ti.operatorCode];
					endif;
				elseif aMap.chargeTypeCode = CM_DebtorType.DT_SHIP_OPERATOR then
					lMessage := "Invoice Line Charge Mapping, Ship Operator ";
					tmpVoyage := _ti.myVoyage;
					if tmpVoyage &lt;&gt; null then
						combinationObj := tmpVoyage.myOperator;
						if tmpVoyage.myOperator &lt;&gt; null then
							lMessage := lMessage &amp; " " &amp; tmpVoyage.myOperator.code;
						endif;
					endif;
				endif;
				
			elseif aMap.myCombinationMappingObject.isKindOf(CM_CustomsAgent) then
				tmpCustomsAgent := _ti.myCustomsAgent;
				if tmpCustomsAgent &lt;&gt; null then
					lMessage := "Invoice Line Charge Mapping, Customs Agent "&amp;tmpCustomsAgent.code;
					combinationObj := tmpCustomsAgent;
				endif;
				// 24094 add carrier
			elseif aMap.myCombinationMappingObject.isKindOf(CM_Carrier) then
				lMessage := "Invoice Line Charge Mapping, Carrier "&amp;_ti.carrier;
				if _ti.carrier &lt;&gt; null then
					combinationObj := app.myRoot.allCarriers[_ti.carrier];
				endif;

			elseif aMap.myCombinationMappingObject.isKindOf(CM_Debtor) then
				lMessage := "Invoice Line Charge Mapping, Debtor "&amp;aMap.chargeTypeCode;
				dt := _ti.allDebtorsByType[aMap.chargeTypeCode];
				
				combinationObj := dt;
			
			endif;
		endif;
	endif;
	
	if app.canLogExtraDetail then		//05.10.2022 navma1 #52967
		if combinationObj &lt;&gt; null then
			app.invLog(lMessage, LogINFO.String);
		endif;
	endif;
	
	return self.getDebtorTypeFromMapping(_invLine, _parentObj, combinationObj);
end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLineDesc"/>
        <Parameter name="_parentObj" type="CM_Object"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_DebtorType"/>
    </JadeMethod>
    <JadeMethod name="getDebtorTypeFromMapTrans" id="b4c3b260-db4c-4be1-92d9-81573eb38053">
        <source>getDebtorTypeFromMapTrans(_invLine : CM_InvoiceLineDesc; _parentObj : CM_Object; _tran : CM_TITransaction) : CM_DebtorType;
// ---------------------------------------------------------------------------
// Created:     July 2008 ANDREW BISHOP
//
// Purpose:     get the first mapping for this inv line type/ parent object. 
//					Use that to work out what debtor type we are mapping to. 
//					Then use the debtor type to get the actual combination object from the transaction.
//					See if there is a mapping for line type/ parent object/ combination object 
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 16JUL2008		AKBishop		PAR 17557 created
// 05/06/2019		jlgdap1			TFS 44554 AAT Stevedore Data Access
// 18 Oct 2024  	navlw1			JIRA-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------

vars
	aMap : CM_InvoiceLineChargeMapping;
	combinationObj : CM_Object;
	dt : CM_Debtor;
	tmpVoyage : CM_Voyage;
	lMessage	: String;
begin
	// no mappings do not check
	if self.allInvLineChargeMappings.isEmpty() then
		return null;
	endif;
	if _tran = null then
		return null;
	endif;
		
	aMap := self.allInvLineChargeMappings.getAtKeyGeq(_invLine, _parentObj, null);
	if aMap &lt;&gt; null then
		if aMap.myInvoiceLineDesc = _invLine
		and aMap.myParentMappingObject = _parentObj then
			// Get the Debtor Type
			if aMap.myCombinationMappingObject.isKindOf(CM_ConsigneeConsignor) then
				if aMap.chargeTypeCode = CM_DebtorType.DT_FREIGHT_FORWARDER then
					lMessage := "Invoice Line Charge Mapping, Freight Forwarder "&amp;_tran.freightForwarderCode;
					combinationObj := app.myRoot.allConsigneeConsignors[_tran.freightForwarderCode];
				elseif aMap.chargeTypeCode = CM_DebtorType.DT_CONSIGNEE then
					lMessage := "Invoice Line Charge Mapping, Consignee "&amp;_tran.consignee;
					combinationObj := app.myRoot.allConsigneeConsignors[_tran.consignee];
				elseif aMap.chargeTypeCode = CM_DebtorType.DT_CONSIGNOR then
					lMessage := "Invoice Line Charge Mapping, Consignor "&amp;_tran.consignor;
					combinationObj := app.myRoot.allConsigneeConsignors[_tran.consignor];
				endif;
			
			elseif aMap.myCombinationMappingObject.isKindOf(CM_Operator) then
				if aMap.chargeTypeCode = CM_DebtorType.DT_CARGO_OPERATOR then
					lMessage := "Invoice Line Charge Mapping, Cargo Operator "&amp;_tran.operatorCode;
					if _tran.operatorCode &lt;&gt; null then
						combinationObj := app.myRoot.allOperators[_tran.operatorCode];
					endif;
				elseif aMap.chargeTypeCode = CM_DebtorType.DT_SHIP_OPERATOR then
					lMessage := "Invoice Line Charge Mapping, Ship Operator ";
					tmpVoyage := _tran.getVoyage();
					if tmpVoyage &lt;&gt; null then
						combinationObj := tmpVoyage.myOperator;
						if tmpVoyage.myOperator &lt;&gt; null then
							lMessage := lMessage &amp; " " &amp; tmpVoyage.myOperator.code;
						endif;
					endif;
				endif;
			elseif aMap.myCombinationMappingObject.isKindOf(CM_CustomsAgent) then
				lMessage := "Invoice Line Charge Mapping, Customs Agent "&amp;_tran.customsAgentCode;
				if _tran.customsAgentCode &lt;&gt; null then
					combinationObj := app.myRoot.allCustomsAgents[_tran.customsAgentCode];
				endif;
				// 24094 add carrier
			elseif aMap.myCombinationMappingObject.isKindOf(CM_Carrier) then
				lMessage := "Invoice Line Charge Mapping, Carrier ";
				if _tran.myTrackedItem &lt;&gt; null then
					if _tran.myTrackedItem.carrier &lt;&gt; null then
						combinationObj := app.myRoot.allCarriers[_tran.myTrackedItem.carrier];
						lMessage := lMessage &amp; _tran.myTrackedItem.carrier;
					endif;
				endif;
			elseif aMap.myCombinationMappingObject.isKindOf(CM_Stevedore) then						// TFS 44554
				lMessage := "Invoice Line Charge Mapping, Stevedore " &amp; _tran.stevedoreCode;		// TFS 44554
				if _tran.stevedoreCode &lt;&gt; null then													// TFS 44554
					combinationObj := app.myRoot.allStevedores[_tran.stevedoreCode];				// TFS 44554
				endif;																				// TFS 44554

			elseif aMap.myCombinationMappingObject.isKindOf(CM_Debtor) then
				lMessage := "Invoice Line Charge Mapping, Debtor "&amp;aMap.chargeTypeCode;
				dt := _tran.allDebtorsByType[aMap.chargeTypeCode];
				
				combinationObj := dt;
			
			endif;
		endif;
	endif;
	
	if combinationObj &lt;&gt; null then
		app.invLog(lMessage, LogINFO.String);
	endif;
	
	return self.getDebtorTypeFromMapping(_invLine, _parentObj,combinationObj);
end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLineDesc"/>
        <Parameter name="_parentObj" type="CM_Object"/>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <ReturnType type="CM_DebtorType"/>
    </JadeMethod>
    <JadeMethod name="getDebtorTypeFromMapping" id="d6112b56-e2d9-4dc1-9a5f-3e7d847b2b1b">
        <source>getDebtorTypeFromMapping(_invLine : CM_InvoiceLineDesc; _parentObj : CM_Object; _combinationObj : CM_Object) : CM_DebtorType;
// ---------------------------------------------------------------------------
// Created:	21 April 2008 By Graeme Black cnwgb1
// 05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 18 Oct 2024 navlw1		JIRA-33107: Invoice Logging Use Levels
// ---------------------------------------------------------------------------
vars
	aMap : CM_InvoiceLineChargeMapping;
begin
	// no mappings do not check
	if self.allInvLineChargeMappings.isEmpty() then
		return null;
	endif;
	if _combinationObj = null then
		return null;
	endif;
		
	aMap := self.allInvLineChargeMappings[_invLine, _parentObj, _combinationObj];
	if aMap = null then
		return null;
	else
		if aMap.myDebtorType &lt;&gt; null then
			if app.canLogExtraDetail then				//05.10.2022 navma1 #52967
				app.invLog("Debtor type " &amp; aMap.myDebtorType.code &amp; " from invoice line charge mapping", LogINFO.String);
			endif;
		endif;
		return aMap.myDebtorType;
	endif;
end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLineDesc"/>
        <Parameter name="_parentObj" type="CM_Object"/>
        <Parameter name="_combinationObj" type="CM_Object"/>
        <ReturnType type="CM_DebtorType"/>
    </JadeMethod>
    <JadeMethod name="getDefaultFPE" id="ec6bb965-1dbe-4b5a-8e59-c3f58d01618f">
        <source>getDefaultFPE() : CM_FinancialPeriodEnd;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aFPE : CM_FinancialPeriodEnd;
begin
	foreach aFPE in self.allFinancialPeriods do
		if aFPE.isDefault then
			return aFPE;
		endif;
	endforeach;
	
	return null;
end;</source>
        <ReturnType type="CM_FinancialPeriodEnd"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="28e5c6cd-d715-4c0a-ae6d-22a7d1c9f7dd">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.code;
	else
		return '('&amp;self.code&amp;')  '&amp;self.mailingName;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="6eeef4c2-96b5-470d-8649-0cb44d124a33">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		27 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;
	tmpStr : String;
	idx, rows : Integer;
begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Name", DC_Label, 1, self);
	block.addNewItem(self.mailingName, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Code", DC_Label, 1, self);
	block.addNewItem(self.code, DC_Data, 1, self);

	rows := self.mailingAddress.size;
	if rows &gt; 0 then
		foreach idx in 1 to rows do
			tmpStr := tmpStr &amp; self.mailingAddress[idx] &amp; Cr;
		endforeach;
		block := _dataContainer.addNewBlock;
		block.addNewItem("Address", DC_Label, 1, self);
		block.addNewItem(tmpStr, DC_Data, 1, self);
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem("Email", DC_Label, 1, self);
	block.addNewItem(self.emailAddress, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Fax", DC_Label, 1, self);
	block.addNewItem(self.faxNumber, DC_Data, 1, self);


	block := _dataContainer.addNewBlock;
	block.addNewItem("Phone", DC_Label, 1, self);
	block.addNewItem(self.phoneNumber, DC_Data, 1, self);

	if self.allBankDetails &lt;&gt; null then
		rows := self.allBankDetails.size;
		tmpStr := "";
		if rows &gt; 0 then
			foreach idx in 1 to rows do
				tmpStr := tmpStr &amp; self.allBankDetails[idx] &amp; Cr;
			endforeach;
			block := _dataContainer.addNewBlock;
			block.addNewItem("Bank Details", DC_Label, 1, self);
			block.addNewItem(tmpStr, DC_Data, 1, self);
		endif;
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem("Suspended", DC_Label, 1, self);
	block.addNewItem(self.isSuspended.String, DC_Data, 1, self);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInvLineGroupAll" id="dc67ab44-b9b7-4af6-b5e4-f5023765eb68">
        <source>getInvLineGroupAll() : CM_TranMapInvoiceLineGroupType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 November 2012	cnwjre1	CCMS QNS 2177 get the 'all' CM_TranMapInvoiceLineGroupType instance

*/

vars
//	lgType	: CM_TranMapInvoiceLineGroupType;
begin
	return self.getInvLineGroupByType(TranMapInvLineGroupTypeAll);
	
