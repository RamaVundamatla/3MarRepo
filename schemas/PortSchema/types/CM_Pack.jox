    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="419f97d9-e7ec-4571-9a6e-2f41d3bc817f">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 11 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	containerId : String;
begin	
	//th2 PAR 11962 - whoever implemented user defined todo tasks failed to consider
	//the fact that user may associate any TI transaction type to create along with it.
	//For toDoTasks the _tiTransCntrl is always just type CMIF_TITransactionController
	if CMIF_PackTransController.hasInstance(_tiTransCntrl) then
		self.action := _tiTransCntrl.CMIF_PackTransController.action;
	endif;
	inheritMethod(_tiTransCntrl, _passport);

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="2cce8df7-d9a7-42ca-bcea-99e6e0ad3f49">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController ) updating;
//----------------------------------------------------------------
//	Created:	11 December 2003	by Jason Chapman  (cnwjc2)
// 08/09/2016   cnwma1  TFS #2589:PAR38142 STWR - TFS2239 " Double assign to release" -fix not OK
//----------------------------------------------------------------
vars
	bulkRelease : CM_BulkRelease;
	reserveSelection : CM_ReserveSelection;
	reserveDetail :     CM_ReserveDetail;
	reserveDetails : CM_ReserveDetailSet;
begin
	inheritMethod(pTI, _tiTransCntrl);

	//cnwjo3 par 20707
	self.location := pTI.locationId;
	if _tiTransCntrl.myBulkRelease &lt;&gt; null then   //08/09/2016 cnwma1 TFS #2589
		self.documentName :=_tiTransCntrl.myBulkRelease.code;
		self.documentContext :=  app.releaseRequestTypeEnumToString( _tiTransCntrl.myBulkRelease.type );
	endif;
	
	//30 Sep 2020	TFS 49598
	if _tiTransCntrl.myOriginatingLocation &lt;&gt; null then
		self.priorLocation := _tiTransCntrl.myOriginatingLocation.getFullId();
	endif;
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="setNewProperties" id="a5c05f22-fc46-4e52-a343-4ac197ff964b">
        <updating/>
        <source>setNewProperties(previousTrans: CM_TITransaction input) updating;

begin
	inheritMethod(previousTrans);

	previousTrans.totalVolume	:= self.totalVolume - self.otherTrackedItem.getMyTotalVolume;
	previousTrans.totalWeight	:= self.totalWeight - self.otherTrackedItem.totalWeight;
end;</source>
        <Parameter name="previousTrans" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOtherTrackedItem" id="e52d6452-7966-4259-a54d-7b9c9d9904a2">
        <updating/>
        <source>setOtherTrackedItem(pTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if pTI = null then
		return;
	endif;
	
	if not WarehouseIntegrated then
		// cnwsb1 18 Jul 2002: This is only required while the Port Otago
		// Warehouse module is not integrated.
		// Remove this null guard when the warehouse is integrated.
		self.otherTrackedItem			:= null;
		self.otherTrackedItemId			:= null;
		self.otherTrackedItemCargoType	:= null;
	else
		self.otherTrackedItem			:= pTI;
		self.otherTrackedItemId			:= pTI.id;
		self.otherTrackedItemCargoType	:= pTI.cargoType;
	endif;
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setOtherTrackedItemDummy" id="e4129652-c33b-40db-b1ec-1e547368f5b4">
        <updating/>
        <source>setOtherTrackedItemDummy(_otherTICargoType: Integer; _otherTIId: String) updating;
//--------------------------------------------------------------
// Created: 01 August 2002 By: cnwsb1
//--------------------------------------------------------------
vars

begin
	self.otherTrackedItemCargoType	:= _otherTICargoType;
	self.otherTrackedItemId			:= _otherTIId;
end;</source>
        <Parameter name="_otherTICargoType" type="Integer"/>
        <Parameter name="_otherTIId" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="3c453bb1-9c41-4db1-a2e3-d6e9b11de444">
        <updating/>
        <source>updateTI(_passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     27 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 26/09/2008	concms1	par 16130 - new parameter for clearPIN method
vars
	tmpTI	: CM_TrackedItem;
begin
	inheritMethod(_passport);			//cnwmc5 - 17 April 2015 - PAR 35925

	tmpTI := self.myTrackedItem;
	
	if tmpTI = null then
		return;
	endif;
	
	//cnwjo3 commented out for par 20271, if its not a child don't update pack/unpack datetime, wait for PackComplete
	//tmpTI.setPackedDT(self.dateTime);
	
	if self.action = ACTION_PACK_INTO then
		// this is the child TI so clear its PIN as
		// not valid for child TIs
	//	tmpTI.clearPIN(true);	// par 16130
		tmpTI.removePIN(true, false); // cnwrd1 par 22624 3.5.2010
		tmpTI.setPackedDT(self.dateTime);  //cnwjo3 par 20271, its a child, set pack/unpack datetime
		tmpTI.setUnpackedDT(null);
		
		//don't do this at this time.  cnwjo3
		//there really isn't any reason to clear out unpacked date
		//tmpTI.setUnpackedDT(null); //cnwjo3 par 20271, if child has been packed, its unpack time is nulled
	endif;

//	self.myTrackedItem.setLocationsForPacking();

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="e9f68799-fac5-4980-a894-ab1a0e8df27c">
        <source>validateForUpdate(pProxyTransaction: CM_TITransaction);
// ---------------------------------------------------------------------------
// Created:     24 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// You cannot edit any fields for this transaction type
	app.raiseCMException(ERR_INVALID_TRANS_EDIT, null, null);

	inheritMethod(pProxyTransaction);

end;</source>
        <Parameter name="pProxyTransaction" type="CM_TITransaction"/>
    </JadeMethod>
</Class>
