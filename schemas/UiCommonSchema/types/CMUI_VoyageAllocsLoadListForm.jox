    <JadeMethod name="deactivate" id="44b1407a-432a-4582-bce2-123bdfd6c8fb">
        <controlMethod name="Form::deactivate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>deactivate() updating;
// --------------------------------------------------------------------------------
// Created:		27 July 2010 by cnwjo3
//
// Purpose:		par 25114
//
vars
	idx : Integer;
	f : Form;
begin
	f := app.activeForm;
	if f = null then
		return;
	endif;	
	
	if f &lt;&gt; self.myParentForm and not f.isKindOf(CMUI_YAMaintVoyForm) then
		self.myParentForm.deactivate();
	endif;			//cnwas3 par 27769


end;</source>
    </JadeMethod>
    <JadeMethod name="deleteVoyAllocation" id="ae6acae9-ee2c-4b47-acf1-eb048220e8d8">
        <updating/>
        <source>deleteVoyAllocation() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars
	
	realAlloc	: CM_VoyageAllocation;
	result		: Integer;
	
begin
	
	if self.myVoyage = null then		
		return false;
	endif;
	
	realAlloc := self.myCurrentVoyageAllocation;		
											
	if realAlloc = null then
		return false;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteVoyageAllocation(realAlloc, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_load_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;	
	
epilog	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyAllocationALL" id="7a2fc981-4c86-4ca5-b7d2-eab969461bcd">
        <updating/>
        <source>deleteVoyAllocationALL() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars

	voyAllocations : CM_YardAllocationSet;
	idx : Integer;
	obj : Object;
	msg : String;
	result : Integer;
	
begin
	
	if self.myVoyage = null then		
		return false;
	endif;
	
	create voyAllocations transient;
	
	foreach idx in self.tblCCAllocation.fixedRows + 1 to self.tblCCAllocation.rows do //cnwas3 par26840
		obj := self.tblCCAllocation.accessRow(idx).itemObject;
		if obj = null then // PAR 23405
			continue;
		endif;
		voyAllocations.add(obj.CM_VoyageAllocation);
	endforeach;
	
	if voyAllocations.isEmpty() then
		return false;
	endif;
	
	msg := app.getErrorString2(CONFIRM_ALL_VOY_ALLOC_DELETE, app.getErrorString(Export), self.myVoyage.code);
	
	if app.msgBox( msg, app.getErrorString(Confirmed), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return true;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteVoyageAllocations(voyAllocations, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_load_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;	
	
epilog	
	delete voyAllocations;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
