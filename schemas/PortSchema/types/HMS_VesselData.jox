    <JadeMethod name="validate" id="2de8dc4e-ef40-4adf-94af-703026c7dfe4">
        <source>validate(_conflictManager : CMIF_HMS_ConflictsManager output; _passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 23 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	realObj : HMS_VesselData;
begin
	
	self.validateMe(_passport);			
	// Compare old and new data
	realObj := self.pxyGetRealObject();
	if realObj &lt;&gt; null then
		realObj.validateConflictsBeforeUpdate(_conflictManager, self);
	endif;

end;</source>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateBasicDimension" id="a229cad3-0167-4ed8-a9c0-7087d07e1827">
        <source>validateBasicDimension();
//--------------------------------------------------------------
//Created: 23 July 2003 By: cnwgd1
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------------------
vars

begin
	if app.myRoot.canDo( Mod_Harbour) then  //06.10.2017	cnwma1  TFS #7257
		// Check 'Length Overall' need to only do this for voyage commodity planning if we are not licensed for VTMIS 
		//18/3/08 epr 16214 also deleted the code block that validated LOA &gt; 0 because it is doing the same thing here
		if self.dim_LengthOverall &lt;= LOA_LowerLimit or self.dim_LengthOverall &gt; LOA_UpperLimit then
			app.raiseCMException3(VesselData_Dimension, 'Length Overall (LOA) (m)', LOA_LowerLimit.String, LOA_UpperLimit.String, null, null); 	
		endif;
	endif;

	// if not have HMS can still enter dimension, but do not have to. 
	// This is for Event Invoicing
	if not app.myRoot.canDo( Mod_Harbour) then
		return;
	endif;


	if self.dim_GrossRegTonnes &lt; GRT_LowerLimit or self.dim_GrossRegTonnes &gt; GRT_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Gross Reg Tonnes', GRT_LowerLimit.String, GRT_UpperLimit.String, null, null); 
	endif;
	if self.dim_NetRegTonnes &lt; GRT_LowerLimit or self.dim_NetRegTonnes &gt; GRT_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Net Reg Tonnes', GRT_LowerLimit.String, GRT_UpperLimit.String, null, null); 
	endif;

	// Check 'DeadWeight'
	if self.dim_DeadWeight &lt; DWT_LowerLimit or self.dim_DeadWeight &gt; DWT_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Dead Weight', DWT_LowerLimit.String, DWT_UpperLimit.String, null, null); 
	endif;

	// Check 'Beam'
	if self.dim_Beam &lt; BEAM_LowerLimit or self.dim_Beam &gt; BEAM_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Beam', BEAM_LowerLimit.String, BEAM_UpperLimit.String, null, null); 
	endif;

	// Check 'Aft Draft'
	if self.dim_DraftAft &lt; DRAFT_LowerLimit or self.dim_DraftAft &gt; DRAFT_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Draft Aft', DRAFT_LowerLimit.String, DRAFT_UpperLimit.String, null, null); 
	endif;
	
	 // Check 'Fore Draft'
	if self.dim_DraftFore &lt; DRAFT_LowerLimit or self.dim_DraftFore &gt; DRAFT_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Draft Fore', DRAFT_LowerLimit.String, DRAFT_UpperLimit.String, null, null); 
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateConflictsBeforeUpdate" id="ecdfb675-5075-4a46-8083-d6e8c03c05f8">
        <source>validateConflictsBeforeUpdate(_conflictManager: CMIF_HMS_ConflictsManager output;_pxyVesselData : HMS_VesselData);
//--------------------------------------------------------------
//Created: 22 July 2003 By: cnwgd1
//--------------------------------------------------------------
begin
	if self.myVessel.isToBeNamed() then
		return;
	endif;
	
	create _conflictManager transient;
	
	if self.dim_LengthOverall &lt;&gt; _pxyVesselData.dim_LengthOverall then
		// Ship length has been changed
		// Run validation on ship length changes
		_conflictManager.allValidationTypes.add(ValidateShipPosn);
	endif;

	if self.dim_DraftAft &lt;&gt; _pxyVesselData.dim_DraftAft
	or self.dim_DraftFore &lt;&gt; _pxyVesselData.dim_DraftFore
	then
		// Ship max draft has been changed
		// Run validation on ship draft changes
		_conflictManager.allValidationTypes.add(ValidateShipDraft);
	endif;

	if (not _conflictManager.allValidationTypes.isEmpty()) then
		_conflictManager.myChangedVessel := self.myVessel;
		// Build a collection of movements to validate
		app.myRoot.validateVoyageConflicts(_conflictManager);
	endif;
	
	if (not _conflictManager.allCMIFConflicts.isEmpty) then
		app.raiseCMWarning(HMSMovementConflict, null, null, self.myVessel);
	else
		delete _conflictManager;
		_conflictManager	:=	null;
	endif;
end;</source>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_pxyVesselData" type="HMS_VesselData"/>
    </JadeMethod>
    <JadeMethod name="validateDistances" id="c4d62660-21c6-4789-8807-e74a0642d76d">
        <source>validateDistances();
//--------------------------------------------------------------
//Created: 23 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.dist_BridgeToBow &lt; Distance_LowerLimit or self.dist_BridgeToBow &gt; Distance_UpperLimit then
		app.raiseCMException3(VesselData_Distance, 'Bridge To Bow', Distance_LowerLimit.String, Distance_UpperLimit.String, null, null); 
	endif;

	// Bridge to Stern
	if self.dist_BridgeToStern &lt; Distance_LowerLimit or self.dist_BridgeToBow &gt; Distance_UpperLimit then
		app.raiseCMException3(VesselData_Distance, 'Bridge To Stern', Distance_LowerLimit.String, Distance_UpperLimit.String, null, null); 
	endif;	

	// Bow to Fwd Container Bay
	if self.dist_BowToFwdContainer &lt; Distance_LowerLimit or self.dist_BridgeToBow &gt; Distance_UpperLimit then
		app.raiseCMException3(VesselData_Distance, 'Bow To Fwd Container', Distance_LowerLimit.String, Distance_UpperLimit.String,null, null); 
	endif;
		
	// Stern to Aft Container Bay
	if self.dist_SternToAftContainer &lt; Distance_LowerLimit or self.dist_BridgeToBow &gt; Distance_UpperLimit then
		app.raiseCMException3(VesselData_Distance, 'Stern To Aft Container', Distance_LowerLimit.String, Distance_UpperLimit.String,null, null); 
	endif;
		
	// Stern to Bunker Point
	if self.dist_SternToBunker &lt; Distance_LowerLimit or self.dist_BridgeToBow &gt; Distance_UpperLimit then
		app.raiseCMException3(VesselData_Distance, 'Stern To Bunker', Distance_LowerLimit.String, Distance_UpperLimit.String, null,null); 
	endif;		

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="61aab640-606c-4b38-969a-b6ec1acd7390">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 23 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpData		: HMS_VesselDataHarbour;
	oa			: ObjectArray;
	obj			: Object;
begin
	inheritMethod(_passport);
	
	if self.myRoot = null then
	//	app.raiseCMException1(REQUIRED_FIELD , 'Harbour Root', null, null );
		app.raiseCMException(Input_required_field_harbRoot, null, null ); // cnwdb2	PAR 35364
	endif;

	if _passport.hasErrors() then
		return;
	endif;			
	
	self.validateBasicDimension();
	self.validateDistances();
	
	// Aug 2012 cnwjre1 after load of Messina vessel def: can get null-valued content in allVesselDataForHarbour - find and remove it here
	create oa transient;
	foreach tmpData in self.allVesselDataForHarbour do
		if tmpData.myHarbour = null and
		   tmpData.myLineCompany = null and
		   tmpData.myShippingAgent = null and
		   tmpData.myTidalClassArrival = null /* and  //03 Apr 2017	NDL	TFS 3941
		   tmpData.myTidalClassArrival = null and
		   tmpData.myTidalClassDeparture = null */
		   then
			oa.add(tmpData);
		endif;
	endforeach;
	foreach obj in oa do
		tmpData := obj.HMS_VesselDataHarbour;
		self.allVesselDataForHarbour.remove(tmpData);
		delete tmpData; // 13 Feb 2020 NDL: Found in testing - leaking transients.
	endforeach;
	
	foreach tmpData in self.allVesselDataForHarbour do
		tmpData.validateMe(_passport);
	endforeach;
epilog
	delete oa;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
