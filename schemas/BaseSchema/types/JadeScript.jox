    <JadeMethod name="cnwdad1_MelbourneCup_Draw" id="50547f0b-4779-4375-b75f-80eed1bbbae8">
        <source>cnwdad1_MelbourneCup_Draw(	pAllHorses:StringArray input;
							pAllEntries:StringArray input;
							pSweepValue:Integer;
							pSweepCount:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		01 November 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	FIRST_PLACE		: Integer = 60;
	SECOND_PLACE	: Integer = 25;
	THIRD_PLACE		: Integer = 10;
	LAST_PLACE		: Integer = 5;
	
vars
	horseName		: String;
	entryName		: String;
	entryIndex		: Integer;
	totalPool		: Integer;
	prize1			: Decimal[12,2];
	prize2			: Decimal[12,2];
	prize3			: Decimal[12,2];
	prizeL			: Decimal[12,2];
	
begin
	write CrLf &amp; "$" &amp; pSweepValue.String &amp; " Dollar Sweep (" &amp; pSweepCount.String &amp; ")";
	write "-------------------";
	pAllHorses.cnEcScramble();
	pAllEntries.cnEcSort(false);
	entryIndex	:=	0;
	
	foreach entryName in pAllEntries do
		entryIndex	:=	entryIndex + 1;
		horseName	:=	pAllHorses[entryIndex];
		
		write entryIndex.padLeadingWith(" ", 2) &amp; ". " &amp; entryName &amp; " - " &amp; horseName;
	endforeach;
	
	totalPool	:=	pAllEntries.size() * pSweepValue;
	prize1		:=	totalPool * FIRST_PLACE / 100;
	prize2		:=	totalPool * SECOND_PLACE / 100;
	prize3		:=	totalPool * THIRD_PLACE / 100;
	prizeL		:=	totalPool * LAST_PLACE / 100;
	
	write CrLf &amp; "$" &amp; pSweepValue.String &amp; " Pool " &amp; pSweepCount.String &amp; ": $" &amp; (totalPool).cnEcNumberFormat() &amp;
		" - " &amp; "1st $" &amp; prize1.cnEcRoundToTenCents().numberFormat() &amp;
		", 2nd $" &amp; prize2.cnEcRoundToTenCents().numberFormat() &amp;
		", 3rd $" &amp; prize3.cnEcRoundToTenCents().numberFormat() &amp;
		", Last $" &amp; prizeL.cnEcRoundToTenCents().numberFormat();
end;</source>
        <access>protected</access>
        <Parameter name="pAllHorses" type="StringArray" usage="input"/>
        <Parameter name="pAllEntries" type="StringArray" usage="input"/>
        <Parameter name="pSweepValue" type="Integer"/>
        <Parameter name="pSweepCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnwdad1_MelbourneCup_Sweep" id="6d0d069c-92ee-445f-b967-75e78486b104">
        <source>cnwdad1_MelbourneCup_Sweep() protected;
// --------------------------------------------------------------------------------
// Created:		01 November 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ENTRANTS			: Integer = 22;
	
vars
	allHorses			: StringArray;
	sweep5				: StringArray;
	sweep2				: StringArray;
	allEntries			: StringArray;
	entryName			: String;
	horseCount			: Integer;
	sweepCount			: Integer;
	entryIndex			: Integer;
	maxSweepSize		: Integer;
	
begin
	create allHorses transient;
	create sweep5 transient;
	create sweep2 transient;
	create allEntries transient;
	
	allHorses.add("#1 TAWQEET (USA) 6h (3) (57.0) ($51.00) D DUNN");
	allHorses.add("#2 BLUE MONDAY (GB) 7g (13) (56.0) ($31.00) N RAWILLER");
	allHorses.add("#3 BLUTIGEROO 6g (11) (55.5) ($31.00) L NOLEN");
	//allHorses.add("#4 GALLIC (NZ) 8g (24) (55.5) ($21.00) S W ARNOLD");
	allHorses.add("#5 RAILINGS 6g (17) (55.5) ($101.00) G CHILDS");
	allHorses.add("#6 EFFICIENT (NZ) 4g (10) (54.5) ($18.00) M RODD");
	allHorses.add("#7 MAYBE BETTER 5g (7) (54.0) ($16.00) C BROWN");
	allHorses.add("#8 TUNGSTEN STRIKE (USA) 7g (2) (54.0) ($31.00) D HOLLAND");
	allHorses.add("#9 ZIPPING 6g (21) (54.0) ($8.50) D NIKOLIC");
	allHorses.add("#10 BLACK TOM 7h (20) (53.5) ($151.00) P A HALL");
	allHorses.add("#11 MASTER O'REILLY (NZ) 5g (17) (53.5) ($5.00) V DURIC");
	allHorses.add("#12 PURPLE MOON (IRE) 5g (14) (53.5) ($8.00) D OLIVER");
	allHorses.add("#13 LAZER SHARP (NZ) 4g (15) (52.5) ($51.00) B SHINN");
	allHorses.add("#14 ON A JEUNE 7g (4) (52.5) ($31.00) K MCEVOY");
	allHorses.add("#15 SCENIC SHOT 5g (18) (52.5) ($101.00) M J ZAHRA");
	allHorses.add("#16 SARRERA 7g (22) (52.0) ($81.00) S MURPHY");
	allHorses.add("#17 SCULPTOR (NZ) 5h (8) (52.0) ($21.00) L CROPP");
	allHorses.add("#18 DOLPHIN JO 5g (1) (51.5) ($61.00) C LINDOP");
	allHorses.add("#19 DOURO VALLEY 6g (12) (51.5) ($41.00) J M WINKS");
	allHorses.add("#20 SIRMIONE 4g (19) (51.5) ($12.00) P MERTENS");
	//allHorses.add("#21 THE FUZZ (NZ) 5g (11) (51.5) ($26.00) C WILLIAMS");
	allHorses.add("#22 ESKIMO QUEEN (NZ) 4m (5) (51.0) ($26.00) C NEWITT");
	allHorses.add("#23 PRINCESS COUP 4m (9) (51.0) ($12.00) N G HARRIS");
	allHorses.add("#24 MAHLER (GB) 4h (6) (50.5) ($10.00) S BASTER");
	
	horseCount	:=	allHorses.size();
	
	// $5 sweep entries.
	
	sweep5.add("Andrew Hawker");
 	sweep5.add("Darrell Duniam");
	//sweep5.add("Darrell Duniam");
	sweep5.add("David Blair");
	sweep5.add("David Blair");
	sweep5.add("Jeff South");
	sweep5.add("John Ascroft");
	sweep5.add("Judith West");
	sweep5.add("Kevin Callaghan");
	sweep5.add("Kevin Douglas");
	sweep5.add("Kevin Douglas");
	sweep5.add("Mary Harvey");
	sweep5.add("Lucy Maley");
	sweep5.add("Mitch");
	sweep5.add("Mitch");
	sweep5.add("Paul Ainsworth");
	sweep5.add("Peter Smith");
	sweep5.add("Phil Camp");
	//sweep5.add("Phil Camp");
	sweep5.add("Richard Mitchell");
	sweep5.add("Richard Mitchell");
	sweep5.add("Selwyn Bankier");
	sweep5.add("Steve Foster");
	sweep5.add("Victor Paul");
	
	// $2 sweep entries.
	
	sweep2.add("Andrew Hawker");
	sweep2.add("Darrell Duniam");
	//sweep2.add("Darrell Duniam");
	//sweep2.add("Darrell Duniam");
	sweep2.add("David Blair");
	sweep2.add("Jeff South");
	sweep2.add("John Ascroft");
	sweep2.add("Kevin Callaghan");
	sweep2.add("Lucy Maley");
	sweep2.add("Lucy Maley");
	sweep2.add("Lynne Lipinski");
	sweep2.add("Lynne Lipinski");
	sweep2.add("Mike Maynard");
	sweep2.add("Mitch");
	sweep2.add("Mitch");
	sweep2.add("Nancy Kane");
	sweep2.add("Paul Ainsworth");
	sweep2.add("Paul Ryder");
	sweep2.add("Phil Camp");
	sweep2.add("Phil Camp");
	sweep2.add("Phil Camp");
	sweep2.add("Selwyn Bankier");
	sweep2.add("Shirley-Ann Griffiths");
	sweep2.add("Steve Foster");
	
	sweep2.add("Anthony Woodgate");
	sweep2.add("Darrell Duniam");
	//sweep2.add("Darrell Duniam");
	//sweep2.add("Darrell Duniam");
	sweep2.add("David Blair");
	sweep2.add("Greg Thompson");
	sweep2.add("Karen Morris");
	sweep2.add("Lynne Lipinski");
	sweep2.add("Lucy Maley");
	sweep2.add("Lucy Maley");
	sweep2.add("Marise Wason");
	sweep2.add("Mary Harvey");
	sweep2.add("Maureen Callaghan");
	sweep2.add("Mike Maynard");
	sweep2.add("Mitch");
	sweep2.add("Mitch");
	sweep2.add("Mitch");
	sweep2.add("Patricia Mattsen");
	sweep2.add("Paul Ainsworth");
	sweep2.add("Phil Camp");
	sweep2.add("Phil Camp");
	sweep2.add("Ray Hollis");
	sweep2.add("Shirley-Ann Griffiths");
	sweep2.add("Velinda Raines");
	
	sweepCount		:=	0;
	entryIndex		:=	0;
	
	if sweep5.size() &lt;= horseCount then
		maxSweepSize	:=	horseCount;
	else
		maxSweepSize	:=	ENTRANTS;
	endif;
	
	allEntries.clear();
	
	foreach entryName in sweep5 do
		allEntries.add(entryName);
		entryIndex	:=	entryIndex + 1;
		
		if entryIndex = maxSweepSize then
			sweepCount	:=	sweepCount + 1;
			self.cnwdad1_MelbourneCup_Draw(allHorses, allEntries, 5, sweepCount);
			allEntries.clear();
			entryIndex	:=	0;
		endif;
	endforeach;
	
	if allEntries.cnEcIsNotEmpty() then
		sweepCount	:=	sweepCount + 1;
		self.cnwdad1_MelbourneCup_Draw(allHorses, allEntries, 5, sweepCount);
	endif;
	
	sweepCount		:=	0;
	entryIndex		:=	0;
	
	if sweep2.size() &lt;= horseCount then
		maxSweepSize	:=	horseCount;
	else
		maxSweepSize	:=	ENTRANTS;
	endif;
	
	allEntries.clear();
	
	foreach entryName in sweep2 do
		allEntries.add(entryName);
		entryIndex	:=	entryIndex + 1;
		
		if entryIndex = maxSweepSize then
			sweepCount	:=	sweepCount + 1;
			self.cnwdad1_MelbourneCup_Draw(allHorses, allEntries, 2, sweepCount);
			allEntries.clear();
			entryIndex	:=	0;
		endif;
	endforeach;
	
	if allEntries.cnEcIsNotEmpty() then
		sweepCount	:=	sweepCount + 1;
		self.cnwdad1_MelbourneCup_Draw(allHorses, allEntries, 2, sweepCount);
	endif;
epilog
	delete allHorses;
	delete sweep5;
	delete sweep2;
	delete allEntries;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Processes" id="4ff02c65-ed0f-4a93-a3e9-89d70552dc46">
        <source>cnwdad1_Processes();
// --------------------------------------------------------------------------------
// Created:		21 June 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	nodeObj		: Node;
	processObj	: Process;
	description	: String;
	
begin
	write "System.: " &amp; system.name;
	
	foreach nodeObj in system.nodes do
		if nodeObj.isServerNode then
			description	:=	"(server)";
write "server app";
		else
			if nodeObj.isApplicationServer then
				description	:=	"(application server)";
			else
				description	:=	"(client)";
			endif;
		endif;
		
		write "Node...: " &amp; nodeObj.name &amp; " " &amp; description;
		
		foreach processObj in nodeObj.processes do
			if processObj.isUsingThinClient then
				description	:=	"(thin client,";
			else
				description	:=	"(standard client,";
			endif;
			
			description	:=	description	&amp; " app=" &amp; processObj.persistentApp.name &amp; ")";
			
			write "Process: " &amp; nodeObj.name &amp; "." &amp; processObj.userCode &amp; " " &amp; description;
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Releases_Purge" id="2b2838b7-bff0-4bba-9763-64a4b64f4895">
        <source>cnwdad1_Releases_Purge();
// --------------------------------------------------------------------------------
// Created:		19 August 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	baseRootObj	: CnEcBaseRoot;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	baseRootObj	:=	CnEcBaseRoot.firstInstance;
	beginTransaction;
	
	baseRootObj.allReleaseHistoryMasters.purge();
	baseRootObj.setCurrentBaseSchemaRelease(null);
	
	commitTransaction;
epilog
	write "Releases purge completed in " &amp; startTime.cnEcClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_ReportMethodReferences" id="84e79483-f42a-4b3e-af15-ab61c48e6a9c">
        <source>cnwdad1_ReportMethodReferences(pTheSchema:Schema; pTheClass:Class; pMethodName:String);
// --------------------------------------------------------------------------------
// Created:		28 November 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	methodObj	: Method;
	allMethods	: MethodSet;
	callerObj	: Method;
	
begin
	methodObj	:=	pTheClass.getMethod(pMethodName);
	
	if methodObj = null then
		write "&lt;&lt;&lt;" &amp; pTheClass.name &amp; "::" &amp; pMethodName &amp; "  NOT FOUND&gt;&gt;&gt;";
		return;
	endif;
	
	create allMethods transient;
	
	if methodObj.hasSenders() then
		methodObj.getMethodRefs(allMethods);
		
		if allMethods.isEmpty() then
			return;
		else
			write "-------------------------------------------------";
			write "References to " &amp; pTheClass.name &amp; "::" &amp; pMethodName &amp; CrLf;
			
			foreach callerObj in allMethods do
				if callerObj.getSchema().name = pTheSchema.name then
					write "--&gt;" &amp; callerObj.getSchemaType.name &amp; "::" &amp; callerObj.name;
				endif;
			endforeach;
		endif;
	endif;
epilog
	delete allMethods;
end;</source>
        <Parameter name="pTheSchema" type="Schema"/>
        <Parameter name="pTheClass" type="Class"/>
        <Parameter name="pMethodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnwdad1_SetGlobalConstantText" id="073d9380-9874-4bc3-a4ee-5ce0f473a5b4">
        <source>cnwdad1_SetGlobalConstantText();
// -----------------------------------------------------------------------------
// Created:		24 November 2001 by cnwdad1
