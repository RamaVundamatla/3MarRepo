    <JadeMethod name="translateForm" id="10f9628e-6e8c-4396-b92c-2e87ffedbee6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 February 2023 08:13:56.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017248, locale);
	btnCancel.translateCaption(Xlat_0000001, locale);
	btnNext.translateCaption(Xlat_0000002, locale);
	btnSave.translateCaption(Xlat_0000003, locale);
	optDocket.translateCaption(Xlat_0000004, locale);
	optLocation.translateCaption(Xlat_0000005, locale);
	optSingleItem.translateCaption(Xlat_0000006, locale);
end;</source>
    </JadeMethod>
