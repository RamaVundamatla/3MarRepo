    <JadeMethod name="create" id="3c280421-fb93-4868-9ea4-e9db2625becf">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.permissionView  := PmGCVoyageOpsView;
	self.permissionMaint := PmGCVoyageOpsMaint;
	self.helpFileName := HelpFile_Voyage;
	//self.mnuHideShowInfo.caption := $Hide_Additional_Info;	
