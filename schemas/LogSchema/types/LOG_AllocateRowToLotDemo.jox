    <JadeMethod name="translateForm" id="6c89c497-7dbd-4b03-9bc9-de3571dbed6c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006306, locale);
	btnCancel.translateCaption(Xlat_0002324, locale);
	btnNext_1.translateCaption(Xlat_0002325, locale);
	btnSave.translateCaption(Xlat_0002329, locale);
	btnSave_1.translateCaption(Xlat_0002327, locale);
	btnSave_2.translateCaption(Xlat_0002326, locale);
	btnSave_3.translateCaption(Xlat_0002328, locale);
	lblAllocated.translateCaption(Xlat_0002323, locale);
	lblAllocated_1.translateCaption(Xlat_0002322, locale);
end;</source>
    </JadeMethod>
</GUIClass>
