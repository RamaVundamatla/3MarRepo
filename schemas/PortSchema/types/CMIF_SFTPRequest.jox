    <JadeMethod name="convertMthNameToNumber" id="292d0717-e2d6-485d-96a3-bbde0cb6fba4">
        <source>convertMthNameToNumber(_mthName : String) : Integer;
//
// 24 Oct 2019	jlgrs1	TFS 46087 JMT implement SFTP.
//
constants
	Jan = "JAN";
	Feb = "FEB";
	Mar = "MAR";
	Apr = "APR";
	May = "MAY";
	Jun = "JUN";
	Jul = "JUL";
	Aug = "AUG";
	Sep = "SEP";
	Oct = "OCT";
	Nov = "NOV";
	Dec = "DEC";
vars
	str : String;
	num : Integer;
begin
	str := _mthName.toUpper;
	if str = Jan then
		num := 1;
	elseif str = Feb then
		num := 2;
	elseif str = Mar then
		num := 3;
	elseif str = Apr then
		num := 4;
	elseif str = May then
		num := 5;
	elseif str = Jun then
		num := 6;
	elseif str = Jul then
		num := 7;
	elseif str = Aug then
		num := 8;
	elseif str = Sep then
		num := 9;
	elseif str = Oct then
		num := 10;
	elseif str = Nov then
		num := 11;
	elseif str = Dec then
		num := 12;
	endif;
	return num;
epilog

end;</source>
        <Parameter name="_mthName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="e59039f9-c542-4c03-a32b-56ce650342c3">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05 September 2022	navsp1		Initial creation TFS#54620 - CNWSSH 1.0.0.17 Library update
//
vars
	logLevel : Integer;
	result : String;
begin
	logLevel := self.getCNWSSHLogLevel();
	if logLevel &lt;&gt; -1 then
		self.emSetLoggingVerbosityLevel(logLevel,result);
		app.writeLog("CNWSSH Log result "&amp;result,LogDEBUG);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="7f5ff10f-9887-470c-978b-d5e37ab0ed57">
