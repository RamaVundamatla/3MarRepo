    <DbClassMap file="query"/>
    <JadeMethod name="create" id="4b00d0de-d7e8-4db1-bc42-b7d873c5c31f">
        <updating/>
        <source>create() updating;
// Feb 2012 CCMS 1262 Transaction Enquiry
vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="43a13455-7353-4ff4-a6c5-a1d6f14fb0af">
        <source>getKeyLengthForXTABDictionary(): Integer;
//  CCMS 1262 feb 2012 transaction enquiry and selector queries
vars

begin
	return CM_EventType::name.length;
end;</source>
