    <JadeMethod name="getID" id="780aa75c-872a-4823-9e88-2e7605a0cf68">
        <source>getID(): String;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	if (not global.isValidObject(self.myTrackedItem)) then 
		// this can happen when auto-planning a receival and
		// the item is deleted when trying to raise an alert
		return null;
	endif;

	return self.myTrackedItem.id;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
