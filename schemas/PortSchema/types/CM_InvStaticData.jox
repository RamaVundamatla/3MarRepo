    <JadeMethod name="setStaticFields" id="dc677b84-8128-4310-a855-45689b348c5b">
        <updating/>
        <source>setStaticFields(_bankName : String; _debtorName : String; _debtorLongName : String; _invoiceTypeDesc : String; _details : String; _currencyDescription: String;  _localeDescription : String; _contractIds : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2024	navra1	Initial creation for TFS 57933 Invoice and Invoice Line details that need to be static &lt;&lt;54090&gt;&gt;

*/

vars

begin
	self.bankName := _bankName[1:30];	// ### TFS BUG 65937 02SEP2024 NAVAB1
	self.debtorName := _debtorName[1:100];	// ### TFS BUG 65937 02SEP2024 NAVAB1
	self.debtorLongName := _debtorLongName;
	self.invoiceTypeDesc := _invoiceTypeDesc[1:30];	// ### TFS BUG 65937 02SEP2024 NAVAB1
	self.details := _details[1:500];	// ### TFS BUG 65937 02SEP2024 NAVAB1
	self.currencyDescription := _currencyDescription[1:200];	// ### TFS BUG 65937 02SEP2024 NAVAB1
	self.localeDescription:= _localeDescription[1:30];	// ### TFS BUG 65937 02SEP2024 NAVAB1
	self.contractIds := _contractIds;

epilog

end;</source>
        <Parameter name="_bankName" type="String"/>
        <Parameter name="_debtorName" type="String"/>
        <Parameter name="_debtorLongName" type="String"/>
        <Parameter name="_invoiceTypeDesc" type="String"/>
        <Parameter name="_details" type="String"/>
        <Parameter name="_currencyDescription" type="String"/>
        <Parameter name="_localeDescription" type="String"/>
        <Parameter name="_contractIds" type="String"/>
    </JadeMethod>
</Class>
