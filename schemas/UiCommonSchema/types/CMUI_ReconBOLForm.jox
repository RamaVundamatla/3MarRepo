    <JadeMethod name="setCmbBOL" id="181b0044-fbec-48cc-a9b7-8abfd2af1e15">
        <updating/>
        <source>setCmbBOL()updating, protected;
//21 January 2010	cnwml2


vars
	bol : CM_BOL;
begin
	self.cmbBOL.clear();
		foreach bol in self.myTerminal.allBOLsReceivedByTypeNumberDT do
		if bol.myTerminal = self.myTerminal then
			if bol.CM_BOLIn.myVoyage = self.myVoyage then
				self.cmbBOL.addItemObject(bol.number, bol);
			endif;
			if bol = self.myBOL then
				self.cmbBOL.setIndexFromObject(bol);
			endif;
		endif;
	endforeach;
	self.loadData();


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
