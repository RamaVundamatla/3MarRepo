    <JadeMethod name="getAllCriteriaValues" id="7479646a-2b30-4b4b-8291-5a8d755cf5e5">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs: CM_ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 June 2023	navpw1	Initial creation TFS: 58429 (58517)

*/

begin
	app.myRoot.allSortingMethods.copy(_allCriteriaValues);
	
end;</source>
