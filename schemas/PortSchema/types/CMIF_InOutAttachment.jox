    <JadeMethod name="setFromMasterObject" id="ec1efbb2-125a-4b19-9c0d-e234f6e602d5">
        <updating/>
        <source>setFromMasterObject(_cmif: SelfType) updating;
//----------------------------------------------------------------
//	Created:	07 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_cmif);

	self.id := _cmif.id;
	self.state := _cmif.state;
	self.bolType := _cmif.bolType;
	self.voyageCode := _cmif.voyageCode;
	self.imExStatus := _cmif.imExStatus;
	self.operatorCode := _cmif.operatorCode;
	
