    <JadeMethod name="loadUserInternal" id="30f822da-ebe5-4e05-af17-086d73e9353a">
        <source>loadUserInternal(_userInternalProxy:CM_User io) :Boolean protected;

vars
	realObject, proxyObject: CM_User;
	error: CM_Error;
	countError,countOK: Integer;
begin
	if _userInternalProxy.code.toUpper = SUPERUSER_Str or
	   _userInternalProxy.code.toUpper = "ADMIN" then
		return true;
	endif;
	realObject := app.myRoot.allUsers[_userInternalProxy.code];
	if realObject &lt;&gt; null then
		beginTransaction;
		delete realObject;
		realObject := null;
		commitTransaction;
	endif;
	if realObject = null then
		app.myTrxCA.trxCreateUser(_userInternalProxy, "password", realObject, app.myPassport);
//		realObject.setPropertyValue(CM_User::currentPassword.name, _userInternalProxy.currentPassword);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_userInternalProxy.code&amp;" ERROR: "&amp;"User already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_userInternalProxy.code&amp;" WARNING: "&amp;error.text,0);
			write(class.name&amp;'::'&amp;method.name&amp;' '&amp;_userInternalProxy.code&amp;" WARNING: "&amp;error.text);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_userInternalProxy.code&amp;" ERROR: "&amp;error.text,0);
			write(class.name&amp;'::'&amp;method.name&amp;' '&amp;_userInternalProxy.code&amp;" ERROR: "&amp;error.text);
		endforeach;
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_userInternalProxy" type="CM_User" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
