        <source>selectAll() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2009	cnwjk3	Initial creation

*/

vars

begin
	self.selStart := 0;
	self.selLength := -1;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="stretchHeight" id="9b0092e0-1402-446f-a68e-2e06515e5a5e">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>stretchHeight(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set and _value then
		if lockBottom then
			lockBottom := false;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="stretchWidth" id="4558d5ce-38b7-4e6b-9894-ef5a1da8b022">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>stretchWidth(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

    if set and _value then
    	if lockRight then
    		lockRight := false;
    	endif;
   	endif;
   	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="text" id="04698c26-c740-4ffa-bb78-bacb083a1f41">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>text(set: Boolean; value: String io) updating, mapping, clientExecution;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 May 2007	cnwer1	Initial creation - PAR#xxxx
07/06/2011	cnwmh5	#27657 - Add test for isInPainter on set
*/
vars

begin
	if set and not self.isInPainter() then
		if (value = null and self.showNullAsZero)
		or (self.decimals &gt; 0 and value &lt;&gt; null)
		then
			if  self.dataType = TextBox.DataType_Numeric then
				value:= value.asDecimalJMT().roundedTo(decimals).asStringJMT;
			elseif self.dataType = TextBox.DataType_SignedNumeric then
				value:= value.asRealJMT.roundedTo(decimals).asStringJMT;
			endif;
		endif;
	endif;

epilog
	inheritMethod(set, value);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
