    <JadeMethod name="getJobBoundary" id="826ef71f-ffa0-46be-ada1-85c0c4411631">
        <source>getJobBoundary(_isLoad : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:     30 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRequest,
	otherRequest	: CM_SlotRequest;
	theJob			: CM_Job;
	otherSlot		: CM_SlotController;
	rtnValue	: Integer;
	
begin

	if _isLoad then
		theRequest := self.mySlotRequestLoad;
	else
		theRequest := self.mySlotRequestDischarge;
	endif;
	
	if theRequest = null then
		return rtnValue;
	endif;
	theJob := theRequest.myJob;
	if theJob = null then
		return rtnValue;
	endif;
	
	otherSlot := self.myOverheadSlot;
	if otherSlot &lt;&gt; null then
		if (not otherSlot.isJobTheSame(_isLoad, theJob)) then
			rtnValue := rtnValue + BoundaryOver;
		endif;
	else
		rtnValue := rtnValue + BoundaryOver;
	endif;

	otherSlot := self.myUnderfootSlot;
	if otherSlot &lt;&gt; null then
		if (not otherSlot.isJobTheSame(_isLoad, theJob)) then
			rtnValue := rtnValue + BoundaryUnder;
		endif;
	else
		rtnValue := rtnValue + BoundaryUnder;
	endif;

	otherSlot := self.myPortSlot;
	if otherSlot &lt;&gt; null then
		if (not otherSlot.isJobTheSame(_isLoad, theJob)) then
			rtnValue := rtnValue + BoundaryLeft;
		endif;
	else
		rtnValue := rtnValue + BoundaryLeft;
	endif;

	otherSlot := self.myStarboardSlot;
	if otherSlot &lt;&gt; null then
		if (not otherSlot.isJobTheSame(_isLoad, theJob)) then
			rtnValue := rtnValue + BoundaryRight;
		endif;
	else
		rtnValue := rtnValue + BoundaryRight;
	endif;
	
	return rtnValue;

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getJobSheetCode" id="6f9c5230-7dd6-40dd-856b-deb003176f09">
        <source>getJobSheetCode(_isLoad : Boolean) : String;
/*
Purpose:			

Date		Who		Reason
16 December 2021	navab1	TFS 51855
*/

vars
	slotreq : CM_SlotRequest;
	job : CM_Job;
	
begin
	if _isLoad then
		slotreq := self.mySlotRequestLoad;
	else
		slotreq := self.mySlotRequestDischarge;
	endif;
	
	if slotreq &lt;&gt; null then
		job := slotreq.myJob;
		if job &lt;&gt; null then
			return job.CM_VoyageJob.craneId;
		endif;
	endif;

	return "";
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
