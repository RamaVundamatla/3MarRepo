    <JadeMethod name="kaBarrierCode" id="84f9aeab-5a9e-4294-a8af-24d42e59e7b5">
        <source>kaBarrierCode() : WS_Response;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 31 May 2023
TFS#		: 56398
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/


vars
	response : WS_Response;
	request : WS_BarrierCodeRequest;	
	webServiceService : MasterTerminalAPIService;
	barrierDateTime :TimeStampOffset;
	completedOK : Boolean;
begin

	app.initialize();
	
	create webServiceService transient;
	
	app.myPassport.setMyUserFromCode("jlika1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["JBL"]);	

	create request transient;
	create response transient;
			
	request.setPropertyValue("barrierCode","98268");
	request.setPropertyValue("barrierDateTime",barrierDateTime);
	request.setPropertyValue("truckLicense","REG888");
	
	response := webServiceService.putBarrierCode(request);
	
	if response.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	
epilog

	delete response;
	delete request;
	delete webServiceService;

end;</source>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="kaGateCheckInspection" id="0502be92-f60c-4063-a428-1f7dee89008f">
        <source>kaGateCheckInspection() : WS_Response;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 31 May 2023
TFS#		: 56398
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/


vars
	response : WS_Response;
	request : WS_GateCheckRequest;	
	webServiceService : MasterTerminalAPIService;
	barrierDateTime :TimeStampOffset;
	completedOK : Boolean;
begin

	app.initialize();
	
	create webServiceService transient;
	
	app.myPassport.setMyUserFromCode("jlika1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["JBL"]);	

	create request transient;
	create response transient;
			
	request.setPropertyValue("truckLicense","REG888");
	request.setPropertyValue("checkType","Gate IN");
	request.setPropertyValue("status","Completed");
	request.setPropertyValue("checkDateTime",barrierDateTime);
	
	response := webServiceService.putGateCheck(request);
	
	if response.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	
epilog

	delete response;
	delete request;
	delete webServiceService;

end;</source>
        <ReturnType type="WS_Response"/>
