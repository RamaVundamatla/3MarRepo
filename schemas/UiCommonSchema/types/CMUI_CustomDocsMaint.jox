    <JadeMethod name="getXMLSettingsForSetup" id="1530fc89-a95e-48c1-ba10-ffac56dcb3f1">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
/*
Purpose:			

Date		Who		Reason
01 September 2023	navab1	CR 59942 TASK 59943 
*/

vars

	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	showParams : Boolean;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	
	
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagShowParams);
 	showParams := false;
 	if theXMLValue &lt;&gt; null then
 		showParams := theXMLValue.Integer.Boolean;
 	endif;
 	
	self.chkShowDataEntry.value := showParams;
	self.chkShowDataEntry_click(self.chkShowDataEntry);

end;</source>
