<GUIClass name="GTE_EditTIReceiveTypeForm" id="28b261fa-2b64-45e4-8eb2-dc8665f7e0f9">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allPreNoteItems" id="90f8ba65-10d9-4ba1-ad93-1d63f835ac59">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="cmbType" id="3ab7c2ac-50bd-4f7f-9727-ac2dec7cb02a">
        <embedded/>
        <type name="CMUI_ComboBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblInstruction" id="3afcbd5b-1f56-482a-baf3-ad5b71f5a09d">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblType" id="d9b111bc-a813-4e99-8667-d5f208f6b1a3">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="b6ed2cf9-c82b-4f4f-b1df-81e931bb621f">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2013	cnwmc5	Initial creation

*/
vars
	type		: Integer;
	result		: Integer;
begin
	if self.cmbType.listIndex = CNEC_NULL_INDEX then
		// Please select a Status for this operation
		app.msgBox(	app.getString( NothingSelected, self.lblType.caption ),
					app.getString( Nothing_Selected ),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		self.cmbType.setFocus;
		return;
	else
		type	:=	self.cmbType.itemData[ self.cmbType.listIndex ];
	endif;
	
	while true do : transaction_loop
		app.myTrxUA.trxSetTIReceiveType( type, self.allPreNoteItems, app.myPassport );
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window.
			self.clearErrorWarnings();
			break transaction_loop;
		else
			result	:=	app.showErrorWarningDialog(	self.caption, app.myPassport,
													ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
			
			if app.myPassport.noErrors() and result = IDOK then
				// There must have just been warnings that the user has acknowledged so...
				app.myPassport.warningsAcknowledged	:=	true;
				continue transaction_loop;
			endif;
			
			self.setAllErrorWarnings( app.myPassport );	// Copies errors to this form and shows in err/warnings window.
		endif;
		break transaction_loop;
	endwhile transaction_loop;
	
	if result = IDOK then				// otherwise unloads the form!
		inheritMethod();
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setAllPreNoteItems" id="03021c09-0ff1-479f-b304-89c747026f88">
        <updating/>
        <source>setAllPreNoteItems(_value : CM_TISet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2013	cnwmc5	Initial creation

*/
vars
	coll	: CM_TISet;
begin
	coll	:= self.allPreNoteItems;
	
	coll.clear;
	_value.copy( coll );
epilog

end;</source>
        <Parameter name="_value" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b6b633c8-653d-429f-ae7e-a50c4b349fc3">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2013	cnwmc5	Initial creation

*/

vars
	terminal	:CM_Terminal;
begin
	if self.allPreNoteItems.isEmpty() then
		app.msgBox(	app.getString( NothingSelected, app.getString( TrackedItem ) ),
					app.getString( Nothing_Selected ),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		self.unloadForm();
		return;
	endif;

	inheritMethod();
	
	// load the combo with the valid types
	terminal := self.myTerminal;
	
	self.myAssistant.comboBoxTIReceiveType (self.cmbType, 
												true, 
												true,
												true);
	self.cmbType.setFocus();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7cb09ba2-0be9-47d6-96c3-242cfb478bd9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018151, locale);
	lblInstruction.translateCaption(Xlat_0018152, locale);
	lblType.translateCaption(Xlat_0018153, locale);
end;</source>
    </JadeMethod>
</GUIClass>
