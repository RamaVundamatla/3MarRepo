    <JadeMethod name="showResourceUsageToDoTxn" id="60048b2e-9e21-454f-a59a-babff41c2ca9">
        <source>showResourceUsageToDoTxn( _transaction 	: CM_Transaction;
							_masterMenuAction 	: CMUI_MenuAction;
							_toDoTaskDesc 		: CM_ToDoTaskDesc;
							_proxyUsageSet 		: CM_ResourceTypeUsageSet io;
							_addMode 			: Boolean;
							_objectStr			: String
							): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
13 December 2022	navcs2		ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
05/04/2023			navcs2		Bug 57455: EUP - Todo Tasks Completed without adding Mandatory resources

*/

vars
	form : CMUI_ResourceTypeUsageForm;
	transaction : CM_Transaction;
	originalEdition : Integer;
	result : Integer;
	toDoTaskDesc : CM_ToDoTaskDesc;
begin
	form := app.loadForm(CMUI_ResourceTypeUsageForm, CMUI_Assistant, false, false, true, app.myPassport.myTerminal, _masterMenuAction).CMUI_ResourceTypeUsageForm;
	form.CMUI_ResourceTypeUsageForm.setObjectString(_objectStr);		//05/04/2023	navcs2	Bug 57455
	
	if form = null then
		return false;
	endif;
	
	if _transaction &lt;&gt; null then
		originalEdition := _transaction.edition;	//get the edition before we allow the user to update the resources...
	endif;

	form.setMyToDoTransaction( _transaction, _toDoTaskDesc );
		
	if _addMode then
		form.grpResource.enabled := true;
		form.chkVoid.enabled 	 := false;
		form.cmbResourceType.setFocus();
	else
		form.grpResource.enabled := false;
	endif;	
	
	form.showModal();
	
	if form.modalResult &lt;&gt; IDOK then
		return false;
	endif;
	
	//single transaction - updating multiple resources.
	if _transaction &lt;&gt; null then
		transaction := _transaction;
		while true do		
			app.myTrxUA.trxUpdateResourceUsageToDo( transaction, originalEdition, form.allNewProxyResourceTypeUsages, form.allUpdProxyResourceTypeUsages, form.allRealResourceTypeUsagesToDel, app.myPassport);
			if app.myPassport.trxCompletedOK then
				return true;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Resource_usage), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and result = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return false;
			endif;
		endwhile;
	endif;
	
	//multiple transactions and multiple resources.
	if _toDoTaskDesc &lt;&gt; null and _proxyUsageSet &lt;&gt; null then
		if not form.allNewProxyResourceTypeUsages.isEmpty then
			form.allNewProxyResourceTypeUsages.copy(_proxyUsageSet);
		endif;	
	endif;
	
	_toDoTaskDesc.validateResourceUsage(_proxyUsageSet);		//12/04/2023	navcs2	Bug 57455

	return true;
	
epilog

	delete form;
	
end;</source>
        <Parameter name="_transaction" type="CM_Transaction"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_proxyUsageSet" type="CM_ResourceTypeUsageSet" usage="io"/>
        <Parameter name="_addMode" type="Boolean"/>
        <Parameter name="_objectStr" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showRestrictionsForm" id="da80b848-eff1-430b-bfd4-ecb65c1f05df">
        <source>showRestrictionsForm(	_theTerminalArea	: CM_TerminalArea;
						_areaMode			: Integer;
						_initObject			: CM_Object;
						_xmlFlipH,
						_xmlFlipV			: Boolean;
