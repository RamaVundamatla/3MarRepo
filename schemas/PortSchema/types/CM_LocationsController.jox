    <JadeMethod name="isTIPrimaryLocation" id="1521eee4-59a6-46f2-8067-d1e5290587b5">
        <source>isTIPrimaryLocation(ti : CM_TrackedItem; mode : Integer) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			15 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	array : CM_TIArray;
begin
	if ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'ti ref', null, null);
		return false;
	endif;
	create array transient;
	getTIs(array, mode, true); // PAR 27749
	if array.isEmpty then
		return false;
	endif;
	return (array.first = ti);
epilog
	delete array;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
