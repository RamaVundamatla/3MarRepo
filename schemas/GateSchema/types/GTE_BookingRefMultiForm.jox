    <JadeMethod name="setFilterValues" id="e88627a1-44c6-4860-af11-cc5baee97029">
        <updating/>
        <source>setFilterValues() updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 May 2009	cnwkpd1	PAR #19785 - CCMS SFW 1079 - Booking Reference Status changes
// 19 Apr 2011	cnwrs2	PAR #27412 - Add voyage arrival from/to dates
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
// ---------------------------------------------------------------------------

vars
	voy 	  : CM_Voyage;
	stevedore : CM_Stevedore;
	tblSearch : CM_EntryTable;
begin
	inheritMethod();
	
	tblSearch := self.tblSearch ;
	
	voy := self.cmbFiltVoyage.getCurrentItemObject().CM_Voyage;
	
	if voy = null then
		self.filterVoyageCode := tblSearch.getValueByName(ETRow_FilterVoyage).String;
	else
		self.filterVoyageCode := voy.code;
	endif;
	
	stevedore := self.cmbStevedore.getCurrentItemObject().CM_Stevedore;
	if stevedore &lt;&gt; null then
		self.filterStevedoreCode := stevedore.code;
	endif;
	
	self.filterStatus 	      := app.bookingRefStatusStringToEnum(tblSearch.getValueByName(ETRow_FilterStatus).String);
	self.filterReconciled     := tblSearch.getValueByName(ETRow_FilterReconciled).String;
	self.filterBookingType 	  := tblSearch.getValueByName(ETRow_FilterBookingType).String;
	self.filterVoyArrivalFrom := tblSearch.getValueAsDate(ETRow_FilterVoyArrivalDateFrom);
	self.filterVoyArrivalTo   := tblSearch.getValueAsDate(ETRow_FilterVoyArrivalDateTo);

end;</source>
    </JadeMethod>
