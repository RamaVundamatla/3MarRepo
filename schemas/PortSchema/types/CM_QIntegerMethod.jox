/*
----------   ----------  --------------------------------------------------
Created:	06 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin
	return _obj.sendMsg(self.propertyName).Integer;

end;</source>
