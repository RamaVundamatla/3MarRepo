    <JadeMethod name="userNotificationUpdateLocal" id="1a856f7a-581a-4102-9f3d-f7102e7c86cd">
        <updating/>
        <source>userNotificationUpdateLocal(_event: Integer; _noteObj: CM_Object; _obj: Any) updating;
/*

Purpose:			Notification method for handling user notifications from trx's

Parameters:			_event		Integer		The event tag to use (EVENT_MAPPING_DELETEOID, EVENT_MAPPING_UPDATE, EVENT_MAPPING_CREATE)
					_noteObj	CM_Object	The notification object (in this case it is CM_Terminal)
					_obj		Any			The object we raised the notification for (can be either CM_InvoiceLineDescMapping or String) (String used as oid)

Return Value:		NONE

Date			Who		Reason
11 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	theMapping	: CM_InvoiceLineDescMapping;
	theRow		: Integer;
	theDataLine	: String;
	theTable	: CM_DataTable;
	obj			: Any;
	
begin 
	if not _obj.isKindOf(CM_InvoiceLineDescMapping) and
	   not _obj.isKindOf(String) then
		return;
	endif;
	
	obj := _obj;
	theTable := self.tblData;
	
	if _event = EVENT_MAPPING_DELETEOID then
		if theTable.findObjectInRow(obj.String.asOid(), theRow) then
			theTable.removeItem(theRow);
			self.myCurrentInvLineMapping := null;
		endif;
		
		return;
	endif;
	
	if obj &lt;&gt; null and 
		(_event = EVENT_MAPPING_UPDATE or _event = EVENT_MAPPING_CREATE) 
	then
		theMapping := obj.CM_InvoiceLineDescMapping;
		theTable.findObjectInRow(theMapping, theRow);
		
		if theRow &gt; 0 then //Update
			theDataLine := theMapping.getAttributeStringForDefArray(theTable.allTblDataEntRows);
			theTable.accessCell(theRow,1).text := theDataLine;
			theTable.accessRow(theRow).itemObject := theMapping;
		else //Add
			theDataLine := theMapping.getAttributeStringForDefArray(theTable.allTblDataEntRows);
			theRow := theTable.addItem(theDataLine);
			theTable.accessRow(theRow).itemObject := theMapping;
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteObj" type="CM_Object"/>
        <Parameter name="_obj" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="f9a3cd6a-6e52-4e9d-b6e8-54f8bbefd209">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			Notification method for handling user notifications

Parameters:			_event		Integer		The event tag to use (EVENT_MAPPING_DELETEOID, EVENT_MAPPING_UPDATE, EVENT_MAPPING_CREATE)
					_noteObj	CM_Object	The notification object (in this case it is CM_Terminal)
					_obj		Any			The object we raised the notification for (can be either CM_InvoiceLineDescMapping or String)

Return Value:		NONE

Date		Who		Reason
14 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	event : Integer;
	
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	self.userNotificationUpdateLocal(event, theObject.CM_Object, userInfo);
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
