    <JadeMethod name="exportBlockStack" id="a10b9b1a-38f3-496f-be56-b93b3a913efa">
        <source>exportBlockStack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation

*/

vars
    agent: CM_DataExportAgent;
begin
    create agent transient;
	
	app.initialize();
	app.myPassport.setMyUserFromCode("NAVIV1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals['DAVE']);
	
   agent.exportToXml("BlockStackDefinition",1,"BLOCK1");
	
   agent.saveXmlToFile("C:\Users\naviv1\BSTest.xml");

    
epilog
    delete agent;
end;</source>
    </JadeMethod>
