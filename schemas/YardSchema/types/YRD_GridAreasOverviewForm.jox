    <JadeMethod name="getData" id="6732adad-e556-40a3-86b4-2642919bb070">
        <updating/>
        <source>getData(pText: String input; pType: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		Passback method called from CMUI_GetData form
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars
	loadStateSet : Boolean;
	aProxyTI : CM_TrackedItem;
	result : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	if pType = self.GetData_Remarks then
		app.cmsBeginLoad(loadStateSet);
		aProxyTI := self.mnuRemarks.userObject.CM_TrackedItem.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadStateSet);
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateTIRemarks(aProxyTI, pText, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Grid Area', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
		
	endif;
	
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	if aProxyTI &lt;&gt; null then
		delete aProxyTI;
	endif;
end;</source>
        <Parameter name="pText" type="String" usage="input"/>
        <Parameter name="pType" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDefaultViewMode" id="a621dd7c-16d5-47a9-8972-6f832a9f2811">
        <source>getDefaultViewMode(viewMode : Integer io);
// ---------------------------------------------------------------------------
// Created:		11 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//19-may-2022 navtnr20 ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
//06-06-2022 navtnr20	53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
vars
	
begin
	viewMode := self.xmlViewMode; //VIEW_VOYAGE;
	if self.myCurrentDrawingController &lt;&gt; null then
		viewMode := self.myCurrentDrawingController.viewMode;
	else
		if viewMode = VIEW_VOYAGE then
			self.btnViewVoyage.value := true;
		elseif viewMode = VIEW_DISPORT then
			self.btnViewDischarge.value := true;
		elseif viewMode = VIEW_COMMODITY then
			self.btnViewCommodity.value := true;
		elseif viewMode = VIEW_CONSIGNEE then
			self.btnViewConsignee.value := true;
		//elseif viewMode = VIEW_DWELL then
		//	self.btnViewDwell.value := true;
		
		elseif viewMode = VIEW_DWELL_DAYS then	// 20 Jul 2011	NDL	Par 27890
			self.btnViewDwellDays.value := true;
		elseif viewMode = VIEW_MTGRADE then	// 29 Jul 2011	NDL	Par 27890
			self.btnViewMTGrade.value := true;
			
		elseif viewMode = VIEW_HAZ then
			self.btnViewHaz.value := true;
		elseif viewMode = VIEW_HEIGHT then
			self.btnViewHeight.value := true;
		elseif viewMode = VIEW_ISOGROUP then
			self.btnViewISOGroup.value := true;
		elseif viewMode = VIEW_IMEX then
			self.btnViewImEx.value := true;
		elseif viewMode = VIEW_OPERATOR then
			self.btnViewOperator.value := true;
		elseif viewMode = VIEW_STATUS then
			self.btnViewStatus.value := true;
		elseif viewMode = VIEW_TEMPERATURE then
			self.btnViewTempRange.value := true;
		elseif viewMode = VIEW_WEIGHT then
			self.btnViewWeight.value := true;
		elseif viewMode = VIEW_SHIPPINGLINE then		// 19-May-2022 navtnr20 #tfs 53204
			self.btnViewShippingLine.value := true;

		endif;
	endif;

end;</source>
        <Parameter name="viewMode" type="Integer" usage="io"/>
    </JadeMethod>
