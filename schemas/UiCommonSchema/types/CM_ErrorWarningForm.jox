    <JadeMethod name="load" id="859fc41e-984f-4a0e-855a-6ee5fdc0a55e">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theMdiFrame	: Form;

begin

	theMdiFrame := self.getMdiFrame;
	if theMdiFrame &lt;&gt; null and theMdiFrame.isKindOf(CMUI_SuperAppForm2) then
		if app.useTiledView then
			self.doLockRight();
			//self.doLockLeft();
		else
			//self.doLockLeft();
			self.initPosition;
			self.doFloating();
		endif;
	else
		self.doLockRight();
	//	self.doLockLeft();
	endif;
	
	self.frmToolbarBtns.visible := false;
/*	
	self.tblData.optimiseRowHeight := true;
	self.tblData.top 	:= 0;
	self.tblData.left	:= 0;
	self.tblData.width	:= self.clientWidth;
	self.tblData.height	:= self.clientHeight;
*/	
end;</source>
    </JadeMethod>
