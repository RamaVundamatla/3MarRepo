    <JadeMethod name="initQueueTable" id="7b73db02-2f33-4b07-8b4b-74c04340ebaf">
        <updating/>
        <source>initQueueTable() updating;

begin
	tableQueueItems.clear;

	// Set table configuration access mode to 'by cell'
	tableQueueItems.accessMode := tableQueueItems.AccessMode_Cell;

//	tableQueueDetails.rows := ?_initial_table_rows;

	/**************************************************************

	  Set up TABLE SORTING by timestamp + Ispec name, ascending

	**************************************************************/

	tableQueueItems.sortColumn[1]	:= 2;	// first sort column is 2
	tableQueueItems.sortAsc[1]		:= true;
	tableQueueItems.sortColumn[2] 	:= 1;	// second sort column is 1
	tableQueueItems.sortAsc[2] 		:= true;

	/**************************************************************

	  Set up TABLE and COLUMN WIDTHS

	**************************************************************/

	tableQueueItems.columnWidth[1] := Queue_col_width_ispec;
	tableQueueItems.columnWidth[2] := Queue_col_width_timestamp;
	tableQueueItems.columnWidth[3] := Queue_col_width_status;
	tableQueueItems.columnWidth[4] := Queue_col_width_priority;
	tableQueueItems.columnWidth[5] := Queue_col_width_timeout;

	// Set the overall table width
	tableQueueItems.width :=  Queue_col_width_ispec +
								Queue_col_width_timestamp +
								Queue_col_width_priority +
								Queue_col_width_status +
								Queue_col_width_timeout +
								Col_width_scrollbar + 
								Col_width_border;

	/**************************************************************

	  Set up COLUMN HEADINGS

	**************************************************************/

	tableQueueItems.row			:= 1;

	tableQueueItems.column		:= 1;
	tableQueueItems.alignment	:= tableQueueItems.Alignment_Center;
	tableQueueItems.text			:= Queue_col_head_ispec;

	tableQueueItems.column		:= 2;
	tableQueueItems.alignment	:= tableQueueItems.Alignment_Center;
	tableQueueItems.text			:= Queue_col_head_timestamp;

	tableQueueItems.column		:= 3;
	tableQueueItems.alignment	:= tableQueueItems.Alignment_Center;
	tableQueueItems.text			:= Queue_col_head_status;

	tableQueueItems.column		:= 4;
	tableQueueItems.alignment	:= tableQueueItems.Alignment_Center;
	tableQueueItems.text			:= Queue_col_head_priority;

	tableQueueItems.column		:= 5;
	tableQueueItems.alignment	:= tableQueueItems.Alignment_Center;
	tableQueueItems.text			:= Queue_col_head_timeout;
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="6876f899-f40f-468f-9f53-78e9818f312b">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	myLincSystemDef := CnEcLincSystemDef.firstInstance;

	// set notification for additions/changes additions of queue items

	beginClassNotification(CnEcIspecToHost, false, Any_System_Event, Response_Continuous, 0);	

	// Populate the queue item details table
	initQueueTable();
	updateQueueTable();
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="3cd6cefc-0e74-4aab-98b7-739e23f08038">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; userTag: Integer) updating;

begin
	// Get nofications for changes to the Linc Queue, i.e. respond
	// to queue items being created, updated or deleted

//	if theObject.isKindOf(IspecToHost) then 
		if	  eventType = Object_Create_Event 
			or eventType = Object_Update_Event 
			or eventType = Object_Delete_Event then

				initQueueTable();
				updateQueueTable();
		endif;
//	endif; 
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="userTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tableQueueItems_click" id="ad297a08-d9c8-4229-ab7f-a69a241178fe">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tableQueueItems_click(table: Table input) updating;

vars
	selColumn : Integer;

begin
	// Take enote of the selected column
	selColumn := tableQueueItems.column;

	tableQueueItems.column := 1;
	tableQueueItems.selected := true;

	tableQueueItems.column := 2;
	tableQueueItems.selected := true;

	tableQueueItems.column := 3;
	tableQueueItems.selected := true;

	tableQueueItems.column := 4;
	tableQueueItems.selected := true;

	tableQueueItems.column := 5;
	tableQueueItems.selected := true;

	// Return to the selected column
	tableQueueItems.column	:= selColumn;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
