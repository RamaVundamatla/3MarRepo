    <JadeMethod name="getDisplay" id="da3a1697-d5d2-4c45-8518-99176fcce06d">
        <source>getDisplay():String;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Purpose:		Returns a string to use for the GUI interface to display the receiver's
//				details.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	compDescription	: String;
	returnValue		: String;
	
begin
	if self.componentDescription.length() &gt; 60 then
		compDescription	:=	self.componentDescription[1:60];
	else
		compDescription	:=	self.componentDescription;
	endif;
	
	returnValue	:=	self.componentId.String &amp; " - " &amp; compDescription;
	
	return returnValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="ecf19b45-b806-492c-b11f-359b0325205a">
        <updating/>
        <source>updateMe(pComponentId:Integer; pComponentDescription:String; pTheProduct:JSSLKProduct) updating;
// --------------------------------------------------------------------------------
// Created:		15 January 2003 by cnwdad1
//
// Purpose:		Updates the receiver's properties.
//
// Parameters:	pComponentId - The unique identitier number of the Product Component.
//				pTheProduct - The Product to which the Component belongs.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateMe(pComponentId, pComponentDescription, pTheProduct) then
		// Update general properties and references.
		
		if self.componentDescription &lt;&gt; pComponentDescription then
			self.componentDescription	:=	pComponentDescription;
		endif;
		
		// Update any key properties.
		
		if self.componentId &lt;&gt; pComponentId then
			self.componentId	:=	pComponentId;
		endif;
		
		// Update inverse references.
		
		if self.myProduct &lt;&gt; pTheProduct then
			self.myProduct	:=	pTheProduct;
		endif;
	endif;
end;</source>
        <Parameter name="pComponentId" type="Integer"/>
        <Parameter name="pComponentDescription" type="String"/>
        <Parameter name="pTheProduct" type="JSSLKProduct"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="c90f46da-e302-47f4-a443-4e4c55b27fbe">
        <source>validateMe(pComponentId:Integer; pComponentDescription:String; pTheProduct:JSSLKProduct):Boolean;
// --------------------------------------------------------------------------------
// Created:		15 January 2003 by cnwdad1
//
// Purpose:		Validates the receiver's properties.
//
// Parameters:	pComponentId - The unique identitier number of the Product Component.
//				pTheProduct - The Product to which the Component belongs.
//
// Returns:		True if the data is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pComponentId = 0 then
		JSSLKException.raise_(99999, $COMPONENT_ID_IS_ZERO);
		return false;
	endif;
	
	if pTheProduct = null then
		JSSLKException.raise_(99999, $PRODUCT_IS_NULL);
	endif;
	
	return true;
end;</source>
        <Parameter name="pComponentId" type="Integer"/>
        <Parameter name="pComponentDescription" type="String"/>
        <Parameter name="pTheProduct" type="JSSLKProduct"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
