    <JadeMethod name="userNotification" id="a55895b2-0770-49e9-a5e6-dc71924a302a">
        <updating/>
        <source>userNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	smtp: CnSmtpConnection;
begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' eventType ='&amp;_eventType.String&amp;' userInfo ='&amp;_userInfo.String, LogDebug);
	smtp := _theObject.CnSmtpConnection;

	if smtp.result &lt;&gt; null then
		app.writeLog(class.name&amp;"::"&amp;method.name&amp;" Email Message failed with error="&amp;smtp.extendedErrorText&amp;" Error", LogAlways);
	else
		app.writeLog(class.name&amp;"::"&amp;method.name&amp;" Email Message sent OK", LogDebug);
	endif;
epilog
	delete smtp;
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
</Class>
