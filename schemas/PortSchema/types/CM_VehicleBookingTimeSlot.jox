    <JadeMethod name="setForUpdateVBSTimeSlotItems" id="b0e312c3-7aff-4f57-979d-c289bf421546">
        <updating/>
        <source>setForUpdateVBSTimeSlotItems(_proxyVBSTimeSlot 			  : CM_VehicleBookingTimeSlot;
							_allNewVBSTimeSlotItemProxies : CM_VehicleBookingTSItemSet input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 Jul 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
29 May 2023 navma1	Bug 58195: FR - EUP 53429 - BR - VBS changes MTN - null object reference.

*/

vars
	pxyVehicleBookingTimeSlot ,
	realVBSItem 				: CM_VehicleBookingTimeSlotItem;
	deleteVBSItems 				: CM_VehicleBookingTSItemSet;
begin
	
	//all current time slot items
	create deleteVBSItems transient;
	 self.allVehicleBookingItems.copy(deleteVBSItems);
	foreach pxyVehicleBookingTimeSlot in _proxyVBSTimeSlot.allVehicleBookingItems do
		realVBSItem := app.myProxyManager.getRealObject(pxyVehicleBookingTimeSlot).CM_VehicleBookingTimeSlotItem;
	
		if realVBSItem = null then
			create realVBSItem persistent;	
			realVBSItem.setForCreate(pxyVehicleBookingTimeSlot, self);
			if not _allNewVBSTimeSlotItemProxies.includes(pxyVehicleBookingTimeSlot) then
				_allNewVBSTimeSlotItemProxies.add(pxyVehicleBookingTimeSlot);
			endif;
		else
			
			//update it remove from delete set
			realVBSItem.setForUpdate(pxyVehicleBookingTimeSlot, self);
			deleteVBSItems.removeIfPresent(realVBSItem);
			
		endif;
				
	endforeach;
	
	foreach realVBSItem in deleteVBSItems do
		realVBSItem.validateForDelete();
	endforeach;
	
epilog
	if deleteVBSItems &lt;&gt; null then					//29.05.2023 navma1 #58195
		deleteVBSItems.purge;	
		delete deleteVBSItems;
	endif;

end;</source>
        <Parameter name="_proxyVBSTimeSlot" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_allNewVBSTimeSlotItemProxies" type="CM_VehicleBookingTSItemSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setIdForConversion" id="08005924-af5e-4162-bd24-4724b9f386fe">
        <updating/>
        <source>setIdForConversion( _int : Integer io ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2014	cnwndl1	Initial creation	- Par 35008 For conversion purposes ONLY.

*/

vars

	convId : String;
	dateStr : String;

begin

	if self.id.trimBlanks &lt;&gt; null then
		return;
	endif;
	if not self.bookingTSstart.date.isValid then
		return;
	endif;
	
	dateStr := self.bookingTSstart.date.formatAsYYMMDD();

	_int := _int + 1;
	convId := "VBC" &amp; dateStr &amp; _int.String.padZeros(4);
	
	if self.myVehicleBookingTerminal = null or self.myVehicleBookingTerminal.allVBTimeslotsById.getAtKey(convId) &lt;&gt; null then
		return;
	endif;
	
	beginTransaction;
	self.id := convId;
	commitTransaction;

epilog

end;</source>
        <Parameter name="_int" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="197c14d1-891f-4a9b-91b3-c08376a3b4ee">
        <updating/>
        <source>setProxy(	_scheduleTSstart : TimeStamp;
			_scheduleTSend : TimeStamp;
			_myVBTerminal : CM_VehicleBookingTerminal;
			_myCarrier : CM_Carrier;
			_mySubCarrier : CM_Carrier;
			_myDriver : CM_DriverDetails;
			_myVehicle : CM_Vehicle;
			_remarks : String;
			_includesDelivery : Boolean;
			_includesPickUp : Boolean;
			_bookedTiIds : StringArray;
			_myVehicleVisitRecord : CM_VehicleVisitRecord;
			_myVBTimeslotType : CM_VehicleBookingTimeSlotType;
			_id : String;
			_allBookingRefs : CM_BookingRefSet;
			_allBulkReleases : CM_BulkReleaseSet;
			_allVBSTimeSlotItems : CM_VehicleBookingTSItemSet;
			_preGateInCheck : Boolean;
			_preGateOutChck : Boolean;
			_kioskCheck : Boolean;
			_externalReference : String;
			_myTILCType	: CM_TILCType
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2013		cnwndl1	Initial creation	Par 31393
01 February 2023	navpw1	Change Request: 53898 (53961) - Merged setProxyAdv with this one and removed it
15 Aug 2023	ChangeRequest 59875: EUP | VBS - Add Created by user code
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
26 Aug 2024 navcs2	Bug 62476: MTN - CM_VehicleBookingTimeSlot allTiIds collection not updating
*/

vars
	ti					   	: CM_TrackedItem;
	terminal			   	: CM_Terminal;
	vbsProcess			   	: CM_VBSProcess;
	vehicleBookingTerminal 	: CM_VehicleBookingTerminal;
	isAdvanced				: Boolean; 
begin

	
	// bare minimum
	self.bookingTSstart 		  := _scheduleTSstart;
	self.bookingTSend 			  := _scheduleTSend;
	self.myVehicleBookingTerminal := _myVBTerminal;
	self.myVBTimeSlotType 		  := _myVBTimeslotType;		//02 Oct 2014	NDL	CCMS 2399
	self.id := _id;											//02 Oct 2014	NDL	CCMS 2399
	
	//booked
	self.myCarrier 			:= _myCarrier;
	self.myDriver 			:= _myDriver;
	self.myVehicle 			:= _myVehicle;
	self.remarks 		    := _remarks;
	self.includesDelivery 	:= _includesDelivery;
	self.includesPickUp 	:= _includesPickUp;
	
	self.allTiIds.clear();
	if _bookedTiIds &lt;&gt; null and not _bookedTiIds.isEmpty then
		_bookedTiIds.copy( self.allTiIds );
	endif;
	//02 Oct 2014	NDL	CCMS 2399
	self.allBookingRefs.clear();
	if _allBookingRefs &lt;&gt; null and not _allBookingRefs.isEmpty then
		_allBookingRefs.copy( self.allBookingRefs );
	endif;
	//02 Oct 2014	NDL	CCMS 2399
	self.allBulkReleases.clear();
	if _allBulkReleases &lt;&gt; null and not _allBulkReleases.isEmpty then
		_allBulkReleases.copy( self.allBulkReleases );
	endif;
	
	//used
	self.myVehicleVisitRecord := _myVehicleVisitRecord;
	vehicleBookingTerminal 	  := self.myVehicleBookingTerminal;
	
	// ### TFS 56718 22Feb2023 NAVPW1
	if vehicleBookingTerminal = null then
		return;
	endif;
	// ### TFS 56718 22Feb2023 NAVPW1
	
	if vehicleBookingTerminal.myTerminal &lt;&gt; null then
		terminal := vehicleBookingTerminal.myTerminal;
	else
		return;
	endif;
	
	vbsProcess := terminal.getMyVBSProcess;
	
	if not vbsProcess.isVbsSlotValidation then	
		return;
	endif;
	
	self.mySubCarrier      := _mySubCarrier;
	self.externalReference := _externalReference.toUpper().replace(Space,'');
	
	self.preGateInCheck  := _preGateInCheck;
	self.preGateOutCheck := _preGateOutChck;
	self.kioskCheck      := _kioskCheck;

	
	self.myTILCType :=  _myTILCType;															// 08 Aug 2024 navcs2	ChangeRequest 63928
	
epilog

end;</source>
        <Parameter name="_scheduleTSstart" type="TimeStamp"/>
        <Parameter name="_scheduleTSend" type="TimeStamp"/>
        <Parameter name="_myVBTerminal" type="CM_VehicleBookingTerminal"/>
        <Parameter name="_myCarrier" type="CM_Carrier"/>
        <Parameter name="_mySubCarrier" type="CM_Carrier"/>
        <Parameter name="_myDriver" type="CM_DriverDetails"/>
        <Parameter name="_myVehicle" type="CM_Vehicle"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_includesDelivery" type="Boolean"/>
        <Parameter name="_includesPickUp" type="Boolean"/>
        <Parameter name="_bookedTiIds" type="StringArray"/>
        <Parameter name="_myVehicleVisitRecord" type="CM_VehicleVisitRecord"/>
        <Parameter name="_myVBTimeslotType" type="CM_VehicleBookingTimeSlotType"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_allBookingRefs" type="CM_BookingRefSet"/>
        <Parameter name="_allBulkReleases" type="CM_BulkReleaseSet"/>
        <Parameter name="_allVBSTimeSlotItems" type="CM_VehicleBookingTSItemSet"/>
        <Parameter name="_preGateInCheck" type="Boolean"/>
        <Parameter name="_preGateOutChck" type="Boolean"/>
        <Parameter name="_kioskCheck" type="Boolean"/>
        <Parameter name="_externalReference" type="String"/>
        <Parameter name="_myTILCType" type="CM_TILCType"/>
    </JadeMethod>
