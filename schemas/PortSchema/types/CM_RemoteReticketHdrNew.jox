<Class name="CM_RemoteReticketHdrNew" id="e653b417-c5b9-42a6-afe0-78b05995beb1">
    <superclass name="CM_RemoteDataHdr"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Reticket V2&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <JadeMethod name="getDescription" id="b79a8f54-a4df-4c00-9f18-fff689b01fad">
