		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors)
	return self.lastError;
end;</source>
        <Parameter name="pMessageName" type="String"/>
        <Parameter name="pMessageData" type="String"/>
        <Parameter name="pWebServerName" type="String"/>
        <Parameter name="webServerPath" type="String"/>
        <Parameter name="pTestMessage" type="CnEcWebTestMessage" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
