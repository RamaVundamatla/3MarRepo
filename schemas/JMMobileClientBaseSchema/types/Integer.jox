<PrimType name="Integer">
    <JadeMethod name="mbAsKilobytes" id="a90c4468-478e-4282-b14b-f765c3730af6">
        <source>mbAsKilobytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent kilobytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into kilobytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_KILOBYTE	: Integer = 1024;
	
begin
	return self / BYTES_PER_KILOBYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="mbAsMegabytes" id="558a0014-349c-4544-afc6-453e1f484f73">
        <source>mbAsMegabytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent megabytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into megabytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_MEGABYTE	: Integer = 1048576;
	
begin
	return self / BYTES_PER_MEGABYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="mbDaysInMonth" id="79b2f583-1fc6-4a15-8708-94db50a85ab4">
        <source>mbDaysInMonth(_isLeapYear:Boolean):Integer;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Returns the number of days of the month number.
//
// Parameters:	_isLeapYear (Boolean) - Flag to indicate whether the month number
//					is within a leap year.
//
// Returns:		Integer - The number of days, or zero if the month number is invalid.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_UNICODE_SYS	: Boolean = (-1).Character.Integer = 65535;
	DAYS_IN_MONTH	: Binary = #"1F 1C 1F 1E 1F 1E 1F 1F 1E 1F 1E 1F".Binary;	// Construct a compile-time value array.

begin
	if self &lt; 1 or self &gt; 12 then
		return null;
	endif;
	
    if self = 2 and _isLeapYear then
        return 29;
    endif;

	if IS_UNICODE_SYS then
		return DAYS_IN_MONTH[(self*2-1):2].Integer;
	endif;

	return DAYS_IN_MONTH[self];
end;</source>
        <Parameter name="_isLeapYear" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mbGetEasterSundayForYear" id="d1517172-fb63-4ce0-beca-f0fb5c1d5a34">
        <source>mbGetEasterSundayForYear():Date;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the date of Easter Sunday for a (receiver) year.
//
// Parameters:	None
//
// Returns:		Date - The date Easter Sunday for the (receiver) year.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/*

This method computes the date on which Easter Sunday occurs for the year passed as
a parameter.

The Gregorian calendar officially started in September 1752, so the formula shouldn't
be applied to 1752 and has been coded to return a null date for years prior to 1753.

The formula implemented by this method was devised by Christophorus Clavius under 
commission from Pope Gregory XIII. Basically it works out the date of the Paschal
Full moon, which is supposed to be the first full moon following the Vernal Equinox.
The formula here was worked out so that the new moon calculated always falls on, or
one, or two days after the true mean astronomical new moon. The full moon is then
considered to occur on the fourteenth day of the lunar month and Easter Sunday is
the first Sunday following that. In fact the formula is quite rough and ready as is
the Gregorian Calendar.

*/
constants	
	MARCH_21		: Integer = 31 + 28 + 21;
	GREGORY_START	: Integer = 1753;

vars
	yearNum			: Integer;
	century			: Integer;
	clavius			: Integer;
	dominical		: Integer;
	easter			: Integer;
	epact			: Integer;
	golden			: Integer;
	leap			: Integer;
	metonic_error	: Integer;
	moon			: Integer;
	paschal			: Integer;
	easter_sunday	: Date;

begin
	yearNum	:=	self;
	
	if (yearNum &lt; GREGORY_START) then
		easter_sunday.setDate(0, 0, 0);
		return easter_sunday;
	endif;

	century	:=	yearNum div 100;

	if (yearNum mod 4 = 0) and (yearNum mod 100 &lt;&gt; 0) or (yearNum mod 400 = 0) then
		leap	:=	1;
	else
		leap	:=	0;
	endif;				

	dominical		:=	7 - (yearNum + yearNum div 4 - century + century div 4 - 1 - leap) mod 7;
	golden			:=	yearNum mod 19 + 1;
	metonic_error	:=	(century - century div 4 - (century - (century - 17) div 25) div 3 - 8) mod 30;
	epact			:=	(11 * (golden - 1) - metonic_error) mod 30;
	moon			:=	31 - epact + 59 + leap;
	paschal			:=	moon + 13;	           // We got it - unless . .. .

	if (paschal &lt; (MARCH_21 + leap)) then	// It was before the Equinox.
		if (golden &gt; 11) then
			clavius	:=	26;
		else
			clavius	:=	25;
		endif;

		if (epact &lt; clavius) then
			moon	:=	moon + 29;
		else
			moon	:=	moon + 30;
		endif;

		paschal	:=	moon + 13;
	endif;	 				 			

	easter			:=	paschal + 7 - (paschal - dominical) mod 7;	// Sunday after Paschal full moon.
	easter_sunday.setDate(1, 1, yearNum);
	easter_sunday	:=	easter_sunday + easter - 1;

	return easter_sunday;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="mbGetRGBValues" id="c4f6b049-6ebe-48d9-922c-27ed3eadec51">
        <source>mbGetRGBValues(_colorRed:Integer output; _colorGreen:Integer output; _colorBlue:Integer output);
// --------------------------------------------------------------------------------
// Created:		06 June 2001 by cnwdad1
//
// Purpose:		Get the RGB values which make up the receiver's colour value.
//
// Parameters:	_colorRed (Integer) - The red part of the color.
//				_colorGreen (Integer) - The green part of the color.
//				_colorBlue (Integer) - The blue part of the color.
//
// Returns:		The red, green and blue values as output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	workValue	: Integer;
	
begin
	workValue	:=	self;	
	_colorRed	:=	workValue mod 256;
	workValue	:=	workValue div 256;
	_colorGreen	:=	workValue mod 256;
	workValue	:=	workValue div 256;
	_colorBlue	:=	workValue mod 256;
end;</source>
        <Parameter name="_colorRed" type="Integer" usage="output"/>
        <Parameter name="_colorGreen" type="Integer" usage="output"/>
        <Parameter name="_colorBlue" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="mbGetReverseColor" id="65d1213e-a28c-45ea-b631-78e17c58cc14">
        <source>mbGetReverseColor():Integer;
// --------------------------------------------------------------------------------
// Created:		30 March 2005 by cnwdad1
//
// Purpose:		Returns opposite of the color to the receiver's current color.
//
// Parameters:	None
//
// Returns:		The reverse color.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colorRed	: Integer;
	colorGreen	: Integer;
	colorBlue	: Integer;
	revColor	: Integer;
	
begin
	revColor	:=	self.bitAnd(#FFFFFF);		// Remove sign bit if any.
	revColor.mbGetRGBValues(colorRed, colorGreen, colorBlue);
	
	// Get the opposite colors.
	colorRed	:=	(255 - colorRed).abs;
	colorBlue	:=	(255 - colorBlue).abs;
	colorGreen	:=	(255 - colorGreen).abs;
	revColor.mbSetColorFromRGB(colorRed, colorGreen, colorBlue);
	
	return revColor;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mbIsAltKey" id="32daf802-481d-47e3-a834-e30a0b4aa573">
        <source>mbIsAltKey():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the ALT key is pressed.
//				This method assumes that the receiver is the value of the "shift"
//				parameter of various GUI object event methods, such as the keyDown,
//				keyUp, mouseDown, mouseMove and mouseUp events.
//
// Parameters:	None
//
// Returns:		True if the ALT key is pressed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.bitAnd(4) &lt;&gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbIsBetween" id="8f65e7c7-bb53-4c86-a7e3-c6d5211c517c">
        <source>mbIsBetween(_lowerValue:Integer; _upperValue:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		09 April 2002 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is within
//				(or equal to) to supplied range of values.
//
// Parameters:	_lowerValue - The lower limit of the range.
//				_upperValue - The upper limit of the range.
//
// Returns:		True if the receiver is within the range, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self &gt;= _lowerValue and self &lt;= _upperValue);
end;</source>
        <Parameter name="_lowerValue" type="Integer"/>
        <Parameter name="_upperValue" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbIsCtrlKey" id="0744d5ef-04f3-4294-9f5a-72f453034681">
        <source>mbIsCtrlKey():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the CTRL key is pressed.
//				This method assumes that the receiver is the value of the "shift"
//				parameter of various GUI object event methods, such as the keyDown,
//				keyUp, mouseDown, mouseMove and mouseUp events.
//
// Parameters:	None
//
// Returns:		True if the CTRL key is pressed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.bitAnd(2) &lt;&gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbIsLeapYear" id="d1ec3353-2898-4516-becc-a6f507f4d550">
        <source>mbIsLeapYear():Boolean;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Determines if the receiver year is a leap year.
//
// Parameters:	None
//
// Returns:		True if the receiver is a leap year, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
    return (self mod 4 = 0 and self mod 100 &lt;&gt; 0) or self mod 400 = 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbIsShiftKey" id="a1a2cb30-c63e-4083-a125-770363182f98">
        <source>mbIsShiftKey():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the Shift key is pressed.
//				This method assumes that the receiver is the value of the "shift"
//				parameter of various GUI object event methods, such as the keyDown,
//				keyUp, mouseDown, mouseMove and mouseUp events.
//
// Parameters:	None
//
// Returns:		True if the Shift key is pressed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.bitAnd(1) &lt;&gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mbSetColorFromRGB" id="2f389327-9125-4695-93cf-9794d2b995b2">
        <updating/>
        <source>mbSetColorFromRGB(_colorRed:Integer; _colorGreen:Integer; _colorBlue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		06 June 2001 by cnwdad1
//
// Purpose:		Sets the receiver to the JADE (Windows) color number corresponding
//				to the passed RGB values.
//
// Parameters:	_colorRed (Integer) - The red part of the color.
//				_colorGreen (Integer) - The green part of the color.
//				_colorBlue (Integer) - The blue part of the color.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self	:=	((_colorBlue * 256) + _colorGreen) * 256 + _colorRed;
end;</source>
        <Parameter name="_colorRed" type="Integer"/>
        <Parameter name="_colorGreen" type="Integer"/>
        <Parameter name="_colorBlue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mbToPowerOf" id="0dd4b145-5b7c-440c-b8ab-94eabbfea4ed">
        <source>mbToPowerOf(_powerOf:Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		30 March 2005 by cnwdad1
//
// Purpose:		Returns the receiver, multiplied to the power of the specified value.
//
// Parameters:	_powerOf - The power to multiply by.
//
// Returns:		The receiver, multiplied to the power of the specified value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	loopCount		: Integer;
	resultValue		: Integer;
	
begin
	if _powerOf &lt;= 0 then
		return 0;
	endif;
	
	resultValue	:=	1;
	
	foreach loopCount in 1 to _powerOf do
		resultValue	:=	resultValue * self;
	endforeach;
	
	return resultValue;
end;</source>
        <Parameter name="_powerOf" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</PrimType>
