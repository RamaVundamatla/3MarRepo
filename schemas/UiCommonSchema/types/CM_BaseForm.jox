    <JadeMethod name="setCaption" id="b1aa439e-dcce-48f7-ae34-6e50d0dbd6f9">
        <updating/>
        <source>setCaption(_caption : String) updating;
// ---------------------------------------------------------------------------
// Created:		Nov  2003 By cnwrs2
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
06 Apr 2016	cnwkpd1	TFS 488 - Multi timezone changes - display Terminal's short timezone
					ID in the caption if it is set
16 Apr 2021 navmd1	TFS 51044 Handle situations where self.caption is passed in as the _caption already. (eg. CMUI_ErrorWarningDialog)
	
*/

vars
	terminal		: CM_Terminal;
	codeAndZone,
	tmpCaption		: String;

begin
	
	terminal := self.myTerminal;
	if terminal &lt;&gt; null then
		codeAndZone := terminal.code;
		// If the caption passed in already has the Terminal code appended to it, we don't need to add it again
		if codeAndZone.length + 1 &gt; _caption.length then	//19 Jul 2021	NDL	TFS 51546
			//can't have already been appended yet if the caption is shorter than the terminal code, so don't try to check or you'll get a 4031.
		else
			if _caption[_caption.length - codeAndZone.length + 1:end] = codeAndZone then
				codeAndZone := '';
			endif;
		endif;
		
		if terminal.timeZoneShortID &lt;&gt; null then
			codeAndZone := codeAndZone &amp; ' (' &amp; terminal.timeZoneShortID &amp; ')';
		endif;
		
		if codeAndZone.length &gt; 0 then
			tmpCaption := _caption &amp; ' ' &amp; codeAndZone;
		else
			tmpCaption := _caption;
		endif;
		
		if tmpCaption.length &gt; 255 then
			tmpCaption := _caption[1:200] &amp; '... ' &amp; codeAndZone;
		endif;
		
		self.caption := tmpCaption;
	else
		self.caption := _caption;
	endif;
end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
