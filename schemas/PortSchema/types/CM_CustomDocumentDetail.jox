    </JadeMethod>
    <JadeMethod name="erase" id="d89d05e9-8ead-43b9-9147-c41af141d16c">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars
	custDoc : CM_CustomDocument;
begin
	// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	custDoc := self.getCustomDocumentHeader(); // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
	if custDoc &lt;&gt; null then
		custDoc.removeTI(self.myTrackedItem);
	endif;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="ca546d05-d981-4f26-80f4-7e9a9416f689">
        <source>getAuditText(): String;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars
	txt,
	tmpStr	: String;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
//	txt := txt &amp;'Incoterm'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCustomDocumentHeader" id="a41b915d-5edb-4e0d-b117-e84625f69487">
        <source>getCustomDocumentHeader() : CM_CustomDocument;
/*
Purpose - 	
Who - NAVAB1
Date - 04SEP2023
ADO - CR 59942 TASK 59943 
*/

vars

begin
	if self.myParentCustomDocument &lt;&gt; null then
		return self.myParentCustomDocument;
	endif;
	if self.myParentCustomDocumentDetail &lt;&gt; null then
		return self.myParentCustomDocumentDetail.myParentCustomDocument;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a785de05-3c47-4a4e-b6b3-6ea38c6328c9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	str, type : String;
	ct : CM_CargoType;
	cg : CM_CargoGroup;
	st : CM_Product;
	cm : CM_Commodity;
begin
	
	if _attrName = ETRow_IncludeChk then
		return self.included.getYesNo();
// ### TFS CR 60424 TASK 60549 19SEP2023 NAVAB1	elseif _attrName = ETRow_ClearedVolume then
// ### TFS CR 60424 TASK 60549 19SEP2023 NAVAB1		return self.clearedVolume.String;
	elseif _attrName = ETRow_ClearedQuantity then
		return self.clearedQuantity.String;
	elseif _attrName = ETRow_TotalQuantity then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.totalQuantity.asStringJMT;
		endif;
	elseif _attrName = ETRow_OriginalQuantity then // ### TFS CR 60424 TASK 60549 25SEP2023 NAVAB1
		return self.originalQuantity.String;
	elseif _attrName = ETRow_ReleasedQuantity then // ### TFS CR 60424 TASK 60549 25SEP2023 NAVAB1
		return self.releasedQuantity.String;

	elseif	_attrName = ETRow_Included or
			_attrName = ETRow_Include then
		return self.included.getYesNo();
	elseif 
		_attrName = ETRow_IMEXStatus or
		_attrName = ETRow_CargoId or
		_attrName = ETRow_CargoGroupId or
		_attrName = ETRow_CommodityCode or
		_attrName = ETRow_Commodity or
		_attrName = ETRow_CommodityDesc or 
		_attrName = ETRow_CargoTypeCode or
		_attrName = ETRow_CargoTypeDesc or
		_attrName = ETRow_CargoSubTypeCode or
		_attrName = ETRow_CargoSubTypeDesc or
		_attrName = ETRow_ImexStatus or
		_attrName	= ETRow_VesselCode or
		_attrName	= ETRow_Location or // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
		_attrName	= ETRow_Site or // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
		_attrName	= ETRow_CustomsStatus or // ### TFS CR 59942 TASK 59943 06SEP2023 NAVAB1
		_attrName	= ETRow_CountryOfOriginRgnCode or // ### TFS CR 59942 TASK 59943 06SEP2023 NAVAB1
		_attrName	= ETRow_CountryOfOriginRegion or // ### TFS CR 59942 TASK 59943 06SEP2023 NAVAB1
		_attrName	= ETRow_CountryOfDestRegion or // ### TFS CR 59942 TASK 59943 06SEP2023 NAVAB1
		_attrName	= ETRow_CountryOfDestRegionCode or // ### TFS CR 59942 TASK 59943 06SEP2023 NAVAB1
		_attrName	= ETRow_VoyageCode or
		_attrName	= ETRow_Remarks then
		if self.myTrackedItem &lt;&gt; null then
			// ### TFS CR 59942 TASK 59943 06SEP2023 NAVAB1 moved to CM_CargoGroup
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;

	elseif _attrName = ETRow_IncludeDetail then
		return self.included.getYesNo();
	elseif _attrName.isMeasurementType() then 
		_attrName.getRowNameMeasureType(str, type);
		return self.getMeasurementStringForAttrib(str, type, _short); 
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="8335a601-c0e8-461a-a12a-051ebfff25d6">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars

begin
	if _attrName = ETRow_TotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.myTrackedItem.totalWeight); // ### TFS BUG 59668 31AUG2023 NAVAB1 - use TOTAL WEIGHT
	elseif _attrName = ETRow_TotalVolume then
		return app.convertMeasurementForDisplay(_measureType, self.myTrackedItem.totalVolume); // ### TFS BUG 59668 31AUG2023 NAVAB1 - use TOTAL VOLUME
	elseif _attrName = ETRow_ClearedWeight then
		return app.convertMeasurementForDisplay(_measureType, self.clearedWeight);
	elseif _attrName = ETRow_ClearedVolume then
		return app.convertMeasurementForDisplay(_measureType, self.clearedVolume);
 
	elseif _attrName = ETRow_OriginalWeight then // ### TFS CR 60424 TASK 60549 25SEP2023 NAVAB1
		return app.convertMeasurementForDisplay(_measureType, self.originalWeight);
	elseif _attrName = ETRow_OriginalVolume then // ### TFS CR 60424 TASK 60549 25SEP2023 NAVAB1
		return app.convertMeasurementForDisplay(_measureType, self.originalVolume);
	elseif _attrName = ETRow_ReleasedWeight then // ### TFS CR 60424 TASK 60549 25SEP2023 NAVAB1
		return app.convertMeasurementForDisplay(_measureType, self.releasedWeight);
	elseif _attrName = ETRow_ReleasedVolume then // ### TFS CR 60424 TASK 60549 25SEP2023 NAVAB1
		return app.convertMeasurementForDisplay(_measureType, self.releasedVolume);
    endif;
    return null;
	

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPrevCustDoc" id="23abaf2e-e68c-4d7b-8762-ea1bd497c636">
        <source>getPrevCustDoc() : CM_CustomDocument;
/*
Purpose:			

Date		Who		Reason
18 August 2023	navab1	CR 59615 TASK 59620
*/

vars
	custDoc, myCustDoc, prevCustDoc : CM_CustomDocument;
	seq : Integer;
	ti : CM_TrackedItem;
begin
	
	// ### Get my custom Document, might be via the cargo group's custom document
	myCustDoc := self.getCustomDocumentHeader();// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
	
	seq := myCustDoc.sequence;
	ti := self.myTrackedItem;

	foreach custDoc in ti.allCustomDocuments reversed, discreteLock do
		// ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1
		if custDoc.isCancelled() then
			continue;
		endif;
		if custDoc.sequence &lt; seq
		and custDoc.direction = myCustDoc.direction then
			prevCustDoc := custDoc;
			break;
		endif;
	endforeach;
	
	return prevCustDoc;

epilog

end;</source>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="getPrevCustDocDetail" id="d421573d-bf78-449e-9b9a-9787096938bd">
        <source>getPrevCustDocDetail() : CM_CustomDocumentDetail;
/*
Purpose:			

Date		Who		Reason
18 August 2023	navab1	CR 59615 TASK 59620
*/

vars
	custDoc, myCustDoc, prevCustDoc : CM_CustomDocument;
	realMe, prevCustDocDetail : CM_CustomDocumentDetail;
	seq : Integer;
	ti : CM_TrackedItem;
	cg : CM_CargoGroup;
	foundme : Boolean;
begin
	
	// ### Get my custom Document, might be via the cargo group's custom document
	prevCustDoc := self.getPrevCustDoc();
	
	if prevCustDoc = null then
		return null;
	endif;

	foreach prevCustDocDetail in prevCustDoc.allCustomDocumentDetails discreteLock 
		where prevCustDocDetail.included do
		if prevCustDocDetail.myTrackedItem = ti then
			return prevCustDocDetail;
		endif;
	endforeach;

	// ### Might be via the cargo group's custom document
	if cg &lt;&gt; null then
		foreach prevCustDocDetail in prevCustDoc.allCustomDocumentDetails discreteLock 
			where prevCustDocDetail.included do
			if prevCustDocDetail.myTrackedItem = cg then
				return prevCustDocDetail;
			endif;
		endforeach;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_CustomDocumentDetail"/>
    </JadeMethod>
    <JadeMethod name="handleMerge4SourceAdjustment" id="a173de01-3639-430b-a61e-fd351f61ce5f">
        <updating/>
        <source>handleMerge4SourceAdjustment(_moveAmount : Decimal) updating;
/*
Purpose:			

Date		Who		Reason
13 September 2023	navab1	CR 59942 TASK 59943 
*/
// ### TFS CR 60922 TASK 60980 30OCT2023 NAVAB1 renamed
vars
	ti : CM_TrackedItem;
	diffQty, newClearedQty, clearedForTIQty : Integer;
	diffAmount, newClearedAmount, density : Decimal[23,4];
	ct : CM_CargoType;
begin
	ti := self.myTrackedItem;
	ct := ti.myCargoType;
	
	if ct.allowDuplicates then
		if ct.isBreakBulk then
			// ### QUANTITY
			
			diffQty := _moveAmount.Integer; // ### TFS 60922 TASK 60980 30OCT2023 NAVAB1 .originalQuantity - ti.totalQuantity;
			newClearedQty := self.clearedQuantity - diffQty;
			
			// ### TFS CR 60424 TASK 60549 03OCT2023 NAVAB1
			if newClearedQty &lt; 0 then 
				newClearedQty := 0;
			endif;
			self.clearedQuantity := newClearedQty;
				
		else
			if ct.isBulkByWeight() then
				// ### WEIGHT
				diffAmount := _moveAmount; // ### TFS 60922 TASK 60980 30OCT2023 NAVAB1self.originalWeight - ti.totalWeight;
				newClearedAmount := self.clearedWeight - diffAmount;

				// ### TFS CR 60424 TASK 60549 03OCT2023 NAVAB1
				if newClearedAmount &lt; 0 then 
					newClearedAmount := 0;
				endif;
				self.clearedWeight := newClearedAmount;
			else
				// ### VOLUME
				density := ti.getDensity().max(1);
				diffAmount := _moveAmount / density; // ### TFS 60922 TASK 60980 30OCT2023 NAVAB1 self.originalWeight - ti.totalVolume;
				newClearedAmount := self.clearedVolume - diffAmount;

				// ### TFS CR 60424 TASK 60549 03OCT2023 NAVAB1
				if newClearedAmount &lt; 0 then 
					newClearedAmount := 0;
				endif;
				self.clearedVolume := newClearedAmount;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_moveAmount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="handleMerge4TargetAdjustment" id="d189933b-e3aa-42bb-b27f-5ee9eb9f66fc">
        <updating/>
        <source>handleMerge4TargetAdjustment(_mergeToCargo: CM_TrackedItem; _moveAmount : Decimal ) updating;
/*
Purpose:			

Date		Who		Reason
30 October 2023	navab1	60922 TASK 60980
*/

vars
	ti : CM_TrackedItem;
	myClearedQty, combinedClearedQty, clearedForTIQty : Integer;
	myClearedAmt, combinedClearedAmount, clearedForTIAmt, density : Decimal[23,4];
	ct : CM_CargoType;
begin
	ti := self.myTrackedItem;
	ct := ti.myCargoType;
	
	if ct.allowDuplicates then
		if ct.isBreakBulk then
			// ### QUANTITY
			clearedForTIQty := _mergeToCargo.getCustDocClearedQuantityForId();
			myClearedQty := self.clearedQuantity; // for debugging
			combinedClearedQty := (self.clearedQuantity + _moveAmount).Integer;
			if clearedForTIQty &lt; combinedClearedQty then
				self.clearedQuantity := clearedForTIQty;
			else
				self.clearedQuantity := combinedClearedQty;
			endif;
		else
			if ct.isBulkByWeight() then
				// ### WEIGHT
				clearedForTIAmt := _mergeToCargo.getCustDocClearedWeightForId();
				myClearedAmt := self.clearedWeight; // for debugging
				combinedClearedAmount := (self.clearedWeight + _moveAmount).Integer;
				if clearedForTIAmt &lt; combinedClearedAmount then
					self.clearedWeight := clearedForTIAmt;
				else
					self.clearedWeight := combinedClearedAmount;
				endif;
			else
				// ### VOLUME
				density := ti.getDensity().max(1);
				clearedForTIAmt := _mergeToCargo.getCustDocClearedVolumeForId();
				myClearedAmt := self.clearedVolume; // for debugging
				combinedClearedAmount := (self.clearedVolume + _moveAmount).Integer;
				if clearedForTIAmt &lt; combinedClearedAmount then
					self.clearedVolume := clearedForTIAmt;
				else
					self.clearedVolume := combinedClearedAmount;
				endif;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_mergeToCargo" type="CM_TrackedItem"/>
        <Parameter name="_moveAmount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="handleStops" id="7e076167-3997-4b3e-af88-3027a2c6476f">
        <updating/>
        <source>handleStops(_oldDocType : CM_CustomDocumentType) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 26SEP2023
ADO - CR 60424 TASK 60549  
*/

vars
	allTIs : CM_TISet;
	stop : CM_StopsTable;
	docType : CM_CustomDocumentType;
	ti, cgti, proxyTI : CM_TrackedItem;
	cg : CM_CargoGroup;
	pxyStop : CM_Stops;
	cdd, subCDD : CM_CustomDocumentDetail;
	docTypeChange : Boolean;
	cd : CM_CustomDocument;
begin
	
	create allTIs transient; // do here so epilog is OK

	cd := self.getCustomDocumentHeader();
	
	docType:= cd.myCustomDocumentType;
	
	if docType = null then
		return;
	endif;
	
	if docType.allStopsToApply.isEmpty
	and docType.allStopsToClear.isEmpty then
		return;
	endif;
	
	if docType &lt;&gt; _oldDocType
	and _oldDocType &lt;&gt; null then
		docTypeChange := true;
	endif;
	
	ti := self.myTrackedItem;
		
	if ti.isCargoGroupItem then
		foreach subCDD in self.allSubDetails discreteLock 
					where subCDD.included do

			cgti := subCDD.myTrackedItem;
			proxyTI	:= app.createUpdateProxy( cgti ).CM_TrackedItem;
			allTIs.add(proxyTI);
			// ### Apply proxy stops to the proxy TIs
			subCDD.applyStops(proxyTI, docType.allStopsToApply, true);
			// ### Clear proxy stops for the proxy TIs
			subCDD.clearStops(proxyTI, docType.allStopsToClear);
			
			if docTypeChange then
				// ### Apply proxy stops to the proxy TIs
				subCDD.applyStops(proxyTI, _oldDocType.allStopsToClear, true);
				// ### Clear proxy stops for the proxy TIs
				subCDD.cancelStops(proxyTI, _oldDocType.allStopsToApply);
			
			
			endif;
		
		endforeach;
	else
		proxyTI	:= app.createUpdateProxy( ti ).CM_TrackedItem;
		allTIs.add(proxyTI);
		// ### Apply proxy stops to the proxy TIs
		self.applyStops(proxyTI, docType.allStopsToApply, true);
		// ### Clear proxy stops for the proxy TIs
		self.clearStops(proxyTI, docType.allStopsToClear);
			
		if docTypeChange then
			// ### Apply proxy stops to the proxy TIs
			self.applyStops(proxyTI, _oldDocType.allStopsToClear, false);
			// ### Clear proxy stops for the proxy TIs
			self.cancelStops(proxyTI, _oldDocType.allStopsToApply);
		
		
		endif;
	
	endif;

	
	// ### Update the stops on the TIs
	foreach ti in allTIs do
		app.myUtilityUA.utlUpdateTrackedItem(ti, null, TI_UPDMODE_NORMAL, null, null, null, app.myPassport); 
		if (not app.myPassport.noErrors) then
			break;
		endif;
	endforeach;
	
epilog
	allTIs.purge();
	delete allTIs;
end;</source>
        <Parameter name="_oldDocType" type="CM_CustomDocumentType"/>
    </JadeMethod>
