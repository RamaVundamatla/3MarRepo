<Class name="JadeScript">
    <JadeMethod name="abc" id="ed375a0d-18df-45b3-b0ae-a26e90996898">
        <source>abc();

vars
	alert 		: CM_SystemAlert;
	editForm	: CMUI_RemoteDataEditForm;
	remoteHdr	: CM_RemoteDataHdr;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode('SUPERUSER');
	foreach alert in CM_SystemAlert.instances do
		if alert.myRemoteDataHdr &lt;&gt; null then
			break;
		endif;
	endforeach;
		remoteHdr := alert.myRemoteDataHdr;
		create editForm transient;
		editForm.initialize(remoteHdr);
		editForm.openWithSavedSettings();//4 sep 2008 cnwdz2 par17846
		editForm.show();
end;</source>
    </JadeMethod>
    <JadeMethod name="abdebug" id="e97036ca-09d5-4fcf-bbe5-a109670fb209">
        <source>abdebug();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2017	jlgab1	Initial creation

*/

vars
	root : CM_Root;
	term : CM_Terminal;
	tran, tmptran : CM_TITransaction;
	invline, pxyInvoiceLine : CM_InvoiceLine;
	cont : CM_TrackedItem;
	cargo, lastcargo, pxyCargo : CM_TrackedItem;
	cargoItems : DynaDictionary;
	iter : Iterator;
	 con, id,  lastcon : String;
	controller : CMIF_TiTransactionResync;
	ct,lastct,totalqty, origqty : Integer;
	theStatus : CMIF_InvoiceStatus;
	resycTrans : CM_TITransactionSet;
	voidTrans : CM_TITransactionSet;
	resyncTIs : CM_TISet;
	voidTIs : CM_TISet;
	load : Boolean;
    err : CM_Error;
	trans : CM_TITransactionSet;
begin
	root := CM_Root.firstInstance;
	
	term := root.allTerminals["BISH"];
	app.initialize();
	app.myPassport.setMyUserFromCode("CNWAB1");
	app.myPassport.setMyTerminal(term);
	
    create cargoItems transient;
    cargoItems.setMembership(CM_TrackedItem);
    cargoItems.addMemberKey("cargoType", false, false);
    cargoItems.addMemberKey("consignee", false, false);
    cargoItems.addMemberKey("id", false, false);
    cargoItems.endKeys(true);
	
	
	create resycTrans transient;
	create voidTrans transient;
	create resyncTIs transient;
	create voidTIs transient;
	
	
	cont := term.allOnsiteTIsByIdCargoType["PACK1709154",1];
	
	// #### GET ALL THE EX CHILDREN
	foreach tran in cont.allTransactions	discreteLock do
		if tran.type = TRANS_TYPE_UNPACK then
			cargo := tran.CM_Unpack.getOtherTrackedItem();
			
			if cargo &lt;&gt; null then
		write cargo.cargoTypeDescr &amp; " " &amp; cargo.consignee &amp; " " &amp; cargo.id &amp; " " &amp; tran.totalQuantity.String;
				cargoItems.addNoDuplicates(cargo, false);
			endif;
		endif;
	endforeach;
	
	// #### GET ALL THE TIs FOR RESYCH
	iter := cargoItems.createIterator;
    while iter.next(cargo) do	
		cargoItems.getIteratorKeys(ct, con, id, iter);
		
		if lastct &gt; 0 and (lastct &lt;&gt; ct or lastcon &lt;&gt; con) then
				resyncTIs.addNoDuplicates(lastcargo, false);
		endif;
	
	
		lastcargo := cargo;
		lastct := ct;
		lastcon := con;
	endwhile;
	
	if lastcargo &lt;&gt; null then
				resyncTIs.addNoDuplicates(lastcargo, false);
	endif;
			
			
	iter.reset(); 
    while iter.next(cargo) do	
		if not resyncTIs.includes(cargo) then
			voidTIs.add(cargo);
		endif;
	endwhile;
	
	// #### GET THE UNPACK TRANSACTIONS FOR THE RESYCH CARGO
	totalqty := 0;
	foreach lastcargo in resyncTIs	discreteLock do
		tran := lastcargo.getTransactionOfType(TRANS_TYPE_UNPACK);
		if tran &lt;&gt; null then
			resycTrans.add(tran);
		endif;
		trans := lastcargo.getTransOfType(TRANS_TYPE_UNPACK);
		foreach tmptran in trans do
			if tmptran &lt;&gt; tran then
				voidTrans.addNoDuplicates(tmptran, false);
			endif;
		endforeach;
	
		// #### GET THE TOTAL QUANTITY FOR EACH RESYCH
		iter.reset();
		while iter.next(cargo) do	
			cargoItems.getIteratorKeys(ct, con, id, iter);
			if ct = lastcargo.cargoType and con = lastcargo.consignee then
					tmptran := lastcargo.getTransactionOfType(TRANS_TYPE_UNPACK);
					if tmptran &lt;&gt; null then
						if tmptran.cargoWeight &gt; 0 then // ORIGINAL QUANTITY on the transaction used for resynch
								totalqty := totalqty + tmptran.cargoWeight.Integer; // ORIGINAL QUANTITY
						else
							if tran.totalQuantity &gt; 0 then
								totalqty := totalqty + tmptran.totalQuantity;
							else
								totalqty := totalqty + cargo.totalQuantity;
							
							endif;
						endif;
					endif;
			endif;
		endwhile;
	
		
		if tran &lt;&gt; null then
			// #### WE NEED TO UPDATE THE QUANTITY ON THE TRANS AND THEN RESYCH IT
			// #### HOWEVER WE CAN ONLY UPDATE THE QUANTITY ON THE TRANS FROM THE CARGO
			// #### SO WE MUST UPDATE THE CARGO, RESYCH THE TRANS AND THEN UPDATE THE CARGO WITH THE ORIGINAL QUANTITY
			
		write lastcargo.cargoTypeDescr &amp; " " &amp; lastcargo.consignee &amp; " " &amp; lastcargo.id &amp; " RESYNC QTY: " &amp; totalqty.String;
			
			// #### UPDATE THE CARGO WITH THE NEW QUANTITY
			origqty := lastcargo.totalQuantity;
			app.cmsBeginLoad( load );
			pxyCargo := lastcargo.pxyCreateUpdateProxy().CM_TrackedItem;
			app.cmsEndLoad( load );
			if lastcargo.weightCargo = 0 then
				pxyCargo.setWeightCargo(lastcargo.totalQuantity);
			endif;
			pxyCargo.setTotalQuantity( totalqty );
			
			app.myTrxUA.trxUpdateTrackedItem( pxyCargo, null, TI_UPDMODE_NORMAL, null, app.myPassport );
			
			if not app.myPassport .allErrorWarnings.isEmpty then
				foreach err in app.myPassport .allErrorWarnings do
			
				write "ERROR: trxUpdateTrackedItem 1 - " &amp; err.text;
				endforeach;
			endif;
			delete pxyCargo;
			
			// #### RESYNCH TRANSACTION WITH NEW AMOUNT
			create controller transient;
			controller.allTransactions.add(tran);
			controller.myTrackedItem := lastcargo;
			controller.updateQuantity := true;
			controller.force := true;
			app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
			if not app.myPassport .allErrorWarnings.isEmpty then
				foreach err in app.myPassport .allErrorWarnings do
				write "ERROR: trxUpdateRsyncTrans - " &amp; err.text;
				endforeach;
			endif;
			delete controller;

			// #### UPDATE THE CARGO WITH THE ORIGINAL QUANTITY
			app.cmsBeginLoad( load );
			pxyCargo := lastcargo.pxyCreateUpdateProxy().CM_TrackedItem;
			app.cmsEndLoad( load );
			pxyCargo.setTotalQuantity( origqty );
			
			app.myTrxUA.trxUpdateTrackedItem( pxyCargo, null, TI_UPDMODE_NORMAL, null, app.myPassport );
			if not app.myPassport .allErrorWarnings.isEmpty then
				foreach err in app.myPassport .allErrorWarnings do
				write "ERROR: trxUpdateTrackedItem 2 - " &amp; err.text;
				endforeach;
			endif;
			delete pxyCargo;
		endif;
			
			
		totalqty := 0;
	
	endforeach;
	
	
	// #### VOID ALL THE UNPACK INVOICE LINES ON THE VOID CARGO
	foreach lastcargo in voidTIs	discreteLock do
			write lastcargo.cargoTypeDescr &amp; " " &amp; lastcargo.consignee &amp; " " &amp; lastcargo.id &amp; " VOIDED" ;
			
			trans := lastcargo.getTransOfType(TRANS_TYPE_UNPACK);
//			tran := lastcargo.getTransactionOfType(TRANS_TYPE_UNPACK);
			create theStatus transient;
			theStatus.newStatus := CM_InvoiceLine.STATUS_VOIDED;

			foreach tran in trans	discreteLock do
				foreach invline in tran.allInvoiceLines 	discreteLock where invline.status = CM_InvoiceLine.STATUS_NORMAL do
						pxyInvoiceLine := app.createUpdateProxy(invline).CM_InvoiceLine;
						theStatus.allInvoiceLines.add(pxyInvoiceLine);
				endforeach;
			endforeach;
	
			
			theStatus.voidReason:= "Voided in Resynce Hook Code For Container Unpack Complete";
			app.myTrxUA.trxUpdateInvoiceStatus(theStatus,app.myPassport);
				foreach err in app.myPassport .allErrorWarnings do
				write "ERROR: trxUpdateInvoiceStatus - " &amp; err.text;
				endforeach;
			delete theStatus;
		
	endforeach;
	
	if not voidTrans.isEmpty then
			create theStatus transient;
			theStatus.newStatus := CM_InvoiceLine.STATUS_VOIDED;

			foreach tran in voidTrans	discreteLock do
				foreach invline in tran.allInvoiceLines 	discreteLock where invline.status = CM_InvoiceLine.STATUS_NORMAL do
						pxyInvoiceLine := app.createUpdateProxy(invline).CM_InvoiceLine;
						theStatus.allInvoiceLines.add(pxyInvoiceLine);
				endforeach;
			endforeach;
	
			
			theStatus.voidReason:= "Voided in Resynce Hook Code For Container Unpack Complete";
			app.myTrxUA.trxUpdateInvoiceStatus(theStatus,app.myPassport);
				foreach err in app.myPassport .allErrorWarnings do
				write "ERROR: trxUpdateInvoiceStatus - " &amp; err.text;
				endforeach;
			delete theStatus;
	
	endif;
		
	
	
epilog
			delete pxyCargo;
	delete controller;
	delete cargoItems;
	delete iter;
	delete theStatus;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkStockMoves" id="78cd4353-2863-4609-83cf-22771503f67a">
        <source>checkStockMoves();
// ---------------------------------------------------------------------------
// Created:     03 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpLC		: CM_LocationsController;
	tmpSOHLocn	: CM_SOHLocation;
	tmpBucket	: CM_StockMoveLocation;
	tmpStkMove	: CM_StockMovement;
	tiTrans		: CM_TITransaction;
	iter		: Iterator;
	startDate	: Date;
	fl			: File;
	diffStr,
	tmpStr		: String;
	totDiff,
	transWeight,
	tiWeight,
	diffWeight	: Decimal[14,4];
	startPos,
	endPos		: Integer;
	
begin

	startDate.setDate(3, 12, 2003);
	tmpLC := '4353.13231'.asOid.CM_LocationsController;
	//tmpLC := CM_LocationsController.firstInstance;

	create fl transient;
	fl.mode := File.Mode_Output; // 1/3/16  cnwns1 PAR 36286 unicode version
	fl.usePresentationFileSystem := true;
	fl.fileName := 'c:\temp\checkStockMoves.log';
	
	foreach tmpSOHLocn in tmpLC.allProductLocations do
		iter := tmpSOHLocn.allStockMovementsByDate.createIterator;
		tmpSOHLocn.allStockMovementsByDate.startKeyGeq(startDate, iter);
		while iter.next(tmpBucket) do
			fl.writeLine('=== processing ' &amp; tmpBucket.date.String &amp; ' ===');
			foreach tmpStkMove in tmpBucket.allStockMovements do
				fl.writeLine('Handling Type ' &amp; tmpStkMove.type.String);
				foreach tiTrans in tmpStkMove.CM_StockMovementLocation.allTITransactions do
					if tiTrans.isKindOf(CM_Edit) then
						tmpStr := tiTrans.CM_Edit.fieldsValues.getAsEditPair();
						startPos := tmpStr.pos('weight', 1);
						if startPos &gt; 0 then
							startPos := tmpStr.pos(' =&gt; ', startPos) + 4;
							endPos := tmpStr.pos(':', startPos);
							
							transWeight := tmpStr[startPos : (endPos - startPos + 1)].Integer;
							//tiWeight := tiTrans.myTrackedItem.weight;					//-cnwml2 MSL CCMS 1017
							tiWeight := tiTrans.myTrackedItem.totalWeight;				//+cnwml2 MSL CCMS 1017
							diffWeight := transWeight - tiWeight;
							if diffWeight &lt;&gt; 0 then
								diffStr := '  +++ diff of ' &amp; diffWeight.String;
								totDiff := totDiff + diffWeight;
							else
								diffStr := null;
							endif;
							fl.writeLine(tiTrans.id &amp; '  &gt;&gt;&gt; ' &amp; tmpStr &amp; '  ' &amp; transWeight.String &amp; '  ' &amp; tiWeight.String &amp; '  ' &amp; diffStr);
						endif;
					endif;
				endforeach;
			endforeach;
		endwhile;
	endforeach;
	
	fl.writeLine('TOTAL DIFF = ' &amp; totDiff.String);

epilog
	if fl &lt;&gt; null then
		fl.close;
		delete fl;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkTITransStockMoves" id="a2f453df-8c34-4d47-856d-001ee8d40125">
        <source>checkTITransStockMoves();
// ---------------------------------------------------------------------------
// Created:     03 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTI		: CM_TrackedItem;
	tmpLC		: CM_LocationsController;
	tmpSOHLocn	: CM_SOHLocation;
	tmpBucket	: CM_StockMoveLocation;
	tmpStkMove	: CM_StockMovement;
	tiTrans		: CM_TITransaction;
	iter		: Iterator;
	startDate	: Date;
	file		: File;
	diffStr,
	tmpStr		: String;
	totDiff,
	transWeight,
	tiWeight,
	diffWeight	: Decimal[14,4];
	startPos,
	endPos		: Integer;
	
begin

	startDate.setDate(3, 12, 2003);
	tmpLC := '4353.13231'.asOid.CM_LocationsController;

	create file transient;
	file.mode := File.Mode_Output; // 1/3/16  cnwns1 PAR 36286 unicode version
	file.usePresentationFileSystem := true;
	file.fileName := 'c:\temp\checkTITransStockMoves.log';
	
	foreach tmpSOHLocn in tmpLC.allProductLocations do
	
		foreach tmpTI in tmpSOHLocn.allTrackedItems do
			delete iter;
			iter := tmpTI.allTransactions.createIterator;
			tmpTI.allTransactions.startKeyGeq(startDate.TimeStamp, 0, iter);
			
			while iter.next(tiTrans) do
			
				if CM_Create.hasInstance(tiTrans) or
				   CM_ReceiveRoad.hasInstance(tiTrans) then
				   	continue;
				endif;
			
				tmpStkMove := tiTrans.getMyStockMovement();
				
				file.writeLine(tmpTI.id &amp; Tab &amp; tiTrans.String &amp; Tab &amp; tmpStkMove.String);

				if tiTrans.isKindOf(CM_Edit) and tmpStkMove = null then
					tmpStr := tiTrans.CM_Edit.fieldsValues.getAsEditPair();
					startPos := tmpStr.pos('weight', 1);
					if startPos &gt; 0 then
						startPos := tmpStr.pos(' =&gt; ', startPos) + 4;
						endPos := tmpStr.pos(':', startPos);
						
						transWeight := tmpStr[startPos : (endPos - startPos + 1)].Integer;
						//tiWeight := tiTrans.myTrackedItem.weight;  			//-cnwml2 MSL CCMS 1017
						tiWeight := tiTrans.myTrackedItem.totalWeight;			//+cnwml2 MSL CCMS 1017
						diffWeight := transWeight - tiWeight;
						if diffWeight &lt;&gt; 0 then
							diffStr := '  +++ diff of ' &amp; diffWeight.String;
							totDiff := totDiff + diffWeight;
						else
							diffStr := null;
						endif;
						file.writeLine(tiTrans.id &amp; '  &gt;&gt;&gt; ' &amp; tmpStr &amp; '  ' &amp; transWeight.String &amp; '  ' &amp; tiWeight.String &amp; '  ' &amp; diffStr);
					endif;
				endif;
			endwhile;
		endforeach;
	
	endforeach;
	
epilog
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;
end;</source>
    </JadeMethod>
