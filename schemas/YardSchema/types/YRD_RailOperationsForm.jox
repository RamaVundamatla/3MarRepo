    <JadeMethod name="frmGridArea_dblClick" id="a921b5d1-1038-440e-96b7-eed89ce5b5da">
        <controlMethod name="CMUI_GridAreaFrame::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmGridArea_dblClick(frame: Frame input) updating;
//--------------------------------------------------------------
//Created: 04 April 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	gridPoint : CMUI_GridPoint;
	locnCntrl : CM_LocationsController;
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if (not frame.isKindOf(CMUI_GridAreaFrame)) then
		return;
	endif;
	
	gridPoint := frame.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(self.origXPos, self.origYPos); 

	if gridPoint &lt;&gt; null then
		if gridPoint.isKindOf(YRD_WagonBody) or gridPoint.isKindOf(YRD_WagonWheels) then
			//self.showWagonEnquiryForm(gridPoint.myGridArea.YRD_WagonArea.myWagon);
			self.showWagonMaintForm(gridPoint.myGridArea.YRD_WagonArea.myWagon,YRD_TrainWagonForm.Mode_View, null);
			return;
			
		elseif gridPoint.isKindOf(YRD_WagonPoint) and gridPoint.YRD_WagonPoint.isBoxcar then	//08 Apr 2013	NDL	Par 31278
			locnCntrl := gridPoint.YRD_WagonPoint.myLocationsController;
			if locnCntrl &lt;&gt; null then
				self.myAssistant.showLocationEnquiryForm(locnCntrl, self.myMasterMenuAction, false, false);		
			endif;
			
		else
			ti := gridPoint.getTI(self.origXPos, self.origYPos);
			if ti &lt;&gt; null then
				self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);
			endif;
			
		endif;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="frmGridArea_dragDrop" id="d6044140-c8e1-492a-be28-459b8cc00caf">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmGridArea_dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 03 April 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/06/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars
	gridPoint : CMUI_GridPoint;
begin

	if (not frame.isKindOf(CMUI_GridAreaFrame)) then
		return;
	endif;

	if app.myWagonMoveController &lt;&gt; null
	and self.wagonAreaReceiveDrop(frame.CMUI_GridAreaFrame.myGridArea.YRD_WagonArea) then
		return;
	endif;

	gridPoint := frame.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(x, y - 5); 
	self.gridPointRecieveDrop(frame, win, gridPoint, x, y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
