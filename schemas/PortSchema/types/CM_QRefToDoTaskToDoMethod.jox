    <JadeMethod name="setComboValues" id="ac57c363-4899-48fd-9f0a-e7f0e71f3295">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
// --------------------------------------------------------------------------------
// Created:		04 May 2010 by cnwjo3
//
// Purpose:		
//
// Parameters:	
//
// Returns:		Nothing
//
vars
	col : CM_ToDoTaskDescByShortDesc;
	task : CM_ToDoTaskDesc;
begin
	_combo.clear();
	
	col := app.myRoot.allToDoTaskDescsByShortDesc;

	foreach task in col do
		_combo.itemObject[_combo.addItem(task.shortDescription)] := task;
	endforeach;
	
	if CM_QStringContains.hasInstance(_queryOperator) then
		_combo.listObject := col[_queryOperator.CM_QStringContains.searchValue];
	endif;	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="30844d99-3d33-4b6d-b132-57ba87fbcde0">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
// --------------------------------------------------------------------------------
// Created:		04 May 2010 by cnwjo3
//
// Purpose:		
//
// Parameters:	
//
// Returns:		Nothing
//
vars
	set : ObjectArray;
	task : CM_ToDoTaskDesc;
	selectionValue : Boolean;
	allSelected : StringArray;
	shortDescription : String;
begin
	_tbl.rows := 0;
	
	if _params = null then
		return;
	endif;

	allSelected := _operator.CM_QStringIsOneOf.allSelectionValues;
	
	//doesn't know about CMUI_ListTable - so have to do this:
	set := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	set.clear();
	
	foreach task in app.myRoot.allToDoTaskDescsByShortDesc do
		selectionValue := true;
		set.add(task);

		shortDescription := task.shortDescription;
		if allSelected.includes(shortDescription) then
			_tbl.accessRow(_tbl.addItem(1.String &amp; Tab &amp; shortDescription)).itemObject := task;
		else
			_tbl.accessRow(_tbl.addItem(0.String &amp; Tab &amp; shortDescription)).itemObject := task;
		endif;
	endforeach;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="c010a2bd-61f2-40af-a4f9-bbc7fb55ca43">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// --------------------------------------------------------------------------------
// Created:		04 May 2010 by cnwjo3
//
// Purpose:		
//
// Parameters:	
//
// Returns:		Nothing
//
vars
	task		: CM_ToDoTaskDesc;
	str			: String;
	numRows,
	idx			: Integer;
	sa			: StringArray;

begin

	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			task := _tbl.accessRow(idx).itemObject.CM_ToDoTaskDesc;
			sa.add(task.shortDescription);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="5adff96c-b830-4170-aaa3-eaaebd2fd3df">
        <source>translateToDisplayValue(_value: Any): String;
// --------------------------------------------------------------------------------
// Created:		04 May 2010 by cnwjo3
//
// Purpose:		
//
// Parameters:	
//
// Returns:		Nothing
//
vars

begin
	if _value.isKindOf(CM_ToDoTaskDesc) then
		if _value &lt;&gt; null then
			return _value.CM_ToDoTaskDesc.shortDescription;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="7aee43d0-908f-4100-b6e8-962c39c4f3f9">
        <source>translateToSearchValue(_value: Any): Any;
// --------------------------------------------------------------------------------
// Created:		04 May 2010 by cnwjo3
//
// Purpose:		
//
// Parameters:	
//
// Returns:		Nothing
//
vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_ToDoTaskDesc) then
			return _value.CM_ToDoTaskDesc.shortDescription;
		endif;
	endif;
	
	return app.myRoot.allToDoTaskDescsByShortDesc[_value.String];
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
