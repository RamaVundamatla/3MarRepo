    <JadeMethod name="fillNoLoggingCalls" id="9d7d55be-f807-454c-aa21-6a69a6a87928">
        <updating/>
        <source>fillNoLoggingCalls() updating, protected;
/*

Purpose:	
	This method has the APIs that dont need to be logged, so in case you add a new REST hander, 
	and you wish that it not be logged, please add it to the list below		

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2022	navra1	Initial creation

*/

vars

begin	
	self.allLoggingExclusions.add("ping");	//navra1 - 24th Aug 2022 - TFS 50365 
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="finaliseResponse" id="ae630092-4e0a-4cae-9108-c63480abd999">
        <updating/>
        <source>finaliseResponse(_response : WS_InterfaceObject input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2019	jlger1	Initial creation 44759
14 July 2019	jlgrr1	Added Response Code if error
*/

vars

begin
	
epilog
	
	// Copy any errors and warnings to the response before returning it
	if _response &lt;&gt; null then
		
		_response.setErrorsFromPassport();
		
		if self.httpStatusCode = HttpResponseOK then
			self.httpStatusCode := _response.getResponseCode();
		endif;
		
		self.objectsToBeDeleted.add(_response);
	endif;
	
	// this will avoid the annoying 100010 exception 
	if self.startCnTrx &lt;&gt; null then
		self.cnEndTransactionEx(self.startCnTrx);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_response" type="WS_InterfaceObject" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDemo" id="58d9cd04-f7fc-41df-8467-02344c170f6e">
        <updating/>
        <source>getDemo(paramList : ParamListType) : WS_Response updating;
/*order

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlgrr1	Initial creation

*/

vars
	response : WS_Response;
	terminal : CM_Terminal;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
		
	if app.myPassport.hasErrors then
		app.writeLog("Passport has errors", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
			
	
	terminal := app.myPassport.myTerminal;
	
	// Retrieve the actual information

	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="paramList" type="ParamListType"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="getForbidden" id="d06f1419-be28-4a03-9736-d0e556019fa9">
        <updating/>
        <source>getForbidden() /*: WS_NAPIResponse*/ updating;
/*

Purpose:			
Empty method to process when Licensing checks fail so this can be done in ProcessRequest instead of each web method

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2020	jlgrr1	Initial creation TFS 49632
07 Sep 2021	navdap1	TFS 50853 Reefer App Permission and License Checks
26 Jul 2023 navmd1	TFS 58575 MasterTerminalAPI processRequest not clearing passport
*/

vars
	response : WS_NAPIResponse;			// TFS 50853

begin	
	// Doesn't return a response - simply sets the status code
	self.httpStatusCode := HttpResponseForbidden;
	
	// TFS 50853 Change to return a reponse object, if we have errors on the passport, transfer to the response
	// This is to handle changes to validateLicense at the NReeferAPI level
	//if app.myPassport &lt;&gt; null and app.myPassport.hasErrors then
	//	self.startCnTrx := null;
	//	create response as WS_NAPIErrResponse;
	//endif;
	//return response;
epilog
	//if response &lt;&gt; null then
	//	self.finaliseResponse(response);
	//endif;
	
	// 58575 - If we come into here because of a license validation error then we *may* have already rasied an exception
	// So lets do what finaliseResponse would have done and clear the passport just in case
	if app.myPassport &lt;&gt; null then
		app.myPassport.clearErrorsWarnings();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getInfo" id="7f26d5c6-f050-4613-966e-497c495d473e">
        <updating/>
        <source>getInfo(): WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 June 2019	jlger1	Initial creation 44759
23 Nov 2021		navmd1	Changes to match Wmast prior to JADE 2020 cut
07 Dec 2021		navmd1	Changed response type to WS_Response to the REST '__type' magic string is included for OpsView

*/

vars
	user 			: CM_User;
	response 		: WS_AboutMtmResponse;
	terminalInfo 	: WS_InfoMessage;
	termCode     	: String;

begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	// An error code might be returned, but the info data will also always be returned
	if self.httpStatusCode &lt;&gt; HttpResponseOK then		
		// GET /Info should always return a response regardless of whether the user is logged in or not
		self.httpStatusCode := HttpResponseOK;
		app.myPassport.setMyUser(null);
	endif;
	
	create response transient;
	create terminalInfo transient;
	
	if app.myPassport.myTerminal &lt;&gt; null then
		termCode := app.myPassport.myTerminal.code;
	else
		termCode := "None";
	endif;
	
	terminalInfo.text := "Current Terminal: " &amp; termCode;
	response.allInfo.add(terminalInfo);

	return response;
epilog
	
	self.finaliseResponse(response);
	
end;</source>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="getJsonFormatError" id="80aa28a2-ce58-4e6f-b8fb-8017d3b85c48">
        <updating/>
        <source>getJsonFormatError(_errorCode : Integer; _errorItem : String) : WS_GAPIErrorResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
17 June 2022	navpw1	Initial creation TFS: 53883
26 July 2023	navmd1	TFS 58575 MasterTerminalAPI processRequest not clearing passport

*/

vars
	response : WS_GAPIErrorResponse;
	str : String;
begin
	self.httpStatusCode := HttpResponseClientError;
	
	str := _errorItem;
	str.replaceHTMLChars();
	
	create response transient;
	response.errorCode := _errorCode;
	response.errorItem := str;
	
	return response;
	
epilog
	if response &lt;&gt; null then
		self.objectsToBeDeleted.add(response);
		// Do the same as what finaliseResponse does and call response.setErrorsFromPassport
		// Then do the same as what setErrorsFromPassport does and clear the passwort!
		if app.myPassport &lt;&gt; null then
			app.myPassport.clearErrorsWarnings();
		endif;
	endif;
	
end;</source>
        <Parameter name="_errorCode" type="Integer"/>
        <Parameter name="_errorItem" type="String"/>
        <ReturnType type="WS_GAPIErrorResponse"/>
    </JadeMethod>
    <JadeMethod name="getLicenseCheck" id="278f29f0-a6b6-4a16-915e-cb1e38bfab52">
        <updating/>
        <source>getLicenseCheck() : String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2020	jlgrr1	Initial creation

*/

vars
	
begin
	// We don't want to pass a path here, as the path is only used to 'skip' the actual check in processRequest for specific requests
	return app.name &amp; " License Valid: " &amp; validateLicense(null).String;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocales" id="0626b41b-554a-4251-b1bb-4d0440fd4b2b">
        <updating/>
        <source>getLocales(): WS_AllLocalesResponse updating;
/*

Purpose: This is the REST version of the getAllLocales 

Parameters: 

Return Value:		

Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/


vars
	response 		: WS_AllLocalesResponse;	
	locale			: WS_Locale;
	sysLocale		: CM_Locale;
	defaultLocale 	: CM_Locale;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Create the response
	create response transient;
		
	self.initialisePassportPartial();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String, LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;		
	
	foreach sysLocale in app.myRoot.allLocales discreteLock do
		create locale transient;		
		locale.setProxyFromObject(sysLocale);
		response.allLocales.add(locale);
	endforeach;
		
	return response;
	
epilog
	finaliseResponse(response);	
end;</source>
        <ReturnType type="WS_AllLocalesResponse"/>
    </JadeMethod>
    <JadeMethod name="getLogout" id="dc1df9a6-61ef-448a-b2bc-1c04f71098d4">
        <updating/>
        <source>getLogout() : WS_Response updating;
/*

Purpose:			OAUTH-like authentication using JSON Web Tokens.
					Invalidates all Access and RefreshTokens.

Parameters:			A Bearer token containing a valid AccessToken

Return Value:		Nothing

Date				Who		Reason
15 April 2022		navmd1	Initial creation TFS 53378 REST Refactor / Generic API
27 July 2022 		navlw1	TFS 53854 MTN API Mapper

*/

vars
	response		: WS_Response;
	
	accessToken		: String;
	user			: CM_User;
	terminal		: CM_Terminal;
	audience		: String;
	
	nonceKeyName	: String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	self.httpStatusCode := HttpResponseUnauthorized;	// Default to 401 Unauthorised
	
	if app.myPassport.hasErrors then
		app.writeLog("Passport has errors after initialisePassport, so returning in getLogout()", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	
	// 1. Get the Access Token and make sure its still valid
	// Yes, we're pretty much validating twice, now that initialisePassport/initAuthorizedUser calls validateJWT too
	WS_WebServiceAgent@validateJWT(self.parseBearerAuth(), false, user, terminal, audience,self.allJWTClaims); // 27/07/2022 navlw1 tfs 53854
	if app.myPassport.hasErrors then
		app.writeLog("Passport has errors, so returning in getLogout()", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// 3. Invalidate everything by removing the nonce
	nonceKeyName := (WS_WebServiceAgent.JWT_NONCE_KEY &amp; "_" &amp; app.getNiceName &amp; "_" &amp; audience)[1:CM_StateData::key.length];
	app.myTrxUA.trxUpdateUserStateData(user, ConfigGrp_Web, nonceKeyName, null, app.myPassport);
	
	if app.myPassport.hasErrors then
		app.writeLog("Passport has errors after removing the nonce, so returning in getLogout()", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	
	self.httpStatusCode := HttpResponseOK;
	return response;
	
epilog
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementTypes" id="fd03113b-d9fe-40ec-8ac2-3c96f9e11db7">
        <updating/>
        <source>getMeasurementTypes() : WS_MeasurementTypeResponse updating;
/*

Purpose: This is the REST version of the getMeasurementTypes 

Parameters: 

Return Value:		

Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/



vars
	response 		: WS_MeasurementTypeResponse;	
	measureType 	: CM_MeasurementType;
	wsMeasureType	: WS_MeasurementType;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Create the response
	create response transient;
		
	self.initialisePassportPartial();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String &amp; " in getMeasurementTypes", LogERROR);		//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;		
	
	foreach measureType in app.myRoot.allMeasurementTypesByShortName discreteLock  where measureType.isAvailableForEntry and measureType.isDisplay do
		create wsMeasureType transient;
		wsMeasureType.setProxyFromObject(measureType);
		response.allMeasurementTypes.add(wsMeasureType);
	endforeach;
		
	return response;
	
epilog
	finaliseResponse(response);	
end;</source>
        <ReturnType type="WS_MeasurementTypeResponse"/>
    </JadeMethod>
    <JadeMethod name="getPing" id="d396cfa2-2578-4673-9afd-d1f4300ca5a6">
        <source>getPing() : String;
/*

Purpose:			Used by JSA's WebAlive minitoring to trigger alerts to csys if the APIs are down

Parameters:			

Return Value:		

Date				Who		Reason
31 January 2020		jlgmd1	Initial creation

*/

vars
	now : TimeStamp;
begin
	now := app.actualTimeAppServer;
	
	return app.name &amp; " " &amp; now.formatAsYYYYMMDDHHMMSSMMM;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPortsForVoyage" id="a87f4862-528e-49eb-81c8-abccec65c450">
        <updating/>
        <source>getPortsForVoyage() : WS_PortsResponse updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Aug 2020	jlgrr1	Initial creation
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/
constants
	VOYAGECODE = "VoyageCode";
vars
	voyageCode 	: String;
	voyage 	 	: CM_Voyage;	
	
	response 	: WS_PortsResponse;
	proxyPort 	: WS_Port;
	port		: CM_Port;
	allPortsVoyCodeDisplay	: CM_PortByCode3AndCountryDict;
	terminal 	: CM_Terminal;
	user	 	: CM_User;
	passport 	: CM_Passport;
	failedDAC	: CM_DataAccessController;

begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String &amp; " in getPortsForVoyage", LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
		
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	passport := app.myPassport;
	terminal := passport.myTerminal;
	user     := passport.myUser;
	
	//==== Get Voyage Code ====
	voyageCode := self.qsData.getValue(VOYAGECODE);
	if voyageCode &lt;&gt; null then
		// decode the input parameter
		voyage := terminal.lookupVoyage(voyageCode,null,false);		
	endif;
	
	if voyage = null or voyage.isNullVoyage() then		
		foreach port in app.myRoot.allActiveDestinations do
			if not port.canUserAccessSelf(user, failedDAC, passport) then
				continue;
			endif;
			if  not port.isActivePort then
				continue;
			endif;
			
			create proxyPort transient;								
			proxyPort.setProxyFromObject(port);
			response.allPorts.add(proxyPort);
		endforeach;
	else
		create allPortsVoyCodeDisplay transient;
		foreach port in voyage.allPorts discreteLock do
			if port = null then
				continue;
			endif;
		
			if port.isActivePort then
				if not port.canUserAccessSelf(user, failedDAC, passport) then
					continue;
				endif;
				if not allPortsVoyCodeDisplay.includes(port) then
					allPortsVoyCodeDisplay.add(port);
				endif;
			endif;
		endforeach;
		// read from dictionary to get in sequence
		foreach port in allPortsVoyCodeDisplay do
			create proxyPort transient;								
			proxyPort.setProxyFromObject(port);
			response.allPorts.add(proxyPort);
		endforeach;
	endif;
	
	return response;	
	
epilog
	delete allPortsVoyCodeDisplay;			//08.01.2026 navma1 #MTN-36897
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_PortsResponse"/>
    </JadeMethod>
    <JadeMethod name="getRefresh" id="6dda1879-65f6-4a38-a226-c541918dae4c">
        <updating/>
        <source>getRefresh() : WS_InterfaceObject updating;
/*

Purpose:			OAUTH-like authentication using JSON Web Tokens.
					Uses a valid RefreshToken to generate a new AccessToken

Parameters:			A Bearer token containing a valid RefreshToken

Return Value:		AccessToekn - a JWT used to authenticate future webservice calls

Date				Who		Reason
15 April 2022		navmd1	Initial creation TFS 53378 REST Refactor / Generic API
27 Jul 2022			navlw1 	TFS 53854 MTN API Mapper add claims to create / validate tokens

*/

vars
	response		: WS_InterfaceObject;
	
	user			: CM_User;
	terminal		: CM_Terminal;
	audience		: String;
	expiry			: Integer;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response as WS_Response transient;
	
	self.initialisePassport();
	
	self.httpStatusCode := HttpResponseUnauthorized;	// Default to 401 Unauthorised
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	// 1. Get the Refresh Token and make sure its still valid
	// Yes, we're pretty much validating twice, now that initialisePassport/initAuthorizedUser calls validateJWT too
	WS_WebServiceAgent@validateJWT(self.parseBearerAuth(), true, user, terminal, audience, self.allJWTClaims); // 27 July 2022 navlw1 tfs 53854
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	// 2. Generate a new AccessToken and subsequent RefreshToken with new nonce
	delete response;
	create response as WS_NAuthTokenResponse transient;
	//expiry := 15; // TODO: remove after testing
	response.WS_NAuthTokenResponse.accessToken := WS_WebServiceAgent@createJWT(user, terminal, audience, null, expiry, false, self.allJWTClaims); // 27 July 2022 navlw1 tfs 53854
	response.WS_NAuthTokenResponse.expiresIn := expiry;
	expiry := 0;	// Use default
	response.WS_NAuthTokenResponse.refreshToken := WS_WebServiceAgent@createJWT(user, terminal, audience, null, expiry, true, self.allJWTClaims); // 27 July 2022 navlw1 tfs 53854
	
	self.httpStatusCode := HttpResponseOK;
	
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_InterfaceObject"/>
    </JadeMethod>
    <JadeMethod name="getServerVariable" id="3dc190dd-7f81-45b8-b609-a4a5ce225612">
        <source>getServerVariable(var: String): String;
/*

Purpose:			Allow the testing of web service methods that rely on request data
					eg: HTTP Headers

Parameters:			

Return Value:		

Date			Who		Reason
16 April 2022	navmd1	Initial creation TFS 53378 REST Refactor / Generic API

*/

vars
	dummyData : String;
begin
	if not app.isJMTUnitTest then
		return inheritMethod(var);
	endif;

	if self.unitTestData.includesKey(var) then
		dummyData := self.unitTestData.str(var);
		app.writeLog("Returning dummy data for " &amp; var &amp; " [" &amp; dummyData &amp; "]", LogDEBUG);
	endif;
	
	return dummyData;
epilog

end;</source>
        <Parameter name="var" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUnauthorised" id="fa9798fb-4305-46b5-bf36-8da66a929391">
        <updating/>
        <source>getUnauthorised(_paramList: ParamListType) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 Aug 2022		navlw1	Initial creation TFS 53854
13 Dec 2023		navmd1	TFS 60597 Allow HttpResponseClientError (400) as a response code

*/

vars
	response : WS_Response;
	responseCode : Integer;
begin	
	if app.getParamListTypeLength(_paramList) &gt;= 1 then
		responseCode := self.parseParameterList(_paramList, 1, Integer).Integer;
	endif;
	if responseCode = null or responseCode = HttpResponseOK then
		responseCode := HttpResponseUnauthorized;
	endif;
	
	// Doesn't return a response - simply sets the status code
	self.httpStatusCode := responseCode;
	
	if app.myPassport &lt;&gt; null and app.myPassport.hasErrors then
		self.startCnTrx := null;
		create response as WS_Response;
	endif;
	return response;
epilog
	if response &lt;&gt; null then
		self.finaliseResponse(response);
	endif;
end;</source>
        <Parameter name="_paramList" type="ParamListType"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="getUserLocale" id="1b6b53c5-3bf2-473e-893b-1df51bb743eb">
        <updating/>
        <source>getUserLocale(): WS_UserLocaleResponse updating;
/*

Purpose: This is the REST version of the getUserLocale 

Parameters: 

Return Value:		

Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/


vars
	response 		: WS_UserLocaleResponse;	
	userLocale		: WS_Locale;
	sysLocale		: CM_Locale;
	defaultLocale 	: CM_Locale;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Create the response
	create response transient;
	create userLocale transient;
	
	self.initialisePassportPartial(); //before they log on use the public user locale for translations
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String &amp; " in getUserLocale", LogERROR);		//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;		
	
	
	sysLocale := app.myPassport.myUser.myLocale;	
	if sysLocale &lt;&gt; null then		
		userLocale.setProxyFromObject(sysLocale);
		response.userLocale := userLocale;
	else
		defaultLocale := app.myRoot.myDefaultLocale;
		if defaultLocale = null then
			defaultLocale := app.myRoot.getDefaultLocale(false);
		endif;
		userLocale.setProxyFromObject(defaultLocale);
		response.userLocale := userLocale;
	endif;
		
	return response;
	
epilog
	finaliseResponse(response);	
end;</source>
        <ReturnType type="WS_UserLocaleResponse"/>
    </JadeMethod>
    <JadeMethod name="handleCMException" id="f4eec190-d794-4cf3-87f1-28051ff0f8d2">
        <source>handleCMException(_exc : CM_Exception) : Integer protected;

/*

Purpose:			Handle CM_Exceptions during a web service method execution

Parameters:			CM_Exception object

Return Value:		Exception return code


Date		Who		Reason
13 Jun 2019	jlger1	TFS 44759

*/

vars

begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	
	if _exc.isWarning then
		app.myPassport.addWarningFull(_exc.errorCode, _exc.extendedErrorText, _exc.userString, _exc.myUserObject, _exc.mySubject);
		return Ex_Continue;
	else
		abortTransaction;
		abortTransientTransaction;
		app.myPassport.addErrorFull(_exc.errorCode, _exc.extendedErrorText, _exc.userString, _exc.myUserObject, _exc);
		return Ex_Resume_Next;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="CM_Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleJSONException" id="f9b9c91c-3082-4525-a687-35b789ebfa73">
        <source>handleJSONException(_exc : Exception; _parsingError : Boolean io) :  Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 May 2022	navpw1	Initial creation TFS 52773 Used to capture errors and convert them to JSON

*/

constants
	JSONErrorRangeStart	: Integer = 11100;
	JSONErrorRangeEnd	: Integer = 11199;

vars
	returnVal		: Integer;
	
begin
	_parsingError := false;

	// Not an exception we care about
	if _exc.errorCode &lt; JSONErrorRangeStart or _exc.errorCode &gt; JSONErrorRangeEnd then
		returnVal := Ex_Pass_Back;
		return returnVal;
	endif;
	
	// Must be a JSON exception to get this far
	_parsingError := true;
	returnVal := Ex_Resume_Next;
	
	app.writeLog(method.qualifiedName &amp; " (" &amp; _exc.errorCode.String &amp; ") " &amp; _exc.text &amp; CrLf &amp; _exc.extendedErrorText, LogERROR);
epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_parsingError" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleLockExceptions" id="8571b4ed-1f7e-4388-a227-76f1f926bdc0">
        <source>handleLockExceptions(_exc : LockException io) : Integer protected;

/*

Purpose:			Generic local lock exception handler for Web Service methods 

Parameters:			Lock Exception

Return Value:		Exception handler return code


Date		Who		Reason
13 Jun 2019	jlger1	TFS 44759

*/

vars

begin
	// Just allow standard CardSchema lock retry mechanism
	return app.cnGlobalLockExceptionHandler(_exc);
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="LockException" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handlePropToLong" id="12c14aa5-358e-40de-9e18-7b6bb59d9b94">
        <updating/>
        <source>handlePropToLong(_exObj: Exception; _handled : Boolean output; _exMessage : String output; _exCode : Integer output; _httpIn : String): Integer protected, updating;
/*

Purpose:			Handle 1035s when setting properties on incoming JSON objects

Parameters:			

Return Value:		

Date			Who		Reason
17 June 2022	navmd1	Initial creation TFS: 53883
31 Aug 2022		navmd1	TFS 54659 - Fixed wrong prop being shown in error between D and Wmast
22 Sep 2023		navmd1	Check calling method is REST processMessage so we aren't trying to handle (and hide) other 1035 errors

*/

constants
	STRING_TO_LONG			: Integer = 1035;
	INTERNAL_PROCESS_MSG	: String = "JadeRestService::_processMessage";
	
vars
	exClass			: Class;
	exProperty		: Property;
	exProperties	: PropertyODict;
	ordinal 		: String;
	returnVal 		: Integer;
	fieldPos,
	lastFieldPos,
	startPos		: Integer;
	finalValue,
	value,
	errItemStr		: String;
	
begin
	returnVal := Ex_Pass_Back;
	
	//20/01/2026	navkc1 JIRA MTN 36571
	if _exObj.errorCode = 4033 then
		returnVal := Ex_Resume_Next;
		_handled := true;
		_exMessage := 'Error - Result of expression overflows Decimal precision. Please check the decimal precision of the data.';
	endif;
	
	// Only handle RootSchema::JadeRestService::_processMessage exceptions
	if _exObj.currentMethodDesc &lt;&gt; null and _exObj.currentMethodDesc.getName() &lt;&gt; INTERNAL_PROCESS_MSG then
		return returnVal;
	endif;
	
	if _exObj.errorCode = STRING_TO_LONG then
		returnVal := Ex_Resume_Next;
		//self.httpStatusCode := HttpResponseClientError; //This gets reset everytime processRequest gets called
		_handled := true;
		_exCode := _exObj.errorCode;
		_exMessage := _exCode.String &amp; ": " &amp; _exObj.text &amp; " - ";
		
		errItemStr := _exObj.errorItem;
		startPos := errItemStr.pos(",", 1) + 1;
		ordinal := errItemStr.scanUntil(",", startPos);		// errorItem = "class element &lt;16077,1,5&gt;"	grabbing the middle bit
		
		if _exObj.errorObject() &lt;&gt; null then
			exClass := _exObj.errorObject().class;
			exProperties := exClass.cnEcGetPropertiesByOrdinal();
			exProperty := exProperties[ordinal.Integer];
		endif;
		
		if exProperty &lt;&gt; null then
			//Try to find property value that is too long
			lastFieldPos := 1; //Jade indexes at 1 not 0
			fieldPos := 1; //Jade indexes at 1 not 0
			
			while true do
				fieldPos := _httpIn.pos(exProperty.name, fieldPos) + exProperty.name.length + 2; //Get Id Position and add the length plus 2 so we get to the colon or there about
				
				if fieldPos = 0 then
					break; //Reached end of string/not found
				elseif fieldPos = lastFieldPos then
					break; //Same position reocurring
				elseif fieldPos &gt; lastFieldPos then
					lastFieldPos := fieldPos; //Set last Field pos to current field pos
					fieldPos := _httpIn.pos('"', lastFieldPos)+1; //Get position of " from field position and add 1 to exclude the quote mark
					value := _httpIn.scanUntil('"', fieldPos); //Scan until we hit the next quote mark as this is our value we're interested in
					
					if value.length &gt; exProperty.getLength()-1 then //Check if value is longer than propertyValue
						finalValue := value;
						break; //Found value
					endif;
					
				endif;
				
			endwhile;
			
			_exMessage &amp;= "Maximum Length: " &amp; (exProperty.getLength()-1).String &amp; " | Property: " &amp; exProperty.name &amp; " | Value: " &amp; finalValue;
		else
			_exMessage &amp;= _exObj.errorItem;
		endif;
		
		app.writeLog(method.qualifiedName &amp; ": " &amp; _exMessage, LogERROR);
		
	endif;
	
epilog
	return returnVal;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_handled" type="Boolean" usage="output"/>
        <Parameter name="_exMessage" type="String" usage="output"/>
        <Parameter name="_exCode" type="Integer" usage="output"/>
        <Parameter name="_httpIn" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initAuthorizedUser" id="31c3d293-e912-4094-98aa-d56a04121534">
        <updating/>
        <source>initAuthorizedUser(_usercode, _password: String; _forMachine : Boolean; _user: CM_User output; _terminal: CM_Terminal output)  updating, protected;
/*

Purpose:			
	Validates the Username and Password from Authorisation Header (Basic Auth).
	Returns the validated User ID or null if invalid.
	Creates an app.myPassport
	
Parameters:			

Return Value:		

Date			Who		Reason
29 April 2019	jlgrr1	Initial creation
15 April 2022	navmd1	TFS 53378 REST Refactor / GenericAPI
27 July 2022 	navlw1	TFS 53854 MTN API Mapper pass through claims to validateJWT
16 Nov 2022	jlier1 TFS 55160
*/
vars
	username	: String;
	password	: String;
	result		: Integer;
	user		: CM_User;
	token		: String;
	terminal	: CM_Terminal;
	audience	: String;
begin
	
	// Call to POST /login
	if _usercode &lt;&gt; null and _password &lt;&gt; null then
		username := _usercode;
		password := _password;
	else
		// initialisePassport calls us, so skip this one on POST /login
		if self.requestPath = "/login" then
			return ;
		endif;
		
		// Try Bearer auth first, as that should eventually be more popular
		token := self.parseBearerAuth();
		if token &lt;&gt; null then
			self.httpStatusCode := HttpResponseUnauthorized;	// Default to 401 unauthorized
			
			// Are we doing a GET /refresh ? if so, check against the refresh token instead
			if self.requestPath = "/refresh" then
				WS_WebServiceAgent@validateJWT(token, true, user, terminal, audience, self.allJWTClaims); // 27 July 2022 navlw1 tfs 53854
			else
				WS_WebServiceAgent@validateJWT(token, false, user, terminal, audience, self.allJWTClaims); // 27 July 2022 navlw1 tfs 53854
			endif;
			
			self.httpStatusCode := HttpResponseOK;
			_user := user;
			_terminal := terminal;
			
			return ;	// Skip the rest, we're all validated and good to go
		else
			// Otherwise, just use Basic auth
			self.parseBasicAuth(username, password);
		endif;
	endif;
	
	if username = null then
		app.writeLog(method.qualifiedName &amp; " Username not found", LogERROR);
		return;
	endif;
	
	//jlier1 TFS 55160 16/11/22 calling validateUserPassword doesn't work because that doesn't know what the current machine is for the single session signon
	// this was done anyway but on the postLogonForMachine messages - also means for vehicle app not creating logon events for every message
	if _forMachine then
		user := app.myRoot.allUsers[username.toUpper];
		if user = null then
			app.writeLog(method.qualifiedName &amp; " User not found", LogERROR);
			return;
		endif;
		
		if not user.isValidPassword(password) then
			app.writeLog(method.qualifiedName &amp; " Invalid password", LogERROR);
			return;
		endif;
		_user:=user;
	else
	
	
		// TFS 53378 Use the same validation code as the rest of Master Terminal!
		result := app.validateUserPassword(username, password);
		if result &lt;&gt; 0 then
			app.writeLog(method.qualifiedName &amp; " Invalid Username/Password", LogERROR);
			return;
		endif;
		_user := app.myRoot.allUsers[username.toUpper];
	endif;
	
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_usercode" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_forMachine" type="Boolean"/>
        <Parameter name="_user" type="CM_User" usage="output"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="initMachine" id="32fdd485-b210-4ffd-a298-76bf95cd5749">
        <updating/>
        <source>initMachine() : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2021	jlier1	Initial creation 52595
16 November 2022	jlier1	Initial creation 55160
15 Nov 2022	jlier1	 TFS 55160
*/


constants
    MachineID = "MachineID";
vars
	machineCookie : CM_StringWithString; 
	machineCookieID : String ;
	machine : CM_Machine ; 
	cookies : CM_StringDict;
begin
	
	create cookies transient;
	self.parseCookies(cookies);
    //epr TFS 49429 5/2/20
	
	machineCookie:=cookies[MachineID].CM_StringWithString;
	if machineCookie &lt;&gt; null and machineCookie.strString &lt;&gt; null then
		machineCookieID:=machineCookie.strString;
	endif;
	app.writeLog(" Machine Cookie = " &amp; machineCookieID, LogDEBUG);
	machine := app.myValUA.valMachineForLogon(machineCookieID,app.myPassport.myTerminal.code,app.myPassport);
	if machine = null or app.myPassport.hasErrors() then
		self.httpStatusCode := HttpResponseForbidden;
		return false;
	endif;
	
	app.myPassport.setMyMachine(machine);
	
	
	return true;
epilog
	if cookies &lt;&gt; null then
		cookies.purge;
	endif;
	delete cookies;
	

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initMachineByMachineId" id="f0bd5c6e-8dd0-434e-80ab-255870a8cdd5">
        <updating/>
        <source>initMachineByMachineId(_machineId	: String) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2025 navnk30	JIRA 34701: SSO Implementation for Vehicle App - Jade Portion

*/

vars
	machine : CM_Machine;
begin
	machine := app.myValUA.valMachineForLogon(_machineId, app.myPassport.myTerminal.code, app.myPassport);
	if machine = null or app.myPassport.hasErrors() then
		self.httpStatusCode := HttpResponseForbidden;
		return false;
	endif;
	
	app.myPassport.setMyMachine(machine);
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_machineId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTerminal" id="6f076bf8-3113-4cbc-8d56-99f6ab785475">
        <updating/>
        <source>initTerminal(user : CM_User) : CM_Terminal updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2020	jlgrr1	Initial creation

*/
constants
	TERMINAL = "Terminal";
vars
	realTerminal : CM_Terminal;
	currentTerminal : String;
	terminalCookieCode : String;
	cookies : CM_StringDict;
	terminalCookie : CM_StringWithString;	
begin
	
	// Get the terminal from the request header
	create cookies transient;
	self.parseCookies(cookies);
	terminalCookie:=cookies[TERMINAL].CM_StringWithString;
	if terminalCookie &lt;&gt; null and terminalCookie.strString &lt;&gt; null then
		terminalCookieCode:=terminalCookie.strString;
	endif;

	if terminalCookieCode &lt;&gt; null  then
		realTerminal := app.myRoot.allTerminals[terminalCookieCode];
		app.writeLog(" Terminal Cookie = " &amp; terminalCookieCode, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	else	
		app.writeLog(" Terminal Cookie = NULL. Using User State Terminal", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		currentTerminal := user.getStateData(ConfigGrp_Web, UserCurrentTerminal).String;
		if currentTerminal &lt;&gt; null then	
			realTerminal:=app.myRoot.allTerminals[currentTerminal];
		endif;
	endif;
	
	if realTerminal &lt;&gt; null and user.allUserTerminals[realTerminal] = null then
		realTerminal := null;
	endif;

	if realTerminal = null or user.allUserTerminals[realTerminal] = null then
		self.httpStatusCode := HttpResponseForbidden;
		app.raiseCMException(ERR_dontHaveAccessToThisItem,null,null);		
		return null;
	endif;
	
	app.writeLog("Terminal: " &amp; realTerminal.code, LogDEBUG);
	return realTerminal;
epilog
	if cookies &lt;&gt; null then
		cookies.purge;
	endif;
	delete cookies;
end;</source>
        <access>protected</access>
        <Parameter name="user" type="CM_User"/>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="initTerminalFromScope" id="df72265e-05a3-4785-97a6-eb6008b12cec">
        <source>initTerminalFromScope(	_user							: CM_User; 
						_terminal 						: CM_Terminal output; 
						_operator, _complex, _facility	: String output;
						_yard							: CM_Object output	) : Boolean protected;
/*

Purpose:			Work out which Terminal operations should be made in

Parameters:			_user	: CM_User	A valid user used to limit which terminals can be accessed

Return Value:		false if a Terminal could not be found or the specified user doesn't have access

Date		Who		Reason
09 Sep 2020	jlgrr1	Initial creation TFS 49227
23 Sep 2020	jlgdap1	TFS 49227 MTN Navis API - nReefer API
13 Apr 2021	navmd1	TFS 51086 JADE 2020 Fixes
15 Apr 2022 navmd1	TFS 53378 Moved up from NavisAPIService and tided up a little
22 Aug 2022 navlw1 	TFS 53854 API Mapper to set the scope claims on CMIF_WSClaimsObj
02 Sep 2022 navmd1	TFS 54726 Add back basic validation to just check we've been given an OperatorId
*/

vars
	yard : String;	
begin
	_operator := self.formData.getValue(WS_RestWebServiceProvider.SCOPE_OPERATOR).toUpper;
	_complex := self.formData.getValue(WS_RestWebServiceProvider.SCOPE_COMPLEX).toUpper;
	_facility := self.formData.getValue(WS_RestWebServiceProvider.SCOPE_FACILITY).toUpper;
	yard := self.formData.getValue(WS_RestWebServiceProvider.SCOPE_YARD).toUpper;
	
	app.writeLog("Scope - Operator: [" &amp; _operator &amp; "], Complex: [" &amp; _complex &amp; "], Facility: [" &amp; _facility &amp; "], Yard: [" &amp; yard &amp; "]", LogINFO);
	
	// TFS 53378	Operator will be used to split off any customer specific code if required, so don't bother limiting it to anything
	//				Complex is not currently being used, so no point in validating it
	// TFS 54726	Complex is now being used! So lets check we have at least got *something*
	
	// 1. Validate the Operator
	if _operator = null then
		app.writeLog("Invalid Scope, OperatorId not found.", LogERROR);
		return false;
	endif;

	// 2. validate the complex (this is the MTN environment name) or "Master Terminal"
/*	if _complex &lt;&gt; app.getEnvName().toUpper then
		app.writeLog("Failed to find complex " &amp; _complex, LogINFO);
		_terminal := null;
		return false;
	endif;
*/
	
	// 3. Facility is the terminal code
	if _facility &lt;&gt; null  then
		_terminal := app.myRoot.allTerminals[_facility];
	endif;
	
	// Make sure the user actually has access to the terminal
	if _terminal &lt;&gt; null and _user.allUserTerminals[_terminal] = null then
		app.writeLog("Failed to find user terminal for user " &amp; _user.code &amp; " and terminal " &amp; _terminal.code, LogERROR);
		_terminal := null;
		return false;
	endif;	
	
	// 4. Yard - not currently used, so no point in validing it
		// NB. The NReeferAPI overrides this and uses yard to scope the Reefer Walk Path (CM_ReeferBlock)
	
	
	if _terminal = null then
		app.writeLog("Failed to find terminal " &amp; _facility, LogERROR);
		return false;
	endif;
	
	// 27 July 2022 navlw1 tfs 53854 set the claims
	self.allJWTClaims.setScopeClaims(_complex,_terminal.code,_operator,yard);
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="output"/>
        <Parameter name="_operator" type="String" usage="output"/>
        <Parameter name="_complex" type="String" usage="output"/>
        <Parameter name="_facility" type="String" usage="output"/>
        <Parameter name="_yard" type="CM_Object" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialisePassport" id="38c1b85d-0b34-4344-af06-bf0513c455f3">
        <updating/>
        <source>initialisePassport() : Boolean protected, updating;

/*

Purpose:			Initialise passport to clean state

Parameters:			None

Return Value:		None
 Returns True if Passport was initialised successfully

Date		Who		Reason 44759
06 Sep 2020	jlgrr1	Refactor for REST Webservice structure TFS 49227
24 Nov 2021 navmd1	Moved debug code up
15 Apr 2022 navmd1	TFS 53378 REST Refactor / GenericAPI
15 Nov 2022	jlier	TFS 55160
05 Apr 2024 navmj1	TFS 63510: MTN - Change the name of the method for the JSM transaction
18 Jun 2024 navmd1	TFS 59460 Handle situatiosn where initialisePassport is reimplemented when picking the name for trans stats
*/

vars
	locale 		 : CM_Locale;
	terminal 	 : CM_Terminal;
	user 		 : CM_User;
    callStack    : ProcessStackArray;
    methCallDesc : MethodCallDesc;
	stackLevel	 : Integer;
	tmpStr		 : String;
	restMethod   : String;													//navra1 - MTN-36928 - 8th Jan 2026-1
begin
	// Debug code to skip re-initialising when running from a JadeScript
	executeWhen JMTDevelopmentEnvironment;
		if self.httpStatusCode = 666 then
			self.httpStatusCode:=HttpResponseOK;
			return true;
		endif;
	endExecuteWhen;
	
	// Get the calling method, not the current one, so the correct name is 
	// used in the JSM trx. 04 Apr 2024. 
	create callStack transient;
    process.currentStack(callStack);
	stackLevel := 2;	// technically, we'll start at 3, which is the calling method
	
	// A bit janky, but handle situations where initialisePassport is overwritten at a lower level
	// Most of the time we're only expecting to go straight through this loop
	while true do
		stackLevel += 1;
		methCallDesc := callStack[stackLevel];
		if methCallDesc.method.name = method.name then
			continue;
		endif;
		
		restMethod := methCallDesc.method.name;										//navra1 - MTN-36928 - 8th Jan 2026-1
		
		break;
	endwhile;
	tmpStr := process.adminInfo &amp; "::" &amp; methCallDesc.method.name;	// adminInfo is set by karma controller
	
	self.startCnTrx:= cnStartTransaction(tmpStr[1:CN_TRANSACTION_ID_MAXLENGTH]);
	app.writeLog(methCallDesc.method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053

	app.createPassport();
		
	//navra1 - MTN-36928 - 8th Jan 2026-1 - start
	if self.isNotEventRecordingAPI(restMethod) then	
		app.myPassport.setContext(Context_Pass_NoEventRecord);
	endif;
	//navra1 - MTN-36928 - 8th Jan 2026-1 - end
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	self.initAuthorizedUser(null, null, false,user, terminal);
	
	if user = null then
		self.httpStatusCode := HttpResponseUnauthorized;
		return false;
	endif;

	if terminal = null then
		terminal := self.initTerminal(user);
	endif;
	
	if terminal = null then
		if self.httpStatusCode = null then
			self.httpStatusCode := HttpResponseForbidden;
		endif;
		return false;
	endif;

	
	// Set Locale and Special based on user
	app.isRTApp := false;
	app.myPassport.setMyUser(user);
	app.myPassport.setMyTerminal(terminal);
	
	locale := user.getLocale();
	app.setLocale(locale);

	// Ensure "special" is set correctly
	if user.code = "SUPERUSER" then
		app.setSpecial('31/12/3000'.TimeStamp);
	else
		app.setSpecial(app.actualTimeServer);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;

	self.saveUserState(user, terminal);
	return true;

epilog
	if callStack &lt;&gt; null then
		callStack.purge;
		delete callStack;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialisePassportMachine" id="02f8b636-f2e4-4484-be8d-9b580f1d1bf1">
        <updating/>
        <source>initialisePassportMachine() : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2022	jlier1	Initial creation  TFS 52595
15 Nov 2022	jlier1	TFS 55160
03 May 2023 navma1	Bug 56239: MSL - The system does not recognize the availability grade of the Release Requests
05 Apr 2024 navmj1	TFS 63510: MTN - Change the name of the method for the JSM transaction
*/

vars
	locale 	  	 : CM_Locale;
	terminal  	 : CM_Terminal;
	user 	  	 : CM_User;
    callStack    : ProcessStackArray;
    methCallDesc : MethodCallDesc;
begin
	// Debug code to skip re-initialising when running from a JadeScript
	executeWhen JMTDevelopmentEnvironment;
		if self.httpStatusCode = 666 then
			self.httpStatusCode:=HttpResponseOK;
			return true;
		endif;
	endExecuteWhen;
	
	// Get the calling method, not the current one, so the correct name is 
	// used in the JSM trx. 04 Apr 2024. 
	create callStack;
    process.currentStack(callStack);
	methCallDesc := callStack[3];  
	
	self.startCnTrx:= cnStartTransaction(methCallDesc.method.qualifiedName[1:CN_TRANSACTION_ID_MAXLENGTH]);
	app.writeLog(methCallDesc.method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053

	app.createPassport();

	// Initialises user and checks request has valid headers deletes and recreates the passport
	self.initAuthorizedUser(null, null,true, user, terminal);
	
	if user = null then
		self.httpStatusCode := HttpResponseUnauthorized;
		return false;
	endif;

	if terminal = null then
		terminal := self.initTerminal(user);
	endif;
	
	if terminal = null then
		if self.httpStatusCode = null then
			self.httpStatusCode := HttpResponseForbidden;
		endif;
		return false;
	endif;

	// Set Locale and Special based on user
	app.isRTApp := true;								//03.05.2023 navma1 #56239
	app.myPassport.setMyUser(user);
	app.myPassport.setMyTerminal(terminal);
	
	locale := user.getLocale();
	app.setLocale(locale);

	// Ensure "special" is set correctly
	if user.code = "SUPERUSER" then
		app.setSpecial('31/12/3000'.TimeStamp);
	else
		app.setSpecial(app.actualTimeServer);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	
	// 16 Dec 2021	jlier1	TFS 52595
	self.initMachine();
	
	if self.httpStatusCode = HttpResponseForbidden then
		return false;
	endif;

	self.saveUserState(user, terminal);
	return true;

epilog
	if callStack &lt;&gt; null then
		callStack.purge;
		delete callStack;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialisePassportPartial" id="4ebda70e-af61-4aaf-8721-a94304cfb28c">
        <updating/>
        <source>initialisePassportPartial() protected, updating;

/*

Purpose: Initialise Passport that does not check any of the Terminal or Machine cookie code stuff.
		 - Will user the public user if user not specified

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
15 Apr 2022 navmd1	TFS 53378 REST Refactor / GenericAPI
15 Nov 2022	jlier1	TFS 55160
05 Apr 2024 navmj1	TFS 63510: MTN - Change the name of the method for the JSM transaction
============================================================================*/

vars
	locale		 : CM_Locale;	
	user 		 : CM_User;
	machine 	 : CM_Machine;
	terminalCode : String;
	terminal	 : CM_Terminal;
	userName,
	password 	 : String;
    callStack    : ProcessStackArray;
    methCallDesc : MethodCallDesc;
begin
	// Get the calling method, not the current one, so the correct name is 
	// used in the JSM trx. 04 Apr 2024. 
	create callStack;
    process.currentStack(callStack);
	methCallDesc := callStack[3];  
	
	self.startCnTrx:= cnStartTransaction(methCallDesc.method.qualifiedName[1:CN_TRANSACTION_ID_MAXLENGTH]);
	app.writeLog(methCallDesc.method.qualifiedName, LogTRACE);
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	self.initAuthorizedUser(null, null, true,user, terminal);
	
	if user = null then
		user := app.myPublicUser;
	endif;
	
	if user = null then
		self.httpStatusCode := HttpResponseUnauthorized;
		return;
	endif;
	app.createPassport();

	// Set Locale and Special based on user
	
	app.myPassport.setMyUser(user);
	locale := user.getLocale();
	app.setLocale(locale);

	// Ensure "special" is set correctly
	if user.code = "SUPERUSER" then
		app.setSpecial('31/12/3000'.TimeStamp);
	else
		app.setSpecial(app.actualTimeServer);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	
	
	app.isRTApp := false;
	
	terminalCode := user.getStateData(ConfigGrp_Web, UserCurrentTerminal).asString;
	terminal := app.myRoot.allTerminals[terminalCode];	
	app.myPassport.setMyTerminal(terminal);

epilog	
	if callStack &lt;&gt; null then
		callStack.purge;
		delete callStack;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isNotEventRecordingAPI" id="ac87646d-b31b-4ae8-8d73-20233d087dd0">
        <source>isNotEventRecordingAPI(_apiMethodName : String) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2026	navra1	Initial creation for //navra1 - MTN-36928 - 8th Jan 2026-1

*/

vars

begin
	if _apiMethodName &lt;&gt; WS_RestWebServiceProvider::postRecordLogon.name and
	_apiMethodName &lt;&gt; WS_RestWebServiceProvider::postRecordLogout.name and
	_apiMethodName &lt;&gt; JMTHandheldService::postLogonMachineForPicking.name and
	_apiMethodName &lt;&gt; JMTHandheldService::postLogoffMachineForPicking.name and
	_apiMethodName &lt;&gt; MTNInternalAPIService::postLogonMachine.name and
	_apiMethodName &lt;&gt; MTNInternalAPIService::postLogoffMachineForPicking.name and
	_apiMethodName &lt;&gt; MTNInternalAPIService::postLogonMachineChangePassword.name and
	_apiMethodName &lt;&gt; MTNInternalAPIService::postLogonMachineForPicking.name and
	_apiMethodName &lt;&gt; MTNInternalAPIService::postLogonSSOMachine.name and
	_apiMethodName &lt;&gt; HandheldInternalAPIService::postSignin.name and
	_apiMethodName &lt;&gt; KioskInternalAPIService::postSignin.name then		//add more methods that might need events to be recorded
			return true;
	endif;
	
	return false;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_apiMethodName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="parseBasicAuth" id="ee183b41-6839-483b-b765-3041f5f452e3">
        <source>parseBasicAuth(username : String output; password : String output) protected;
/*

Purpose:			
Parses HTTP_AUTHORIZATION header and returns username and password.
NAVMA1 22.2.2022 authToken changed to  StringUtf8 to fix ANSI strings in Unicode environments
Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2020	jlgrr1	Initial creation TFS 49632 / TFS 44759
20 Dec 2021	jlier1  TFS  52595 - can be no token
22 Feb 2022 navma1	Bug 52931: Euroports (TEST) Rail Load by Request not locating (Rail) Release Request   
16 Sep 2022 navmd1	TFS 54858 Changed from using LCID 0 to Invairant as using the "current" locale lead to 1445 UEs
*/

vars
	authString : String;  
	authToken  : StringUtf8; // String;   // 22.02.2022 navma1 #52931 
	pos 	   : Integer;

begin
	// AUTHORIZATION
	// Basic Authentication
	authString := self.getServerVariable("HTTP_AUTHORIZATION");
	if authString.pos("Basic ", 1) &gt; 0 then
		
		authToken   := authString[7:authString.length].base64Decode.StringUtf8;
		if authToken &lt;&gt; null then
			pos := 1;
			username   := authToken.scanUntil(":", pos).asString(LCID_Invariant);
			pos := authToken.pos(":", 1) + 1;
			if pos &gt; 0 and pos &lt;= authToken.length then
				password   := authToken[pos: end].asString(LCID_Invariant);
			endif;
		endif;
		app.writeLog(method.qualifiedName &amp; " Auth Basic found user: " &amp;  username, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	else
		app.writeLog(method.qualifiedName &amp; " Auth Basic found user: None", LogDEBUG);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="username" type="String" usage="output"/>
        <Parameter name="password" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="parseBearerAuth" id="461a3e30-50c0-41af-9572-5ab6b77f3929">
        <source>parseBearerAuth(): String protected;
/*

Purpose:			
Parses HTTP_AUTHORIZATION header and returns Token

Parameters:			

Return Value:		

Date			Who		Reason
09 July 2020	jlgrr1	Initial creation TFS 49227
16 Apr 2022		navmd1	TFS 53378 REST Refactor / Generic API

*/
constants
	HTTP_AUTHORIZATION = "HTTP_AUTHORIZATION";
	
vars
	authString : String;
	authToken : String;
begin
	// AUTHORIZATION
	// Bearer Authentication
	authString := self.getServerVariable(HTTP_AUTHORIZATION);
	app.writeLog(method.qualifiedName &amp; " Authorization: " &amp;  authString, LogDEBUG);
	if authString.pos("Bearer ", 1) &gt; 0  and authString.length &gt; 7 then
		authToken := authString[8:authString.length];
		app.writeLog(method.qualifiedName &amp; " Auth Bearer found token: " &amp;  authToken, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	else
		app.writeLog(method.qualifiedName &amp; " Auth Bearer found token: None", LogDEBUG);
	endif;
	
	return authToken;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="parseCookies" id="6b564577-16b0-4ea6-8503-b2033dd350f7">
        <source>parseCookies( cookies : CM_StringDict input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2019	jlgrr1	Initial creation

*/

vars
	httpCookiesString : String;	
	cookie : CM_StringWithString;
	cookieName, 
	cookieString : String;
	endofName : Integer;
	endofValue : Integer;
	
begin
	httpCookiesString := self.getServerVariable("HTTP_COOKIE").trimBlanks;
	app.writeLog("cookies string " &amp;  httpCookiesString, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	while httpCookiesString.length &gt; 0 do

		endofName := httpCookiesString.pos("=", 1) - 1;
		endofValue := httpCookiesString.pos(";", 1) - 1;	
		if endofValue &lt;= 0 then
			endofValue := httpCookiesString.length;
		endif;
		
		cookieString := httpCookiesString[1 : endofValue];
		
		if endofName &gt; 0 then
			cookieName:=cookieString[1 : endofName];
			if cookieName &lt;&gt; null then
				cookie:=cookies[cookieName].CM_StringWithString;
				if cookie = null  and (endofValue-endofName &gt; 1)   then
					create cookie transient;
					cookie.set(cookieName , cookieString[endofName + 2 : endofValue - endofName + 1]);
					cookies.add(cookie);
				endif;
			endif;		
			if httpCookiesString.length &gt; endofValue + 3 then
				httpCookiesString := httpCookiesString[endofValue + 3 : httpCookiesString.length - endofValue - 2].trimBlanks;
			else
				httpCookiesString := "";
			endif;
	
		endif;
		
	endwhile;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="cookies" type="CM_StringDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="parseParameterList" id="b1520b08-4ecc-4aa8-89c7-e31ef2701d3c">
        <source>parseParameterList(paramList : ParamListType; index : Integer; type : Type) : Any protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2019	jlgrr1	Initial creation
01 Aug 2024	navmd1	TFS 65497 Allow Epoch (Integer64) timestamp values

*/

vars
	param : Any;
	result : Any;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	if (app.getParamListTypeLength(paramList) &gt;= index) then
		param := app.getParamListTypeEntry(index, paramList);
		
		if (type = Integer or type = Integer64) then
			// Catch the empty parameter case
			if param.String = "" then
				return 0;
			endif;

			// Catch the "0" case
			if param.String = "0" then
				return 0;
			endif;
			
			// parse to integer
			if type = Integer then
				result := param.Integer;
			else
				result := param.Integer64;
			endif;
			
			// if result is not an integer then raise an exception
			if result = null then
				app.raiseCMException(ERR_INVALID_PARAMETER, "Parameter Index: " &amp; index.String, null); 
			endif;

			// return the integer result
			return result;
	
		elseif (type = String) then	
			result := param.String;
			return result;
		elseif (type = Boolean) then //jlier1 TFS 53023 22/4/22
			result:=param.Boolean;
			return result;	
			
		else
			app.raiseCMException(ERR_INVALID_PARAMETER, "Parameter Index: " &amp; index.String, null); 
			return null;
		endif;
	endif;
	
	return null;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="paramList" type="ParamListType"/>
        <Parameter name="index" type="Integer"/>
        <Parameter name="type" type="Type"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="postChangePassword" id="fe4119e2-204a-4057-9d74-83d23e7faa2c">
        <updating/>
        <source>postChangePassword(request : WS_LogonRestRequest): WS_Response updating;
/*

Purpose: This is the REST version of the changePassword 

Parameters: REST JSON Body parameters as sample below
				{    
					"confirmNewPassword" : "confirmNewPassword",
					"newPassword" : "newPassword"
				}

Return Value:		

Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
25 Oct 2024	navnk30	JIRA 32980: POL - Unable to reset password from vehicle apps (changed param request type)
26 Jun 2025 navah1	Bug 35193: MTN - Multiple Sessions Allowed for Users with Single User Session enabled
============================================================================*/

vars	
	response 	: WS_Response;	
	user	 	: CM_User;
	
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Create the response
	create response transient;
	
	//self.initialisePassport();			//26.06.2025 navah1 #35193
	self.initialisePassportMachine();       //26.06.2025 navah1 #35193
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String &amp; " in postChangePassword", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;		
		
	user := app.getMyUser();
	if user = app.myPublicUser then
		app.writeLog(self.httpStatusCode.String &amp; " in postChangePassword", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return null;
	endif;
	//epr TFS 49676 5/7/21 make users enter current password
	app.myTrxUA.trxUpdatePassword(true, user.code, request.password, request.newPassword, request.confirmNewPassword, app.myPassport);
	
	// Check for errors in change password
	if not app.myPassport.trxCompletedOK then
		app.writeLog("Passport trx completion not ok in postChangePassword", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
		
	return response;
	
epilog
	finaliseResponse(response);	
end;</source>
        <Parameter name="request" type="WS_LogonRestRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postLogin" id="7da5dbeb-2ce9-4a72-82ef-e36aaa82b22b">
        <updating/>
        <source>postLogin(_request: WS_RESTLoginAuthRequest) : WS_InterfaceObject updating;
/*

Purpose:			OAUTH-like authentication using JSON Web Tokens.
					The AccessToken should have a short lifetime, with the RefreshToken being used to generate a new one as required

Parameters:			userId			: String
					password		: String
					scope
						operator	: String	An identifier used to invoke customer specific logic. This should be 'Navis' unless specified otherwise
						complex		: String	Not used. This should always be 'Master Terminal'
						facility	: String	An identifier used to determine which Terminal operations should occur in. Must match a Terminal Code.
						yard:		: String	For future use. This should always be 'MTN'.
					applicationId	: String	A unique Id representing the calling application

Return Value:		AccessToekn - a JWT used to authenticate future webservice calls
					RefreshToken - a JWT used to generate a new AccessToken after it expires

Date				Who		Reason
13 April 2022		navmd1	Initial creation 53378 MTNGenericInterfaceService
27 July  2022		navlw1	53854 MTN API Mapper
15 Nov 2022	jlier1	 TFS 55160
3  Apr 2023 navra1	TFS - 56641 - Moved the parseNameValuePair to WS_NameValuePairDict/WS_QueryStringParamDict
*/

vars
	response	: WS_InterfaceObject;
	user 		: CM_User;
	terminal	: CM_Terminal;
	scope,
	operator,
	complex,
	facility	: String;
	yard		: CM_Object;
	expiry		: Integer;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response as WS_Response transient;
	
	self.initialisePassport();
	
	self.httpStatusCode := HttpResponseUnauthorized;	// Default to 401 Unauthorised
	
	// 1. Validate Username/Password
	self.initAuthorizedUser(_request.userId, _request.password,false, user, terminal);
	if user = null then
		app.raiseCMException1(ErrApiAuthInvalid, "Invalid Username/Password", null, null);
		return response;
	endif;
	
	// 2. Validate Scope/Terminal
	if _request.scope &lt;&gt; null then
		scope := _request.scope.asStringJMT;
	endif;
	self.formData.parseNameValuePair(scope);	//navra1 - TFS - 56641 - 3rd April 2023
	if not self.initTerminalFromScope(user, terminal, operator, complex, facility, yard) then
		self.httpStatusCode := HttpResponseClientError;
		app.raiseCMException1(ErrApiAuthInvalid, "Invalid Scope", null, null);
		return response;
	endif;
	
	// 3. Validate client/applicaion id
	if _request.applicationId = null then
		self.httpStatusCode := HttpResponseClientError;
		app.raiseCMException1(ErrApiAuthInvalid, WS_RESTLoginAuthRequest::applicationId.name &amp; " not specified, and is required for JWT auth", null, null);
		return response;
	endif;	
	
	// 3. Generate a new AccessToken JWT
	delete response;
	create response as WS_NAuthTokenResponse transient;
	response.WS_NAuthTokenResponse.accessToken := WS_WebServiceAgent@createJWT(user, terminal, _request.applicationId, null, expiry, false, self.allJWTClaims); // 27 July 2022 navlw1 tfs 53854
	response.WS_NAuthTokenResponse.expiresIn := expiry;
	
	// 4. Generate a new RefreshToken JWT
	expiry := 0;	// Use the default expiry for Refresh Tokens
	response.WS_NAuthTokenResponse.refreshToken := WS_WebServiceAgent@createJWT(user, terminal, _request.applicationId, null, expiry, true, self.allJWTClaims); // 27 July 2022 navlw1 tfs 53854
	
	self.httpStatusCode := HttpResponseOK;

	return response;
epilog
	self.formData.purge();
	self.finaliseResponse(response);
end;</source>
        <Parameter name="_request" type="WS_RESTLoginAuthRequest"/>
        <ReturnType type="WS_InterfaceObject"/>
    </JadeMethod>
    <JadeMethod name="postRecordLogon" id="36df3418-fe91-4f56-8adc-38dadf1550a9">
        <updating/>
        <source>postRecordLogon(): WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2019	jlger1	Initial creation 44759
*/

vars
	response : WS_Response;
	username,
	password : String;
	result : Integer;
	passport : CM_Passport;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.startCnTrx := cnStartTransaction(method.qualifiedName[1:CN_TRANSACTION_ID_MAXLENGTH]);
	
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	// Initialises user and checks request has valid headers deletes and recreates the passport
	
	self.parseBasicAuth(username,password);
	
	result :=app.myTrxUA.trxUpdateLogon(username.toUpper, password,null,  passport);
	
	if result &lt;&gt; 0  then
		app.writeLog("result of trxUpdateLogon not 0 in postRecordLogon", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		self.httpStatusCode := HttpResponseForbidden;
		return null;
	endif;
	
	create response transient;
	
	return response;
epilog
	
	self.finaliseResponse(response);

end;</source>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postRecordLogout" id="71e40bee-6d58-4e7e-b9d1-7b9cd08add37">
        <updating/>
        <source>postRecordLogout() : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jun 2019	jlger1	Initial creation 44759
16 Nov 2022	jlier1	TFS 55160
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

constants
    MachineID = "MachineID";
vars
	machineCookie 	: CM_StringWithString; 
	machineCookieID : String ;
	cookies 		: CM_StringDict;
	response 		: WS_Response;
	term			: CM_Terminal;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportPartial();

	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String &amp; " in postRecordLogout", LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
	
	//may optionally have a machine so need to set that on the passport
	create cookies transient;
	self.parseCookies(cookies);
	
	machineCookie := cookies[MachineID].CM_StringWithString;
	if machineCookie &lt;&gt; null and machineCookie.strString &lt;&gt; null then
		machineCookieID:=machineCookie.strString;
	endif;
	
	term := app.myPassport.myTerminal;
	if machineCookieID &lt;&gt; null and term &lt;&gt; null  then					//08.01.2026 navma1 #MTN-36897
		app.myPassport.setMyMachine(term.machines[machineCookieID]);
	endif;
	
	create response transient;
	if app.myPassport.hasErrors then
		app.writeLog("Passport has errors in postRecordLogout()", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	//16 Dec 2021	jlier1	Initial creation TFS 52595
	app.myTrxUA.trxUpdateLogoff(app.myPassport.myMachine,app.myPassport);
	
	return response;
epilog
	if cookies &lt;&gt; null then
		cookies.purge;
	endif;
	delete cookies;	
	self.finaliseResponse(response);

end;</source>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postUserLocale" id="2f169ffb-ed6a-46da-85c2-2b74312d4728">
        <updating/>
        <source>postUserLocale(localeId : String): WS_Response updating;
/*

Purpose: This is the REST version of the setUserLocale 

Parameters: 

Return Value:		

Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/


vars
	response		: WS_Response;	
	sysLocale		: CM_Locale;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Create the response
	create response transient;
	
	self.initialisePassport();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String &amp; " in postUserLocale", LogERROR);	//navra1 - 24th Aug 2022 - TFS 50365	
		return response;
	endif;		
	
	sysLocale := app.myRoot.allLocales[localeId];
	if sysLocale = null then
		app.raiseCMException(Unknown_locale,null,null);		
		return response;
	endif;
	
	app.myTrxUA.trxUpdateUserLocale(app.myPassport.myUser, sysLocale, app.myPassport);
	
		
	return response;
	
epilog
	finaliseResponse(response);	
end;</source>
        <Parameter name="localeId" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postUserStateData" id="96a32c1c-1e50-47fc-9715-a36b22cd7961">
        <updating/>
        <source>postUserStateData(key: String; value: String) : WS_StateDataResponse updating;
/*

Purpose: This is the REST version of the setUserStateData 

Parameters: 

Return Value:		

Date		Name	TFS#		Description
============================================================================
16 Dec 2021	jlier1	Initial creation TFS 52595
============================================================================*/



vars
	response 		: WS_StateDataResponse;	
	
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Create the response
	create response transient;
		
	self.initialisePassport();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String &amp; " in postUserStateData", LogERROR);		//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;		
	
	if key = null or value = null then
		app.writeLog("key or value is null in postUserStateData", LogERROR);		//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;
	
	app.myTrxUA.trxUpdateUserStateData(app.getMyUser(), ConfigGrp_Web, key, value, app.myPassport);
		
	return response;
	
epilog
	finaliseResponse(response);	
end;</source>
        <Parameter name="key" type="String"/>
        <Parameter name="value" type="String"/>
        <ReturnType type="WS_StateDataResponse"/>
    </JadeMethod>
    <JadeMethod name="preProcessRequest" id="107045b8-0b13-434b-af7b-05a086ae01bf">
        <updating/>
        <source>preProcessRequest(httpIn : String io; queryStr, pathIn, methodType, contentType : String) : String updating, protected;
/*

Purpose:			Pre-Process Request - Used to do anything that needs to be done before we process a request on our web api

Parameters:			httpIn		String	The body of the request we want to process
					queryStr	String	The query string supplied with the request
					pathIn		String	The path used for the request
					methodType	String	The method type of the request
					contentType	String	The content type of the request

Return Value:		NONE

Date		Who		Reason
08 Mar 2023	navpw1	Initial creation TFS: 56988 (57003)
15 Jan 2026	navdap1	MTN-36569 CPL | Reefer Runner Integration
*/

vars

begin
	return pathIn;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="httpIn" type="String" usage="io"/>
        <Parameter name="queryStr" type="String"/>
        <Parameter name="pathIn" type="String"/>
        <Parameter name="methodType" type="String"/>
        <Parameter name="contentType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processRequest" id="b0ef7dea-c07b-4c14-bbfd-666110a418ea">
        <updating/>
        <source>processRequest(httpIn: String; queryStr: String; pathIn: String; methodType: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Aug 2019	jlger1	Initial creation
23 Sep 2019 jlger1	TFS 46632 - isses of pathIn had params with characters like /  or \  unbreak the unencoded and make the param include the %hex value
21 Sep 2020	jlgdap1	TFS 49227 MTN Navis API - nReefer API
13 Apr 2022 navmd1	TFS 53376 REST Refactor
20 Jun 2022 navpw1	TFS 53883 Added Request Exception handler to handle string too long errors
01 Aug 2022 navlw1	TFS 53854 API Mapper added transform request to format the httpIn into a format we can use
02 Sep 2022	navmd1	TFS 54664 Changed prop to long exception handler to use the transformed input string
08 Mar 2023	navpw1	TFS 56988 (57004) - Added a new method call called preProcessRequest that will be used to modify the request as it comes in
04 Jul 2023	navmd1	TFS 58575 MTN - MasterTerminalAPI processRequest not clearing passport
18 Aug 2023 navmd1	TFS 59024 Save transformed request string to 'preTransformedRequest' variable for saving later
13 Dec 2023 navmd1	TFS 60597 Wrap transform and preProcess in an exception handler so we can not die completely when they return CM_Errors
15 Jul 2024	navmd1	TFS 65226 Add postTransformedRequest so it can be used when debugging later down the callstack
15 Jan 2026	navdap1	`MTN-36569 CPL | Reefer Runner Integration
*/
constants
	UNENCODED_URL = "UNENCODED_URL";
	HTTP_CONTENT_TYPE = "HTTP_CONTENT_TYPE";
	
vars
	allPathIns 			: StringArray;
	newPathIn,
	pathParams 			: String;
	unencodedURL,
	unencodedParams 	: String;
	pathStart,
	paramStart,paramEnd : Integer;
	newMethodType 		: String;				// TFS 49227
	newHttpIn 			: String;				// TFS 49227
	contentType			: String;				// TFS 53376
	hadError			: Boolean;				// ### TFS 53883 22Jun2022 NAVPW1
	exMessage			: String;				// ### TFS 53883 22Jun2022 NAVPW1
	exCode				: Integer;				// ### TFS 53883 22Jun2022 NAVPW1
	
begin
	// Arm exception handler for CM Exceptions
	on Exception do self.handlePropToLong(exception, hadError, exMessage, exCode, newHttpIn); // ### TFS 53883 20June2022 NAVPW1
	
	unencodedURL := self.getServerVariable(UNENCODED_URL);
	contentType := self.getServerVariable(HTTP_CONTENT_TYPE);
	
	//app.writeLog("incoming =" &amp; CrLf &amp; "httpIn: " &amp; httpIn &amp; CrLf &amp; "queryStr: " &amp; queryStr &amp; CrLf &amp; "pathIn: " &amp; pathIn &amp; CrLf &amp; "methodType: " &amp; methodType &amp; CrLf &amp; "contentType: " &amp; contentType, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	//epr TFS 46632 23/9/19
	newPathIn := pathIn;
	newMethodType := methodType;		// TFS 49227
	newHttpIn := httpIn;
		
	// pathIn = methodName/param1/param2/param3 ... etc
	create allPathIns transient;
	pathIn.trimCharacters("/").getTokensForDelimiter("/", allPathIns);
	
	if allPathIns.size &gt;= 1 and not self.allLoggingExclusions.includes(allPathIns[1]) then	
		app.writeLog("incoming=" &amp; methodType &amp; " " &amp; pathIn &amp; "?" &amp; queryStr, LogINFO);				//navra1 - 24th Aug 2022 - TFS 50365          
		app.writeLog("Content-Type: " &amp; contentType &amp; CrLf &amp; "Body: " &amp; httpIn, LogDEBUG);				//navra1 - 24th Aug 2022 - TFS 50365          
	else
		app.writeLog("incoming=" &amp; methodType &amp; " " &amp; pathIn &amp; "?" &amp; queryStr, LogTRACE);				//navra1 - 24th Aug 2022 - TFS 50365          
		app.writeLog("Content-Type: " &amp; contentType &amp; CrLf &amp; "Body: " &amp; httpIn, LogTRACE);				//navra1 - 24th Aug 2022 - TFS 50365          
	endif;	
	
	// Try and handle '/' in the parameters sent in to jadehttp.dll
	if allPathIns.size &gt; 1 then
		// Skip all the base url stuff, and start at the called method name
		paramStart := unencodedURL.pos(allPathIns[1],1);
		if paramStart &gt; 0 then
		
			// Work out how long our parameter list should be
			// All requests coming in here will contain a '?' in the URL otherwise jadehttp.dll won't know who to send it to
			paramStart := paramStart + allPathIns[1].length + 1;
			paramEnd := unencodedURL.pos("?", paramStart);
						
			// Get just the method parameters from methodName/[param1,param2 ...]?WebServiceName
			unencodedParams := unencodedURL[paramStart:(paramEnd - paramStart)];
			app.writeLog("unencodedParams = " &amp; unencodedParams, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
			
			// Now work out what JADE thinks the path is, starting after the methodName/ bit
			pathStart := pathIn.pos("/", 2);
			if pathStart &gt; 0 then
				pathParams:=pathIn[pathStart + 1 :  end];	
			endif;
			
			// If JADE hasn't quite got it right, then let set the 'real' path
			if pathParams &lt;&gt; null and pathParams &lt;&gt; unencodedParams then
				newPathIn := pathIn[1 : pathStart] &amp; unencodedParams;
			endif;
			
		endif;
	endif;
	
	// TFS 49227 start
	// Validate License based on the API call
	if not self.validateLicense(newPathIn) then
		// this calls a getForbidden method which at the moment is just implemented at the WS_RestWebServiceProvider level
		// and returns HttpResponseForbidden. 
		inheritMethod("", queryStr, "/Unauthorised", "GET");
		return;
	endif;
	
	// Parse any form data into a Name-Value-Pair Dictionay
	if contentType = "application/x-www-form-urlencoded" and newHttpIn &lt;&gt; "" then
		self.formData.parseNameValuePair(newHttpIn);
	endif;
	
	// Parse any query string data into a Name-Value-Pair Dictionay
	if queryStr &lt;&gt; "" then
		self.qsData.parseNameValuePair(queryStr);
	endif;
	// TFS 49227 end
	
	// 01/08/2022 navlw1 TFS 53854 new code to replace above
	on CM_Exception do self.handleCMException(exception);
	self.preTransformedRequest := newHttpIn;
	self.postTransformedRequest := null;
	newHttpIn := self.transformRequest(newHttpIn,queryStr,pathIn,newMethodType);
	
	//self.preProcessRequest(newHttpIn, queryStr, pathIn, methodType, contentType);	// ### TFS 56988 (57003) 08Mar2023 NAVPW1				// MTN-36569
	newPathIn := self.preProcessRequest(newHttpIn, queryStr, pathIn, methodType, contentType);	// ### TFS 56988 (57003) 08Mar2023 NAVPW1	// MTN-36569
	on CM_Exception do null;
	
	// if the token is invalid for some reason then we redirect to /Unauthorise
	if app.myPassport.hasErrors() then
		inheritMethod("", queryStr, "/Unauthorised/" &amp; self.httpStatusCode.String, "GET");
		return;
	endif;
	
	self.postTransformedRequest := newHttpIn;
	self.requestPath := newPathIn.toLower();
	inheritMethod(newHttpIn, queryStr, newPathIn, newMethodType);
	
	//navra1 - MTN-36928 - 8th Jan 2026-1 - start
	//should already be done or not even set on this passport, but just for extra safety - doesnt cause harm
	if app.myPassport.context = Context_Pass_NoEventRecord then
		app.myPassport.setContext(Context_Pass_Null);
	endif;
	//navra1 - MTN-36928 - 8th Jan 2026-1 - end
	
	// ### TFS 53883 20June2022 NAVPW1
	if hadError then //Redirects request to a rest method that handles string too long errors and returns an nice 400 error back to the user
		newHttpIn := "";
		newPathIn := "/jsonFormatError/" &amp; exCode.String &amp; "/" &amp; exMessage.replaceCharsWithHTML();
		newMethodType := "GET";
		inheritMethod(newHttpIn, queryStr, newPathIn, newMethodType);
	endif;
	// ### TFS 53883 20June2022 NAVPW1
	
epilog
	delete allPathIns;
	
	// TFS 49227 start
	if self.formData &lt;&gt; null then
		self.formData.purge();
	endif;
	if self.qsData &lt;&gt; null then
		self.qsData.purge();
	endif;
	// TFS 49227 end
	
	self.allJWTClaims.clear(); // 1 August 2022 navlw tfs 53854
end;</source>
        <Parameter name="httpIn" type="String"/>
        <Parameter name="queryStr" type="String"/>
        <Parameter name="pathIn" type="String"/>
        <Parameter name="methodType" type="String"/>
    </JadeMethod>
    <JadeMethod name="reply" id="1e94f5d9-d956-4f7f-8fb8-e22fc0d1c61d">
        <source>reply(msg: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2019	jlger1	Initial creation

*/

vars
	pos				: Integer;
	allPathIns		: StringArray;
begin
	inheritMethod(msg);
	
	//app.writeLog("reply=" &amp; msg, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053		
	
	create allPathIns transient;															//navra1 -9Sep2022 - TFS 50365 	
	self.requestPath.trimCharacters("/").getTokensForDelimiter("/", allPathIns);			//navra1 -9Sep2022 - TFS 50365 	
	if allPathIns.size &gt;= 1 and not self.allLoggingExclusions.includes(allPathIns[1]) then	//navra1 -9Sep2022 - TFS 50365 	
		app.writeLog("Sending reply", LogINFO);												//navra1 -9Sep2022 - TFS 50365 	
		app.writeLog("reply=" &amp; msg, LogDEBUG);												//navra1 -9Sep2022 - TFS 50365 	
	else																					//navra1 -9Sep2022 - TFS 50365 	
		app.writeLog("reply=" &amp; msg, LogTRACE);												//navra1 -9Sep2022 - TFS 50365 	
	endif;	
	
epilog

end;</source>
        <Parameter name="msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="saveUserState" id="014fcbc7-a35e-43a5-9978-eb7ca6cce6f1">
        <updating/>
        <source>saveUserState(user : CM_User; terminal : CM_Terminal) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 September 2020	jlgrr1	Initial creation from InitialisePassport TFS 49227
16 April 2022		navmd1	TFS 53378 REST Refactor / GenericAPI

*/

vars

begin
	executeWhen JMTDevelopmentEnvironment;
		// No need to do this for Unit Tests
		if app.isJMTUnitTest then
			return;
		endif;
	endExecuteWhen;
	
	if  user &lt;&gt; app.myPublicUser  then
		app.myTrxUA.trxUpdateUserStateData(app.getMyUser(), ConfigGrp_Web, UserCurrentTerminal, terminal.code, app.myPassport);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="user" type="CM_User"/>
        <Parameter name="terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setIgnoreWarnings" id="c9880081-6298-4773-8d07-0be7f4faa883">
        <source>setIgnoreWarnings(ignore : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021	jlier1	Initial creation TFS 52595

*/

vars

begin
	app.myPassport.setWarningsIgnored(ignore); 
	app.myPassport.warningsAcknowledged := ignore; 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="ignore" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="templateGet" id="bcf10005-d9f4-4afe-a159-34ccc969e046">
        <updating/>
        <source>templateGet() : WS_Response updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2019	jlger1	Initial creation

*/

vars
	response : WS_Response;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		// this will return the rest faults
		return response;
	endif;	
	
	
	
	return response;
epilog
	
	self.finaliseResponse(response);


end;</source>
        <access>protected</access>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="templatePut" id="0e8e9205-ba1c-4189-a745-f2c27452de0b">
        <updating/>
        <source>templatePut() : WS_Response updating , protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2019	jlger1	Initial creation

*/

vars
	response : WS_Response;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	//check permissions
	app.checkCurrentUserHasAccess(PmHHReleaseStaging);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;		// Set Response code accordingly
		return response;
	endif;	
	
	
	//call trx method
	
	return response;
epilog
	//delete transients;
	
	self.finaliseResponse(response);

end;</source>
        <access>protected</access>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="transformRequest" id="1bfdaa37-d8c3-46e9-8aa3-623a424bcce4">
        <updating/>
        <source>transformRequest(_httpIn: String; _queryStr: String; _pathIn: String; _methodType: String) : String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 August 2022		navlw1	Initial creation TFS 53854
08 September 2022	navmd1	TFS 54664 Added additional logging to determine why a transform didn't happen
23 February	2024	navcs2	ChangeRequest 60787: EUP | Add system alert for File Loading fails 

*/

vars
	errors 		: String;
	operator	: String;
	body		: String;
	token		: String;
	user 		: CM_User;
	terminal 	: CM_Terminal;
	audience 	: String;
	methodName 	: String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	if _methodType &lt;&gt; JadeHTTPConnection.Verb_POST and _methodType &lt;&gt; JadeHTTPConnection.Verb_PUT then
		app.writeLog(method.qualifiedName &amp; " Returning Early: Message not POST or PUT", LogTRACE);
		return _httpIn;
	endif;
	
	// if we are a login we will not have a token yet so return
	if _pathIn = "/login" then
		app.writeLog(method.qualifiedName &amp; " Returning Early: Message POST /login", LogTRACE);
		return _httpIn;
	endif;
	
	token := self.parseBearerAuth();
	if token = "" then
		app.writeLog(method.qualifiedName &amp; " Returning Early: Bearer Token not found", LogTRACE);
		return _httpIn;
	endif;
	
	WS_WebServiceAgent@validateJWT(token, false, user, terminal, audience, self.allJWTClaims); // 08 Aug 2022 navlw1 tfs 53854
	if app.myPassport.hasErrors() then
		app.writeLog(method.qualifiedName &amp; " Returning Early: Bearer Token invalid", LogTRACE);
		return _httpIn;
	endif;
	
	if allJWTClaims.operatorId = "" then
		app.writeLog(method.qualifiedName &amp; " Returning Early: Operator JWT Claim not found", LogTRACE);
		return _httpIn;
	endif;
	
	// operator check
	operator := self.allJWTClaims.operatorId;
	if operator = "" or (operator = "MTN" or operator = "NAVIS") then
		app.writeLog(method.qualifiedName &amp; " Returning Early: Operator not customised", LogTRACE);
		return _httpIn;
	endif;
	
	methodName := _pathIn.trimCharacters('/');
	body := myMapperDll.transformIncomingMessage(operator,methodName,_httpIn,_methodType,errors);

	app.writeLog(method.qualifiedName &amp; Tab &amp; "Before " &amp; _httpIn, LogDEBUG);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "After " &amp; body, LogDEBUG);
	
	if errors &lt;&gt; "" then
		// Check to only create an alert from the call in WebServicesSchema::WS_RestWebServiceProvider::processRequest
		if _queryStr &lt;&gt; null then			// 23/02/2024 navcs2 ChangeRequest 60787 	
			self.createAlert(errors);		// 23/02/2024 navcs2 ChangeRequest 60787
		endif;								// 23/02/2024 navcs2 ChangeRequest 60787
		app.writeLog(method.qualifiedName &amp; Tab &amp; "We had some errors: " &amp; errors, LogERROR);
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Before " &amp; _httpIn, LogERROR);
		app.raiseCMWarning1(Unable_transform_message, errors, null, null, null);
	endif;
	
	return body;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_httpIn" type="String"/>
        <Parameter name="_queryStr" type="String"/>
        <Parameter name="_pathIn" type="String"/>
        <Parameter name="_methodType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateLicense" id="3ec73e4b-a47e-4c06-8bfc-1970e6286faf">
        <source>validateLicense(path : String): Boolean abstract;

/*
	This abstract method should be implemented by each API to validate its specific licensing requirements.

	This is called from ProcessRequest with the URL path being processed, before the actual webservice method is called.
	If this returns FALSE, the getForbidden method will be called instead of the webservice method indicated by the URL.
	This adds a HttpResponseForbidden to the status code.
*/</source>
        <abstract/>
        <Parameter name="path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
