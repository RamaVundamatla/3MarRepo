    <JadeMethod name="secondary" id="a55073e1-8e6c-4b0d-a125-a072876e3333">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>secondary(set: Boolean; _value: Boolean io) mapping, updating;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(SecondaryFlag);
		else
			flags := flags.getValueWithBitUnset(SecondaryFlag);
		endif;
	else
		_value := (flags.bitAnd(SecondaryFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="954ec3df-f202-4432-a40f-5d89ef7ade1b">
        <updating/>
        <source>setForDelete(_reason: String) updating;
//----------------------------------------------------------------
//	Created:	25 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	inheritMethod(_reason);

	if self.myTrackedItem = null then
		return;
	endif;

	self.myTrackedItem.setForConnectDelete(self);	
	

end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="4b0278a2-920a-444d-8741-8da46a79bdbc">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/08/2013	cnwdap1		Initial creation PAR #31935 - recalculate remaining allowable time off power at connect
//
vars
	ti					: CM_TrackedItem;
	minutesOff			: Integer;
	minutesAllowed		: Decimal [12,4];
	minutesRemaining	: Integer;
	timeChanged			: Boolean;
	hours				: Integer;
	minutes				: Decimal [12, 4];

begin
	if self.dateTime &lt;&gt; _tiTransCntrl.dateTime then
		timeChanged := true;
	endif;
	inheritMethod(_tiTransCntrl, _passport);
	
	// now recalculate remaining time off power because we've changed a connection time
	if timeChanged then
		ti := self.myTrackedItem;
		minutesOff := ti.getTotalMinutesOffPower();
		minutesAllowed := ti.getAllowableTimeOffPower();
		minutesAllowed := (minutesAllowed.Integer * 60) + ((minutesAllowed - minutesAllowed.Integer) * 100);
		minutesRemaining := minutesAllowed.Integer - minutesOff;
		hours := (minutesRemaining / 60).Integer;
		minutes := (minutesRemaining mod 60) / 100;
		ti.setRemainingTimeOffPower(hours + minutes);
	endif;
	
epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
