    <JadeMethod name="handleCancel" id="c6779f2a-4595-492a-bebf-26f88c69e58a">
        <updating/>
        <source>handleCancel()updating;
/*
	Created on 14 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

