    <JadeMethod name="doConfirmBoom" id="83306e37-8bad-4b5e-b047-970c2bf4d33e">
        <updating/>
        <source>doConfirmBoom() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorMsgs		: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	numWLEs			: Integer;
	error			: DTO_HandHeldGateError;
	containerInfo	: MobileHandHeldThin::DTO_ContainerInfo;
begin
	create errorMsgs transient;
	self.doClearErrors();
	foreach containerInfo in self.allContainerInfo do
		if (not containerInfo.confirmed) then
			create error transient;
			error.errorNo := error.Error_FowardContainerConfirm;
			error.errorDescr := 'Confirmation of container ' &amp; containerInfo.idx.String &amp; ' is required before proceeding this truck';
			errorMsgs.add(error);
		endif;
	endforeach;

	if (not errorMsgs.isEmpty) then
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
		return;
	endif;
	
	//everything is confirmed: BOOM!!
	app.myHandHeldGateGuiAgent.doProceedJob(self.txtVehicle.text.trimBlanks.toUpper, errorMsgs);
	if (not errorMsgs.isEmpty) then
		app.msgBox('Errors occured when proceeding this truck. They will now be displayed','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
	else
		app.msgBox('Proceeding job successful.','Proceed Success', MsgBox_Exclamation_Mark_Icon);
		self.txtVehicle.text := null;
		self.clearAllInfo();
		self.txtVehicle.setFocus();
	endif;
	
epilog
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	
	delete errorMsgs;
end;





</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmContainer" id="71e66bb3-38df-4c97-b8e9-204b6ffdb5c5">
        <updating/>
        <source>doConfirmContainer() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorMsgs				: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	error					: DTO_HandHeldGateError;
	containerInfo			: MobileHandHeldThin::DTO_ContainerInfo;
	
begin
	containerInfo := self.allContainerInfo[self.showingContainerNum];
	
	containerInfo.containerId 		:= self.txtId.text.trimBlanks.toUpper();
	containerInfo.customsSeal 		:= self.txtSealCust.text.trimBlanks.toUpper();
	containerInfo.operatorSeal 		:= self.txtSealOp.text.trimBlanks.toUpper();
	containerInfo.shipperSeal 		:= self.txtSealShip.text.trimBlanks.toUpper();
	containerInfo.hazardousChecked 	:= self.chkHaz.value;

	create errorMsgs transient;
	self.doClearErrors();
	app.myHandHeldGateGuiAgent.doConfirmContainer(self.txtVehicle.text.trimBlanks.toUpper, 
														containerInfo, 
														errorMsgs);
	
	containerInfo.setButtonCaption();
	if containerInfo.confirmed then
		// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
		//self.tblDamage.setTableFromTI(containerInfo.myRealTrackedItem.allDamageInstances);
		self.tblDamage.setTableFromTI(containerInfo.myRealTrackedItem.allDamageInstancesByPos);
		self.txtDamage.text := containerInfo.myRealTrackedItem.remarks;
		self.lblInfoCaption.caption := 'CONTAINER ' &amp; containerInfo.idx.String &amp; ' CONFIRMED';
		self.doShowFrmMain();
	else
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
	endif;
	self.btnDamage.enabled  := containerInfo.myPxyTrackedItem &lt;&gt; null;
	
epilog
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	
	delete errorMsgs;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmDamage" id="3ac5738d-4c19-4a53-8d0b-bc0fbb78b316">
        <updating/>
        <source>doConfirmDamage() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	damageRemarks		: String;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//damageDict			: MobileHandHeldThin::CM_DamageInstanceByLocDict;
	damageDict			: MobileHandHeldThin::CM_DamageInstanceByDmgePos;
	errorMsgs			: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	containerInfo		: MobileHandHeldThin::DTO_ContainerInfo;
	errors				: String;
begin
	containerInfo := self.allContainerInfo[self.showingContainerNum];
	
	if (not containerInfo.confirmed) then
		app.msgBox('You must confirm container ' &amp; self.showingContainerNum.String &amp; ' before entering damage info.','Error: Container not yet confirmed.',MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	create damageDict transient;
	create errorMsgs transient;
	
	self.tblDamage.setProxyFromTable(damageDict,null, errors);
	
	if errors &lt;&gt; null then
		if app.msgBox(errors &amp; CrLf &amp; 'Continue?', 'Entry Warnings - Continue?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	damageRemarks := self.txtDamage.text.trimBlanks;
	
	app.myHandHeldGateGuiAgent.doConfirmDamage(self.txtVehicle.text.trimBlanks,
											containerInfo,
											damageRemarks,
											damageDict,
											errorMsgs);
	
	if (not errorMsgs.isEmpty) then
		app.msgBox('Errors occured when applying damage details. They will now be displayed','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
	else
		app.msgBox('Damage details confirmed.','Damage Confirmed', MsgBox_Exclamation_Mark_Icon);
		self.doShowFrmInfo(self.showingContainerNum);
	endif;

epilog
	
	if damageDict &lt;&gt; null then
		damageDict.purge();
	endif;
	delete damageDict;

	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	delete errorMsgs;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmDamageNew" id="f31256ef-224c-4e2e-93c6-edee75bca8bd">
        <updating/>
        <source>doConfirmDamageNew() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	damageRemarks		: String;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//damageDict			: MobileHandHeldThin::CM_DamageInstanceByLocDict;
	damageDict			: MobileHandHeldThin::CM_DamageInstanceByDmgePos;
	errorMsgs			: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	containerInfo		: MobileHandHeldThin::DTO_ContainerInfo;
	errors				: String;
	damageInstance  	: MobileHandHeldThin::CM_DamageInstance;
begin
	containerInfo := self.allContainerInfo[self.showingContainerNum];
	
	create damageDict transient;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//containerInfo.myPxyTrackedItem.allDamageInstances.purge;
	containerInfo.myPxyTrackedItem.allDamageInstancesByPos.purge;
	self.tblDamage.setProxyFromTable(damageDict,containerInfo.myPxyTrackedItem,  errors);
	
	if errors &lt;&gt; null then
		if app.msgBox(errors &amp; CrLf &amp; 'Continue?', 'Entry Warnings - Continue?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	containerInfo.damageRemarks := self.txtDamage.text.trimBlanks;
	
	self.doShowFrmInfo(self.showingContainerNum);
	
epilog
	delete damageDict;

end;
</source>
    </JadeMethod>
    <JadeMethod name="doGetValidContainer" id="1b9c21cc-d711-4464-86dd-61ca585d9d42">
        <source>doGetValidContainer();
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	errorMsgs				: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
