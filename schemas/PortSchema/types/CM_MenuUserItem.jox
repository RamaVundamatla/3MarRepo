    <JadeMethod name="setProxyMenuUserItem" id="7efc568a-0971-4c08-bf75-380a75d691d3">
        <updating/>
        <source>setProxyMenuUserItem(_heading, _pictureButton,_pictureButtonDown, _pictureIcon,_toolTip : String;
					 _menuItem : CM_MenuItem; _menuRoot : CM_MenuRoot) updating;

vars

begin

	self.heading				:= _heading;
	self.myMenuItem				:= _menuItem;
	self.pictureStringButton	:= _pictureButton;
	self.pictureStringButtonDown:= _pictureButtonDown;
	self.pictureStringIcon		:= _pictureIcon;
	self.toolTip 				:= _toolTip;
	
	if _menuItem &lt;&gt; null then
		// only set menuRoot and add into dict if myMenuItem is not null
		self.myMenuRoot	:= _menuRoot;
	else
		self.myMenuRoot	:= null;
	endif;
		
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_pictureButton" type="String"/>
        <Parameter name="_pictureButtonDown" type="String"/>
        <Parameter name="_pictureIcon" type="String"/>
        <Parameter name="_toolTip" type="String"/>
        <Parameter name="_menuItem" type="CM_MenuItem"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot"/>
    </JadeMethod>
