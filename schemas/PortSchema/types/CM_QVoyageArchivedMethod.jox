<Class name="CM_QVoyageArchivedMethod" id="4acc5eac-1417-4bd6-8945-5fdeda954cb8">
    <superclass name="CM_QIntegerLookupMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="43a1e505-f0e7-4006-abd0-1e7152fcf326">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2011	cnwndl1	Initial creation	Par 28421

*/

vars
	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;
	
	self.allAllowedOperators.purge();
	
	create oper as CM_QIntegerIsOneOf persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
