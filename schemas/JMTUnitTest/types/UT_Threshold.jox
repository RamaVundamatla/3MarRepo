					);
					
	//1 with repair task in repair task area
	self.addCargo(	"THRS1110307",	//_id : String;
					isoType,	///_isoType: String;
					grade,	//_mtGrade : CM_MTGrade;
					_operator,	//_operator : CM_Operator;
					_ptiRepairToDo,	//_toDo : CM_ToDoTaskDesc;
					_repairTA	//_ta : CM_TerminalArea
					);
					
	//1 with repair task in different area
	self.addCargo(	"THRS1110308",	//_id : String;
					isoType,	///_isoType: String;
					grade,	//_mtGrade : CM_MTGrade;
					_operator,	//_operator : CM_Operator;
					_ptiRepairToDo,	//_toDo : CM_ToDoTaskDesc;
