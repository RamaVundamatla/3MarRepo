<Class name="CnEcSerialInterface" id="6724021a-8deb-4412-b3a4-7e3c7e0472d8">
    <superclass name="Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <access>protected</access>
