<Class name="CM_Fuel" id="5a06033a-a55e-427c-ae87-30c8878e88ca">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="litres" id="ce42f8a5-2977-4cd9-84c3-26b1d800cbf0">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <JadeMethod name="canUpdateTransaction" id="9eafbc6e-4a67-4389-b75c-6f55dc9fc23b">
        <source>canUpdateTransaction(): Boolean;
// ---------------------------------------------------------------------------
// Created:     02 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="afff02a2-35d3-46df-a5ab-97432e1c8668">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := "Litres: " &amp; self.litres.String;
	
			lDetail := lDetail &amp; " " &amp; self.urNumber.String;	
			
			return lDetail;
			
		endif;
	elseif _attrName = ETRow_Litres or
		   _attrName = ETRow_FuelLitres then
		return self.litres.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="d67c9871-10cb-468e-8388-194d1996e8fb">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
begin
	lDetail := inheritMethod();
	
	lDetail := lDetail &amp; "Litres: " &amp; self.litres.String;
	
	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="4f7a2c32-f080-47bb-a0d1-23847e51c902">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_tiTransCntrl, _passport);
	//th2 PAR 11962 - whoever implemented user defined todo tasks failed to consider
	//the fact that user may associate any TI transaction type to create along with it.
	//For toDoTasks the _tiTransCntrl is always just type CMIF_TITransactionController
	if CMIF_FuelTransController.hasInstance(_tiTransCntrl) then
		self.litres := _tiTransCntrl.CMIF_FuelTransController.litres;
	endif;
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFuelDetails" id="dba03964-333b-4b02-a0e0-dde09d00219b">
        <updating/>
        <source>setFuelDetails(_litres : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.litres := _litres;

end;</source>
        <Parameter name="_litres" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setNewProperties" id="5de11e5b-3bb3-4305-a9d4-eac651187335">
        <updating/>
        <source>setNewProperties(previousTrans: CM_Fuel input) updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(previousTrans);

	previousTrans.litres := self.litres;
end;</source>
        <Parameter name="previousTrans" type="CM_Fuel" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="729a5a1f-4f12-45eb-bdf8-d7758344a2b8">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;

vars
begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then 
		return;
	endif;
	
	self.myTrackedItem.setFuelledDetails();

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
