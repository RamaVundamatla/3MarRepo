    <JadeMethod name="getDefaultModeAndTypeFromColl" id="89d3a7c8-340d-4268-a05f-a12041c7a024">
        <source>getDefaultModeAndTypeFromColl(_type, _mode :Integer output) protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/03/2010	cnwcs5		Fixed issue with BOL
// 22 Dec 2022  navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 18 Feb 2023  navmv20     TFS 55649 Task 55689: UI - Selector Query Contracts
// ---------------------------------------------------------------------------

vars
	obj	:Object;
begin
	obj 	:= self.myCollection.first;
	_mode := 0;
	_type := 0;
	
	if obj = null then
		return;
	endif;
	
	if obj.isKindOf (CM_DynamicObject_Snapshot) then
		_type := CM_QueryDefinition.Snapshot_Query_Type;
		_mode := CM_QueryDefinition.Snapshot_Query_Mode;
	elseif obj.isKindOf (CM_BulkRelease) then
		_type := CM_QueryDefinition.Release_Query_Type;
		_mode := CM_QueryDefinition.Release_Query_Mode;
	elseif obj.isKindOf (CM_ReserveDetail) then
		_type := CM_QueryDefinition.Release_Query_Type;
		_mode :=  CM_QueryDefinition.ReleaseItem_Query_Mode;
	elseif obj.isKindOf (CM_BookingRef) then
		_type := CM_QueryDefinition.BookRef_Query_Type;
		_mode := CM_QueryDefinition.BookRef_Query_Mode;
	elseif obj.isKindOf (CM_BookingRefItem) then
		_type := CM_QueryDefinition.BookRef_Query_Type;
		_mode := CM_QueryDefinition.BookRefItem_Query_Mode;
	elseif obj.isKindOf (CM_BOL) then				// 01/03/2010 cnwcs5
		_type := CM_QueryDefinition.BOL_Query_Type;	// 01/03/2010 cnwcs5
		_mode := obj.CM_BOL.bolType;				// 01/03/2010 cnwcs5
	// Feb 2012 CMS 1262 transaction selectors
	elseif obj.isKindOf(CM_TITransaction) then
		_type := CM_QueryDefinition.Transaction_Query_Type;
		_mode := CM_QueryDefinition.CargoTransaction_Query_Mode;
	//Start 22.12.2022 navhl20 #54350[54269]
	elseif obj.isKindOf(CM_WOTransaction) then
		_type := CM_QueryDefinition.Transaction_Query_Type;
		_mode := CM_QueryDefinition.WorkOrderTrans_Query_Mode;
	//End 22.12.2022 navhl20 #54350[54269]
	elseif obj.isKindOf(CM_EventTransaction) then
		_type := CM_QueryDefinition.Transaction_Query_Type;
		_mode := CM_QueryDefinition.EventTransaction_Query_Mode;
	elseif obj.isKindOf(HMS_VTMISTransaction) then
		_type := CM_QueryDefinition.Transaction_Query_Type;
		_mode := CM_QueryDefinition.HMSTransaction_Query_Mode;
	elseif obj.isKindOf(CM_Invoice) then
		_type := CM_QueryDefinition.Invoicing_Query_Type;
		_mode := CM_QueryDefinition.Invoice_Query_Mode;
	elseif obj.isKindOf(CM_InvoiceLine) then
		_type := CM_QueryDefinition.Invoicing_Query_Type;
		_mode := CM_QueryDefinition.InvoiceLine_Query_Mode;
	elseif obj.isKindOf(CM_CashPayment) then
		_type := CM_QueryDefinition.Cash_Query_Type;
		_mode := CM_QueryDefinition.CashPayment_Query_Mode;
	elseif obj.isKindOf(CM_CashReceipt) then
		_type := CM_QueryDefinition.Cash_Query_Type;
		_mode := CM_QueryDefinition.CashReceipt_Query_Mode;
	// 18/02/2023  navmv20  TFS 55649 Task 55689 - START
	elseif obj.isKindOf(CM_InvoiceContract) then
		_type := CM_QueryDefinition.Invoicing_Query_Type;
		_mode := CM_QueryDefinition.Contract_Query_Mode;
	// 18/02/2023  navmv20  TFS 55649 Task 55689 - END
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer" usage="output"/>
        <Parameter name="_mode" type="Integer" usage="output"/>
    </JadeMethod>
