    <JadeMethod name="setDetailsFromParentForm" id="0521173b-47ab-4184-8e4c-491621c329cc">
        <updating/>
        <source>setDetailsFromParentForm(	_description : String;
							_stops, _tasks : ObjectArray;
							_stow : CM_SpecialStow;
							_lifts : ObjectArray;
							_freightForwarder : CM_ConsigneeConsignor;
							_customsAgent : CM_CustomsAgent;
							_bol, _consVoyage, _eirNumber, _purchaseOrder,_shippingReference, _transportMode, _wagon, _train : String;
							_wagonClass : CM_WagonClass;
							_subTerminal : CM_SubTerminal;
							_businessUnit : CM_Bank;
							_curtainsIn : Boolean;
							_coolingType, _voltageType : String;
							_cargoId : String;
							_pxyTi : CM_TrackedItem;
							_shipLine	: CM_ShippingLine;			// 20 may 2022 navgm20 TFS 53204
							_countryOfOrigin : CM_Country;		// 16.08.2022 navak20 TFS 54441
							_isPrenoteForm : Boolean;
							_cargoType : CM_CargoType;			// 17.4.2023 navmk20 TFS 56980
							_invoicecontractID: CM_InvoiceContract;
							_overlanded : Boolean) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2009	cnwdap1	Initial creation
25 November2015	cnwma1  PAR #36943 Shipping Reference error during extract
14 March 2016	cnwdap1	PAR #37606 "Not available for entry" customs agent and freight forwarder
20 May 2022	navgm20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
17 April 2023   navmk20 Bug 56980: MTN - Additional details form not displayed
05/02/2023		navkc1 	Bug 62302: CUX | Can't mark onboard or child cargo as 'overlanded'
*/
vars
	intArray	: IntegerArray;
	obj			: Object;
	strArray	: StringArray;
	index : Integer;

begin

	self.selectedCargoType := _cargoType;		// 17.4.2023 navmk20 TFS 56980

	self.loadCombos;
	
	self.txtDescription.setValue(_description);
	
	create intArray transient;
	self.lstAllStops.clearSelected();
	foreach obj in _stops do
		intArray.add(obj.CM_StopsTable.id);
	endforeach;
	self.myAssistant.setListTableStopsTables(self.lstAllStops, intArray);
	self.lstStops.hasLostFocus(self.lstStops);
	
	intArray.clear;
	self.lstToDoTasks.clearSelected();
	foreach obj in _tasks do
		intArray.add(obj.CM_ToDoTaskDesc.code);
	endforeach;
	self.myAssistant.setListTableToDoTasks(self.lstToDoTasks, intArray);
	self.lstToDo.hasLostFocus(self.lstToDo);
	
	cmbSpecialStow.setForObject(_stow);
	// Start 20 may 2022 navgm20 TFS 53204
	cmbShippingLine.setForObject(_shipLine);	
	if _shipLine &lt;&gt; null and _shipLine.isNotAvailableForEntry then																								
		self.cmbShippingLine.getEmbeddedControl.ComboBox.listIndex := self.cmbShippingLine.addItemObject(_shipLine.code &amp; Tab &amp; _shipLine.description, _shipLine);	
	endif;
	// End 20 may 2022 navgm20 TFS 53204
	
	// 16.08.2022 navak20 TFS 54441
	cmbCtryOfOrigin.setForObject(_countryOfOrigin);	
	if _countryOfOrigin &lt;&gt; null and _countryOfOrigin.isNotAvailableForEntry then																								
		self.cmbCtryOfOrigin.getEmbeddedControl.ComboBox.listIndex := self.cmbCtryOfOrigin.addItemObject(_countryOfOrigin.code &amp; Tab &amp; _countryOfOrigin.description, _countryOfOrigin);	
	endif;
	// 16.08.2022 navak20 TFS 54441
	
	create strArray transient;
	strArray.clear;
	foreach obj in _lifts do
		strArray.add(obj.CM_SpecialLift.code);
	endforeach;
	self.myAssistant.setListTableSpecialLift(self.lstSpecialLift, strArray);
	self.txtSpecialLift.text := self.truncateDisplayString(self.lstSpecialLift.getSelectedString(CM_SpecialLift::code.name), -1);
	
	cmbFreightFwdr.setForObject(_freightForwarder);
	if _freightForwarder &lt;&gt; null and _freightForwarder.isNotAvailableForEntry then																			// PAR #37606
		self.cmbFreightFwdr.getEmbeddedControl.ComboBox.listIndex := self.cmbFreightFwdr.addItemObject(_freightForwarder.getYADisplay, _freightForwarder);	// PAR #37606
	endif;																																					// PAR #37606
	cmbCustomsAgent.setForObject(_customsAgent);
	if _customsAgent &lt;&gt; null and _customsAgent.isNotAvailableForEntry then																								// PAR #37606
		self.cmbCustomsAgent.getEmbeddedControl.ComboBox.listIndex := self.cmbCustomsAgent.addItemObject(_customsAgent.code &amp; Tab &amp; _customsAgent.name, _customsAgent);	// PAR #37606
	endif;																																								// PAR #37606
	txtHouseBOL.setValue(_bol);
	txtConsignVoy.setValue(_consVoyage);
	txtEquipXchg.setValue(_eirNumber);
	txtPurchaseOrder.setValue(_purchaseOrder);
	txtShippingRef.setValue(_shippingReference);    //25/11/2015 cnwma1 PAR #36943
	cmbTransportMode.setForText(_transportMode);
	txtWagon.setValue(_wagon);
	cmbWagonClass.setForObject(_wagonClass);	//12 May 2014	NDL	Par 33615
	txtWagonTrain.setValue(_train);	//04 Nov 2009	NDL Par 21519
	cmbSubTerminal.setForObject(_subTerminal);
	cmbBusUnit.setForObject(_businessUnit);
	chkCurtainsIn.setValue(_curtainsIn);
	cmbCoolingType.setForText(_coolingType);
	cmbVoltageType.setForText(_voltageType);
	
	chkOverlanded.setValue(_overlanded); //05/02/2023	navkc1 Bug 62302
	
	self.loadInvContract();
	cmbInvContractID.setForObject(_invoicecontractID);	//23.02.2023 navtnr20 TFS CR 55648 Task 55663:
	/*if _invoicecontractID &lt;&gt; null then		//28.03.2023 navtnr20 TFS 57332
		self.cmbInvContractID.getEmbeddedControl.ComboBox.listIndex := self.cmbInvContractID.addItemObject(_invoicecontractID.contractId,_invoicecontractID);	
	endif;	*/
	self.cargoId := _cargoId;
	
	//03 May 2018	NDL	TFS 37795
	txtAddRemarks1.setIsEnabled( false );
	txtAddRemarks2.setIsEnabled( false );
	if _pxyTi &lt;&gt; null then
		txtAddRemarks1.setMaxLength(0);	//21 May 2018	NDL	TFS 38566
		txtAddRemarks2.setMaxLength(0);	//21 May 2018	NDL	TFS 38566
		if _isPrenoteForm then
			txtAddRemarks1.setIsEnabled( true );
			txtAddRemarks2.setIsEnabled( true );
		endif;
		txtAddRemarks1.setValue( _pxyTi.remarksAdditional1 );
		txtAddRemarks2.setValue( _pxyTi.remarksAdditional2 );
	endif;
	
epilog
	delete intArray;
	delete strArray;
end;</source>
