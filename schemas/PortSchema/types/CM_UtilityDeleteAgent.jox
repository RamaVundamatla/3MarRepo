    <JadeMethod name="utlDeleteActivityHistory" id="4d5ed496-22af-4d86-981c-819c6767ae52">
        <source>utlDeleteActivityHistory(_history :CM_ActivityHistory io; _passport : CM_Passport);
// -------------------------------------------
// Created 30 March 2004 by cnwdvb1
// -------------------------------------------
// 14/05/2012	cnwcs5	par 29450 - change to delete single history (not collection)
//								  - 
vars
	
begin
	// I do not call self.initialiseActivity because I want the calling method to decide whether
	// to set app.continueCMExceptions
	self.raiseExceptionIfNotInTranState(method);
	
	_history.erase(NORMAL_ERASE);
end;</source>
        <Parameter name="_history" type="CM_ActivityHistory" usage="io"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteAutoSchedule" id="c0aa35a6-1717-4fa7-8919-8331d6cfbc80">
        <source>utlDeleteAutoSchedule(_autoSchedule : CM_AutoSchedule io; _passport : CM_Passport input);

// cnwdvb1 15 January 2003 

vars
	description		: String;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	if not self.exclusiveLockObjectToDelete(_autoSchedule) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;
	
	if _passport.noErrors then
		description := app.getErrorString2(AutoScheduleRemoved, _autoSchedule.description, _passport.userCode);
		app.createActivityHistory(ActivityHistoryGeneral, null, null, description, true, false);
	endif;
	
	if _passport.noErrors then
		delete _autoSchedule;
	endif;

end;</source>
        <Parameter name="_autoSchedule" type="CM_AutoSchedule" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
