    <JadeMethod name="setAgentsBooleans" id="9f3fd49d-1da6-4769-bac1-8373727587e3">
        <updating/>
        <source>setAgentsBooleans(_doCT, _doCont, _doHaz, _doImex, _doIso, _doOp, _doPorts, _doSpace, _doTA, _doVoy, _doYA : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.doChkCargoType := _doCT;
	self.doChkContents := _doCont;
	self.doChkHAZ := _doHaz;
	self.doChkIMEX := _doImex;
	self.doChkISO := _doIso;
	self.doChkOperator := _doOp;
	self.doChkPorts := _doPorts;
	self.doChkSpace := _doSpace;
	self.doChkTerminalArea := _doTA;
	self.doChkVoyages := _doVoy;
	self.doChkYA := _doYA;
end;</source>
        <Parameter name="_doCT" type="Boolean"/>
        <Parameter name="_doCont" type="Boolean"/>
        <Parameter name="_doHaz" type="Boolean"/>
        <Parameter name="_doImex" type="Boolean"/>
        <Parameter name="_doIso" type="Boolean"/>
        <Parameter name="_doOp" type="Boolean"/>
        <Parameter name="_doPorts" type="Boolean"/>
        <Parameter name="_doSpace" type="Boolean"/>
        <Parameter name="_doTA" type="Boolean"/>
        <Parameter name="_doVoy" type="Boolean"/>
