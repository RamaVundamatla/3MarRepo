    </JadeMethod>
    <JadeMethod name="validateRFIDTagReaderUsage" id="be9ca481-c854-41d1-a50b-8776a7e7f0ab">
        <source>validateRFIDTagReaderUsage(_rfidTagReaders : CM_RFIDTagReaderByCodeDict input) : Boolean;

/*
Date			Who		Reason
01 September 2009	cnwar2	Initial creation

Checks for duplicate RFID Tag Readers for a gate.
*/
vars
	reader 	: CM_RFIDTagReader;
	context, 
	readerType	: String;
	area	: CM_TerminalArea;
	type	: CM_TerminalAreaType;
begin
	if self.isGateAreaLocation then
		context := app.getErrorString (Gate);
	else
		area := self.myTerminalArea;
		
		if area &lt;&gt; null then
			type := area.myType;
		endif;
		
		if type &lt;&gt; null then
			context := type.description;
		endif;
	endif;
	
	reader := self.getRFIDTagReader(true);	// read Tag Reader
	
	if reader &lt;&gt; null then
		
		if not _rfidTagReaders.includes(reader) then
			_rfidTagReaders.add(reader);
		else 
			if self.isGateAreaLocation then
				readerType := app.getErrorString (XLAT_RFID_Read);
			endif;
			app.raiseCMException4(XLAT_Rfid_Used_In_Gate, readerType, reader.description, 
									self.getFullId, context, null, null);
			return false;
		endif;
	endif;
	
	reader := self.getRFIDTagReader(false);	// assign Tag Reader
	if reader &lt;&gt; null then
		
		if not _rfidTagReaders.includes(reader) then
			_rfidTagReaders.add(reader);
		else
			if self.isGateAreaLocation then
				readerType := app.getErrorString (XLAT_RFID_Assign);
			endif;
			
			app.raiseCMException4(XLAT_Rfid_Used_In_Gate, readerType, reader.description, 
									self.getFullId, context, null, null);
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <Parameter name="_rfidTagReaders" type="CM_RFIDTagReaderByCodeDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="59a0904c-28b8-4574-be7b-c04a1ac2436b">
