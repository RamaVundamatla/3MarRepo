        <source>utlCreateInOutVehicle(pIntFaceCommon : CMIF_InOutCommon input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2014	cnwmc5	Initial creation

*/

vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	pIntFaceCommon.validateForCreate(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

