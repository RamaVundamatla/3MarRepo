    <JadeMethod name="doExportXMLDeck" id="1d141a0e-05f1-4832-b318-8cd4c6f23c65">
        <source>doExportXMLDeck() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwer1	Initial creation

*/

vars
	theFileName : String;
	deck : CM_Deck;
begin

	if self.tbRoRolDecks.accessRow(self.tbRoRolDecks.row) = null then
		return;
	endif;
	deck:=self.tbRoRolDecks.accessRow(self.tbRoRolDecks.row).itemObject.CM_Deck;

	if deck = null then
		return;
	endif;
	
	theFileName:=self.getExportFileName(deck);
	if theFileName = null then
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	app.myTrxUA.trxExportAsXMLDoc(deck,theFileName,app.myPassport);

epilog

	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doExportXMLVessel" id="183a340d-21d9-4a83-a132-b4f1bc0f0f7f">
        <source>doExportXMLVessel() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2011	cnwer1	Initial creation

*/

vars
	
	theFileName : String;
begin


	theFileName:=self.getExportFileName(null);
	if theFileName = null then
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	app.myTrxUA.trxExportAsXMLDoc(self.getROROStructure,theFileName,app.myPassport);

	//export the sucker
epilog

	app.mousePointer := Window.MousePointer_Default;
end;</source>
