    <JadeMethod name="convertErrorsWarningsToAlert" id="cbb70b11-8da2-4efc-948b-7024276a73a1">
        <updating/>
        <source>convertErrorsWarningsToAlert(hdgToAdd : String; _linkObject : CM_Object) : CM_SystemAlert updating;
/*
 ------------------------------------------------------------------------
Created:			26 June 2002 by cnwdwq1
Purpose:			Called from R/T areas (and wherever else is required). Converts the errors
							and warnings generated by a TRX into an alert.
							hdgToAdd is the heading for the alert.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	err		: CM_Error;
	alert	: CM_SystemAlert;
begin
	create alert;
	alert.details := hdgToAdd;
	alert.setSeverity(SEVERE_ERROR);
	foreach err in self.allErrorWarnings do
		alert.addLogEntry(err.text);
	endforeach;
	alert.add;
	alert.setLinkedTo(_linkObject);
	app.commitAlert();
	return alert;
end;</source>
        <Parameter name="hdgToAdd" type="String"/>
        <Parameter name="_linkObject" type="CM_Object"/>
        <ReturnType type="CM_SystemAlert"/>
    </JadeMethod>
