    <JadeMethod name="doTblDataDBClick" id="afc90154-7506-4a29-8b55-c00dfe948b87">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2018	jlgndl1	Initial creation	TFS 37447

*/

vars

	rowIndex : Integer;

begin

	rowIndex := table.row;
	
	if rowIndex = table.fixedRows then
		self.doSortByColumn (table);
		return;
	endif;

	inheritMethod(table);

epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateCmbRejectReason" id="768c9d3f-8c3c-4649-95fc-43dcd87c6312">
        <source>populateCmbRejectReason();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2018	jlgndl1	Initial creation	TFS 37928

*/

vars

	index : Integer;
	remark : CM_PredefinedRemark;

begin

	self.cmbRejectReason.clear();
	
	self.cmbRejectReason.addItem( null );
	foreach remark in app.myRoot.allPreDefinedRemarks do
		index := self.cmbRejectReason.addItem( remark.description );
		self.cmbRejectReason.itemObject[index] := remark;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTblData" id="f8f8c8f4-48b5-40a4-b289-d910dce96f93">
        <source>populateTblData();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
14 June 2018	jlgndl1	Initial creation	TFS 39167
15 Aug 2018		NDL		Rewrite for subtotalling.....
18 Oct 2018		jlger1	TFS 41310 - re working for permit requests
15 Feb 2023 	navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars


	comboValues : String; 
	wodCargoRequest : CM_WodCargoRequest;
	statusStr : String;
	dynaDict : DynaDictionary;
	holdId : String;
	obj : Object;
	allCargoRequests : CM_WodCargoRequestSet;
begin

	allCargoRequests:=self.myWorkOrderVoyageDtl.getAllCargoRequests;
	

	if allCargoRequests &lt;&gt; null	then
	
		self.setupTable( comboValues );	
		if not allCargoRequests.isEmpty then
			create dynaDict transient;
			dynaDict.setMembership( CM_WodCargoRequest );
			dynaDict.addExternalKey(String, 100, false, false);
			dynaDict.endKeys(true);
			
			foreach wodCargoRequest in allCargoRequests do
				dynaDict.putAtKey(wodCargoRequest.getHoldId, wodCargoRequest);
			endforeach;
			
			foreach obj in dynaDict do
				wodCargoRequest := obj.CM_WodCargoRequest;
				if holdId &lt;&gt; null then
					//we have loaded at least one
					if holdId &lt;&gt; wodCargoRequest.getHoldId then
						self.addHoldSubTotalLine( holdId );
					endif;
				endif;
				self.addWodCargoRequestLine( wodCargoRequest, comboValues );
				holdId := wodCargoRequest.getHoldId;
			endforeach;
			self.addHoldSubTotalLine( holdId );
			
		endif;
			
	else
	
		self.txtConsecutive.enabled := false;
		self.lblConsecutive.enabled := false;
		self.txtLongest.enabled     := false;
		self.lblLongest.enabled     := false;
		self.lblInPort.caption      := app.getErrorString(Total_days);
	endif;
	
	if self.myWorkOrderVoyageDtl &lt;&gt; null then
		statusStr := self.myWorkOrderVoyageDtl.getStatusString();
	endif;
	
	//15 Aug 2018	NDL	TFS 40050
	self.lblStatus.foreColor := Black;
	self.lblStatus.caption   := null;
	
	if statusStr &lt;&gt; null then
		if statusStr = app.getErrorString(WO_STATUS_APPROVED_DESC) then					//15.02.2023 navma1 #56561
			self.lblStatus.foreColor := Red;
		endif;
		self.lblStatus.caption 		 := app.getErrorString( Status ) &amp; " = " &amp; statusStr;
	endif;
	
	self.setDaysTextBoxes();
	
epilog

	self.setButtons();
	delete dynaDict;

end;</source>
    </JadeMethod>
    <JadeMethod name="setButtons" id="89ead6fd-c4b8-4397-98ad-c6bd3da4229a">
        <source>setButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Mar 2018	jlgndl1	Initial creation	TFS 37447
14 Aug 2018 cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
18 Oct 2021 navma1  Bug 52162: SAL – Approve/Reject option in OOW Confirmation screen for Work Order with Status Complete  
*/

vars

begin

	if myWOVoyage &lt;&gt; null
	and myWOVoyage.myVoyageProcess &lt;&gt; null
	and not myWOVoyage.myVoyageProcess.isDefaultProcessJMT	//23 July 2018	NDL	TFS 39882
	then
		self.btnApprove.visible := true;
		
		self.btnApprove.enabled := true;    //18.10.2021 navma1 #52162
		self.btnReject.enabled  := true;    //18.10.2021 navma1 #52162
		
		if self.myWorkOrderVoyageDtl &lt;&gt; null then
			if self.myWorkOrderVoyageDtl.myParent &lt;&gt; null then
				if self.myWorkOrderVoyageDtl.myParent.taskStatus = WO_STATUS_COMPLETE then	//18.10.2021 navma1 #52162
					self.btnApprove.enabled := false;
					self.btnReject.enabled  := false;
				endif;
			endif;
		endif;
	
		self.btnReject.visible 		 := true;
		self.lblReject.visible 		 := true;
		self.cmbRejectReason.visible := true;
	else
		self.btnApprove.visible 	 := false;
		self.btnReject.visible 		 := false;
		self.lblReject.visible 		 := false;
		self.cmbRejectReason.visible := false;
	endif;
	
	self.btnSave.visible := not self.btnApprove.visible;	//06 Apr 2018	NDL	TFS 37928
	
	if not self.allowUpdate then
		self.txtInPort.enabled 		  := false;
		self.btnApprove.enabled 	  := false;
		self.btnReject.enabled 		  := false;
		self.btnSave.enabled 		  := false;
		self.tblData.userInputEnabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDaysTextBoxes" id="2886ddc0-242d-4bea-9198-ca3a0027693b">
        <source>setDaysTextBoxes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/03/2018	jlgndl1	Initial creation	TFS 37447
23/04/2018	jlgdap1	TFS 38215 PEL1 OOW Confirmation Changes
03 Aug 2018	NDL	TFS 40048 - Mk 3  Combine 'Export' &amp; 'Import' seperate by hold not hatch, and round to nearest 1/4 day, plus add 1/4 day to longest as time in port.
14 Aug 2018	NDL TFS 40267 - mk 4  Now make the 1/4 day crap soft.
15 Aug 2018	NDL	TFS	40050 - Mk 5  Add some more columns and subtotal by holds in the table
20 Aug 2018 NDL	TFS	40050 - Mk 6  Add some more columns and change the rounding again.
18 Sep 2018	NDL	TFS 40893 - mk 7  New total display/calculation rules
*/

vars

	rowIndex : Integer;
	wodCargoRequest : CM_WodCargoRequest;
	holdId : String;
	index : Integer;
	longestDays : Decimal[6,2];
	totDays : Decimal[6,2];
	daysToComplete : Decimal[6,2];
	holdValueArray : DecimalArray;
	holdIdArray : StringArray;
	incrementForCargo : Decimal[5,2];
	roundedTotal : Decimal[6,2];

begin

	create holdValueArray transient;
	create holdIdArray transient;

	foreach rowIndex in 1 to self.tblData.rows do
		if rowIndex &lt;= self.tblData.fixedRows then
			continue;
		endif;
		wodCargoRequest := self.tblData.accessRow( rowIndex ).itemObject.CM_WodCargoRequest;
		if wodCargoRequest = null then
			//Hold summary line, round up then reset the sub total
			roundedTotal := self.myTerminal.applyRoundingToValue( holdValueArray[ index ] );
			holdValueArray[ index ] := roundedTotal;
			self.tblData.setCellText( rowIndex, HoldTotalCol, roundedTotal.asStringJMT );
			continue;
		endif;
		holdId := wodCargoRequest.getHoldId();
			
		if holdIdArray.includes( holdId ) then
			index := holdIdArray.indexOf( holdId );
		else
			holdValueArray.add(0.00);
			holdIdArray.add(holdId);
			index := holdIdArray.size;
		endif;
		
		daysToComplete := self.tblData.accessCell( rowIndex, DaysToCompleteCol ).text.asDecimalJMT;
		
		holdValueArray[ index ] := holdValueArray[ index ] + daysToComplete;
		
	endforeach;
	
	if not holdValueArray.isEmpty then
		foreach index in 1 to holdValueArray.size do
			daysToComplete := holdValueArray[ index ];
			if daysToComplete &gt; 0 then
				if longestDays &lt; daysToComplete then
					longestDays := daysToComplete; 
				endif;
				totDays := totDays + daysToComplete;
			endif;
		endforeach;
	//	longestDays := longestDays + 0.25; // increase the biggest one by another 1/4 day.
		//14 Aug 2018	NDL	TFS 40267
		incrementForCargo := self.myTerminal.getConfig( TotDaysReqAddForCargo ).Decimal;
		longestDays := longestDays + incrementForCargo; 
	endif;

	self.txtConsecutive.text := totDays.asStringJMT;
	self.txtLongest.text := longestDays.asStringJMT;
	
	//13 Dec 2018	epr	TFS 42501
	if  self.tblData.rows &lt;= 1 then
		self.txtInPort.text := self.myWorkOrderVoyageDtl.getCurrentLengthOfTime.asStringJMT;
		return;
	else
//	if self.myWorkOrderVoyageDtl &lt;&gt; null and self.myWorkOrderVoyageDtl.getCurrentLengthOfTime &gt; 0 then
//		self.txtInPort.text := self.myWorkOrderVoyageDtl.getCurrentLengthOfTime.asStringJMT;
	//If it has already been saved off before leave it alone.
		if self.myWorkOrderVoyageDtl &lt;&gt; null and self.myWorkOrderVoyageDtl.getMyParent.CM_WorkOrderVoyage.lengthOfTime &gt; 0 then	//13 Dec 2018	NDL	TFS 42501
			self.txtInPort.text := self.myWorkOrderVoyageDtl.getMyParent.CM_WorkOrderVoyage.lengthOfTime.asStringJMT;
			return;
		endif;
	endif;
	
	//If the users have set it manually, leave it alone in the current session, leave it alone.
	if self.inPortEntered then
		if self.txtInPort.text.Integer &gt; 0 then // 18 Sep 2018	NDL	TFS 40893, to allow for re-calculation if the value has been changed back to zero.
			return;
		endif;
	endif;
	
	//epr TFS 41310 18/10/18
	self.txtInPort.text := longestDays.asStringJMT;
	
epilog

	delete holdValueArray;
	delete holdIdArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="setDaysTextBoxes2" id="aeb2522c-8452-46cb-95f4-489c7b41b99d">
        <source>setDaysTextBoxes2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/03/2018	jlgndl1	Initial creation	TFS 37447
23/04/2018	jlgdap1	TFS 38215 PEL1 OOW Confirmation Changes
03 Aug 2018	NDl	TFS 40048 - Temporary version - Don't del;ete until live, in case pelindo change their mind again.
*/

vars
/*
	rowIndex : Integer;
	wodCargoRequest : CM_WodCargoRequest;
	location : CM_LocationsController;
	imex : Integer;
	longestDays : Decimal[6,2];
	totDays : Decimal[6,2];
	daysToComplete : Decimal[6,2];
	countArray : DecimalArray;
	voyage : CM_Voyage;
	voyageJob : CM_Job;
	workPoint : CM_WorkPoint;
	holdId : String;
	cargo : CM_TrackedItem;
	wle : CM_WorkListEntry;
	holdIdArray : StringArray;
	index : Integer;
	daysToCompleteInt : Integer;
	rem : Decimal[3,2];
	isRelease : Boolean;
*/
begin
/*
	if self.myWorkOrderVoyageDtl &lt;&gt; null then
		self.txtInPort.text := self.myWorkOrderVoyageDtl.getCurrentLengthOfTime.asStringJMT;
		return;
	endif;
	
	//If the users have set it manually, leave it alone
	if self.inPortEntered then
		return;
	endif;
	
	wodCargoRequest := self.tblData.accessRow( self.tblData.rows ).itemObject.CM_WodCargoRequest;
	if wodCargoRequest &lt;&gt; null then
		voyage := wodCargoRequest.getMyVoyageObject();
		workPoint := wodCargoRequest.myWorkpoint;
	endif;
	
	if voyage = null then
		app.msgBox("Voyage not identified, unable to calculate total days",app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	if workPoint = null then
		app.msgBox("Work Popint not identified, unable to calculate total days",app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;

	
	//03 Aug 2018	NDL	TFS 40048 - New way is to total by individual Cargo ( on the planned jobs ) in a hold, and/or planned to a hold, .
	
	create countArray transient;
	create holdIdArray transient;
	
	foreach voyageJob in voyage.allVoyageJobs do
	
		isRelease := voyageJob.isRelease;
		
		foreach wle in voyageJob.workListEntries discreteLock do
		
			cargo := wle.myTrackedItem;
			if cargo = null then
				continue;
			endif;
			
			if isRelease then
				//export
				location := wle.getTargetLocation();
			else
				//import
				location := cargo.myPrimaryActualLocation;
			endif;
			
			if location &lt;&gt; null and location.isVoyageController then
				holdId := location.CM_VoyageController.getHoldID;
				if holdId = null then
					holdId := "Unknown";
				endif;
			else
				holdId := "Unknown";
			endif;
				
			if holdIdArray.includes( holdId ) then
				index := holdIdArray.indexOf( holdId );
			else
				countArray.add(0.00);
				holdIdArray.add(holdId);
				index := holdIdArray.size;
			endif;
			
			daysToComplete := workPoint.getDaysToCompleteWLE( wle );
			
			countArray[ index ] := countArray[ index ] + daysToComplete;
				
		endforeach;
	
	endforeach;
	
	if not countArray.isEmpty then
	
		// round up the daysElapsed for each hold to the nearest 1/4 day
		foreach index in 1 to countArray.size do
			daysToComplete := countArray[ index ];
			daysToCompleteInt := daysToComplete.Integer;
			rem := daysToComplete mod 1;
			if rem &gt; 0 then
				if rem &gt; .75 then
					daysToComplete := daysToCompleteInt + 1;
				elseif rem &gt; .5 then
					daysToComplete := daysToCompleteInt + .75;
				elseif rem &gt; .25 then
					daysToComplete := daysToCompleteInt + .5;
				else
					daysToComplete := daysToCompleteInt + .25;
				endif;
			endif;
			countArray[ index ] := daysToComplete;
		endforeach;
			
		foreach index in 1 to countArray.size do
			daysToComplete := countArray[ index ];
			if daysToComplete &gt; 0 then
				if longestDays &lt; daysToComplete then
					longestDays := daysToComplete; 
				endif;
				totDays := totDays + daysToComplete;
			endif;
		endforeach;
		
		longestDays := longestDays + 0.25; // increase the biggest one by another 1/4 day.
		
	endif;

	self.txtConsecutive.text := totDays.asStringJMT;
	self.txtLongest.text := longestDays.asStringJMT;
	
	if self.myWodCargoRequest &lt;&gt; null then
		if self.myWodCargoRequest.getCurrentLengthOfTime &gt; 0 then
			//Its already been set, don't dick with it.
			self.txtInPort.text := self.myWodCargoRequest.getCurrentLengthOfTime.asStringJMT;
		else
			//If they've set it manually, leave it alone			
			if self.inPortEntered then								
			else													
				//Never been set, calculate it for them.
				self.txtInPort.text := totDays.asStringJMT;
			endif;													
		endif;
	
	else
		if self.myWOVoyage.totalTimeInPort &gt; 0 then
			//Its already been set, don't dick with it.
			self.txtInPort.text := self.myWOVoyage.totalTimeInPort.asStringJMT;
		else
			//If they've set it manually, leave it alone			// TFS 38215
			if self.inPortEntered then								// TFS 38215
			else													// TFS 38215
				//Never been set, calculate it for them.
				self.txtInPort.text := totDays.asStringJMT;
			endif;													// TFS 38215
		endif;
	
	endif;
*/
epilog
/*
	delete countArray;
	delete holdIdArray;
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyWodVoyageCargoRequest" id="8699633d-34e5-44e7-ba09-eaf8c3447ae0">
        <updating/>
        <source>setMyWodVoyageCargoRequest( _workOrderVoyageDtl : CM_WorkOrderVoyageDtl )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Mar 2018	jlgndl1	Initial creation	TFS 37447
18 Oct 2018 jlger1	TFS 41310 - permits have cargo requests now
*/

vars

	
begin

	if _workOrderVoyageDtl &lt;&gt; null then
		self.myWorkOrderVoyageDtl := _workOrderVoyageDtl;
		self.myWOVoyage := _workOrderVoyageDtl.getMyVoyageObject;
	endif;

epilog

end;</source>
        <Parameter name="_workOrderVoyageDtl" type="CM_WorkOrderVoyageDtl"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="fba8b010-23ee-4770-86df-061d86a694e5">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2018	jlgndl1	Initial creation
15 Jun 2018	NDL	TFS 39167
27 Jul 2018	NDL	TFS 39932

*/

vars

begin

	self.allowUpdate := app.getMyUser.canDo( self.myTerminal, PmAdmOrdWorkConfirmMaint);
	
	self.minimumWidth := 1020;
	self.minimumHeight := 370;

	if self.myWorkOrderVoyageDtl &lt;&gt; null then
		self.caption := app.getErrorString1( Total_days_requir_work_order, self.myWorkOrderVoyageDtl.getDisplayString(false) );
	else
		app.msgBox( "No Work Order Cargo requests, or no Voyage found", app.getErrorString(Error), MsgBox_OK_Only );
		self.unloadForm();
		return;
	endif;
	
	if self.myWorkOrderVoyageDtl.getAllCargoRequests = null then
		self.minimumHeight := 160;
		self.height := 160;
	endif;
	
	self.btnApprove.left := self.btnSave.left;
	
	self.useTableSorting := true;
	
	self.populateCmbRejectReason();	//06 Apr 2018	NDL	TFS 37928

	inheritMethod();
	
	self.splMain.top := 0;
	
	self.populateTblData();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTable" id="8875aaa4-739d-4a19-88e5-163e462009be">
        <source>setupTable( _comboValues : String output );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2018	jlgndl1	Initial creation	TFS 39167

*/

vars

	headingStr : String;
	voyTfrType : CM_VoyageJobTransferType;

begin

	self.tblData.clear();
	self.tblData.rows := 1;
	self.tblData.fixedRows := 1;
	self.tblData.columns := self.HoldTotalCol;
	self.tblData.fixedColumns := 0;
	
	headingStr := 	app.getErrorString(Hold) &amp; Tab
				&amp;	app.getErrorString(Workpoint) &amp; Tab
				&amp;	app.getErrorString(CM_Type) &amp; Tab
				&amp;	app.getErrorString(Operator_GC) &amp; Tab
				&amp;	app.getErrorString(Consignee) &amp; Tab
				&amp;	app.getErrorString(CM_Commodity_GC) &amp; Tab
				&amp;	app.getErrorString(Move_amount) &amp; Tab
				&amp;	app.getErrorString(Transfer_type) &amp; Tab
				&amp;	app.getErrorString(Gangs) &amp; Tab
				&amp;	app.getErrorString(HoursPerDay) &amp; Tab
				&amp;	app.getErrorString(Hourly_target_rate) &amp; Tab
				&amp;	app.getErrorString(Days_complete) &amp; Tab
				&amp;	app.getErrorString(Hold_sub_total);
	
	self.tblData.setCellText(1,1,headingStr);
	self.tblData.tabKey := J_key_Tab;
	
	foreach voyTfrType in app.myRoot.allVoyageJobTransferTypes do
		if voyTfrType.id = 0 then
			continue;
		endif;
		if _comboValues &lt;&gt; null then
			_comboValues := _comboValues &amp; Tab;
		endif;
		_comboValues := _comboValues &amp; voyTfrType.description;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_comboValues" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="tblData_queryRowColChg" id="7eb5a2f5-75d8-4c47-a30d-315bc0beaed3">
        <updating/>
        <source>tblData_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/03/2018	jlgndl1	Initial creation	TFS 37447
23/04/2018	jlgdap1	TFS 38215 PEL1 OOW Confirmation Changes
14 Jun 2018		NDL	TFS 39197
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object
*/

vars

	colIndex : Integer;
	rowIndex : Integer;
	
	wodCargoRequest : CM_WodCargoRequest;
	
	gangs : Integer;
	trsfrTypeStr : String;
	trsfrTypeInt : Integer;
	firstTi : CM_TrackedItem;
	
	newTrsfrType : CM_VoyageJobTransferType;
	workPoint : CM_WorkPoint;
	wpRate : CM_WorkPointCargoRates;
	daysToComplete : Decimal[6,2];
	
begin

	rowIndex := table.row;
	
	if rowIndex &gt; table.fixedRows then
		colIndex := table.column;
		if colIndex = TransferTypeCol or colIndex = GangsCol then
			wodCargoRequest := self.tblData.accessRow( rowIndex ).itemObject.CM_WodCargoRequest;
			if wodCargoRequest &lt;&gt; null then
				gangs := self.tblData.accessCell( rowIndex, GangsCol ).text.Integer;
				trsfrTypeStr := self.tblData.accessCell( rowIndex, TransferTypeCol ).text;
				trsfrTypeInt := app.vesselAccessTypeStrToEnum(trsfrTypeStr);
				newTrsfrType := app.myRoot.allVoyageJobTransferTypes.getAtKey( trsfrTypeInt );
				workPoint := wodCargoRequest.getMyWorkPoint;
				wpRate := workPoint.getDefinedTargetRate( wodCargoRequest, newTrsfrType, firstTi );
				if wpRate &lt;&gt; null then
					daysToComplete := wpRate.getDaysToComplete( wodCargoRequest, gangs, false );
				endif;
			//	daysToComplete := daysToComplete / gangs;				// TFS 38215
				self.tblData.accessCell( rowIndex, DaysToCompleteCol ).text := daysToComplete.asStringJMT;
				
				self.setDaysTextBoxes();
				
			endif;
		endif;
	endif;

	return inheritMethod(table, newSheet, newRow, newCol);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9dead556-24af-44d7-b3f5-7263222ef56c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 17 August 2018 08:17:54.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022266, locale);
	btnApprove.translateCaption(Xlat_0022267, locale);
	btnCancel2.translateCaption(Xlat_0022268, locale);
	btnReject.translateCaption(Xlat_0022269, locale);
	btnSave.translateCaption(Xlat_0022270, locale);
	lblConsecutive.translateCaption(Xlat_0022271, locale);
	lblInPort.translateCaption(Xlat_0022272, locale);
	lblLongest.translateCaption(Xlat_0022273, locale);
	lblReject.translateCaption(Xlat_0022374, locale);
	lblStatus.translateCaption(Xlat_0022934, locale);
end;</source>
