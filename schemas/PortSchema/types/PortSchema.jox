    <JadeMethod name="getStackDisplayExHandler" id="dd368983-a9cf-454b-a3fd-9f350d6abd1b">
        <source>getStackDisplayExHandler(_exc : Exception; _error : Boolean io) : Integer protected;

/*

Purpose:			Handle exceptions during getStackDisplayExHandler

Parameters:			Exception, boolean error

Return Value:		Exception return code, also error set to true


Date		Who		Reason
18 Feb 2010	cnwkpd1	Created due to recommendation from JADE Plant re JADE PAR #53405

*/

vars

begin
	// Unconditionally set error and resume, to prevent stack overflow
	_error := true;
	return Ex_Resume_Next;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_error" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStackDisplayStringArray" id="b75d2fb1-409a-441f-857a-328c856610de">
        <source>getStackDisplayStringArray(displayStringArray : HugeStringArray input; numberOfMethodsToExclude : Integer);
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsgp1
//
// Purpose:		Use this method to populate an array with display strings
//				for the current call stack.
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
8 Feb 2010	cnwkpd1	Added exception handling do prevent stack overflow/hang in development
					environment (see JADE PAR #53405)
05 Dec 2013	cnwkpd1	PAR #33145 - Added delete of the removed ObjMethodCallDesc to prevent transient leak

*/

vars
	theCallStack 	: ProcessStackArray;
	theMethodCall 	: MethodCallDesc;
	count 			: Integer;
	displayStr		: String;
	error			: Boolean;
	
begin
	on Exception do self.getStackDisplayExHandler(exception, error);
	
	create theCallStack transient;
	self.cnEcGetPreviousMethods(theCallStack);
	delete theCallStack.removeAt(1);			// Remove this method call (i.e. self).
	
	foreach theMethodCall in theCallStack do
		count := count + 1;
		if count &lt;= numberOfMethodsToExclude then
			continue;
		endif;
		
		error := false;
		displayStr := theMethodCall.display;
		if error then
			displayStr := "&lt;an error occured accessing " &amp; theMethodCall.String &amp; "&gt;";
		endif;
		displayStringArray.add(displayStr);
	endforeach;

epilog
	if theCallStack &lt;&gt; null then
		theCallStack.purge();
		delete theCallStack;
	endif;
end;</source>
        <Parameter name="displayStringArray" type="HugeStringArray" usage="input"/>
        <Parameter name="numberOfMethodsToExclude" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getString" id="f4940e68-cfb9-4af1-b0e7-fc3b3435a8cc">
        <source>getString(paramList : ParamListType) : String;
// JadeParameterList

// experimental replacement for getErrorStringN() methods

vars
	translation : XLAT_Translation;
	paramArray	: HugeStringArray;
	paramCount	: Integer;
	paramString	: String;
	errorCode 	: Integer; 
begin

	// substitute 1 or more paramters
	create paramArray transient;
	
	foreach paramCount in 1 to app.getParamListTypeLength(paramList) do
		if paramCount = 1 then
			errorCode := app.getParamListTypeEntry(1, paramList).Integer;
		else
			paramString := app.getParamListTypeEntry(paramCount, paramList).String;
			paramArray.add(paramString);
		endif;
	endforeach;

	if errorCode = 0 then
		return "Error - invalid call: " &amp; method.qualifiedName;
	elseif errorCode &lt; self.baseErrorNum then
		return getJadeErrorString(errorCode);
	endif;
	translation := self.zGetTranslatedText(XLAT_Exceptions, errorCode);
	if translation = null then
//		return "Error " &amp; errorCode.String &amp; ": Unknown message";	// cnwrl1 22/05/2009 PAR 19668 - CCMS 1814
		return "Error " &amp; errorCode.String &amp; UnknownMessage;
	endif;
	
	if paramArray.isEmpty then
		if app.useShortErrorMsg and translation.shortText &lt;&gt; null then
			return translation.shortText;
		endif;
		return translation.text;	
	endif;

//	if paramArray.size &lt;&gt; translation.getNumberOfSubstitutes(false) then
//		return 'Error: Incorrect parameter count: ' &amp; translation.text;
//	endif;
	
	return translation.getTextWithSubstitutedParams(paramArray);	

epilog
	delete paramArray;
end;
</source>
        <Parameter name="paramList" type="ParamListType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSubTerminalReceiveTxnType" id="8444c2c1-934b-4c60-80cd-bf7df5d66b74">
        <source>getSubTerminalReceiveTxnType(_subTerminalType : Integer; _transportMode : Integer) : Integer;
/* ---------------------------------------------------------------------------
Created:     20 August 2009 by cnwrs2

Purpose:    Returns the TI Transaction type to create for a receival into
			a sub-terminal of the passed in type
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if _subTerminalType = SubTermType_Marine_Int then
		if _transportMode = TI_TRANSMODE_RAIL then
			return TRANS_TYPE_REC_ST_MARINE_RAIL;
		elseif _transportMode = TI_TRANSMODE_ROAD then
			return TRANS_TYPE_REC_ST_MARINE_ROAD;
		elseif _transportMode = TI_TRANSMODE_SHIP then
			return TRANS_TYPE_REC_ST_MARINE_SHIP;
		elseif _transportMode = TI_TRANSMODE_INTERNAL then
			return TRANS_TYPE_REC_ST_MARINE_INT;
		else
			return TRANS_TYPE_RECEIVE_ST_MARINE;
		endif;
	elseif _subTerminalType = SubTermType_Depot_Int then
		if _transportMode = TI_TRANSMODE_RAIL then
			return TRANS_TYPE_REC_ST_DEPOT_RAIL;
		elseif _transportMode = TI_TRANSMODE_ROAD then
			return TRANS_TYPE_REC_ST_DEPOT_ROAD;
		elseif _transportMode = TI_TRANSMODE_SHIP then
			return TRANS_TYPE_REC_ST_DEPOT_SHIP;
		elseif _transportMode = TI_TRANSMODE_INTERNAL then
			return TRANS_TYPE_REC_ST_DEPOT_INT;
		else
			return TRANS_TYPE_RECEIVE_ST_DEPOT;
		endif;
	elseif _subTerminalType = SubTermType_Warehouse_Int then
		if _transportMode = TI_TRANSMODE_RAIL then
			return TRANS_TYPE_REC_ST_WHOUSE_RAIL;
		elseif _transportMode = TI_TRANSMODE_ROAD then
			return TRANS_TYPE_REC_ST_WHOUSE_ROAD;
		elseif _transportMode = TI_TRANSMODE_SHIP then
			return TRANS_TYPE_REC_ST_WHOUSE_SHIP;
		elseif _transportMode = TI_TRANSMODE_INTERNAL then
			return TRANS_TYPE_REC_ST_WHOUSE_INT;
		else
			return TRANS_TYPE_RECEIVE_ST_WHOUSE;
		endif;
	endif;
	
	app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled subterminal type (' &amp; _subTerminalType.String &amp; ')');
	return null;

epilog

end;</source>
        <Parameter name="_subTerminalType" type="Integer"/>
        <Parameter name="_transportMode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSubTerminalReleaseTxnType" id="96975a48-398d-4ae0-9e0d-887f61acc3b4">
        <source>getSubTerminalReleaseTxnType(_subTerminalType : Integer; _transportMode: Integer) : Integer;
/* ---------------------------------------------------------------------------
Created:     20 August 2009 by cnwrs2

Purpose:    Returns the TI Transaction type to create for a receival into
			a sub-terminal of the passed in type
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
begin
	if _subTerminalType = SubTermType_Marine_Int then
		if _transportMode = TI_TRANSMODE_RAIL then
			return TRANS_TYPE_REL_ST_MARINE_RAIL;
		elseif _transportMode = TI_TRANSMODE_ROAD then
			return TRANS_TYPE_REL_ST_MARINE_ROAD;
		elseif _transportMode = TI_TRANSMODE_SHIP then
			return TRANS_TYPE_REL_ST_MARINE_SHIP;
		elseif _transportMode = TI_TRANSMODE_INTERNAL then
			return TRANS_TYPE_REL_ST_MARINE_INT;
		else
			return TRANS_TYPE_RELEASE_ST_MARINE;
		endif;
	elseif _subTerminalType = SubTermType_Depot_Int then
		if _transportMode = TI_TRANSMODE_RAIL then
			return TRANS_TYPE_REL_ST_DEPOT_RAIL;
		elseif _transportMode = TI_TRANSMODE_ROAD then
			return TRANS_TYPE_REL_ST_DEPOT_ROAD;
		elseif _transportMode = TI_TRANSMODE_SHIP then
			return TRANS_TYPE_REL_ST_DEPOT_SHIP;
		elseif _transportMode = TI_TRANSMODE_INTERNAL then
			return TRANS_TYPE_REL_ST_DEPOT_INT;
		else
			return TRANS_TYPE_RELEASE_ST_DEPOT;
		endif;
	elseif _subTerminalType = SubTermType_Warehouse_Int then
		if _transportMode = TI_TRANSMODE_RAIL then
			return TRANS_TYPE_REL_ST_WHOUSE_RAIL;
		elseif _transportMode = TI_TRANSMODE_ROAD then
			return TRANS_TYPE_REL_ST_WHOUSE_ROAD;
		elseif _transportMode = TI_TRANSMODE_SHIP then
			return TRANS_TYPE_REL_ST_WHOUSE_SHIP;
		elseif _transportMode = TI_TRANSMODE_INTERNAL then
			return TRANS_TYPE_REL_ST_WHOUSE_INT;
		else
			return TRANS_TYPE_RELEASE_ST_WHOUSE;
		endif;
	endif;
	
	app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled subterminal type (' &amp; _subTerminalType.String &amp; ')');
	return null;
end;</source>
        <Parameter name="_subTerminalType" type="Integer"/>
        <Parameter name="_transportMode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTempDirectoryFromSysConfig" id="6d173120-0fe3-4518-8d3c-ff3a72b5f054">
        <source>getTempDirectoryFromSysConfig() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 30 July 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// 30/07/2010	cnwsh3		PAR22336 Return JMT system config defined temp directory.
//							Use this instead of app.getTempDir specifically so
//							managed service systems can avoid using the temp dir
//							that is on the same drive as the window system files.
//----------------------------------------------------------------------
vars
	fileName : String;
begin
	fileName := app.myRoot.getConfig(SystemTempDir).String;
	
	return fileName.addLastSeparatorToFilePath();
epilog
end;</source>
        <ReturnType type="String"/>
