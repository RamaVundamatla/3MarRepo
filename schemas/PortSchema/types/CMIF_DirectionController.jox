    <JadeMethod name="setForCreate" id="23ac56b6-e8a5-4653-b741-72222a2ba8e0">
        <updating/>
        <source>setForCreate() updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theRoot : CM_Root;
begin
	theRoot := app.myRoot;
	
	self.dirODDoors20AFT := theRoot.getConfig(DirODDoors20AFT).Boolean;
	self.dirODDoors40AFT  := theRoot.getConfig(DirODDoors40AFT).Boolean;
	self.dirODMotor20AFT  := theRoot.getConfig(DirODMotor20AFT).Boolean;
	self.dirODMotor40AFT  := theRoot.getConfig(DirODMotor40AFT).Boolean;
	self.dirUDDoors20FWDAFT  := theRoot.getConfig(DirUDDoors20FWDAFT).Boolean;
	self.dirUDDoors20AFTFWD  := theRoot.getConfig(DirUDDoors20AFTFWD).Boolean;
	self.dirUDDoors40AFT  := theRoot.getConfig(DirUDDoors40AFT).Boolean;
	self.dirUDMotor20FWDFWD  := theRoot.getConfig(DirUDMotor20FWDFWD).Boolean;
	self.dirUDMotor20AFTAFT  := theRoot.getConfig(DirUDMotor20AFTAFT).Boolean;
	self.dirUDMotor40AFT   := theRoot.getConfig(DirUDMotor40AFT).Boolean;
end;</source>
    </JadeMethod>
