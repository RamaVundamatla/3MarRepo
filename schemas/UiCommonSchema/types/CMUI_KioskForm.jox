    <JadeMethod name="keyDown" id="4cc21c6b-6a7f-44f4-be3f-2d3831b32e3b">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if keyCode = CMUI_Key_F1 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			app.showHelp(self.hwnd, HelpFile_Index);		
		else
			app.showHelp(self.hwnd, self.aHelpFileName);
		endif;
		
		keyCode	:=	null;	// Stop further processing by Jade/Windows.
		
	elseif keyCode = CMUI_Key_F5 then
		self.doRefresh();
		return;
		
	elseif keyCode = J_key_P then 
	    if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
	    then
	        self.doPrint();
	    endif;
	    
	elseif keyCode = CMUI_Key_F11
	and app.isControlKeyDown()
	and not app.isAltKeyDown()
	and not app.isShiftKeyDown()
	and (app.isAllowedToInspect() or app.isDevelopmentSystem())
	then
		self.inspect();
		//app.inspect;
	elseif keyCode = CMUI_Key_F12 then
		if (app.isSpecial() or app.isDevelopmentSystem()) and shift.cnEcIsCtrlKey() then
			if shift.cnEcIsShiftKey() then
				self.cnEcShowContents();
			else
				self.cnEcShowGuiInfo();
//				self.showActiveDetails();
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="ad0a570f-dbe6-4d89-ad2e-eb9531bcccf6">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.instrumentFormUsage( self );	//25 Feb 2014 NDL	Par 33587
	self.setupForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="setTerminalRef" id="2bfcf039-66f6-4df7-bf7f-9b232be74eb2">
        <updating/>
        <source>setTerminalRef(_terminalObj:CM_Terminal) updating;
// --------------------------------------------------------------------------------
// Created:		07 August 2006 by cnwdad1
//
// Purpose:		Sets a reference to a Terminal object on the receiver.
//
// Parameters:	_terminalObj - A reference to the Terminal object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyTerminal	:=	_terminalObj;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c719c52f-73aa-4aac-b04f-b4c88ec14ccb">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.centreWindow();
	self.setTerminalRef(app.getMyTerminalDO_NOT_USE());
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showActiveDetails" id="658003ae-b06f-4d57-af96-35e32fed0452">
        <source>showActiveDetails() protected;
// --------------------------------------------------------------------------------
// Created:		22 November 2005 by cnwdad1
//
// Purpose:		Displays the Current Active Form and Control and copies the Form
//				name to the clipboard.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formName			: String;
	formSchemaName		: String;
	controlName			: String;
	controlTypeName		: String;
	controlSchemaName	: String;
	helpId				: String;
	controlHelp			: String;
	controlTab			: String;
	displayValue		: String;
	
begin
	if app.activeForm = null then
		formName			:=	"None";
		formSchemaName		:=	"N/A";
		formName.cnEcCopyToClipboard();
		helpId				:=	"N/A";
	else
		formName			:=	app.activeForm.name;
		formSchemaName		:=	app.activeForm.class.schema.name;
		formName.cnEcCopyToClipboard();
		helpId				:=	app.activeForm.helpContextId.String;
	endif;
	
	if app.activeControl = null then
		controlName			:=	"None";
		controlTypeName		:=	"N/A";
		controlSchemaName	:=	"N/A";
		controlHelp			:=	"N/A";
		controlTab			:=	"N/A";
	else
		controlName			:=	app.activeControl.name;
		controlTypeName		:=	app.activeControl.class.name;
		controlSchemaName	:=	app.activeControl.class.schema.name;
		controlHelp			:=	app.activeControl.helpContextId.String;
		controlTab			:=	app.activeControl.tabIndex.String;
	endif;
	
	displayValue	:=	"Active Form = " &amp; formName  &amp; " (" &amp; formSchemaName &amp; ")" &amp; CrLf &amp;
						"Help Context Id = " &amp; helpId &amp; CrLf &amp; CrLf &amp;
						"Active Control = " &amp; controlName &amp; " (" &amp; controlSchemaName &amp; ":" &amp; controlTypeName &amp; ")" &amp; CrLf &amp;
						"Control Help Id = " &amp; controlHelp &amp; CrLf &amp;
						"Tab Index = " &amp; controlTab &amp; CrLf &amp;
						CrLf &amp;
						"Yes to inspect, No to close" ;
	
	if app.msgBox(displayValue, "Active Form", MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_Yes then
//		app.activeForm().inspect();
		app.activeControl().inspect();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateForm" id="bd331e1f-1da3-4c44-b596-1cfba0de963a">
        <updating/>
        <source>updateForm(_isDelete:Boolean):Boolean updating, protected;
