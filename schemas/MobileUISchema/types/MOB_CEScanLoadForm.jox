    <JadeMethod name="translateForm" id="f3652d8c-6992-41c9-b5d3-8255b5809a4c">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017598, locale);
	btn_Back.translateCaption(Xlat_0012974, locale);
	btn_ChangeLoc.translateCaption(Xlat_0012975, locale);
	btn_Clear.translateCaption(Xlat_0012976, locale);
	btn_Menu.translateCaption(Xlat_0012977, locale);
	btn_SetDown.translateCaption(Xlat_0012978, locale);
	btn_TruckDone.translateCaption(Xlat_0012979, locale);
	lbl_CargoID.translateCaption(Xlat_0012980, locale);
	lbl_LocationID.translateCaption(Xlat_0012981, locale);
	lbl_OrderCount.translateCaption(Xlat_0012982, locale);
	lbl_Truck.translateCaption(Xlat_0012983, locale);
	lbl_TruckNo.translateCaption(Xlat_0012984, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
