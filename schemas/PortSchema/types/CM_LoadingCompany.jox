    <JadeMethod name="setForUpdate" id="bfe567b7-99dd-47ed-8c79-9385bb64c2e8">
        <updating/>
        <source>setForUpdate(_pxyLoader : CM_LoadingCompany; _passport : CM_Passport input) updating;
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	self.code := _pxyLoader.code;
	self.description := _pxyLoader.description;
	self.isNotAvailableForEntry := _pxyLoader.isNotAvailableForEntry;
	self.myRoot := _pxyLoader.myRoot;
	self.allContacts.clear();
	_pxyLoader.allContacts.copy(self.allContacts);	
end;</source>
        <Parameter name="_pxyLoader" type="CM_LoadingCompany"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
