    <JadeMethod name="getHolidayDesc" id="23e6b8a4-d7bc-4bdb-98c5-d19edb562519">
        <source>getHolidayDesc(_holiday : Date) : String;
// ---------------------------------------------------------------------------
// Created:		18 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// ---------------------------------------------------------------------------
vars
	hol 		: CM_CalendarDate;
	calendar	: CM_Calendar;
begin
	
	calendar := self.getMyHolidayCalendar();	//06.03.2025 navma1 #MTN-34179
	
	if calendar = null then
		return null;
	endif;
	
	hol := calendar.getFirstCalendarDateForDay(_holiday);	// 27 Oct 2010	NDL Par 25530	/ CCMS 1185
	if hol &lt;&gt; null then
		return hol.description;
	endif;

	return null;
end;</source>
