    <JadeMethod name="setProxyFromObject" id="41c5099a-de11-42b1-a384-3959b5ebea71">
        <updating/>
        <source>setProxyFromObject(_object: CM_AuditTALocations) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2008	cnwkao1	Initial creation

*/

vars
	ta : CM_TerminalArea;
begin
	inheritMethod(_object);
	
	
	self.timestamp	:= _object.timestamp.asStringForWebInterface ;			//cnwmc5 - 26 Jan 2016 - PAR 37326
	self.typeCode := _object.typeCode ;
	self.userCode := _object.userCode ;
	self.locationUpdateDetails := _object.locationUpdateDetails ;
	self.locationUpdateMode := _object.locationUpdateMode ;
	self.locationUpdateType := _object.locationUpdateType ;
	self.locationUpdateTypeStr  := _object.locationUpdateTypeStr  ;
	self.locationStr  := _object.locationStr ;
	
	if _object.mySubject.isKindOf(CM_TerminalArea) then
		self.terminalAreaId := _object.mySubject.CM_TerminalArea.id;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_AuditTALocations"/>
    </JadeMethod>
</Class>
