    <JadeMethod name="amIAvailable" id="821a8a68-9a04-418c-b9b5-355a08911939">
        <source>amIAvailable(): Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	17 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return true;

end;


</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="calculateAllContaineSizeTotals" id="7e9192bf-1480-47ea-aa52-08a82158d5c2">
        <updating/>
        <source>calculateAllContaineSizeTotals(total20Containers : Integer io;
							   total30Containers : Integer io;
							   total40Containers : Integer io;
							   total45Containers : Integer io;
							   total53Containers : Integer io;
							   _minHeight		 : Integer;
							   _maxHeight		 : Integer;
							   set               : CM_GridControllersByRowColumn;
							   oa                : ObjectArray io) updating;
/*

Purpose:			Calculate the maximum possible containers for each area

Parameters:			set - set of Controllers for this area
					oa  - array of used Controllers for 40 foot containers

Return Value:		Totals for each container length


Date		Who		Reason
20 August 2008	conkc1	Initial creation

*/
vars
	count             : Integer;
	stackSize : Integer;
	maxHeight: Integer;
	nextGC            : CM_GridController;

begin
	if self.amIAvailable = false then
		return;
	endif;
	
	// Check to see if location is within the min/max range (ie this is for a YABlock with min/max height)
	maxHeight := _maxHeight.min(self.getMaxStackingHeight());
	if maxHeight &lt; _minHeight then
		return;							// This location is not in the range
	endif;
	
	stackSize := maxHeight - _minHeight + 1;
	total20Containers := total20Containers + stackSize;
	if self.isKindOf(CM_GridController) then
			
		count := self.CM_GridController.getMaxAllowedStackingHeight(set, oa);
		if count &gt; 0 and _minHeight &gt;= count then
			count := count - _minHeight + 1;
		endif;
		if count &gt; stackSize then
			count := stackSize;
		endif;
		total40Containers := total40Containers + count;
		
	//	if self.is30ft = true then
		
	//		if self.offset30 &lt;&gt; -1 then
				nextGC := self.myNextController;
				if nextGC &lt;&gt; null and nextGC.amIAvailable = true and /*nextGC.is30ft = true and*/ set.includes(nextGC) = true then
					total30Containers := total30Containers + stackSize;
				endif;
	//		endif;
			
//		endif;
/* DOUG ADD THIS IN ???
		if self.is40ft = true then
			if self.offset40 &lt;&gt; -1 then
				nextGC := self.myNextController;
				if nextGC &lt;&gt; null and nextGC.amIAvailable = true and nextGC.is40ft = true and set.includes(nextGC) = true then
					total40Containers := total40Containers + stackSize;
				endif;
			endif;
			
		endif;
*/
		if self.is45ft = true then
		
			if self.offset45 &lt;&gt; -1 and self.offset45 &lt;&gt; 20 then  // the check for 20 is because every 9th LC has 20 not -1 is being fixed
				nextGC := self.myNextController;
				if nextGC &lt;&gt; null and nextGC.is45ft = true and set.includes(nextGC) = true then
					nextGC := nextGC.myNextController;
					if nextGC &lt;&gt; null and nextGC.amIAvailable = true and nextGC.is45ft = true and set.includes(nextGC) = true then
						total45Containers := total45Containers + stackSize;
					endif;
				endif;
			endif;
			
		endif;

		if self.is53ft = true then
		
			if self.offset53 &lt;&gt; -1 then
				nextGC := self.myNextController;
				if nextGC &lt;&gt; null and nextGC.is53ft = true and set.includes(nextGC) = true then
					nextGC := nextGC.myNextController;
					if nextGC &lt;&gt; null and nextGC.amIAvailable = true and nextGC.is53ft = true and set.includes(nextGC) = true then
						total53Containers := total53Containers + stackSize;
					endif;
				endif;
			endif;			
		endif;

	endif;

epilog

end;</source>
        <Parameter name="total20Containers" type="Integer" usage="io"/>
        <Parameter name="total30Containers" type="Integer" usage="io"/>
        <Parameter name="total40Containers" type="Integer" usage="io"/>
        <Parameter name="total45Containers" type="Integer" usage="io"/>
        <Parameter name="total53Containers" type="Integer" usage="io"/>
        <Parameter name="_minHeight" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <Parameter name="set" type="CM_GridControllersByRowColumn"/>
        <Parameter name="oa" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="calculateMoveLCs" id="55625ffe-64e9-467f-9110-a3110a8947c8">
        <source>calculateMoveLCs(ti : CM_TrackedItem): Real;
/*
 ------------------------------------------------------------------------
Created:			13 September 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	len : Real;
begin
	len := ti.getLengthInUnits();
	if len &gt; 1 then
		return len div 2;
	else
		return 1;
	endif;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="canAccessHeight" id="cf17930f-ee9e-4d39-ae80-76d2ad2adbdd">
        <source>canAccessHeight(pHeight : Real; _mode: Integer): Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2001 By Andrew Bishop cnwab1
//
// Purpose:		add up the height in feet of all the real and queued TIs in this location.
//				then compair it to the height that is being passed in.
//				This is mainly for Fork Lift Stacks where MAX height for Fulls, MTs and Power are checked
//				For par 27198 also max height of RMGs Apr 2011
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/08/2011	cnmwh5		#27903 - Add getting height of queued items
// ---------------------------------------------------------------------------

vars
	lTargetHeight : Real;
	lTI 	: CM_TrackedItem;
	array : CM_TIArray;
begin

	create array transient;

	if  self.myTerminalArea.canAccessHeight() then
		return true;
	endif;

	lTargetHeight := 0;
	// add up the height of all the containers at this location to see whether our machine can lift that high
	foreach lTI in self.allTrackedItems do
		lTargetHeight := lTargetHeight + lTI.getActualHeight();
	endforeach;
	
	if _mode &lt;&gt; REAL_MODE then  // PAR 26700 ignore planned if doing a real mode move
		self.getTIs(array,  PLANNING_MODE, true); // PAR 27749
		self.getTIs(array,  QUEUE_MODE, false);		// 02/08/2011 cnwmh5 #27903
		foreach lTI in array do
			lTargetHeight := lTargetHeight + lTI.getActualHeight();
		endforeach;
	endif;
	
	// pHeight will have the MAX height for Fulls, MTs or Power (or RMG max height) for this terminal area
	if lTargetHeight &gt; pHeight then
		return false;
	else
		return true;
	endif;
epilog
	delete array;
end;</source>
        <Parameter name="pHeight" type="Real"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
