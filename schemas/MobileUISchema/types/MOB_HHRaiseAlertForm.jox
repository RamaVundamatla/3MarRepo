    <JadeMethod name="populateTrackedItem" id="86ed72e3-cf1d-499e-8386-de6e120059dd">
        <source>populateTrackedItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null then
		self.txtCargoId.text := self.myTrackedItem.id;
		
	else
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="e58b88c8-3c96-4367-bcd3-fae51430c7ff">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2013	cnwndl1	Initial creation	Par 31506

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;	
	
begin

	self.setMyTrackedItem( null );

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );
		self.populateTrackedItem();
		return;
		
	else
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( cargoId.trimBlanks &lt;&gt; null );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);	
		
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete revDict;	

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendAlert" id="cc821837-c217-40ee-88c8-b55affddfdbe">
        <source>sendAlert() protected;
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Purpose:	If there is a message in the textbox, send it as an alert 
//			Put up confirmation of sending message
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
	actualMessage : String;
	cont : CM_TrackedItem;
	linkedObj : CM_Object;
begin
	if self.txtMessage.text.length &gt; 0 then
		linkedObj := self.myTrackedItem;
		if linkedObj = null then
			linkedObj := app.getRTDeviceForSelf(app.myPassport.myEventLogin.computerName);
		endif;
	
		app.myPassport.clearErrorsWarnings;
		actualMessage := app.getErrorString(Sent_from_hand_held) &amp; ' ' &amp; app.myPassport.myEventLogin.computerName &amp; ': ' &amp; self.txtMessage.text;
		cont := self.myTrackedItem;
		if cont = null or not cont.isReefer then
			app.myPassport.createAlert(SEVERE_ERROR, 
					actualMessage,
					EVENT_AT_HandHeldAlert,
					linkedObj);
		else
			app.myPassport.createAlert(SEVERE_REEFER_MAX, 
					actualMessage,
					EVENT_AT_HandHeldAlert,
					linkedObj);
		endif;
		
		beginTransaction;
		app.commitAlert();
		commitTransaction;
		if app.myPassport.hasErrors then
			self.msgBox( app.getErrorString(Failed_send_alert), app.getErrorString(Raise_alert), MsgBox_OK_Only, false );
		else
			self.msgBox( app.getErrorString(Alert_sent) &amp; CrLf &amp; actualMessage, app.getErrorString(Raise_alert), MsgBox_OK_Only, false );
		endif;
	endif;
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="e5d9fb4c-4fdd-4906-aa14-e44ade645d12">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myTrackedItem := _ti;
	self.doHandleValueChange();
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="b3d60153-157e-40ee-bf33-631edbb21570">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2013	cnwndl1	Initial creation	Par 31506

*/

vars
	
	iter : Iterator;
	remark : CM_PredefinedRemark;

begin
						  
	self.doResizeControls(true);					  
						  
	iter := app.myRoot.allPreDefinedRemarks.createIterator;
	self.cmbPredefined.addItem(" ");
	while iter.next(remark) do
		self.cmbPredefined.itemObject[self.cmbPredefined.addItem(remark.description)] := remark;
	endwhile;
	
	self.populateTrackedItem();
	
	self.txtMessage.setFocus();
	self.changedText := false;
	

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c98bb8cf-ba37-4ef0-bbdc-ebf927d85b1d">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:	09 January 2009 By Graeme Black cnwgb1
// Purpose:	Basic form setup
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars

	ti : CM_TrackedItem;

begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;
	
	self.setupCmdButtons( 2, app.getErrorString(Send), BACK_BUTTON, null, null, null );
	
	inheritMethod();
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showWarningMessage" id="47112404-9d06-4252-bd08-acfd63463dda">
        <source>showWarningMessage() : Boolean protected;
// This method displays a warning message to the user that if they proceed with their current
// selection in either of the combo boxes then their current message that they have created will
// be cleared and replaced by a new one. Will be called when the message is a customized one.
// Where they have just selected a predefined message this warning should not be shown

// Returns true if they are to proceed, false if to return
vars

begin

	return self.msgBox(app.getErrorString(Will_lose_your_curre_messa_pro) &amp; CrLf &amp; app.getErrorString(DoYouWantToContinue),
					app.getErrorString(Warning), MsgBox_Information_Icon + MsgBox_Yes_No, false)
					= MsgBox_Return_Yes;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d8594764-6e51-43c4-9726-3ff88554780a">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013108, locale);
	lblCargoId.translateCaption(Xlat_0019066, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="0ee30f02-e088-4914-ae16-669af293787a">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 51506

*/

vars

begin

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="e7e9e53b-5051-4ad6-a8e5-96b4e43548e7">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation		Par 51506

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.setMyTrackedItem( null );
		//do nothing
	elseif self.txtCargoId.text.trimBlanks = null then
		self.setMyTrackedItem( null );
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
