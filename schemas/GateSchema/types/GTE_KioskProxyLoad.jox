    <JadeMethod name="clearMe" id="8f03d559-d3cf-4fcf-9e7a-3370bf9a148d">
        <updating/>
        <source>clearMe() updating;
// --------------------------------------------------------------------------------
// Created:		31 July 2006 by cnwdad1
//
// Purpose:		Clears the receiver's references and property values.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myCarrier		:=	null;
//	self.allReceivals.clear();
//	self.allReleases.clear();

	// PAR 15085 - if clear then should delete all
	// transient data
	self.allReceivals.purge();
	self.allReleases.purge();

	self.pinNumber		:=	null;
	self.regoNumber		:=	null;
end;</source>
    </JadeMethod>
    <JadeMethod name="cloneHazardsForTI" id="a65c573f-774b-42d8-b080-a1b732e82e8f">
        <source>cloneHazardsForTI(_receivalObj:CMIF_Receival input; _trackedItemObj:CM_TrackedItem);
// --------------------------------------------------------------------------------
// Created:		14 August 2006 by cnwdad1
//
// Purpose:		Clone the hazards of the specified Tracked Item onto the receival
//				interface object.
//
// Parameters:	_receivalObj - 
//				_trackedItemObj - 
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 29/05/2019	jlgdap1		TFS 43346 Update new(ish) hazard attributes
// --------------------------------------------------------------------------------
// 

vars
	hazardObj	: CM_Hazard;
	cloneObj	: CM_TIHazard;
	
begin
	foreach hazardObj in _trackedItemObj.allTIHazards do
		create cloneObj transient;
		cloneObj.setFromHazardClass(app.myRoot.allHazardClasses[hazardObj.code]);
		cloneObj.setUNDGCodes(hazardObj.CM_TIHazard.getUndgCodesAsString(false));	//25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
		cloneObj.setLimitedQuantity(hazardObj.CM_TIHazard.limitedQuantity);
		cloneObj.setPackingGroup(hazardObj.CM_TIHazard.packingGroup);						// TFS 43346
		cloneObj.setFlashpointTemperature(hazardObj.CM_TIHazard.flashpointTemperature);		// TFS 43346
		cloneObj.setIsMarinePollutant(hazardObj.CM_TIHazard.isMarinePollutant);				// TFS 43346
		cloneObj.setAcidsBases(hazardObj.CM_TIHazard.acidsBases);							// TFS 43346
		_receivalObj.allTIHazards.add(cloneObj);
	endforeach;
end;</source>
        <Parameter name="_receivalObj" type="CMIF_Receival" usage="input"/>
        <Parameter name="_trackedItemObj" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createCargo" id="17e8aa90-255a-4edc-8024-c05839d99622">
        <source>createCargo(_cargoItemObj: CM_Object; _tiInterfaceObj:CMIF_TIObject; _totalWeight:Decimal; _isDoorsBack:Boolean):GTE_KioskProxyCargo;
// --------------------------------------------------------------------------------
// Created:		11 August 2006 by cnwdad1:2
//
// Purpose:		Creates a proxy cargo object for the receiver.
//
// Parameters:	_cargoItemObj - A reference to the actual cargo item object.
//				_tiInterfaceObj - A reference to a TI Interface object (for Bulk Releases).
//				_totalWeight - The total weight of the cargo item currently being edited.
//				_isDoorsBack - True if the cargo doors are at the rear.
//
// Returns:		A reference to the new proxy cargo object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/07/2007	cnwdad1		CCMS #1493 - Added cargo item weight, which may be amended
//							by the driver.
//
// --------------------------------------------------------------------------------
vars
	cargoObj	: GTE_KioskProxyCargo;
	cargoCount	: Integer;
	
begin
	if self.isReceivalItem(_cargoItemObj) then
		cargoCount	:=	self.allReceivals.getCargoCount(_cargoItemObj);
	elseif self.isReleaseItem(_cargoItemObj) then
		cargoCount	:=	self.allReleases.getCargoCount(_cargoItemObj);
	endif;
	
	cargoCount	:=	cargoCount + 1;
	
	create cargoObj transient;
	cargoObj.updateMe(cargoCount, _cargoItemObj, _tiInterfaceObj, self, _totalWeight, _isDoorsBack);
	
	return cargoObj;
end;</source>
        <Parameter name="_cargoItemObj" type="CM_Object"/>
        <Parameter name="_tiInterfaceObj" type="CMIF_TIObject"/>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_isDoorsBack" type="Boolean"/>
        <ReturnType type="GTE_KioskProxyCargo"/>
    </JadeMethod>
    <JadeMethod name="delete" id="73c37417-f57b-44aa-9bb0-65f3d044cd48">
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 September 2006 by cnwdad1:2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allReceivals.purge();
	self.allReleases.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="findCargoForId" id="989a0cb1-7237-4e52-a24f-250836462e07">
        <source>findCargoForId(_cargoId:String; _cargoCount:Integer):GTE_KioskProxyCargo;
// --------------------------------------------------------------------------------
// Created:		25 September 2006 by cnwdad1
//
// Purpose:		Returns a reference to a cargo object for the specified Cargo ID.
//
// Parameters:	_cargoId - The Cargo ID to scan for.
//				_cargoCount - The unique "index" of the Cargo item.
//
// Returns:		A reference to a cargo object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyCargoObj	: GTE_KioskProxyCargo;
	
begin
	foreach proxyCargoObj in self.allReleases do
		if proxyCargoObj.id = _cargoId and proxyCargoObj.count = _cargoCount then
			return proxyCargoObj;
		endif;
	endforeach;
	
	foreach proxyCargoObj in self.allReceivals do
		if proxyCargoObj.id = _cargoId and proxyCargoObj.count = _cargoCount then
			return proxyCargoObj;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_cargoCount" type="Integer"/>
        <ReturnType type="GTE_KioskProxyCargo"/>
    </JadeMethod>
    <JadeMethod name="getAllCargo" id="35f1f2af-8850-4bef-bd7b-47f72f32a1ac">
        <source>getAllCargo(_allProxyCargoArrayObj:GTE_KioskProxyCargoArray input);
// --------------------------------------------------------------------------------
// Created:		22 August 2006 by cnwdad1
//
// Purpose:		Populates the specified array parameter with all of the receiver's
//				proxy cargo objects.
//
// Parameters:	_allProxyCargoArrayObj - A reference to an array of proxy cargo objects.
//
// Returns:		The populated array parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyCargoObj	: GTE_KioskProxyCargo;
	
begin
	foreach proxyCargoObj in self.allReceivals do
		_allProxyCargoArrayObj.add(proxyCargoObj);
	endforeach;
	
	foreach proxyCargoObj in self.allReleases do
		_allProxyCargoArrayObj.add(proxyCargoObj);
	endforeach;
end;</source>
        <Parameter name="_allProxyCargoArrayObj" type="GTE_KioskProxyCargoArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCargoForId" id="d55b4133-80c2-4669-80e3-45cee6a8a682">
        <source>getCargoForId(_cargoId:String; _cargoCount:Integer; _isRelease:Boolean):GTE_KioskProxyCargo;
// --------------------------------------------------------------------------------
// Created:		24 September 2006 by cnwdad1
//
// Purpose:		Returns a reference to a cargo object for the specified Cargo ID.
//
// Parameters:	_cargoId - The Cargo ID to scan for.
//				_cargoCount - The unique "index" of the Cargo item.
//				_isRelease - True if the cargo is for release, otherwise a receival
//					is assumed.
//
// Returns:		A reference to a cargo object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyCargoObj	: GTE_KioskProxyCargo;
	
begin
	if _isRelease then
		foreach proxyCargoObj in self.allReleases do
			if proxyCargoObj.id = _cargoId and proxyCargoObj.count = _cargoCount then
				return proxyCargoObj;
			endif;
		endforeach;
	else
		foreach proxyCargoObj in self.allReceivals do
			if proxyCargoObj.id = _cargoId and proxyCargoObj.count = _cargoCount then
				return proxyCargoObj;
			endif;
		endforeach;
	endif;
	
	return null;
end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_cargoCount" type="Integer"/>
        <Parameter name="_isRelease" type="Boolean"/>
        <ReturnType type="GTE_KioskProxyCargo"/>
    </JadeMethod>
    <JadeMethod name="getProxyCargoArray" id="dc8f94bc-d670-41fd-a085-8212d2cf93db">
        <source>getProxyCargoArray(_proxyCargoObj:GTE_KioskProxyCargo):GTE_KioskProxyCargoArray;
// --------------------------------------------------------------------------------
// Created:		26 September 2006 by cnwdad1
//
// Purpose:		Returns the array to which the specified proxy Cargo belongs.
//
// Parameters:	_proxyCargoObj - A reference to the proxy Cargo who's array to fetch.
//
// Returns:		A reference to an array of proxy Cargos, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allProxyCargosObj	: GTE_KioskProxyCargoArray;
	
begin
	if _proxyCargoObj.isForReceival() then
		return self.allReceivals;
	elseif _proxyCargoObj.isForRelease() then
		return self.allReleases;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_proxyCargoObj" type="GTE_KioskProxyCargo"/>
        <ReturnType type="GTE_KioskProxyCargoArray"/>
    </JadeMethod>
    <JadeMethod name="isCargoAllowed" id="262ceeba-4b5e-4cb2-9bff-008f6309f178">
        <source>isCargoAllowed(_cargoItemObj:CM_Object; _errorMsg:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 September 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is full of
//				cargo.
//
// Parameters:	_cargoItemObj - A reference to the cargo to add to the load.
//				_errorMsg - An error message if the cargo win't fit.
//
// Returns:		True if the cargo is allowed on the load, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tiObj		: CM_TrackedItem;
	brObj		: CM_BulkRelease;
	isForty		: Boolean;
	
begin
	if _cargoItemObj.isKindOf(CM_TrackedItem) then
		tiObj	:=	_cargoItemObj.CM_TrackedItem;
	elseif _cargoItemObj.isKindOf(CM_BulkRelease) then
		brObj	:=	_cargoItemObj.CM_BulkRelease;
	endif;
	
	return true;
end;</source>
        <Parameter name="_cargoItemObj" type="CM_Object"/>
        <Parameter name="_errorMsg" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCargoAlreadyUsed" id="2ad3d7d3-46a9-4b92-a102-27e0c7ae3a3a">
        <source>isCargoAlreadyUsed(_cargoItemObj:CM_Object):Boolean;
// --------------------------------------------------------------------------------
// Created:		05 October 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether a Cargo item has already
//				been requested for the current load.
//
// Parameters:	_cargoItemObj - A reference to the Cargo item object.
//
// Returns:		True if the Cargo is already requested, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyCargoObj	: GTE_KioskProxyCargo;
	
begin
	foreach proxyCargoObj in self.allReceivals do
		if proxyCargoObj.myCargoItem = _cargoItemObj then
			return true;
		endif;
	endforeach;
	
	foreach proxyCargoObj in self.allReleases do
		if proxyCargoObj.myCargoItem = _cargoItemObj then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_cargoItemObj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReceivalItem" id="aebf8d92-7ef6-477e-a069-1286345e01e6">
        <source>isReceivalItem(_trackedItemObj:CM_Object):Boolean;
// --------------------------------------------------------------------------------
// Created:		09 August 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified Tracked
//				Item is a receival.
//
// Parameters:	_trackedItemObj - A reference to the Tracked Item.
//
// Returns:		True if the item is a receival, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _trackedItemObj.isKindOf(CM_TrackedItem) then
		if _trackedItemObj.CM_TrackedItem.state = TI_STATE_NOTIFIED then
			return true;
		else
			return false;
		endif;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_trackedItemObj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReleaseItem" id="8eb7bd66-2cc9-4ead-baac-918cb2d99656">
        <source>isReleaseItem(_trackedItemObj:CM_Object):Boolean;
// --------------------------------------------------------------------------------
// Created:		09 August 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified Cargo
//				Item is a release.
//
// Parameters:	_trackedItemObj - A reference to the Tracked Item.
//
// Returns:		True if the item is a release, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _trackedItemObj.isKindOf(CM_BulkRelease) then
		return true;
	elseif _trackedItemObj.isKindOf(CM_TrackedItem) then
		if _trackedItemObj.CM_TrackedItem.state = TI_STATE_NORMAL then
			return true;
		else
			return false;
		endif;
	endif;
end;</source>
        <Parameter name="_trackedItemObj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveCargoPosition" id="63e4d33d-a07c-4671-b1c6-ba08f540846f">
        <source>moveCargoPosition(_object:GTE_KioskProxyCargo; _position:Integer; _isReceival:Boolean; _isRelease:Boolean);
// --------------------------------------------------------------------------------
// Created:		09 August 2006 by cnwdad1
//
// Purpose:		Moves the specified cargo item to the specified position within the
//				item array (where position 1 is the front).
//
// Parameters:	_object - A reference to the cargo item to move.
//				_position - The position to move the item to.
//				_isReceival - True if the item is a receival.
//				_isRelease - True if the item is a release.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allCargoItems	: GTE_KioskProxyCargoArray;
	
begin
	if _isReceival then
		allCargoItems	:=	self.allReceivals;
	elseif _isRelease then
		allCargoItems	:=	self.allReleases;
	else
		return;
	endif;
	
	if allCargoItems.includes(_object)
	and allCargoItems.indexOf(_object) &lt;&gt; _position
	then
		allCargoItems.remove(_object);
		allCargoItems.insert(_position, _object);
	endif;
end;</source>
        <Parameter name="_object" type="GTE_KioskProxyCargo"/>
        <Parameter name="_position" type="Integer"/>
        <Parameter name="_isReceival" type="Boolean"/>
        <Parameter name="_isRelease" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveLoad" id="dcf93454-93b2-4564-81b1-23859cb175cd">
        <source>moveLoad(_proxyCargoObj:GTE_KioskProxyCargo);
// --------------------------------------------------------------------------------
// Created:		26 September 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	_proxyCargoObj - A reference to the proxy Cargo Container to move.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allProxyCargosObj	: GTE_KioskProxyCargoArray;
	arrayPos			: Integer;
	
begin
	allProxyCargosObj	:=	self.getProxyCargoArray(_proxyCargoObj);
	arrayPos			:=	allProxyCargosObj.indexOf(_proxyCargoObj);
	
	if arrayPos = allProxyCargosObj.size() then
		while true do
			allProxyCargosObj.moveElement(_proxyCargoObj, true);
			
			if allProxyCargosObj.indexOf(_proxyCargoObj) = 1 then
				break;
			endif;
		endwhile;
	else
		allProxyCargosObj.moveElement(_proxyCargoObj, false);
	endif;
end;</source>
        <Parameter name="_proxyCargoObj" type="GTE_KioskProxyCargo"/>
    </JadeMethod>
    <JadeMethod name="setTerminal" id="825339ec-501a-47a3-8d31-c205562a24e7">
        <updating/>
        <source>setTerminal(_terminalObj:CM_Terminal) updating;
// --------------------------------------------------------------------------------
// Created:		15 August 2006 by cnwdad1
//
// Purpose:		Sets a reference to the receiver's Terminal object.
//
// Parameters:	_terminalObj - A reference to the Terminal object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myTerminal	:=	_terminalObj;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setVehicle" id="b60370db-63d5-4dd1-a565-bf908d7cf898">
        <updating/>
        <source>setVehicle(_regoNumber:String):String updating;
// --------------------------------------------------------------------------------
// Created:		14 August 2006 by cnwdad1
//
// Purpose:		Sets the details of a vehicle for the specified registration number.
//
// Parameters:	_regoNumber - The registration number of the vehicle.
//
// Returns:		Null if the vehicle details were set, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	vehicleObj	: CM_Vehicle;
	
begin
	vehicleObj	:=	self.myTerminal.vehicles[_regoNumber, ""];
	
	if vehicleObj = null then
		return "There is no vehicle recorded for licence plate '" &amp; _regoNumber &amp; "'.";
	endif;

	if vehicleObj.carrier = null then
		return "There is no carrier associated with the licence plate '" &amp; _regoNumber &amp; "'.";
	endif;
	
	self.regoNumber	:=	_regoNumber;
	self.myVehicle	:=	vehicleObj;
	
	return null;
end;</source>
        <Parameter name="_regoNumber" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
