<Class name="CM_InvoiceStatusReason" id="6f7424a5-656c-48d5-ac2a-cdd45e09b283">
    <superclass name="CM_Code"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ExplicitInverseRef name="myTerminal" id="e648b8f3-6e32-4410-9e2d-ae31a0fdb88b">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allInvoiceStatusReasons"/>
    </ExplicitInverseRef>
    <JadeMethod name="setForCreate" id="82c18beb-66ae-4593-bb63-3ad01686f003">
        <updating/>
        <source>setForCreate(pProxy: CM_InvoiceStatusReason) updating;
/*

Date		Who		Reason
29 September 2015	cnwer1	Initial creation PAR 36958

*/

vars

begin
	inheritMethod(pProxy);
	self.myTerminal:=pProxy.myTerminal;
epilog

end;</source>
        <Parameter name="pProxy" type="CM_InvoiceStatusReason"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="da149811-346a-4508-97a8-f788fee85454">
        <updating/>
        <source>setProxy(	_code, 
			_description : String;
			_notAvailableForEntry: Boolean;
			_terminal : CM_Terminal input)updating;
/*
Date		Who		Reason
29 September 2015	cnwer1	Initial creation PAR 36958

*/

vars


begin
	self.setSuperClassDetailsForProxy(_code, _description,_notAvailableForEntry,null);
	self.myTerminal := _terminal;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="a0bdba9c-0047-40ad-aaf3-37bcce0071f9">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2018	jlgns1	Initial creation
//23/04/2018 JLGNS1 Bug 38115: GUQ - 7206 extension-Show Parent &amp; Child items from BOL (issue 2)
// Don't let the user delete the current reason if there are no reasons in the terminal that are available for entry.
// unless this is the only reason left in the Terminal, then we don't care.
*/

vars
	reason : CM_InvoiceStatusReason;
	
begin
	inheritMethod();
	
	if self.myTerminal.allInvoiceStatusReasons.size = 1 then
		//We are deleting the last one, All good
		return;
	endif;
	
		
	foreach reason in self.myTerminal.allInvoiceStatusReasons do
		if reason &lt;&gt; self and not reason.notAvailableForEntry then
			//We've found a useable one, All good
			return;
		endif;
	endforeach;
		
	//we have no useable reasons in the terminal, Raise exception
	app.raiseCMException1(Must_have_invoice_statu_ch,self.myTerminal.name,self.code,null);
	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="9017ab92-1e68-4167-9c4d-c133a5954980">
        <source>validateMe() protected;
/*

Date		Who		Reason
29 September 2015	cnwer1	Initial creation PAR
//23/04/2018 JLGNS1 Bug 38115: GUQ - 7206 extension-Show Parent &amp; Child items from BOL (issue 2)
*/

vars
	reason 			: CM_InvoiceStatusReason;		// Bug 38115
	realReason 		: CM_InvoiceStatusReason;		// Bug 38115
	availableReason : Boolean;						// Bug 38115
begin
	inheritMethod();
	//its a create
	if self.pxyGetRealObject = null or self.pxyGetRealObject.CM_InvoiceStatusReason.code &lt;&gt; self.code then
		//duplicate
		if self.myTerminal.allInvoiceStatusReasons[self.code] &lt;&gt; null then
			app.raiseCMException1(Duplicate_code_must_unique,self.code,null,null);
		endif;
	endif;
	
	
	
	if self.notAvailableForEntry then																	// Bug 38115
		realReason := self.pxyGetRealObject;															// Bug 38115
		availableReason := false;																		// Bug 38115
		foreach reason in self.myTerminal.allInvoiceStatusReasons do									// Bug 38115
			if not reason = realReason and not reason.notAvailableForEntry then							// Bug 38115
				//We have a usable one, All is good														// Bug 38115
				availableReason := true;																// Bug 38115
				break;																					// Bug 38115
			endif;																						// Bug 38115
		endforeach;																						// Bug 38115
																										// Bug 38115
		if not availableReason then																		// Bug 38115
			//we have no usable reasons, Raise an exception												// Bug 38115
			app.raiseCMException1(Must_have_invoice_statu_ch,self.myTerminal.name,self.code,null);		// Bug 38115
		endif;																							// Bug 38115
	endif;																								// Bug 38115
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
