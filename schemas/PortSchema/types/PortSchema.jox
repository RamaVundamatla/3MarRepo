	elseif _context = FileCategoryContext_Voyage then
		return FileCategoryContext_VoyageStr;
	elseif _context = FileCategoryContext_CargoType then
		return FileCategoryContext_CrgoTypStr;
	elseif _context = FileCategoryContext_Invoice then
	return FileCategoryContext_InvoiceStr;
	elseif _context = FileCategoryContext_Other  then
