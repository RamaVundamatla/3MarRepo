        <source>showHSCodeMaintForm(_parentForm: CM_BaseForm; _showModal : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
14 December 2022		jlizm1	Initial creation TFS 55582 HS Code Searcher

*/

vars
	form : CMUI_HSCodeMaint;
	
begin
	
	if _showModal then
		form := app.loadForm(CMUI_HSCodeMaintModal, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_HSCodeMaintModal;
	else
		form := app.loadForm(CMUI_HSCodeMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_HSCodeMaint;
	endif;
	
	if form = null then
		return;
