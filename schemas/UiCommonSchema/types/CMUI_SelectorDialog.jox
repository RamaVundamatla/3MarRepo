        <source>checkIsQryFromToParent() updating;
/*

Purpose:	This method determines whether the QueryDefinition and Query Criteria is coming from and sending to the parent form.
			If true, then we set self.myQDef from parent, and build the criteria table from parent's criteria
			Otherwise, build default criteria;

Parameters:			

Return Value:		

Date		Who		Reason
12/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries

*/

vars

begin
	if self.myParentFrm.isKindOf(CMUI_CargoReview) then
		self.isQryFromToParent := true;
	endif;
epilog

end;</source>
