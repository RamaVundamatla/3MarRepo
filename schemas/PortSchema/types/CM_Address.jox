    <JadeMethod name="cnEcGetDuplicate" id="d51327d6-e81c-4114-b4d0-6eda57cc7a20">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	consign : CM_ConsigneeConsignor;
	address : CM_Address;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, "CM_ConsigneeConsignor", "code" ).String; 
	
	if code &lt;&gt; null then
		consign := app.myRoot.allConsigneeConsignors.getAtKey( code );
		if consign &lt;&gt; null then
			address := consign.myAddress;
		endif;
	endif;

epilog

	return address;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="countryName" id="0eb4a673-67ef-4c2d-a400-e1077e73a5ea">
        <methodInvocation>mapping</methodInvocation>
        <source>countryName(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     18 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCountry	: CM_Country;
begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		// get code here
		tmpCountry := app.myRoot.allCountries[self.countryCode];
		if tmpCountry &lt;&gt; null then
			_value := tmpCountry.description;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAuditChildSubjects" id="2c1e410d-66be-4f21-8030-cebd29af3c41">
        <source>getAuditChildSubjects(_childAuditSubjectNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	jlier1	Initial creation

*/

vars

begin
	inheritMethod(_childAuditSubjectNames);
	_childAuditSubjectNames.addTruncated(app.getErrorString(Address) &amp; " "  &amp; self.code);

epilog

end;</source>
