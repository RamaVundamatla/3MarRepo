<Class name="System">
    <JadeMethod name="cnEcGetCPUInfo" id="4743ee4e-c4f6-4fac-a24f-4edbcbd3299d">
        <source>cnEcGetCPUInfo():String;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Returns a description of the number of CPUs and their type.
//
// Parameters:	None
//
// Returns:		A string describing the CPU(s).
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	HKEY_CLASSES_ROOT		: Integer = #80000000;
	HKEY_CURRENT_USER		: Integer = #80000001;
	HKEY_LOCAL_MACHINE		: Integer = #80000002;
	HKEY_USERS				: Integer = #80000003;
	HKEY_PERFORMANCE_DATA	: Integer = #80000004;
	HKEY_CURRENT_CONFIG		: Integer = #80000005;
	HKEY_DYN_DATA			: Integer = #80000006;
	PROCESSOR_INTEL_386		: Integer = 386;
	PROCESSOR_INTEL_486		: Integer = 486;
	PROCESSOR_INTEL_PENTIUM	: Integer = 586;
	PROCESSOR_MIPS_R4000	: Integer = 4000;
	PROCESSOR_ALPHA_21064	: Integer = 21064;
	
vars
	systemInfoData	: Binary;
	keyHandle		: Integer;
	subKey			: String[256];
	valueName		: String[256];
	infoData		: Binary[256]; 
	openKey			: Integer;
	functionResult	: Integer; 
	openResult		: Integer;
	dataLength		: Integer;
	cpuCount		: Integer;
	cpuType			: Integer;
	returnString	: String;
	
begin
	keyHandle		:=	HKEY_LOCAL_MACHINE;
	subKey			:=	"HARDWARE\DESCRIPTION\System\CentralProcessor\0";
	infoData		:=	null;
	infoData[255:1]	:=	0.Binary;
	dataLength		:=	255;
	valueName		:=	"~MHz";
	systemInfoData	:=	null;
	systemInfoData[32:1]	:=	0.Binary;
	
	if app.isUnicode() then
		openResult		:=	call cnEcRegOpenKeyW(keyHandle, subKey, openKey);
		functionResult	:=	call cnEcRegQueryValueExW(openKey, valueName, null, null, infoData, dataLength);
	else
		openResult		:=	call cnEcRegOpenKeyA(keyHandle, subKey, openKey);
		functionResult	:=	call cnEcRegQueryValueExA(openKey, valueName, null, null, infoData, dataLength);
	endif;

	functionResult	:=	call cnEcRegCloseKey(openKey);

	call cnEcGetSystemInfo(systemInfoData);
	
	cpuCount	:=	systemInfoData[21:4].Integer;
	cpuType		:=	systemInfoData[25:4].Integer;

	if cpuCount &gt; 1 then
		returnString	:=	cpuCount.String &amp; " x ";
	else
		returnString	:=	null;
	endif;

	if cpuType = PROCESSOR_INTEL_386 then
		returnString	:=	returnString &amp; "i386 ";
	elseif cpuType = PROCESSOR_INTEL_486 then
		returnString	:=	returnString &amp; "i486 ";
	elseif cpuType = PROCESSOR_INTEL_PENTIUM then
		returnString	:=	returnString &amp; "Pentium ";
	else
		returnString	:=	returnString &amp; "Non-Intel ";
	endif;
	
	returnString	:=	returnString &amp; infoData.Binary[1:4].Integer.String;
	
	return returnString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDiskAndMemory" id="04deff91-b386-4343-9dd3-db75014cfa78">
        <source>cnEcGetDiskAndMemory(pFreeMemory:Integer output; pFreeDiskSpace:Decimal output; pDriveName:String output);
// --------------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Returns the free memory, disk space and the drive name (letter)
//				from the database server node's machine.
//
// Parameters:	pFreeMemory - The amount of free memory.
//				pFreeDiskSpace - The amount of free disk space.
//				pDriveName - The default drive letter.
//
// Returns:		The above parameter values.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorNumber	: Integer;
	errorText	: String;

begin
	pFreeMemory		:=	0;
	pFreeDiskSpace	:=	0;
	pDriveName		:=	null;
	
	// Arm an exception handler to guard against something going wrong in
	// cnEcGetFreeDiskAndMemory (eg: the external functions are not available).
	on Exception do global.cnEcXHandlerResumeNext(exception, errorNumber, errorText);
	
	self.cnEcGetFreeDiskAndMemory(pFreeMemory, pFreeDiskSpace, pDriveName);

	// If an exception occurs in cnEcGetFreeDiskAndMemory, our handler armed
	// above will resume to here and we'll just return from this method.
end;</source>
        <Parameter name="pFreeMemory" type="Integer" usage="output"/>
        <Parameter name="pFreeDiskSpace" type="Decimal" usage="output"/>
        <Parameter name="pDriveName" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDiskAndMemoryServer" id="b898239b-afdb-4d08-905d-00f878293f1f">
        <executionLocation>server</executionLocation>
        <source>cnEcGetDiskAndMemoryServer(pFreeMemory:Integer output; pFreeDiskSpace:Decimal output; pDriveName:String output) serverExecution;
// --------------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Returns the free memory, disk space and the drive name (letter)
//				from the database server node's machine.
//
// Parameters:	pFreeMemory - The amount of free memory.
//				pFreeDiskSpace - The amount of free disk space.
//				pDriveName - The default drive letter.
//
// Returns:		The above parameter values.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorNumber	: Integer;
	errorText	: String;

begin
	pFreeMemory		:=	0;
	pFreeDiskSpace	:=	0;
	pDriveName		:=	null;
	
	// Arm an exception handler to guard against something going wrong in
	// cnEcGetFreeDiskAndMemory (eg: the external functions are not available).
	on Exception do global.cnEcXHandlerResumeNext(exception, errorNumber, errorText);
	
	self.cnEcGetFreeDiskAndMemory(pFreeMemory, pFreeDiskSpace, pDriveName);

	// If an exception occurs in cnEcGetFreeDiskAndMemory, our handler armed
	// above will resume to here and we'll just return from this method.
end;</source>
        <Parameter name="pFreeMemory" type="Integer" usage="output"/>
        <Parameter name="pFreeDiskSpace" type="Decimal" usage="output"/>
        <Parameter name="pDriveName" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetFreeDiskAndMemory" id="79de8f94-0775-40cc-867d-a5065aeaaadf">
        <source>cnEcGetFreeDiskAndMemory(	pFreeMemory: Integer output;
							pFreeDiskSpace: Decimal output;
							pDriveName: String output) protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2000 by cnwdad1
//
// Purpose:		Returns the free memory, disk space and the driver name (letter).
//				This method assumes it is executing on the database server node
//				(ie: the caller must itself be a server method, or have been called
//				from a server method).
//
// Parameters:	pFreeMemory - The amount of free memory.
//				pFreeDiskSpace - The amount of free disk space.
//				pDriveName - The default drive letter.
//
// Returns:		The above parameter values.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	databasePath	: String;
	userFreeBytes	: Binary[8];
	totalBytes		: Binary[8];
	totalFreeBytes	: Binary[8];
	availableBytes	: Decimal[23];
	topHalf			: Integer;
	bottomHalf		: Integer;
	colonPosition	: Integer;
	statusStructure	: Binary;

begin
	statusStructure[1:256]	:=	0.Binary;
	
	call cnEcGlobalMemoryStatus(statusStructure);

	pFreeMemory := statusStructure[13:4].Integer;

	databasePath	:=	app.getJadeInstallDir();
	if databasePath = null then
		return;
	endif;
	
	colonPosition	:=	databasePath.pos(':', 1);
	if colonPosition &lt; 2 then
		return;
	endif;
	
	databasePath	:=	databasePath[1:colonPosition];
	pDriveName		:=	databasePath[1:(colonPosition - 1)];
	
	if app.isUnicode() then
		call cnEcGetDiskFreeSpaceExW(databasePath, userFreeBytes, totalBytes, totalFreeBytes);
	else
		call cnEcGetDiskFreeSpaceExA(databasePath, userFreeBytes, totalBytes, totalFreeBytes);
	endif;
		
	topHalf		:=	totalFreeBytes[5:4].Integer;
	bottomHalf	:=	totalFreeBytes[1:4].Integer;

	if bottomHalf &lt; 0 then
		availableBytes := bottomHalf.bitAnd(#7FFFFFFF) + 2147483648;
	else
		availableBytes := bottomHalf;
	endif;
	
	availableBytes := availableBytes + (topHalf * 4294967296);

	pFreeDiskSpace := availableBytes;
end;</source>
        <access>protected</access>
        <Parameter name="pFreeMemory" type="Integer" usage="output"/>
        <Parameter name="pFreeDiskSpace" type="Decimal" usage="output"/>
        <Parameter name="pDriveName" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetMachineMemory" id="965756d4-7297-441a-a7ee-e48112fd404d">
        <source>cnEcGetMachineMemory():Integer protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2006 by cnwdad1
//
// Purpose:		Fetches the amount of memory that is installed on the machine where
//				this method is executing.
//
// Parameters:	None
//
// Returns:		The amount of installed memory, in megabytes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	lngMemoryLoad    : Integer;
	lngTotalPhys     : Integer;
	lngAvailPhys     : Integer;
	lngTotalPageFile : Integer;
	lngAvailPageFile : Integer;
	lngTotalVirtual  : Integer;
	lngAvailVirtual  : Integer;
	memoryStructure  : Binary;

begin
	memoryStructure[28:4]	:=	0.Binary;
	memoryStructure[ 1:4]	:=	32.Binary;
    call cnEcGetMemoryValues(memoryStructure);

    lngMemoryLoad		:=	memoryStructure[ 5:4].Integer;    
    lngTotalPhys		:=	memoryStructure[ 9:4].Integer;
    lngAvailPhys		:=	memoryStructure[13:4].Integer;
    lngTotalPageFile	:=	memoryStructure[17:4].Integer;
    lngAvailPageFile	:=	memoryStructure[21:4].Integer;
    lngTotalVirtual		:=	memoryStructure[25:4].Integer;
    lngAvailVirtual		:=	memoryStructure[29:4].Integer;
	
    return lngTotalPhys div 1024000;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetMachineMemoryAppServ" id="6fbd1f82-fff6-4834-a111-0def978118ae">
        <source>cnEcGetMachineMemoryAppServ():Integer;
// --------------------------------------------------------------------------------
// Created:		07 June 2006 by cnwdad1
//
// Purpose:		Fetches the amount of memory that is installed on the machine where
//				the Application Sserver node is running.
//
// Parameters:	None
//
// Returns:		The amount of installed memory, in megabytes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	lngMemoryLoad    : Integer;
	lngTotalPhys     : Integer;
	lngAvailPhys     : Integer;
	lngTotalPageFile : Integer;
	lngAvailPageFile : Integer;
	lngTotalVirtual  : Integer;
	lngAvailVirtual  : Integer;
	memoryStructure  : Binary;

begin
	memoryStructure[28:4]	:=	0.Binary;
	memoryStructure[ 1:4]	:=	32.Binary;
    call cnEcGetMemoryValuesOnAppServer(memoryStructure);

    lngMemoryLoad		:=	memoryStructure[ 5:4].Integer;    
    lngTotalPhys		:=	memoryStructure[ 9:4].Integer;
    lngAvailPhys		:=	memoryStructure[13:4].Integer;
    lngTotalPageFile	:=	memoryStructure[17:4].Integer;
    lngAvailPageFile	:=	memoryStructure[21:4].Integer;
    lngTotalVirtual		:=	memoryStructure[25:4].Integer;
    lngAvailVirtual		:=	memoryStructure[29:4].Integer;
	
    return lngTotalPhys div 1024000;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetMachineMemoryClient" id="b5d93d3b-aae4-44af-a45c-16f307b5c0fa">
        <source>cnEcGetMachineMemoryClient():Integer;
// --------------------------------------------------------------------------------
// Created:		07 June 2006 by cnwdad1
