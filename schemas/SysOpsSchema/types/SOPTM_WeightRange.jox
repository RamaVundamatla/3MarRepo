end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="948728f9-88b9-4f09-aff2-4d4bddd0f0bd">
        <updating/>
        <source>setupThumbnailDetails() updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 25 September 2003
//
//-----------------------------------------------------------------------

vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_WeightRangeTbl);
//	theForm.zAddColumn('TempRange Value', 'value', Table.InputType_None, 50);
//	theForm.zAddColumn('Colour','colour',Table.InputType_None,30);
//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Value, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_WeightRangeMain);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);			
		
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="16cfff53-4aaa-407f-bb47-f8be083324f7">
        <updating/>
        <source>showThumbnail(pWeightRange : CM_WeightRange) updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 25 September 2003
//
//-----------------------------------------------------------------------

vars

	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Percentage, pWeightRange.percentage);
	theForm.tblInput1.setValueByName(ETRow_Colour,pWeightRange.colour);
	theForm.tblInput1.setValueByName(ETRow_Lower, pWeightRange.lower);
	theForm.tblInput1.setValueByName(ETRow_Upper, pWeightRange.upper);
end;</source>
        <Parameter name="pWeightRange" type="CM_WeightRange"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="ab8ec116-00e1-4546-8459-86ccd4235351">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	weightRange	:	CM_WeightRange;
	cell     	:	JadeTableCell;
begin

	weightRange := _obj.CM_WeightRange;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;			
			cell.backColor := weightRange.colour;
		endif;
	endif;

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
