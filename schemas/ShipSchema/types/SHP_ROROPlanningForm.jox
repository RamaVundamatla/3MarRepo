    <JadeMethod name="doInsertPoint" id="bf8a0ed5-203b-4543-b227-059ed6d7aecb">
        <updating/>
        <source>doInsertPoint(_insertBefore : Boolean) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/
vars
	thePoint : Point;
	theFrame : CMUI_PointDrawingFrame;
	theReturn : Integer;
begin

	theFrame := self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame;
	thePoint := theFrame.getDragPoint2(); 
	
	while true do
		app.myTrxUA.trxUpdateROROPointInsert(thePoint,_insertBefore,theFrame.theGraphic, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Insert) &amp; " " &amp; app.getErrorString(New_point), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

end;</source>
        <Parameter name="_insertBefore" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doJobDelete" id="e14aee8a-064d-4d72-8bbc-f6c8201b406b">
        <updating/>
        <source>doJobDelete() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theJobId : String;
	isCreate: Boolean;
	result  : Integer;
	theRealVJob : CM_VoyageJob;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	if self.modeWork &lt;&gt; WorkMode_Job then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString1(Invalid_working_mode_none,self.modeWork.String));
		return;
	endif;
	
	theRealVJob :=  self.cmbWPJob.listObject.CM_VoyageJob; 
	isCreate := false;
	if theRealVJob = null then
		// the job id may not be in the combo cos it has not been allocated to the crane so go to the point to get the job id
		theRealVJob := self.getTheSelectedJob();
	endif;

	if theRealVJob = null then
		app.msgBox(app.getErrorString(Job_must_entered_selected),app.getErrorString(Job) &amp; " " &amp; app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	theJobId := theRealVJob.jobNum;
	
	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete,theJobId), app.getErrorString1(Confirm_delete_something,app.getErrorString(Job)), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	

	while true do
		app.myTrxDA.trxDeleteVoyageJob(theRealVJob, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_job), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

		endif;
		return;
	endwhile;

	self.doCmbJobBuild(true);
	
epilog

	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doJobNotificationUpdate" id="41c395fb-48a8-4d85-8015-d9d74b2357bc">
        <updating/>
        <source>doJobNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
/*
Date		    Who			Reason
27 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
Dec 2011		cnwjre1		revised for 28750 - this code wasn't being called and needed cleaning up
*/

vars
	theJob 					: CM_VoyageJob;
	theTable 				: CM_DataTable;
	theTopRow,idx,
	foreColour, backColour	: Integer;
	theJobTITotals 			: CMIF_JobTITotals;
	theDataLine				: String;
begin
	theTable := self.tblJobsData;

	if _event = VoyageJob_Delete_Event  or not global.isValidObject(_obj) then 
		if self.myCurrentJob = _obj then
			self.myCurrentJob:=null;
		endif;
		self.updateJobRemove(_obj);
		//cnwmc5 - PAR 31061 - added validation
		if self.myCurrentDeck &lt;&gt; null then
			// 29296 Mar 2012 update total on Jobs tab
			self.shtJobs.caption := app.getErrorString(Deck) &amp; " " &amp; self.myCurrentDeck.code &amp; " " &amp; app.getErrorString(Jobs) &amp; " (" &amp; (theTable.rows-theTable.fixedRows).asStringJMT() &amp; ")";
		endif;
		return;

	elseif CM_VoyageJob.hasInstance(_obj) then 
		
		theJob := _obj.CM_VoyageJob;
		if theJob.myVoyage &lt;&gt; self.myCurrentVoyage then
			return;
		endif;
				
		// find the job and update that line OR add onto the end of the list
		theTable.findObjectInRow(theJob,theTopRow);
		// if it exists, remove and add back at the same row to keep the existing order,
		//  otherwise add to the end of the table
		if theTopRow &gt; 0 then	
			theTable.removeItem(theTopRow);	
		else
			theTopRow := theTable.rows + 1;		// 28750 Jan 2012 job deletion add +1
		endif;	

		create theJobTITotals transient;
		theJob.getJobTITotals(theJobTITotals);
		theDataLine := theJobTITotals.getAttributeStringForDefArray(theTable.allTblDataEntRows);
		
		theTable.addItemAt(theDataLine,theTopRow);
		theTable.accessRow(theTopRow).itemObject := theJob;
		idx := theTopRow;

		theJob.getRowColour(foreColour, backColour);
		theTable.accessRow(idx).backColor := backColour;
		theTable.accessRow(idx).foreColor := foreColour;
		if theTable.accessRow(idx).backColor = Red then
			theTable.accessRow(idx).fontBold := true;
		else
			theTable.accessRow(idx).fontBold := false;				
		endif;
		
		//cnwmc5 - PAR 31061 - added validation
		if self.myCurrentDeck &lt;&gt; null then
			self.shtJobs.caption := app.getErrorString(Deck) &amp; " " &amp; self.myCurrentDeck.code &amp; " " &amp; app.getErrorString(Jobs) &amp; " (" &amp; (theTable.rows-theTable.fixedRows).asStringJMT() &amp; ")";
		endif;
	endif;
epilog
	delete theJobTITotals;
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doJobQuery" id="580fc134-e008-44fa-b61c-634b4d30ab1f">
        <source>doJobQuery();
/*
Date		    Who			Reason
26 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	allJobs 		: CM_VoyageJobSet;
	theTable 		: CM_DataTable;
	theRow,
	idx,
	theJobTotal,
	foreColour,
	backColour,
	theRunningTotal,
	numJobs			: Integer;
	theJob 			: CM_VoyageJob;
	theJobTITotals	: CMIF_JobTITotals;
	allJobTITotals 	: ObjectSet;
	theDataLine		: String;
begin
	theTable := self.tblJobsData;
	create allJobs transient;
	create allJobTITotals transient;//epr tfs 830 more leaking transients
	self.myCurrentDeck.getAllDeckJobs(allJobs); 
	
	theTable.rows := theTable.fixedRows;
	theRow := 0;
	numJobs := allJobs.size();
	
	foreach theJob in allJobs do
		create theJobTITotals transient;
		theJobTITotals.myJob := theJob;
		allJobTITotals.add(theJobTITotals);
		theJob.getJobTITotals(theJobTITotals);
		theRow := theRow + 1;
		
		theDataLine := theJobTITotals.getAttributeStringForDefArray(theTable.allTblDataEntRows);
		
		idx := theTable.addItemObject(theJob,theDataLine);
		theTable.accessRow(idx).itemObject := theJob;	// 28750 Jan 2012 job deletion
		
		theJobTotal := theTable.getCellValueByName(ETRow_TotalJob,idx).Integer;
		theRunningTotal := theRunningTotal + theJobTotal;
		
		if theJobTotal &lt;&gt; 0 then
			theTable.setCellValueByName(ETRow_TotalPlan,idx,theRunningTotal.String);
		endif;
		
		theJob.getRowColour(foreColour, backColour);
		theTable.accessRow(idx).backColor := backColour;
		theTable.accessRow(idx).foreColor := foreColour;
		
	endforeach;
epilog
	delete allJobs;
	if allJobTITotals &lt;&gt; null then
		allJobTITotals.purge;
		delete allJobTITotals;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doJobsRefresh" id="2a5879ea-6306-4f51-a963-630c17f0df8d">
        <source>doJobsRefresh();
/*
Date		    Who			Reason
21 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	jobs : CM_VoyageJobSet;
begin
	create jobs transient;
	self.myCurrentDeck.getAllDeckJobs(jobs);
	
	self.shtJobs.caption := app.getErrorString(Deck) &amp; " " &amp; self.myCurrentDeck.code &amp; " " &amp; app.getErrorString(Jobs) &amp; " (" &amp; jobs.size.asStringJMT() &amp; ")";
	self.doJobQuery();
epilog
	delete jobs;
end;</source>
    </JadeMethod>
