    <JadeMethod name="setProxy" id="b5000a18-471a-403d-99b5-5f22bccbb873">
        <updating/>
        <source>setProxy(_bank : CM_Bank; _parent : CM_Object; _invLine : CM_InvoiceLineDesc; _combination : CM_Object; _type : Integer; _debtorType : CM_DebtorType; _chgType : String ) updating;
// ---------------------------------------------------------------------------
// Created:		19 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myParentMappingObject := _parent;
	self.myCombinationMappingObject := _combination;
	self.myInvoiceLineDesc := _invLine;
	self.chargeByOpCon := _type;
	self.myDebtorType := _debtorType; //cp ccms 1047 Par 16666 cnwgb1 18 April 2008
	self.chargeTypeCode := _chgType;
	
	self.myBank := _bank;
	
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_invLine" type="CM_InvoiceLineDesc"/>
        <Parameter name="_combination" type="CM_Object"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_debtorType" type="CM_DebtorType"/>
        <Parameter name="_chgType" type="String"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="46e2043d-c9ee-4d8a-8a1d-0e8fb8d60aec">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

	vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_InvoiceLineChargeMapping::myChildQuantityMap.name   or
		propName = CM_InvoiceLineChargeMapping::myInvoiceLineDesc.name    or
		propName = CM_InvoiceLineChargeMapping::myBank.name or 
		propName = CM_InvoiceLineChargeMapping::chargeByOpCon.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="91601ecc-bae9-48d4-9b20-793df0563b8b">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 23/12/2014  cnwdb2	PAR 35364
vars
	aCom, aParent : CM_Object; 
	aLine : CM_InvoiceLineDesc; 
	aMap, aMapFirst : CM_InvoiceLineChargeMapping;
	blnReturn : Boolean;
begin
	aParent := self.myParentMappingObject;
	aLine := self.myInvoiceLineDesc;
	aCom := self.myCombinationMappingObject;

	if aParent = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Parent (e.g. Freight Forwarder, Operator etc)', null, self);
		app.raiseCMException(Input_required_field_parent, null, self); // cnwdb2	PAR 35364
		blnReturn := true;
	endif;
	if aLine = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'invoice line', null, self);
		app.raiseCMException(Input_required_field_invLine, null, self); // cnwdb2	PAR 35364


		blnReturn := true;
	endif;	
	if aCom = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Combination (e.g. Freight Forwarder, Operator etc)', null, self);
		app.raiseCMException(Input_required_field_comb, null, self); // cnwdb2	PAR 35364


		blnReturn := true;
	endif;
	// dh end of changes
	if blnReturn then
		return;
	endif;
	
	aMap := self.myBank.allInvLineChargeMappings[self.myInvoiceLineDesc, self.myParentMappingObject, self.myCombinationMappingObject];
	if aMap &lt;&gt; null then
			app.raiseCMException2(ERR_INVALID_VALUE, "Mapping", 
				"A mapping for " &amp; self.getDescription(2) &amp; " already exists. Delete and create again.", null, null);
	endif;

	// PAR 17557
	// Get first mapping. All mappings must be to the same combination type
	aMap := self.myBank.allInvLineChargeMappings.getAtKeyGeq(self.myInvoiceLineDesc, self.myParentMappingObject, null);
	if aMap &lt;&gt; null then
		if aMap.myInvoiceLineDesc = self.myInvoiceLineDesc
		and aMap.myParentMappingObject = self.myParentMappingObject then
			if aMap.myCombinationMappingObject.class() &lt;&gt; self.myCombinationMappingObject.class() then
				app.raiseCMException2(ERR_INVALID_VALUE, "Mapping", 
					"A mapping for " &amp; self.getDescription(1) &amp; " already exists. It is being used in combination with " &amp; self.getObjectTypeString(aMap.myCombinationMappingObject) &amp; "s, and "
					&amp; self.getObjectDesc(self.myCombinationMappingObject) &amp; " is not a " &amp; self.getObjectTypeString(aMap.myCombinationMappingObject), null, null);

			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
