    <JadeMethod name="mdhRemoveInvNoBank" id="093739b4-9adc-4a03-86a1-7896e3b5dd19">
        <source>mdhRemoveInvNoBank();

/*

Purpose:		Find any Invoices that don't have a bank reference and remove

Date			Who		Reason
12/03/2015		cnwmh5	Initial creation

*/

vars

	invoice					: CM_Invoice;
	
	count					: Integer;

begin

	beginTransaction;
	foreach invoice in CM_Invoice.instances discreteLock do
	
		if invoice.bank &lt;&gt; null and global.isValidObject(invoice.bank) then
			continue;
		endif;
		
		count := count + 1;
		write invoice.String &amp; Tab &amp; invoice.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; invoice.creationTime.time.String &amp; Tab &amp; 
			invoice.sequenceNum.String &amp; Tab &amp; invoice.bank.String;
			
		delete invoice;
	
	endforeach;
	commitTransaction;
	write 'Count: ' &amp; count.String;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhShowDetails" id="4af09818-782f-4d3b-887e-3f1524838362">
        <source>mdhShowDetails();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwmh5	Initial creation

*/

vars

	jdo					: JadeDynamicObject;
	fc					: XLAT_FormCaption;
	gc					: GlobalConstant;
	obj					: Object;
	
	dynaDict			: DynaDictionary;
	allMethodRefs		: MethodSet;
		
	count				: Integer;
	deleteCount			: Integer;
	
begin


	create dynaDict transient;
	dynaDict.setMembership(JadeDynamicObject);
	dynaDict.addExternalKey(String, 30, false, true);
	dynaDict.addExternalKey(String, 470, false, true);
	dynaDict.endKeys(true);

	create allMethodRefs transient;
	
	foreach fc in XLAT_FormCaption.instances discreteLock do
	
		gc := fc.myGlobalConstant;
		
		// check to see if method used anywhere.  If not add to deleted line
		allMethodRefs.clear();
		gc.getMethodRefs(allMethodRefs);
		if allMethodRefs.isEmpty then
			jdo := dynaDict['Delete', ''].JadeDynamicObject;
			if jdo = null then
				create jdo transient;
				jdo.addProperty('A', String);
				jdo.setPropertyValue('A', 'Delete');
				jdo.addProperty('B', String);
				jdo.setPropertyValue('B', '');
				jdo.addProperty('C', Integer);
				jdo.setPropertyValue('C', 1);
				dynaDict.putAtKey('Delete', '', jdo);
			else
				jdo.setPropertyValue('C', jdo.getPropertyValue('C'). Integer + 1);
			endif;
			continue;
		endif;
		
		// check to see if the string exists
		jdo := dynaDict['String', fc.vDefaultMessage[1:470]].JadeDynamicObject;
		if jdo = null then
				create jdo transient;
				jdo.addProperty('A', String);
				jdo.setPropertyValue('A', 'String');
				jdo.addProperty('B', String);
				jdo.setPropertyValue('B', fc.vDefaultMessage[1:470]);
				jdo.addProperty('C', Integer);
				jdo.setPropertyValue('C', 1);
				dynaDict.putAtKey('String', fc.vDefaultMessage[1:470], jdo);
			else
				jdo.setPropertyValue('C', jdo.getPropertyValue('C'). Integer + 1);
			endif;
		
	endforeach;

	foreach obj in dynaDict do
	
		jdo := obj.JadeDynamicObject;
		
		if jdo.getPropertyValue('A').String = "Delete" then
			deleteCount := jdo.getPropertyValue('C').Integer;
			write jdo.getPropertyValue('A').String &amp; Tab &amp; jdo.getPropertyValue('B').String &amp; Tab &amp; 
				deleteCount.String;
			continue;
		endif;
		
		write jdo.getPropertyValue('A').String &amp; Tab &amp; jdo.getPropertyValue('B').String &amp; Tab &amp; 
			jdo.getPropertyValue('C').String;		
		
		count := count + 1;
		
	endforeach;
	
	write 'Current XLAT_FormCaption size: ' &amp; XLAT_FormCaption.instances.size.String &amp; CrLf &amp;
		'Constants not used: ' &amp; deleteCount.String &amp; CrLf &amp;
		'Unique text: ' &amp; count.String &amp; CrLf &amp;
		'Diff: ' &amp; (XLAT_FormCaption.instances.size - count - deleteCount).String;
	
	
epilog

	delete jdo;
	delete dynaDict;
	delete allMethodRefs;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTest3" id="82d32d5d-7286-460a-8c6e-461c134023bc">
        <source>mdhTest3();

vars

	lsSchema				: LSschema;
	lsClass					: LSclass;
	
	formAgent				: FormCaptionsAgent;
	
begin

	app.initialize();

	create formAgent transient;
	
	create lsSchema transient;
	lsSchema.mySchema := rootSchema.getSchema("UiCommonSchema");
	lsSchema.name := lsSchema.mySchema.name;
		
	lsSchema.getLSclass("CMUI_BOLItemForm");
	lsClass := lsSchema.allClasses["CMUI_BOLItemForm"];
	if lsClass = null then
		return;
	endif;
		
	formAgent.processFormMethodDetails(lsSchema, lsClass);
	
	process.debug;
	
epilog

	delete lsSchema;
	delete formAgent;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTestLinkRunDetails" id="9f97de40-0a7b-4f19-a841-27a3b6e05044">
        <source>mdhTestLinkRunDetails();

/*

Purpose:		From the CSV dump from TestLink check to see what version the test was last run in

Date			Who		Reason
23/09/2013		cnwmh5	Initial creation
20/09/2016		cnwmh5	Rewrite

*/

vars

	file						: File;
	fileFolder					: FileFolder;
	fileNode					: FileNode;
	
	xmlDoc						: JadeXMLDocument;
	elementTestCase				: JadeXMLElement;
	xmlAttribute				: JadeXMLAttribute;
	xmlElement					: JadeXMLElement;
	xmlCDATA					: JadeXMLCDATA;
	
	testCaseXMLArray			: JadeXMLElementArray;
	
	testCaseDict				: DynaDictionary;
	
	tokens						: HugeStringArray;
	inactiveIds					: StringArray;
	releaseIdArray				: RealArray;
	resultArray					: HugeStringArray;
	resultArray2				: HugeStringArray;
	priorityArray				: StringArray;
	testCaseNameArray			: HugeStringArray;
	dummyArray					: StringArray;
	
	allFiles					: FileNodeArray;
	
	iter						: Iterator;

	directoryName				: String;
	line						: String;
	lastId						: String;
	activeFlag					: Integer;
	releaseIdStr				: String;
	posUnderscore				: Integer;
	posComma					: Integer;
	testCaseName				: String;
	externalId					: String;
	testSuite					: String;
	index						: Integer;
	indexOf						: Integer;
	priority					: String;
	lastExecution				: String;
	testCaseName2				: String;
	releaseIdHdrStr				: String;
	results						: String;
	notLessThanThisIndex		: Integer;
	lastRun						: String;
	lastRunIndex				: Integer;
	lastRunResult				: String;
	suiteName					: String;
	suiteName2					: String;
	needsAttention				: String;
	includeThisRun				: String;
	indexOf2					: Integer;
	tempStr						: String;
	tempStr2					: String;
	posFirstDblQuote			: Integer;
	posNextDblQuote				: Integer;
	posColon					: Integer;

begin

	// initialisations
	delete testCaseDict;
	create testCaseDict transient;
	testCaseDict.setMembership(HugeStringArray);
	testCaseDict.addExternalKey(String, 150, false, false);			// suite  name
	testCaseDict.addExternalKey(String, 150, false, false);			// test name
	testCaseDict.endKeys(false);
	
	directoryName := "C:\TestLink_Additional\results";
	
	/*******************************************************************
	* get the inactive tests
	*******************************************************************/
	write 'Getting inactive test details.  Please wait...';
	create tokens transient;
	create inactiveIds transient;
	create priorityArray transient;
	create testCaseNameArray transient;
	create dummyArray transient;
	
	delete file;
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := directoryName &amp; "\inactiveTests.csv";
	
	while not file.endOfFile do
		line := file.readLine();
		
		if line.trimBlanks().length() = 0 then
			continue;
		endif;
		
		tokens.clear();
		line.getHugeTokensForDelimiter(",", tokens);
		
		if lastId = null then
			lastId := tokens[1];
			activeFlag := tokens[tokens.size].Integer;
		endif;
		
		if lastId &lt;&gt; tokens[1] then
			if not inactiveIds.includes("01-" &amp; lastId) and activeFlag = 0 then
				inactiveIds.add("01-" &amp; lastId);
			endif;
			lastId := tokens[1];
		endif;
		
		activeFlag := tokens[tokens.size].Integer;
		
	endwhile;
	file.close();
	
	// get the files we are going to get details for
	// read through the csv files
	write 'Getting release id(s) from available files.  Please wait...';
	create fileFolder transient;
	fileFolder.fileName := directoryName;
	fileFolder.mask := "resultsTC_*.csv";
	if not fileFolder.isValidPathName(fileFolder.fileName) or not fileFolder.isAvailable() then
		write "Unable to find directory (" &amp; fileFolder.fileName &amp; ")";
		return;
	endif;

	// get the files in the directory
	allFiles := fileFolder.files();
	
	// get the release ids
	releaseIdHdrStr := null;
	create releaseIdArray transient;
	foreach fileNode in allFiles do
	
		// don't care about directory's
		if not fileNode.isKindOf(File) then
			continue;
		endif;
	
		posUnderscore := fileNode.fileName.reversePos("_");
		posComma := fileNode.fileName.reversePos(".");
		releaseIdStr := fileNode.fileName[posUnderscore+1:posComma-posUnderscore-1];
		releaseIdStr := releaseIdStr.replaceString(".", "");
		releaseIdArray.add(releaseIdStr.Real);
	
	endforeach;
	releaseIdArray.cnEcSort(true);
	notLessThanThisIndex := 8;
	foreach index in 1 to releaseIdArray.size do
		if releaseIdHdrStr &lt;&gt; null then
			releaseIdHdrStr := releaseIdHdrStr &amp; ",";
		endif;
		line := "00" &amp; releaseIdArray[index].String;
		tempStr := line[1:3] &amp; "." &amp; line[4:3] &amp; "." &amp; line[7:3];
		if line.length &gt; 9 then
			tempStr := tempStr &amp; "." &amp; line[10:end];
		endif;
		releaseIdHdrStr := releaseIdHdrStr &amp; tempStr;
	endforeach;
	
	/*******************************************************************
	* create and load the test project xml docuemnt
	*******************************************************************/
	write 'Getting active test details.  Please wait...';
	create xmlDoc transient;
	xmlDoc.parseFile(directoryName &amp; "\Master Terminal.xml");
	
	// get the test suite elements
	create testCaseXMLArray transient;
	xmlDoc.getElementsByTagName('testcase', testCaseXMLArray);
	
	foreach elementTestCase in testCaseXMLArray do
				
		// get the test case id
		xmlElement := elementTestCase.getElementByTagName("externalid");
		externalId := null;
		if xmlElement &lt;&gt; null then
			xmlCDATA := xmlElement.childNodes.first.JadeXMLCDATA;
			externalId := xmlCDATA.data.String;
		endif;
			
		// if in the ignore list then don't need to process any further
		if inactiveIds.includes("01-" &amp; externalId) then				
			continue;
		endif;		
		
		// get the test case name
		testCaseName := null;
		xmlAttribute := elementTestCase.getAttributeByName("name");
		if xmlAttribute.value = null then
			continue;
		endif;
		testCaseName := xmlAttribute.value.String.trimBlanks();
		
		// get the test suite details for the test
		xmlElement := elementTestCase;
		testSuite := null;
		while true do
			xmlElement := xmlElement.parentElement;
			if xmlElement = null then
				break;
			endif;
			xmlAttribute := xmlElement.getAttributeByName("name");
			if xmlAttribute &lt;&gt; null and xmlAttribute.value &lt;&gt; null then
				testSuite := xmlAttribute.value.String &amp; "/" &amp; testSuite.trimBlanks();
			endif;
		endwhile;
		testSuite := testSuite[1:testSuite.length-1].trimBlanks();
		
		testCaseName := testCaseName.replaceString(",", " ").trimBlanks();
		create resultArray transient;
		create resultArray2 transient;
		foreach index in 1 to releaseIdArray.size step 1 do
			resultArray.add(null);
		endforeach;
		tempStr := ("01-" &amp; externalId &amp; ":" &amp; testCaseName)[1:150].trimBlanks();
		testCaseDict.putAtKey(testSuite[1:150], tempStr, resultArray);
		///write "****XML LOAD****" &amp; tempStr;
		testCaseNameArray.add(tempStr);
		priorityArray.add("");
		
	endforeach;
	testCaseXMLArray.clear();
	delete xmlDoc;
	
	/*******************************************************************
	* read thorugh the results file(s)
	*******************************************************************/
	write 'Reading through all test results.  Please wait...';
	foreach fileNode in allFiles do
	
		// don't care about directory's
		if not fileNode.isKindOf(File) then
			continue;
		endif;
		
		// get the release id and it's index
		posUnderscore := fileNode.fileName.reversePos("_");
		posComma := fileNode.fileName.reversePos(".");
		releaseIdStr := fileNode.fileName[posUnderscore+1:posComma-posUnderscore-1];
		releaseIdStr := releaseIdStr.replaceString(".", "");
		indexOf := releaseIdArray.indexOf(releaseIdStr.Real);
		
		// read through the file and update the appropriate record
		delete file;
		create file transient;
		file.kind := File.Kind_Unknown_Text;	
		file.fileName := fileNode.fileName;
		
		line := null;
		file.readLine();
		while not file.endOfFile do
		
			line := file.readLine;
			
			// need to check to see if there are any " in the line and sort any commas between then out
			posFirstDblQuote := 1;
			posFirstDblQuote := line.pos('"', posFirstDblQuote);
			if posFirstDblQuote &gt; 0 then
				tempStr := line[1:posFirstDblQuote-1];
				while posFirstDblQuote &gt; 0 do
					
					posNextDblQuote := posFirstDblQuote + 1;
					posNextDblQuote := line.pos('"', posNextDblQuote);
					
					tempStr2 := line[posFirstDblQuote:posNextDblQuote-posFirstDblQuote+1];
					tempStr2 := tempStr2.replaceString(",", " ");
					tempStr := tempStr &amp; tempStr2;
					
					posFirstDblQuote := posNextDblQuote + 1;
					posFirstDblQuote := line.pos('"', posFirstDblQuote);
				endwhile;
				tempStr := tempStr &amp; line[posNextDblQuote+1:end];
				tempStr := tempStr.replaceString('"', "");
				line := tempStr;
			endif;
			
			tokens.clear();
			line.getHugeTokensForDelimiter(",", tokens);
			
			suiteName := tokens[1].trimBlanks(); 
			suiteName := suiteName.replaceString(",", "");
			testCaseName := tokens[2].trimBlanks();
			testCaseName := testCaseName.replaceString(",", "");
			posColon := 1;
			tempStr := testCaseName.scanUntil(":", posColon) &amp; ":";
			if testCaseName[posColon+1:1] = " " then
				testCaseName := tempStr &amp; testCaseName[posColon+2:end];
			endif;
			lastExecution := tokens[tokens.size];
			index := 1;
			lastExecution := lastExecution.scanUntil("[", index).trimBlanks();
			priority := tokens[3];
	
			//if testCaseName.cnContains("01-1131") then
			//	write 'lets debug';
			//endif;
	
			// check the testcase dict and update the appropriate resultArray object
			delete iter;
			iter := testCaseDict.createIterator;
			testCaseDict.startKeyLeq(suiteName, testCaseName, iter);
			while iter.next(resultArray) do
			
				testCaseDict.getIteratorKeys(suiteName2, testCaseName2, iter);
				///write Tab &amp; suiteName &amp; Tab &amp; suiteName2 &amp; Tab &amp; testCaseName &amp; Tab &amp; testCaseName2;
				if suiteName2 &lt;&gt; suiteName or testCaseName2 &lt;&gt; testCaseName then
					break;
				endif;
				
				// update the resultArray
				resultArray[indexOf] := lastExecution;
				indexOf2 := testCaseNameArray.indexOf(testCaseName);
				///write '****File Load****' &amp; testCaseName &amp; Tab &amp; indexOf2.String;
				if indexOf2 &gt; 0 then
					priorityArray[indexOf] := priority;
				endif;			
				
				break;
			
			endwhile;
		
		endwhile;
		
	endforeach;
	file.close();
	
	/*******************************************************************
	* Ouptut the details to file
	*******************************************************************/
	write 'Outputing Test Case Details.  Please wait...';
	delete file;
	create file transient;
	file.mode := File.Mode_Output;
	file.fileName := directoryName &amp; "\TestCaseDetails.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("Test Case,ID,Priority,Last Run,Last Run Result,Needs Attention,Include This Run,No Longer Required,Done," &amp; releaseIdHdrStr);
	
	delete iter;
	iter := testCaseDict.createIterator;
	while iter.next(resultArray) do
	
		results := null;
		lastRun := null;
		lastRunIndex := null;
		lastRunResult := null;
		needsAttention := null;
		includeThisRun := null;
		indexOf2 := null;
	
		testCaseDict.getIteratorKeys(suiteName, testCaseName, iter);
		
		foreach index in 1 to resultArray.size step 1 do
			results := results &amp; resultArray[index] &amp; ",";
			if resultArray[index] &lt;&gt; null then
				line := "00" &amp; releaseIdArray[index].String;
				tempStr := line[1:3] &amp; "." &amp; line[4:3] &amp; "." &amp; line[7:3];
				if line.length &gt; 9 then
					tempStr := tempStr &amp; "." &amp; line[10:end];
				endif;
				if lastRun = null then
					lastRun := tempStr;
					lastRunIndex := index;
					lastRunResult := resultArray[index];
				endif;
			endif;
		endforeach;
		
		// work out whether test needs attention
		write suiteName &amp; "," &amp; testCaseName &amp; "," &amp; priority &amp; "," &amp; lastRun &amp; "," &amp; 
			lastRunResult &amp; "," &amp; needsAttention &amp; "," &amp; includeThisRun &amp; Tab &amp; lastRunIndex.String &amp; Tab &amp; 
			notLessThanThisIndex.String;
		if lastRunIndex = 0 then
			needsAttention := "Y";
		elseif lastRunIndex &lt; notLessThanThisIndex and lastRunResult &lt;&gt; "Passed" then
			needsAttention := "Y";
		elseif lastRunIndex &gt; notLessThanThisIndex then
			needsAttention := "Y";
		endif;
		
		indexOf2 := testCaseNameArray.indexOf(testCaseName);
		////write "**testCaseName**" &amp; Tab &amp; testCaseName &amp; Tab &amp; indexOf2.String;
		if indexOf2 &gt; 0 then
			priority := priorityArray[indexOf2];
			if priority = "High" then
				needsAttention := null;
				includeThisRun := "Y";
			endif;
		endif;
	
		// write the line to the file
		file.writeLine(suiteName &amp; "," &amp; testCaseName &amp; "," &amp; priority &amp; "," &amp; lastRun &amp; "," &amp; 
			lastRunResult &amp; "," &amp; needsAttention &amp; "," &amp; includeThisRun &amp; ",,," &amp; results );
		write suiteName &amp; "," &amp; testCaseName &amp; "," &amp; priority &amp; "," &amp; lastRun &amp; "," &amp;
			lastRunResult &amp; "," &amp; needsAttention &amp; "," &amp; includeThisRun &amp; ",,," &amp; results ;
	
	endwhile;
	file.close();

epilog

	delete file;
	
	delete tokens;
	delete inactiveIds;
	delete releaseIdArray;
	delete xmlDoc;
	delete testCaseDict;
	delete testCaseXMLArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTestSomethingB" id="31231915-7b19-4348-a4d9-5a1d18174cb1">
        <source>mdhTestSomethingB();

