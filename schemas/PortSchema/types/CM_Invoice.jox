        <source>setMyInvoiceProcess( _invoiceProcess : CM_InvoiceProcess ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jan 2021	jlgndl1	Initial creation	TFS 50600
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars

	invProcess : CM_InvoiceProcess;

begin

	invProcess := _invoiceProcess;
	
	if invProcess = null then
		invProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessDefault];	//05.06.2025 navma1 #MTN-34114;
	endif;

	if self.myInvoiceProcess &lt;&gt; invProcess then
		self.myInvoiceProcess := invProcess;
	endif;

epilog

end;</source>
