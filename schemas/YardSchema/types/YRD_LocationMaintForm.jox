// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.mySDF.myVLabels.width := 40;
	self.mySDF.myVLabels.top := 5;
	self.mySDF.myHLabels.height := 25;
	self.mySDF.myTopLeftFillerFrame.visible := true;
	
	self.mySDF.left := 0;
	self.mySDF.top := 0;
	self.mySDF.allGridAreasByColumnRow.clear;
	self.mySDF.allGridAreasByRowColumn.clear;
	self.mySDF.caption := "";

end;</source>
