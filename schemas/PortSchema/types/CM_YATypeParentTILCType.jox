    <JadeMethod name="isCMIFDataMatch" id="8cccd7fc-d49a-4d1a-920f-c941d180d8a1">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2024	jlier1	Initial creation 63834

*/

vars

begin
	return _cmifAutoPlan.isParentTrailerType_Match(_yaData);

epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
