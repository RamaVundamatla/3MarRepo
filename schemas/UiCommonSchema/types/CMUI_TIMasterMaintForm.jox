    <JadeMethod name="doSave" id="296f1c20-da36-4393-bea3-009a118bfa0e">
        <updating/>
        <source>doSave() : Boolean protected, updating;
// -------------------------------------------
// Created 09 December 2005 by cnwdvb1
// -------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 12/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 06/03/2014	cnwdap1		PAR #33638 Correct Tare Weight field
// 27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
// 15/05/2025	navcs2	MTN-34843  Development - Fleet file Form implementation
vars
	realMaster,
	pxyMaster		: CM_TIMasterTILC;
	id,
	description		: String;
	licenseIssuer	: String;
	licenseNumber	: String;
	operator 		: CM_Operator;
	owner	 		: CM_Operator;
	tILCType		: CM_TILCType;
	//tareWeight	: Integer;						// PAR #31155
	tareWeight		: Decimal [23,10];				// PAR #31155
	allStopTables 	: CM_StopsTableByIdDict;
	allToDoTasks 	: CM_ToDoTaskDescByCode;
	result			: Integer;
	errors 			: String;
	damage			: CM_DamageInstance;
	objectArray		: CM_ObjectArray;
	offHireDate		: Date;
	onHireDate		: Date;
	remarks			: String;
	weightType		: CM_MeasurementType;			// PAR #31155
	generatorMaster : CM_TIMaster;
	floorType		: Integer;						// 15/05/2025	navcs2	MTN-34843
begin
	
	beginLoad;
	if self.isEdit then
		pxyMaster := app.createUpdateProxy(self.myTiMaster).CM_TIMasterTILC;
	else
		create pxyMaster transient;
	endif;
	endLoad;
	
	id :=self.txtID.text;
	description :=self.txtDescription.text;

	licenseIssuer	:= self.txtLicenceIssuer.text;
	licenseNumber	:= self.txtLicenceNo.text;
	
	if cmbOperator.listIndex &gt; 0 then
		operator := self.cmbOperator.itemObject[cmbOperator.listIndex].CM_Operator;
	endif;
	
	if cmbOwner.listIndex &gt; 0 then
		owner := self.cmbOwner.itemObject[cmbOwner.listIndex].CM_Operator;
	endif;
	
	if cmbTILCType.listIndex &gt; 0 then
		tILCType := self.cmbTILCType.itemObject[cmbTILCType.listIndex].CM_TILCType;
	endif;
	
	if cmbGenerators.listIndex &gt; 0 then  //27.02.2018 cnwma1 ChangeRequest #36813
		generatorMaster := self.cmbGenerators.itemObject[cmbGenerators.listIndex].CM_TIMaster;
	endif;
	
	floorType := self.cmbFloorType.getCurrentItemData; // 15/05/2025	navcs2	MTN-34843
	
	//weightType := app.getDefaultMeasurementForType(Type_Weight);										// PAR #31155	// PAR #33638
	//tareWeight := self.txtWeight.text.Integer;														// PAR #31155	// PAR #33638
	//tareWeight := app.convertMeasurementForStorage(weightType.shortName, self.txtWeight.text.Decimal);// PAR #31155	// PAR #33638
	tareWeight := self.txtWeight.getConvertedValue();																	// PAR #33638
	
	create allStopTables transient;
	self.lstTblStops.allSelectedObjects.copy(allStopTables);
	
	create allToDoTasks transient;
	self.lstTblToDoTasks.allSelectedObjects.copy(allToDoTasks);
	
	//+cnwml2 MSL CCMS 1027
	offHireDate := self.dateOffHire.text.asDateJMT();
	onHireDate := self.dateOnHire.text.asDateJMT();
	remarks := self.txtRemarks.text;
	
	create objectArray transient;
	pxyMaster.setForProxyMasterTILC( id, description,app.myRoot,licenseIssuer, licenseNumber, tareWeight, tILCType, operator, owner ,  
									allStopTables, allToDoTasks, offHireDate, onHireDate, remarks,generatorMaster, floorType ); //27.02.2018 cnwma1 ChangeRequest #36813		// 15/05/2025	navcs2	MTN-34843
	if self.isDamageFormInitialised then
		foreach damage in pxyMaster.allDamageInstancesByPos do
			if not self.allDamageInstancesByPos.includes(damage) then
				delete damage;  //cnwjo3 par 21463
				objectArray.add(damage);
			endif;
		endforeach;
	endif;
	self.setDamageParent(pxyMaster);
	
	if pxyMaster = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
		return false;
	endif;
	
	while true do
		if not self.isEdit then
			app.myTrxCA.trxCreateTIMasterTILC( pxyMaster, realMaster, app.myPassport );
		else
			app.myTrxUA.trxUpdateTIMasterTILC(pxyMaster, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then	
			result := app.showErrorWarningDialog('Create Master Item', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			self.setAllErrorWarnings(app.myPassport);	
			if app.myPassport.noErrors and  result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		else
			self.clearErrorWarnings();
			if self.isEdit then				
			else
				self.myTiMaster := realMaster;
			endif;
			
			self.myParentForm.CMUI_TIMasterForm.setMyCurrentTiMaster( self.myTiMaster );
			self.btnDamage.enabled := true;	// cnwrd1 par 20799 27/10/09
			return true;
		endif;
		break;
	endwhile;
	
	return false;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	pxyMaster.allDamageInstancesByPos.purge();
	delete pxyMaster;	
	objectArray.purge();
	delete objectArray;
	self.allDamageInstancesByPos.purge();
end;

</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
