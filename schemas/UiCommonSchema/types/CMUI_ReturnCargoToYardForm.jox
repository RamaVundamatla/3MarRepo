    <JadeMethod name="doSave" id="4dee29be-2f58-4c74-a0ac-5df1caeec88e">
        <updating/>
        <source>doSave() : Boolean updating, protected;
//------------------------------------------------
// Created: 08 May 2006 By: cnwgd1
// Edited: 10 July 2012 By: cnwmc5 - par 29306
//------------------------------------------------
vars
	obj : Object;
	tiArray : CM_TIArray;
	rtnValue : Boolean;
	result : Integer;
	tmpTI : CM_TrackedItem;
	tmpSlot : CM_SlotController;
	tmpRORO : CM_VoyageROROController;
	theJobParams : CMIF_VoyageJobParams;
begin
	
	create tiArray transient;
	create theJobParams transient;
	theJobParams.isDischarge 	:= true;
	theJobParams.useNewMethod 	:= true;
	theJobParams.isExportReturn := true;
	theJobParams.isAutoplan 	:= self.ckbAutoplan.value;
	theJobParams.isChargable 	:= self.ckbChargeable.value;
	theJobParams.id 			:= self.txtJobId.text.trimBlanks.toUpper;
	theJobParams.myVoyage 		:= self.myVoyage;	
	
	if CM_Crane.hasInstance(self.cmbCranes.listObject) then
		theJobParams.craneID :=	self.cmbCranes.listObject.CM_Crane.id;
	endif;
	if CM_WorkPoint.hasInstance(self.cmbCranes.listObject) then
		theJobParams.craneID 		:= self.cmbCranes.listObject.CM_WorkPoint.code;
		theJobParams.myWorkPoint	:= self.cmbCranes.listObject.CM_WorkPoint;
		theJobParams.resquence		:= true;
		theJobParams.isSeqForJob	:= false;
	endif;
		
	foreach obj in self.tblData.allSelectedObjects do
		tmpTI := obj.CM_TrackedItem;
		if CM_SlotController.hasInstance(tmpTI.myPrimaryActualLocation) then
			tmpSlot := tmpTI.myPrimaryActualLocation.CM_SlotController;
			tiArray.add(tmpTI);
			if (not theJobParams.allSlotControllers.includes(tmpSlot)) then
				theJobParams.allSlotControllers.add(tmpSlot);
				theJobParams.allObjectEditions.add(tmpSlot);
			endif;
		elseif CM_VoyageROROController.hasInstance(tmpTI.myPrimaryActualLocation) then
			tmpRORO := tmpTI.myPrimaryActualLocation.CM_VoyageROROController;
			theJobParams.myDeck				:= tmpRORO.myDeck;
			tiArray.add(tmpTI);
			if (not theJobParams.allROROControllers.includes(tmpRORO)) then
				theJobParams.allROROControllers.add(tmpRORO);
				theJobParams.allObjectEditions.add(tmpRORO);
			endif;
		endif;
	endforeach;
	
	if tiArray.isEmpty() then
//		app.msgBox('Please select cargo to return.', 'Select Cargo', MsgBox_OK_Only+MsgBox_Stop_Icon);
		app.msgBox(app.getErrorString(Please_select_cargo_return), app.getErrorString(Select_cargo), MsgBox_OK_Only+MsgBox_Stop_Icon);
		
		return false;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateReturnCargoToYard(theJobParams, tiArray, app.myPassport);		
		if app.myPassport.trxCompletedOK then
			rtnValue := true;
			break;
		else
//			result := app.showErrorWarningDialog('Return Cargo To Yard', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			result := app.showErrorWarningDialog(app.getErrorString(Return_cargo_yard), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;	
	return rtnValue;

epilog
	delete theJobParams;
	delete tiArray;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="e2339c1a-f7a8-44cf-9eb7-15ad17626447">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//------------------------------------------------
// Created: 08 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	inheritMethod();
	
	self.tblData.displayRowsForCollection(self.allTrackedItems, self.colorRow1, self.colorRow2, app.myPassport);
	self.tblData.selectAll();
	
	if self.myVoyage &lt;&gt; null then
		self.myVoyage.getAllCranes(self.allCranesForVoyage);
		self.myVoyage.getAllWorkPoints(self.allWorkPointsForVoyage);	//par 29306 - cnwmc5
		self.setCaption(self.caption &amp; ' ' &amp; self.myVoyage.getDisplayDetails(false));
	endif;
	
	
	//par 29306 - cnwmc5
	if self.isRORO = true then
		lblCranes.caption := app.getErrorString(Work_point) &amp; ":";
		self.cmbCranes.listCollection(self.allWorkPointsForVoyage, false, null);
	else
		lblCranes.caption := app.getErrorString(CM_Crane_GC) &amp; ":";
		self.cmbCranes.listCollection(self.allCranesForVoyage, false, null);
	endif;
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="219e6009-3f6b-47c8-9b73-64dd8b138f88">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//------------------------------------------------
// Created: 08 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	self.tblData.rows := self.tblData.fixedRows;
	self.tblData.displayRowsForCollection(self.allTrackedItems, self.colorRow1, self.colorRow2, app.myPassport);
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f4e883ae-b1bb-4170-9bd3-95e987da1594">
        <updating/>
        <source>setupForm() updating;
//------------------------------------------------
// Created: 08 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	inheritMethod();
	self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_ReturnCargoToYard));
	self.tblData.userInputEnabled := false;
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	self.tblData.selectionType := CM_DataTable.SelectionType_Row;
	self.tblData.multiSelect := self.tblData.MultiSelect_Simple;
	self.setColorsForTable(self.tblData);
	
	self.cmbCranes.setFocus();
//	self.btnOk.top := self.btnPrint.top;
//	self.btnCancel.top := self.btnPrint.top;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0e27e9b8-4af2-4e36-8f6e-9854c82659a8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008060, locale);
	btnPrint.translateCaption(Xlat_0000816, locale);
	ckbAutoplan.translateCaption(Xlat_0000814, locale);
	ckbChargeable.translateCaption(Xlat_0000813, locale);
	lblCranes.translateCaption(Xlat_0000815, locale);
	lblJobId.translateCaption(Xlat_0000817, locale);
end;</source>
    </JadeMethod>
</GUIClass>
