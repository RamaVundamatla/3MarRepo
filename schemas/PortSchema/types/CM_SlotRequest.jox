    <JadeMethod name="getOOWDesc" id="07f0de25-f75a-4474-a677-1f50fc019558">
        <source>getOOWDesc(): String;
//----------------------------------------------------------------
//	Created:	05 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	returnVal	: String;
	invalid 	: Boolean;
	commGrp		: CM_CommodityGroup;
	port		: CM_Port;
	
begin
	// PAR 16415 CCMS 1029
	if self.getAttrIs53() then
		returnVal := "53";
	elseif self.getAttrIs30() then
		returnVal := "30";
	elseif self.getAttrIs45() then
		returnVal := "45";
	elseif self.getAttrIs40() then
		returnVal	:=	"40'";
	else
		returnVal	:=	"20'";
	endif;
	
	if self.myTerminal.getConfig(OOWUseSimpleNonPlanned).Boolean then
		returnVal	:=	returnVal &amp; self.getSimpleLabel();
	else
		commGrp := self.getAttrCommodityGroup();
		if commGrp &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, commGrp, invalid);
			returnVal := returnVal &amp; commGrp.code;
			on Exception do null;
		endif;
	endif;
	
	port := self.getAttrDischargePort();
	if port &lt;&gt; null then
		returnVal	:=	returnVal &amp; ' ' &amp; port.code.padBlanks(5);
	endif;
	
	return returnVal;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPlannersGroup" id="f0326432-7d78-4af0-9efd-d9fa5ca937d0">
        <source>getPlannersGroup(): String;
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
// Note:	This method is used to create a key which is used
//			to group items on Load List Summary screen
//
/*

Date		Who		Reason
02 Jun 2010	cnwkpd1	PAR #21621 - rewrite to use new constants, and to allow for Flats, OpenTop, etc 
					to be separated out into empty and full

*/

vars
	group			: Integer;
	cargoTyp		: CM_CargoType;
	isGen : Boolean; // PAR 34143
begin
	group := null;
	
	//cnwjo3 par 24993
	if self.useVoyageAllocations then
		return self.getVoyageAllocationGroupKey();
	else
		cargoTyp := self.getAttrCargoType();
		if cargoTyp = null or cargoTyp.id = TI_CargoType_Container then
			// First get length sorted
			if self.getAttrIs40() then	
				group := PlanningGroup_FortyFoot;
			elseif self.getAttrIs30() then
				group := PlanningGroup_ThirtyFoot;
			elseif self.getAttrIs45() then
				group := PlanningGroup_FortyFiveFoot;
			elseif self.getAttrIs53() then
				group := PlanningGroup_FiftyThreeFoot;
			else
				group := PlanningGroup_TwentyFoot;
			endif;
		
			// Now check special attributes
			if self.getAttrFlatRack() then
				group := group + PlanningGroup_FlatRack;
			elseif self.getAttrCrib() then
				group := group + PlanningGroup_Crib;
			elseif self.getAttrFrame() then	//05 Feb 2018	NDL	TFS 36752
				group := group + PlanningGroup_Frame;
			elseif self.getAttrTank() then
				group := group + PlanningGroup_Tank;
			elseif self.getAttrOpenTop() then
				group := group + PlanningGroup_OpenTop;
			elseif self.getAttrFantainer() then
				group := group + PlanningGroup_Fantainer;
			else
				isGen := true;
			endif;
			
			// Now empty or power
			if self.getAttrEmpty() then
				group := group + PlanningGroup_Empty;
			elseif self.getAttrPowerRequired() then
				group := group + PlanningGroup_PowerRequired;
			elseif isGen then // PAR 34184
				group := group + PlanningGroup_General; // PAR 34184
			endif;
			
			// Finally High Cube
			if self.getAttrHiCubed() then
				group := group + PlanningGroup_HighCube;
			endif;
		
		else
			// Non-container cargo, so sort to the end, with System-defined types before
			// User-defined types
			group := cargoTyp.id;
			if group &lt; TI_CargoBOLType_Max then
				group := TI_CargoBOLType_Max - group;
			endif;
		endif;		
	endif;

	return group.String.padLeadingZeros(5).truncatedAt(5);		// Allow for extreme cargoType id values
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPlannersGroupDesc" id="dda5fde7-481e-428d-9967-444a7e70d781">
        <source>getPlannersGroupDesc(): String;
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
// Note:	This method is used to display a description (or code) which
//			matches up with the key created in getPlannersGroup
//
/*

Date		Who		Reason
02 Jun 2010	cnwkpd1	PAR #21621 - rewrite to use new constants, and to allow for Flats, OpenTop, etc 
					to be separated out into empty and full

*/

vars
	isGen			: Boolean;
	groupDesc		: String;
	cargoTyp		: CM_CargoType;

begin
	groupDesc := null;
	
	//cnwjo3 par 24993
	if self.useVoyageAllocations then
		groupDesc := self.getVoyageAllocationGroupDesc();
	else
		cargoTyp := self.getAttrCargoType();
		if cargoTyp = null or cargoTyp.id = TI_CargoType_Container then
	
			// First get length sorted
			if self.getAttrIs40() then	
				groupDesc := app.getErrorString(FortyFoot);
			elseif self.getAttrIs30() then
				groupDesc := app.getErrorString(ThirtyFoot);
			elseif self.getAttrIs45() then
				groupDesc := app.getErrorString(FortyFiveFoot);
			elseif self.getAttrIs53() then
				groupDesc := app.getErrorString(FiftyThreeFoot);
			else
				groupDesc := app.getErrorString(TwentyFoot);
			endif;
		
			// Now check special attributes
			if self.getAttrFlatRack() then
				groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_FlatRack);
			elseif self.getAttrCrib() then
				groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Crib);
			elseif self.getAttrFrame() then		//05 Feb 2018	NDL	TFS 36752
				groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Frame);
			elseif self.getAttrTank() then
				groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Tank);
			elseif self.getAttrOpenTop() then
				groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_OpenTop);
			elseif self.getAttrFantainer() then
				groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Fantainer);
			else
				isGen := true;
			endif;
			
			// Now empty or power
			if self.getAttrEmpty() then
				groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Empty);
			elseif self.getAttrPowerRequired() then
				groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Integral);
			elseif isGen then
				groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_General);
			endif;
			
			// Finally High Cube
			if self.getAttrHiCubed() then
				groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_HighCube);
			endif;
			
		else
			// Non-container cargo, so use Cargo Type Description
			groupDesc := cargoTyp.description;
		endif;
	endif;
	
	return groupDesc.truncatedAt(30);


epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPlanningGuide" id="aa6b66e2-9bc3-463d-9820-ef4c185eef44">
        <source>getPlanningGuide(guide : CMIF_PlanningGuideBay input; use40Id : Boolean; colourCodeType : Integer);
/*
------------------------------------------------------------------------
Created:			21 November 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	wleSize : Integer;
begin
	
	if self.unavailable then
		return;	//ignore any that are unavailable
	endif;
	
	if self.mySlotDefinition &lt;&gt; null and self.mySlotDefinition.unavailable then
		return;
	endif;
	// PAR 21746  if self.fortyBack then
	if self.getAttrIsBackend() then // PAR 21746
		return;	//ignore any back ends
	endif;
	if use40Id and guide.is40Bay and not(self.getAttrIs40()) then // looking for 40's I am a request for a 20
		return;
	elseif use40Id and not(guide.is40Bay) and self.getAttrIs40() then // looking for 20's I am a request for a 40
		return;
	endif;
	if self.moveType = NULL_MOVETYPE then
		return;
	endif;
	
	// PAR 7072 changed to locale variable incase it was empty.
	wleSize := self.allWorkListEntries.size;
	if wleSize = 0 then
		wleSize := 1;
	endif;
	
	if self.moveType = DISCHARGE_MOVETYPE then
		if self.ordinalDeck = DeckOnDeck then
			guide.dischargeImportOD := guide.dischargeImportOD + wleSize;
		else
			guide.dischargeImportUD := guide.dischargeImportUD + wleSize;
		endif;
		
	elseif self.moveType = LOAD_MOVETYPE then
		if self.ordinalDeck = DeckOnDeck  then
			guide.loadExportOD := guide.loadExportOD + wleSize; // for LOAD these WLEs may be empty but they will exist
		else
			guide.loadExportUD := guide.loadExportUD + wleSize;
		endif;
		
	elseif self.isSOB then
		if colourCodeType = DISCHARGE_COLOURCODE then
			if self.ordinalDeck = DeckOnDeck  then
				guide.dischargeSOBOD := guide.dischargeSOBOD + wleSize;
			else
				guide.dischargeSOBUD := guide.dischargeSOBUD + wleSize;
			endif;
		endif;
	
	elseif self.isRehandle then
		if colourCodeType = DISCHARGE_COLOURCODE then
			if self.ordinalDeck = DeckOnDeck  then
				guide.dischargeDLROD := guide.dischargeDLROD + wleSize;
			else
				guide.dischargeDLRUD := guide.dischargeDLRUD + wleSize;
			endif;
		else
			//Load Colour Code
			if self.ordinalDeck = DeckOnDeck  then
				guide.loadDLROD := guide.loadDLROD + wleSize; // for LOAD these WLEs may be empty but they will exist
			else
				guide.loadDLRUD := guide.loadDLRUD +  wleSize;
			endif;
		endif;	
	endif;
end;</source>
        <Parameter name="guide" type="CMIF_PlanningGuideBay" usage="input"/>
        <Parameter name="use40Id" type="Boolean"/>
        <Parameter name="colourCodeType" type="Integer"/>
    </JadeMethod>
