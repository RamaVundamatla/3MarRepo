<Class name="CM_AuditLineMerged" id="ff6ec4d5-9cf4-4ce0-9ea3-e8322eea4389">
    <superclass name="CM_Audit"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
