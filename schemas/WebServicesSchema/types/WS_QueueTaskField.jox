    <JadeMethod name="setProxyFromObject" id="23ffbb48-806e-49f0-8fc8-30a1796ba0dc">
        <updating/>
        <source>setProxyFromObject(_object: EntTableRow ) updating;
/*

Date		Who		Reason
20 June 2017	cnwer1	Initial creation TFS

*/

vars
	locale : CM_Locale;
begin
	inheritMethod(_object);

	locale:=app.getMyUser().getLocale();
	//jlier1 TFS 52595 21/12/21
	self.heading:=_object.getHeading(null,app.myPassport.myTerminal,locale);
	self.name:= _object.name;
	self.entRowNumber:=_object.number;
epilog

end;</source>
